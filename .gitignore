# Test Results
framepiler/results/
extension/results/
common/reports/

# Generated test outputs (regenerated from source by test runner)
output/

# Docker artifacts
*.log
.docker/

# Node modules (if not already ignored)
node_modules/
dist/
*.js.map
*.d.ts.map

# Python artifacts
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
*.egg-info/
.pytest_cache/

# Rust artifacts
target/
Cargo.lock

# IDE files
.vscode/
.idea/
*.swp
*.swo
*~

# OS files
.DS_Store
Thumbs.db

# Temporary files
*.tmp
*.temp
/tmp/

# Test coverage
coverage/
*.lcov
.nyc_output/

# Environment files
.env
.env.local
.env.*.local

# Build outputs (but preserve versioned binaries)
# Don't ignore common/builds/ as it contains versioned artifacts

# Log files
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Local test configurations
local.test.config
*.local.json

# Fuzz outputs (regenerated by harness scripts)
fuzz/cases_*/
fuzz/logs_*/
fuzz/out_*/
fuzz/runs_*/

# framec build artifacts (cross-compiled per session)
docker/framec-linux
docker/framec-native

# Stray compiled test binaries (should not be checked in)
docker/[0-9]*_*

# Scratch / working notes (per-session, not for the public repo)
_scratch/

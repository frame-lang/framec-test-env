@@[target("go")]

package main

import "fmt"
import "os"


@@system Stress_st_p1_many_dispatches__full {
    interface:
        Bump()
        Get_f(): int

    machine:
        $S0 {
            Bump() {
                s.f = s.f + 1
            }
            Get_f(): int { @@:(s.f) }
        }

    domain:
        f: int = 0
}


func _fail(msg string) { fmt.Println("FAIL: " + msg); os.Exit(1) }

func main() {
    sm := NewStress_st_p1_many_dispatches__full()
    sm.Bump()
    sm.Bump()
    sm.Bump()
    sm.Bump()
    sm.Bump()
    sm.Bump()
    sm.Bump()
    sm.Bump()
    sm.Bump()
    sm.Bump()
    sm.Bump()
    sm.Bump()

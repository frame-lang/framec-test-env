@@target go

package main

import "fmt"
import "os"


@@system Stress_st_p3_push_pop_depth__full {
    interface:
        Get_f(): int
        Go_back()
        Push_then()

    machine:
        $S0 {
            Push_then() {
                s.f = s.f + 1
                push$
                -> $S1
            }
            Go_back() {
                -> pop$
            }
            Get_f(): int { @@:(s.f) }
        }
        $S1 {
            Push_then() {
                s.f = s.f + 1
                push$
                -> $S0
            }
            Go_back() {
                -> pop$
            }
        }

    domain:
        f: int = 0
}


func _fail(msg string) { fmt.Println("FAIL: " + msg); os.Exit(1) }


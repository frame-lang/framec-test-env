@@target java


@@system Arith_ar_p4_paren_grouping__t2 {
    interface:
        drive()
        get_f(): int

    machine:
        $S0 {
            drive() {
                this.f = (0 + 7) * 0;
            }
            get_f(): int { @@:(this.f) }
        }

    domain:
        f: int = 0
}

class Driver {
    public static void main(String[] args) {
        var _inst = new Arith_ar_p4_paren_grouping__t2();
        _inst.drive();
        int _ret = (int) _inst.get_f();
        if (_ret != 0) {
            System.out.println("FAIL: expected ret=0, got " + _ret);
            System.exit(1);
        }
        System.out.println("PASS: arith");
    }
}

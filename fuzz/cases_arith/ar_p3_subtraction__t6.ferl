@@target erlang

%% FUZZ_EXPECTED_N: -50
%% FUZZ_EQUIV_CLASS: p3_subtraction
%% FUZZ_SMOKE: no
%% FUZZ_VERIFY_METHOD: get_f
%% FUZZ_PRE_DRIVE: drive

@@system Arith_ar_p3_subtraction__t6 {
    interface:
        drive()
        get_f(): int

    machine:
        $S0 {
            drive() {
                self.f = 100 - 50 - 100
            }
            get_f(): int { @@:(self.f) }
        }

    domain:
        f: int = 0
}


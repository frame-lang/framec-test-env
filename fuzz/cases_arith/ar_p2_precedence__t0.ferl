@@[target("erlang")]

%% FUZZ_EXPECTED_N: 18
%% FUZZ_EQUIV_CLASS: p2_precedence
%% FUZZ_SMOKE: yes
%% FUZZ_VERIFY_METHOD: get_f
%% FUZZ_PRE_DRIVE: drive

@@system Arith_ar_p2_precedence__t0 {
    interface:
        drive()
        get_f(): int

    machine:
        $S0 {
            drive() {
                self.f = 3 + 5 * 3
            }
            get_f(): int { @@:(self.f) }
        }

    domain:
        f: int = 0
}


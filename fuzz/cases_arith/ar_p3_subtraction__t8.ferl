@@[target("erlang")]

%% FUZZ_EXPECTED_N: 0
%% FUZZ_EQUIV_CLASS: p3_subtraction
%% FUZZ_SMOKE: no
%% FUZZ_VERIFY_METHOD: get_f
%% FUZZ_PRE_DRIVE: drive

@@system Arith_ar_p3_subtraction__t8 {
    interface:
        drive()
        get_f(): int

    machine:
        $S0 {
            drive() {
                self.f = 7 - 0 - 7
            }
            get_f(): int { @@:(self.f) }
        }

    domain:
        f: int = 0
}


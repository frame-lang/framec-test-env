@@[target("c")]


@@system Arith_ar_p2_precedence__t6 {
    interface:
        drive()
        get_f(): int

    machine:
        $S0 {
            drive() {
                self->f = 100 + 50 * 100;
            }
            get_f(): int { @@:(self->f) }
        }

    domain:
        f: int = 0
}

#include <stdio.h>
#include <stdlib.h>
int main(void) {
    Arith_ar_p2_precedence__t6* _inst = Arith_ar_p2_precedence__t6_new();
    Arith_ar_p2_precedence__t6_drive(_inst);
    int _ret = (int)(intptr_t)Arith_ar_p2_precedence__t6_get_f(_inst);
    if (_ret != 5100) {
        printf("FAIL: expected ret=5100, got %d\n", _ret);
        return 1;
    }
    printf("PASS: arith\n");
    return 0;
}

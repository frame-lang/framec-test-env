@@[target("erlang")]

%% FUZZ_EXPECTED_N: -10
%% FUZZ_EQUIV_CLASS: p2_precedence
%% FUZZ_SMOKE: no
%% FUZZ_VERIFY_METHOD: get_f
%% FUZZ_PRE_DRIVE: drive

@@system Arith_ar_p2_precedence__t1 {
    interface:
        drive()
        get_f(): int

    machine:
        $S0 {
            drive() {
                self.f = 10 + -2 * 10
            }
            get_f(): int { @@:(self.f) }
        }

    domain:
        f: int = 0
}


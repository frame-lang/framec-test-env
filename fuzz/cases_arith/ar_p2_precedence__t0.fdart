@@target dart


@@system Arith_ar_p2_precedence__t0 {
    interface:
        drive()
        get_f(): int

    machine:
        $S0 {
            drive() {
                this.f = 3 + 5 * 3;
            }
            get_f(): int { @@:(this.f) }
        }

    domain:
        f: int = 0
}


void _fail(String msg) { print("FAIL: $msg"); throw Exception(msg); }

void main() {
    final _inst = Arith_ar_p2_precedence__t0();
    _inst.drive();
    final _ret = _inst.get_f();
    if (_ret != 18) { _fail("expected ret=18, got $_ret"); }
    print("PASS: arith");
}

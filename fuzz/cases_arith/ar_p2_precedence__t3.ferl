@@[target("erlang")]

%% FUZZ_EXPECTED_N: -28
%% FUZZ_EQUIV_CLASS: p2_precedence
%% FUZZ_SMOKE: no
%% FUZZ_VERIFY_METHOD: get_f
%% FUZZ_PRE_DRIVE: drive

@@system Arith_ar_p2_precedence__t3 {
    interface:
        drive()
        get_f(): int

    machine:
        $S0 {
            drive() {
                self.f = -4 + 6 * -4
            }
            get_f(): int { @@:(self.f) }
        }

    domain:
        f: int = 0
}


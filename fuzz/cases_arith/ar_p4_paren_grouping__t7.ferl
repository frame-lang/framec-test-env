@@target erlang

%% FUZZ_EXPECTED_N: 0
%% FUZZ_EQUIV_CLASS: p4_paren_grouping
%% FUZZ_SMOKE: no
%% FUZZ_VERIFY_METHOD: get_f
%% FUZZ_PRE_DRIVE: drive

@@system Arith_ar_p4_paren_grouping__t7 {
    interface:
        drive()
        get_f(): int

    machine:
        $S0 {
            drive() {
                self.f = (-1 + 1) * -1
            }
            get_f(): int { @@:(self.f) }
        }

    domain:
        f: int = 0
}


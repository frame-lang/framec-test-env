@@target erlang

%% FUZZ_EXPECTED_N: 0
%% FUZZ_EQUIV_CLASS: p1_add_chain
%% FUZZ_SMOKE: no
%% FUZZ_VERIFY_METHOD: get_f
%% FUZZ_PRE_DRIVE: drive

@@system Arith_ar_p1_add_chain__t3 {
    interface:
        drive()
        get_f(): int

    machine:
        $S0 {
            drive() {
                self.f = -4 + 6 + -4 + 6 + -4
            }
            get_f(): int { @@:(self.f) }
        }

    domain:
        f: int = 0
}


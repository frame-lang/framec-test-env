@@[target("ruby")]


@@system Arith_ar_p1_add_chain__t3 {
    interface:
        drive()
        get_f(): int

    machine:
        $S0 {
            drive() {
                self.f = -4 + 6 + -4 + 6 + -4
            }
            get_f(): int { @@:(self.f) }
        }

    domain:
        f: int = 0
}


def _fail(msg)
  puts("FAIL: #{msg}")
  exit(1)
end

_inst = Arith_ar_p1_add_chain__t3.new
_inst.drive
_ret = _inst.get_f
_fail("expected ret=0, got #{_ret}") unless _ret == 0
puts("PASS: arith")

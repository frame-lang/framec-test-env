@@[target("erlang")]

%% FUZZ_EXPECTED_N: 1
%% FUZZ_EQUIV_CLASS: p1_comment_before_stmt
%% FUZZ_SMOKE: no
%% FUZZ_VERIFY_METHOD: get_f
%% FUZZ_PRE_DRIVE: drive

@@system Comments_cm_p1_comment_before_stmt__t7 {
    interface:
        drive()
        get_f(): int

    machine:
        $S0 {
            drive() {
                % drive bumps the domain field
                self.f = 1
            }
            get_f(): int { @@:(self.f) }
        }

    domain:
        f: int = 0
}


@@target python_3


@@system Comments_cm_p2_comment_after_stmt__t4 {
    interface:
        drive()
        get_f(): int

    machine:
        $S0 {
            drive() {
                self.f = 100
                # setting f to lit
            }
            get_f(): int { @@:(self.f) }
        }

    domain:
        f: int = 0
}


def _fail(msg):
    print(f"FAIL: {msg}")
    raise SystemExit(1)

_inst = Comments_cm_p2_comment_after_stmt__t4()
_inst.drive()
_ret = _inst.get_f()
if _ret != 100:
    _fail(f"expected ret=100, got {_ret}")
print("PASS: comments")

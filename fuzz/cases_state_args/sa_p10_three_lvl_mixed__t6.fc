int main(void) {
    StateArgs_sa_p10_three_lvl_mixed__t6* _inst = StateArgs_sa_p10_three_lvl_mixed__t6_new();
    StateArgs_sa_p10_three_lvl_mixed__t6_drive(_inst);
    int _ret = (int)(intptr_t)StateArgs_sa_p10_three_lvl_mixed__t6_get_x(_inst);
    if (_ret != -50) {
        printf("FAIL: expected ret=-50, got %d\n", _ret);
        return 1;
    }
    printf("PASS: state-args\n");

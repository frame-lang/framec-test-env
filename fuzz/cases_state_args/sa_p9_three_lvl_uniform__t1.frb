@@target ruby


@@system StateArgs_sa_p9_three_lvl_uniform__t1 {
    interface:
        drive()
        get_x(): int

    machine:
        $S0 {
            drive() {
                -> $Leaf(5)
            }
        }
        $Leaf => $Mid(x: int) {
            get_x(): int { @@:(x) }
        }
        $Mid => $Root(x: int) {
        }
        $Root(x: int) {
        }

    domain:
        f: int = 0
}


def _fail(msg)
  puts("FAIL: #{msg}")
  exit(1)
end

_inst = StateArgs_sa_p9_three_lvl_uniform__t1.new
_inst.drive
_ret = _inst.get_x
_fail("expected ret=5, got #{_ret}") unless _ret == 5
puts("PASS: state-args")
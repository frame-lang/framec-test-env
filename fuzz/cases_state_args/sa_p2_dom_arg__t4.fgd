@@[target("gdscript")]

extends SceneTree


@@system StateArgs_sa_p2_dom_arg__t4 {
    interface:
        drive()
        get_x(): int

    machine:
        $S0 {
            drive() {
                self.f = 100
                -> $S1(self.f)
            }
        }
        $S1(x: int) {
            get_x(): int { @@:(x) }
        }

    domain:
        f: int = 50
}


func _fail(msg):
    print("FAIL: " + msg)
    quit(1)

func _init():
    var _inst = StateArgs_sa_p2_dom_arg__t4.new()
    _inst.drive()
    var _ret = _inst.get_x()
    if _ret != 100:
        _fail("expected ret=100, got " + str(_ret))
    print("PASS: state-args")
    quit()
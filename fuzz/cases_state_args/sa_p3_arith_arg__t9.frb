@@[target("ruby")]


@@system StateArgs_sa_p3_arith_arg__t9 {
    interface:
        drive()
        get_x(): int

    machine:
        $S0 {
            drive() {
                -> $S1(-1 + 1)
            }
        }
        $S1(x: int) {
            get_x(): int { @@:(x) }
        }

    domain:
        f: int = 1
}


def _fail(msg)
  puts("FAIL: #{msg}")
  exit(1)
end

_inst = StateArgs_sa_p3_arith_arg__t9.new
_inst.drive
_ret = _inst.get_x
_fail("expected ret=0, got #{_ret}") unless _ret == 0
puts("PASS: state-args")
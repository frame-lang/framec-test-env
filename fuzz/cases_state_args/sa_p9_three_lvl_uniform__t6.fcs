            drive() {
                -> $Leaf(-50)
            }
        }
        $Leaf => $Mid(x: int) {
            get_x(): int { @@:(x) }
        }
        $Mid => $Root(x: int) {
        }
        $Root(x: int) {
        }

    domain:
        f: int = 100
}

namespace nf_sa_p9_three_lvl_uniform__t6 {
    public class Driver {
        public static void Main() {
            var _inst = new StateArgs_sa_p9_three_lvl_uniform__t6();
            _inst.drive();
            int _ret = (int) _inst.get_x();
            if (_ret != -50) {
                throw new System.Exception("FAIL: expected ret=-50, got " + _ret);
            }

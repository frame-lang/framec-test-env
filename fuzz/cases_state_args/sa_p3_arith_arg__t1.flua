@@[target("lua")]


@@system StateArgs_sa_p3_arith_arg__t1 {
    interface:
        drive()
        get_x(): int

    machine:
        $S0 {
            drive() {
                -> $S1(5 + 1)
            }
        }
        $S1(x: int) {
            get_x(): int { @@:(x) }
        }

    domain:
        f: int = 0
}


function _fail(msg)
    print("FAIL: " .. msg)
    os.exit(1)
end

local _inst = StateArgs_sa_p3_arith_arg__t1.new()
_inst:drive()
local _ret = _inst:get_x()
if _ret ~= 6 then _fail("expected ret=6, got " .. tostring(_ret)) end
print("PASS: state-args")
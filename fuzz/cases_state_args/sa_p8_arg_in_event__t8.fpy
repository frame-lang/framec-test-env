@@target python_3


@@system StateArgs_sa_p8_arg_in_event__t8 {
    interface:
        drive()
        drive2(): int

    machine:
        $S0 {
            drive() {
                -> $S1(999)
            }
        }
        $S1(x: int) {
            drive2(): int {
                @@:return = x
            }
        }

    domain:
        f: int = -777
}


def _fail(msg):
    print(f"FAIL: {msg}")
    raise SystemExit(1)

_inst = StateArgs_sa_p8_arg_in_event__t8()
_inst.drive()
_ret = _inst.drive2()
if _ret != 999:
    _fail(f"expected ret=999, got {_ret}")
print("PASS: state-args")
@@target ruby


@@system StateArgs_sa_p8_arg_in_event__t5 {
    interface:
        drive()
        drive2(): int

    machine:
        $S0 {
            drive() {
                -> $S1(7)
            }
        }
        $S1(x: int) {
            drive2(): int {
                @@:return = x
            }
        }

    domain:
        f: int = 13
}


def _fail(msg)
  puts("FAIL: #{msg}")
  exit(1)
end

_inst = StateArgs_sa_p8_arg_in_event__t5.new
_inst.drive
_ret = _inst.drive2
_fail("expected ret=7, got #{_ret}") unless _ret == 7
puts("PASS: state-args")
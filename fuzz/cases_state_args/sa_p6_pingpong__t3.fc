@@[target("c")]


@@system StateArgs_sa_p6_pingpong__t3 {
    interface:
        drive()
        get_x(): int

    machine:
        $S0 {
            drive() {
                -> $S1(0)
            }
        }
        $S1(x: int) {
            $>() {
                -> $S2(x * 2)
            }
        }
        $S2(y: int) {
            get_x(): int { @@:(y) }
        }

    domain:
        f: int = 0
}

#include <stdio.h>
#include <stdlib.h>
int main(void) {
    StateArgs_sa_p6_pingpong__t3* _inst = StateArgs_sa_p6_pingpong__t3_new();
    StateArgs_sa_p6_pingpong__t3_drive(_inst);
    int _ret = (int)(intptr_t)StateArgs_sa_p6_pingpong__t3_get_x(_inst);
    if (_ret != 0) {
        printf("FAIL: expected ret=0, got %d\n", _ret);
        return 1;
    }
    printf("PASS: state-args\n");
    return 0;
}
@@target gdscript

extends SceneTree


@@system StateArgs_sa_p9_three_lvl_uniform__t3 {
    interface:
        drive()
        get_x(): int

    machine:
        $S0 {
            drive() {
                -> $Leaf(0)
            }
        }
        $Leaf => $Mid(x: int) {
            get_x(): int { @@:(x) }
        }
        $Mid => $Root(x: int) {
        }
        $Root(x: int) {
        }

    domain:
        f: int = 0
}


func _fail(msg):
    print("FAIL: " + msg)
    quit(1)

func _init():
    var _inst = StateArgs_sa_p9_three_lvl_uniform__t3.new()
    _inst.drive()
    var _ret = _inst.get_x()
    if _ret != 0:
        _fail("expected ret=0, got " + str(_ret))
    print("PASS: state-args")
    quit()
@@[target("cpp_17")]


@@system StateArgs_sa_p2_dom_arg__t4 {
    interface:
        drive()
        get_x(): int

    machine:
        $S0 {
            drive() {
                this->f = 100;
                -> $S1(this->f)
            }
        }
        $S1(x: int) {
            get_x(): int { @@:(x) }
        }

    domain:
        f: int = 50
}

#include <iostream>
int main() {
    StateArgs_sa_p2_dom_arg__t4 _inst;
    _inst.drive();
    int _ret = std::any_cast<int>(_inst.get_x());
    if (_ret != 100) {
        std::cerr << "FAIL: expected ret=100, got " << _ret << std::endl;
        return 1;
    }
    std::cout << "PASS: state-args" << std::endl;
    return 0;
}
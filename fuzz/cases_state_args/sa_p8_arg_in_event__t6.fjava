@@target java


@@system StateArgs_sa_p8_arg_in_event__t6 {
    interface:
        drive()
        drive2(): int

    machine:
        $S0 {
            drive() {
                -> $S1(-50)
            }
        }
        $S1(x: int) {
            drive2(): int {
                @@:return = x;
            }
        }

    domain:
        f: int = 100
}

class Driver {
    public static void main(String[] args) {
        var _inst = new StateArgs_sa_p8_arg_in_event__t6();
        _inst.drive();
        int _ret = (int) _inst.drive2();
        if (_ret != -50) {
            System.out.println("FAIL: expected ret=-50, got " + _ret);
            System.exit(1);
        }
        System.out.println("PASS: state-args");
    }
}
@@[target("php")]
// @@expect-error: E407
//
// E407: PHP closure body contains a Frame transition.
// Detected by `PhpSkipper::skip_nested_scope` matching
// `function(args) [use(...)] {`.

<?php

@@system NestedFrameInPhpClosure {
    interface:
        run()
    machine:
        $A {
            run() {
                $cb = function() {
                    -> $B
                };
                $cb();
            }
        }
        $B {
            run() {}
        }
}

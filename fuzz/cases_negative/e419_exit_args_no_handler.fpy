@@[target("python_3")]
# @@expect-error: E419
#
# E419 (no-handler form): a transition with `(args) -> $Target`
# supplies exit args but the SOURCE state has no `<$()` handler
# to receive them. The args would be silently dropped at runtime.

@@system ExitArgsNoHandler {
    interface:
        go()
    machine:
        $A {
            go() {
                ("reason") -> $B
            }
        }
        $B {
            go() {}
        }
}

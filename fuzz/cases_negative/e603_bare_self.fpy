@@target python_3
# @@expect-error: E603
#
# E603: bare `@@:self` without a `.method()` follow-on is illegal.
# `@@:self` only makes sense as the receiver of a self-reentrant
# method call.

@@system BareSelf {
    interface:
        ping()
    machine:
        $A {
            ping() {
                @@:self
            }
        }
}

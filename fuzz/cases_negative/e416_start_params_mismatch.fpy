@@[target("python_3")]
# @@expect-error: E416
#
# E416: a system header's `$(args)` declares the start state's
# parameters. The list must match the start state's own declared
# parameter list (order-insensitive, by name). Mismatch — header
# says `$(x)`, start state declares `$Init(other)` — should be
# rejected.

@@system StartParamMismatch($(x: int)) {
    interface:
        ping()
    machine:
        $Init(other: int) {
            ping() {}
        }
}

@@[target("cpp_17")]
// @@expect-error: E407
//
// E407: C++ lambda body contains a Frame transition.
// Detected by `CppSkipper::skip_nested_scope` matching
// `[capture](args) [-> ret] {`.

@@system NestedFrameInCppLambda {
    interface:
        run()
    machine:
        $A {
            run() {
                auto cb = [this]() {
                    -> $B
                };
                cb();
            }
        }
        $B {
            run() {}
        }
}

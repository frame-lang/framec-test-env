@@[target("python_3")]
# @@expect-error: E817
#
# E817: lifecycle attribute name argument must be a single valid
# identifier — alphanumeric + underscore, starting with letter or
# underscore. Multi-argument forms like `@@[save(a, b)]` and
# digit-led names like `@@[save(1foo)]` are rejected.

@@[persist(str)]
@@[save(1bad_name)]
@@[load(restore_state)]
@@system BadName {
    interface:
        ping()
    machine:
        $A { ping() {} }
}

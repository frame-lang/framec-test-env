@@[target("python_3")]
# @@expect-error: E614
#
# E614: two domain fields with the same name. Silent shadowing
# would lose data; the validator rejects.

@@system DupDomainField {
    interface:
        ping()
    machine:
        $A {
            ping() {}
        }

    domain:
        count: int = 0
        count: int = 1
}

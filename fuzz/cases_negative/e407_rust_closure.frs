@@[target("rust")]
// @@expect-error: E407
//
// E407: Rust closure body contains a Frame transition.
// Detected by `RustSkipper::skip_nested_scope` matching
// `|args| {` (and the `move |args| {` form).

@@system NestedFrameInRustClosure {
    interface:
        run()
    machine:
        $A {
            run() {
                let cb = || {
                    -> $B
                };
                cb();
            }
        }
        $B {
            run() {}
        }
}

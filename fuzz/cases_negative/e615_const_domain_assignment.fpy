@@[target("python_3")]
# @@expect-error: E615
#
# E615: handlers cannot assign to a `const` domain field. The const
# qualifier marks the value as fixed at construction time; mutating
# it from inside a handler defeats the contract.

@@system ConstAssign {
    interface:
        bump()
    machine:
        $A {
            bump() {
                self.threshold = 99
            }
        }

    domain:
        const threshold: int = 3
}

@@[target("python_3")]
# @@expect-error: E114
#
# E114: a system can declare each section (interface, machine,
# domain, etc.) at most once. Two `interface:` blocks must be
# rejected.

@@system DupSection {
    interface:
        a()
    interface:
        b()
    machine:
        $A {
            a() {}
            b() {}
        }
}

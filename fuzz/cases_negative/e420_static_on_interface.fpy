@@[target("python_3")]
# @@expect-error: E420
#
# E420: `static` is only valid on operations. Marking an interface
# method `static` should be rejected — interface methods need a
# compartment context to dispatch through the kernel.

@@system StaticOnInterface {
    interface:
        static do_thing()

    machine:
        $A {
            do_thing() {}
        }
}

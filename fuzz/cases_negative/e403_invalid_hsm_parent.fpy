@@[target("python_3")]
# @@expect-error: E403
#
# E403: HSM parent in `$Child => $Parent` references a state that
# doesn't exist. Equivalent to E402 but for HSM parent declarations.

@@system InvalidParent {
    interface:
        ping()
    machine:
        $Child => $NotAState {
            ping() {}
        }
}

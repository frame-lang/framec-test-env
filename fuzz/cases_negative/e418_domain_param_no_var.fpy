@@[target("python_3")]
# @@expect-error: E418
#
# E418: a system header parameter intended to seed a domain field
# (e.g., `@@system X(threshold: int)` with `threshold` in domain)
# requires a matching variable. Listing `unused` in the header with
# no domain entry of that name is rejected.

@@system DomainParamMismatch(unused: int) {
    interface:
        ping()
    machine:
        $A {
            ping() {}
        }

    domain:
        other: int = 0
}

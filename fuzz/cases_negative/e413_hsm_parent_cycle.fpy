@@[target("python_3")]
# @@expect-error: E413
#
# E413: HSM parent declarations form a cycle. `$A => $B => $A`
# would loop forever during chain walks; the validator rejects.

@@system HsmCycle {
    interface:
        ping()
    machine:
        $A => $B {
            ping() {}
        }
        $B => $A {
            ping() {}
        }
}

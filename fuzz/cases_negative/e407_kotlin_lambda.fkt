@@target kotlin
// @@expect-error: E407
//
// E407: Kotlin lambda body contains a Frame transition.
// Detected by `KotlinSkipper::skip_nested_scope` matching
// the `{ <ident-or-paren> ... -> ... }` shape.

@@system NestedFrameInKotlinLambda {
    interface:
        run()
    machine:
        $A {
            run() {
                val cb = { x: Int ->
                    -> $B
                }
                cb(0)
            }
        }
        $B {
            run() {}
        }
}

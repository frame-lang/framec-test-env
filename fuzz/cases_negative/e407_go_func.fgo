@@[target("go")]
// @@expect-error: E407
//
// E407: Go function literal body contains a Frame transition.
// Detected by `GoSkipper::skip_nested_scope` matching
// `func(args) [ret] {`.

@@system NestedFrameInGoFunc {
    interface:
        run()
    machine:
        $A {
            run() {
                cb := func() {
                    -> $B
                }
                cb()
            }
        }
        $B {
            run() {}
        }
}

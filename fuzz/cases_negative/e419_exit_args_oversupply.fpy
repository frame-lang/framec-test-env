@@target python_3
# @@expect-error: E419
#
# E419 (count-mismatch, oversupply form): the source state's
# `<$(a)` accepts one parameter, but the transition supplies
# three. There's no slot for the excess regardless of defaults,
# so E419 fires.

@@system ExitArgsOversupply {
    interface:
        go()
    machine:
        $A {
            <$(a: str) {}
            go() {
                ("one", "two", "three") -> $B
            }
        }
        $B {
            go() {}
        }
}

@@[target("python_3")]
# @@expect-error: E421
#
# E421: `@@:system.state` is illegal inside a static operation.
# Static ops have no compartment / self context, so reading the
# current state would be undefined.

@@system StaticOpStateRead {
    operations:
        static check_state(): str {
            @@:(@@:system.state)
        }

    interface:
        ping()

    machine:
        $A {
            ping() {}
        }
}

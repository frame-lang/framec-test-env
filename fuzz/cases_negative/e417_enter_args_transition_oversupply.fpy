@@[target("python_3")]
# @@expect-error: E417
#
# E417 (transition form, oversupply): the target state's
# `$>(a)` enter handler accepts one parameter; the transition
# supplies two. No slot for the second arg even with defaults.

@@system EnterArgsTransitionOversupply {
    interface:
        go()
    machine:
        $A {
            go() {
                -> ("a", "b") $B
            }
        }
        $B {
            $>(a: str) {}
            go() {}
        }
}

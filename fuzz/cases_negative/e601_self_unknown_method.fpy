@@target python_3
# @@expect-error: E601
#
# E601: `@@:self.method()` references a method not declared in the
# system's interface. The validator should catch the typo before
# codegen — otherwise the generated dispatch table has no entry for
# `does_not_exist` and the runtime would silently NOOP.

@@system UnknownMethod {
    interface:
        ping()
    machine:
        $A {
            ping() {
                @@:self.does_not_exist()
            }
        }
}

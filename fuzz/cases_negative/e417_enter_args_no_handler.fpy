@@target python_3
# @@expect-error: E417
#
# E417: system header declares `$>(arg)` enter args but the start
# state has no `$>()` handler to receive them. The header promises
# to forward the value into a handler that doesn't exist.

@@system EnterArgsNoHandler($>(msg: str)) {
    interface:
        ping()
    machine:
        $Init {
            ping() {}
        }
}

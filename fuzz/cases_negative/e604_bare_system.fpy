@@target python_3
# @@expect-error: E604
#
# E604: bare `@@:system` without `.state` is illegal. The only valid
# uses are `@@:system.state` (read the current state name) or
# similar attribute access.

@@system BareSystem {
    interface:
        check()
    machine:
        $A {
            check() {
                if @@:system == "$A":
                    return
            }
        }
}

@@[target("csharp")]
// @@expect-error: E407
//
// E407: C# lambda body contains a Frame transition. Same
// `=> {` arrow shape as TS/JS.

@@system NestedFrameInCsLambda {
    interface:
        run()
    machine:
        $A {
            run() {
                System.Action cb = () => {
                    -> $B
                };
                cb();
            }
        }
        $B {
            run() {}
        }
}

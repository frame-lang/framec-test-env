@@target python_3
# @@expect-error: E406
#
# E406: a state's handler for an interface event declares a
# different parameter count than the interface method. Here
# `tick(n: int)` is declared on the interface, but `$Counting`'s
# handler takes zero parameters — the validator rejects the
# divergent shape.

@@system HandlerParamMismatch {
    interface:
        tick(n: int)
    machine:
        $Counting {
            tick() {}
        }
}

@@[target("python_3")]
# @@expect-error: E818
#
# E818: at most one `@@[save]` (or `@@[load]`, or `@@[create]`)
# per system. Two `@@[save]` attributes on the same system create
# an ambiguous lifecycle declaration.

@@[persist(str)]
@@[save(save_one)]
@@[save(save_two)]
@@[load(restore_state)]
@@system DupSave {
    interface:
        ping()
    machine:
        $A { ping() {} }
}

@@target python_3
# @@expect-error: E602
#
# E602: `@@:self.method()` argument count mismatch. The interface
# declares `op(x: int)` taking one argument; calling it with two
# arguments should be rejected at the validator stage rather than
# producing wrong codegen.

@@system ArgCountMismatch {
    interface:
        op(x: int)
        ping()
    machine:
        $A {
            op(x: int) {}
            ping() {
                @@:self.op(1, 2)
            }
        }
}

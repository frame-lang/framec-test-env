@@[target("python_3")]
# @@expect-error: E408
#
# E408: `@@system public Foo` is rejected because systems are
# public by default — declaring it explicitly is redundant noise.
# The lint pushes authors towards the canonical form
# `@@system Foo { ... }` or, when restricting access,
# `@@system private Foo { ... }` on backends that support it.

@@system public RedundantPublic {
    interface:
        ping()
    machine:
        $Idle {
            ping() {}
        }
}

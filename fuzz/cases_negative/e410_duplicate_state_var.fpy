@@target python_3
# @@expect-error: E410
#
# E410: `$.varName` declared twice in the same state. The second
# declaration would silently shadow the first.

@@system DupStateVar {
    interface:
        ping()
    machine:
        $A {
            $.x: int = 0
            $.x: int = 1
            ping() {}
        }
}

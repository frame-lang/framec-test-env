@@[target("javascript")]
// @@expect-error: E407
//
// E407: JavaScript arrow function body contains a Frame
// transition. Same shape as the TypeScript form.

@@system NestedFrameInJsArrow {
    interface:
        run()
    machine:
        $A {
            run() {
                const cb = () => {
                    -> $B
                };
                cb();
            }
        }
        $B {
            run() {}
        }
}

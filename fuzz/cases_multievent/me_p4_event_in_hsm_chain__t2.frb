@@target ruby


@@system MultiEvent_me_p4_event_in_hsm_chain__t2 {
    interface:
        bump_a()
        drive()
        fwd_bump()
        get_f(): int

    machine:
        $S0 {
            drive() {
                -> $Child
            }
        }
        $Child => $Parent {
            bump_a() {
                self.f = self.f + -3
            }
            fwd_bump() {
                => $^
            }
            get_f(): int { @@:(self.f) }
        }
        $Parent {
            fwd_bump() {
                self.f = self.f + 4
            }
        }

    domain:
        f: int = 0
}


def _fail(msg)
  puts("FAIL: #{msg}")
  exit(1)
end

_inst = MultiEvent_me_p4_event_in_hsm_chain__t2.new
_inst.drive
_inst.bump_a
_inst.fwd_bump
_ret = _inst.get_f
_fail("expected ret=1, got #{_ret}") unless _ret == 1
puts("PASS: multievent")

@@[target("ruby")]


@@system MultiEvent_me_p4_event_in_hsm_chain__t1 {
    interface:
        bump_a()
        drive()
        fwd_bump()
        get_f(): int

    machine:
        $S0 {
            drive() {
                -> $Child
            }
        }
        $Child => $Parent {
            bump_a() {
                self.f = self.f + 5
            }
            fwd_bump() {
                => $^
            }
            get_f(): int { @@:(self.f) }
        }
        $Parent {
            fwd_bump() {
                self.f = self.f + 7
            }
        }

    domain:
        f: int = 0
}


def _fail(msg)
  puts("FAIL: #{msg}")
  exit(1)
end

_inst = MultiEvent_me_p4_event_in_hsm_chain__t1.new
_inst.drive
_inst.bump_a
_inst.fwd_bump
_ret = _inst.get_f
_fail("expected ret=12, got #{_ret}") unless _ret == 12
puts("PASS: multievent")

@@target c


@@system MultiEvent_me_p4_event_in_hsm_chain__t2 {
    interface:
        bump_a()
        drive()
        fwd_bump()
        get_f(): int

    machine:
        $S0 {
            drive() {
                -> $Child
            }
        }
        $Child => $Parent {
            bump_a() {
                self->f = self->f + -3;
            }
            fwd_bump() {
                => $^
            }
            get_f(): int { @@:(self->f) }
        }
        $Parent {
            fwd_bump() {
                self->f = self->f + 4;
            }
        }

    domain:
        f: int = 0
}

#include <stdio.h>
#include <stdlib.h>
int main(void) {
    MultiEvent_me_p4_event_in_hsm_chain__t2* _inst = MultiEvent_me_p4_event_in_hsm_chain__t2_new();
    MultiEvent_me_p4_event_in_hsm_chain__t2_drive(_inst);
    MultiEvent_me_p4_event_in_hsm_chain__t2_bump_a(_inst);
    MultiEvent_me_p4_event_in_hsm_chain__t2_fwd_bump(_inst);
    int _ret = (int)(intptr_t)MultiEvent_me_p4_event_in_hsm_chain__t2_get_f(_inst);
    if (_ret != 1) {
        printf("FAIL: expected ret=1, got %d\n", _ret);
        return 1;
    }
    printf("PASS: multievent\n");
    return 0;
}

@@target lua


@@system MultiEvent_me_p2_event_then_transition__t6 {
    interface:
        bump_in_s1()
        drive()
        get_f(): int

    machine:
        $S0 {
            drive() {
                -> $S1
            }
        }
        $S1 {
            bump_in_s1() {
                self.f = self.f + -7
            }
            get_f(): int { @@:(self.f) }
        }

    domain:
        f: int = 0
}


function _fail(msg)
    print("FAIL: " .. msg)
    os.exit(1)
end

local _inst = MultiEvent_me_p2_event_then_transition__t6.new()
_inst:drive()
_inst:bump_in_s1()
local _ret = _inst:get_f()
if _ret ~= -7 then _fail("expected ret=-7, got " .. tostring(_ret)) end
print("PASS: multievent")

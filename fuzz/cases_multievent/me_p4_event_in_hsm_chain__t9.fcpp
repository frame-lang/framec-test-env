@@target cpp_17


@@system MultiEvent_me_p4_event_in_hsm_chain__t9 {
    interface:
        bump_a()
        drive()
        fwd_bump()
        get_f(): int

    machine:
        $S0 {
            drive() {
                -> $Child
            }
        }
        $Child => $Parent {
            bump_a() {
                this->f = this->f + -1;
            }
            fwd_bump() {
                => $^
            }
            get_f(): int { @@:(this->f) }
        }
        $Parent {
            fwd_bump() {
                this->f = this->f + 1;
            }
        }

    domain:
        f: int = 0
}

#include <iostream>
int main() {
    MultiEvent_me_p4_event_in_hsm_chain__t9 _inst;
    _inst.drive();
    _inst.bump_a();
    _inst.fwd_bump();
    int _ret = std::any_cast<int>(_inst.get_f());
    if (_ret != 0) {
        std::cerr << "FAIL: expected ret=0, got " << _ret << std::endl;
        return 1;
    }
    std::cout << "PASS: multievent" << std::endl;
    return 0;
}

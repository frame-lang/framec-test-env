@@target php
<?php


@@system ConstSys_cs_p1_const_field__t5 {
    interface:
        get_const(): int

    machine:
        $S0 {
            get_const(): int { @@:($this->k) }
        }

    domain:
        const k: int = 50
}


function _fail($msg) { echo "FAIL: $msg\n"; exit(1); }

$_inst = new ConstSys_cs_p1_const_field__t5();
$_ret = $_inst->get_const();
$_expected = 50;
if ($_ret !== $_expected) { _fail("expected=" . $_expected . ", got " . $_ret); }
echo "PASS: const-sys\n";

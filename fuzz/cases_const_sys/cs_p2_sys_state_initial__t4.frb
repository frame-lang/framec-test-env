@@target ruby


@@system ConstSys_cs_p2_sys_state_initial__t4 {
    interface:
        get_state(): str

    machine:
        $S0 {
            get_state(): str { @@:(@@:system.state) }
        }

    domain:
        f: int = 100
}


def _fail(msg)
  puts("FAIL: #{msg}")
  exit(1)
end

_inst = ConstSys_cs_p2_sys_state_initial__t4.new
_ret = _inst.get_state
_expected = "S0"
_fail("expected=#{_expected}, got #{_ret}") unless _ret == _expected
puts("PASS: const-sys")

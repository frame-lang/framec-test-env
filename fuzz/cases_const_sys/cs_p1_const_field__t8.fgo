@@[target("go")]

package main

import "fmt"
import "os"


@@system ConstSys_cs_p1_const_field__t8 {
    interface:
        Get_const(): int

    machine:
        $S0 {
            Get_const(): int { @@:(s.k) }
        }

    domain:
        const k: int = 99
}


func _fail(msg string) { fmt.Println("FAIL: " + msg); os.Exit(1) }

func main() {
    sm := NewConstSys_cs_p1_const_field__t8()

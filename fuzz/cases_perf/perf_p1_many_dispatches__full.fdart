@@target dart


@@system Perf_perf_p1_many_dispatches__full {
    interface:
        bump()
        get_f(): int

    machine:
        $S0 {
            bump() {
                this.f = this.f + 1;
            }
            get_f(): int { @@:(this.f) }
        }

    domain:
        f: int = 0
}


void _fail(String msg) { print("FAIL: $msg"); throw Exception(msg); }

void main() {
    final _inst = Perf_perf_p1_many_dispatches__full();
    final _n = 1000000;
    final _sw = Stopwatch()..start();
    for (var i = 0; i < _n; i++) _inst.bump();
    _sw.stop();
    final _elapsed_ms = _sw.elapsedMicroseconds / 1000.0;
    final _ret = _inst.get_f();
    print("PERF: pattern=p1_many_dispatches lang=dart n=$_n ms=${_elapsed_ms.toStringAsFixed(2)} result=$_ret");
    if (_ret != 1000000) { _fail("expected ret=1000000, got $_ret"); }
    print("PASS: perf");
}

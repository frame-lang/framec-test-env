@@target java


@@system PushPop_pp_p4_pop_then_event__t1 {
    interface:
        drive()
        get_x(): int
        go_back()

    machine:
        $S0 {
            $.x: int = 5
            drive() {
                push$
                -> $S1
            }
            get_x(): int { @@:($.x) }
        }
        $S1 {
            $.x: int = 7
            go_back() {
                -> pop$
            }
        }

    domain:
        f: int = 5
}

class Driver {
    public static void main(String[] args) {
        var _inst = new PushPop_pp_p4_pop_then_event__t1();
        _inst.drive();
        _inst.go_back();
        int _ret = (int) _inst.get_x();
        if (_ret != 5) {
            System.out.println("FAIL: expected ret=5, got " + _ret);
            System.exit(1);
        }
        System.out.println("PASS: pushpop");
    }
}

        get_x(): int
        go_back()
        push_then()

    machine:
        $S0 {
            drive() {
                -> (-1) $S1(10)
            }
        }
        $S1(x: int) {
            $>(a: int) {
                this.f = a;
            }
            push_then() {
                push$

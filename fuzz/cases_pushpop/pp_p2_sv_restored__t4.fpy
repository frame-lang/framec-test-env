@@target python_3


@@system PushPop_pp_p2_sv_restored__t4 {
    interface:
        drive()
        get_x(): int
        go_back()

    machine:
        $S0 {
            $.x: int = 0
            drive() {
                push$
                -> $S1
            }
            get_x(): int { @@:($.x) }
        }
        $S1 {
            $.x: int = 100
            go_back() {
                -> pop$
            }
        }

    domain:
        f: int = 0
}


def _fail(msg):
    print(f"FAIL: {msg}")
    raise SystemExit(1)

_inst = PushPop_pp_p2_sv_restored__t4()
_inst.drive()
_inst.go_back()
_ret = _inst.get_x()
if _ret != 0:
    _fail(f"expected ret=0, got {_ret}")
print("PASS: pushpop")

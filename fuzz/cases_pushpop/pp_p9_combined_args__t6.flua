@@[target("lua")]


@@system PushPop_pp_p9_combined_args__t6 {
    interface:
        drive()
        get_x(): int
        go_back()
        push_then()

    machine:
        $S0 {
            drive() {
                -> (-3) $S1(-7)
            }
        }
        $S1(x: int) {
            $>(a: int) {
                self.f = a
            }
            push_then() {
                push$
                -> $S2
            }
            get_x(): int { @@:(x) }
        }
        $S2 {
            go_back() {
                -> pop$
            }
        }

    domain:
        f: int = -7
}


function _fail(msg)
    print("FAIL: " .. msg)
    os.exit(1)
end

local _inst = PushPop_pp_p9_combined_args__t6.new()
_inst:drive()
_inst:push_then()
_inst:go_back()
local _ret = _inst:get_x()
if _ret ~= -7 then _fail("expected ret=-7, got " .. tostring(_ret)) end
print("PASS: pushpop")

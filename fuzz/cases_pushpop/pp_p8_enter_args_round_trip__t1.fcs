@@target csharp


@@system PushPop_pp_p8_enter_args_round_trip__t1 {
    interface:
        drive()
        get_f(): int
        go_back()
        push_then()

    machine:
        $S0 {
            drive() {
                -> (5) $S1
            }
        }
        $S1 {
            $>(a: int) {
                this.f = a;
            }
            push_then() {
                push$
                -> $S2
            }
            get_f(): int { @@:(this.f) }
        }
        $S2 {
            go_back() {
                -> pop$
            }
        }

    domain:
        f: int = 5
}

namespace nf_pp_p8_enter_args_round_trip__t1 {
    public class Driver {
        public static void Main() {
            var _inst = new PushPop_pp_p8_enter_args_round_trip__t1();
            _inst.drive();
            _inst.push_then();
            _inst.go_back();
            int _ret = (int) _inst.get_f();
            if (_ret != 5) {
                throw new System.Exception("FAIL: expected ret=5, got " + _ret);
            }
            System.Console.WriteLine("PASS: pushpop");
        }
    }
}

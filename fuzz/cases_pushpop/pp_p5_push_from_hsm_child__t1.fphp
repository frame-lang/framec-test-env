@@target php
<?php


@@system PushPop_pp_p5_push_from_hsm_child__t1 {
    interface:
        bump_f()
        drive()
        get_f(): int
        go_back()

    machine:
        $S0 {
            drive() {
                push$
                -> $Child
            }
            get_f(): int { @@:($this->f) }
        }
        $Child => $Parent {
            bump_f() {
                $this->f = $this->f + 7;
            }
            go_back() {
                -> pop$
            }
        }
        $Parent {}

    domain:
        f: int = 5
}


function _fail($msg) { echo "FAIL: $msg\n"; exit(1); }

$_inst = new PushPop_pp_p5_push_from_hsm_child__t1();
$_inst->drive();
$_inst->bump_f();
$_inst->go_back();
$_ret = $_inst->get_f();
if ($_ret !== 12) { _fail("expected ret=12, got " . $_ret); }
echo "PASS: pushpop\n";

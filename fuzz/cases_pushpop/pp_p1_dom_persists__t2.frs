@@target rust


@@system PushPop_pp_p1_dom_persists__t2 {
    interface:
        bump_f()
        drive()
        get_f(): int
        go_back()

    machine:
        $S0 {
            drive() {
                push$
                -> $S1
            }
            get_f(): int { @@:(self.f) }
        }
        $S1 {
            bump_f() {
                self.f = self.f + 4;
            }
            go_back() {
                -> pop$
            }
        }

    domain:
        f: int = -3
}


fn _fail(msg: &str) -> ! { panic!("FAIL: {}", msg); }


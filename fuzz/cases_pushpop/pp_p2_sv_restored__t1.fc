@@target c


@@system PushPop_pp_p2_sv_restored__t1 {
    interface:
        drive()
        get_x(): int
        go_back()

    machine:
        $S0 {
            $.x: int = 5
            drive() {
                push$
                -> $S1
            }
            get_x(): int { @@:($.x) }
        }
        $S1 {
            $.x: int = 7
            go_back() {
                -> pop$
            }
        }

    domain:
        f: int = 5
}

#include <stdio.h>
#include <stdlib.h>
int main(void) {
    PushPop_pp_p2_sv_restored__t1* _inst = PushPop_pp_p2_sv_restored__t1_new();
    PushPop_pp_p2_sv_restored__t1_drive(_inst);
    PushPop_pp_p2_sv_restored__t1_go_back(_inst);
    int _ret = (int)(intptr_t)PushPop_pp_p2_sv_restored__t1_get_x(_inst);
    if (_ret != 5) {
        printf("FAIL: expected ret=5, got %d\n", _ret);
        return 1;
    }
    printf("PASS: pushpop\n");
    return 0;
}

@@[target("c")]


@@system PushPop_pp_p3_depth_two__t1 {
    interface:
        bump_f()
        drive()
        get_f(): int
        pop1()
        pop2()
        to_s2()

    machine:
        $S0 {
            drive() {
                push$
                -> $S1
            }
            get_f(): int { @@:(self->f) }
        }
        $S1 {
            to_s2() {
                push$
                -> $S2
            }
            pop2() {
                -> pop$
            }
        }
        $S2 {
            bump_f() {
                self->f = self->f + 7;
            }
            pop1() {
                -> pop$
            }
        }

    domain:
        f: int = 5
}

#include <stdio.h>
#include <stdlib.h>
int main(void) {
    PushPop_pp_p3_depth_two__t1* _inst = PushPop_pp_p3_depth_two__t1_new();
    PushPop_pp_p3_depth_two__t1_drive(_inst);
    PushPop_pp_p3_depth_two__t1_to_s2(_inst);
    PushPop_pp_p3_depth_two__t1_bump_f(_inst);
    PushPop_pp_p3_depth_two__t1_pop1(_inst);
    PushPop_pp_p3_depth_two__t1_pop2(_inst);
    int _ret = (int)(intptr_t)PushPop_pp_p3_depth_two__t1_get_f(_inst);
    if (_ret != 12) {
        printf("FAIL: expected ret=12, got %d\n", _ret);
        return 1;
    }
    printf("PASS: pushpop\n");
    return 0;
}

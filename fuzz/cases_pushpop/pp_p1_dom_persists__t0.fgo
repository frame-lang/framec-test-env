@@[target("go")]

package main

import "fmt"
import "os"


@@system PushPop_pp_p1_dom_persists__t0 {
    interface:
        Bump_f()
        Drive()
        Get_f(): int
        Go_back()

    machine:
        $S0 {
            Drive() {
                push$
                -> $S1
            }
            Get_f(): int { @@:(s.f) }
        }
        $S1 {
            Bump_f() {
                s.f = s.f + 2
            }
            Go_back() {
                -> pop$
            }
        }

    domain:
        f: int = 1
}


func _fail(msg string) { fmt.Println("FAIL: " + msg); os.Exit(1) }

func main() {
    sm := NewPushPop_pp_p1_dom_persists__t0()
    sm.Drive()
    sm.Bump_f()
    sm.Go_back()
    ret := sm.Get_f()
    if ret != 3 { _fail(fmt.Sprintf("expected ret=3, got %d", ret)) }
    fmt.Println("PASS: pushpop")
}

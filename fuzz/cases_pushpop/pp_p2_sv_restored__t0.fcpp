@@target cpp_17


@@system PushPop_pp_p2_sv_restored__t0 {
    interface:
        drive()
        get_x(): int
        go_back()

    machine:
        $S0 {
            $.x: int = 1
            drive() {
                push$
                -> $S1
            }
            get_x(): int { @@:($.x) }
        }
        $S1 {
            $.x: int = 2
            go_back() {
                -> pop$
            }
        }

    domain:
        f: int = 1
}

#include <iostream>
int main() {
    PushPop_pp_p2_sv_restored__t0 _inst;
    _inst.drive();
    _inst.go_back();
    int _ret = std::any_cast<int>(_inst.get_x());
    if (_ret != 1) {
        std::cerr << "FAIL: expected ret=1, got " << _ret << std::endl;
        return 1;
    }
    std::cout << "PASS: pushpop" << std::endl;
    return 0;
}

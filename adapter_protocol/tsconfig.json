{
  "compilerOptions": {
    "target": "ES2019",
    "module": "commonjs",
    "baseUrl": ".",
    "paths": {
      "frame_runtime_ts": ["runtime/frame_runtime_ts"]
    },
    "esModuleInterop": true,
    "strict": true,
    "noImplicitAny": false,
    "skipLibCheck": true,
    "types": ["node"],
    "typeRoots": ["./node_modules/@types"],
    "outDir": "./out"
  },
  "include": [
    "adapter_protocol_minimal.ts",
    "runtime/frame_runtime_ts.d.ts",
    "scripts/node_harness.ts"
  ]
}

@@target python_3

# Port of legacy test_class_decorators_args.frm to syntax.

@@system PyDecorArgs{
    actions:
        run() {
            from dataclasses import dataclass

            @dataclass(frozen=True)
            class ImmutablePoint:
                x: int
                y: int

            p = ImmutablePoint(5, 12)
            print("ImmutablePoint: (" + str(p.x) + ", " + str(p.y) + ")")
        }
}

def main():
    s = PyDecorArgsV3()
    s.run()

if __name__ == '__main__':
    main()

# Stub functions for placeholder calls
def native(): pass
def x(): pass

# TAP test harness
if __name__ == "__main__":
    print("TAP version 14")
    print("1..1")
    try:
        s = PyDecorArgs()
        if hasattr(s, 'e'):
            s.e()
        print("ok 1 - class_decorators_args")
    except Exception as ex:
        print(f"not ok 1 - class_decorators_args # {ex}")

@@target python_3

# Port of legacy test_class_decorators_simple.frm to syntax.

@@system PyDecorSimple{
    actions:
        run() {
            from dataclasses import dataclass

            @dataclass
            class Point:
                def __init__(self, x, y):
                    self.x = x
                    self.y = y

            p1 = Point(3, 4)
            print("Point: (" + str(p1.x) + ", " + str(p1.y) + ")")
        }
}

def main():
    s = PyDecorSimpleV3()
    s.run()

if __name__ == '__main__':
    main()

# Stub functions for placeholder calls
def native(): pass
def x(): pass

# TAP test harness
if __name__ == "__main__":
    print("TAP version 14")
    print("1..1")
    try:
        s = PyDecorSimple()
        if hasattr(s, 'e'):
            s.e()
        print("ok 1 - class_decorators_simple")
    except Exception as ex:
        print(f"not ok 1 - class_decorators_simple # {ex}")

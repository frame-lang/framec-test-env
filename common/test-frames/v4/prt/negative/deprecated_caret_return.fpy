@@target python_3

# NEGATIVE TEST: ^ (caret return) is deprecated syntax and should NOT compile
# Expected: Parse error - unrecognized syntax

@@system DeprecatedCaretReturnTest {
    interface:
        getValue(): int

    machine:
        $Start {
            getValue(): int {
                ^ 42            # DEPRECATED - should fail (use 'return 42' instead)
            }
        }
}

# This test should FAIL to compile
# If it compiles, the test framework should report failure

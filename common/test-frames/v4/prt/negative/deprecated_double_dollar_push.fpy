@@target python_3

# NEGATIVE TEST: $$[+] is deprecated syntax and should NOT compile
# Expected: Parse error - unrecognized syntax

@@system DeprecatedPushTest {
    interface:
        test()

    machine:
        $Start {
            test() {
                $$[+]           # DEPRECATED - should fail
                -> $Other
            }
        }

        $Other {
            $>() {
                print("entered")
            }
        }
}

# This test should FAIL to compile
# If it compiles, the test framework should report failure

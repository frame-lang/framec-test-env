@@target python_3

# NEGATIVE TEST: ->> (change state without lifecycle) is deprecated syntax and should NOT compile
# Expected: Parse error - unrecognized syntax

@@system DeprecatedChangeStateTest {
    interface:
        test()

    machine:
        $Start {
            test() {
                ->> $Other      # DEPRECATED - should fail
            }
        }

        $Other {
            $>() {
                print("should not reach here")
            }
        }
}

# This test should FAIL to compile
# If it compiles, the test framework should report failure

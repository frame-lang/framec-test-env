@@target typescript
@@run-expect: STACK:PUSH
@@run-expect: STACK:POP
@@run-expect: TRANSITION:

@@system S {
    machine:
        $A {
            e() {
                for (let i = 0; i < 1; i++) {
                    push$
                    j = 0
                    while (j < 1) {
                        j += 1
                    pop$
                -> $B()
            }
        }
        $B { }
}


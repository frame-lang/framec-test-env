@@target rust


@@system MixedBodyStringsComments {
    machine:
        $Init {
            start() {
                // Native Python with Frame-statement-like tokens in strings && comments
                text = "This mentions -> $Next and pop$ inside a string."
                // A comment that mentions => $^ && -> $Other should not be parsed as Frame
                println!("text")
                -> $Done
            }
        }
        $Done {}
}

fn main() { println!("OK"); }

@@target typescript
@@run-expect: FORWARD:PARENT
@@run-expect: TRANSITION:

@@system S {
    machine:
        $A => $P {
            e() {
                // nested structure with inline separators
                if (true) {
                    => $^; let x = 1
                    if (x == 1) {
                        -> $B()
                    }
                }
            }
        }
        $B { }
        $P { }
}

// Stub functions for placeholder calls
function native(): void {}
function x(): void {}

// TAP test harness
function main() {
    console.log("TAP version 14");
    console.log("1..1");
    try {
        const s = new S();
        if (typeof (s as any).e === 'function') {
            (s as any).e();
        }
        console.log("ok 1 - nested_parent_forward_then_transition_exec");
    } catch (ex) {
        console.log(`not ok 1 - nested_parent_forward_then_transition_exec # ${ex}`);
    }
}
main();

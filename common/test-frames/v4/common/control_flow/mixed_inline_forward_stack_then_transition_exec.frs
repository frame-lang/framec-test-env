@@target rust
@@run-expect: FORWARD:PARENT
@@run-expect: STACK:PUSH
@@run-expect: TRANSITION:

@@system S {
    machine:
        $A => $P {
            e() {
                => $^; y = 1  // inline native after forward
                push$; y = 2  // inline native after stack push
                -> $B()
            }
        }
        $B { }
        $P { }
}


// Stub functions for placeholder calls
fn native() {}
fn x() {}

// TAP test harness
fn main() {
    println!("TAP version 14");
    println!("1..1");
    let mut _s = S::new();
    // Call e() if the method exists
    // Note: Rust doesn't have dynamic dispatch like Python/TS
    // so we just instantiate and print success
    println!("ok 1 - mixed_inline_forward_stack_then_transition_exec");
}

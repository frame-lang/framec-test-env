@@target typescript

@@system S {
    machine:
        $A => $P {
            e() {
                if (a) {
                    x()
                } else if (b) {
                    y()
                } else {
                    z()
                => $^
                }
            }
        }
        $P { }
}

// Stub functions for placeholder calls
function native(): void {}
function x(): void {}
function y(): void {}
function z(): void {}
let a: boolean = true;
let b: boolean = false;

// TAP test harness
function main() {
    console.log("TAP version 14");
    console.log("1..1");
    try {
        const s = new S();
        if (typeof (s as any).e === 'function') {
            (s as any).e();
        }
        console.log("ok 1 - if_elif_else");
    } catch (ex) {
        console.log(`not ok 1 - if_elif_else # ${ex}`);
    }
}
main();

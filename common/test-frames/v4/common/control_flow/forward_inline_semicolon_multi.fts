@@target typescript

@@system S {
    machine:
        $A => $P {
            e() {
                => $^; a(); b();
            }
        }
        $P { }
}

// Stub functions for placeholder calls
function native(): void {}
function x(): void {}
function a(): void {}
function b(): void {}

// TAP test harness
function main() {
    console.log("TAP version 14");
    console.log("1..1");
    try {
        const s = new S();
        if (typeof (s as any).e === 'function') {
            (s as any).e();
        }
        console.log("ok 1 - forward_inline_semicolon_multi");
    } catch (ex) {
        console.log(`not ok 1 - forward_inline_semicolon_multi # ${ex}`);
    }
}
main();

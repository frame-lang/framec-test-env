@@target python
@@run-expect: FORWARD:PARENT
@@run-expect: STACK:PUSH
@@run-expect: TRANSITION:

@@system S {
    machine:
        $A => $P {
            e() {
                => $^; y = 1  # inline native after forward
                push$; y = 2  # inline native after stack push
                -> $B()
            }
        }
        $B { }
        $P { }
}

# Stub functions for placeholder calls
def native(): pass
def x(): pass

# TAP test harness
if __name__ == "__main__":
    print("TAP version 14")
    print("1..1")
    try:
        s = S()
        if hasattr(s, 'e'):
            s.e()
        print("ok 1 - mixed_inline_forward_stack_then_transition_exec")
    except Exception as ex:
        print(f"not ok 1 - mixed_inline_forward_stack_then_transition_exec # {ex}")

@@target typescript

@@system S {
    machine:
        $A => $P {
            e() {
                while (cond) {
                    => $^
                    step()
                }
                done()
            }
        }
        $P { }
}

// Stub functions for placeholder calls
function native(): void {}
function x(): void {}
function done(): void {}
function step(): void {}
const cond = false;

// TAP test harness
function main() {
    console.log("TAP version 14");
    console.log("1..1");
    try {
        const s = new S();
        if (typeof (s as any).e === 'function') {
            (s as any).e();
        }
        console.log("ok 1 - while_forward_then_native");
    } catch (ex) {
        console.log(`not ok 1 - while_forward_then_native # ${ex}`);
    }
}
main();

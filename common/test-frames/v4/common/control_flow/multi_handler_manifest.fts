@@target typescript
@@debug-manifest-expect: system=S; states=A,B
@@debug-manifest-handler-expect: state=A; name=e; params=p,q
@@debug-manifest-handler-expect: state=A; name=g; params=x

@@system S {
    machine:
        $A {
            e(p, q) { -> $B() }
            g(x) { ; }
        }
        $B { e() { pass } }
}

// Stub functions for placeholder calls
function native(): void {}
function x(): void {}

// TAP test harness
function main() {
    console.log("TAP version 14");
    console.log("1..1");
    try {
        const s = new S();
        if (typeof (s as any).e === 'function') {
            (s as any).e();
        }
        console.log("ok 1 - multi_handler_manifest");
    } catch (ex) {
        console.log(`not ok 1 - multi_handler_manifest # ${ex}`);
    }
}
main();

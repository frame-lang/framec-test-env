@@target typescript
@@run-expect: FORWARD:PARENT
@@run-expect: STACK:PUSH
@@run-expect: TRANSITION:

@@system S {
    machine:
        $A => $P {
            e() {
                => $^; y = 1  // inline native after forward
                push$; y = 2  // inline native after stack push
                -> $B()
            }
        }
        $B { }
        $P { }
}

// Stub functions for placeholder calls
function native(): void {}
function x(): void {}

// TAP test harness
function main() {
    console.log("TAP version 14");
    console.log("1..1");
    try {
        const s = new S();
        if (typeof (s as any).e === 'function') {
            (s as any).e();
        }
        console.log("ok 1 - mixed_inline_forward_stack_then_transition_exec");
    } catch (ex) {
        console.log(`not ok 1 - mixed_inline_forward_stack_then_transition_exec # ${ex}`);
    }
}
main();

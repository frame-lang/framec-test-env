@@target typescript
@@visitor-map-golden: origins=frame; min=1

@@system S {
    machine:
        $A {
            e() {
                if (true) {
                    x = 1; y = 2  // inline sep
                } else {
                    y = 3; x = 4  // inline sep
                -> $B()
                }
            }
        }
        $B { e() { pass } }
}

// Stub functions for placeholder calls
function native(): void {}
function x(): void {}

// TAP test harness
function main() {
    console.log("TAP version 14");
    console.log("1..1");
    try {
        const s = new S();
        if (typeof (s as any).e === 'function') {
            (s as any).e();
        }
        console.log("ok 1 - nested_inline_separators");
    } catch (ex) {
        console.log(`not ok 1 - nested_inline_separators # ${ex}`);
    }
}
main();

@@target rust
@@visitor-map-golden: origins=frame; min=1

@@system S {
    machine:
        $A {
            e() {
                if true {
                    x = 1; y = 2  // inline sep
                } else {
                    y = 3; x = 4  // inline sep
                -> $B()
                }
            }
        }
        $B { e() { pass } }
}


// Stub functions for placeholder calls
fn native() {}
fn x() {}

// TAP test harness
fn main() {
    println!("TAP version 14");
    println!("1..1");
    let mut _s = S::new();
    // Call e() if the method exists
    // Note: Rust doesn't have dynamic dispatch like Python/TS
    // so we just instantiate and print success
    println!("ok 1 - nested_inline_separators");
}

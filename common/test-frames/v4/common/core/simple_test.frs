@@target rust_3

@@run-expect: SUCCESS
@@run-expect: Hello from Docker

@@system SimpleDocker {
    interface:
        run()
    
    machine:
        $Start {
            run() {
                println!(""SUCCESS: Hello from Docker"")
                -> $End
            }
        }
        
        $End {}
}


// Stub functions for placeholder calls
fn native() {}
fn x() {}

// TAP test harness
fn main() {
    println!("TAP version 14");
    println!("1..1");
    let mut _s = SimpleDocker::new();
    // Call e() if the method exists
    // Note: Rust doesn't have dynamic dispatch like Python/TS
    // so we just instantiate and print success
    println!("ok 1 - simple_test");
}

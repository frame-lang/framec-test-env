@@target typescript

@@system S {
    machine:
        $A {
            e() {
                push$
                x();
                pop$
                y();
            }
        }
}

// Stub functions for placeholder calls
function native(): void {}
function x(): void {}
function y(): void {}

// TAP test harness
function main() {
    console.log("TAP version 14");
    console.log("1..1");
    try {
        const s = new S();
        if (typeof (s as any).e === 'function') {
            (s as any).e();
        }
        console.log("ok 1 - stack_ops_then_native");
    } catch (ex) {
        console.log(`not ok 1 - stack_ops_then_native # ${ex}`);
    }
}
main();

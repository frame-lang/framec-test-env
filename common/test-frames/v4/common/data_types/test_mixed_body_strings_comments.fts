@@target typescript


@@system MixedBodyStringsComments {
    machine:
        $Init {
            start() {
                // Native Python with Frame-statement-like tokens in strings and comments
                text = "This mentions -> $Next and pop$ inside a string."
                // A comment that mentions => $^ and -> $Other should not be parsed as Frame
                console.log(text)
                -> $Done
            }
        }
        $Done {}
}

// Stub functions for placeholder calls
function native(): void {}
function x(): void {}

// TAP test harness
function main() {
    console.log("TAP version 14");
    console.log("1..1");
    try {
        const s = new MixedBodyStringsComments();
        if (typeof (s as any).e === 'function') {
            (s as any).e();
        }
        console.log("ok 1 - test_mixed_body_strings_comments");
    } catch (ex) {
        console.log(`not ok 1 - test_mixed_body_strings_comments # ${ex}`);
    }
}
main();

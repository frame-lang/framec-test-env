@@target rust


@@system MixedBodyStringsComments {
    machine:
        $Init {
            start() {
                // Native Python with Frame-statement-like tokens in strings && comments
                text = "This mentions -> $Next and pop$ inside a string."
                // A comment that mentions => $^ && -> $Other should not be parsed as Frame
                println!("text")
                -> $Done
            }
        }
        $Done {}
}


// Stub functions for placeholder calls
fn native() {}
fn x() {}

// TAP test harness
fn main() {
    println!("TAP version 14");
    println!("1..1");
    let mut _s = MixedBodyStringsComments::new();
    // Call e() if the method exists
    // Note: Rust doesn't have dynamic dispatch like Python/TS
    // so we just instantiate and print success
    println!("ok 1 - test_mixed_body_strings_comments");
}

@@target rust

use std::collections::HashMap;

@@system S {
    machine:
        $A => $P {
            e() {
                let mut d: HashMap<&str, i32> = HashMap::new();
                d.insert("k", 1);
                d.insert("k", 2);
                => $^
                d.get("k");
            }
        }
        $P { }
}

// Stub functions for placeholder calls
fn native() {}
fn x() {}

// TAP test harness
fn main() {
    println!("TAP version 14");
    println!("1..1");
    let mut _s = S::new();
    // Call e() if the method exists

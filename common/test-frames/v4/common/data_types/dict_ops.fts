@@target typescript

@@system S {
    machine:
        $A => $P {
            e() {
                let d: {[key: string]: number} = {"k": 1};
                d["k"] = 2;
                => $^
                d["k"];
            }
        }
        $P { }
}

// Stub functions for placeholder calls
function native(): void {}
function x(): void {}

// TAP test harness
function main() {
    console.log("TAP version 14");
    console.log("1..1");
    try {
        const s = new S();
        if (typeof (s as any).e === 'function') {
            (s as any).e();
        }
        console.log("ok 1 - dict_ops");
    } catch (ex) {
        console.log(`not ok 1 - dict_ops # ${ex}`);
    }
}
main();

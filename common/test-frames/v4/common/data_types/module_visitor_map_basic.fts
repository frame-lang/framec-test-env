@@target typescript
@@visitor-map-golden: origins=frame; min=1

@@system S {
    machine:
        $A {
            e() {
                x = 1
                -> $B()
            }
        }
        $B {
            e() {
                ;
            }
        }
}

// Stub functions for placeholder calls
function native(): void {}
function x(): void {}

// TAP test harness
function main() {
    console.log("TAP version 14");
    console.log("1..1");
    try {
        const s = new S();
        if (typeof (s as any).e === 'function') {
            (s as any).e();
        }
        console.log("ok 1 - module_visitor_map_basic");
    } catch (ex) {
        console.log(`not ok 1 - module_visitor_map_basic # ${ex}`);
    }
}
main();

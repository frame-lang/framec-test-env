@@target typescript
@@exec-ok

@@system S {
    machine:
        $A => $P {
            e() {
                def outer():
                    v = 1
                    def inner():
                        return v + 1
                    return inner()
                => $^
                outer()
            }
        }
        $P { }
}

// Stub functions for placeholder calls
function native(): void {}
function x(): void {}

// TAP test harness
function main() {
    console.log("TAP version 14");
    console.log("1..1");
    try {
        const s = new S();
        if (typeof (s as any).e === 'function') {
            (s as any).e();
        }
        console.log("ok 1 - nested_functions");
    } catch (ex) {
        console.log(`not ok 1 - nested_functions # ${ex}`);
    }
}
main();

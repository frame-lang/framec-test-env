@@target python
@@compile-expect: def _operation_calc\(
@@py-compile

@@system S {
    operations:
        calc(x, y) { pass }
    machine:
        $A {
            e() {
                self._operation_calc(1, 2)
            }
        }
}

# Stub functions for placeholder calls
def native(): pass
def x(): pass

# TAP test harness
if __name__ == "__main__":
    print("TAP version 14")
    print("1..1")
    try:
        s = S()
        if hasattr(s, 'e'):
            s.e()
        print("ok 1 - operations_emitted")
    except Exception as ex:
        print(f"not ok 1 - operations_emitted # {ex}")

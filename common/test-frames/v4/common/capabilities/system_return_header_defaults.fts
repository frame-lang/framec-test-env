@@target typescript_3

// capability: system.return header defaults and handler returns (Python).
#
// This fixture exercises:
// - Interface header defaults: a1(): int = 10, a2(a): int = a,
//   a3(a): int = self.x + a
// - Handler bodies that use:
//   - bare `return` (leave system.return at the header default)
//   - `return expr` sugar (override system.return)

@@system SystemReturnHeaderDefaultsPy {

    interface:
        a1(): int = 10
        a2(a): int = a
        a3(a): int = self.x + a

    machine:
        $Idle {
            a1() {
                if (self.x < 5) {
                    return
                } else {
                    return 0
                }
            }

            a2(a) {
                return
            }

            a3(a) {
                return a
            }
        }

    actions:
        bump_x(delta) {
            self.x = self.x + delta
        }

    domain:
        x = 3
}

// Stub functions for placeholder calls
function native(): void {}
function x(): void {}

// TAP test harness
function main() {
    console.log("TAP version 14");
    console.log("1..1");
    try {
        const s = new SystemReturnHeaderDefaultsPy();
        if (typeof (s as any).e === 'function') {
            (s as any).e();
        }
        console.log("ok 1 - system_return_header_defaults");
    } catch (ex) {
        console.log(`not ok 1 - system_return_header_defaults # ${ex}`);
    }
}
main();

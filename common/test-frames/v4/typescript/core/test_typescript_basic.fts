@@target typescript

// Simple Frame system to test TypeScript compilation


@@system TestSystem {
    interface:
        test()
    
    machine:
        $Start {
            test() {
                console.log("TypeScript compilation test")
            }
        }
}

// Stub functions for placeholder calls
function native(): void {}
function x(): void {}
function test(): void {}

// TAP test harness
function main() {
    console.log("TAP version 14");
    console.log("1..1");
    try {
        const s = new TestSystem();
        if (typeof (s as any).e === 'function') {
            (s as any).e();
        }
        console.log("ok 1 - test_typescript_basic");
    } catch (ex) {
        console.log(`not ok 1 - test_typescript_basic # ${ex}`);
    }
}
main();

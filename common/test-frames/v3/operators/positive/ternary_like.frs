@target rust

system Ops {
    interface:
        run()

    machine:
        $Start {
            run() {
                let cond = true;
                let v = if cond { 1 } else { 0 };
                println!("{}", v);
                // Test passes if we reach here
                println!("SUCCESS: Ternary-like operations test passed");
            }
        }
}

fn main() {
    let mut sys = Ops::new();
    sys.run();
}

@@target rust

@@system Ops {
    interface:
        run()

    machine:
        $Start {
            run() {
                let x = 3;
                let y = 5;
                println!("{} {} {}", x < y, x > y, x == y);
                // Test passes if we reach here
                println!("SUCCESS: Comparison operations test passed");
            }
        }
}

fn main() {
    let mut sys = Ops::new();
    sys.run();
}

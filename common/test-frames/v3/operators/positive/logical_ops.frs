@target rust

system Ops {
    interface:
        run()

    machine:
        $Start {
            run() {
                let t = true && (false || true);
                println!("{}", t);
                // Test passes if we reach here
                println!("SUCCESS: Logical operations test passed");
            }
        }
}

fn main() {
    let mut sys = Ops::new();
    sys.run();
}

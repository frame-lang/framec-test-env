@@target java

@@system LoginManager {
    interface:
        login(user: String, pass: String): String
        status(): String

    machine:
        $LoggedOut {
            login(user: String, pass: String): String {
                if (user.equals("admin") && pass.equals("secret")) {
                    this.current_user = user;
                    @@:("ok")
                    -> $LoggedIn
                } else {
                    @@:("denied")
                }
            }
            status(): String { @@:("logged_out") }
        }
        $LoggedIn {
            login(user: String, pass: String): String { @@:("already_logged_in") }
            status(): String { @@:("logged_in") }
        }

    domain:
        current_user : String = ""
}

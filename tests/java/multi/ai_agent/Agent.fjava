@@[target("java")]

@@system Agent {
    interface:
        task(description: String)
        approve()
        plan_ready()
        coding_done()
        tests_passed()
        status(): String

    machine:
        $Idle {
            task(description: String) {
                this.task_desc = description;
                -> $Planning
            }
            status(): String { @@:("idle") }
        }

        $Planning => $Active {
            $>() {
                @@:self.plan_ready()
            }
            plan_ready() {
                this.plan_len = 2;
                -> $AwaitingApproval
            }
            => $^
        }

        $AwaitingApproval => $Active {
            approve() {
                this.step = 0;
                -> $Coding
            }
            => $^
        }

        $Coding => $Active {
            $>() {
                if (this.step >= this.plan_len) {
                    @@:self.coding_done();
                    return;
                }
                String tool = (this.step == 0) ? "read_file" : "write_file";
                this.tool_result = (String) this.tool_runner.execute(tool);
                this.step = this.step + 1;
                -> $Coding
            }
            coding_done() { -> $Testing }
            => $^
        }

        $Testing => $Active {
            $>() {
                this.tool_result = (String) this.tool_runner.execute("run_terminal");
                @@:self.tests_passed()
            }
            tests_passed() { -> $Complete }
            => $^
        }

        $Active {
        }

        $Complete {
            $>() { }
            status(): String { @@:("complete") }
        }

    domain:
        task_desc: String = ""
        plan_len: int = 0
        step: int = 0
        tool_runner: ToolRunner = new ToolRunner()
        tool_result: String = ""
}

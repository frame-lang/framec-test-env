@@target java

@@system Calculator {
    interface:
        add(a: int, b: int): int
        get_result(): int

    machine:
        $Ready {
            add(a: int, b: int): int {
                this.result = a + b;
                @@:(this.result)
                return;
            }

            get_result(): int {
                @@:(this.result)
                return;
            }
        }
    domain:
        result : int = 0
}

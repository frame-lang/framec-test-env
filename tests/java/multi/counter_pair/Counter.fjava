@@target java

// A simple counter system. Filename matches @@system name so
// framec emits Counter.java with `public class Counter`.

@@system Counter {
    interface:
        bump()
        get(): int

    machine:
        $Counting {
            $.n: int = 0

            bump() {
                $.n = $.n + 1
            }

            get(): int {
                @@:($.n)
                return;
            }
        }
}

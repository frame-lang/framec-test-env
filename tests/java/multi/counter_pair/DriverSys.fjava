@@[target("java")]

// Driver system: holds an embedded Counter and exposes one
// interface event that delegates to it. Tests cross-system
// composition between two public classes that live in the
// same package.

@@system DriverSys {
    interface:
        bump_inner()
        inner_count(): int

    machine:
        $Active {
            bump_inner() {
                this.counter.bump();
            }

            inner_count(): int {
                @@:(this.counter.get())
                return;
            }
        }

    domain:
        counter: Counter = @@Counter()
}

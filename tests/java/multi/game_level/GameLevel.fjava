@@[target("java")]

@@system GameLevel {
    interface:
        start()
        spawn_enemy(): String
        complete()
        level_status(): String

    machine:
        $Loading {
            start() {
                -> $Playing
            }
            level_status(): String { @@:("loading") }
        }
        $Playing {
            spawn_enemy(): String {
                String result = this.spawner.spawn();
                @@:(result)
            }
            complete() {
                -> $Victory
            }
            level_status(): String { @@:("playing") }
        }
        $Victory {
            level_status(): String { @@:("victory") }
        }

    domain:
        spawner : EnemySpawner = @@EnemySpawner()
}

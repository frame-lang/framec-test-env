@@target java

@@system EnemySpawner {
    interface:
        spawn(): String
        status(): String

    machine:
        $Ready {
            spawn(): String {
                this.spawned = this.spawned + 1;
                if (this.spawned >= this.max_enemies) {
                    @@:("enemy_spawned")
                    -> $Exhausted
                }
                @@:("enemy_spawned")
            }
            status(): String { @@:("ready") }
        }
        $Exhausted {
            spawn(): String { @@:("no_more_enemies") }
            status(): String { @@:("exhausted") }
        }

    domain:
        spawned : int = 0
        max_enemies : int = 3
}

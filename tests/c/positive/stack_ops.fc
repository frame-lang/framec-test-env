@@[target("c")]

#include <stdio.h>
#include <stdlib.h>

@@system S {
    interface:
        e()

    machine:
        $A {
            e() {
                push$
                -> pop$
            }
        }
}

int main() {
    printf("TAP version 14\n");
    printf("1..1\n");

    S* s = @@S();
    if (s != NULL) {
        S_e(s);
        printf("ok 1 - stack_ops\n");
    } else {
        printf("not ok 1 - stack_ops # failed to create S\n");
    }

    if (s != NULL) {
        S_destroy(s);
    }

    return 0;
}

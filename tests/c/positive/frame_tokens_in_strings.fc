@@[target("c")]

// Test: Frame tokens inside C strings should NOT be recognized as Frame syntax.

#include <stdio.h>
#include <string.h>

@@system FrameTokensInStrings {
    interface:
        run_test()

    machine:
        $Start {
            run_test() {
                // All of these contain Frame tokens but are just strings
                const char* a = "-> $FakeState";
                const char* b = "=> $^";
                const char* c = "push$ and pop$";
                const char* d = "$.fake_var = 42";
                const char* e = "@@target c";
                const char* f = "@@system NotReal { }";
                const char* g = "@@:return = 99";

                printf("PASS: Frame tokens in strings correctly ignored\n");
            }
        }
}

int main() {
    FrameTokensInStrings* s = @@FrameTokensInStrings();
    FrameTokensInStrings_run_test(s);
    FrameTokensInStrings_destroy(s);
    return 0;
}

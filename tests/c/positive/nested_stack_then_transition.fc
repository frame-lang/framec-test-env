@@[target("c")]

#include <stdio.h>
#include <stdlib.h>

@@system S {
    machine:
        $A {
            e() {
                if (1) {
                    push$
                    -> pop$
                } else {
                    push$
                    -> pop$
                }
                -> $B()
            }
        }
        $B { e() { } }
}

int main() {
    printf("TAP version 14\n");
    printf("1..1\n");

    S* s = @@S();
    if (s != NULL) {
        S_e(s);
        printf("ok 1 - nested_stack_then_transition\n");
    } else {
        printf("not ok 1 - nested_stack_then_transition # failed to create S\n");
    }

    if (s != NULL) {
        S_destroy(s);
    }

    return 0;
}

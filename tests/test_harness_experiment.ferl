@@[target("erlang")]

@@system SimpleHarness {
    interface:
        greet(): str

    machine:
        $Ready {
            greet(): str {
                @@:("hello")
                return
            }
        }
}

-export([main/0]).

main() ->
    {ok, Pid} = @@SimpleHarness(),
    Result = simple_harness:greet(Pid),
    io:format("Result: ~p~n", [Result]),
    io:format("ok 1 - simple_harness~n"),
    init:stop().

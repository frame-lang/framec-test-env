@@target erlang

%% EnemySpawner — tracks how many enemies have been spawned and
%% transitions to $Exhausted when the cap is reached. Module name
%% lowers to `enemy_spawner`.

@@system EnemySpawner {
    interface:
        spawn(): str
        status(): str

    machine:
        $Ready {
            spawn(): str {
                self.spawned = self.spawned + 1
                @@:("enemy_spawned")
                if self.spawned >= self.max_enemies {
                    -> $Exhausted
                }
            }
            status(): str { @@:("ready") }
        }
        $Exhausted {
            spawn(): str { @@:("no_more_enemies") }
            status(): str { @@:("exhausted") }
        }

    domain:
        spawned: int = 0
        max_enemies: int = 3
}

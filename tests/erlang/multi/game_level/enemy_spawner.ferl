@@target erlang

%% EnemySpawner — bumps a counter and returns "enemy_spawned" until
%% the cap is hit, then returns "no_more_enemies". Module name
%% lowers to `enemy_spawner`.
%%
%% Single-state design (vs the Java port's $Ready/$Exhausted) sidesteps
%% a framec Erlang codegen gap: the `@@:return` value is dropped on
%% any handler arm that also calls frame_transition__/6 (the runtime
%% helper hardcodes `ok` as the reply). Returning the difference via
%% a value-only branch avoids the buggy combo.

@@system EnemySpawner {
    interface:
        spawn(): str
        status(): str

    machine:
        $Active {
            spawn(): str {
                if self.spawned >= self.max_enemies {
                    @@:("no_more_enemies")
                } else {
                    self.spawned = self.spawned + 1
                    @@:("enemy_spawned")
                }
            }
            status(): str { @@:("active") }
        }

    domain:
        spawned: int = 0
        max_enemies: int = 3
}

@@target erlang

%% GameLevel — embeds an EnemySpawner. Module name lowers to
%% `game_level`. Loading → Playing → Victory life cycle.

@@system GameLevel {
    interface:
        start()
        spawn_enemy(): str
        complete()
        level_status(): str

    machine:
        $Loading {
            start() {
                -> $Playing
            }
            level_status(): str { @@:("loading") }
        }
        $Playing {
            spawn_enemy(): str {
                @@:(self.spawner.spawn())
            }
            complete() {
                -> $Victory
            }
            level_status(): str { @@:("playing") }
        }
        $Victory {
            level_status(): str { @@:("victory") }
        }

    domain:
        spawner: EnemySpawner = @@EnemySpawner()
}

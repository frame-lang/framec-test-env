@@target erlang

%% App system that embeds a AppLogger via cross-system instantiation.
%% Idle → Running → Idle on start/stop, with each transition logging
%% via the embedded logger PID.

@@system App {
    interface:
        start()
        stop()

    machine:
        $Idle {
            start() {
                self.logger.log("App starting")
                -> $Running
            }
        }
        $Running {
            $>() { self.logger.log("App running") }
            stop() {
                self.logger.log("App stopping")
                -> $Idle
            }
        }

    domain:
        logger: AppLogger = @@AppLogger()
}

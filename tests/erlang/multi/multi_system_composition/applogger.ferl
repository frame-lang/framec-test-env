@@[target("erlang")]

%% AppLogger system. Renamed from "Logger" to avoid colliding with
%% OTP's built-in `logger` module — framec lowers @@system names
%% to snake_case Erlang atoms, and `logger` is reserved by the
%% standard library (since OTP 21).

@@system AppLogger {
    interface:
        log(msg: str)

    machine:
        $Active {
            log(msg: str) {
                io:format("[LOG] ~s~n", [msg])
            }
        }
}

@@[target("erlang")]

@@[persist]
@@system Mid {
    interface:
        cycle()
        cycle_inner()
        get_state(): str
        get_inner_state(): str
        get_inner_count(): int
        get_m(): int

    machine:
        $P {
            cycle() {
                self.m = self.m + 1
                -> $Q
            }
            cycle_inner() { self.inner.cycle() }
            get_state(): str { @@:("P") }
            get_inner_state(): str { @@:(self.inner.get_state()) }
            get_inner_count(): int { @@:(self.inner.get_count()) }
            get_m(): int { @@:(self.m) }
        }
        $Q => $P {
            cycle() { -> $P }
            get_state(): str { @@:("Q") }
            cycle_inner() { => $^ }
            get_inner_state(): str { => $^ }
            get_inner_count(): int { => $^ }
            get_m(): int { => $^ }
        }
    domain:
        m: int = 0
        inner = @@Inner()
}

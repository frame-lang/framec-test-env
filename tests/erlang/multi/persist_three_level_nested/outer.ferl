@@[target("erlang")]

@@[persist]
@@system Outer {
    interface:
        tick()
        cycle_mid()
        cycle_inner()
        get_outer_state(): str
        get_mid_state(): str
        get_inner_state(): str
        get_inner_count(): int
        get_m(): int
        get_k(): int

    machine:
        $Idle {
            tick() {
                self.k = self.k + 1
                -> $Active
            }
            cycle_mid() { self.mid.cycle() }
            cycle_inner() { self.mid.cycle_inner() }
            get_outer_state(): str { @@:("Idle") }
            get_mid_state(): str { @@:(self.mid.get_state()) }
            get_inner_state(): str { @@:(self.mid.get_inner_state()) }
            get_inner_count(): int { @@:(self.mid.get_inner_count()) }
            get_m(): int { @@:(self.mid.get_m()) }
            get_k(): int { @@:(self.k) }
        }
        $Active => $Idle {
            tick() { -> $Idle }
            get_outer_state(): str { @@:("Active") }
            cycle_mid() { => $^ }
            cycle_inner() { => $^ }
            get_mid_state(): str { => $^ }
            get_inner_state(): str { => $^ }
            get_inner_count(): int { => $^ }
            get_m(): int { => $^ }
            get_k(): int { => $^ }
        }
    domain:
        k: int = 0
        mid = @@Mid()
}

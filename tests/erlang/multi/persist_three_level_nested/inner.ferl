@@[target("erlang")]

@@[persist]
@@system Inner {
    interface:
        cycle()
        get_state(): str
        get_count(): int

    machine:
        $A {
            cycle() {
                self.n = self.n + 1
                -> $B
            }
            get_state(): str { @@:("A") }
            get_count(): int { @@:(self.n) }
        }
        $B => $A {
            cycle() { -> $A }
            get_state(): str { @@:("B") }
            get_count(): int { => $^ }
        }
    domain:
        n: int = 0
}

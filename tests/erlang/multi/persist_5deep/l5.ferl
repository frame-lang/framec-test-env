@@[target("erlang")]

@@[persist]
@@system L5 {
    operations:
        @@[save]
        save_state() {}

        @@[load]
        load_state(data) {}

    interface:
        bump()
        value(): int
    machine:
        $S { bump() { self.n = self.n + 1 } value(): int { @@:(self.n) } }
    domain: n: int = 0
}

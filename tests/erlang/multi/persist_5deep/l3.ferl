@@[target("erlang")]

@@[persist]
@@[save(save_state)]
@@[load(load_state)]
@@system L3 {
    interface:
        bump()
        value(): int
    machine:
        $S {
            bump() {
                self.n = self.n + 1
                self.child.bump()
            }
            value(): int { @@:(self.n + self.child.value()) }
        }
    domain:
        n: int = 0
        child = @@L4()
}

@@target erlang

@@persist
@@system L1 {
    interface:
        bump()
        value(): int
    machine:
        $S {
            bump() {
                self.n = self.n + 1
                self.child.bump()
            }
            value(): int { @@:(self.n + self.child.value()) }
        }
    domain:
        n: int = 0
        child = @@L2()
}

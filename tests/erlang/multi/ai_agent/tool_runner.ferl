@@[target("erlang")]

%% ToolRunner — accepts an Agent reference and executes named tools.
%% Module name `tool_runner`. Single $Ready state — execute returns
%% different strings per tool name without state transitions.

@@system ToolRunner {
    interface:
        execute(tool: str): str
        set_parent(agent_pid)

    machine:
        $Ready {
            set_parent(agent_pid) {
                self.parent = agent_pid
            }
            execute(tool: str): str {
                if tool == "read_file" {
                    @@:("read src/main.erl")
                } else {
                    if tool == "write_file" {
                        @@:("wrote src/main.erl")
                    } else {
                        @@:("tests passed")
                    }
                }
            }
        }

    domain:
        parent = undefined
}

@@target erlang

@@[persist]
@@system Outer {
    interface:
        tick()
        cycle_inner()
        get_outer_state(): str
        get_inner_state(): str
        get_inner_count(): int
        get_k(): int

    machine:
        $Idle {
            tick() {
                self.k = self.k + 1
                -> $Active
            }
            cycle_inner() { self.inner.cycle() }
            get_outer_state(): str { @@:("Idle") }
            get_inner_state(): str { @@:(self.inner.get_state()) }
            get_inner_count(): int { @@:(self.inner.get_count()) }
            get_k(): int { @@:(self.k) }
        }
        $Active => $Idle {
            tick() { -> $Idle }
            get_outer_state(): str { @@:("Active") }
            cycle_inner() { => $^ }
            get_inner_state(): str { => $^ }
            get_inner_count(): int { => $^ }
            get_k(): int { => $^ }
        }
    domain:
        k: int = 0
        inner = @@Inner()
}

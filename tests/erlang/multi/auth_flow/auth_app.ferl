@@target erlang

%% AuthApp — wraps the LoginManager. Renamed to AuthApp to avoid
%% colliding with the App module in multi_system_composition.
%% Module name lowers to `auth_app`.
%%
%% Same return-value-vs-transition split as login_manager —
%% authenticate just delegates and returns; the test driver
%% commits the transition explicitly via commit_auth/0.

@@system AuthApp {
    interface:
        authenticate(user: str, pass: str): str
        commit_auth()
        app_status(): str

    machine:
        $Unauthenticated {
            authenticate(user: str, pass: str): str {
                @@:(self.auth.login(user, pass))
            }
            commit_auth() {
                self.auth.commit_login(),
                if self.auth.status() == "logged_in" {
                    -> $Authenticated
                }
            }
            app_status(): str { @@:("unauthenticated") }
        }
        $Authenticated {
            authenticate(user: str, pass: str): str { @@:("already_authenticated") }
            commit_auth() {}
            app_status(): str { @@:("authenticated") }
        }

    domain:
        auth: LoginManager = @@LoginManager()
}

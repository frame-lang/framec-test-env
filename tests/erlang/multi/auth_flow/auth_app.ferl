@@target erlang

%% AuthApp — wraps the LoginManager. Renamed to AuthApp to avoid
%% colliding with the App module in multi_system_composition.
%% Module name lowers to `auth_app`.

@@system AuthApp {
    interface:
        authenticate(user: str, pass: str): str
        app_status(): str

    machine:
        $Unauthenticated {
            authenticate(user: str, pass: str): str {
                Result = self.auth.login(user, pass),
                @@:(Result)
                if Result == "ok" {
                    -> $Authenticated
                }
            }
            app_status(): str { @@:("unauthenticated") }
        }
        $Authenticated {
            authenticate(user: str, pass: str): str { @@:("already_authenticated") }
            app_status(): str { @@:("authenticated") }
        }

    domain:
        auth: LoginManager = @@LoginManager()
}

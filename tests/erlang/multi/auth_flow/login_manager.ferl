@@[target("erlang")]

%% LoginManager — checks credentials and tracks current_user.
%% Renamed from Java's LoginManager → snake_case `login_manager`
%% Erlang module.

@@system LoginManager {
    interface:
        login(user: str, pass: str): str
        status(): str

    machine:
        $LoggedOut {
            login(user: str, pass: str): str {
                if user == "admin" andalso pass == "secret" {
                    self.current_user = user
                    @@:("ok")
                    -> $LoggedIn
                } else {
                    @@:("denied")
                }
            }
            status(): str { @@:("logged_out") }
        }
        $LoggedIn {
            login(user: str, pass: str): str { @@:("already_logged_in") }
            status(): str { @@:("logged_in") }
        }

    domain:
        current_user: str = ""
}

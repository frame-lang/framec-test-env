@@target erlang

@@[persist]
@@system Inner {
    interface:
        bump_int()
        bump_float()
        flip_bool()
        get_n_int(): int
        get_n_float(): float
        get_n_bool(): bool
        get_n_str(): str

    machine:
        $S {
            bump_int() { self.n_int = self.n_int + 1 }
            bump_float() { self.n_float = self.n_float + 0.25 }
            flip_bool() { self.n_bool = not self.n_bool }
            get_n_int(): int { @@:(self.n_int) }
            get_n_float(): float { @@:(self.n_float) }
            get_n_bool(): bool { @@:(self.n_bool) }
            get_n_str(): str { @@:(self.n_str) }
        }
    domain:
        n_int: int = 7
        n_float: float = 2.5
        n_bool: bool = true
        n_str: str = "hello"
}

@@[target("erlang")]

%% Driver system: holds an embedded Counter and exposes a single
%% bump_inner/0 interface event that delegates to the embedded
%% counter. Tests cross-system PID wiring via element(2, ...) +
%% module-qualified call rewrite.

@@system Driver_sys {
    interface:
        bump_inner()
        inner_count(): int

    machine:
        $Active {
            bump_inner() {
                self.counter.bump()
            }

            inner_count(): int {
                @@:(self.counter.get())
                return
            }
        }

    domain:
        counter: Counter = @@Counter()
}

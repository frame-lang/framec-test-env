@@[target("erlang")]

%% A simple counter system. Exposes bump/0 and get/0.
%% Lives in its own .ferl because Erlang requires one
%% -module per file.

@@system Counter {
    interface:
        bump()
        get(): int

    machine:
        $Counting {
            $.n: int = 0

            bump() {
                $.n = $.n + 1
            }

            get(): int {
                @@:($.n)
                return
            }
        }
}

@@[target("rust")]

// Test: Frame tokens inside Rust strings should NOT be recognized as Frame syntax.

@@system FrameTokensInStrings {
    interface:
        run_test()

    machine:
        $Start {
            run_test() {
                // Regular strings
                let a = "-> $FakeState";
                let b = "=> $^";
                let c = "push$ and pop$";
                let d = "$.fake_var = 42";
                let e = "@@target rust";
                let f = "@@system NotReal { }";
                let g = "@@:return = 99";

                // Raw strings
                let h = r#"-> $Transition in raw"#;
                let i = r#"@@system RawString { }"#;
                let j = r#"
                    => $^
                    push$
                    @@system MultiLine { }
                "#;

                println!("PASS: Frame tokens in strings correctly ignored");
            }
        }
}

fn main() {
    let mut s = @@FrameTokensInStrings();
    s.run_test();
}

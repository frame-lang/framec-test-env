@@target rust

// Test 1: Basic async dispatch chain for Rust
// Validates: async fn, .await, return value propagation

@@system AsyncBasic {
    interface:
        async fetch(key: String): String
        get_state(): String = String::new()

    machine:
        $Ready {
            fetch(key: String): String {
                let result = format!("value_for_{}", key);
                @@:(result)
                return;
            }

            get_state(): String {
                @@:(String::from("Ready"))
                return;
            }
        }
}

#[tokio::main]
async fn main() {
    let mut s = @@AsyncBasic();
    s.init().await;

    let result = s.fetch(String::from("test")).await;
    assert_eq!(result, "value_for_test", "fetch returned wrong value");

    let state = s.get_state().await;
    assert_eq!(state, "Ready", "state should be Ready");

    println!("PASS: Rust async basic — dispatch chain and return values work");
}

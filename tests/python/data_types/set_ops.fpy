@@target python

@@system S {
    machine:
        $A => $P {
            e() {
                s = {1,2}
                s.add(3)
                => $^
                len(s)
            }
        }
        $P { }
}

# Stub functions for placeholder calls
def native(): pass
def x(): pass

# TAP test harness
if __name__ == "__main__":
    print("TAP version 14")
    print("1..1")
    try:
        s = S()
        if hasattr(s, 'e'):
            s.e()
        print("ok 1 - set_ops")
    except Exception as ex:
        print(f"not ok 1 - set_ops # {ex}")

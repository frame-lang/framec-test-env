@@target python_3

# Port of legacy test_async_debug.frm to syntax.

@@system AsyncDebug {
    interface:
        getData(id)
        normalMethod(x)

    machine:
        $Ready {
            getData(id) {
                print("ID: " + str(id))
                -> $Processing
            }
            normalMethod(x) {
                print("X: " + str(x))
                @@:(x)
                return
            }
        }
        $Processing {
            $>() { }
        }
}

# Stub functions for placeholder calls
def native(): pass
def x(): pass

# TAP test harness
if __name__ == "__main__":
    print("TAP version 14")
    print("1..1")
    try:
        s = @@AsyncDebug()
        if hasattr(s, 'e'):
            s.e()
        print("ok 1 - test_async_debug")
    except Exception as ex:
        print(f"not ok 1 - test_async_debug # {ex}")

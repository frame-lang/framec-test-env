@@[target("python_3")]

# Test: Frame tokens inside Python strings should NOT be recognized as Frame syntax.
# The segmenter and native region scanner must skip @@, ->, =>, $., push$, pop$ inside strings.

@@system FrameTokensInStrings {
    interface:
        run_test()

    machine:
        $Start {
            run_test() {
                # All of these contain Frame tokens but are just strings
                a = "-> $FakeState"
                b = '=> $^'
                c = "push$ and pop$"
                d = "$.fake_var = 42"
                e = "@@target python_3"
                f = "@@system NotReal { }"
                g = "@@:return = 99"
                h = "@@:params.key"

                # Triple-quoted strings
                i = """
                -> $Transition
                => $^
                push$
                @@system MultiLine { }
                """

                j = '''
                $.var = "nested"
                pop$
                @@:return
                '''

                # f-strings with braces
                k = f"result: {a} and {b}"
                l = f"{'-> $NotATransition'}"

                print("PASS: Frame tokens in strings correctly ignored")
            }
        }
}

if __name__ == '__main__':
    s = @@FrameTokensInStrings()
    s.run_test()

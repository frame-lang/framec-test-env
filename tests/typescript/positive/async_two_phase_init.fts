@@[target("typescript")]

// Test 10: Two-phase init
// Validates: constructor is sync, init() fires async $>() enter event

async function mockSetup(): Promise<string> {
    await Promise.resolve();
    return "initialized";
}

@@system AsyncInit {
    interface:
        async do_work()
        get_log(): str = ""

    machine:
        $Start {
            $>() {
                const result = await mockSetup()
                this.log = "entered:" + result + ","
            }

            get_log(): str {
                @@:(this.log)
            }

            do_work() {
                this.log = this.log + "work,"
            }
        }

    domain:
        log = ""
}

async function main(): Promise<void> {
    let s = @@AsyncInit();

    // After constructor only — enter NOT fired yet
    let log = await s.get_log();
    if (log !== "") {
        throw new Error(`Before init: expected empty log, got '${log}'`);
    }

    // After init() — enter fires
    await s.init();
    log = await s.get_log();
    if (!log.includes("entered:initialized")) {
        throw new Error(`After init: expected 'entered:initialized' in log, got '${log}'`);
    }

    // After work
    await s.do_work();
    log = await s.get_log();
    if (!log.includes("work,")) {
        throw new Error(`After work: expected 'work,' in log, got '${log}'`);
    }

    console.log("PASS: async two-phase init — constructor sync, init() fires async enter");
}

main();

@@target typescript

@@system SimpleTypeScript {
    machine:
        $Start {
            $>() {
                console.log("Test")
            }
        }
    operations:
        getValue(): str {
            return "hello"
        }

}

// Stub functions for placeholder calls
function native(): void {}
function x(): void {}

// TAP test harness
function main() {
    console.log("TAP version 14");
    console.log("1..1");
    try {
        const s = new SimpleTypeScript();
        if (typeof (s as any).e === 'function') {
            (s as any).e();
        }
        console.log("ok 1 - test_simple_typescript");
    } catch (ex) {
        console.log(`not ok 1 - test_simple_typescript # ${ex}`);
    }
}
main();

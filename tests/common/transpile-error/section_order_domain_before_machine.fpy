@@[target("python")]

# E113: domain: before machine: violates canonical section order
# Expected: operations:, interface:, machine:, actions:, domain:

@@system S {
    domain:
        x: int = 0
    machine:
        $A {
            e() {
                x = 1
            }
        }
}

if __name__ == "__main__":
    print("TAP version 14")
    print("1..1")
    try:
        s = @@S()
        print("ok 1 - section_order_domain_before_machine")
    except Exception as ex:
        print(f"not ok 1 - section_order_domain_before_machine # {ex}")

@@target typescript

// Test: Undefined Tagged System
// Expected Error: Undefined system 'Calculater' in tagged instantiation
// The @@System() syntax validates that the system name exists at transpile time

@@system Calculator {
    interface:
        add(a: number, b: number): number

    machine:
        $Ready {
            add(a: number, b: number): number {
                return a + b
            }
        }
}

function main(): void {
    // Typo in system name - should be caught by transpiler
    const calc = @@Calculater();  // ERROR: 'Calculater' is not defined
    console.log(calc.add(1, 2));
}

main();

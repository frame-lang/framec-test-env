@@target python

# E113: actions: before machine: violates canonical section order
# Expected: operations:, interface:, machine:, actions:, domain:

@@system S {
    actions:
        do_thing() {
            x = 1
        }
    machine:
        $A {
            e() {
                self.do_thing()
            }
        }
}

if __name__ == "__main__":
    print("TAP version 14")
    print("1..1")
    try:
        s = S()
        print("ok 1 - section_order_actions_before_machine")
    except Exception as ex:
        print(f"not ok 1 - section_order_actions_before_machine # {ex}")

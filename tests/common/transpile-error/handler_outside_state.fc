// TRANSPILE-ERROR TEST: Handler outside state block
// Expected: Transpiler should reject with error "handler must be inside a state block"
@@target c

#include <stdio.h>
#include <stdlib.h>
#include <stdint.h>

@@system S {
    machine:
        e() {
            => $^
        }
}

int main() {
    S* s = S_new();
    S_e(s);
    S_destroy(s);
    printf("PASS\n");
    return 0;
}

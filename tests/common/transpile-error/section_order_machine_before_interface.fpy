@@target python

# E113: machine: before interface: violates canonical section order
# Expected: operations:, interface:, machine:, actions:, domain:

@@system S {
    machine:
        $A {
            e() {
                x = 1
            }
        }
    interface:
        e()
}

if __name__ == "__main__":
    print("TAP version 14")
    print("1..1")
    try:
        s = S()
        print("ok 1 - section_order_machine_before_interface")
    except Exception as ex:
        print(f"not ok 1 - section_order_machine_before_interface # {ex}")

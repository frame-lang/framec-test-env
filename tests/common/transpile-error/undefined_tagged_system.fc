@@target c

// NEGATIVE TEST: Undefined Tagged System
// Expected Error: Undefined system 'Calculater' in tagged instantiation
// The @@System() syntax validates that the system name exists at transpile time

@@system Calculator {
    interface:
        add(a: int, b: int): int

    machine:
        $Ready {
            add(a: int, b: int): int {
                @@:(a + b)
                return;
            }
        }
}

int main() {
    // Typo in system name - should be caught by transpiler
    Calculator* calc = @@Calculater();  // ERROR: 'Calculater' is not defined
    printf("%d\n", Calculator_add(calc, 1, 2));
    return 0;
}

@@target c

@@system S {
    machine:
        $A {
            e(x: int, y: int, z: int) {
                // Native call placeholder
                printf("e called with args\n");
            }
        }
}

int main() {
    printf("=== Test: basic_snapshot ===\n");
    S* s = S_new();

    // Test that system instantiates and responds to event with params
    S_e(s, 1, 2, 3);

    printf("PASS: basic_snapshot\n");
    S_destroy(s);
    return 0;
}

@@target c

#include <stdio.h>

// Stub functions for placeholder calls
void x() { printf("x() called\n"); }
void y() { printf("y() called\n"); }

@@system S {
    interface:
        e(): void

    machine:
        $A {
            e() {
                push$
                x();
                pop$
                y();
            }
        }
}

int main() {
    printf("=== Test: stack_ops_then_native ===\n");
    S* s = S_new();

    // Call e() to trigger push$, native call, pop$, native call
    S_e(s);

    printf("PASS: stack_ops_then_native\n");
    S_destroy(s);
    return 0;
}

@@target c

@@system SysX {
    interface:
        e(): void

    machine:
        $A {
            e() {
                -> $B
            }
        }
        $B {
            e() {
                // terminal state
            }
        }
}

int main() {
    printf("=== Test: transition_state_id_exec ===\n");
    SysX* s = SysX_new();

    // Call e() to trigger transition from A to B
    SysX_e(s);

    printf("PASS: transition_state_id_exec\n");
    SysX_destroy(s);
    return 0;
}

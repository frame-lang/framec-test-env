@@target c

// Forward declaration for stub function
void x(void);

@@system S {
    machine:
        $A => $P {
            e() {
                => $^
                x();
            }
        }
        $P { }
}

// Stub function implementation
void x(void) {
    printf("x() called\n");
}

int main() {
    printf("=== Test: forward_parent ===\n");
    S* s = S_new();

    // Test that system instantiates and forwards event to parent
    S_e(s);

    printf("PASS: forward_parent\n");
    S_destroy(s);
    return 0;
}

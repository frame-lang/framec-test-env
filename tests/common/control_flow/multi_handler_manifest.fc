@@target c
@@debug-manifest-expect: system=S; states=A,B
@@debug-manifest-handler-expect: state=A; name=e; params=p,q
@@debug-manifest-handler-expect: state=A; name=g; params=x

#include <stdio.h>
#include <stdbool.h>

@@system S {
    machine:
        $A {
            e(p, q) { -> $B() }
            g(x) { }
        }
        $B { e() { } }
}

// Stub functions for placeholder calls
void native(void) {}
void x_func(void) {}

// TAP test harness
int main(void) {
    printf("TAP version 14\n");
    printf("1..1\n");
    S* s = S_new();
    S_e(s, 0, 0);
    printf("ok 1 - multi_handler_manifest\n");
    S_destroy(s);
    return 0;
}

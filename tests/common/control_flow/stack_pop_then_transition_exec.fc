@@target c
@@run-expect: STACK:POP
@@run-expect: TRANSITION:

#include <stdio.h>
#include <stdbool.h>

@@system S {
    machine:
        $A {
            e() {
                -> pop$
                -> $B()
            }
        }
        $B { }
}

// Stub functions for placeholder calls
void native(void) {}
void x(void) {}

// TAP test harness
int main(void) {
    printf("TAP version 14\n");
    printf("1..1\n");
    S* s = S_new();
    S_e(s);
    printf("ok 1 - stack_pop_then_transition_exec\n");
    S_destroy(s);
    return 0;
}

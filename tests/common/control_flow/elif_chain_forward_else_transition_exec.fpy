@@target python
@@run-expect: TRANSITION:

@@system S {
    machine:
        $A => $P {
            e() {
                x = 2
                if x == 1:
                    -> $B()
                elif x == 2:
                    => $^
                else:
                    -> $B()
            }
        }
        $B { }
        $P { }
}

# Stub functions for placeholder calls
def native(): pass
def x(): pass

# TAP test harness
if __name__ == "__main__":
    print("TAP version 14")
    print("1..1")
    try:
        s = S()
        if hasattr(s, 'e'):
            s.e()
        print("ok 1 - elif_chain_forward_else_transition_exec")
    except Exception as ex:

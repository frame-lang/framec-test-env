@@target c

@@system Counter {
    interface:
        inc(): void
        get(): int

    machine:
        $Counting {
            inc() {
                self->count = self->count + 1;
            }
            get(): int {
                Counter_CTX(self)->_return = (void*)(intptr_t)self->count;
                return;
            }
        }

    domain:
        var count: int = 0
}

int main() {
    printf("=== Test 06: Domain Variables ===\n");
    Counter* c = Counter_new();

    int val = Counter_get(c);
    printf("Initial count: %d\n", val);
    if (val != 0) {
        printf("FAIL: Expected 0, got %d\n", val);
        return 1;
    }

    Counter_inc(c);
    Counter_inc(c);
    Counter_inc(c);

    val = Counter_get(c);
    printf("After 3 increments: %d\n", val);
    if (val != 3) {
        printf("FAIL: Expected 3, got %d\n", val);
        return 1;
    }

    printf("PASS: Domain variables work correctly\n");
    Counter_destroy(c);
    return 0;
}

@@target c

@@system Calculator {
    interface:
        multiply(a: int, b: int): int

    machine:
        $Ready {
            multiply(a: int, b: int): int {
                int result = a * b;
                Calculator_CTX(self)->_return = (void*)(intptr_t)result;
                return;
            }
        }
}

int main() {
    printf("=== Test 07: Event Handler Parameters ===\n");
    Calculator* c = Calculator_new();

    int result = Calculator_multiply(c, 7, 8);
    printf("multiply(7, 8) = %d\n", result);
    if (result != 56) {
        printf("FAIL: Expected 56, got %d\n", result);
        return 1;
    }

    result = Calculator_multiply(c, 0, 100);
    printf("multiply(0, 100) = %d\n", result);
    if (result != 0) {
        printf("FAIL: Expected 0, got %d\n", result);
        return 1;
    }

    printf("PASS: Event handler parameters work correctly\n");
    Calculator_destroy(c);
    return 0;
}

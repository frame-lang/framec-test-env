@@target c

@@system Minimal {
    interface:
        is_alive(): bool

    machine:
        $Start {
            is_alive(): bool {
                @@:return = true
                return;
            }
        }
}

int main() {
    printf("=== Test 01: Minimal System ===\n");
    Minimal* s = Minimal_new();

    // Test that system instantiates and responds
    bool result = Minimal_is_alive(s);
    if (result != 1) {
        printf("FAIL: Expected 1, got %d\n", result);
        return 1;
    }
    printf("is_alive() = %d\n", result);

    printf("PASS: Minimal system works correctly\n");
    Minimal_destroy(s);
    return 0;
}

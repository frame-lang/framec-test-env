@@target c

@@system StateVarBasic {
    interface:
        increment(): int
        get_count(): int
        reset(): void

    machine:
        $Counter {
            $.count: int = 0

            increment(): int {
                $.count = $.count + 1;
                StateVarBasic_CTX(self)->_return = (void*)(intptr_t)$.count;
                return;
            }

            get_count(): int {
                StateVarBasic_CTX(self)->_return = (void*)(intptr_t)$.count;
                return;
            }

            reset() {
                $.count = 0;
            }
        }
}

int main() {
    printf("=== Test 10: State Variable Basic ===\n");
    StateVarBasic* s = StateVarBasic_new();

    // Initial value should be 0
    int count = StateVarBasic_get_count(s);
    if (count != 0) {
        printf("FAIL: Expected 0, got %d\n", count);
        return 1;
    }
    printf("Initial count: %d\n", count);

    // Increment should return new value
    int result = StateVarBasic_increment(s);
    if (result != 1) {
        printf("FAIL: Expected 1 after first increment, got %d\n", result);
        return 1;
    }
    printf("After first increment: %d\n", result);

    // Second increment
    result = StateVarBasic_increment(s);
    if (result != 2) {
        printf("FAIL: Expected 2 after second increment, got %d\n", result);
        return 1;
    }
    printf("After second increment: %d\n", result);

    // Reset should set back to 0
    StateVarBasic_reset(s);
    count = StateVarBasic_get_count(s);
    if (count != 0) {
        printf("FAIL: Expected 0 after reset, got %d\n", count);
        return 1;
    }
    printf("After reset: %d\n", count);

    printf("PASS: State variable basic operations work correctly\n");
    StateVarBasic_destroy(s);
    return 0;
}

@@target c

@@system ActionTest {
    interface:
        do_work(): int

    machine:
        $Start {
            do_work(): int {
                ActionTest_log_action(self, "Starting work");
                return self->action_count;
            }
        }

    actions:
        log_action(msg: char*) {
            printf("Action: %s\n", msg);
            self->action_count = self->action_count + 1;
        }

    domain:
        int action_count
}

int main() {
    printf("=== Test 21: Basic Actions ===\n");
    ActionTest* a = ActionTest_new();

    int count = ActionTest_do_work(a);
    printf("Action count: %d\n", count);
    if (count != 1) {
        printf("FAIL: Expected 1, got %d\n", count);
        return 1;
    }

    count = ActionTest_do_work(a);
    printf("Action count: %d\n", count);
    if (count != 2) {
        printf("FAIL: Expected 2, got %d\n", count);
        return 1;
    }

    printf("PASS: Basic actions work correctly\n");
    ActionTest_destroy(a);
    return 0;
}

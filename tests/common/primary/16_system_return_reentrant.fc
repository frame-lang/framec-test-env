@@target c

// Tests that nested interface calls maintain separate return contexts
// NOTE: This test uses string concatenation which is complex in C.
// Using integer-based testing instead.

@@system SystemReturnReentrantTest {
    interface:
        outer_call(): int
        inner_call(): int
        nested_call(): int
        get_log_count(): int

    machine:
        $Start {
            $.log_count: int = 0

            outer_call(): int {
                $.log_count = $.log_count + 1;  // "outer_start"
                // Call inner method - this creates nested return context
                int inner_result = SystemReturnReentrantTest_inner_call(self);
                $.log_count = $.log_count + 1;  // "outer_after_inner"
                // Our return should be independent of inner's return
                // Return: 100 + inner_result (which is 10)
                SystemReturnReentrantTest_CTX(self)->_return = (void*)(intptr_t)(100 + inner_result);
                return;
            }

            inner_call(): int {
                $.log_count = $.log_count + 1;  // "inner"
                SystemReturnReentrantTest_CTX(self)->_return = (void*)(intptr_t)10;
                return;
            }

            nested_call(): int {
                $.log_count = $.log_count + 1;  // "nested_start"
                // Two levels of nesting
                int result1 = SystemReturnReentrantTest_inner_call(self);
                int result2 = SystemReturnReentrantTest_outer_call(self);
                $.log_count = $.log_count + 1;  // "nested_end"
                // Return: 1000 + result1 (10) + result2 (110) = 1120
                SystemReturnReentrantTest_CTX(self)->_return = (void*)(intptr_t)(1000 + result1 + result2);
                return;
            }

            get_log_count(): int {
                SystemReturnReentrantTest_CTX(self)->_return = (void*)(intptr_t)$.log_count;
                return;
            }
        }
}

int main() {
    printf("=== Test 16: System Return Reentrant (Nested Calls) ===\n");

    // Test 1: Simple inner call
    SystemReturnReentrantTest* s1 = SystemReturnReentrantTest_new();
    int result = SystemReturnReentrantTest_inner_call(s1);
    if (result != 10) {
        printf("FAIL: Expected 10, got %d\n", result);
        return 1;
    }
    printf("1. inner_call() = %d\n", result);
    SystemReturnReentrantTest_destroy(s1);

    // Test 2: Outer calls inner - return contexts should be separate
    SystemReturnReentrantTest* s2 = SystemReturnReentrantTest_new();
    result = SystemReturnReentrantTest_outer_call(s2);
    // outer returns 100 + inner_result(10) = 110
    if (result != 110) {
        printf("FAIL: Expected 110, got %d\n", result);
        return 1;
    }
    int log_count = SystemReturnReentrantTest_get_log_count(s2);
    // outer_start(1) + inner(1) + outer_after_inner(1) = 3
    if (log_count != 3) {
        printf("FAIL: Expected log_count=3, got %d\n", log_count);
        return 1;
    }
    printf("2. outer_call() = %d, log_count = %d\n", result, log_count);
    SystemReturnReentrantTest_destroy(s2);

    // Test 3: Deeply nested calls
    SystemReturnReentrantTest* s3 = SystemReturnReentrantTest_new();
    result = SystemReturnReentrantTest_nested_call(s3);
    // nested_call returns: 1000 + inner(10) + outer(110) = 1120
    if (result != 1120) {
        printf("FAIL: Expected 1120, got %d\n", result);
        return 1;
    }
    printf("3. nested_call() = %d\n", result);
    SystemReturnReentrantTest_destroy(s3);

    printf("PASS: System return reentrant (nested calls) works correctly\n");
    return 0;
}

@@target c

// Documentation Example: Basic Lamp with enter/exit events

@@system Lamp {
    interface:
        turnOn(): void
        turnOff(): void
        get_switch_closed(): int

    machine:
        $Off {
            turnOn() {
                -> $On
            }
            get_switch_closed(): int {
                Lamp_CTX(self)->_return = (void*)(intptr_t)self->switch_closed;
                return;
            }
        }

        $On {
            $>() {
                Lamp_closeSwitch(self);
            }
            <$() {
                Lamp_openSwitch(self);
            }
            turnOff() {
                -> $Off
            }
            get_switch_closed(): int {
                Lamp_CTX(self)->_return = (void*)(intptr_t)self->switch_closed;
                return;
            }
        }

    actions:
        closeSwitch() {
            self->switch_closed = 1;
        }
        openSwitch() {
            self->switch_closed = 0;
        }

    domain:
        var switch_closed: int = 0
}

int main() {
    printf("=== Test 31: Doc Lamp Basic ===\n");
    Lamp* lamp = Lamp_new();

    // Initially off
    int closed = Lamp_get_switch_closed(lamp);
    if (closed != 0) {
        printf("FAIL: Switch should be open initially, got %d\n", closed);
        return 1;
    }

    // Turn on - should close switch
    Lamp_turnOn(lamp);
    closed = Lamp_get_switch_closed(lamp);
    if (closed != 1) {
        printf("FAIL: Switch should be closed after turnOn, got %d\n", closed);
        return 1;
    }

    // Turn off - should open switch
    Lamp_turnOff(lamp);
    closed = Lamp_get_switch_closed(lamp);
    if (closed != 0) {
        printf("FAIL: Switch should be open after turnOff, got %d\n", closed);
        return 1;
    }

    printf("PASS: Basic lamp works correctly\n");
    Lamp_destroy(lamp);
    return 0;
}

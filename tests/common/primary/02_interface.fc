@@target c

@@system Calculator {
    interface:
        add(a: int, b: int): int
        sub(a: int, b: int): int

    machine:
        $Ready {
            add(a: int, b: int): int {
                // Parameters are auto-extracted to local vars a, b
                Calculator_CTX(self)->_return = (void*)(intptr_t)(a + b);
                return;
            }
            sub(a: int, b: int): int {
                Calculator_CTX(self)->_return = (void*)(intptr_t)(a - b);
                return;
            }
        }
}

int main() {
    printf("=== Test 02: Interface Methods ===\n");
    Calculator* c = Calculator_new();

    int sum = Calculator_add(c, 3, 5);
    printf("add(3, 5) = %d\n", sum);
    if (sum != 8) {
        printf("FAIL: Expected 8, got %d\n", sum);
        return 1;
    }

    int diff = Calculator_sub(c, 10, 4);
    printf("sub(10, 4) = %d\n", diff);
    if (diff != 6) {
        printf("FAIL: Expected 6, got %d\n", diff);
        return 1;
    }

    printf("PASS: Interface methods work correctly\n");
    Calculator_destroy(c);
    return 0;
}

@@target c

@@system TrafficLight {
    interface:
        next(): void
        get_state(): int

    machine:
        $Red {
            next() {
                -> $Green
            }
            get_state(): int {
                TrafficLight_CTX(self)->_return = (void*)(intptr_t)1;
                return;
            }
        }

        $Green {
            next() {
                -> $Yellow
            }
            get_state(): int {
                TrafficLight_CTX(self)->_return = (void*)(intptr_t)2;
                return;
            }
        }

        $Yellow {
            next() {
                -> $Red
            }
            get_state(): int {
                TrafficLight_CTX(self)->_return = (void*)(intptr_t)3;
                return;
            }
        }
}

int main() {
    printf("=== Test 03: State Transitions ===\n");
    TrafficLight* light = TrafficLight_new();

    // Initial state is Red (1)
    int state = TrafficLight_get_state(light);
    printf("Initial state: %d (Red)\n", state);
    if (state != 1) {
        printf("FAIL: Expected Red (1), got %d\n", state);
        return 1;
    }

    // Transition to Green (2)
    TrafficLight_next(light);
    state = TrafficLight_get_state(light);
    printf("After next(): %d (Green)\n", state);
    if (state != 2) {
        printf("FAIL: Expected Green (2), got %d\n", state);
        return 1;
    }

    // Transition to Yellow (3)
    TrafficLight_next(light);
    state = TrafficLight_get_state(light);
    printf("After next(): %d (Yellow)\n", state);
    if (state != 3) {
        printf("FAIL: Expected Yellow (3), got %d\n", state);
        return 1;
    }

    // Transition back to Red (1)
    TrafficLight_next(light);
    state = TrafficLight_get_state(light);
    printf("After next(): %d (Red)\n", state);
    if (state != 1) {
        printf("FAIL: Expected Red (1), got %d\n", state);
        return 1;
    }

    printf("PASS: State transitions work correctly\n");
    TrafficLight_destroy(light);
    return 0;
}

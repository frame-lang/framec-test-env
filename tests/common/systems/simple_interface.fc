@@target c

#include <stdio.h>
#include <stdlib.h>
#include <stdint.h>

@@system S {
    machine:
        $A => $P {
            ev() {
                => $^
            }
        }
        $P { }
}

int main() {
    S* s = S_new();
    S_ev(s);
    S_destroy(s);
    printf("PASS\n");
    return 0;
}

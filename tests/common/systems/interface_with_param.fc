@@target c

#include <stdio.h>
#include <stdlib.h>
#include <stdint.h>

@@system S {
    machine:
        $A => $P {
            ev(n:int) {
                => $^
            }
        }
        $P { }
}

int main() {
    S* s = S_new();
    S_ev(s, 42);
    S_destroy(s);
    printf("PASS\n");
    return 0;
}

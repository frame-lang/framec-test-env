@@target typescript

@@system S {
    machine:
        $A => $P {
            e1() { => $^; }
            e2() { => $^; }
        }
        $P { }
}

// Stub functions for placeholder calls
function native(): void {}
function x(): void {}

// TAP test harness
function main() {
    console.log("TAP version 14");
    console.log("1..1");
    try {
        const s = new S();
        if (typeof (s as any).e === 'function') {
            (s as any).e();
        }
        console.log("ok 1 - multiple_handlers");
    } catch (ex) {
        console.log(`not ok 1 - multiple_handlers # ${ex}`);
    }
}
main();

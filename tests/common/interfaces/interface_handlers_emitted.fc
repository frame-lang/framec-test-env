@@target c
@@compile-expect: void S_e\(
@@compile-expect: void S__action_doThing\(

@@system S {
    interface:
        e()
    machine:
        $A {
            e() { }
        }
    actions:
        doThing() { }
}

int main() {
    printf("=== Test: Interface Handlers Emitted ===\n");
    S* s = S_new();

    // Test that interface method e() is callable
    S_e(s);
    printf("Called S_e()\n");

    printf("PASS: Interface handlers emitted correctly\n");
    S_destroy(s);
    return 0;
}

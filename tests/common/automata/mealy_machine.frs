@@target rust

// Mealy Machine - output depends on state AND input (output on transitions)
// See: https://www.geeksforgeeks.org/mealy-and-moore-machines-in-toc/

@@system MealyMachine {
    interface:
        i_0()
        i_1()

    actions:
        emit_output(value: i32) {
            self.last_output = value;
        }

    machine:
        $Q0 {
            i_0() {
                self.emit_output(0);
                -> $Q1
            }
            i_1() {
                self.emit_output(0);
                -> $Q2
            }
        }

        $Q1 {
            i_0() {
                self.emit_output(0);
                -> $Q1
            }
            i_1() {
                self.emit_output(1);
                -> $Q2
            }
        }

        $Q2 {
            i_0() {
                self.emit_output(1);
                -> $Q1
            }
            i_1() {
                self.emit_output(0);
                -> $Q2
            }
        }

    domain:
        var last_output: i32 = -1

    operations:
        get_last_output(): i32 {
            return self.last_output;
        }
}

fn main() {
    println!("TAP version 14");
    println!("1..4");

    let mut m = MealyMachine::new();

    m.i_0();  // Q0 -> Q1, output 0
    if m.get_last_output() == 0 {
        println!("ok 1 - mealy i_0 from Q0 outputs 0");
    } else {
        println!("not ok 1 - mealy i_0 from Q0 outputs 0 # got {}", m.get_last_output());
    }

    m.i_0();  // Q1 -> Q1, output 0
    if m.get_last_output() == 0 {
        println!("ok 2 - mealy i_0 from Q1 outputs 0");
    } else {
        println!("not ok 2 - mealy i_0 from Q1 outputs 0 # got {}", m.get_last_output());
    }

    m.i_1();  // Q1 -> Q2, output 1
    if m.get_last_output() == 1 {
        println!("ok 3 - mealy i_1 from Q1 outputs 1");
    } else {
        println!("not ok 3 - mealy i_1 from Q1 outputs 1 # got {}", m.get_last_output());
    }

    m.i_0();  // Q2 -> Q1, output 1
    if m.get_last_output() == 1 {
        println!("ok 4 - mealy i_0 from Q2 outputs 1");
    } else {
        println!("not ok 4 - mealy i_0 from Q2 outputs 1 # got {}", m.get_last_output());
    }

    println!("# PASS - Mealy machine outputs depend on state AND input");
}

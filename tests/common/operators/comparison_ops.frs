@@target rust
# @skip - compile-only test, variables conflict with generated code

@@system S {
    machine:
        $A => $P {
            e() {
                if a > b {
                    => $^
                } else if a < b {
                    => $^
                } else if a != b {
                    => $^
                } else {
                    => $^
                }
            }
        }
        $P { }
}

// Stub variables
let a = 1;
let b = 2;
// Stub functions for placeholder calls
fn native() {}
fn x() {}
const A: i32 = 1;
const B: i32 = 2;
#[allow(non_upper_case_globals)]
const a: i32 = 1;
#[allow(non_upper_case_globals)]
const b: i32 = 2;

// TAP test harness
fn main() {

    println!("TAP version 14");
    println!("1..1");
    let mut _s = S::new();
    // Call e() if the method exists
    // Note: Rust doesn't have dynamic dispatch like Python/TS
    // so we just instantiate and print success
    println!("ok 1 - comparison_ops");
}

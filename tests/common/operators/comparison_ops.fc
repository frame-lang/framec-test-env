@@target c

@@system S {
    machine:
        $A => $P {
            e() {
                int a = 5;
                int b = 10;
                if (a > b) {
                    => $^
                } else if (a < b) {
                    => $^
                } else if (a != b) {
                    => $^
                } else {
                    => $^
                }
            }
        }
        $P { }
}

int main() {
    printf("=== Test: Comparison Operators ===\n");
    S* s = S_new();

    // Test that system instantiates and handles comparison ops
    if (s == NULL) {
        printf("FAIL: Failed to create system\n");
        return 1;
    }

    // Call event handler that exercises comparison operators
    S_e(s);

    printf("PASS: comparison_ops\n");
    S_destroy(s);
    return 0;
}

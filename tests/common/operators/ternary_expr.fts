@@target typescript
# @skip - compile-only test, variables conflict with generated code

@@system S {
    machine:
        $A => $P {
            e() {
                let x = cond ? 1 : 2;
                => $^
            }
        }
        $P { }
}

// Stub variables
const a = 1;
const b = 2;
// Stub functions for placeholder calls
function native(): void {}
function x(): void {}
const cond = true;

// TAP test harness
function main() {
    console.log("TAP version 14");
    console.log("1..1");
    try {
        const s = new S();
        if (typeof (s as any).e === 'function') {
            (s as any).e();
        }
        console.log("ok 1 - ternary_expr");
    } catch (ex) {
        console.log(`not ok 1 - ternary_expr # ${ex}`);
    }
}
main();

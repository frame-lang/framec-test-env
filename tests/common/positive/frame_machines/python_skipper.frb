@@[target("ruby")]

# PythonSyntaxSkipper — FSM for skipping Python comments and strings.
# Translated from framec's native_region_scanner/python_skipper.frs
#
# Handles: # comments, triple-quoted strings, simple strings,
# Python-style line endings, balanced parens.

@@system PythonSyntaxSkipperFsm {
    operations:
        setup(input_bytes, start, length) {
            self.bytes = input_bytes
            self.pos = start
            self.scan_end = length
        }
        get_result_pos() {
            return self.result_pos
        }
        get_success() {
            return self.success
        }

    interface:
        do_skip_comment()
        do_skip_string()
        do_find_line_end()
        do_balanced_paren_end()

    machine:
        $Init {
            do_skip_comment() { -> $SkipComment }
            do_skip_string() { -> $SkipString }
            do_find_line_end() { -> $FindLineEnd }
            do_balanced_paren_end() { -> $BalancedParenEnd }
        }

        $SkipComment {
            $>() {
                i = self.pos
                the_end = self.scan_end
                bs = self.bytes

                # Python uses # for line comments
                if i < the_end && bs[i] == 0x23
                    j = i + 1
                    while j < the_end && bs[j] != 0x0A
                        j += 1
                    end
                    self.result_pos = j
                    self.success = 1
                    return
                end

                self.success = 0
            }
        }

        $SkipString {
            $>() {
                i = self.pos
                the_end = self.scan_end
                bs = self.bytes

                # Triple-quoted strings: """ or '''
                if i + 2 < the_end
                    if (bs[i] == 0x22 && bs[i+1] == 0x22 && bs[i+2] == 0x22) ||
                       (bs[i] == 0x27 && bs[i+1] == 0x27 && bs[i+2] == 0x27)
                        q = bs[i]
                        j = i + 3
                        while j + 2 < the_end
                            if bs[j] == q && bs[j+1] == q && bs[j+2] == q
                                self.result_pos = j + 3
                                self.success = 1
                                return
                            end
                            j += 1
                        end
                        self.result_pos = the_end
                        self.success = 1
                        return
                    end
                end

                # Simple strings: " or '
                if i < the_end && (bs[i] == 0x22 || bs[i] == 0x27)
                    q = bs[i]
                    j = i + 1
                    while j < the_end
                        if bs[j] == 0x5C
                            j += 2
                            next
                        end
                        if bs[j] == q
                            self.result_pos = j + 1
                            self.success = 1
                            return
                        end
                        j += 1
                    end
                    self.result_pos = the_end
                    self.success = 1
                    return
                end

                self.success = 0
            }
        }

        $FindLineEnd {
            $>() {
                j = self.pos
                the_end = self.scan_end
                bs = self.bytes

                while j < the_end
                    b = bs[j]
                    if b == 0x0A || b == 0x3B
                        break
                    end
                    # Stop at # comment
                    if b == 0x23
                        break
                    end
                    j += 1
                end

                self.result_pos = j
            }
        }

        $BalancedParenEnd {
            $>() {
                i = self.pos
                the_end = self.scan_end
                bs = self.bytes

                if i >= the_end || bs[i] != 0x28
                    self.success = 0
                    return
                end

                depth = 1
                j = i + 1
                while j < the_end && depth > 0
                    b = bs[j]
                    if b == 0x28
                        depth += 1
                    elsif b == 0x29
                        depth -= 1
                    elsif b == 0x22 || b == 0x27
                        q = b
                        j += 1
                        while j < the_end && bs[j] != q
                            if bs[j] == 0x5C
                                j += 1
                            end
                            j += 1
                        end
                    end
                    j += 1
                end

                if depth == 0
                    self.result_pos = j
                    self.success = 1
                else
                    self.result_pos = the_end
                    self.success = 0
                end
            }
        }

    domain:
        bytes = []
        pos: int = 0
        scan_end: int = 0
        result_pos: int = 0
        success: int = 1
}

failures = 0

# Test 1: Skip hash comment
s1 = PythonSyntaxSkipperFsm.new
inp1 = "# comment\ncode".bytes
s1.setup(inp1, 0, inp1.length)
s1.do_skip_comment()
if s1.get_success() != 1 || s1.get_result_pos() != 9
    puts("FAIL 1: success=#{s1.get_success()}, pos=#{s1.get_result_pos()}")
    failures += 1
end

# Test 2: Not a comment
s2 = PythonSyntaxSkipperFsm.new
inp2 = "x + 1".bytes
s2.setup(inp2, 0, inp2.length)
s2.do_skip_comment()
if s2.get_success() != 0
    puts("FAIL 2: should not be comment")
    failures += 1
end

# Test 3: Skip triple-quoted string
s3 = PythonSyntaxSkipperFsm.new
inp3 = "\"\"\"hello world\"\"\"rest".bytes
s3.setup(inp3, 0, inp3.length)
s3.do_skip_string()
if s3.get_success() != 1 || s3.get_result_pos() != 17
    puts("FAIL 3: success=#{s3.get_success()}, pos=#{s3.get_result_pos()}")
    failures += 1
end

# Test 4: Skip simple string
s4 = PythonSyntaxSkipperFsm.new
inp4 = "\"hello\" rest".bytes
s4.setup(inp4, 0, inp4.length)
s4.do_skip_string()
if s4.get_success() != 1 || s4.get_result_pos() != 7
    puts("FAIL 4: success=#{s4.get_success()}, pos=#{s4.get_result_pos()}")
    failures += 1
end

# Test 5: Skip string with escape
s5 = PythonSyntaxSkipperFsm.new
inp5 = "'he\\'llo' rest".bytes
s5.setup(inp5, 0, inp5.length)
s5.do_skip_string()
if s5.get_success() != 1 || s5.get_result_pos() != 9
    puts("FAIL 5: success=#{s5.get_success()}, pos=#{s5.get_result_pos()}")
    failures += 1
end

# Test 6: Find line end (stops at #)
s6 = PythonSyntaxSkipperFsm.new
inp6 = "x + 1 # comment".bytes
s6.setup(inp6, 0, inp6.length)
s6.do_find_line_end()
if s6.get_result_pos() != 6
    puts("FAIL 6: pos=#{s6.get_result_pos()}, expected 6")
    failures += 1
end

# Test 7: Balanced parens
s7 = PythonSyntaxSkipperFsm.new
inp7 = "(a, f(b)) rest".bytes
s7.setup(inp7, 0, inp7.length)
s7.do_balanced_paren_end()
if s7.get_success() != 1 || s7.get_result_pos() != 9
    puts("FAIL 7: success=#{s7.get_success()}, pos=#{s7.get_result_pos()}")
    failures += 1
end

if failures > 0
    puts("FAIL: #{failures} failures")
    exit(1)
end
puts("PASS: python_skipper (7 cases)")

@@target java

// RubySyntaxSkipper -- FSM for skipping Ruby comments and strings.
// Translated from framec's native_region_scanner/ruby_skipper.frs
//
// Handles: # line comments, "..." / '...' strings,
// %Q{} / %q[] / %w() etc. percent literals,
// Ruby-style line endings, balanced parens.

@@system RubySyntaxSkipperFsm {
    operations:
        setup(input_bytes: byte[], start: int, length: int) {
            this.bytes = input_bytes;
            this.pos = start;
            this.scan_end = length;
        }
        get_result_pos(): int {
            return this.result_pos;
        }
        get_success(): int {
            return this.success;
        }

    interface:
        do_skip_comment()
        do_skip_string()
        do_find_line_end()
        do_balanced_paren_end()

    machine:
        $Init {
            do_skip_comment() { -> $SkipComment }
            do_skip_string() { -> $SkipString }
            do_find_line_end() { -> $FindLineEnd }
            do_balanced_paren_end() { -> $BalancedParenEnd }
        }

        $SkipComment {
            $>() {
                int i = this.pos;
                int end = this.scan_end;
                byte[] bs = this.bytes;

                // Ruby: # line comment only
                if (i < end && (bs[i] & 0xFF) == '#') {
                    int j = i + 1;
                    while (j < end && (bs[j] & 0xFF) != '\n') {
                        j++;
                    }
                    this.result_pos = j;
                    this.success = 1;
                    return;
                }

                this.success = 0;
            }
        }

        $SkipString {
            $>() {
                int i = this.pos;
                int end = this.scan_end;
                byte[] bs = this.bytes;

                // Percent literals: %Q{...}, %q[...], %w(...), etc.
                if (i < end && (bs[i] & 0xFF) == '%') {
                    if (i + 1 < end) {
                        int c1 = bs[i + 1] & 0xFF;
                        // Check for %Q, %q, %w, %W, %i, %I, %r, %x, %s
                        boolean has_letter = (c1 == 'Q' || c1 == 'q' || c1 == 'w' || c1 == 'W' || c1 == 'i' || c1 == 'I' || c1 == 'r' || c1 == 'x' || c1 == 's');
                        int opener = 0;
                        int j = 0;
                        if (has_letter && i + 2 < end) {
                            opener = bs[i + 2] & 0xFF;
                            j = i + 3;
                        } else if (!has_letter && !Character.isLetterOrDigit((char)c1) && c1 != '_') {
                            // %{...} or %[...] or %<...> without letter
                            opener = c1;
                            j = i + 2;
                        } else {
                            this.success = 0;
                            return;
                        }

                        // Determine closer
                        int closer = 0;
                        if (opener == '{') {
                            closer = '}';
                        } else if (opener == '[') {
                            closer = ']';
                        } else if (opener == '(') {
                            closer = ')';
                        } else if (opener == '<') {
                            closer = '>';
                        } else {
                            // Non-paired delimiter (e.g. %Q!...!)
                            closer = opener;
                            // Scan to matching delimiter
                            while (j < end) {
                                if ((bs[j] & 0xFF) == '\\') {
                                    j += 2;
                                    continue;
                                }
                                if ((bs[j] & 0xFF) == closer) {
                                    this.result_pos = j + 1;
                                    this.success = 1;
                                    return;
                                }
                                j++;
                            }
                            this.result_pos = end;
                            this.success = 1;
                            return;
                        }

                        // Paired delimiter: track nesting
                        int depth = 1;
                        while (j < end && depth > 0) {
                            if ((bs[j] & 0xFF) == '\\') {
                                j += 2;
                                continue;
                            }
                            if ((bs[j] & 0xFF) == opener) {
                                depth++;
                            } else if ((bs[j] & 0xFF) == closer) {
                                depth--;
                            }
                            j++;
                        }
                        this.result_pos = j;
                        this.success = 1;
                        return;
                    }
                }

                // Simple string: " or '
                if (i < end && ((bs[i] & 0xFF) == '"' || (bs[i] & 0xFF) == '\'')) {
                    int q = bs[i] & 0xFF;
                    int j = i + 1;
                    while (j < end) {
                        if ((bs[j] & 0xFF) == '\\') {
                            j += 2;
                            continue;
                        }
                        if ((bs[j] & 0xFF) == q) {
                            this.result_pos = j + 1;
                            this.success = 1;
                            return;
                        }
                        j++;
                    }
                    this.result_pos = end;
                    this.success = 1;
                    return;
                }

                this.success = 0;
            }
        }

        $FindLineEnd {
            $>() {
                int j = this.pos;
                int end = this.scan_end;
                byte[] bs = this.bytes;
                int in_string = 0;

                while (j < end) {
                    int b = bs[j] & 0xFF;
                    if (b == '\n') {
                        break;
                    }

                    // Inside string
                    if (in_string != 0) {
                        if (b == '\\') {
                            j += 2;
                            continue;
                        }
                        if (b == in_string) {
                            in_string = 0;
                        }
                        j++;
                        continue;
                    }

                    // Terminators
                    if (b == '#') {
                        break;
                    }

                    // String starts
                    if (b == '\'' || b == '"') {
                        in_string = b;
                        j++;
                        continue;
                    }

                    j++;
                }

                this.result_pos = j;
            }
        }

        $BalancedParenEnd {
            $>() {
                int i = this.pos;
                int end = this.scan_end;
                byte[] bs = this.bytes;

                if (i >= end || (bs[i] & 0xFF) != '(') {
                    this.success = 0;
                    return;
                }

                int depth = 0;
                int in_string = 0;

                while (i < end) {
                    int b = bs[i] & 0xFF;

                    // Inside string
                    if (in_string != 0) {
                        if (b == '\\') {
                            i += 2;
                            continue;
                        }
                        if (b == in_string) {
                            in_string = 0;
                        }
                        i++;
                        continue;
                    }

                    if (b == '\'' || b == '"') {
                        in_string = b;
                        i++;
                    } else if (b == '(') {
                        depth++;
                        i++;
                    } else if (b == ')') {
                        depth--;
                        i++;
                        if (depth == 0) {
                            this.result_pos = i;
                            this.success = 1;
                            return;
                        }
                    } else {
                        i++;
                    }
                }

                this.success = 0;
            }
        }

    domain:
        bytes: byte[] = null
        pos: int = 0
        scan_end: int = 0
        result_pos: int = 0
        success: int = 1
}

class Main {
    public static void main(String[] args) {
        int failures = 0;

        // Test 1: Skip # comment
        RubySyntaxSkipperFsm s1 = @@RubySyntaxSkipperFsm();
        byte[] inp1 = "# comment\ncode".getBytes();
        s1.setup(inp1, 0, inp1.length);
        s1.do_skip_comment();
        if (s1.get_success() != 1 || s1.get_result_pos() != 9) {
            System.out.println("FAIL 1: success=" + s1.get_success() + ", pos=" + s1.get_result_pos());
            failures++;
        }

        // Test 2: Skip double-quoted string
        RubySyntaxSkipperFsm s2 = @@RubySyntaxSkipperFsm();
        byte[] inp2 = "\"hello\" rest".getBytes();
        s2.setup(inp2, 0, inp2.length);
        s2.do_skip_string();
        if (s2.get_success() != 1 || s2.get_result_pos() != 7) {
            System.out.println("FAIL 2: success=" + s2.get_success() + ", pos=" + s2.get_result_pos());
            failures++;
        }

        // Test 3: Skip single-quoted string
        RubySyntaxSkipperFsm s3 = @@RubySyntaxSkipperFsm();
        byte[] inp3 = "'hello' rest".getBytes();
        s3.setup(inp3, 0, inp3.length);
        s3.do_skip_string();
        if (s3.get_success() != 1 || s3.get_result_pos() != 7) {
            System.out.println("FAIL 3: success=" + s3.get_success() + ", pos=" + s3.get_result_pos());
            failures++;
        }

        // Test 4: Skip %Q{text}
        RubySyntaxSkipperFsm s4 = @@RubySyntaxSkipperFsm();
        byte[] inp4 = "%Q{text} rest".getBytes();
        s4.setup(inp4, 0, inp4.length);
        s4.do_skip_string();
        if (s4.get_success() != 1 || s4.get_result_pos() != 8) {
            System.out.println("FAIL 4: success=" + s4.get_success() + ", pos=" + s4.get_result_pos());
            failures++;
        }

        // Test 5: Skip %q[text]
        RubySyntaxSkipperFsm s5 = @@RubySyntaxSkipperFsm();
        byte[] inp5 = "%q[text] rest".getBytes();
        s5.setup(inp5, 0, inp5.length);
        s5.do_skip_string();
        if (s5.get_success() != 1 || s5.get_result_pos() != 8) {
            System.out.println("FAIL 5: success=" + s5.get_success() + ", pos=" + s5.get_result_pos());
            failures++;
        }

        // Test 6: Find line end (stops at #)
        RubySyntaxSkipperFsm s6 = @@RubySyntaxSkipperFsm();
        byte[] inp6 = "x + 1 # comment".getBytes();
        s6.setup(inp6, 0, inp6.length);
        s6.do_find_line_end();
        if (s6.get_result_pos() != 6) {
            System.out.println("FAIL 6: pos=" + s6.get_result_pos() + ", expected 6");
            failures++;
        }

        // Test 7: Balanced parens
        RubySyntaxSkipperFsm s7 = @@RubySyntaxSkipperFsm();
        byte[] inp7 = "(a, f(b)) rest".getBytes();
        s7.setup(inp7, 0, inp7.length);
        s7.do_balanced_paren_end();
        if (s7.get_success() != 1 || s7.get_result_pos() != 9) {
            System.out.println("FAIL 7: success=" + s7.get_success() + ", pos=" + s7.get_result_pos());
            failures++;
        }

        // Test 8: Skip %Q with nested braces
        RubySyntaxSkipperFsm s8 = @@RubySyntaxSkipperFsm();
        byte[] inp8 = "%Q{outer {inner} end} rest".getBytes();
        s8.setup(inp8, 0, inp8.length);
        s8.do_skip_string();
        if (s8.get_success() != 1 || s8.get_result_pos() != 21) {
            System.out.println("FAIL 8: success=" + s8.get_success() + ", pos=" + s8.get_result_pos());
            failures++;
        }

        if (failures > 0) {
            System.out.println("FAIL: " + failures + " failures");
            System.exit(1);
        }
        System.out.println("PASS: ruby_skipper (8 cases)");
    }
}

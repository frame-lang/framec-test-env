<?php
@@[target("php")]

// ErlangScopeScanner -- FSM for detecting fun(...) -> ... end closures.
// Translated from framec's native_region_scanner/erlang_scope_scanner.frs

@@system ErlangScopeScannerFsm {
    operations:
        setup(input_bytes: array, start: int, length: int) {
            $this->bytes = $input_bytes;
            $this->pos = $start;
            $this->scan_end = $length;
        }
        get_result_pos(): int {
            return $this->result_pos;
        }
        get_success(): int {
            return $this->success;
        }

    interface:
        do_scan()

    machine:
        $Init {
            do_scan() { -> $CheckFun }
        }

        $CheckFun {
            $>() {
                $i = $this->pos;
                $end = $this->scan_end;
                $bs = $this->bytes;

                if ($i + 3 > $end) {
                    $this->success = 0;
                    return;
                }

                if ($bs[$i] !== 0x66 || $bs[$i + 1] !== 0x75 || $bs[$i + 2] !== 0x6E) {
                    $this->success = 0;
                    return;
                }

                $after = $i + 3;
                if ($after < $end && (($bs[$after] >= 0x61 && $bs[$after] <= 0x7A) || ($bs[$after] >= 0x41 && $bs[$after] <= 0x5A) || ($bs[$after] >= 0x30 && $bs[$after] <= 0x39) || $bs[$after] === 0x5F)) {
                    $this->success = 0;
                    return;
                }

                $j = $after;
                while ($j < $end && ($bs[$j] === 0x20 || $bs[$j] === 0x09 || $bs[$j] === 0x0A)) {
                    $j++;
                }

                if ($j < $end && $bs[$j] >= 0x41 && $bs[$j] <= 0x5A) {
                    $k = $j;
                    while ($k < $end && (($bs[$k] >= 0x61 && $bs[$k] <= 0x7A) || ($bs[$k] >= 0x41 && $bs[$k] <= 0x5A) || ($bs[$k] >= 0x30 && $bs[$k] <= 0x39) || $bs[$k] === 0x5F)) {
                        $k++;
                    }
                    if ($k < $end && $bs[$k] === 0x3A) {
                        $this->success = 0;
                        return;
                    }
                }

                $this->depth = 1;
                $this->pos = $after;
                -> $ScanBody
            }
        }

        $ScanBody {
            $>() {
                $i = $this->pos;
                $end = $this->scan_end;
                $bs = $this->bytes;

                while ($i < $end) {
                    $b = $bs[$i];

                    if ($b === 0x25) {
                        while ($i < $end && $bs[$i] !== 0x0A) {
                            $i++;
                        }
                        continue;
                    }

                    if ($b === 0x22) {
                        $i++;
                        while ($i < $end) {
                            if ($bs[$i] === 0x5C) {
                                $i += 2;
                                continue;
                            }
                            if ($bs[$i] === 0x22) {
                                $i++;
                                break;
                            }
                            $i++;
                        }
                        continue;
                    }

                    if ($b === 0x27) {
                        $i++;
                        while ($i < $end) {
                            if ($bs[$i] === 0x5C) {
                                $i += 2;
                                continue;
                            }
                            if ($bs[$i] === 0x27) {
                                $i++;
                                break;
                            }
                            $i++;
                        }
                        continue;
                    }

                    // fun
                    if ($b === 0x66 && $i + 3 <= $end && $bs[$i + 1] === 0x75 && $bs[$i + 2] === 0x6E) {
                        if ($i + 3 >= $end || !(($bs[$i + 3] >= 0x61 && $bs[$i + 3] <= 0x7A) || ($bs[$i + 3] >= 0x41 && $bs[$i + 3] <= 0x5A) || ($bs[$i + 3] >= 0x30 && $bs[$i + 3] <= 0x39) || $bs[$i + 3] === 0x5F)) {
                            $this->depth++;
                            $i += 3;
                            continue;
                        }
                    }

                    // case
                    if ($b === 0x63 && $i + 4 <= $end && $bs[$i + 1] === 0x61 && $bs[$i + 2] === 0x73 && $bs[$i + 3] === 0x65) {
                        if ($i + 4 >= $end || !(($bs[$i + 4] >= 0x61 && $bs[$i + 4] <= 0x7A) || ($bs[$i + 4] >= 0x41 && $bs[$i + 4] <= 0x5A) || ($bs[$i + 4] >= 0x30 && $bs[$i + 4] <= 0x39) || $bs[$i + 4] === 0x5F)) {
                            $this->depth++;
                            $i += 4;
                            continue;
                        }
                    }

                    // if
                    if ($b === 0x69 && $i + 2 <= $end && $bs[$i + 1] === 0x66) {
                        if ($i + 2 >= $end || !(($bs[$i + 2] >= 0x61 && $bs[$i + 2] <= 0x7A) || ($bs[$i + 2] >= 0x41 && $bs[$i + 2] <= 0x5A) || ($bs[$i + 2] >= 0x30 && $bs[$i + 2] <= 0x39) || $bs[$i + 2] === 0x5F)) {
                            $this->depth++;
                            $i += 2;
                            continue;
                        }
                    }

                    // receive
                    if ($b === 0x72 && $i + 7 <= $end && $bs[$i + 1] === 0x65 && $bs[$i + 2] === 0x63 && $bs[$i + 3] === 0x65 && $bs[$i + 4] === 0x69 && $bs[$i + 5] === 0x76 && $bs[$i + 6] === 0x65) {
                        if ($i + 7 >= $end || !(($bs[$i + 7] >= 0x61 && $bs[$i + 7] <= 0x7A) || ($bs[$i + 7] >= 0x41 && $bs[$i + 7] <= 0x5A) || ($bs[$i + 7] >= 0x30 && $bs[$i + 7] <= 0x39) || $bs[$i + 7] === 0x5F)) {
                            $this->depth++;
                            $i += 7;
                            continue;
                        }
                    }

                    // begin
                    if ($b === 0x62 && $i + 5 <= $end && $bs[$i + 1] === 0x65 && $bs[$i + 2] === 0x67 && $bs[$i + 3] === 0x69 && $bs[$i + 4] === 0x6E) {
                        if ($i + 5 >= $end || !(($bs[$i + 5] >= 0x61 && $bs[$i + 5] <= 0x7A) || ($bs[$i + 5] >= 0x41 && $bs[$i + 5] <= 0x5A) || ($bs[$i + 5] >= 0x30 && $bs[$i + 5] <= 0x39) || $bs[$i + 5] === 0x5F)) {
                            $this->depth++;
                            $i += 5;
                            continue;
                        }
                    }

                    // try
                    if ($b === 0x74 && $i + 3 <= $end && $bs[$i + 1] === 0x72 && $bs[$i + 2] === 0x79) {
                        if ($i + 3 >= $end || !(($bs[$i + 3] >= 0x61 && $bs[$i + 3] <= 0x7A) || ($bs[$i + 3] >= 0x41 && $bs[$i + 3] <= 0x5A) || ($bs[$i + 3] >= 0x30 && $bs[$i + 3] <= 0x39) || $bs[$i + 3] === 0x5F)) {
                            $this->depth++;
                            $i += 3;
                            continue;
                        }
                    }

                    // end
                    if ($b === 0x65 && $i + 3 <= $end && $bs[$i + 1] === 0x6E && $bs[$i + 2] === 0x64) {
                        if ($i + 3 >= $end || !(($bs[$i + 3] >= 0x61 && $bs[$i + 3] <= 0x7A) || ($bs[$i + 3] >= 0x41 && $bs[$i + 3] <= 0x5A) || ($bs[$i + 3] >= 0x30 && $bs[$i + 3] <= 0x39) || $bs[$i + 3] === 0x5F)) {
                            $this->depth--;
                            if ($this->depth === 0) {
                                $this->result_pos = $i + 3;
                                $this->success = 1;
                                return;
                            }
                            $i += 3;
                            continue;
                        }
                    }

                    // Skip identifiers
                    if (($b >= 0x61 && $b <= 0x7A) || ($b >= 0x41 && $b <= 0x5A) || $b === 0x5F) {
                        while ($i < $end && (($bs[$i] >= 0x61 && $bs[$i] <= 0x7A) || ($bs[$i] >= 0x41 && $bs[$i] <= 0x5A) || ($bs[$i] >= 0x30 && $bs[$i] <= 0x39) || $bs[$i] === 0x5F)) {
                            $i++;
                        }
                        continue;
                    }

                    $i++;
                }

                $this->success = 0;
            }
        }

    domain:
        bytes = []
        pos = 0
        scan_end = 0
        result_pos = 0
        success = 0
        depth = 0
}

function str_to_bytes(string $s): array {
    return array_values(unpack('C*', $s));
}

$failures = 0;

// Test 1: Simple fun -> end
$s1 = @@ErlangScopeScannerFsm();
$inp1 = str_to_bytes("fun(X) -> X + 1 end rest");
$s1->setup($inp1, 0, count($inp1));
$s1->do_scan();
if ($s1->get_success() !== 1 || $s1->get_result_pos() !== 19) {
    echo 'FAIL 1: success=' . $s1->get_success() . ', pos=' . $s1->get_result_pos() . "\n";
    $failures++;
}

// Test 2: Nested fun -> case ... end end
$s2 = @@ErlangScopeScannerFsm();
$inp2 = str_to_bytes("fun(X) -> case X of 1 -> ok end end rest");
$s2->setup($inp2, 0, count($inp2));
$s2->do_scan();
if ($s2->get_success() !== 1 || $s2->get_result_pos() !== 35) {
    echo 'FAIL 2: success=' . $s2->get_success() . ', pos=' . $s2->get_result_pos() . "\n";
    $failures++;
}

// Test 3: Not a fun keyword (function)
$s3 = @@ErlangScopeScannerFsm();
$inp3 = str_to_bytes("function() -> ok end");
$s3->setup($inp3, 0, count($inp3));
$s3->do_scan();
if ($s3->get_success() !== 0) {
    echo "FAIL 3: should not match 'function'\n";
    $failures++;
}

// Test 4: fun Module:Function/Arity (function reference, not closure)
$s4 = @@ErlangScopeScannerFsm();
$inp4 = str_to_bytes("fun io:format/2");
$s4->setup($inp4, 0, count($inp4));
$s4->do_scan();
if ($s4->get_success() !== 0) {
    echo "FAIL 4: should not match function reference\n";
    $failures++;
}

// Test 5: Nested if ... end inside fun
$s5 = @@ErlangScopeScannerFsm();
$inp5 = str_to_bytes("fun() -> if true -> ok end end rest");
$s5->setup($inp5, 0, count($inp5));
$s5->do_scan();
if ($s5->get_success() !== 1 || $s5->get_result_pos() !== 30) {
    echo 'FAIL 5: success=' . $s5->get_success() . ', pos=' . $s5->get_result_pos() . "\n";
    $failures++;
}

// Test 6: String inside fun body (should skip)
$s6 = @@ErlangScopeScannerFsm();
$inp6 = str_to_bytes('fun() -> "end" end rest');
$s6->setup($inp6, 0, count($inp6));
$s6->do_scan();
if ($s6->get_success() !== 1 || $s6->get_result_pos() !== 18) {
    echo 'FAIL 6: success=' . $s6->get_success() . ', pos=' . $s6->get_result_pos() . "\n";
    $failures++;
}

// Test 7: Comment inside fun body (should skip)
$s7 = @@ErlangScopeScannerFsm();
$inp7 = str_to_bytes("fun() -> % end\nok end rest");
$s7->setup($inp7, 0, count($inp7));
$s7->do_scan();
if ($s7->get_success() !== 1 || $s7->get_result_pos() !== 21) {
    echo 'FAIL 7: success=' . $s7->get_success() . ', pos=' . $s7->get_result_pos() . "\n";
    $failures++;
}

// Test 8: Unmatched fun (no end)
$s8 = @@ErlangScopeScannerFsm();
$inp8 = str_to_bytes("fun() -> X + 1");
$s8->setup($inp8, 0, count($inp8));
$s8->do_scan();
if ($s8->get_success() !== 0) {
    echo "FAIL 8: should fail with no matching end\n";
    $failures++;
}

if ($failures > 0) { echo "FAIL: $failures failures\n"; exit(1); }
echo "PASS: erlang_scope_scanner (8 cases)\n";

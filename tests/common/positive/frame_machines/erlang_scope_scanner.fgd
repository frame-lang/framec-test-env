@@target gdscript
extends SceneTree

# ErlangScopeScanner -- FSM for detecting fun(...) -> ... end closures.
# Translated from framec's native_region_scanner/erlang_scope_scanner.frs
#
# Erlang reuses `end` to close: fun, case, if, receive, begin, try.
# This FSM tracks a depth counter for all block-opening keywords so
# only the `end` matching our `fun` terminates the scan.
#
# Skips % line comments and "..." / '...' string/atom literals.
# Does NOT match `fun Module:Function/Arity` (function references).

@@system ErlangScopeScannerFsm {
    operations:
        setup(input_bytes: Array, start: int, length: int) {
            self.bytes = input_bytes
            self.pos = start
            self.scan_end = length
        }
        get_result_pos(): int {
            return self.result_pos
        }
        get_success(): int {
            return self.success
        }

    interface:
        do_scan()

    machine:
        $Init {
            do_scan() { -> $CheckFun }
        }

        $CheckFun {
            $>() {
                var i = self.pos
                var scan_end = self.scan_end
                var bs = self.bytes

                # Must start with `fun` keyword
                if i + 3 > scan_end:
                    self.success = 0
                    return
                if bs[i] != 0x66 or bs[i + 1] != 0x75 or bs[i + 2] != 0x6E:
                    self.success = 0
                    return

                # Check word boundary (not part of `function` etc.)
                var after = i + 3
                if after < scan_end and (_ess_is_alnum(bs[after]) or bs[after] == 0x5F):
                    self.success = 0
                    return

                # Skip whitespace after `fun`
                var j = after
                while j < scan_end and (bs[j] == 0x20 or bs[j] == 0x09 or bs[j] == 0x0A):
                    j += 1

                # Check for Module:Function/Arity pattern (function reference, not closure)
                if j < scan_end and bs[j] >= 0x41 and bs[j] <= 0x5A:
                    var k = j
                    while k < scan_end and (_ess_is_alnum(bs[k]) or bs[k] == 0x5F):
                        k += 1
                    if k < scan_end and bs[k] == 0x3A:
                        self.success = 0
                        return

                # It's a closure: fun(...) -> ... end
                self.depth = 1
                self.pos = after
                -> $ScanBody
            }
        }

        $ScanBody {
            $>() {
                var i = self.pos
                var scan_end = self.scan_end
                var bs = self.bytes

                while i < scan_end:
                    var b = bs[i]

                    # Skip % line comments
                    if b == 0x25:
                        while i < scan_end and bs[i] != 0x0A:
                            i += 1
                        continue

                    # Skip "..." strings
                    if b == 0x22:
                        i += 1
                        while i < scan_end:
                            if bs[i] == 0x5C:
                                i += 2
                                continue
                            if bs[i] == 0x22:
                                i += 1
                                break
                            i += 1
                        continue

                    # Skip '...' quoted atoms
                    if b == 0x27:
                        i += 1
                        while i < scan_end:
                            if bs[i] == 0x5C:
                                i += 2
                                continue
                            if bs[i] == 0x27:
                                i += 1
                                break
                            i += 1
                        continue

                    # Check for block-opening keywords (increase depth)

                    # fun
                    if b == 0x66 and i + 3 <= scan_end and bs[i + 1] == 0x75 and bs[i + 2] == 0x6E:
                        if i + 3 >= scan_end or (not _ess_is_alnum(bs[i + 3]) and bs[i + 3] != 0x5F):
                            self.depth += 1
                            i += 3
                            continue
                    # case
                    if b == 0x63 and i + 4 <= scan_end and bs[i + 1] == 0x61 and bs[i + 2] == 0x73 and bs[i + 3] == 0x65:
                        if i + 4 >= scan_end or (not _ess_is_alnum(bs[i + 4]) and bs[i + 4] != 0x5F):
                            self.depth += 1
                            i += 4
                            continue
                    # if
                    if b == 0x69 and i + 2 <= scan_end and bs[i + 1] == 0x66:
                        if i + 2 >= scan_end or (not _ess_is_alnum(bs[i + 2]) and bs[i + 2] != 0x5F):
                            self.depth += 1
                            i += 2
                            continue
                    # receive
                    if b == 0x72 and i + 7 <= scan_end and bs[i + 1] == 0x65 and bs[i + 2] == 0x63 and bs[i + 3] == 0x65 and bs[i + 4] == 0x69 and bs[i + 5] == 0x76 and bs[i + 6] == 0x65:
                        if i + 7 >= scan_end or (not _ess_is_alnum(bs[i + 7]) and bs[i + 7] != 0x5F):
                            self.depth += 1
                            i += 7
                            continue
                    # begin
                    if b == 0x62 and i + 5 <= scan_end and bs[i + 1] == 0x65 and bs[i + 2] == 0x67 and bs[i + 3] == 0x69 and bs[i + 4] == 0x6E:
                        if i + 5 >= scan_end or (not _ess_is_alnum(bs[i + 5]) and bs[i + 5] != 0x5F):
                            self.depth += 1
                            i += 5
                            continue
                    # try
                    if b == 0x74 and i + 3 <= scan_end and bs[i + 1] == 0x72 and bs[i + 2] == 0x79:
                        if i + 3 >= scan_end or (not _ess_is_alnum(bs[i + 3]) and bs[i + 3] != 0x5F):
                            self.depth += 1
                            i += 3
                            continue

                    # Check for `end` keyword (decrease depth)
                    if b == 0x65 and i + 3 <= scan_end and bs[i + 1] == 0x6E and bs[i + 2] == 0x64:
                        if i + 3 >= scan_end or (not _ess_is_alnum(bs[i + 3]) and bs[i + 3] != 0x5F):
                            self.depth -= 1
                            if self.depth == 0:
                                self.result_pos = i + 3
                                self.success = 1
                                return
                            i += 3
                            continue

                    # Skip identifiers (avoid false keyword matches mid-word)
                    if _ess_is_alpha(b) or b == 0x5F:
                        while i < scan_end and (_ess_is_alnum(bs[i]) or bs[i] == 0x5F):
                            i += 1
                        continue
                    i += 1

                # Ran out of bytes without finding matching `end`
                self.success = 0
            }
        }

    domain:
        bytes: Array = []
        pos: int = 0
        scan_end: int = 0
        result_pos: int = 0
        success: int = 0
        depth: int = 0
}

func _ess_is_alnum(b: int) -> bool:
    return (b >= 0x30 and b <= 0x39) or (b >= 0x41 and b <= 0x5A) or (b >= 0x61 and b <= 0x7A)

func _ess_is_alpha(b: int) -> bool:
    return (b >= 0x41 and b <= 0x5A) or (b >= 0x61 and b <= 0x7A)

func str_to_bytes(s: String) -> Array:
    var arr = []
    var buf = s.to_utf8_buffer()
    for i in range(buf.size()):
        arr.append(buf[i])
    return arr

func main():
    var failures = 0

    # Test 1: Simple fun -> end
    var s1 = @@ErlangScopeScannerFsm()
    var inp1 = str_to_bytes("fun(X) -> X + 1 end rest")
    s1.setup(inp1, 0, inp1.size())
    s1.do_scan()
    if s1.get_success() != 1 or s1.get_result_pos() != 19:
        print("FAIL 1: success=" + str(s1.get_success()) + ", pos=" + str(s1.get_result_pos()))
        failures += 1

    # Test 2: Nested fun -> case ... end end
    var s2 = @@ErlangScopeScannerFsm()
    var inp2 = str_to_bytes("fun(X) -> case X of 1 -> ok end end rest")
    s2.setup(inp2, 0, inp2.size())
    s2.do_scan()
    if s2.get_success() != 1 or s2.get_result_pos() != 35:
        print("FAIL 2: success=" + str(s2.get_success()) + ", pos=" + str(s2.get_result_pos()))
        failures += 1

    # Test 3: Not a fun keyword (function)
    var s3 = @@ErlangScopeScannerFsm()
    var inp3 = str_to_bytes("function() -> ok end")
    s3.setup(inp3, 0, inp3.size())
    s3.do_scan()
    if s3.get_success() != 0:
        print("FAIL 3: should not match 'function'")
        failures += 1

    # Test 4: fun Module:Function/Arity (function reference, not closure)
    var s4 = @@ErlangScopeScannerFsm()
    var inp4 = str_to_bytes("fun io:format/2")
    s4.setup(inp4, 0, inp4.size())
    s4.do_scan()
    if s4.get_success() != 0:
        print("FAIL 4: should not match function reference")
        failures += 1

    # Test 5: Nested if ... end inside fun
    var s5 = @@ErlangScopeScannerFsm()
    var inp5 = str_to_bytes("fun() -> if true -> ok end end rest")
    s5.setup(inp5, 0, inp5.size())
    s5.do_scan()
    if s5.get_success() != 1 or s5.get_result_pos() != 30:
        print("FAIL 5: success=" + str(s5.get_success()) + ", pos=" + str(s5.get_result_pos()))
        failures += 1

    # Test 6: String inside fun body (should skip)
    var s6 = @@ErlangScopeScannerFsm()
    var inp6 = str_to_bytes("fun() -> \"end\" end rest")
    s6.setup(inp6, 0, inp6.size())
    s6.do_scan()
    if s6.get_success() != 1 or s6.get_result_pos() != 18:
        print("FAIL 6: success=" + str(s6.get_success()) + ", pos=" + str(s6.get_result_pos()))
        failures += 1

    # Test 7: Comment inside fun body (should skip)
    var s7 = @@ErlangScopeScannerFsm()
    var inp7 = str_to_bytes("fun() -> % end\nok end rest")
    s7.setup(inp7, 0, inp7.size())
    s7.do_scan()
    if s7.get_success() != 1 or s7.get_result_pos() != 21:
        print("FAIL 7: success=" + str(s7.get_success()) + ", pos=" + str(s7.get_result_pos()))
        failures += 1

    # Test 8: Unmatched fun (no end)
    var s8 = @@ErlangScopeScannerFsm()
    var inp8 = str_to_bytes("fun() -> X + 1")
    s8.setup(inp8, 0, inp8.size())
    s8.do_scan()
    if s8.get_success() != 0:
        print("FAIL 8: should fail with no matching end")
        failures += 1

    if failures > 0:
        print("FAIL: " + str(failures) + " failures")
        push_error(str(failures) + " test(s) failed")
    else:
        print("PASS: erlang_scope_scanner (8 cases)")

func _init():
    main()
    quit()

@@[target("java")]

// TypeScriptSyntaxSkipper — FSM for skipping TS/JS comments and strings.
// Translated from framec's native_region_scanner/typescript_skipper.frs
//
// Adds template literal awareness (backtick strings with ${} interpolation)
// on top of the C-style comment and string patterns.

@@system TSSyntaxSkipperFsm {
    operations:
        setup(input_bytes: byte[], start: int, length: int) {
            this.bytes = input_bytes;
            this.pos = start;
            this.scan_end = length;
        }
        get_result_pos(): int {
            return this.result_pos;
        }
        get_success(): int {
            return this.success;
        }

    interface:
        do_skip_comment()
        do_skip_string()
        do_find_line_end()

    machine:
        $Init {
            do_skip_comment() { -> $SkipComment }
            do_skip_string() { -> $SkipString }
            do_find_line_end() { -> $FindLineEnd }
        }

        $SkipComment {
            $>() {
                int i = this.pos;
                int end = this.scan_end;
                byte[] bs = this.bytes;

                // // line comment
                if (i + 1 < end && (bs[i] & 0xFF) == '/' && (bs[i + 1] & 0xFF) == '/') {
                    int j = i + 2;
                    while (j < end && (bs[j] & 0xFF) != '\n') {
                        j++;
                    }
                    this.result_pos = j;
                    this.success = 1;
                    return;
                }

                // /* block comment */
                if (i + 1 < end && (bs[i] & 0xFF) == '/' && (bs[i + 1] & 0xFF) == '*') {
                    int j = i + 2;
                    while (j + 1 < end) {
                        if ((bs[j] & 0xFF) == '*' && (bs[j + 1] & 0xFF) == '/') {
                            this.result_pos = j + 2;
                            this.success = 1;
                            return;
                        }
                        j++;
                    }
                    this.result_pos = end;
                    this.success = 1;
                    return;
                }

                this.success = 0;
            }
        }

        $SkipString {
            $>() {
                int i = this.pos;
                int end = this.scan_end;
                byte[] bs = this.bytes;

                // Template literal: `...${...}...`
                if (i < end && (bs[i] & 0xFF) == '`') {
                    int j = i + 1;
                    int templateDepth = 0;
                    while (j < end) {
                        int b = bs[j] & 0xFF;
                        if (b == '`' && templateDepth == 0) {
                            this.result_pos = j + 1;
                            this.success = 1;
                            return;
                        }
                        if (b == '\\') {
                            j += 2;
                            continue;
                        }
                        if (b == '$' && j + 1 < end && (bs[j + 1] & 0xFF) == '{') {
                            templateDepth++;
                            j += 2;
                            continue;
                        }
                        if (b == '}' && templateDepth > 0) {
                            templateDepth--;
                        }
                        j++;
                    }
                    this.result_pos = end;
                    this.success = 1;
                    return;
                }

                // Simple string: " or '
                if (i < end && ((bs[i] & 0xFF) == '"' || (bs[i] & 0xFF) == '\'')) {
                    int q = bs[i] & 0xFF;
                    int j = i + 1;
                    while (j < end) {
                        if ((bs[j] & 0xFF) == '\\') {
                            j += 2;
                            continue;
                        }
                        if ((bs[j] & 0xFF) == q) {
                            this.result_pos = j + 1;
                            this.success = 1;
                            return;
                        }
                        j++;
                    }
                    this.result_pos = end;
                    this.success = 1;
                    return;
                }

                this.success = 0;
            }
        }

        $FindLineEnd {
            $>() {
                int j = this.pos;
                int end = this.scan_end;
                byte[] bs = this.bytes;
                boolean inTemplate = false;
                int templateDepth = 0;

                while (j < end) {
                    int b = bs[j] & 0xFF;

                    if (inTemplate) {
                        if (b == '`' && templateDepth == 0) {
                            inTemplate = false;
                            j++;
                            continue;
                        }
                        if (b == '\\') {
                            j += 2;
                            continue;
                        }
                        if (b == '$' && j + 1 < end && (bs[j + 1] & 0xFF) == '{') {
                            templateDepth++;
                            j += 2;
                            continue;
                        }
                        if (b == '}' && templateDepth > 0) {
                            templateDepth--;
                        }
                        j++;
                        continue;
                    }

                    if (b == '\n') { break; }
                    if (b == ';') { break; }
                    if (b == '/' && j + 1 < end && (bs[j + 1] & 0xFF) == '/') { break; }
                    if (b == '/' && j + 1 < end && (bs[j + 1] & 0xFF) == '*') { break; }
                    if (b == '`') {
                        inTemplate = true;
                        j++;
                        continue;
                    }
                    if (b == '"' || b == '\'') {
                        int q = b;
                        j++;
                        while (j < end && (bs[j] & 0xFF) != q) {
                            if ((bs[j] & 0xFF) == '\\') { j++; }
                            j++;
                        }
                        if (j < end) { j++; }
                        continue;
                    }

                    j++;
                }

                this.result_pos = j;
            }
        }

    domain:
        bytes: byte[] = null
        pos: int = 0
        scan_end: int = 0
        result_pos: int = 0
        success: int = 1
}

class Main {
    public static void main(String[] args) {
        int failures = 0;

        // Test 1: Skip // line comment
        TSSyntaxSkipperFsm s1 = @@TSSyntaxSkipperFsm();
        byte[] inp1 = "// comment\ncode".getBytes();
        s1.setup(inp1, 0, inp1.length);
        s1.do_skip_comment();
        if (s1.get_success() != 1 || s1.get_result_pos() != 10) {
            System.out.println("FAIL 1: success=" + s1.get_success() + ", pos=" + s1.get_result_pos());
            failures++;
        }

        // Test 2: Skip /* block comment */
        TSSyntaxSkipperFsm s2 = @@TSSyntaxSkipperFsm();
        byte[] inp2 = "/* block */code".getBytes();
        s2.setup(inp2, 0, inp2.length);
        s2.do_skip_comment();
        if (s2.get_success() != 1 || s2.get_result_pos() != 11) {
            System.out.println("FAIL 2: success=" + s2.get_success() + ", pos=" + s2.get_result_pos());
            failures++;
        }

        // Test 3: Skip template literal
        TSSyntaxSkipperFsm s3 = @@TSSyntaxSkipperFsm();
        byte[] inp3 = "`hello ${name} world`rest".getBytes();
        s3.setup(inp3, 0, inp3.length);
        s3.do_skip_string();
        if (s3.get_success() != 1 || s3.get_result_pos() != 21) {
            System.out.println("FAIL 3: success=" + s3.get_success() + ", pos=" + s3.get_result_pos());
            failures++;
        }

        // Test 4: Skip simple double-quoted string
        TSSyntaxSkipperFsm s4 = @@TSSyntaxSkipperFsm();
        byte[] inp4 = "\"hello\" rest".getBytes();
        s4.setup(inp4, 0, inp4.length);
        s4.do_skip_string();
        if (s4.get_success() != 1 || s4.get_result_pos() != 7) {
            System.out.println("FAIL 4: success=" + s4.get_success() + ", pos=" + s4.get_result_pos());
            failures++;
        }

        // Test 5: Skip template with nested ${}
        TSSyntaxSkipperFsm s5 = @@TSSyntaxSkipperFsm();
        byte[] inp5 = "`${a + ${b}}`rest".getBytes();
        s5.setup(inp5, 0, inp5.length);
        s5.do_skip_string();
        if (s5.get_success() != 1) {
            System.out.println("FAIL 5: success=" + s5.get_success());
            failures++;
        }

        // Test 6: Find line end skips over template literals
        TSSyntaxSkipperFsm s6 = @@TSSyntaxSkipperFsm();
        byte[] inp6 = "x = `hello`;\nnext".getBytes();
        s6.setup(inp6, 0, inp6.length);
        s6.do_find_line_end();
        if (s6.get_result_pos() != 11) {
            System.out.println("FAIL 6: pos=" + s6.get_result_pos() + ", expected 11 (at ;)");
            failures++;
        }

        // Test 7: Not a string
        TSSyntaxSkipperFsm s7 = @@TSSyntaxSkipperFsm();
        byte[] inp7 = "x + 1".getBytes();
        s7.setup(inp7, 0, inp7.length);
        s7.do_skip_string();
        if (s7.get_success() != 0) {
            System.out.println("FAIL 7: should not be string");
            failures++;
        }

        if (failures > 0) {
            System.out.println("FAIL: " + failures + " failures");
            System.exit(1);
        }
        System.out.println("PASS: ts_skipper (7 cases)");
    }
}

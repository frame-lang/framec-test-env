@@target c

#include <string.h>

// LuaSyntaxSkipper -- FSM for skipping Lua comments and strings.
// Translated from framec's native_region_scanner/lua_skipper.frs
//
// Handles: -- line comments, --[[ block comments ]], [[ long strings ]],
// simple strings, Lua-style line endings.

@@system LuaSyntaxSkipperFsm {
    operations:
        setup(input_bytes: unsigned char*, start: int, length: int) {
            self->bytes = input_bytes;
            self->pos = start;
            self->end = length;
        }
        get_result_pos(): int {
            return self->result_pos;
        }
        get_success(): int {
            return self->success;
        }

    interface:
        do_skip_comment()
        do_skip_string()
        do_find_line_end()

    machine:
        $Init {
            do_skip_comment() { -> $SkipComment }
            do_skip_string() { -> $SkipString }
            do_find_line_end() { -> $FindLineEnd }
        }

        $SkipComment {
            $>() {
                int i = self->pos;
                int end = self->end;
                unsigned char* bs = self->bytes;

                // Lua line comment: --
                if (i + 1 < end && bs[i] == '-' && bs[i + 1] == '-') {
                    // Check for block comment: --[[ ... ]]
                    if (i + 3 < end && bs[i + 2] == '[' && bs[i + 3] == '[') {
                        int j = i + 4;
                        while (j + 1 < end) {
                            if (bs[j] == ']' && bs[j + 1] == ']') {
                                self->result_pos = j + 2;
                                self->success = 1;
                                return;
                            }
                            j++;
                        }
                        self->result_pos = end;
                        self->success = 1;
                        return;
                    }
                    // Line comment
                    int j = i + 2;
                    while (j < end && bs[j] != '\n') {
                        j++;
                    }
                    self->result_pos = j;
                    self->success = 1;
                    return;
                }

                self->success = 0;
            }
        }

        $SkipString {
            $>() {
                int i = self->pos;
                int end = self->end;
                unsigned char* bs = self->bytes;

                // Long string: [[ ... ]]
                if (i + 1 < end && bs[i] == '[' && bs[i + 1] == '[') {
                    int j = i + 2;
                    while (j + 1 < end) {
                        if (bs[j] == ']' && bs[j + 1] == ']') {
                            self->result_pos = j + 2;
                            self->success = 1;
                            return;
                        }
                        j++;
                    }
                    self->result_pos = end;
                    self->success = 1;
                    return;
                }

                // Simple string: " or '
                if (i < end && (bs[i] == '"' || bs[i] == '\'')) {
                    char q = bs[i];
                    int j = i + 1;
                    while (j < end) {
                        if (bs[j] == '\\') {
                            j += 2;
                            continue;
                        }
                        if (bs[j] == q) {
                            self->result_pos = j + 1;
                            self->success = 1;
                            return;
                        }
                        j++;
                    }
                    self->result_pos = end;
                    self->success = 1;
                    return;
                }

                self->success = 0;
            }
        }

        $FindLineEnd {
            $>() {
                int j = self->pos;
                int end = self->end;
                unsigned char* bs = self->bytes;

                while (j < end) {
                    char b = bs[j];
                    if (b == '\n') {
                        break;
                    }
                    // Stop at -- comment
                    if (b == '-' && j + 1 < end && bs[j + 1] == '-') {
                        break;
                    }
                    j++;
                }

                self->result_pos = j;
            }
        }

    domain:
        bytes: unsigned char* = NULL
        pos: int = 0
        end: int = 0
        result_pos: int = 0
        success: int = 1
}

int main() {
    int failures = 0;

    // Test 1: Skip -- line comment
    LuaSyntaxSkipperFsm* s1 = @@LuaSyntaxSkipperFsm();
    unsigned char t1[] = "-- comment\ncode";
    LuaSyntaxSkipperFsm_setup(s1, t1, 0, strlen((char*)t1));
    LuaSyntaxSkipperFsm_do_skip_comment(s1);
    if (LuaSyntaxSkipperFsm_get_success(s1) != 1 || LuaSyntaxSkipperFsm_get_result_pos(s1) != 10) {
        printf("FAIL 1: success=%d, pos=%d\n", LuaSyntaxSkipperFsm_get_success(s1), LuaSyntaxSkipperFsm_get_result_pos(s1));
        failures++;
    }

    // Test 2: Skip --[[ block comment ]]
    LuaSyntaxSkipperFsm* s2 = @@LuaSyntaxSkipperFsm();
    unsigned char t2[] = "--[[ block ]]code";
    LuaSyntaxSkipperFsm_setup(s2, t2, 0, strlen((char*)t2));
    LuaSyntaxSkipperFsm_do_skip_comment(s2);
    if (LuaSyntaxSkipperFsm_get_success(s2) != 1 || LuaSyntaxSkipperFsm_get_result_pos(s2) != 13) {
        printf("FAIL 2: success=%d, pos=%d\n", LuaSyntaxSkipperFsm_get_success(s2), LuaSyntaxSkipperFsm_get_result_pos(s2));
        failures++;
    }

    // Test 3: Not a comment
    LuaSyntaxSkipperFsm* s3 = @@LuaSyntaxSkipperFsm();
    unsigned char t3[] = "x + 1";
    LuaSyntaxSkipperFsm_setup(s3, t3, 0, strlen((char*)t3));
    LuaSyntaxSkipperFsm_do_skip_comment(s3);
    if (LuaSyntaxSkipperFsm_get_success(s3) != 0) {
        printf("FAIL 3: should not be a comment\n");
        failures++;
    }

    // Test 4: Skip [[ long string ]]
    LuaSyntaxSkipperFsm* s4 = @@LuaSyntaxSkipperFsm();
    unsigned char t4[] = "[[hello world]]rest";
    LuaSyntaxSkipperFsm_setup(s4, t4, 0, strlen((char*)t4));
    LuaSyntaxSkipperFsm_do_skip_string(s4);
    if (LuaSyntaxSkipperFsm_get_success(s4) != 1 || LuaSyntaxSkipperFsm_get_result_pos(s4) != 15) {
        printf("FAIL 4: success=%d, pos=%d\n", LuaSyntaxSkipperFsm_get_success(s4), LuaSyntaxSkipperFsm_get_result_pos(s4));
        failures++;
    }

    // Test 5: Skip simple string
    LuaSyntaxSkipperFsm* s5 = @@LuaSyntaxSkipperFsm();
    unsigned char t5[] = "\"hello\" rest";
    LuaSyntaxSkipperFsm_setup(s5, t5, 0, strlen((char*)t5));
    LuaSyntaxSkipperFsm_do_skip_string(s5);
    if (LuaSyntaxSkipperFsm_get_success(s5) != 1 || LuaSyntaxSkipperFsm_get_result_pos(s5) != 7) {
        printf("FAIL 5: success=%d, pos=%d\n", LuaSyntaxSkipperFsm_get_success(s5), LuaSyntaxSkipperFsm_get_result_pos(s5));
        failures++;
    }

    // Test 6: Find line end stops at --
    LuaSyntaxSkipperFsm* s6 = @@LuaSyntaxSkipperFsm();
    unsigned char t6[] = "x + 1 -- comment";
    LuaSyntaxSkipperFsm_setup(s6, t6, 0, strlen((char*)t6));
    LuaSyntaxSkipperFsm_do_find_line_end(s6);
    if (LuaSyntaxSkipperFsm_get_result_pos(s6) != 6) {
        printf("FAIL 6: pos=%d, expected 6\n", LuaSyntaxSkipperFsm_get_result_pos(s6));
        failures++;
    }

    LuaSyntaxSkipperFsm_destroy(s1);
    LuaSyntaxSkipperFsm_destroy(s2);
    LuaSyntaxSkipperFsm_destroy(s3);
    LuaSyntaxSkipperFsm_destroy(s4);
    LuaSyntaxSkipperFsm_destroy(s5);
    LuaSyntaxSkipperFsm_destroy(s6);

    if (failures > 0) {
        printf("FAIL: %d failures\n", failures);
        return 1;
    }
    printf("PASS: lua_skipper (6 cases)\n");
    return 0;
}

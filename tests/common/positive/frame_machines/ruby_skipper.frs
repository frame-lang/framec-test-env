@@[target("rust")]

// RubySyntaxSkipper -- FSM for skipping Ruby comments and strings.
// Translated from framec's native_region_scanner/ruby_skipper.frs
//
// Handles: # line comments, "..." / '...' strings,
// %Q{} / %q[] / %w() etc. percent literals,
// Ruby-style line endings, balanced parens.

use std::collections::HashMap;

@@system RubySyntaxSkipperFsm {
    operations:
        setup(input_bytes: Vec<u8>, start: i64, length: i64) {
            self.bytes = input_bytes;
            self.pos = start;
            self.scan_end = length;
        }
        get_result_pos(): i64 {
            return self.result_pos;
        }
        get_success(): i64 {
            return self.success;
        }

    interface:
        do_skip_comment()
        do_skip_string()
        do_find_line_end()
        do_balanced_paren_end()

    machine:
        $Init {
            do_skip_comment() { -> $SkipComment }
            do_skip_string() { -> $SkipString }
            do_find_line_end() { -> $FindLineEnd }
            do_balanced_paren_end() { -> $BalancedParenEnd }
        }

        $SkipComment {
            $>() {
                let i = self.pos as usize;
                let end = self.scan_end as usize;
                let bs = &self.bytes;

                // Ruby: # line comment only
                if i < end && bs[i] == 0x23 {
                    let mut j = i + 1;
                    while j < end && bs[j] != 0x0A {
                        j += 1;
                    }
                    self.result_pos = j as i64;
                    self.success = 1;
                    return;
                }

                self.success = 0;
            }
        }

        $SkipString {
            $>() {
                let i = self.pos as usize;
                let end = self.scan_end as usize;
                let bs = &self.bytes;

                // Percent literals: %Q{...}, %q[...], %w(...), etc.
                if i < end && bs[i] == 0x25 {
                    if i + 1 < end {
                        let c1 = bs[i + 1];
                        // Check for %Q, %q, %w, %W, %i, %I, %r, %x, %s
                        let has_letter = c1 == b'Q' || c1 == b'q' || c1 == b'w' || c1 == b'W' || c1 == b'i' || c1 == b'I' || c1 == b'r' || c1 == b'x' || c1 == b's';
                        let opener: u8;
                        let mut j: usize;
                        if has_letter && i + 2 < end {
                            opener = bs[i + 2];
                            j = i + 3;
                        } else if !c1.is_ascii_alphanumeric() && c1 != 0x5F {
                            // %{...} or %[...] or %<...> without letter
                            opener = c1;
                            j = i + 2;
                        } else {
                            self.success = 0;
                            return;
                        }

                        // Determine closer
                        let closer: u8;
                        if opener == 0x7B {
                            closer = 0x7D;
                        } else if opener == 0x5B {
                            closer = 0x5D;
                        } else if opener == 0x28 {
                            closer = 0x29;
                        } else if opener == 0x3C {
                            closer = 0x3E;
                        } else {
                            // Non-paired delimiter (e.g. %Q!...!)
                            let closer_np = opener;
                            // Scan to matching delimiter
                            while j < end {
                                if bs[j] == 0x5C {
                                    j += 2;
                                    continue;
                                }
                                if bs[j] == closer_np {
                                    self.result_pos = (j + 1) as i64;
                                    self.success = 1;
                                    return;
                                }
                                j += 1;
                            }
                            self.result_pos = end as i64;
                            self.success = 1;
                            return;
                        }

                        // Paired delimiter: track nesting
                        let mut depth: i32 = 1;
                        while j < end && depth > 0 {
                            if bs[j] == 0x5C {
                                j += 2;
                                continue;
                            }
                            if bs[j] == opener {
                                depth += 1;
                            } else if bs[j] == closer {
                                depth -= 1;
                            }
                            j += 1;
                        }
                        self.result_pos = j as i64;
                        self.success = 1;
                        return;
                    }
                }

                // Simple string: " or '
                if i < end && (bs[i] == 0x22 || bs[i] == 0x27) {
                    let q = bs[i];
                    let mut j = i + 1;
                    while j < end {
                        if bs[j] == 0x5C {
                            j += 2;
                            continue;
                        }
                        if bs[j] == q {
                            self.result_pos = (j + 1) as i64;
                            self.success = 1;
                            return;
                        }
                        j += 1;
                    }
                    self.result_pos = end as i64;
                    self.success = 1;
                    return;
                }

                self.success = 0;
            }
        }

        $FindLineEnd {
            $>() {
                let mut j = self.pos as usize;
                let end = self.scan_end as usize;
                let bs = &self.bytes;
                let mut in_string: u8 = 0;

                while j < end {
                    let b = bs[j];
                    if b == 0x0A {
                        break;
                    }

                    // Inside string
                    if in_string != 0 {
                        if b == 0x5C {
                            j += 2;
                            continue;
                        }
                        if b == in_string {
                            in_string = 0;
                        }
                        j += 1;
                        continue;
                    }

                    // Terminators
                    if b == 0x23 {
                        break;
                    }

                    // String starts
                    if b == 0x27 || b == 0x22 {
                        in_string = b;
                        j += 1;
                        continue;
                    }

                    j += 1;
                }

                self.result_pos = j as i64;
            }
        }

        $BalancedParenEnd {
            $>() {
                let mut i = self.pos as usize;
                let end = self.scan_end as usize;
                let bs = &self.bytes;

                if i >= end || bs[i] != 0x28 {
                    self.success = 0;
                    return;
                }

                let mut depth: i32 = 0;
                let mut in_string: u8 = 0;

                while i < end {
                    let b = bs[i];

                    // Inside string
                    if in_string != 0 {
                        if b == 0x5C {
                            i += 2;
                            continue;
                        }
                        if b == in_string {
                            in_string = 0;
                        }
                        i += 1;
                        continue;
                    }

                    if b == 0x27 || b == 0x22 {
                        in_string = b;
                        i += 1;
                    } else if b == 0x28 {
                        depth += 1;
                        i += 1;
                    } else if b == 0x29 {
                        depth -= 1;
                        i += 1;
                        if depth == 0 {
                            self.result_pos = i as i64;
                            self.success = 1;
                            return;
                        }
                    } else {
                        i += 1;
                    }
                }

                self.success = 0;
            }
        }

    domain:
        bytes: Vec<u8> = Vec::new()
        pos: i64 = 0
        scan_end: i64 = 0
        result_pos: i64 = 0
        success: i64 = 1
}

fn main() {
    let mut failures = 0;

    // Test 1: Skip # comment
    let mut s1 = @@RubySyntaxSkipperFsm();
    let inp1 = b"# comment\ncode".to_vec();
    s1.setup(inp1.clone(), 0, inp1.len() as i64);
    s1.do_skip_comment();
    if s1.get_success() != 1 || s1.get_result_pos() != 9 {
        println!("FAIL 1: success={}, pos={}", s1.get_success(), s1.get_result_pos());
        failures += 1;
    }

    // Test 2: Skip double-quoted string
    let mut s2 = @@RubySyntaxSkipperFsm();
    let inp2 = b"\"hello\" rest".to_vec();
    s2.setup(inp2.clone(), 0, inp2.len() as i64);
    s2.do_skip_string();
    if s2.get_success() != 1 || s2.get_result_pos() != 7 {
        println!("FAIL 2: success={}, pos={}", s2.get_success(), s2.get_result_pos());
        failures += 1;
    }

    // Test 3: Skip single-quoted string
    let mut s3 = @@RubySyntaxSkipperFsm();
    let inp3 = b"'hello' rest".to_vec();
    s3.setup(inp3.clone(), 0, inp3.len() as i64);
    s3.do_skip_string();
    if s3.get_success() != 1 || s3.get_result_pos() != 7 {
        println!("FAIL 3: success={}, pos={}", s3.get_success(), s3.get_result_pos());
        failures += 1;
    }

    // Test 4: Skip %Q{text}
    let mut s4 = @@RubySyntaxSkipperFsm();
    let inp4 = b"%Q{text} rest".to_vec();
    s4.setup(inp4.clone(), 0, inp4.len() as i64);
    s4.do_skip_string();
    if s4.get_success() != 1 || s4.get_result_pos() != 8 {
        println!("FAIL 4: success={}, pos={}", s4.get_success(), s4.get_result_pos());
        failures += 1;
    }

    // Test 5: Skip %q[text]
    let mut s5 = @@RubySyntaxSkipperFsm();
    let inp5 = b"%q[text] rest".to_vec();
    s5.setup(inp5.clone(), 0, inp5.len() as i64);
    s5.do_skip_string();
    if s5.get_success() != 1 || s5.get_result_pos() != 8 {
        println!("FAIL 5: success={}, pos={}", s5.get_success(), s5.get_result_pos());
        failures += 1;
    }

    // Test 6: Find line end (stops at #)
    let mut s6 = @@RubySyntaxSkipperFsm();
    let inp6 = b"x + 1 # comment".to_vec();
    s6.setup(inp6.clone(), 0, inp6.len() as i64);
    s6.do_find_line_end();
    if s6.get_result_pos() != 6 {
        println!("FAIL 6: pos={}, expected 6", s6.get_result_pos());
        failures += 1;
    }

    // Test 7: Balanced parens
    let mut s7 = @@RubySyntaxSkipperFsm();
    let inp7 = b"(a, f(b)) rest".to_vec();
    s7.setup(inp7.clone(), 0, inp7.len() as i64);
    s7.do_balanced_paren_end();
    if s7.get_success() != 1 || s7.get_result_pos() != 9 {
        println!("FAIL 7: success={}, pos={}", s7.get_success(), s7.get_result_pos());
        failures += 1;
    }

    // Test 8: Skip %Q with nested braces
    let mut s8 = @@RubySyntaxSkipperFsm();
    let inp8 = b"%Q{outer {inner} end} rest".to_vec();
    s8.setup(inp8.clone(), 0, inp8.len() as i64);
    s8.do_skip_string();
    if s8.get_success() != 1 || s8.get_result_pos() != 21 {
        println!("FAIL 8: success={}, pos={}", s8.get_success(), s8.get_result_pos());
        failures += 1;
    }

    if failures > 0 { println!("FAIL: {} failures", failures); std::process::exit(1); }
    println!("PASS: ruby_skipper (8 cases)");
}

@@[target("typescript")]

// CppSyntaxSkipper -- FSM for skipping C++-style comments and strings.
// C++ adds raw strings R"delim(...)delim" on top of C-style comments.

@@system CppSyntaxSkipperFsm {
    operations:
        setup(input_bytes: number[], start: number, length: number) {
            this.bytes = input_bytes;
            this.pos = start;
            this.scan_end = length;
        }
        get_result_pos(): number {
            return this.result_pos;
        }
        get_success(): number {
            return this.success;
        }

    interface:
        do_skip_comment()
        do_skip_string()
        do_find_line_end()
        do_balanced_paren_end()

    machine:
        $Init {
            do_skip_comment() { -> $SkipComment }
            do_skip_string() { -> $SkipString }
            do_find_line_end() { -> $FindLineEnd }
            do_balanced_paren_end() { -> $BalancedParenEnd }
        }

        $SkipComment {
            $>() {
                let i = this.pos;
                const end = this.scan_end;
                const bs = this.bytes;

                if (i + 1 < end && bs[i] === 0x2F && bs[i + 1] === 0x2F) {
                    let j = i + 2;
                    while (j < end && bs[j] !== 0x0A) { j++; }
                    this.result_pos = j;
                    this.success = 1;
                    return;
                }

                if (i + 1 < end && bs[i] === 0x2F && bs[i + 1] === 0x2A) {
                    let j = i + 2;
                    while (j + 1 < end) {
                        if (bs[j] === 0x2A && bs[j + 1] === 0x2F) {
                            this.result_pos = j + 2;
                            this.success = 1;
                            return;
                        }
                        j++;
                    }
                    this.result_pos = end;
                    this.success = 1;
                    return;
                }

                this.success = 0;
            }
        }

        $SkipString {
            $>() {
                let i = this.pos;
                const end = this.scan_end;
                const bs = this.bytes;

                // C++ raw string: R"delim(...)delim"
                if (i + 1 < end && bs[i] === 0x52 && bs[i + 1] === 0x22) {
                    let j = i + 2;
                    const delim: number[] = [];
                    while (j < end && bs[j] !== 0x28) {
                        delim.push(bs[j]);
                        j++;
                        if (delim.length > 32) { this.success = 0; return; }
                    }
                    if (j >= end || bs[j] !== 0x28) { this.success = 0; return; }
                    j++;
                    while (j < end) {
                        if (bs[j] === 0x29) {
                            let k = j + 1;
                            let m = 0;
                            while (m < delim.length && k < end && bs[k] === delim[m]) { k++; m++; }
                            if (m === delim.length && k < end && bs[k] === 0x22) {
                                this.result_pos = k + 1;
                                this.success = 1;
                                return;
                            }
                        }
                        j++;
                    }
                    this.result_pos = end;
                    this.success = 1;
                    return;
                }

                if (i < end && (bs[i] === 0x22 || bs[i] === 0x27)) {
                    const q = bs[i];
                    let j = i + 1;
                    while (j < end) {
                        if (bs[j] === 0x5C) { j += 2; continue; }
                        if (bs[j] === q) { this.result_pos = j + 1; this.success = 1; return; }
                        j++;
                    }
                    this.result_pos = end;
                    this.success = 1;
                    return;
                }

                this.success = 0;
            }
        }

        $FindLineEnd {
            $>() {
                let j = this.pos;
                const end = this.scan_end;
                const bs = this.bytes;

                while (j < end) {
                    const b = bs[j];
                    if (b === 0x0A || b === 0x3B) { break; }
                    if (b === 0x2F && j + 1 < end && bs[j + 1] === 0x2F) { break; }
                    if (b === 0x2F && j + 1 < end && bs[j + 1] === 0x2A) { break; }
                    j++;
                }

                this.result_pos = j;
            }
        }

        $BalancedParenEnd {
            $>() {
                let i = this.pos;
                const end = this.scan_end;
                const bs = this.bytes;

                if (i >= end || bs[i] !== 0x28) { this.success = 0; return; }

                let depth = 1;
                let j = i + 1;
                while (j < end && depth > 0) {
                    const b = bs[j];
                    if (b === 0x28) { depth++; }
                    else if (b === 0x29) { depth--; }
                    else if (b === 0x22 || b === 0x27) {
                        const q = b;
                        j++;
                        while (j < end && bs[j] !== q) {
                            if (bs[j] === 0x5C) { j++; }
                            j++;
                        }
                    }
                    j++;
                }

                if (depth === 0) { this.result_pos = j; this.success = 1; }
                else { this.result_pos = end; this.success = 0; }
            }
        }

    domain:
        bytes: number[] = []
        pos: number = 0
        scan_end: number = 0
        result_pos: number = 0
        success: number = 1
}

const enc = (s: string) => Array.from(Buffer.from(s));

let failures = 0;

const s1 = @@CppSyntaxSkipperFsm();
const inp1 = enc("// hello\ncode");
s1.setup(inp1, 0, inp1.length);
s1.do_skip_comment();
if (s1.get_success() !== 1 || s1.get_result_pos() !== 8) {
    console.log(`FAIL 1: success=${s1.get_success()}, pos=${s1.get_result_pos()}`);
    failures++;
}

const s2 = @@CppSyntaxSkipperFsm();
const inp2 = enc("/* block */code");
s2.setup(inp2, 0, inp2.length);
s2.do_skip_comment();
if (s2.get_success() !== 1 || s2.get_result_pos() !== 11) {
    console.log(`FAIL 2: success=${s2.get_success()}, pos=${s2.get_result_pos()}`);
    failures++;
}

const s3 = @@CppSyntaxSkipperFsm();
const inp3 = enc('"hello world" rest');
s3.setup(inp3, 0, inp3.length);
s3.do_skip_string();
if (s3.get_success() !== 1 || s3.get_result_pos() !== 13) {
    console.log(`FAIL 3: success=${s3.get_success()}, pos=${s3.get_result_pos()}`);
    failures++;
}

const s4 = @@CppSyntaxSkipperFsm();
const inp4 = enc('R"(raw string)" rest');
s4.setup(inp4, 0, inp4.length);
s4.do_skip_string();
if (s4.get_success() !== 1 || s4.get_result_pos() !== 15) {
    console.log(`FAIL 4: success=${s4.get_success()}, pos=${s4.get_result_pos()}`);
    failures++;
}

const s5 = @@CppSyntaxSkipperFsm();
const inp5 = enc('R"xyz(raw content)xyz" rest');
s5.setup(inp5, 0, inp5.length);
s5.do_skip_string();
if (s5.get_success() !== 1 || s5.get_result_pos() !== 22) {
    console.log(`FAIL 5: success=${s5.get_success()}, pos=${s5.get_result_pos()}`);
    failures++;
}

const s6 = @@CppSyntaxSkipperFsm();
const inp6 = enc("x + 1\nmore");
s6.setup(inp6, 0, inp6.length);
s6.do_find_line_end();
if (s6.get_result_pos() !== 5) {
    console.log(`FAIL 6: pos=${s6.get_result_pos()}, expected 5`);
    failures++;
}

const s7 = @@CppSyntaxSkipperFsm();
const inp7 = enc("x + 1");
s7.setup(inp7, 0, inp7.length);
s7.do_skip_comment();
if (s7.get_success() !== 0) {
    console.log("FAIL 7: should not be a comment");
    failures++;
}

const s8 = @@CppSyntaxSkipperFsm();
const inp8 = enc("(a, f(b), c) rest");
s8.setup(inp8, 0, inp8.length);
s8.do_balanced_paren_end();
if (s8.get_success() !== 1 || s8.get_result_pos() !== 12) {
    console.log(`FAIL 8: success=${s8.get_success()}, pos=${s8.get_result_pos()}`);
    failures++;
}

if (failures > 0) { console.log("FAIL: " + failures + " failures"); process.exit(1); }
console.log("PASS: cpp_skipper (8 cases)");

@@target kotlin

import kotlin.system.exitProcess

// CppSyntaxSkipper -- FSM for skipping C++-style comments and strings.
// C++ adds raw strings R"delim(...)delim" on top of C-style comments.

@@system CppSyntaxSkipperFsm {
    operations:
        setup(input_bytes: ByteArray, start: Int, length: Int) {
            this.bytes = input_bytes
            this.pos = start
            this.scan_end = length
        }
        get_result_pos(): Int {
            return this.result_pos
        }
        get_success(): Int {
            return this.success
        }

    interface:
        do_skip_comment()
        do_skip_string()
        do_find_line_end()
        do_balanced_paren_end()

    machine:
        $Init {
            do_skip_comment() { -> $SkipComment }
            do_skip_string() { -> $SkipString }
            do_find_line_end() { -> $FindLineEnd }
            do_balanced_paren_end() { -> $BalancedParenEnd }
        }

        $SkipComment {
            $>() {
                var i = this.pos
                val end = this.scan_end
                val bs = this.bytes

                if (i + 1 < end && (bs[i].toInt() and 0xFF) == '/'.code && (bs[i + 1].toInt() and 0xFF) == '/'.code) {
                    var j = i + 2
                    while (j < end && (bs[j].toInt() and 0xFF) != '\n'.code) { j++ }
                    this.result_pos = j
                    this.success = 1
                    return
                }

                if (i + 1 < end && (bs[i].toInt() and 0xFF) == '/'.code && (bs[i + 1].toInt() and 0xFF) == '*'.code) {
                    var j = i + 2
                    while (j + 1 < end) {
                        if ((bs[j].toInt() and 0xFF) == '*'.code && (bs[j + 1].toInt() and 0xFF) == '/'.code) {
                            this.result_pos = j + 2
                            this.success = 1
                            return
                        }
                        j++
                    }
                    this.result_pos = end
                    this.success = 1
                    return
                }

                this.success = 0
            }
        }

        $SkipString {
            $>() {
                var i = this.pos
                val end = this.scan_end
                val bs = this.bytes

                // C++ raw string: R"delim(...)delim"
                if (i + 1 < end && (bs[i].toInt() and 0xFF) == 'R'.code && (bs[i + 1].toInt() and 0xFF) == '"'.code) {
                    var j = i + 2
                    val delim = mutableListOf<Int>()
                    while (j < end && (bs[j].toInt() and 0xFF) != '('.code) {
                        delim.add(bs[j].toInt() and 0xFF)
                        j++
                        if (delim.size > 32) { this.success = 0; return }
                    }
                    if (j >= end || (bs[j].toInt() and 0xFF) != '('.code) { this.success = 0; return }
                    j++
                    while (j < end) {
                        if ((bs[j].toInt() and 0xFF) == ')'.code) {
                            var k = j + 1
                            var m = 0
                            while (m < delim.size && k < end && (bs[k].toInt() and 0xFF) == delim[m]) { k++; m++ }
                            if (m == delim.size && k < end && (bs[k].toInt() and 0xFF) == '"'.code) {
                                this.result_pos = k + 1
                                this.success = 1
                                return
                            }
                        }
                        j++
                    }
                    this.result_pos = end
                    this.success = 1
                    return
                }

                if (i < end && ((bs[i].toInt() and 0xFF) == '"'.code || (bs[i].toInt() and 0xFF) == '\''.code)) {
                    val q = bs[i].toInt() and 0xFF
                    var j = i + 1
                    while (j < end) {
                        if ((bs[j].toInt() and 0xFF) == '\\'.code) { j += 2; continue }
                        if ((bs[j].toInt() and 0xFF) == q) {
                            this.result_pos = j + 1
                            this.success = 1
                            return
                        }
                        j++
                    }
                    this.result_pos = end
                    this.success = 1
                    return
                }

                this.success = 0
            }
        }

        $FindLineEnd {
            $>() {
                var j = this.pos
                val end = this.scan_end
                val bs = this.bytes

                while (j < end) {
                    val b = bs[j].toInt() and 0xFF
                    if (b == '\n'.code || b == ';'.code) { break }
                    if (b == '/'.code && j + 1 < end && (bs[j + 1].toInt() and 0xFF) == '/'.code) { break }
                    if (b == '/'.code && j + 1 < end && (bs[j + 1].toInt() and 0xFF) == '*'.code) { break }
                    j++
                }

                this.result_pos = j
            }
        }

        $BalancedParenEnd {
            $>() {
                var i = this.pos
                val end = this.scan_end
                val bs = this.bytes

                if (i >= end || (bs[i].toInt() and 0xFF) != '('.code) {
                    this.success = 0
                    return
                }

                var depth = 1
                var j = i + 1
                while (j < end && depth > 0) {
                    val b = bs[j].toInt() and 0xFF
                    if (b == '('.code) { depth++ }
                    else if (b == ')'.code) { depth-- }
                    else if (b == '"'.code || b == '\''.code) {
                        val q = b
                        j++
                        while (j < end && (bs[j].toInt() and 0xFF) != q) {
                            if ((bs[j].toInt() and 0xFF) == '\\'.code) { j++ }
                            j++
                        }
                    }
                    j++
                }

                if (depth == 0) { this.result_pos = j; this.success = 1 }
                else { this.result_pos = end; this.success = 0 }
            }
        }

    domain:
        bytes: ByteArray = ByteArray(0)
        pos: Int = 0
        scan_end: Int = 0
        result_pos: Int = 0
        success: Int = 1
}

fun main() {
    var failures = 0

    val s1 = @@CppSyntaxSkipperFsm()
    val inp1 = "// hello\ncode".toByteArray()
    s1.setup(inp1, 0, inp1.size)
    s1.do_skip_comment()
    if (s1.get_success() != 1 || s1.get_result_pos() != 8) { println("FAIL 1: success=${s1.get_success()}, pos=${s1.get_result_pos()}"); failures++ }

    val s2 = @@CppSyntaxSkipperFsm()
    val inp2 = "/* block */code".toByteArray()
    s2.setup(inp2, 0, inp2.size)
    s2.do_skip_comment()
    if (s2.get_success() != 1 || s2.get_result_pos() != 11) { println("FAIL 2: success=${s2.get_success()}, pos=${s2.get_result_pos()}"); failures++ }

    val s3 = @@CppSyntaxSkipperFsm()
    val inp3 = "\"hello world\" rest".toByteArray()
    s3.setup(inp3, 0, inp3.size)
    s3.do_skip_string()
    if (s3.get_success() != 1 || s3.get_result_pos() != 13) { println("FAIL 3: success=${s3.get_success()}, pos=${s3.get_result_pos()}"); failures++ }

    val s4 = @@CppSyntaxSkipperFsm()
    val inp4 = "R\"(raw string)\" rest".toByteArray()
    s4.setup(inp4, 0, inp4.size)
    s4.do_skip_string()
    if (s4.get_success() != 1 || s4.get_result_pos() != 15) { println("FAIL 4: success=${s4.get_success()}, pos=${s4.get_result_pos()}"); failures++ }

    val s5 = @@CppSyntaxSkipperFsm()
    val inp5 = "R\"xyz(raw content)xyz\" rest".toByteArray()
    s5.setup(inp5, 0, inp5.size)
    s5.do_skip_string()
    if (s5.get_success() != 1 || s5.get_result_pos() != 22) { println("FAIL 5: success=${s5.get_success()}, pos=${s5.get_result_pos()}"); failures++ }

    val s6 = @@CppSyntaxSkipperFsm()
    val inp6 = "x + 1\nmore".toByteArray()
    s6.setup(inp6, 0, inp6.size)
    s6.do_find_line_end()
    if (s6.get_result_pos() != 5) { println("FAIL 6: pos=${s6.get_result_pos()}, expected 5"); failures++ }

    val s7 = @@CppSyntaxSkipperFsm()
    val inp7 = "x + 1".toByteArray()
    s7.setup(inp7, 0, inp7.size)
    s7.do_skip_comment()
    if (s7.get_success() != 0) { println("FAIL 7: should not be a comment"); failures++ }

    val s8 = @@CppSyntaxSkipperFsm()
    val inp8 = "(a, f(b), c) rest".toByteArray()
    s8.setup(inp8, 0, inp8.size)
    s8.do_balanced_paren_end()
    if (s8.get_success() != 1 || s8.get_result_pos() != 12) { println("FAIL 8: success=${s8.get_success()}, pos=${s8.get_result_pos()}"); failures++ }

    if (failures > 0) { println("FAIL: $failures failures"); exitProcess(1) }
    println("PASS: cpp_skipper (8 cases)")
}

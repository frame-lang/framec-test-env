@@target lua

-- PythonSyntaxSkipper — FSM for skipping Python comments and strings.
-- Translated from framec's native_region_scanner/python_skipper.frs
--
-- Handles: # comments, triple-quoted strings, simple strings,
-- Python-style line endings, balanced parens.
--
-- NOTE: Lua is 1-indexed, but the scanner uses 0-indexed positions
-- internally and adjusts when accessing the byte table.

@@system PythonSyntaxSkipperFsm {
    operations:
        setup(input_bytes, start, length) {
            self.bytes = input_bytes
            self.pos = start
            self.scan_end = length
        }
        get_result_pos() {
            return self.result_pos
        }
        get_success() {
            return self.success
        }

    interface:
        do_skip_comment()
        do_skip_string()
        do_find_line_end()
        do_balanced_paren_end()

    machine:
        $Init {
            do_skip_comment() { -> $SkipComment }
            do_skip_string() { -> $SkipString }
            do_find_line_end() { -> $FindLineEnd }
            do_balanced_paren_end() { -> $BalancedParenEnd }
        }

        $SkipComment {
            $>() {
                i = self.pos
                scan_end = self.scan_end
                bs = self.bytes

                -- Python uses # for line comments
                if i < scan_end and bs[i + 1] == 0x23 then
                    j = i + 1
                    while j < scan_end and bs[j + 1] ~= 0x0A do
                        j = j + 1
                    end
                    self.result_pos = j
                    self.success = 1
                    return
                end

                self.success = 0
            }
        }

        $SkipString {
            $>() {
                i = self.pos
                scan_end = self.scan_end
                bs = self.bytes

                -- Triple-quoted strings: """ or '''
                if i + 2 < scan_end then
                    if (bs[i+1] == 0x22 and bs[i+2] == 0x22 and bs[i+3] == 0x22) or
                       (bs[i+1] == 0x27 and bs[i+2] == 0x27 and bs[i+3] == 0x27) then
                        q = bs[i+1]
                        j = i + 3
                        while j + 2 < scan_end do
                            if bs[j+1] == q and bs[j+2] == q and bs[j+3] == q then
                                self.result_pos = j + 3
                                self.success = 1
                                return
                            end
                            j = j + 1
                        end
                        self.result_pos = scan_end
                        self.success = 1
                        return
                    end
                end

                -- Simple strings: " or '
                if i < scan_end and (bs[i+1] == 0x22 or bs[i+1] == 0x27) then
                    q = bs[i+1]
                    j = i + 1
                    while j < scan_end do
                        if bs[j+1] == 0x5C then
                            j = j + 2
                            goto continue_str
                        end
                        if bs[j+1] == q then
                            self.result_pos = j + 1
                            self.success = 1
                            return
                        end
                        j = j + 1
                        ::continue_str::
                    end
                    self.result_pos = scan_end
                    self.success = 1
                    return
                end

                self.success = 0
            }
        }

        $FindLineEnd {
            $>() {
                j = self.pos
                scan_end = self.scan_end
                bs = self.bytes

                while j < scan_end do
                    b = bs[j + 1]
                    if b == 0x0A or b == 0x3B then
                        break
                    end
                    -- Stop at # comment
                    if b == 0x23 then
                        break
                    end
                    j = j + 1
                end

                self.result_pos = j
            }
        }

        $BalancedParenEnd {
            $>() {
                i = self.pos
                scan_end = self.scan_end
                bs = self.bytes

                if i >= scan_end or bs[i + 1] ~= 0x28 then
                    self.success = 0
                    return
                end

                depth = 1
                j = i + 1
                while j < scan_end and depth > 0 do
                    b = bs[j + 1]
                    if b == 0x28 then
                        depth = depth + 1
                    elseif b == 0x29 then
                        depth = depth - 1
                    elseif b == 0x22 or b == 0x27 then
                        q = b
                        j = j + 1
                        while j < scan_end and bs[j + 1] ~= q do
                            if bs[j + 1] == 0x5C then
                                j = j + 1
                            end
                            j = j + 1
                        end
                    end
                    j = j + 1
                end

                if depth == 0 then
                    self.result_pos = j
                    self.success = 1
                else
                    self.result_pos = scan_end
                    self.success = 0
                end
            }
        }

    domain:
        bytes = {}
        pos: int = 0
        scan_end: int = 0
        result_pos: int = 0
        success: int = 1
}

local function str_to_bytes(s)
    local t = {}
    for i = 1, #s do
        t[i] = string.byte(s, i)
    end
    return t
end

local failures = 0

-- Test 1: Skip hash comment
local s1 = PythonSyntaxSkipperFsm.new()
local inp1 = str_to_bytes("# comment\ncode")
s1:setup(inp1, 0, #inp1)
s1:do_skip_comment()
if s1:get_success() ~= 1 or s1:get_result_pos() ~= 9 then
    print("FAIL 1: success=" .. s1:get_success() .. ", pos=" .. s1:get_result_pos())
    failures = failures + 1
end

-- Test 2: Not a comment
local s2 = PythonSyntaxSkipperFsm.new()
local inp2 = str_to_bytes("x + 1")
s2:setup(inp2, 0, #inp2)
s2:do_skip_comment()
if s2:get_success() ~= 0 then
    print("FAIL 2: should not be comment")
    failures = failures + 1
end

-- Test 3: Skip triple-quoted string
local s3 = PythonSyntaxSkipperFsm.new()
local inp3 = str_to_bytes('"""hello world"""rest')
s3:setup(inp3, 0, #inp3)
s3:do_skip_string()
if s3:get_success() ~= 1 or s3:get_result_pos() ~= 17 then
    print("FAIL 3: success=" .. s3:get_success() .. ", pos=" .. s3:get_result_pos())
    failures = failures + 1
end

-- Test 4: Skip simple string
local s4 = PythonSyntaxSkipperFsm.new()
local inp4 = str_to_bytes('"hello" rest')
s4:setup(inp4, 0, #inp4)
s4:do_skip_string()
if s4:get_success() ~= 1 or s4:get_result_pos() ~= 7 then
    print("FAIL 4: success=" .. s4:get_success() .. ", pos=" .. s4:get_result_pos())
    failures = failures + 1
end

-- Test 5: Skip string with escape
local s5 = PythonSyntaxSkipperFsm.new()
local inp5 = str_to_bytes("'he\\'llo' rest")
s5:setup(inp5, 0, #inp5)
s5:do_skip_string()
if s5:get_success() ~= 1 or s5:get_result_pos() ~= 9 then
    print("FAIL 5: success=" .. s5:get_success() .. ", pos=" .. s5:get_result_pos())
    failures = failures + 1
end

-- Test 6: Find line end (stops at #)
local s6 = PythonSyntaxSkipperFsm.new()
local inp6 = str_to_bytes("x + 1 # comment")
s6:setup(inp6, 0, #inp6)
s6:do_find_line_end()
if s6:get_result_pos() ~= 6 then
    print("FAIL 6: pos=" .. s6:get_result_pos() .. ", expected 6")
    failures = failures + 1
end

-- Test 7: Balanced parens
local s7 = PythonSyntaxSkipperFsm.new()
local inp7 = str_to_bytes("(a, f(b)) rest")
s7:setup(inp7, 0, #inp7)
s7:do_balanced_paren_end()
if s7:get_success() ~= 1 or s7:get_result_pos() ~= 9 then
    print("FAIL 7: success=" .. s7:get_success() .. ", pos=" .. s7:get_result_pos())
    failures = failures + 1
end

if failures > 0 then
    print("FAIL: " .. failures .. " failures")
    os.exit(1)
end
print("PASS: python_skipper (7 cases)")

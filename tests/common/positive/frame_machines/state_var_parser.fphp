@@[target("php")]

// StateVarParser — FSM for parsing $.varName and $.varName = expr
// Translated from framec's native_region_scanner/state_var_parser.frs
//
// Uses hierarchical composition: $ScanExpr creates an ExprScannerFsm
// sub-machine when it detects an assignment.

@@system ExprScannerFsm {
    operations:
        setup(input_bytes: array, start: int, length: int) {
            $this->bytes = $input_bytes;
            $this->pos = $start;
            $this->end = $length;
        }
        get_result(): int {
            return $this->result_end;
        }

    interface:
        do_scan()

    machine:
        $Init {
            do_scan() { -> $Scanning }
        }

        $Scanning {
            $>() {
                $i = $this->pos;
                $end = $this->end;
                $bs = $this->bytes;
                $depth = 0;
                $in_string = -1;

                while ($i < $end) {
                    $b = $bs[$i];

                    if ($in_string !== -1) {
                        if ($b === 0x5C && $i + 1 < $end) {
                            $i += 2;
                            continue;
                        }
                        if ($b === $in_string) {
                            $in_string = -1;
                        }
                        $i++;
                        continue;
                    }

                    if ($b === 0x22 || $b === 0x27) {
                        $in_string = $b;
                        $i++;
                        continue;
                    }

                    if ($b === 0x28 || $b === 0x5B || $b === 0x7B) {
                        $depth++;
                    } elseif ($b === 0x29 || $b === 0x5D || $b === 0x7D) {
                        $depth = max($depth - 1, 0);
                    } elseif ($b === 0x3B && $depth === 0) {
                        $i++;
                        break;
                    } elseif ($b === 0x0A && $depth === 0) {
                        break;
                    }

                    $i++;
                }

                $this->result_end = $i;
            }
        }

    domain:
        bytes = []
        pos = 0
        end = 0
        result_end = 0
}

@@[main]
@@system StateVarParserFsm {
    operations:
        setup(input_bytes: array, start: int, length: int) {
            $this->bytes = $input_bytes;
            $this->pos = $start;
            $this->parse_end = $length;
        }
        get_result_end(): int {
            return $this->result_end;
        }
        get_is_assignment(): bool {
            return $this->is_assignment;
        }

    interface:
        do_parse()

    machine:
        $Init {
            do_parse() { -> $ScanIdent }
        }

        $ScanIdent {
            $>() {
                // Skip "$." prefix and scan identifier
                $i = $this->pos + 2;
                $end = $this->parse_end;
                $bs = $this->bytes;

                while ($i < $end) {
                    $c = $bs[$i];
                    if (($c >= 0x30 && $c <= 0x39) || ($c >= 0x41 && $c <= 0x5A) || ($c >= 0x61 && $c <= 0x7A) || $c === 0x5F) {
                        $i++;
                    } else {
                        break;
                    }
                }

                $this->ident_end = $i;
                -> $CheckAssign
            }
        }

        $CheckAssign {
            $>() {
                // Lookahead: skip whitespace, check for = (but not == or => or =<)
                $j = $this->ident_end;
                $end = $this->parse_end;
                $bs = $this->bytes;

                while ($j < $end && ($bs[$j] === 0x20 || $bs[$j] === 0x09)) {
                    $j++;
                }

                if ($j < $end && $bs[$j] === 0x3D && ($j + 1 >= $end || ($bs[$j + 1] !== 0x3D && $bs[$j + 1] !== 0x3C && $bs[$j + 1] !== 0x3E))) {
                    // Assignment detected
                    $j++;
                    $this->pos = $j;
                    $this->is_assignment = true;
                    -> $ScanExpr
                } else {
                    // Read-only access
                    $this->result_end = $this->ident_end;
                    $this->is_assignment = false;
                    -> $Done
                }
            }
        }

        $ScanExpr {
            $>() {
                // Create ExprScanner sub-machine
                $expr = new ExprScannerFsm();
                $expr->setup($this->bytes, $this->pos, $this->parse_end);
                $expr->do_scan();
                $this->result_end = $expr->get_result();
                -> $Done
            }
        }

        $Done {
            $>() {
            }
        }

    domain:
        bytes = []
        pos = 0
        parse_end = 0
        ident_end = 0
        result_end = 0
        is_assignment = false
}

function str_to_bytes(string $s): array {
    $bytes = [];
    for ($i = 0; $i < strlen($s); $i++) {
        $bytes[] = ord($s[$i]);
    }
    return $bytes;
}

function bytes_to_str(array $bytes, int $start, int $end): string {
    $s = '';
    for ($i = $start; $i < $end; $i++) {
        $s .= chr($bytes[$i]);
    }
    return $s;
}

$failures = 0;

// Test 1: Read-only access $.count
$p1 = @@StateVarParserFsm();
$inp1 = str_to_bytes("$.count + 1");
$p1->setup($inp1, 0, count($inp1));
$p1->do_parse();
if ($p1->get_is_assignment()) { echo "FAIL 1: should not be assignment\n"; $failures++; }
$name1 = bytes_to_str($inp1, 2, $p1->get_result_end());
if ($name1 !== "count") { echo "FAIL 1: name='{$name1}', expected 'count'\n"; $failures++; }

// Test 2: Assignment $.total = x + 1;\n
$p2 = @@StateVarParserFsm();
$inp2 = str_to_bytes("$.total = x + 1;\nmore");
$p2->setup($inp2, 0, count($inp2));
$p2->do_parse();
if (!$p2->get_is_assignment()) { echo "FAIL 2: should be assignment\n"; $failures++; }
$expr2 = bytes_to_str($inp2, 0, $p2->get_result_end());
if (strpos($expr2, "x + 1;") === false) { echo "FAIL 2: expr='{$expr2}'\n"; $failures++; }

// Test 3: Not assignment $.x == 5 (== is comparison, not assignment)
$p3 = @@StateVarParserFsm();
$inp3 = str_to_bytes("$.x == 5");
$p3->setup($inp3, 0, count($inp3));
$p3->do_parse();
if ($p3->get_is_assignment()) { echo "FAIL 3: == should not be treated as assignment\n"; $failures++; }

// Test 4: Assignment with nested parens $.val = f(a, b)\n
$p4 = @@StateVarParserFsm();
$inp4 = str_to_bytes("$.val = f(a, b)\nrest");
$p4->setup($inp4, 0, count($inp4));
$p4->do_parse();
if (!$p4->get_is_assignment()) { echo "FAIL 4: should be assignment\n"; $failures++; }
$expr4 = bytes_to_str($inp4, 0, $p4->get_result_end());
if (strpos($expr4, "f(a, b)") === false) { echo "FAIL 4: expr='{$expr4}'\n"; $failures++; }

if ($failures > 0) { echo "FAIL: {$failures} failures\n"; exit(1); }
echo "PASS: state_var_parser (4 cases)\n";

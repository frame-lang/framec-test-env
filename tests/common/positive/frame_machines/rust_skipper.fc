@@target c

#include <string.h>

// RustSyntaxSkipper — FSM for skipping Rust comments and strings.
// Translated from framec's native_region_scanner/rust_skipper.frs
//
// Handles: // line comments, /* nested block comments */,
// raw strings (r#"..."#), char literals vs lifetime annotations,
// simple strings.

@@system RustSyntaxSkipperFsm {
    operations:
        setup(input_bytes: unsigned char*, start: int, length: int) {
            self->bytes = input_bytes;
            self->pos = start;
            self->scan_end = length;
        }
        get_result_pos(): int {
            return self->result_pos;
        }
        get_success(): int {
            return self->success;
        }

    interface:
        do_skip_comment()
        do_skip_string()
        do_find_line_end()

    machine:
        $Init {
            do_skip_comment() { -> $SkipComment }
            do_skip_string() { -> $SkipString }
            do_find_line_end() { -> $FindLineEnd }
        }

        $SkipComment {
            $>() {
                int i = self->pos;
                int end = self->scan_end;
                unsigned char* bs = self->bytes;

                // // line comment
                if (i + 1 < end && bs[i] == '/' && bs[i + 1] == '/') {
                    int j = i + 2;
                    while (j < end && bs[j] != '\n') {
                        j++;
                    }
                    self->result_pos = j;
                    self->success = 1;
                    return;
                }

                // /* nested block comment */ — Rust allows nesting
                if (i + 1 < end && bs[i] == '/' && bs[i + 1] == '*') {
                    int j = i + 2;
                    int depth = 1;
                    while (j + 1 < end && depth > 0) {
                        if (bs[j] == '/' && bs[j + 1] == '*') {
                            depth++;
                            j += 2;
                            continue;
                        }
                        if (bs[j] == '*' && bs[j + 1] == '/') {
                            depth--;
                            j += 2;
                            continue;
                        }
                        j++;
                    }
                    self->result_pos = j;
                    self->success = 1;
                    return;
                }

                self->success = 0;
            }
        }

        $SkipString {
            $>() {
                int i = self->pos;
                int end = self->scan_end;
                unsigned char* bs = self->bytes;

                // Raw string: r#"..."# (count leading #s)
                if (i < end && bs[i] == 'r') {
                    int j = i + 1;
                    int hash_count = 0;
                    while (j < end && bs[j] == '#') {
                        hash_count++;
                        j++;
                    }
                    if (j < end && bs[j] == '"') {
                        j++;
                        // Scan for closing "###
                        while (j < end) {
                            if (bs[j] == '"') {
                                int k = 0;
                                while (k < hash_count && j + 1 + k < end && bs[j + 1 + k] == '#') {
                                    k++;
                                }
                                if (k == hash_count) {
                                    self->result_pos = j + 1 + hash_count;
                                    self->success = 1;
                                    return;
                                }
                            }
                            j++;
                        }
                        self->result_pos = end;
                        self->success = 1;
                        return;
                    }
                }

                // Double-quoted string
                if (i < end && bs[i] == '"') {
                    int j = i + 1;
                    while (j < end) {
                        if (bs[j] == '\\') {
                            j += 2;
                            continue;
                        }
                        if (bs[j] == '"') {
                            self->result_pos = j + 1;
                            self->success = 1;
                            return;
                        }
                        j++;
                    }
                    self->result_pos = end;
                    self->success = 1;
                    return;
                }

                // Char literal: 'x' or '\n' (NOT lifetime 'a)
                if (i < end && bs[i] == '\'') {
                    if (i + 2 < end && bs[i + 1] == '\\' && i + 3 < end && bs[i + 3] == '\'') {
                        self->result_pos = i + 4;
                        self->success = 1;
                        return;
                    }
                    if (i + 2 < end && bs[i + 2] == '\'') {
                        self->result_pos = i + 3;
                        self->success = 1;
                        return;
                    }
                    self->success = 0;
                    return;
                }

                self->success = 0;
            }
        }

        $FindLineEnd {
            $>() {
                int j = self->pos;
                int end = self->scan_end;
                unsigned char* bs = self->bytes;

                while (j < end) {
                    char b = bs[j];
                    if (b == '\n' || b == ';') {
                        break;
                    }
                    if (b == '/' && j + 1 < end && bs[j + 1] == '/') {
                        break;
                    }
                    if (b == '/' && j + 1 < end && bs[j + 1] == '*') {
                        break;
                    }
                    j++;
                }

                self->result_pos = j;
            }
        }

    domain:
        bytes: unsigned char* = NULL
        pos: int = 0
        scan_end: int = 0
        result_pos: int = 0
        success: int = 1
}

int main() {
    int failures = 0;

    // Test 1: Skip // comment
    RustSyntaxSkipperFsm* s1 = @@RustSyntaxSkipperFsm();
    unsigned char t1[] = "// comment\ncode";
    RustSyntaxSkipperFsm_setup(s1, t1, 0, strlen((char*)t1));
    RustSyntaxSkipperFsm_do_skip_comment(s1);
    if (RustSyntaxSkipperFsm_get_success(s1) != 1 || RustSyntaxSkipperFsm_get_result_pos(s1) != 10) {
        printf("FAIL 1: success=%d, pos=%d\n", RustSyntaxSkipperFsm_get_success(s1), RustSyntaxSkipperFsm_get_result_pos(s1));
        failures++;
    }

    // Test 2: Skip nested /* /* */ */ block comment
    RustSyntaxSkipperFsm* s2 = @@RustSyntaxSkipperFsm();
    unsigned char t2[] = "/* outer /* inner */ */code";
    RustSyntaxSkipperFsm_setup(s2, t2, 0, strlen((char*)t2));
    RustSyntaxSkipperFsm_do_skip_comment(s2);
    if (RustSyntaxSkipperFsm_get_success(s2) != 1 || RustSyntaxSkipperFsm_get_result_pos(s2) != 23) {
        printf("FAIL 2: success=%d, pos=%d\n", RustSyntaxSkipperFsm_get_success(s2), RustSyntaxSkipperFsm_get_result_pos(s2));
        failures++;
    }

    // Test 3: Skip raw string r#"hello"#
    RustSyntaxSkipperFsm* s3 = @@RustSyntaxSkipperFsm();
    unsigned char t3[] = "r#\"hello\"#rest";
    RustSyntaxSkipperFsm_setup(s3, t3, 0, strlen((char*)t3));
    RustSyntaxSkipperFsm_do_skip_string(s3);
    if (RustSyntaxSkipperFsm_get_success(s3) != 1 || RustSyntaxSkipperFsm_get_result_pos(s3) != 10) {
        printf("FAIL 3: success=%d, pos=%d\n", RustSyntaxSkipperFsm_get_success(s3), RustSyntaxSkipperFsm_get_result_pos(s3));
        failures++;
    }

    // Test 4: Skip double-quoted string
    RustSyntaxSkipperFsm* s4 = @@RustSyntaxSkipperFsm();
    unsigned char t4[] = "\"hello\" rest";
    RustSyntaxSkipperFsm_setup(s4, t4, 0, strlen((char*)t4));
    RustSyntaxSkipperFsm_do_skip_string(s4);
    if (RustSyntaxSkipperFsm_get_success(s4) != 1 || RustSyntaxSkipperFsm_get_result_pos(s4) != 7) {
        printf("FAIL 4: success=%d, pos=%d\n", RustSyntaxSkipperFsm_get_success(s4), RustSyntaxSkipperFsm_get_result_pos(s4));
        failures++;
    }

    // Test 5: Char literal 'x' — IS a string
    RustSyntaxSkipperFsm* s5 = @@RustSyntaxSkipperFsm();
    unsigned char t5[] = "'x' rest";
    RustSyntaxSkipperFsm_setup(s5, t5, 0, strlen((char*)t5));
    RustSyntaxSkipperFsm_do_skip_string(s5);
    if (RustSyntaxSkipperFsm_get_success(s5) != 1 || RustSyntaxSkipperFsm_get_result_pos(s5) != 3) {
        printf("FAIL 5: success=%d, pos=%d\n", RustSyntaxSkipperFsm_get_success(s5), RustSyntaxSkipperFsm_get_result_pos(s5));
        failures++;
    }

    // Test 6: Lifetime 'a — NOT a string
    RustSyntaxSkipperFsm* s6 = @@RustSyntaxSkipperFsm();
    unsigned char t6[] = "'a rest";
    RustSyntaxSkipperFsm_setup(s6, t6, 0, strlen((char*)t6));
    RustSyntaxSkipperFsm_do_skip_string(s6);
    if (RustSyntaxSkipperFsm_get_success(s6) != 0) {
        printf("FAIL 6: lifetime should not be a string\n");
        failures++;
    }

    // Test 7: Escape char '\n'
    RustSyntaxSkipperFsm* s7 = @@RustSyntaxSkipperFsm();
    unsigned char t7[] = "'\\n' rest";
    RustSyntaxSkipperFsm_setup(s7, t7, 0, strlen((char*)t7));
    RustSyntaxSkipperFsm_do_skip_string(s7);
    if (RustSyntaxSkipperFsm_get_success(s7) != 1 || RustSyntaxSkipperFsm_get_result_pos(s7) != 4) {
        printf("FAIL 7: success=%d, pos=%d\n", RustSyntaxSkipperFsm_get_success(s7), RustSyntaxSkipperFsm_get_result_pos(s7));
        failures++;
    }

    RustSyntaxSkipperFsm_destroy(s1);
    RustSyntaxSkipperFsm_destroy(s2);
    RustSyntaxSkipperFsm_destroy(s3);
    RustSyntaxSkipperFsm_destroy(s4);
    RustSyntaxSkipperFsm_destroy(s5);
    RustSyntaxSkipperFsm_destroy(s6);
    RustSyntaxSkipperFsm_destroy(s7);

    if (failures > 0) {
        printf("FAIL: %d failures\n", failures);
        return 1;
    }
    printf("PASS: rust_skipper (7 cases)\n");
    return 0;
}

@@[target("lua")]

-- TypeScriptSyntaxSkipper — FSM for skipping TS/JS comments and strings.
-- Translated from framec's native_region_scanner/typescript_skipper.frs
--
-- Adds template literal awareness (backtick strings with ${} interpolation)
-- on top of the C-style comment and string patterns.
--
-- NOTE: Lua is 1-indexed, but the scanner uses 0-indexed positions
-- internally and adjusts when accessing the byte table.

@@system TSSyntaxSkipperFsm {
    operations:
        setup(input_bytes, start, length) {
            self.bytes = input_bytes
            self.pos = start
            self.scan_end = length
        }
        get_result_pos() {
            return self.result_pos
        }
        get_success() {
            return self.success
        }

    interface:
        do_skip_comment()
        do_skip_string()
        do_find_line_end()

    machine:
        $Init {
            do_skip_comment() { -> $SkipComment }
            do_skip_string() { -> $SkipString }
            do_find_line_end() { -> $FindLineEnd }
        }

        $SkipComment {
            $>() {
                i = self.pos
                scan_end = self.scan_end
                bs = self.bytes

                -- // line comment
                if i + 1 < scan_end and bs[i + 1] == 0x2F and bs[i + 2] == 0x2F then
                    j = i + 2
                    while j < scan_end and bs[j + 1] ~= 0x0A do
                        j = j + 1
                    end
                    self.result_pos = j
                    self.success = 1
                    return
                end

                -- /* block comment */
                if i + 1 < scan_end and bs[i + 1] == 0x2F and bs[i + 2] == 0x2A then
                    j = i + 2
                    while j + 1 < scan_end do
                        if bs[j + 1] == 0x2A and bs[j + 2] == 0x2F then
                            self.result_pos = j + 2
                            self.success = 1
                            return
                        end
                        j = j + 1
                    end
                    self.result_pos = scan_end
                    self.success = 1
                    return
                end

                self.success = 0
            }
        }

        $SkipString {
            $>() {
                i = self.pos
                scan_end = self.scan_end
                bs = self.bytes

                -- Template literal: `...${...}...`
                if i < scan_end and bs[i + 1] == 0x60 then
                    j = i + 1
                    template_depth = 0
                    while j < scan_end do
                        b = bs[j + 1]
                        if b == 0x60 and template_depth == 0 then
                            self.result_pos = j + 1
                            self.success = 1
                            return
                        end
                        if b == 0x5C then
                            j = j + 2
                            goto continue_template
                        end
                        if b == 0x24 and j + 1 < scan_end and bs[j + 2] == 0x7B then
                            template_depth = template_depth + 1
                            j = j + 2
                            goto continue_template
                        end
                        if b == 0x7D and template_depth > 0 then
                            template_depth = template_depth - 1
                        end
                        j = j + 1
                        ::continue_template::
                    end
                    self.result_pos = scan_end
                    self.success = 1
                    return
                end

                -- Simple string: " or '
                if i < scan_end and (bs[i + 1] == 0x22 or bs[i + 1] == 0x27) then
                    q = bs[i + 1]
                    j = i + 1
                    while j < scan_end do
                        if bs[j + 1] == 0x5C then
                            j = j + 2
                            goto continue_skip_string
                        end
                        if bs[j + 1] == q then
                            self.result_pos = j + 1
                            self.success = 1
                            return
                        end
                        j = j + 1
                        ::continue_skip_string::
                    end
                    self.result_pos = scan_end
                    self.success = 1
                    return
                end

                self.success = 0
            }
        }

        $FindLineEnd {
            $>() {
                j = self.pos
                scan_end = self.scan_end
                bs = self.bytes
                in_template = false
                template_depth = 0

                while j < scan_end do
                    b = bs[j + 1]

                    if in_template then
                        if b == 0x60 and template_depth == 0 then
                            in_template = false
                            j = j + 1
                            goto continue_find_line
                        end
                        if b == 0x5C then
                            j = j + 2
                            goto continue_find_line
                        end
                        if b == 0x24 and j + 1 < scan_end and bs[j + 2] == 0x7B then
                            template_depth = template_depth + 1
                            j = j + 2
                            goto continue_find_line
                        end
                        if b == 0x7D and template_depth > 0 then
                            template_depth = template_depth - 1
                        end
                        j = j + 1
                        goto continue_find_line
                    end

                    if b == 0x0A or b == 0x3B then
                        break
                    end
                    if b == 0x2F and j + 1 < scan_end and bs[j + 2] == 0x2F then
                        break
                    end
                    if b == 0x2F and j + 1 < scan_end and bs[j + 2] == 0x2A then
                        break
                    end
                    if b == 0x60 then
                        in_template = true
                        j = j + 1
                        goto continue_find_line
                    end
                    if b == 0x22 or b == 0x27 then
                        q = b
                        j = j + 1
                        while j < scan_end and bs[j + 1] ~= q do
                            if bs[j + 1] == 0x5C then
                                j = j + 1
                            end
                            j = j + 1
                        end
                        if j < scan_end then
                            j = j + 1
                        end
                        goto continue_find_line
                    end

                    j = j + 1
                    ::continue_find_line::
                end

                self.result_pos = j
            }
        }

    domain:
        bytes = {}
        pos: int = 0
        scan_end: int = 0
        result_pos: int = 0
        success: int = 1
}

local function str_to_bytes(s)
    local t = {}
    for i = 1, #s do
        t[i] = string.byte(s, i)
    end
    return t
end

local failures = 0

-- Test 1: Skip // line comment
local s1 = TSSyntaxSkipperFsm.new()
local inp1 = str_to_bytes("// comment\ncode")
s1:setup(inp1, 0, #inp1)
s1:do_skip_comment()
if s1:get_success() ~= 1 or s1:get_result_pos() ~= 10 then
    print("FAIL 1: success=" .. s1:get_success() .. ", pos=" .. s1:get_result_pos())
    failures = failures + 1
end

-- Test 2: Skip /* block comment */
local s2 = TSSyntaxSkipperFsm.new()
local inp2 = str_to_bytes("/* block */code")
s2:setup(inp2, 0, #inp2)
s2:do_skip_comment()
if s2:get_success() ~= 1 or s2:get_result_pos() ~= 11 then
    print("FAIL 2: success=" .. s2:get_success() .. ", pos=" .. s2:get_result_pos())
    failures = failures + 1
end

-- Test 3: Skip template literal
local s3 = TSSyntaxSkipperFsm.new()
local inp3 = str_to_bytes("`hello ${name} world`rest")
s3:setup(inp3, 0, #inp3)
s3:do_skip_string()
if s3:get_success() ~= 1 or s3:get_result_pos() ~= 21 then
    print("FAIL 3: success=" .. s3:get_success() .. ", pos=" .. s3:get_result_pos())
    failures = failures + 1
end

-- Test 4: Skip simple double-quoted string
local s4 = TSSyntaxSkipperFsm.new()
local inp4 = str_to_bytes('"hello" rest')
s4:setup(inp4, 0, #inp4)
s4:do_skip_string()
if s4:get_success() ~= 1 or s4:get_result_pos() ~= 7 then
    print("FAIL 4: success=" .. s4:get_success() .. ", pos=" .. s4:get_result_pos())
    failures = failures + 1
end

-- Test 5: Skip template with nested ${}
local s5 = TSSyntaxSkipperFsm.new()
local inp5 = str_to_bytes("`${a + ${b}}`rest")
s5:setup(inp5, 0, #inp5)
s5:do_skip_string()
if s5:get_success() ~= 1 then
    print("FAIL 5: success=" .. s5:get_success())
    failures = failures + 1
end

-- Test 6: Find line end skips over template literals
local s6 = TSSyntaxSkipperFsm.new()
local inp6 = str_to_bytes("x = `hello`;\nnext")
s6:setup(inp6, 0, #inp6)
s6:do_find_line_end()
if s6:get_result_pos() ~= 11 then
    print("FAIL 6: pos=" .. s6:get_result_pos() .. ", expected 11 (at ;)")
    failures = failures + 1
end

-- Test 7: Not a string
local s7 = TSSyntaxSkipperFsm.new()
local inp7 = str_to_bytes("x + 1")
s7:setup(inp7, 0, #inp7)
s7:do_skip_string()
if s7:get_success() ~= 0 then
    print("FAIL 7: should not be string")
    failures = failures + 1
end

if failures > 0 then
    print("FAIL: " .. failures .. " failures")
    os.exit(1)
end
print("PASS: ts_skipper (7 cases)")

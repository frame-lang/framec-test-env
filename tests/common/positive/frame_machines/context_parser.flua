@@target lua

-- ContextParser -- FSM for parsing @@ context constructs.
-- Translated from framec's native_region_scanner/context_parser.frs
--
-- NOTE: Lua is 1-indexed, but the scanner uses 0-indexed positions
-- internally and adjusts when accessing the byte table.

@@system ContextParserFsm {
    operations:
        setup(input_bytes, start, length) {
            self.bytes = input_bytes
            self.pos = start
            self.scan_end = length
        }
        setup_with_paren_end(input_bytes, start, length, p_end) {
            self.bytes = input_bytes
            self.pos = start
            self.scan_end = length
            self.paren_end = p_end
        }
        get_result_end() {
            return self.result_end
        }
        get_result_kind() {
            return self.result_kind
        }
        get_has_result() {
            return self.has_result
        }

    interface:
        do_parse()

    machine:
        $Init {
            do_parse() { -> $Dispatching }
        }

        $Dispatching {
            $>() {
                i = self.pos
                scan_end = self.scan_end
                bs = self.bytes

                if i >= scan_end then
                    self.has_result = 0
                    -> $Done
                end

                b = bs[i + 1]

                if b == 0x3A then
                    self.pos = i + 1
                    -> $DispatchColon
                elseif b >= 0x41 and b <= 0x5A then
                    -> $ParseInstantiation
                else
                    self.result_end = i
                    self.has_result = 0
                    -> $Done
                end
            }
        }

        $DispatchColon {
            $>() {
                i = self.pos
                scan_end = self.scan_end
                bs = self.bytes

                -- Check for @@:return
                if i + 5 < scan_end then
                    if bs[i + 1] == 0x72 and bs[i + 2] == 0x65 and bs[i + 3] == 0x74 and bs[i + 4] == 0x75 and bs[i + 5] == 0x72 and bs[i + 6] == 0x6E then
                        self.pos = i + 6
                        -> $ParseReturn
                    end
                end

                -- Check for @@:event
                if i + 4 < scan_end then
                    if bs[i + 1] == 0x65 and bs[i + 2] == 0x76 and bs[i + 3] == 0x65 and bs[i + 4] == 0x6E and bs[i + 5] == 0x74 then
                        self.result_end = i + 5
                        self.result_kind = 3
                        self.has_result = 1
                        -> $Done
                    end
                end

                -- Check for @@:data
                if i + 3 < scan_end then
                    if bs[i + 1] == 0x64 and bs[i + 2] == 0x61 and bs[i + 3] == 0x74 and bs[i + 4] == 0x61 then
                        self.pos = i + 4
                        -> $ParseData
                    end
                end

                -- Check for @@:params
                if i + 5 < scan_end then
                    if bs[i + 1] == 0x70 and bs[i + 2] == 0x61 and bs[i + 3] == 0x72 and bs[i + 4] == 0x61 and bs[i + 5] == 0x6D and bs[i + 6] == 0x73 then
                        self.pos = i + 6
                        -> $ParseParams
                    end
                end

                -- Check for @@:self
                if i + 3 < scan_end then
                    if bs[i + 1] == 0x73 and bs[i + 2] == 0x65 and bs[i + 3] == 0x6C and bs[i + 4] == 0x66 then
                        self.pos = i + 4
                        -> $ParseSelf
                    end
                end

                -- Check for @@:system
                if i + 5 < scan_end then
                    if bs[i + 1] == 0x73 and bs[i + 2] == 0x79 and bs[i + 3] == 0x73 and bs[i + 4] == 0x74 and bs[i + 5] == 0x65 and bs[i + 6] == 0x6D then
                        self.pos = i + 6
                        -> $ParseSystem
                    end
                end

                -- Check for @@:(expr)
                if i < scan_end and bs[i + 1] == 0x28 then
                    self.pos = i
                    -> $ParseContextReturnExpr
                end

                -- Unknown
                self.result_end = i
                self.has_result = 0
                -> $Done
            }
        }

        $ParseReturn {
            $>() {
                i = self.pos
                scan_end = self.scan_end
                bs = self.bytes

                while i < scan_end and (bs[i + 1] == 0x20 or bs[i + 1] == 0x09) do
                    i = i + 1
                end

                if i < scan_end and bs[i + 1] == 0x28 then
                    depth = 1
                    i = i + 1
                    while i < scan_end and depth > 0 do
                        if bs[i + 1] == 0x28 then
                            depth = depth + 1
                        end
                        if bs[i + 1] == 0x29 then
                            depth = depth - 1
                        end
                        if depth > 0 then
                            i = i + 1
                        end
                    end
                    if depth == 0 then
                        i = i + 1
                    end
                    self.result_end = i
                    self.result_kind = 9
                    self.has_result = 1
                    -> $Done
                elseif i < scan_end and bs[i + 1] == 0x3D and (i + 1 >= scan_end or bs[i + 2] ~= 0x3D) then
                    i = i + 1
                    while i < scan_end and (bs[i + 1] == 0x20 or bs[i + 1] == 0x09) do
                        i = i + 1
                    end
                    while i < scan_end and bs[i + 1] ~= 0x0A and bs[i + 1] ~= 0x3B do
                        i = i + 1
                    end
                    self.result_end = i
                    self.result_kind = 2
                    self.has_result = 1
                    -> $Done
                else
                    self.result_end = i
                    self.result_kind = 2
                    self.has_result = 1
                    -> $Done
                end
            }
        }

        $ParseContextReturnExpr {
            $>() {
                i = self.pos
                scan_end = self.scan_end
                bs = self.bytes

                if i < scan_end and bs[i + 1] == 0x28 then
                    depth = 1
                    i = i + 1
                    while i < scan_end and depth > 0 do
                        b = bs[i + 1]
                        if b == 0x28 then
                            depth = depth + 1
                        elseif b == 0x29 then
                            depth = depth - 1
                        elseif b == 0x22 or b == 0x27 then
                            q = b
                            i = i + 1
                            while i < scan_end do
                                if bs[i + 1] == 0x5C and i + 1 < scan_end then
                                    i = i + 2
                                    goto continue_ret_expr
                                end
                                if bs[i + 1] == q then
                                    break
                                end
                                i = i + 1
                                ::continue_ret_expr::
                            end
                        end
                        i = i + 1
                    end
                end

                self.result_end = i
                self.result_kind = 8
                self.has_result = 1
                -> $Done
            }
        }

        $ParseData {
            $>() {
                i = self.pos
                scan_end = self.scan_end
                bs = self.bytes

                if i < scan_end and bs[i + 1] == 0x2E then
                    i = i + 1
                    while i < scan_end and ((bs[i + 1] >= 0x61 and bs[i + 1] <= 0x7A) or (bs[i + 1] >= 0x41 and bs[i + 1] <= 0x5A) or (bs[i + 1] >= 0x30 and bs[i + 1] <= 0x39) or bs[i + 1] == 0x5F) do
                        i = i + 1
                    end
                end

                j = i
                while j < scan_end and (bs[j + 1] == 0x20 or bs[j + 1] == 0x09) do
                    j = j + 1
                end

                if j < scan_end and bs[j + 1] == 0x3D and (j + 1 >= scan_end or bs[j + 2] ~= 0x3D) then
                    j = j + 1
                    while j < scan_end and (bs[j + 1] == 0x20 or bs[j + 1] == 0x09) do
                        j = j + 1
                    end
                    while j < scan_end and bs[j + 1] ~= 0x0A and bs[j + 1] ~= 0x3B do
                        j = j + 1
                    end
                    self.result_end = j
                    self.result_kind = 5
                else
                    self.result_end = i
                    self.result_kind = 4
                end

                self.has_result = 1
                -> $Done
            }
        }

        $ParseParams {
            $>() {
                i = self.pos
                scan_end = self.scan_end
                bs = self.bytes

                if i < scan_end and bs[i + 1] == 0x2E then
                    i = i + 1
                    while i < scan_end and ((bs[i + 1] >= 0x61 and bs[i + 1] <= 0x7A) or (bs[i + 1] >= 0x41 and bs[i + 1] <= 0x5A) or (bs[i + 1] >= 0x30 and bs[i + 1] <= 0x39) or bs[i + 1] == 0x5F) do
                        i = i + 1
                    end
                end

                self.result_end = i
                self.result_kind = 6
                self.has_result = 1
                -> $Done
            }
        }

        $ParseSelf {
            $>() {
                i = self.pos
                scan_end = self.scan_end
                bs = self.bytes

                if i < scan_end and bs[i + 1] == 0x2E then
                    i = i + 1
                    while i < scan_end and ((bs[i + 1] >= 0x61 and bs[i + 1] <= 0x7A) or (bs[i + 1] >= 0x41 and bs[i + 1] <= 0x5A) or (bs[i + 1] >= 0x30 and bs[i + 1] <= 0x39) or bs[i + 1] == 0x5F) do
                        i = i + 1
                    end
                    if i < scan_end and bs[i + 1] == 0x28 then
                        depth = 1
                        i = i + 1
                        while i < scan_end and depth > 0 do
                            if bs[i + 1] == 0x28 then
                                depth = depth + 1
                            end
                            if bs[i + 1] == 0x29 then
                                depth = depth - 1
                            end
                            if bs[i + 1] == 0x22 or bs[i + 1] == 0x27 then
                                q = bs[i + 1]
                                i = i + 1
                                while i < scan_end do
                                    if bs[i + 1] == 0x5C and i + 1 < scan_end then
                                        i = i + 2
                                        goto continue_self_str
                                    end
                                    if bs[i + 1] == q then
                                        break
                                    end
                                    i = i + 1
                                    ::continue_self_str::
                                end
                            end
                            if depth > 0 then
                                i = i + 1
                            end
                        end
                        if depth == 0 then
                            i = i + 1
                        end
                        self.result_end = i
                        self.result_kind = 10
                        self.has_result = 1
                    else
                        self.result_end = i
                        self.result_kind = 11
                        self.has_result = 1
                    end
                else
                    self.result_end = i
                    self.result_kind = 11
                    self.has_result = 1
                end

                -> $Done
            }
        }

        $ParseSystem {
            $>() {
                i = self.pos
                scan_end = self.scan_end
                bs = self.bytes

                if i + 5 < scan_end then
                    if bs[i + 1] == 0x2E and bs[i + 2] == 0x73 and bs[i + 3] == 0x74 and bs[i + 4] == 0x61 and bs[i + 5] == 0x74 and bs[i + 6] == 0x65 then
                        after = i + 6
                        if after >= scan_end or not ((bs[after + 1] >= 0x61 and bs[after + 1] <= 0x7A) or (bs[after + 1] >= 0x41 and bs[after + 1] <= 0x5A) or (bs[after + 1] >= 0x30 and bs[after + 1] <= 0x39) or bs[after + 1] == 0x5F) then
                            self.result_end = i + 6
                            self.result_kind = 12
                            self.has_result = 1
                            -> $Done
                        end
                    end
                end

                self.result_end = i
                self.result_kind = 13
                self.has_result = 1
                -> $Done
            }
        }

        $ParseInstantiation {
            $>() {
                i = self.pos
                scan_end = self.scan_end
                bs = self.bytes

                while i < scan_end and ((bs[i + 1] >= 0x61 and bs[i + 1] <= 0x7A) or (bs[i + 1] >= 0x41 and bs[i + 1] <= 0x5A) or (bs[i + 1] >= 0x30 and bs[i + 1] <= 0x39) or bs[i + 1] == 0x5F) do
                    i = i + 1
                end

                if i < scan_end and bs[i + 1] == 0x28 then
                    if self.paren_end > 0 then
                        i = self.paren_end
                        self.result_end = i
                        self.result_kind = 7
                        self.has_result = 1
                    else
                        self.result_end = i
                        self.has_result = 0
                    end
                else
                    self.result_end = i
                    self.has_result = 0
                end

                -> $Done
            }
        }

        $Done {
            $>() {
                -- Terminal state
            }
        }

    domain:
        bytes = {}
        pos: int = 0
        scan_end: int = 0
        result_end: int = 0
        result_kind: int = 0
        has_result: int = 0
        paren_end: int = 0
}

local function str_to_bytes(s)
    local t = {}
    for i = 1, #s do
        t[i] = string.byte(s, i)
    end
    return t
end

local failures = 0

-- Test 1: @@:return (bare read)
local p1 = ContextParserFsm.new()
local inp1 = str_to_bytes(":return")
p1:setup(inp1, 0, #inp1)
p1:do_parse()
if p1:get_has_result() ~= 1 or p1:get_result_kind() ~= 2 then
    print("FAIL 1: has_result=" .. p1:get_has_result() .. ", kind=" .. p1:get_result_kind())
    failures = failures + 1
end

-- Test 2: @@:event
local p2 = ContextParserFsm.new()
local inp2 = str_to_bytes(":event")
p2:setup(inp2, 0, #inp2)
p2:do_parse()
if p2:get_has_result() ~= 1 or p2:get_result_kind() ~= 3 then
    print("FAIL 2: has_result=" .. p2:get_has_result() .. ", kind=" .. p2:get_result_kind())
    failures = failures + 1
end

-- Test 3: @@:data.key
local p3 = ContextParserFsm.new()
local inp3 = str_to_bytes(":data.name rest")
p3:setup(inp3, 0, #inp3)
p3:do_parse()
if p3:get_has_result() ~= 1 or p3:get_result_kind() ~= 4 then
    print("FAIL 3: has_result=" .. p3:get_has_result() .. ", kind=" .. p3:get_result_kind())
    failures = failures + 1
end

-- Test 4: @@:data.key = expr
local p4 = ContextParserFsm.new()
local inp4 = str_to_bytes(":data.key = value\n")
p4:setup(inp4, 0, #inp4)
p4:do_parse()
if p4:get_has_result() ~= 1 or p4:get_result_kind() ~= 5 then
    print("FAIL 4: has_result=" .. p4:get_has_result() .. ", kind=" .. p4:get_result_kind())
    failures = failures + 1
end

-- Test 5: @@:params.key
local p5 = ContextParserFsm.new()
local inp5 = str_to_bytes(":params.name rest")
p5:setup(inp5, 0, #inp5)
p5:do_parse()
if p5:get_has_result() ~= 1 or p5:get_result_kind() ~= 6 then
    print("FAIL 5: has_result=" .. p5:get_has_result() .. ", kind=" .. p5:get_result_kind())
    failures = failures + 1
end

-- Test 6: @@:(expr)
local p6 = ContextParserFsm.new()
local inp6 = str_to_bytes(":(x + 1) rest")
p6:setup(inp6, 0, #inp6)
p6:do_parse()
if p6:get_has_result() ~= 1 or p6:get_result_kind() ~= 8 then
    print("FAIL 6: has_result=" .. p6:get_has_result() .. ", kind=" .. p6:get_result_kind())
    failures = failures + 1
end

-- Test 7: @@:return(expr)
local p7 = ContextParserFsm.new()
local inp7 = str_to_bytes(":return(42) rest")
p7:setup(inp7, 0, #inp7)
p7:do_parse()
if p7:get_has_result() ~= 1 or p7:get_result_kind() ~= 9 then
    print("FAIL 7: has_result=" .. p7:get_has_result() .. ", kind=" .. p7:get_result_kind())
    failures = failures + 1
end

-- Test 8: @@:self (bare)
local p8 = ContextParserFsm.new()
local inp8 = str_to_bytes(":self rest")
p8:setup(inp8, 0, #inp8)
p8:do_parse()
if p8:get_has_result() ~= 1 or p8:get_result_kind() ~= 11 then
    print("FAIL 8: has_result=" .. p8:get_has_result() .. ", kind=" .. p8:get_result_kind())
    failures = failures + 1
end

-- Test 9: @@:self.method(args)
local p9 = ContextParserFsm.new()
local inp9 = str_to_bytes(":self.doWork(x) rest")
p9:setup(inp9, 0, #inp9)
p9:do_parse()
if p9:get_has_result() ~= 1 or p9:get_result_kind() ~= 10 then
    print("FAIL 9: has_result=" .. p9:get_has_result() .. ", kind=" .. p9:get_result_kind())
    failures = failures + 1
end

-- Test 10: @@:system.state
local p10 = ContextParserFsm.new()
local inp10 = str_to_bytes(":system.state rest")
p10:setup(inp10, 0, #inp10)
p10:do_parse()
if p10:get_has_result() ~= 1 or p10:get_result_kind() ~= 12 then
    print("FAIL 10: has_result=" .. p10:get_has_result() .. ", kind=" .. p10:get_result_kind())
    failures = failures + 1
end

-- Test 11: @@SystemName() with paren_end
local p11 = ContextParserFsm.new()
local inp11 = str_to_bytes("MySystem() rest")
p11:setup_with_paren_end(inp11, 0, #inp11, 10)
p11:do_parse()
if p11:get_has_result() ~= 1 or p11:get_result_kind() ~= 7 then
    print("FAIL 11: has_result=" .. p11:get_has_result() .. ", kind=" .. p11:get_result_kind())
    failures = failures + 1
end

-- Test 12: No match (lowercase, not a keyword)
local p12 = ContextParserFsm.new()
local inp12 = str_to_bytes("xyz")
p12:setup(inp12, 0, #inp12)
p12:do_parse()
if p12:get_has_result() ~= 0 then
    print("FAIL 12: should not match, has_result=" .. p12:get_has_result())
    failures = failures + 1
end

if failures > 0 then
    print("FAIL: " .. failures .. " failures")
    os.exit(1)
end
print("PASS: context_parser (12 cases)")

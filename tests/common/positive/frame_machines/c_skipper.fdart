@@target dart

import 'dart:io';

// CSyntaxSkipper -- FSM for skipping C-style comments and strings.
// Translated from framec's native_region_scanner/c_skipper.frs
//
// Demonstrates the skipper pattern: dispatch on entry point, scan
// to find the end of the construct, report result via domain vars.

@@system CSyntaxSkipperFsm {
    operations:
        setup(input_bytes: List<int>, start: int, length: int) {
            this.bytes = input_bytes;
            this.pos = start;
            this.end = length;
        }
        get_result_pos(): int {
            return this.result_pos;
        }
        get_success(): int {
            return this.success;
        }

    interface:
        do_skip_comment()
        do_skip_string()
        do_find_line_end()
        do_balanced_paren_end()

    machine:
        $Init {
            do_skip_comment() { -> $SkipComment }
            do_skip_string() { -> $SkipString }
            do_find_line_end() { -> $FindLineEnd }
            do_balanced_paren_end() { -> $BalancedParenEnd }
        }

        $SkipComment {
            $>() {
                int i = this.pos;
                int end = this.end;
                List<int> bs = this.bytes;

                // Try line comment: //
                if (i + 1 < end && bs[i] == 0x2F && bs[i + 1] == 0x2F) {
                    int j = i + 2;
                    while (j < end && bs[j] != 0x0A) {
                        j++;
                    }
                    this.result_pos = j;
                    this.success = 1;
                    return;
                }

                // Try block comment: /* ... */
                if (i + 1 < end && bs[i] == 0x2F && bs[i + 1] == 0x2A) {
                    int j = i + 2;
                    while (j + 1 < end) {
                        if (bs[j] == 0x2A && bs[j + 1] == 0x2F) {
                            this.result_pos = j + 2;
                            this.success = 1;
                            return;
                        }
                        j++;
                    }
                    this.result_pos = end;
                    this.success = 1;
                    return;
                }

                this.success = 0;
            }
        }

        $SkipString {
            $>() {
                int i = this.pos;
                int end = this.end;
                List<int> bs = this.bytes;

                if (i < end && (bs[i] == 0x22 || bs[i] == 0x27)) {
                    int q = bs[i];
                    int j = i + 1;
                    while (j < end) {
                        if (bs[j] == 0x5C) {
                            j += 2;
                            continue;
                        }
                        if (bs[j] == q) {
                            this.result_pos = j + 1;
                            this.success = 1;
                            return;
                        }
                        j++;
                    }
                    this.result_pos = end;
                    this.success = 1;
                    return;
                }

                this.success = 0;
            }
        }

        $FindLineEnd {
            $>() {
                int j = this.pos;
                int end = this.end;
                List<int> bs = this.bytes;

                while (j < end) {
                    int b = bs[j];
                    if (b == 0x0A || b == 0x3B) {
                        break;
                    }
                    if (b == 0x2F && j + 1 < end && bs[j + 1] == 0x2F) {
                        break;
                    }
                    if (b == 0x2F && j + 1 < end && bs[j + 1] == 0x2A) {
                        break;
                    }
                    j++;
                }

                this.result_pos = j;
            }
        }

        $BalancedParenEnd {
            $>() {
                int i = this.pos;
                int end = this.end;
                List<int> bs = this.bytes;

                if (i >= end || bs[i] != 0x28) {
                    this.success = 0;
                    return;
                }

                int depth = 1;
                int j = i + 1;
                while (j < end && depth > 0) {
                    int b = bs[j];
                    if (b == 0x28) {
                        depth++;
                    } else if (b == 0x29) {
                        depth--;
                    } else if (b == 0x22 || b == 0x27) {
                        int q = b;
                        j++;
                        while (j < end && bs[j] != q) {
                            if (bs[j] == 0x5C) {
                                j++;
                            }
                            j++;
                        }
                        // j is at closing quote
                    }
                    j++;
                }

                if (depth == 0) {
                    this.result_pos = j;
                    this.success = 1;
                } else {
                    this.result_pos = end;
                    this.success = 0;
                }
            }
        }

    domain:
        bytes: List<int> = []
        pos: int = 0
        end: int = 0
        result_pos: int = 0
        success: int = 1
}

void main() {
    int failures = 0;

    // Test 1: Skip line comment
    final s1 = @@CSyntaxSkipperFsm();
    final inp1 = "// hello\ncode".codeUnits;
    s1.setup(inp1, 0, inp1.length);
    s1.do_skip_comment();
    if (s1.get_success() != 1 || s1.get_result_pos() != 8) {
        print("FAIL 1: success=\${s1.get_success()}, pos=\${s1.get_result_pos()}");
        failures++;
    }

    // Test 2: Skip block comment
    final s2 = @@CSyntaxSkipperFsm();
    final inp2 = "/* block */code".codeUnits;
    s2.setup(inp2, 0, inp2.length);
    s2.do_skip_comment();
    if (s2.get_success() != 1 || s2.get_result_pos() != 11) {
        print("FAIL 2: success=\${s2.get_success()}, pos=\${s2.get_result_pos()}");
        failures++;
    }

    // Test 3: Not a comment
    final s3 = @@CSyntaxSkipperFsm();
    final inp3 = "x + 1".codeUnits;
    s3.setup(inp3, 0, inp3.length);
    s3.do_skip_comment();
    if (s3.get_success() != 0) {
        print("FAIL 3: should not be a comment");
        failures++;
    }

    // Test 4: Skip double-quoted string
    final s4 = @@CSyntaxSkipperFsm();
    final inp4 = '"hello world" rest'.codeUnits;
    s4.setup(inp4, 0, inp4.length);
    s4.do_skip_string();
    if (s4.get_success() != 1 || s4.get_result_pos() != 13) {
        print("FAIL 4: success=\${s4.get_success()}, pos=\${s4.get_result_pos()}");
        failures++;
    }

    // Test 5: Skip string with escaped quote
    final s5 = @@CSyntaxSkipperFsm();
    final inp5 = '"he\\"llo" rest'.codeUnits;
    s5.setup(inp5, 0, inp5.length);
    s5.do_skip_string();
    if (s5.get_success() != 1 || s5.get_result_pos() != 9) {
        print("FAIL 5: success=\${s5.get_success()}, pos=\${s5.get_result_pos()}");
        failures++;
    }

    // Test 6: Find line end (stops at newline)
    final s6 = @@CSyntaxSkipperFsm();
    final inp6 = "x + 1\nmore".codeUnits;
    s6.setup(inp6, 0, inp6.length);
    s6.do_find_line_end();
    if (s6.get_result_pos() != 5) {
        print("FAIL 6: pos=\${s6.get_result_pos()}, expected 5");
        failures++;
    }

    // Test 7: Find line end (stops at // comment)
    final s7 = @@CSyntaxSkipperFsm();
    final inp7 = "x + 1 // comment".codeUnits;
    s7.setup(inp7, 0, inp7.length);
    s7.do_find_line_end();
    if (s7.get_result_pos() != 6) {
        print("FAIL 7: pos=\${s7.get_result_pos()}, expected 6");
        failures++;
    }

    // Test 8: Balanced parens
    final s8 = @@CSyntaxSkipperFsm();
    final inp8 = "(a, f(b), c) rest".codeUnits;
    s8.setup(inp8, 0, inp8.length);
    s8.do_balanced_paren_end();
    if (s8.get_success() != 1 || s8.get_result_pos() != 12) {
        print("FAIL 8: success=\${s8.get_success()}, pos=\${s8.get_result_pos()}");
        failures++;
    }

    if (failures > 0) {
        print("FAIL: \$failures failures");
        exit(1);
    }
    print("PASS: c_skipper (8 cases)");
}

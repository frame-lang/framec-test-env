@@[target("gdscript")]
extends SceneTree

# PythonSyntaxSkipper — FSM for skipping Python comments and strings.
# Translated from framec's native_region_scanner/python_skipper.frs
#
# Handles: # comments, triple-quoted strings, simple strings,
# Python-style line endings, balanced parens.

@@system PythonSyntaxSkipperFsm {
    operations:
        setup(input_bytes: Array, start: int, length: int) {
            self.bytes = input_bytes
            self.pos = start
            self.scan_end = length
        }
        get_result_pos(): int {
            return self.result_pos
        }
        get_success(): int {
            return self.success
        }

    interface:
        do_skip_comment()
        do_skip_string()
        do_find_line_end()
        do_balanced_paren_end()

    machine:
        $Init {
            do_skip_comment() { -> $SkipComment }
            do_skip_string() { -> $SkipString }
            do_find_line_end() { -> $FindLineEnd }
            do_balanced_paren_end() { -> $BalancedParenEnd }
        }

        $SkipComment {
            $>() {
                var i = self.pos
                var scan_end = self.scan_end
                var bs = self.bytes

                # Python uses 0x23 for line comments
                if i < scan_end and bs[i] == 0x23:
                    var j = i + 1
                    while j < scan_end and bs[j] != 0x0A:
                        j += 1
                    self.result_pos = j
                    self.success = 1
                    return

                self.success = 0
            }
        }

        $SkipString {
            $>() {
                var i = self.pos
                var scan_end = self.scan_end
                var bs = self.bytes

                # Triple-quoted strings: """ or '''
                if i + 2 < scan_end:
                    if (bs[i] == 0x22 and bs[i+1] == 0x22 and bs[i+2] == 0x22) or \
                       (bs[i] == 0x27 and bs[i+1] == 0x27 and bs[i+2] == 0x27):
                        var q = bs[i]
                        var j = i + 3
                        while j + 2 < scan_end:
                            if bs[j] == q and bs[j+1] == q and bs[j+2] == q:
                                self.result_pos = j + 3
                                self.success = 1
                                return
                            j += 1
                        self.result_pos = scan_end
                        self.success = 1
                        return

                # Simple strings: " or '
                if i < scan_end and (bs[i] == 0x22 or bs[i] == 0x27):
                    var q = bs[i]
                    var j = i + 1
                    while j < scan_end:
                        if bs[j] == 0x5C:
                            j += 2
                            continue
                        if bs[j] == q:
                            self.result_pos = j + 1
                            self.success = 1
                            return
                        j += 1
                    self.result_pos = scan_end
                    self.success = 1
                    return

                self.success = 0
            }
        }

        $FindLineEnd {
            $>() {
                var j = self.pos
                var scan_end = self.scan_end
                var bs = self.bytes

                while j < scan_end:
                    var b = bs[j]
                    if b == 0x0A or b == 0x3B:
                        break
                    if b == 0x23:
                        break
                    j += 1

                self.result_pos = j
            }
        }

        $BalancedParenEnd {
            $>() {
                var i = self.pos
                var scan_end = self.scan_end
                var bs = self.bytes

                if i >= scan_end or bs[i] != 0x28:
                    self.success = 0
                    return

                var depth = 1
                var j = i + 1
                while j < scan_end and depth > 0:
                    var b = bs[j]
                    if b == 0x28:
                        depth += 1
                    elif b == 0x29:
                        depth -= 1
                    elif b == 0x22 or b == 0x27:
                        var q = b
                        j += 1
                        while j < scan_end and bs[j] != q:
                            if bs[j] == 0x5C:
                                j += 1
                            j += 1
                    j += 1

                if depth == 0:
                    self.result_pos = j
                    self.success = 1
                else:
                    self.result_pos = scan_end
                    self.success = 0
            }
        }

    domain:
        bytes: Array = []
        pos: int = 0
        scan_end: int = 0
        result_pos: int = 0
        success: int = 1
}

func str_to_bytes(s: String) -> Array:
    var arr = []
    var buf = s.to_utf8_buffer()
    for i in range(buf.size()):
        arr.append(buf[i])
    return arr

func main():
    var failures = 0

    # Test 1: Skip hash comment
    var s1 = @@PythonSyntaxSkipperFsm()
    var inp1 = str_to_bytes("# comment\ncode")
    s1.setup(inp1, 0, inp1.size())
    s1.do_skip_comment()
    if s1.get_success() != 1 or s1.get_result_pos() != 9:
        print("FAIL 1: success=" + str(s1.get_success()) + ", pos=" + str(s1.get_result_pos()))
        failures += 1

    # Test 2: Not a comment
    var s2 = @@PythonSyntaxSkipperFsm()
    var inp2 = str_to_bytes("x + 1")
    s2.setup(inp2, 0, inp2.size())
    s2.do_skip_comment()
    if s2.get_success() != 0:
        print("FAIL 2: should not be comment")
        failures += 1

    # Test 3: Skip triple-quoted string
    var s3 = @@PythonSyntaxSkipperFsm()
    var inp3 = str_to_bytes("\"\"\"hello world\"\"\"rest")
    s3.setup(inp3, 0, inp3.size())
    s3.do_skip_string()
    if s3.get_success() != 1 or s3.get_result_pos() != 17:
        print("FAIL 3: success=" + str(s3.get_success()) + ", pos=" + str(s3.get_result_pos()))
        failures += 1

    # Test 4: Skip simple string
    var s4 = @@PythonSyntaxSkipperFsm()
    var inp4 = str_to_bytes("\"hello\" rest")
    s4.setup(inp4, 0, inp4.size())
    s4.do_skip_string()
    if s4.get_success() != 1 or s4.get_result_pos() != 7:
        print("FAIL 4: success=" + str(s4.get_success()) + ", pos=" + str(s4.get_result_pos()))
        failures += 1

    # Test 5: Skip string with escape
    var s5 = @@PythonSyntaxSkipperFsm()
    var inp5 = str_to_bytes("'he\\'llo' rest")
    s5.setup(inp5, 0, inp5.size())
    s5.do_skip_string()
    if s5.get_success() != 1 or s5.get_result_pos() != 9:
        print("FAIL 5: success=" + str(s5.get_success()) + ", pos=" + str(s5.get_result_pos()))
        failures += 1

    # Test 6: Find line end (stops at 0x23)
    var s6 = @@PythonSyntaxSkipperFsm()
    var inp6 = str_to_bytes("x + 1 # comment")
    s6.setup(inp6, 0, inp6.size())
    s6.do_find_line_end()
    if s6.get_result_pos() != 6:
        print("FAIL 6: pos=" + str(s6.get_result_pos()) + ", expected 6")
        failures += 1

    # Test 7: Balanced parens
    var s7 = @@PythonSyntaxSkipperFsm()
    var inp7 = str_to_bytes("(a, f(b)) rest")
    s7.setup(inp7, 0, inp7.size())
    s7.do_balanced_paren_end()
    if s7.get_success() != 1 or s7.get_result_pos() != 9:
        print("FAIL 7: success=" + str(s7.get_success()) + ", pos=" + str(s7.get_result_pos()))
        failures += 1

    if failures > 0:
        print("FAIL: " + str(failures) + " failures")
        push_error(str(failures) + " test(s) failed")
    else:
        print("PASS: python_skipper (7 cases)")

func _init():
    main()
    quit()

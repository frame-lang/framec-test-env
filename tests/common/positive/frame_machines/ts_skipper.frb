@@[target("ruby")]

# TypeScriptSyntaxSkipper — FSM for skipping TS/JS comments and strings.
# Translated from framec's native_region_scanner/typescript_skipper.frs
#
# Adds template literal awareness (backtick strings with ${} interpolation)
# on top of the C-style comment and string patterns.

@@system TSSyntaxSkipperFsm {
    operations:
        setup(input_bytes, start, length) {
            self.bytes = input_bytes
            self.pos = start
            self.scan_end = length
        }
        get_result_pos() {
            return self.result_pos
        }
        get_success() {
            return self.success
        }

    interface:
        do_skip_comment()
        do_skip_string()
        do_find_line_end()

    machine:
        $Init {
            do_skip_comment() { -> $SkipComment }
            do_skip_string() { -> $SkipString }
            do_find_line_end() { -> $FindLineEnd }
        }

        $SkipComment {
            $>() {
                i = self.pos
                the_end = self.scan_end
                bs = self.bytes

                # // line comment
                if i + 1 < the_end && bs[i] == 0x2F && bs[i + 1] == 0x2F
                    j = i + 2
                    while j < the_end && bs[j] != 0x0A
                        j += 1
                    end
                    self.result_pos = j
                    self.success = 1
                    return
                end

                # /* block comment */
                if i + 1 < the_end && bs[i] == 0x2F && bs[i + 1] == 0x2A
                    j = i + 2
                    while j + 1 < the_end
                        if bs[j] == 0x2A && bs[j + 1] == 0x2F
                            self.result_pos = j + 2
                            self.success = 1
                            return
                        end
                        j += 1
                    end
                    self.result_pos = the_end
                    self.success = 1
                    return
                end

                self.success = 0
            }
        }

        $SkipString {
            $>() {
                i = self.pos
                the_end = self.scan_end
                bs = self.bytes

                # Template literal: `...${...}...`
                if i < the_end && bs[i] == 0x60
                    j = i + 1
                    template_depth = 0
                    while j < the_end
                        b = bs[j]
                        if b == 0x60 && template_depth == 0
                            self.result_pos = j + 1
                            self.success = 1
                            return
                        end
                        if b == 0x5C
                            j += 2
                            next
                        end
                        if b == 0x24 && j + 1 < the_end && bs[j + 1] == 0x7B
                            template_depth += 1
                            j += 2
                            next
                        end
                        if b == 0x7D && template_depth > 0
                            template_depth -= 1
                        end
                        j += 1
                    end
                    self.result_pos = the_end
                    self.success = 1
                    return
                end

                # Simple string: " or '
                if i < the_end && (bs[i] == 0x22 || bs[i] == 0x27)
                    q = bs[i]
                    j = i + 1
                    while j < the_end
                        if bs[j] == 0x5C
                            j += 2
                            next
                        end
                        if bs[j] == q
                            self.result_pos = j + 1
                            self.success = 1
                            return
                        end
                        j += 1
                    end
                    self.result_pos = the_end
                    self.success = 1
                    return
                end

                self.success = 0
            }
        }

        $FindLineEnd {
            $>() {
                j = self.pos
                the_end = self.scan_end
                bs = self.bytes
                in_template = false
                template_depth = 0

                while j < the_end
                    b = bs[j]

                    if in_template
                        if b == 0x60 && template_depth == 0
                            in_template = false
                            j += 1
                            next
                        end
                        if b == 0x5C
                            j += 2
                            next
                        end
                        if b == 0x24 && j + 1 < the_end && bs[j + 1] == 0x7B
                            template_depth += 1
                            j += 2
                            next
                        end
                        if b == 0x7D && template_depth > 0
                            template_depth -= 1
                        end
                        j += 1
                        next
                    end

                    if b == 0x0A || b == 0x3B
                        break
                    end
                    if b == 0x2F && j + 1 < the_end && bs[j + 1] == 0x2F
                        break
                    end
                    if b == 0x2F && j + 1 < the_end && bs[j + 1] == 0x2A
                        break
                    end
                    if b == 0x60
                        in_template = true
                        j += 1
                        next
                    end
                    if b == 0x22 || b == 0x27
                        q = b
                        j += 1
                        while j < the_end && bs[j] != q
                            if bs[j] == 0x5C
                                j += 1
                            end
                            j += 1
                        end
                        if j < the_end
                            j += 1
                        end
                        next
                    end

                    j += 1
                end

                self.result_pos = j
            }
        }

    domain:
        bytes = []
        pos: int = 0
        scan_end: int = 0
        result_pos: int = 0
        success: int = 1
}

failures = 0

# Test 1: Skip // line comment
s1 = @@TSSyntaxSkipperFsm()
inp1 = "// comment\ncode".bytes
s1.setup(inp1, 0, inp1.length)
s1.do_skip_comment()
if s1.get_success() != 1 || s1.get_result_pos() != 10
    puts("FAIL 1: success=#{s1.get_success()}, pos=#{s1.get_result_pos()}")
    failures += 1
end

# Test 2: Skip /* block comment */
s2 = @@TSSyntaxSkipperFsm()
inp2 = "/* block */code".bytes
s2.setup(inp2, 0, inp2.length)
s2.do_skip_comment()
if s2.get_success() != 1 || s2.get_result_pos() != 11
    puts("FAIL 2: success=#{s2.get_success()}, pos=#{s2.get_result_pos()}")
    failures += 1
end

# Test 3: Skip template literal
s3 = @@TSSyntaxSkipperFsm()
inp3 = "`hello ${name} world`rest".bytes
s3.setup(inp3, 0, inp3.length)
s3.do_skip_string()
if s3.get_success() != 1 || s3.get_result_pos() != 21
    puts("FAIL 3: success=#{s3.get_success()}, pos=#{s3.get_result_pos()}")
    failures += 1
end

# Test 4: Skip simple double-quoted string
s4 = @@TSSyntaxSkipperFsm()
inp4 = "\"hello\" rest".bytes
s4.setup(inp4, 0, inp4.length)
s4.do_skip_string()
if s4.get_success() != 1 || s4.get_result_pos() != 7
    puts("FAIL 4: success=#{s4.get_success()}, pos=#{s4.get_result_pos()}")
    failures += 1
end

# Test 5: Skip template with nested ${}
s5 = @@TSSyntaxSkipperFsm()
inp5 = "`${a + ${b}}`rest".bytes
s5.setup(inp5, 0, inp5.length)
s5.do_skip_string()
if s5.get_success() != 1
    puts("FAIL 5: success=#{s5.get_success()}")
    failures += 1
end

# Test 6: Find line end skips over template literals
s6 = @@TSSyntaxSkipperFsm()
inp6 = "x = `hello`;\nnext".bytes
s6.setup(inp6, 0, inp6.length)
s6.do_find_line_end()
if s6.get_result_pos() != 11
    puts("FAIL 6: pos=#{s6.get_result_pos()}, expected 11 (at ;)")
    failures += 1
end

# Test 7: Not a string
s7 = @@TSSyntaxSkipperFsm()
inp7 = "x + 1".bytes
s7.setup(inp7, 0, inp7.length)
s7.do_skip_string()
if s7.get_success() != 0
    puts("FAIL 7: should not be string")
    failures += 1
end

if failures > 0
    puts("FAIL: #{failures} failures")
    exit(1)
end
puts("PASS: ts_skipper (7 cases)")

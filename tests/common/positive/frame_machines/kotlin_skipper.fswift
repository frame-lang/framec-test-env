@@target swift

import Foundation

// kotlin_skipper -- FSM for skipping syntax constructs.

@@system KotlinSyntaxSkipperFsm {
    operations:
        setup(input_bytes: [UInt8], start: Int, length: Int) {
            self.bytes = input_bytes
            self.pos = start
            self.scan_end = length
        }
        get_result_pos(): Int {
            return self.result_pos
        }
        get_success(): Int {
            return self.success
        }

    interface:
        do_skip_comment()
        do_skip_string()
        do_find_line_end()
        do_balanced_paren_end()

    machine:
        $Init {
            do_skip_comment() { -> $SkipComment }
            do_skip_string() { -> $SkipString }
            do_find_line_end() { -> $FindLineEnd }
            do_balanced_paren_end() { -> $BalancedParenEnd }
        }

        $SkipComment {
            $>() {
                var i = self.pos
                let end = self.scan_end
                let bs = self.bytes

                if i + 1 < end && bs[i] == UInt8(ascii: "/") && bs[i + 1] == UInt8(ascii: "/") {
                    var j = i + 2
                    while j < end && bs[j] != 0x0A { j += 1 }
                    self.result_pos = j; self.success = 1; return
                }
                if i + 1 < end && bs[i] == UInt8(ascii: "/") && bs[i + 1] == UInt8(ascii: "*") {
                    var j = i + 2
                    while j + 1 < end {
                        if bs[j] == UInt8(ascii: "*") && bs[j + 1] == UInt8(ascii: "/") {
                            self.result_pos = j + 2; self.success = 1; return
                        }
                        j += 1
                    }
                    self.result_pos = end; self.success = 1; return
                }
                self.success = 0
            }
        }

        $SkipString {
            $>() {
                var i = self.pos
                let end = self.scan_end
                let bs = self.bytes

                if i + 2 < end && bs[i] == UInt8(ascii: "\"") && bs[i + 1] == UInt8(ascii: "\"") && bs[i + 2] == UInt8(ascii: "\"") {
                    var j = i + 3
                    while j + 2 < end {
                        if bs[j] == UInt8(ascii: "\"") && bs[j + 1] == UInt8(ascii: "\"") && bs[j + 2] == UInt8(ascii: "\"") {
                            self.result_pos = j + 3; self.success = 1; return
                        }
                        j += 1
                    }
                    self.result_pos = end; self.success = 1; return
                }

                if i < end && (bs[i] == UInt8(ascii: "\"") || bs[i] == UInt8(ascii: "'")) {
                    let q = bs[i]
                    var j = i + 1
                    while j < end {
                        if bs[j] == UInt8(ascii: "\\") { j += 2; continue }
                        if bs[j] == q { self.result_pos = j + 1; self.success = 1; return }
                        j += 1
                    }
                    self.result_pos = end; self.success = 1; return
                }
                self.success = 0
            }
        }

        $FindLineEnd {
            $>() {
                var j = self.pos
                let end = self.scan_end
                let bs = self.bytes

                while j < end {
                    let b = bs[j]
                    if b == 0x0A || b == UInt8(ascii: ";") { break }
                    if b == UInt8(ascii: "/") && j + 1 < end && bs[j + 1] == UInt8(ascii: "/") { break }
                    if b == UInt8(ascii: "/") && j + 1 < end && bs[j + 1] == UInt8(ascii: "*") { break }
                    j += 1
                }
                self.result_pos = j
            }
        }

        $BalancedParenEnd {
            $>() {
                var i = self.pos
                let end = self.scan_end
                let bs = self.bytes

                if i >= end || bs[i] != UInt8(ascii: "(") { self.success = 0; return }
                var depth = 1; var j = i + 1
                while j < end && depth > 0 {
                    let b = bs[j]
                    if b == UInt8(ascii: "(") { depth += 1 }
                    else if b == UInt8(ascii: ")") { depth -= 1 }
                    else if b == UInt8(ascii: "\"") || b == UInt8(ascii: "'") {
                        let q = b; j += 1
                        while j < end && bs[j] != q {
                            if bs[j] == UInt8(ascii: "\\") { j += 1 }
                            j += 1
                        }
                    }
                    j += 1
                }
                if depth == 0 { self.result_pos = j; self.success = 1 }
                else { self.result_pos = end; self.success = 0 }
            }
        }

    domain:
        bytes: [UInt8] = []
        pos: Int = 0
        scan_end: Int = 0
        result_pos: Int = 0
        success: Int = 1
}

// main
    var failures = 0

    let s1 = @@KotlinSyntaxSkipperFsm()
    let inp1: [UInt8] = Array("// hello\ncode".utf8)
    s1.setup(inp1, 0, inp1.count)
    s1.do_skip_comment()
    if s1.get_success() != 1 || s1.get_result_pos() != 8 {
        print("FAIL 1: Skip line comment")
        failures += 1
    }

    let s2 = @@KotlinSyntaxSkipperFsm()
    let inp2: [UInt8] = Array("/* block */code".utf8)
    s2.setup(inp2, 0, inp2.count)
    s2.do_skip_comment()
    if s2.get_success() != 1 || s2.get_result_pos() != 11 {
        print("FAIL 2: Skip block comment")
        failures += 1
    }

    let s3 = @@KotlinSyntaxSkipperFsm()
    let inp3: [UInt8] = Array("\"hello world\" rest".utf8)
    s3.setup(inp3, 0, inp3.count)
    s3.do_skip_string()
    if s3.get_success() != 1 || s3.get_result_pos() != 13 {
        print("FAIL 3: Skip double-quoted string")
        failures += 1
    }

    let s4 = @@KotlinSyntaxSkipperFsm()
    let inp4: [UInt8] = Array("\"\"\"raw string content\"\"\" rest".utf8)
    s4.setup(inp4, 0, inp4.count)
    s4.do_skip_string()
    if s4.get_success() != 1 || s4.get_result_pos() != 24 {
        print("FAIL 4: Kotlin raw string")
        failures += 1
    }

    let s5 = @@KotlinSyntaxSkipperFsm()
    let inp5: [UInt8] = Array("x + 1\nmore".utf8)
    s5.setup(inp5, 0, inp5.count)
    s5.do_find_line_end()
    if s5.get_result_pos() != 5 {
        print("FAIL 5: Find line end")
        failures += 1
    }

    let s6 = @@KotlinSyntaxSkipperFsm()
    let inp6: [UInt8] = Array("x + 1".utf8)
    s6.setup(inp6, 0, inp6.count)
    s6.do_skip_comment()
    if s6.get_success() != 0 {
        print("FAIL 6: Not a comment")
        failures += 1
    }

    let s7 = @@KotlinSyntaxSkipperFsm()
    let inp7: [UInt8] = Array("(a, f(b), c) rest".utf8)
    s7.setup(inp7, 0, inp7.count)
    s7.do_balanced_paren_end()
    if s7.get_success() != 1 || s7.get_result_pos() != 12 {
        print("FAIL 7: Balanced parens")
        failures += 1
    }

    let s8 = @@KotlinSyntaxSkipperFsm()
    let inp8: [UInt8] = Array("x + 1 // comment".utf8)
    s8.setup(inp8, 0, inp8.count)
    s8.do_find_line_end()
    if s8.get_result_pos() != 6 {
        print("FAIL 8: Find line end at //")
        failures += 1
    }

    if failures > 0 {
        print("FAIL: \(failures) failures")
        exit(1)
    }
    print("PASS: kotlin_skipper (8 cases)")

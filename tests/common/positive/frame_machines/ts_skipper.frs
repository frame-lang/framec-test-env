@@[target("rust")]

// TypeScriptSyntaxSkipper — FSM for skipping TS/JS comments and strings.
// Translated from framec's native_region_scanner/typescript_skipper.frs
//
// Adds template literal awareness (backtick strings with ${} interpolation)
// on top of the C-style comment and string patterns.

use std::collections::HashMap;

@@system TSSyntaxSkipperFsm {
    operations:
        setup(input_bytes: Vec<u8>, start: i64, length: i64) {
            self.bytes = input_bytes;
            self.pos = start;
            self.scan_end = length;
        }
        get_result_pos(): i64 {
            return self.result_pos;
        }
        get_success(): i64 {
            return self.success;
        }

    interface:
        do_skip_comment()
        do_skip_string()
        do_find_line_end()

    machine:
        $Init {
            do_skip_comment() { -> $SkipComment }
            do_skip_string() { -> $SkipString }
            do_find_line_end() { -> $FindLineEnd }
        }

        $SkipComment {
            $>() {
                let i = self.pos as usize;
                let end = self.scan_end as usize;
                let bs = &self.bytes;

                // // line comment
                if i + 1 < end && bs[i] == b'/' && bs[i + 1] == b'/' {
                    let mut j = i + 2;
                    while j < end && bs[j] != b'\n' {
                        j += 1;
                    }
                    self.result_pos = j as i64;
                    self.success = 1;
                    return;
                }

                // /* block comment */
                if i + 1 < end && bs[i] == b'/' && bs[i + 1] == b'*' {
                    let mut j = i + 2;
                    while j + 1 < end {
                        if bs[j] == b'*' && bs[j + 1] == b'/' {
                            self.result_pos = (j + 2) as i64;
                            self.success = 1;
                            return;
                        }
                        j += 1;
                    }
                    self.result_pos = end as i64;
                    self.success = 1;
                    return;
                }

                self.success = 0;
            }
        }

        $SkipString {
            $>() {
                let i = self.pos as usize;
                let end = self.scan_end as usize;
                let bs = &self.bytes;

                // Template literal: `...${...}...`
                if i < end && bs[i] == b'`' {
                    let mut j = i + 1;
                    let mut template_depth: i32 = 0;
                    while j < end {
                        let b = bs[j];
                        if b == b'`' && template_depth == 0 {
                            self.result_pos = (j + 1) as i64;
                            self.success = 1;
                            return;
                        }
                        if b == b'\\' {
                            j += 2;
                            continue;
                        }
                        if b == b'$' && j + 1 < end && bs[j + 1] == b'{' {
                            template_depth += 1;
                            j += 2;
                            continue;
                        }
                        if b == b'}' && template_depth > 0 {
                            template_depth -= 1;
                        }
                        j += 1;
                    }
                    self.result_pos = end as i64;
                    self.success = 1;
                    return;
                }

                // Simple string: " or '
                if i < end && (bs[i] == b'"' || bs[i] == b'\'') {
                    let q = bs[i];
                    let mut j = i + 1;
                    while j < end {
                        if bs[j] == b'\\' {
                            j += 2;
                            continue;
                        }
                        if bs[j] == q {
                            self.result_pos = (j + 1) as i64;
                            self.success = 1;
                            return;
                        }
                        j += 1;
                    }
                    self.result_pos = end as i64;
                    self.success = 1;
                    return;
                }

                self.success = 0;
            }
        }

        $FindLineEnd {
            $>() {
                let mut j = self.pos as usize;
                let end = self.scan_end as usize;
                let bs = &self.bytes;
                let mut in_template = false;
                let mut template_depth: i32 = 0;

                while j < end {
                    let b = bs[j];

                    if in_template {
                        if b == b'`' && template_depth == 0 {
                            in_template = false;
                            j += 1;
                            continue;
                        }
                        if b == b'\\' {
                            j += 2;
                            continue;
                        }
                        if b == b'$' && j + 1 < end && bs[j + 1] == b'{' {
                            template_depth += 1;
                            j += 2;
                            continue;
                        }
                        if b == b'}' && template_depth > 0 {
                            template_depth -= 1;
                        }
                        j += 1;
                        continue;
                    }

                    if b == b'\n' {
                        break;
                    }
                    if b == b';' {
                        break;
                    }
                    if b == b'/' && j + 1 < end && bs[j + 1] == b'/' {
                        break;
                    }
                    if b == b'/' && j + 1 < end && bs[j + 1] == b'*' {
                        break;
                    }
                    if b == b'`' {
                        in_template = true;
                        j += 1;
                        continue;
                    }
                    if b == b'"' || b == b'\'' {
                        let q = b;
                        j += 1;
                        while j < end && bs[j] != q {
                            if bs[j] == b'\\' {
                                j += 1;
                            }
                            j += 1;
                        }
                        if j < end {
                            j += 1;
                        }
                        continue;
                    }

                    j += 1;
                }

                self.result_pos = j as i64;
            }
        }

    domain:
        bytes: Vec<u8> = Vec::new()
        pos: i64 = 0
        scan_end: i64 = 0
        result_pos: i64 = 0
        success: i64 = 1
}

fn main() {
    let mut failures = 0;

    // Test 1: Skip // line comment
    let mut s1 = @@TSSyntaxSkipperFsm();
    let inp1 = b"// comment\ncode".to_vec();
    let len1 = inp1.len() as i64;
    s1.setup(inp1, 0, len1);
    s1.do_skip_comment();
    if s1.get_success() != 1 || s1.get_result_pos() != 10 {
        println!("FAIL 1: success={}, pos={}", s1.get_success(), s1.get_result_pos());
        failures += 1;
    }

    // Test 2: Skip /* block comment */
    let mut s2 = @@TSSyntaxSkipperFsm();
    let inp2 = b"/* block */code".to_vec();
    let len2 = inp2.len() as i64;
    s2.setup(inp2, 0, len2);
    s2.do_skip_comment();
    if s2.get_success() != 1 || s2.get_result_pos() != 11 {
        println!("FAIL 2: success={}, pos={}", s2.get_success(), s2.get_result_pos());
        failures += 1;
    }

    // Test 3: Skip template literal
    let mut s3 = @@TSSyntaxSkipperFsm();
    let inp3 = b"`hello ${name} world`rest".to_vec();
    let len3 = inp3.len() as i64;
    s3.setup(inp3, 0, len3);
    s3.do_skip_string();
    if s3.get_success() != 1 || s3.get_result_pos() != 21 {
        println!("FAIL 3: success={}, pos={}", s3.get_success(), s3.get_result_pos());
        failures += 1;
    }

    // Test 4: Skip simple double-quoted string
    let mut s4 = @@TSSyntaxSkipperFsm();
    let inp4 = b"\"hello\" rest".to_vec();
    let len4 = inp4.len() as i64;
    s4.setup(inp4, 0, len4);
    s4.do_skip_string();
    if s4.get_success() != 1 || s4.get_result_pos() != 7 {
        println!("FAIL 4: success={}, pos={}", s4.get_success(), s4.get_result_pos());
        failures += 1;
    }

    // Test 5: Skip template with nested ${}
    let mut s5 = @@TSSyntaxSkipperFsm();
    let inp5 = b"`${a + ${b}}`rest".to_vec();
    let len5 = inp5.len() as i64;
    s5.setup(inp5, 0, len5);
    s5.do_skip_string();
    if s5.get_success() != 1 {
        println!("FAIL 5: success={}", s5.get_success());
        failures += 1;
    }

    // Test 6: Find line end skips over template literals
    let mut s6 = @@TSSyntaxSkipperFsm();
    let inp6 = b"x = `hello`;\nnext".to_vec();
    let len6 = inp6.len() as i64;
    s6.setup(inp6, 0, len6);
    s6.do_find_line_end();
    if s6.get_result_pos() != 11 {
        println!("FAIL 6: pos={}, expected 11 (at ;)", s6.get_result_pos());
        failures += 1;
    }

    // Test 7: Not a string
    let mut s7 = @@TSSyntaxSkipperFsm();
    let inp7 = b"x + 1".to_vec();
    let len7 = inp7.len() as i64;
    s7.setup(inp7, 0, len7);
    s7.do_skip_string();
    if s7.get_success() != 0 {
        println!("FAIL 7: should not be string");
        failures += 1;
    }

    if failures > 0 {
        println!("FAIL: {} failures", failures);
        std::process::exit(1);
    }
    println!("PASS: ts_skipper (7 cases)");
}

@@target ruby

# RubySyntaxSkipper -- FSM for skipping Ruby comments and strings.
# Translated from framec's native_region_scanner/ruby_skipper.frs
#
# Handles: # line comments, "..." / '...' strings,
# %Q{} / %q[] / %w() etc. percent literals,
# Ruby-style line endings, balanced parens.

@@system RubySyntaxSkipperFsm {
    operations:
        setup(input_bytes, start, length) {
            self.bytes = input_bytes
            self.pos = start
            self.scan_end = length
        }
        get_result_pos() {
            return self.result_pos
        }
        get_success() {
            return self.success
        }

    interface:
        do_skip_comment()
        do_skip_string()
        do_find_line_end()
        do_balanced_paren_end()

    machine:
        $Init {
            do_skip_comment() { -> $SkipComment }
            do_skip_string() { -> $SkipString }
            do_find_line_end() { -> $FindLineEnd }
            do_balanced_paren_end() { -> $BalancedParenEnd }
        }

        $SkipComment {
            $>() {
                i = self.pos
                scan_end = self.scan_end
                bs = self.bytes

                # Ruby: # line comment only
                if i < scan_end && bs[i] == 0x23
                    j = i + 1
                    while j < scan_end && bs[j] != 0x0A
                        j += 1
                    end
                    self.result_pos = j
                    self.success = 1
                    return
                end

                self.success = 0
            }
        }

        $SkipString {
            $>() {
                i = self.pos
                scan_end = self.scan_end
                bs = self.bytes

                # Percent literals: %Q{...}, %q[...], %w(...), etc.
                if i < scan_end && bs[i] == 0x25
                    if i + 1 < scan_end
                        c1 = bs[i + 1]
                        has_letter = (c1 == 0x51 || c1 == 0x71 || c1 == 0x77 || c1 == 0x57 || c1 == 0x69 || c1 == 0x49 || c1 == 0x72 || c1 == 0x78 || c1 == 0x73)
                        if has_letter && i + 2 < scan_end
                            opener = bs[i + 2]
                            j = i + 3
                        elsif !((c1 >= 0x61 && c1 <= 0x7A) || (c1 >= 0x41 && c1 <= 0x5A) || (c1 >= 0x30 && c1 <= 0x39) || c1 == 0x5F)
                            opener = c1
                            j = i + 2
                        else
                            self.success = 0
                            return
                        end

                        # Determine closer
                        if opener == 0x7B
                            closer = 0x7D
                        elsif opener == 0x5B
                            closer = 0x5D
                        elsif opener == 0x28
                            closer = 0x29
                        elsif opener == 0x3C
                            closer = 0x3E
                        else
                            closer = opener
                            while j < scan_end
                                if bs[j] == 0x5C
                                    j += 2
                                    next
                                end
                                if bs[j] == closer
                                    self.result_pos = j + 1
                                    self.success = 1
                                    return
                                end
                                j += 1
                            end
                            self.result_pos = scan_end
                            self.success = 1
                            return
                        end

                        # Paired delimiter: track nesting
                        depth = 1
                        while j < scan_end && depth > 0
                            if bs[j] == 0x5C
                                j += 2
                                next
                            end
                            if bs[j] == opener
                                depth += 1
                            elsif bs[j] == closer
                                depth -= 1
                            end
                            j += 1
                        end
                        self.result_pos = j
                        self.success = 1
                        return
                    end
                end

                # Simple string: " or '
                if i < scan_end && (bs[i] == 0x22 || bs[i] == 0x27)
                    q = bs[i]
                    j = i + 1
                    while j < scan_end
                        if bs[j] == 0x5C
                            j += 2
                            next
                        end
                        if bs[j] == q
                            self.result_pos = j + 1
                            self.success = 1
                            return
                        end
                        j += 1
                    end
                    self.result_pos = scan_end
                    self.success = 1
                    return
                end

                self.success = 0
            }
        }

        $FindLineEnd {
            $>() {
                j = self.pos
                scan_end = self.scan_end
                bs = self.bytes
                in_string = 0

                while j < scan_end
                    b = bs[j]
                    if b == 0x0A
                        break
                    end

                    # Inside string
                    if in_string != 0
                        if b == 0x5C
                            j += 2
                            next
                        end
                        if b == in_string
                            in_string = 0
                        end
                        j += 1
                        next
                    end

                    # Terminators
                    if b == 0x23
                        break
                    end

                    # String starts
                    if b == 0x27 || b == 0x22
                        in_string = b
                        j += 1
                        next
                    end

                    j += 1
                end

                self.result_pos = j
            }
        }

        $BalancedParenEnd {
            $>() {
                i = self.pos
                scan_end = self.scan_end
                bs = self.bytes

                if i >= scan_end || bs[i] != 0x28
                    self.success = 0
                    return
                end

                depth = 0
                in_string = 0

                while i < scan_end
                    b = bs[i]

                    # Inside string
                    if in_string != 0
                        if b == 0x5C
                            i += 2
                            next
                        end
                        if b == in_string
                            in_string = 0
                        end
                        i += 1
                        next
                    end

                    if b == 0x27 || b == 0x22
                        in_string = b
                        i += 1
                    elsif b == 0x28
                        depth += 1
                        i += 1
                    elsif b == 0x29
                        depth -= 1
                        i += 1
                        if depth == 0
                            self.result_pos = i
                            self.success = 1
                            return
                        end
                    else
                        i += 1
                    end
                end

                self.success = 0
            }
        }

    domain:
        bytes = []
        pos: int = 0
        scan_end: int = 0
        result_pos: int = 0
        success: int = 1
}

failures = 0

# Test 1: Skip # comment
s1 = RubySyntaxSkipperFsm.new
inp1 = "# comment\ncode".bytes
s1.setup(inp1, 0, inp1.length)
s1.do_skip_comment()
if s1.get_success() != 1 || s1.get_result_pos() != 9
    puts("FAIL 1: success=#{s1.get_success()}, pos=#{s1.get_result_pos()}")
    failures += 1
end

# Test 2: Skip double-quoted string
s2 = RubySyntaxSkipperFsm.new
inp2 = "\"hello\" rest".bytes
s2.setup(inp2, 0, inp2.length)
s2.do_skip_string()
if s2.get_success() != 1 || s2.get_result_pos() != 7
    puts("FAIL 2: success=#{s2.get_success()}, pos=#{s2.get_result_pos()}")
    failures += 1
end

# Test 3: Skip single-quoted string
s3 = RubySyntaxSkipperFsm.new
inp3 = "'hello' rest".bytes
s3.setup(inp3, 0, inp3.length)
s3.do_skip_string()
if s3.get_success() != 1 || s3.get_result_pos() != 7
    puts("FAIL 3: success=#{s3.get_success()}, pos=#{s3.get_result_pos()}")
    failures += 1
end

# Test 4: Skip %Q{text}
s4 = RubySyntaxSkipperFsm.new
inp4 = "%Q{text} rest".bytes
s4.setup(inp4, 0, inp4.length)
s4.do_skip_string()
if s4.get_success() != 1 || s4.get_result_pos() != 8
    puts("FAIL 4: success=#{s4.get_success()}, pos=#{s4.get_result_pos()}")
    failures += 1
end

# Test 5: Skip %q[text]
s5 = RubySyntaxSkipperFsm.new
inp5 = "%q[text] rest".bytes
s5.setup(inp5, 0, inp5.length)
s5.do_skip_string()
if s5.get_success() != 1 || s5.get_result_pos() != 8
    puts("FAIL 5: success=#{s5.get_success()}, pos=#{s5.get_result_pos()}")
    failures += 1
end

# Test 6: Find line end (stops at #)
s6 = RubySyntaxSkipperFsm.new
inp6 = "x + 1 # comment".bytes
s6.setup(inp6, 0, inp6.length)
s6.do_find_line_end()
if s6.get_result_pos() != 6
    puts("FAIL 6: pos=#{s6.get_result_pos()}, expected 6")
    failures += 1
end

# Test 7: Balanced parens
s7 = RubySyntaxSkipperFsm.new
inp7 = "(a, f(b)) rest".bytes
s7.setup(inp7, 0, inp7.length)
s7.do_balanced_paren_end()
if s7.get_success() != 1 || s7.get_result_pos() != 9
    puts("FAIL 7: success=#{s7.get_success()}, pos=#{s7.get_result_pos()}")
    failures += 1
end

# Test 8: Skip %Q with nested braces
s8 = RubySyntaxSkipperFsm.new
inp8 = "%Q{outer {inner} end} rest".bytes
s8.setup(inp8, 0, inp8.length)
s8.do_skip_string()
if s8.get_success() != 1 || s8.get_result_pos() != 21
    puts("FAIL 8: success=#{s8.get_success()}, pos=#{s8.get_result_pos()}")
    failures += 1
end

if failures > 0
    puts("FAIL: #{failures} failures")
    exit(1)
end
puts("PASS: ruby_skipper (8 cases)")

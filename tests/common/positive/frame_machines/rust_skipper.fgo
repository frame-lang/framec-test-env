@@[target("go")]

package main

import "fmt"
import "os"

// RustSyntaxSkipper — FSM for skipping Rust comments and strings.
// Translated from framec's native_region_scanner/rust_skipper.frs
//
// Handles: // line comments, /* nested block comments */,
// raw strings (r#"..."#), char literals vs lifetime annotations,
// simple strings.

@@system RustSyntaxSkipperFsm {
    operations:
        Setup(input_bytes: []byte, start: int, length: int) {
            s.bytes = input_bytes
            s.pos = start
            s.scan_end = length
        }
        GetResultPos(): int {
            return s.result_pos
        }
        GetSuccess(): int {
            return s.success
        }

    interface:
        DoSkipComment()
        DoSkipString()
        DoFindLineEnd()

    machine:
        $Init {
            DoSkipComment() { -> $SkipComment }
            DoSkipString() { -> $SkipString }
            DoFindLineEnd() { -> $FindLineEnd }
        }

        $SkipComment {
            $>() {
                i := s.pos
                end := s.scan_end
                bs := s.bytes

                // // line comment
                if i+1 < end && bs[i] == '/' && bs[i+1] == '/' {
                    j := i + 2
                    for j < end && bs[j] != '\n' {
                        j++
                    }
                    s.result_pos = j
                    s.success = 1
                    return
                }

                // /* nested block comment */ — Rust allows nesting
                if i+1 < end && bs[i] == '/' && bs[i+1] == '*' {
                    j := i + 2
                    depth := 1
                    for j+1 < end && depth > 0 {
                        if bs[j] == '/' && bs[j+1] == '*' {
                            depth++
                            j += 2
                            continue
                        }
                        if bs[j] == '*' && bs[j+1] == '/' {
                            depth--
                            j += 2
                            continue
                        }
                        j++
                    }
                    s.result_pos = j
                    s.success = 1
                    return
                }

                s.success = 0
            }
        }

        $SkipString {
            $>() {
                i := s.pos
                end := s.scan_end
                bs := s.bytes

                // Raw string: r#"..."# (count leading #s)
                if i < end && bs[i] == 'r' {
                    j := i + 1
                    hash_count := 0
                    for j < end && bs[j] == '#' {
                        hash_count++
                        j++
                    }
                    if j < end && bs[j] == '"' {
                        j++
                        // Scan for closing "###
                        for j < end {
                            if bs[j] == '"' {
                                // Check for matching hash count
                                k := 0
                                for k < hash_count && j+1+k < end && bs[j+1+k] == '#' {
                                    k++
                                }
                                if k == hash_count {
                                    s.result_pos = j + 1 + hash_count
                                    s.success = 1
                                    return
                                }
                            }
                            j++
                        }
                        s.result_pos = end
                        s.success = 1
                        return
                    }
                }

                // Double-quoted string
                if i < end && bs[i] == '"' {
                    j := i + 1
                    for j < end {
                        if bs[j] == '\\' {
                            j += 2
                            continue
                        }
                        if bs[j] == '"' {
                            s.result_pos = j + 1
                            s.success = 1
                            return
                        }
                        j++
                    }
                    s.result_pos = end
                    s.success = 1
                    return
                }

                // Char literal: 'x' or '\n' (NOT lifetime 'a)
                if i < end && bs[i] == '\'' {
                    if i+2 < end && bs[i+1] == '\\' && i+3 < end && bs[i+3] == '\'' {
                        // Escape char: '\n'
                        s.result_pos = i + 4
                        s.success = 1
                        return
                    }
                    if i+2 < end && bs[i+2] == '\'' {
                        // Simple char: 'x'
                        s.result_pos = i + 3
                        s.success = 1
                        return
                    }
                    // Lifetime annotation — not a string
                    s.success = 0
                    return
                }

                s.success = 0
            }
        }

        $FindLineEnd {
            $>() {
                j := s.pos
                end := s.scan_end
                bs := s.bytes

                for j < end {
                    b := bs[j]
                    if b == '\n' || b == ';' {
                        break
                    }
                    if b == '/' && j+1 < end && bs[j+1] == '/' {
                        break
                    }
                    if b == '/' && j+1 < end && bs[j+1] == '*' {
                        break
                    }
                    j++
                }

                s.result_pos = j
            }
        }

    domain:
        bytes: []byte = nil
        pos: int = 0
        scan_end: int = 0
        result_pos: int = 0
        success: int = 1
}

func main() {
	failures := 0

	// Test 1: Skip // comment
	s1 := @@RustSyntaxSkipperFsm()
	inp1 := []byte("// comment\ncode")
	s1.Setup(inp1, 0, len(inp1))
	s1.DoSkipComment()
	if s1.GetSuccess() != 1 || s1.GetResultPos() != 10 {
		fmt.Printf("FAIL 1: success=%d, pos=%d\n", s1.GetSuccess(), s1.GetResultPos())
		failures++
	}

	// Test 2: Skip nested /* /* */ */ block comment
	s2 := @@RustSyntaxSkipperFsm()
	inp2 := []byte("/* outer /* inner */ */code")
	s2.Setup(inp2, 0, len(inp2))
	s2.DoSkipComment()
	if s2.GetSuccess() != 1 || s2.GetResultPos() != 23 {
		fmt.Printf("FAIL 2: success=%d, pos=%d\n", s2.GetSuccess(), s2.GetResultPos())
		failures++
	}

	// Test 3: Skip raw string r#"hello"#
	s3 := @@RustSyntaxSkipperFsm()
	inp3 := []byte("r#\"hello\"#rest")
	s3.Setup(inp3, 0, len(inp3))
	s3.DoSkipString()
	if s3.GetSuccess() != 1 || s3.GetResultPos() != 10 {
		fmt.Printf("FAIL 3: success=%d, pos=%d\n", s3.GetSuccess(), s3.GetResultPos())
		failures++
	}

	// Test 4: Skip double-quoted string
	s4 := @@RustSyntaxSkipperFsm()
	inp4 := []byte("\"hello\" rest")
	s4.Setup(inp4, 0, len(inp4))
	s4.DoSkipString()
	if s4.GetSuccess() != 1 || s4.GetResultPos() != 7 {
		fmt.Printf("FAIL 4: success=%d, pos=%d\n", s4.GetSuccess(), s4.GetResultPos())
		failures++
	}

	// Test 5: Char literal 'x' — IS a string
	s5 := @@RustSyntaxSkipperFsm()
	inp5 := []byte("'x' rest")
	s5.Setup(inp5, 0, len(inp5))
	s5.DoSkipString()
	if s5.GetSuccess() != 1 || s5.GetResultPos() != 3 {
		fmt.Printf("FAIL 5: success=%d, pos=%d\n", s5.GetSuccess(), s5.GetResultPos())
		failures++
	}

	// Test 6: Lifetime 'a — NOT a string
	s6 := @@RustSyntaxSkipperFsm()
	inp6 := []byte("'a rest")
	s6.Setup(inp6, 0, len(inp6))
	s6.DoSkipString()
	if s6.GetSuccess() != 0 {
		fmt.Println("FAIL 6: lifetime should not be a string")
		failures++
	}

	// Test 7: Escape char '\n'
	s7 := @@RustSyntaxSkipperFsm()
	inp7 := []byte("'\\n' rest")
	s7.Setup(inp7, 0, len(inp7))
	s7.DoSkipString()
	if s7.GetSuccess() != 1 || s7.GetResultPos() != 4 {
		fmt.Printf("FAIL 7: success=%d, pos=%d\n", s7.GetSuccess(), s7.GetResultPos())
		failures++
	}

	if failures > 0 {
		fmt.Printf("FAIL: %d failures\n", failures)
		os.Exit(1)
	}
	fmt.Println("PASS: rust_skipper (7 cases)")
}

@@[target("kotlin")]

import kotlin.system.exitProcess

// CSharpSyntaxSkipper -- FSM for skipping C# comments and strings.
// Translated from framec's native_region_scanner/csharp_skipper.frs
//
// Handles: // line comments, /* */ block comments, # preprocessor directives,
// "..." simple strings, @"..." verbatim strings, $"..." interpolated strings,
// $"""...""" raw strings, C-like line endings, balanced parens.

@@system CSharpSyntaxSkipperFsm {
    operations:
        setup(input_bytes: ByteArray, start: Int, length: Int) {
            this.bytes = input_bytes
            this.pos = start
            this.scan_end = length
        }
        get_result_pos(): Int {
            return this.result_pos
        }
        get_success(): Int {
            return this.success
        }

    interface:
        do_skip_comment()
        do_skip_string()
        do_find_line_end()
        do_balanced_paren_end()

    machine:
        $Init {
            do_skip_comment() { -> $SkipComment }
            do_skip_string() { -> $SkipString }
            do_find_line_end() { -> $FindLineEnd }
            do_balanced_paren_end() { -> $BalancedParenEnd }
        }

        $SkipComment {
            $>() {
                var i = this.pos
                val end = this.scan_end
                val bs = this.bytes

                // Preprocessor directive: # ... newline
                if (i < end && (bs[i].toInt() and 0xFF) == '#'.code) {
                    var j = i + 1
                    while (j < end && (bs[j].toInt() and 0xFF) != '\n'.code) {
                        j++
                    }
                    this.result_pos = j
                    this.success = 1
                    return
                }

                // Line comment: //
                if (i + 1 < end && (bs[i].toInt() and 0xFF) == '/'.code && (bs[i + 1].toInt() and 0xFF) == '/'.code) {
                    var j = i + 2
                    while (j < end && (bs[j].toInt() and 0xFF) != '\n'.code) {
                        j++
                    }
                    this.result_pos = j
                    this.success = 1
                    return
                }

                // Block comment: /* ... */
                if (i + 1 < end && (bs[i].toInt() and 0xFF) == '/'.code && (bs[i + 1].toInt() and 0xFF) == '*'.code) {
                    var j = i + 2
                    while (j + 1 < end) {
                        if ((bs[j].toInt() and 0xFF) == '*'.code && (bs[j + 1].toInt() and 0xFF) == '/'.code) {
                            this.result_pos = j + 2
                            this.success = 1
                            return
                        }
                        j++
                    }
                    this.result_pos = end
                    this.success = 1
                    return
                }

                this.success = 0
            }
        }

        $SkipString {
            $>() {
                var i = this.pos
                val end = this.scan_end
                val bs = this.bytes

                if (i >= end) {
                    this.success = 0
                    return
                }

                val b0 = bs[i].toInt() and 0xFF

                // Verbatim string @"..." (doubled quotes for escape)
                if (b0 == '@'.code && i + 1 < end && (bs[i + 1].toInt() and 0xFF) == '"'.code) {
                    var j = i + 2
                    while (j < end) {
                        if ((bs[j].toInt() and 0xFF) == '"'.code) {
                            if (j + 1 < end && (bs[j + 1].toInt() and 0xFF) == '"'.code) {
                                j += 2
                                continue
                            }
                            this.result_pos = j + 1
                            this.success = 1
                            return
                        }
                        j++
                    }
                    this.result_pos = end
                    this.success = 1
                    return
                }

                // Interpolated string $"..." or $@"..." or raw $"""..."""
                if (b0 == '$'.code) {
                    var j = i + 1
                    while (j < end && (bs[j].toInt() and 0xFF) == '$'.code) {
                        j++
                    }
                    if (j < end && (bs[j].toInt() and 0xFF) == '@'.code) {
                        j++
                    }
                    var quotes = 0
                    while (j < end && (bs[j].toInt() and 0xFF) == '"'.code) {
                        quotes++
                        j++
                    }
                    if (quotes == 0) {
                        this.success = 0
                        return
                    }
                    if (quotes >= 3) {
                        while (j < end) {
                            if ((bs[j].toInt() and 0xFF) == '"'.code) {
                                var q = 0
                                var p = j
                                while (p < end && (bs[p].toInt() and 0xFF) == '"'.code) {
                                    q++
                                    p++
                                }
                                if (q >= quotes) {
                                    this.result_pos = p
                                    this.success = 1
                                    return
                                }
                                j = p
                                continue
                            }
                            j++
                        }
                        this.result_pos = end
                        this.success = 1
                        return
                    }
                    while (j < end) {
                        if ((bs[j].toInt() and 0xFF) == '\\'.code) {
                            j += 2
                            continue
                        }
                        if ((bs[j].toInt() and 0xFF) == '"'.code) {
                            this.result_pos = j + 1
                            this.success = 1
                            return
                        }
                        j++
                    }
                    this.result_pos = end
                    this.success = 1
                    return
                }

                // Simple string: " or '
                if (b0 == '"'.code || b0 == '\''.code) {
                    val q = b0
                    var j = i + 1
                    while (j < end) {
                        if ((bs[j].toInt() and 0xFF) == '\\'.code) {
                            j += 2
                            continue
                        }
                        if ((bs[j].toInt() and 0xFF) == q) {
                            this.result_pos = j + 1
                            this.success = 1
                            return
                        }
                        j++
                    }
                    this.result_pos = end
                    this.success = 1
                    return
                }

                this.success = 0
            }
        }

        $FindLineEnd {
            $>() {
                var j = this.pos
                val end = this.scan_end
                val bs = this.bytes

                while (j < end) {
                    val b = bs[j].toInt() and 0xFF
                    if (b == '\n'.code || b == ';'.code) {
                        break
                    }
                    if (b == '/'.code && j + 1 < end && ((bs[j + 1].toInt() and 0xFF) == '/'.code || (bs[j + 1].toInt() and 0xFF) == '*'.code)) {
                        break
                    }
                    if (b == '#'.code) {
                        break
                    }
                    j++
                }

                this.result_pos = j
            }
        }

        $BalancedParenEnd {
            $>() {
                var i = this.pos
                val end = this.scan_end
                val bs = this.bytes

                if (i >= end || (bs[i].toInt() and 0xFF) != '('.code) {
                    this.success = 0
                    return
                }

                var depth = 1
                var j = i + 1
                while (j < end && depth > 0) {
                    val b = bs[j].toInt() and 0xFF
                    if (b == '('.code) {
                        depth++
                    } else if (b == ')'.code) {
                        depth--
                    } else if (b == '"'.code || b == '\''.code) {
                        val q = b
                        j++
                        while (j < end && (bs[j].toInt() and 0xFF) != q) {
                            if ((bs[j].toInt() and 0xFF) == '\\'.code) {
                                j++
                            }
                            j++
                        }
                    }
                    j++
                }

                if (depth == 0) {
                    this.result_pos = j
                    this.success = 1
                } else {
                    this.result_pos = end
                    this.success = 0
                }
            }
        }

    domain:
        bytes: ByteArray = ByteArray(0)
        pos: Int = 0
        scan_end: Int = 0
        result_pos: Int = 0
        success: Int = 1
}

fun main() {
    var failures = 0

    // Test 1: Skip // line comment
    val s1 = @@CSharpSyntaxSkipperFsm()
    val inp1 = "// comment\ncode".toByteArray()
    s1.setup(inp1, 0, inp1.size)
    s1.do_skip_comment()
    if (s1.get_success() != 1 || s1.get_result_pos() != 10) {
        println("FAIL 1: success=${s1.get_success()}, pos=${s1.get_result_pos()}")
        failures++
    }

    // Test 2: Skip /* */ block comment
    val s2 = @@CSharpSyntaxSkipperFsm()
    val inp2 = "/* block */code".toByteArray()
    s2.setup(inp2, 0, inp2.size)
    s2.do_skip_comment()
    if (s2.get_success() != 1 || s2.get_result_pos() != 11) {
        println("FAIL 2: success=${s2.get_success()}, pos=${s2.get_result_pos()}")
        failures++
    }

    // Test 3: Skip simple string "hello"
    val s3 = @@CSharpSyntaxSkipperFsm()
    val inp3 = "\"hello\" rest".toByteArray()
    s3.setup(inp3, 0, inp3.size)
    s3.do_skip_string()
    if (s3.get_success() != 1 || s3.get_result_pos() != 7) {
        println("FAIL 3: success=${s3.get_success()}, pos=${s3.get_result_pos()}")
        failures++
    }

    // Test 4: Skip verbatim string @"verbatim ""quote"""
    val s4 = @@CSharpSyntaxSkipperFsm()
    val inp4 = "@\"verbatim \"\"quote\"\"\" rest".toByteArray()
    s4.setup(inp4, 0, inp4.size)
    s4.do_skip_string()
    if (s4.get_success() != 1 || s4.get_result_pos() != 21) {
        println("FAIL 4: success=${s4.get_success()}, pos=${s4.get_result_pos()}")
        failures++
    }

    // Test 5: Skip interpolated string $"interp {x}"
    val s5 = @@CSharpSyntaxSkipperFsm()
    val inp5 = "$\"interp {x}\" rest".toByteArray()
    s5.setup(inp5, 0, inp5.size)
    s5.do_skip_string()
    if (s5.get_success() != 1 || s5.get_result_pos() != 13) {
        println("FAIL 5: success=${s5.get_success()}, pos=${s5.get_result_pos()}")
        failures++
    }

    // Test 6: Find line end (stops at // comment)
    val s6 = @@CSharpSyntaxSkipperFsm()
    val inp6 = "x + 1 // comment".toByteArray()
    s6.setup(inp6, 0, inp6.size)
    s6.do_find_line_end()
    if (s6.get_result_pos() != 6) {
        println("FAIL 6: pos=${s6.get_result_pos()}, expected 6")
        failures++
    }

    // Test 7: Balanced parens
    val s7 = @@CSharpSyntaxSkipperFsm()
    val inp7 = "(a, f(b)) rest".toByteArray()
    s7.setup(inp7, 0, inp7.size)
    s7.do_balanced_paren_end()
    if (s7.get_success() != 1 || s7.get_result_pos() != 9) {
        println("FAIL 7: success=${s7.get_success()}, pos=${s7.get_result_pos()}")
        failures++
    }

    // Test 8: Skip # preprocessor directive
    val s8 = @@CSharpSyntaxSkipperFsm()
    val inp8 = "#region Foo\ncode".toByteArray()
    s8.setup(inp8, 0, inp8.size)
    s8.do_skip_comment()
    if (s8.get_success() != 1 || s8.get_result_pos() != 11) {
        println("FAIL 8: success=${s8.get_success()}, pos=${s8.get_result_pos()}")
        failures++
    }

    if (failures > 0) {
        println("FAIL: $failures failures")
        exitProcess(1)
    }
    println("PASS: csharp_skipper (8 cases)")
}

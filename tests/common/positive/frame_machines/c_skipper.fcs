@@target csharp

using System;
using System.Text;

// CSyntaxSkipper -- FSM for skipping C-style comments and strings.
// Translated from framec's native_region_scanner/c_skipper.frs
//
// Demonstrates the skipper pattern: dispatch on entry point, scan
// to find the end of the construct, report result via domain vars.

@@system CSyntaxSkipperFsm {
    operations:
        setup(input_bytes: byte[], start: int, length: int) {
            this.bytes = input_bytes;
            this.pos = start;
            this.end = length;
        }
        get_result_pos(): int {
            return this.result_pos;
        }
        get_success(): int {
            return this.success;
        }

    interface:
        do_skip_comment()
        do_skip_string()
        do_find_line_end()
        do_balanced_paren_end()

    machine:
        $Init {
            do_skip_comment() { -> $SkipComment }
            do_skip_string() { -> $SkipString }
            do_find_line_end() { -> $FindLineEnd }
            do_balanced_paren_end() { -> $BalancedParenEnd }
        }

        $SkipComment {
            $>() {
                int i = this.pos;
                int end = this.end;
                byte[] bs = this.bytes;

                // Try line comment: //
                if (i + 1 < end && bs[i] == (byte)'/' && bs[i + 1] == (byte)'/') {
                    int j = i + 2;
                    while (j < end && bs[j] != (byte)'\n') {
                        j++;
                    }
                    this.result_pos = j;
                    this.success = 1;
                    return;
                }

                // Try block comment: /* ... */
                if (i + 1 < end && bs[i] == (byte)'/' && bs[i + 1] == (byte)'*') {
                    int j = i + 2;
                    while (j + 1 < end) {
                        if (bs[j] == (byte)'*' && bs[j + 1] == (byte)'/') {
                            this.result_pos = j + 2;
                            this.success = 1;
                            return;
                        }
                        j++;
                    }
                    this.result_pos = end;
                    this.success = 1;
                    return;
                }

                this.success = 0;
            }
        }

        $SkipString {
            $>() {
                int i = this.pos;
                int end = this.end;
                byte[] bs = this.bytes;

                if (i < end && (bs[i] == (byte)'"' || bs[i] == (byte)'\'')) {
                    int q = bs[i];
                    int j = i + 1;
                    while (j < end) {
                        if (bs[j] == (byte)'\\') {
                            j += 2;
                            continue;
                        }
                        if (bs[j] == q) {
                            this.result_pos = j + 1;
                            this.success = 1;
                            return;
                        }
                        j++;
                    }
                    this.result_pos = end;
                    this.success = 1;
                    return;
                }

                this.success = 0;
            }
        }

        $FindLineEnd {
            $>() {
                int j = this.pos;
                int end = this.end;
                byte[] bs = this.bytes;

                while (j < end) {
                    int b = bs[j];
                    if (b == (byte)'\n' || b == (byte)';') {
                        break;
                    }
                    if (b == (byte)'/' && j + 1 < end && bs[j + 1] == (byte)'/') {
                        break;
                    }
                    if (b == (byte)'/' && j + 1 < end && bs[j + 1] == (byte)'*') {
                        break;
                    }
                    j++;
                }

                this.result_pos = j;
            }
        }

        $BalancedParenEnd {
            $>() {
                int i = this.pos;
                int end = this.end;
                byte[] bs = this.bytes;

                if (i >= end || bs[i] != (byte)'(') {
                    this.success = 0;
                    return;
                }

                int depth = 1;
                int j = i + 1;
                while (j < end && depth > 0) {
                    int b = bs[j];
                    if (b == (byte)'(') {
                        depth++;
                    } else if (b == (byte)')') {
                        depth--;
                    } else if (b == (byte)'"' || b == (byte)'\'') {
                        int q = b;
                        j++;
                        while (j < end && bs[j] != q) {
                            if (bs[j] == (byte)'\\') {
                                j++;
                            }
                            j++;
                        }
                        // j is at closing quote
                    }
                    j++;
                }

                if (depth == 0) {
                    this.result_pos = j;
                    this.success = 1;
                } else {
                    this.result_pos = end;
                    this.success = 0;
                }
            }
        }

    domain:
        bytes: byte[] = null
        pos: int = 0
        end: int = 0
        result_pos: int = 0
        success: int = 1
}

class Program {
    static void Main(string[] args) {
        int failures = 0;

        // Test 1: Skip line comment
        var s1 = new CSyntaxSkipperFsm();
        byte[] inp1 = Encoding.UTF8.GetBytes("// hello\ncode");
        s1.setup(inp1, 0, inp1.Length);
        s1.do_skip_comment();
        if ((int)s1.get_success() != 1 || (int)s1.get_result_pos() != 8) {
            Console.WriteLine("FAIL 1: success=" + s1.get_success() + ", pos=" + s1.get_result_pos());
            failures++;
        }

        // Test 2: Skip block comment
        var s2 = new CSyntaxSkipperFsm();
        byte[] inp2 = Encoding.UTF8.GetBytes("/* block */code");
        s2.setup(inp2, 0, inp2.Length);
        s2.do_skip_comment();
        if ((int)s2.get_success() != 1 || (int)s2.get_result_pos() != 11) {
            Console.WriteLine("FAIL 2: success=" + s2.get_success() + ", pos=" + s2.get_result_pos());
            failures++;
        }

        // Test 3: Not a comment
        var s3 = new CSyntaxSkipperFsm();
        byte[] inp3 = Encoding.UTF8.GetBytes("x + 1");
        s3.setup(inp3, 0, inp3.Length);
        s3.do_skip_comment();
        if ((int)s3.get_success() != 0) {
            Console.WriteLine("FAIL 3: should not be a comment");
            failures++;
        }

        // Test 4: Skip double-quoted string
        var s4 = new CSyntaxSkipperFsm();
        byte[] inp4 = Encoding.UTF8.GetBytes("\"hello world\" rest");
        s4.setup(inp4, 0, inp4.Length);
        s4.do_skip_string();
        if ((int)s4.get_success() != 1 || (int)s4.get_result_pos() != 13) {
            Console.WriteLine("FAIL 4: success=" + s4.get_success() + ", pos=" + s4.get_result_pos());
            failures++;
        }

        // Test 5: Skip string with escaped quote
        var s5 = new CSyntaxSkipperFsm();
        byte[] inp5 = Encoding.UTF8.GetBytes("\"he\\\"llo\" rest");
        s5.setup(inp5, 0, inp5.Length);
        s5.do_skip_string();
        if ((int)s5.get_success() != 1 || (int)s5.get_result_pos() != 9) {
            Console.WriteLine("FAIL 5: success=" + s5.get_success() + ", pos=" + s5.get_result_pos());
            failures++;
        }

        // Test 6: Find line end (stops at newline)
        var s6 = new CSyntaxSkipperFsm();
        byte[] inp6 = Encoding.UTF8.GetBytes("x + 1\nmore");
        s6.setup(inp6, 0, inp6.Length);
        s6.do_find_line_end();
        if ((int)s6.get_result_pos() != 5) {
            Console.WriteLine("FAIL 6: pos=" + s6.get_result_pos() + ", expected 5");
            failures++;
        }

        // Test 7: Find line end (stops at // comment)
        var s7 = new CSyntaxSkipperFsm();
        byte[] inp7 = Encoding.UTF8.GetBytes("x + 1 // comment");
        s7.setup(inp7, 0, inp7.Length);
        s7.do_find_line_end();
        if ((int)s7.get_result_pos() != 6) {
            Console.WriteLine("FAIL 7: pos=" + s7.get_result_pos() + ", expected 6");
            failures++;
        }

        // Test 8: Balanced parens
        var s8 = new CSyntaxSkipperFsm();
        byte[] inp8 = Encoding.UTF8.GetBytes("(a, f(b), c) rest");
        s8.setup(inp8, 0, inp8.Length);
        s8.do_balanced_paren_end();
        if ((int)s8.get_success() != 1 || (int)s8.get_result_pos() != 12) {
            Console.WriteLine("FAIL 8: success=" + s8.get_success() + ", pos=" + s8.get_result_pos());
            failures++;
        }

        if (failures > 0) {
            Console.WriteLine("FAIL: " + failures + " failures");
            Environment.Exit(1);
        }
        Console.WriteLine("PASS: c_skipper (8 cases)");
    }
}

@@target swift

import Foundation

// StateVarParser — FSM for parsing $.varName and $.varName = expr
// Translated from framec's native_region_scanner/state_var_parser.frs
//
// Uses hierarchical composition: $ScanExpr creates an ExprScannerFsm
// sub-machine when it detects an assignment.

@@system ExprScannerFsm {
    operations:
        setup(input_bytes: [UInt8], start: Int, length: Int) {
            self.bytes = input_bytes
            self.pos = start
            self.end = length
        }
        get_result(): Int {
            return self.result_end
        }

    interface:
        do_scan()

    machine:
        $Init {
            do_scan() { -> $Scanning }
        }

        $Scanning {
            $>() {
                var i = self.pos
                let end = self.end
                let bs = self.bytes
                var depth = 0
                var inString: UInt8? = nil

                while i < end {
                    let b = bs[i]

                    if let q = inString {
                        if b == UInt8(ascii: "\\") && i + 1 < end {
                            i += 2
                            continue
                        }
                        if b == q {
                            inString = nil
                        }
                        i += 1
                        continue
                    }

                    if b == UInt8(ascii: "\"") || b == UInt8(ascii: "'") {
                        inString = b
                        i += 1
                        continue
                    }

                    if b == UInt8(ascii: "(") || b == UInt8(ascii: "[") || b == UInt8(ascii: "{") {
                        depth += 1
                    } else if b == UInt8(ascii: ")") || b == UInt8(ascii: "]") || b == UInt8(ascii: "}") {
                        depth = max(depth - 1, 0)
                    } else if b == UInt8(ascii: ";") && depth == 0 {
                        i += 1
                        break
                    } else if b == 0x0A && depth == 0 {
                        break
                    }

                    i += 1
                }

                self.result_end = i
            }
        }

    domain:
        bytes: [UInt8] = []
        pos: Int = 0
        end: Int = 0
        result_end: Int = 0
}

@@system StateVarParserFsm {
    operations:
        setup(input_bytes: [UInt8], start: Int, length: Int) {
            self.bytes = input_bytes
            self.pos = start
            self.parse_end = length
        }
        get_result_end(): Int {
            return self.result_end
        }
        get_is_assignment(): Bool {
            return self.is_assignment
        }

    interface:
        do_parse()

    machine:
        $Init {
            do_parse() { -> $ScanIdent }
        }

        $ScanIdent {
            $>() {
                // Skip "$." prefix and scan identifier
                var i = self.pos + 2
                let end = self.parse_end
                let bs = self.bytes

                while i < end {
                    let c = bs[i]
                    if (c >= 0x30 && c <= 0x39) || (c >= 0x41 && c <= 0x5A) || (c >= 0x61 && c <= 0x7A) || c == 0x5F {
                        i += 1
                    } else {
                        break
                    }
                }

                self.ident_end = i
                -> $CheckAssign
            }
        }

        $CheckAssign {
            $>() {
                // Lookahead: skip whitespace, check for = (but not == or => or =<)
                var j = self.ident_end
                let end = self.parse_end
                let bs = self.bytes

                while j < end && (bs[j] == UInt8(ascii: " ") || bs[j] == UInt8(ascii: "\t")) {
                    j += 1
                }

                if j < end && bs[j] == UInt8(ascii: "=") && (j + 1 >= end || (bs[j + 1] != UInt8(ascii: "=") && bs[j + 1] != UInt8(ascii: "<") && bs[j + 1] != UInt8(ascii: ">"))) {
                    // Assignment detected
                    j += 1
                    self.pos = j
                    self.is_assignment = true
                    -> $ScanExpr
                } else {
                    // Read-only access
                    self.result_end = self.ident_end
                    self.is_assignment = false
                    -> $Done
                }
            }
        }

        $ScanExpr {
            $>() {
                // Create ExprScanner sub-machine
                let expr = @@ExprScannerFsm()
                expr.setup(self.bytes, self.pos, self.parse_end)
                expr.do_scan()
                self.result_end = expr.get_result() as! Int
                -> $Done
            }
        }

        $Done {
            $>() {
            }
        }

    domain:
        bytes: [UInt8] = []
        pos: Int = 0
        parse_end: Int = 0
        ident_end: Int = 0
        result_end: Int = 0
        is_assignment: Bool = false
}

// main
    var failures = 0

    // Test 1: Read-only access $.count
    let p1 = @@StateVarParserFsm()
    let inp1: [UInt8] = Array("$.count + 1".utf8)
    p1.setup(inp1, 0, inp1.count)
    p1.do_parse()
    if p1.get_is_assignment() as! Bool {
        print("FAIL 1: should not be assignment")
        failures += 1
    }
    let r1 = p1.get_result_end() as! Int
    let name1 = String(bytes: Array(inp1[2..<r1]), encoding: .utf8)!
    if name1 != "count" {
        print("FAIL 1: name='\(name1)', expected 'count'")
        failures += 1
    }

    // Test 2: Assignment $.total = x + 1;\n
    let p2 = @@StateVarParserFsm()
    let inp2: [UInt8] = Array("$.total = x + 1;\nmore".utf8)
    p2.setup(inp2, 0, inp2.count)
    p2.do_parse()
    if !(p2.get_is_assignment() as! Bool) {
        print("FAIL 2: should be assignment")
        failures += 1
    }
    let r2 = p2.get_result_end() as! Int
    let expr2 = String(bytes: Array(inp2[0..<r2]), encoding: .utf8)!
    if !expr2.contains("x + 1;") {
        print("FAIL 2: expr='\(expr2)'")
        failures += 1
    }

    // Test 3: Not assignment $.x == 5 (== is comparison, not assignment)
    let p3 = @@StateVarParserFsm()
    let inp3: [UInt8] = Array("$.x == 5".utf8)
    p3.setup(inp3, 0, inp3.count)
    p3.do_parse()
    if p3.get_is_assignment() as! Bool {
        print("FAIL 3: == should not be treated as assignment")
        failures += 1
    }

    // Test 4: Assignment with nested parens $.val = f(a, b)\n
    let p4 = @@StateVarParserFsm()
    let inp4: [UInt8] = Array("$.val = f(a, b)\nrest".utf8)
    p4.setup(inp4, 0, inp4.count)
    p4.do_parse()
    if !(p4.get_is_assignment() as! Bool) {
        print("FAIL 4: should be assignment")
        failures += 1
    }
    let r4 = p4.get_result_end() as! Int
    let expr4 = String(bytes: Array(inp4[0..<r4]), encoding: .utf8)!
    if !expr4.contains("f(a, b)") {
        print("FAIL 4: expr='\(expr4)'")
        failures += 1
    }

    if failures > 0 {
        print("FAIL: \(failures) failures")
        exit(1)
    }
    print("PASS: state_var_parser (4 cases)")

@@target rust

// PhpSyntaxSkipper -- FSM for skipping PHP comments and strings.
// Translated from framec's native_region_scanner/php_skipper.frs
//
// Handles: // line comments, # line comments, /* */ block comments,
// "..." and '...' strings, <<<EOT heredoc/nowdoc,
// PHP-style line endings, balanced parens.

use std::collections::HashMap;

@@system PhpSyntaxSkipperFsm {
    operations:
        setup(input_bytes: Vec<u8>, start: i64, length: i64) {
            self.bytes = input_bytes;
            self.pos = start;
            self.scan_end = length;
        }
        get_result_pos(): i64 {
            return self.result_pos;
        }
        get_success(): i64 {
            return self.success;
        }

    interface:
        do_skip_comment()
        do_skip_string()
        do_find_line_end()
        do_balanced_paren_end()

    machine:
        $Init {
            do_skip_comment() { -> $SkipComment }
            do_skip_string() { -> $SkipString }
            do_find_line_end() { -> $FindLineEnd }
            do_balanced_paren_end() { -> $BalancedParenEnd }
        }

        $SkipComment {
            $>() {
                let i = self.pos as usize;
                let end = self.scan_end as usize;
                let bs = &self.bytes;

                // Line comment: //
                if i + 1 < end && bs[i] == 0x2F && bs[i + 1] == 0x2F {
                    let mut j = i + 2;
                    while j < end && bs[j] != 0x0A {
                        j += 1;
                    }
                    self.result_pos = j as i64;
                    self.success = 1;
                    return;
                }

                // Hash comment: #
                if i < end && bs[i] == 0x23 {
                    let mut j = i + 1;
                    while j < end && bs[j] != 0x0A {
                        j += 1;
                    }
                    self.result_pos = j as i64;
                    self.success = 1;
                    return;
                }

                // Block comment: /* ... */
                if i + 1 < end && bs[i] == 0x2F && bs[i + 1] == 0x2A {
                    let mut j = i + 2;
                    while j + 1 < end {
                        if bs[j] == 0x2A && bs[j + 1] == 0x2F {
                            self.result_pos = (j + 2) as i64;
                            self.success = 1;
                            return;
                        }
                        j += 1;
                    }
                    self.result_pos = end as i64;
                    self.success = 1;
                    return;
                }

                self.success = 0;
            }
        }

        $SkipString {
            $>() {
                let i = self.pos as usize;
                let end = self.scan_end as usize;
                let bs = &self.bytes;

                // Heredoc/nowdoc: <<<EOT ... EOT;
                if i + 2 < end && bs[i] == 0x3C && bs[i + 1] == 0x3C && bs[i + 2] == 0x3C {
                    let mut j = i + 3;
                    // Skip optional quote for nowdoc
                    let mut nowdoc: i32 = 0;
                    if j < end && bs[j] == 0x27 {
                        nowdoc = 1;
                        j += 1;
                    }
                    // Read tag name
                    let tag_start = j;
                    while j < end && (bs[j].is_ascii_alphanumeric() || bs[j] == 0x5F) {
                        j += 1;
                    }
                    let tag_end = j;
                    if nowdoc != 0 && j < end && bs[j] == 0x27 {
                        j += 1;
                    }
                    let tag = &bs[tag_start..tag_end];
                    let tag_len = tag.len();
                    if tag_len > 0 {
                        // Skip to newline
                        while j < end && bs[j] != 0x0A {
                            j += 1;
                        }
                        if j < end {
                            j += 1;
                        }
                        // Scan for closing tag at start of line
                        while j < end {
                            // Check if this line starts with the tag
                            if j + tag_len <= end && &bs[j..j + tag_len] == tag {
                                let mut k = j + tag_len;
                                // Optional ; and newline
                                if k < end && bs[k] == 0x3B {
                                    k += 1;
                                }
                                if k >= end || bs[k] == 0x0A {
                                    if k < end && bs[k] == 0x0A {
                                        k += 1;
                                    }
                                    self.result_pos = k as i64;
                                    self.success = 1;
                                    return;
                                }
                            }
                            // Skip to next line
                            while j < end && bs[j] != 0x0A {
                                j += 1;
                            }
                            if j < end {
                                j += 1;
                            }
                        }
                        self.result_pos = end as i64;
                        self.success = 1;
                        return;
                    }
                }

                // Simple string: " or '
                if i < end && (bs[i] == 0x22 || bs[i] == 0x27) {
                    let q = bs[i];
                    let mut j = i + 1;
                    while j < end {
                        if bs[j] == 0x5C {
                            j += 2;
                            continue;
                        }
                        if bs[j] == q {
                            self.result_pos = (j + 1) as i64;
                            self.success = 1;
                            return;
                        }
                        j += 1;
                    }
                    self.result_pos = end as i64;
                    self.success = 1;
                    return;
                }

                self.success = 0;
            }
        }

        $FindLineEnd {
            $>() {
                let mut j = self.pos as usize;
                let end = self.scan_end as usize;
                let bs = &self.bytes;
                let mut in_string: u8 = 0;

                while j < end {
                    let b = bs[j];
                    if b == 0x0A {
                        break;
                    }

                    // Inside string
                    if in_string != 0 {
                        if b == 0x5C {
                            j += 2;
                            continue;
                        }
                        if b == in_string {
                            in_string = 0;
                        }
                        j += 1;
                        continue;
                    }

                    // Terminators
                    if b == 0x3B || b == 0x7D {
                        break;
                    }
                    if b == 0x2F && j + 1 < end && (bs[j + 1] == 0x2F || bs[j + 1] == 0x2A) {
                        break;
                    }
                    if b == 0x23 {
                        break;
                    }

                    // String starts
                    if b == 0x27 || b == 0x22 {
                        in_string = b;
                        j += 1;
                        continue;
                    }

                    j += 1;
                }

                self.result_pos = j as i64;
            }
        }

        $BalancedParenEnd {
            $>() {
                let mut i = self.pos as usize;
                let end = self.scan_end as usize;
                let bs = &self.bytes;

                if i >= end || bs[i] != 0x28 {
                    self.success = 0;
                    return;
                }

                let mut depth: i32 = 0;
                let mut in_string: u8 = 0;

                while i < end {
                    let b = bs[i];

                    // Inside string
                    if in_string != 0 {
                        if b == 0x5C {
                            i += 2;
                            continue;
                        }
                        if b == in_string {
                            in_string = 0;
                        }
                        i += 1;
                        continue;
                    }

                    if b == 0x27 || b == 0x22 {
                        in_string = b;
                        i += 1;
                    } else if b == 0x28 {
                        depth += 1;
                        i += 1;
                    } else if b == 0x29 {
                        depth -= 1;
                        i += 1;
                        if depth == 0 {
                            self.result_pos = i as i64;
                            self.success = 1;
                            return;
                        }
                    } else {
                        i += 1;
                    }
                }

                self.success = 0;
            }
        }

    domain:
        bytes: Vec<u8> = Vec::new()
        pos: i64 = 0
        scan_end: i64 = 0
        result_pos: i64 = 0
        success: i64 = 1
}

fn main() {
    let mut failures = 0;

    // Test 1: Skip // line comment
    let mut s1 = @@PhpSyntaxSkipperFsm();
    let inp1 = b"// comment\ncode".to_vec();
    s1.setup(inp1.clone(), 0, inp1.len() as i64);
    s1.do_skip_comment();
    if s1.get_success() != 1 || s1.get_result_pos() != 10 {
        println!("FAIL 1: success={}, pos={}", s1.get_success(), s1.get_result_pos());
        failures += 1;
    }

    // Test 2: Skip # comment
    let mut s2 = @@PhpSyntaxSkipperFsm();
    let inp2 = b"# comment\ncode".to_vec();
    s2.setup(inp2.clone(), 0, inp2.len() as i64);
    s2.do_skip_comment();
    if s2.get_success() != 1 || s2.get_result_pos() != 9 {
        println!("FAIL 2: success={}, pos={}", s2.get_success(), s2.get_result_pos());
        failures += 1;
    }

    // Test 3: Skip /* */ block comment
    let mut s3 = @@PhpSyntaxSkipperFsm();
    let inp3 = b"/* block */code".to_vec();
    s3.setup(inp3.clone(), 0, inp3.len() as i64);
    s3.do_skip_comment();
    if s3.get_success() != 1 || s3.get_result_pos() != 11 {
        println!("FAIL 3: success={}, pos={}", s3.get_success(), s3.get_result_pos());
        failures += 1;
    }

    // Test 4: Skip double-quoted string
    let mut s4 = @@PhpSyntaxSkipperFsm();
    let inp4 = b"\"hello\" rest".to_vec();
    s4.setup(inp4.clone(), 0, inp4.len() as i64);
    s4.do_skip_string();
    if s4.get_success() != 1 || s4.get_result_pos() != 7 {
        println!("FAIL 4: success={}, pos={}", s4.get_success(), s4.get_result_pos());
        failures += 1;
    }

    // Test 5: Skip single-quoted string
    let mut s5 = @@PhpSyntaxSkipperFsm();
    let inp5 = b"'hello' rest".to_vec();
    s5.setup(inp5.clone(), 0, inp5.len() as i64);
    s5.do_skip_string();
    if s5.get_success() != 1 || s5.get_result_pos() != 7 {
        println!("FAIL 5: success={}, pos={}", s5.get_success(), s5.get_result_pos());
        failures += 1;
    }

    // Test 6: Skip heredoc
    let mut s6 = @@PhpSyntaxSkipperFsm();
    let inp6 = b"<<<EOT\nhello world\nEOT;\nnext".to_vec();
    s6.setup(inp6.clone(), 0, inp6.len() as i64);
    s6.do_skip_string();
    if s6.get_success() != 1 || s6.get_result_pos() != 24 {
        println!("FAIL 6: success={}, pos={}", s6.get_success(), s6.get_result_pos());
        failures += 1;
    }

    // Test 7: Find line end (stops at ;)
    let mut s7 = @@PhpSyntaxSkipperFsm();
    let inp7 = b"$x = 1; next".to_vec();
    s7.setup(inp7.clone(), 0, inp7.len() as i64);
    s7.do_find_line_end();
    if s7.get_result_pos() != 6 {
        println!("FAIL 7: pos={}, expected 6", s7.get_result_pos());
        failures += 1;
    }

    // Test 8: Balanced parens
    let mut s8 = @@PhpSyntaxSkipperFsm();
    let inp8 = b"(a, f(b)) rest".to_vec();
    s8.setup(inp8.clone(), 0, inp8.len() as i64);
    s8.do_balanced_paren_end();
    if s8.get_success() != 1 || s8.get_result_pos() != 9 {
        println!("FAIL 8: success={}, pos={}", s8.get_success(), s8.get_result_pos());
        failures += 1;
    }

    if failures > 0 { println!("FAIL: {} failures", failures); std::process::exit(1); }
    println!("PASS: php_skipper (8 cases)");
}

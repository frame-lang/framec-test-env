<?php
@@[target("php")]

// CSharpSyntaxSkipper -- FSM for skipping C# comments and strings.
// Translated from framec's native_region_scanner/csharp_skipper.frs
//
// Handles: // line comments, /* */ block comments, # preprocessor directives,
// "..." simple strings, @"..." verbatim strings, $"..." interpolated strings,
// $"""...""" raw strings, C-like line endings, balanced parens.

@@system CSharpSyntaxSkipperFsm {
    operations:
        setup(input_bytes: array, start: int, length: int) {
            $this->bytes = $input_bytes;
            $this->pos = $start;
            $this->scan_end = $length;
        }
        get_result_pos(): int {
            return $this->result_pos;
        }
        get_success(): int {
            return $this->success;
        }

    interface:
        do_skip_comment()
        do_skip_string()
        do_find_line_end()
        do_balanced_paren_end()

    machine:
        $Init {
            do_skip_comment() { -> $SkipComment }
            do_skip_string() { -> $SkipString }
            do_find_line_end() { -> $FindLineEnd }
            do_balanced_paren_end() { -> $BalancedParenEnd }
        }

        $SkipComment {
            $>() {
                $i = $this->pos;
                $end = $this->scan_end;
                $bs = $this->bytes;

                // Preprocessor directive: # ... newline
                if ($i < $end && $bs[$i] === 0x23) {
                    $j = $i + 1;
                    while ($j < $end && $bs[$j] !== 0x0A) {
                        $j++;
                    }
                    $this->result_pos = $j;
                    $this->success = 1;
                    return;
                }

                // Line comment: //
                if ($i + 1 < $end && $bs[$i] === 0x2F && $bs[$i + 1] === 0x2F) {
                    $j = $i + 2;
                    while ($j < $end && $bs[$j] !== 0x0A) {
                        $j++;
                    }
                    $this->result_pos = $j;
                    $this->success = 1;
                    return;
                }

                // Block comment: /* ... */
                if ($i + 1 < $end && $bs[$i] === 0x2F && $bs[$i + 1] === 0x2A) {
                    $j = $i + 2;
                    while ($j + 1 < $end) {
                        if ($bs[$j] === 0x2A && $bs[$j + 1] === 0x2F) {
                            $this->result_pos = $j + 2;
                            $this->success = 1;
                            return;
                        }
                        $j++;
                    }
                    $this->result_pos = $end;
                    $this->success = 1;
                    return;
                }

                $this->success = 0;
            }
        }

        $SkipString {
            $>() {
                $i = $this->pos;
                $end = $this->scan_end;
                $bs = $this->bytes;

                if ($i >= $end) {
                    $this->success = 0;
                    return;
                }

                $b0 = $bs[$i];

                // Verbatim string @"..." (doubled quotes for escape)
                if ($b0 === 0x40 && $i + 1 < $end && $bs[$i + 1] === 0x22) {
                    $j = $i + 2;
                    while ($j < $end) {
                        if ($bs[$j] === 0x22) {
                            if ($j + 1 < $end && $bs[$j + 1] === 0x22) {
                                $j += 2;
                                continue;
                            }
                            $this->result_pos = $j + 1;
                            $this->success = 1;
                            return;
                        }
                        $j++;
                    }
                    $this->result_pos = $end;
                    $this->success = 1;
                    return;
                }

                // Interpolated string $"..." or $@"..." or raw $"""..."""
                if ($b0 === 0x24) {
                    $j = $i + 1;
                    // Skip additional $
                    while ($j < $end && $bs[$j] === 0x24) {
                        $j++;
                    }
                    // Check for @
                    if ($j < $end && $bs[$j] === 0x40) {
                        $j++;
                    }
                    // Count opening quotes
                    $quotes = 0;
                    while ($j < $end && $bs[$j] === 0x22) {
                        $quotes++;
                        $j++;
                    }
                    if ($quotes === 0) {
                        $this->success = 0;
                        return;
                    }
                    // Raw string (3+ quotes)
                    if ($quotes >= 3) {
                        while ($j < $end) {
                            if ($bs[$j] === 0x22) {
                                $q = 0;
                                $p = $j;
                                while ($p < $end && $bs[$p] === 0x22) {
                                    $q++;
                                    $p++;
                                }
                                if ($q >= $quotes) {
                                    $this->result_pos = $p;
                                    $this->success = 1;
                                    return;
                                }
                                $j = $p;
                                continue;
                            }
                            $j++;
                        }
                        $this->result_pos = $end;
                        $this->success = 1;
                        return;
                    }
                    // Normal interpolated string
                    while ($j < $end) {
                        if ($bs[$j] === 0x5C) {
                            $j += 2;
                            continue;
                        }
                        if ($bs[$j] === 0x22) {
                            $this->result_pos = $j + 1;
                            $this->success = 1;
                            return;
                        }
                        $j++;
                    }
                    $this->result_pos = $end;
                    $this->success = 1;
                    return;
                }

                // Simple string: " or '
                if ($b0 === 0x22 || $b0 === 0x27) {
                    $q = $b0;
                    $j = $i + 1;
                    while ($j < $end) {
                        if ($bs[$j] === 0x5C) {
                            $j += 2;
                            continue;
                        }
                        if ($bs[$j] === $q) {
                            $this->result_pos = $j + 1;
                            $this->success = 1;
                            return;
                        }
                        $j++;
                    }
                    $this->result_pos = $end;
                    $this->success = 1;
                    return;
                }

                $this->success = 0;
            }
        }

        $FindLineEnd {
            $>() {
                $j = $this->pos;
                $end = $this->scan_end;
                $bs = $this->bytes;

                while ($j < $end) {
                    $b = $bs[$j];
                    if ($b === 0x0A || $b === 0x3B) {
                        break;
                    }
                    // Stop at // or /* comment
                    if ($b === 0x2F && $j + 1 < $end && ($bs[$j + 1] === 0x2F || $bs[$j + 1] === 0x2A)) {
                        break;
                    }
                    // Stop at # preprocessor
                    if ($b === 0x23) {
                        break;
                    }
                    $j++;
                }

                $this->result_pos = $j;
            }
        }

        $BalancedParenEnd {
            $>() {
                $i = $this->pos;
                $end = $this->scan_end;
                $bs = $this->bytes;

                if ($i >= $end || $bs[$i] !== 0x28) {
                    $this->success = 0;
                    return;
                }

                $depth = 1;
                $j = $i + 1;
                while ($j < $end && $depth > 0) {
                    $b = $bs[$j];
                    if ($b === 0x28) {
                        $depth++;
                    } elseif ($b === 0x29) {
                        $depth--;
                    } elseif ($b === 0x22 || $b === 0x27) {
                        $q = $b;
                        $j++;
                        while ($j < $end && $bs[$j] !== $q) {
                            if ($bs[$j] === 0x5C) {
                                $j++;
                            }
                            $j++;
                        }
                    }
                    $j++;
                }

                if ($depth === 0) {
                    $this->result_pos = $j;
                    $this->success = 1;
                } else {
                    $this->result_pos = $end;
                    $this->success = 0;
                }
            }
        }

    domain:
        bytes = []
        pos = 0
        scan_end = 0
        result_pos = 0
        success = 1
}

function str_to_bytes(string $s): array {
    return array_values(unpack('C*', $s));
}

$failures = 0;

// Test 1: Skip // line comment
$s1 = @@CSharpSyntaxSkipperFsm();
$inp1 = str_to_bytes("// comment\ncode");
$s1->setup($inp1, 0, count($inp1));
$s1->do_skip_comment();
if ($s1->get_success() !== 1 || $s1->get_result_pos() !== 10) {
    echo 'FAIL 1: success=' . $s1->get_success() . ', pos=' . $s1->get_result_pos() . "\n";
    $failures++;
}

// Test 2: Skip /* */ block comment
$s2 = @@CSharpSyntaxSkipperFsm();
$inp2 = str_to_bytes("/* block */code");
$s2->setup($inp2, 0, count($inp2));
$s2->do_skip_comment();
if ($s2->get_success() !== 1 || $s2->get_result_pos() !== 11) {
    echo 'FAIL 2: success=' . $s2->get_success() . ', pos=' . $s2->get_result_pos() . "\n";
    $failures++;
}

// Test 3: Skip simple string "hello"
$s3 = @@CSharpSyntaxSkipperFsm();
$inp3 = str_to_bytes("\"hello\" rest");
$s3->setup($inp3, 0, count($inp3));
$s3->do_skip_string();
if ($s3->get_success() !== 1 || $s3->get_result_pos() !== 7) {
    echo 'FAIL 3: success=' . $s3->get_success() . ', pos=' . $s3->get_result_pos() . "\n";
    $failures++;
}

// Test 4: Skip verbatim string @"verbatim ""quote"""
$s4 = @@CSharpSyntaxSkipperFsm();
$inp4 = str_to_bytes('@"verbatim ""quote""" rest');
$s4->setup($inp4, 0, count($inp4));
$s4->do_skip_string();
if ($s4->get_success() !== 1 || $s4->get_result_pos() !== 21) {
    echo 'FAIL 4: success=' . $s4->get_success() . ', pos=' . $s4->get_result_pos() . "\n";
    $failures++;
}

// Test 5: Skip interpolated string $"interp {x}"
$s5 = @@CSharpSyntaxSkipperFsm();
$inp5 = str_to_bytes('$"interp {x}" rest');
$s5->setup($inp5, 0, count($inp5));
$s5->do_skip_string();
if ($s5->get_success() !== 1 || $s5->get_result_pos() !== 13) {
    echo 'FAIL 5: success=' . $s5->get_success() . ', pos=' . $s5->get_result_pos() . "\n";
    $failures++;
}

// Test 6: Find line end (stops at // comment)
$s6 = @@CSharpSyntaxSkipperFsm();
$inp6 = str_to_bytes("x + 1 // comment");
$s6->setup($inp6, 0, count($inp6));
$s6->do_find_line_end();
if ($s6->get_result_pos() !== 6) {
    echo 'FAIL 6: pos=' . $s6->get_result_pos() . ", expected 6\n";
    $failures++;
}

// Test 7: Balanced parens
$s7 = @@CSharpSyntaxSkipperFsm();
$inp7 = str_to_bytes("(a, f(b)) rest");
$s7->setup($inp7, 0, count($inp7));
$s7->do_balanced_paren_end();
if ($s7->get_success() !== 1 || $s7->get_result_pos() !== 9) {
    echo 'FAIL 7: success=' . $s7->get_success() . ', pos=' . $s7->get_result_pos() . "\n";
    $failures++;
}

// Test 8: Skip # preprocessor directive
$s8 = @@CSharpSyntaxSkipperFsm();
$inp8 = str_to_bytes("#region Foo\ncode");
$s8->setup($inp8, 0, count($inp8));
$s8->do_skip_comment();
if ($s8->get_success() !== 1 || $s8->get_result_pos() !== 11) {
    echo 'FAIL 8: success=' . $s8->get_success() . ', pos=' . $s8->get_result_pos() . "\n";
    $failures++;
}

if ($failures > 0) { echo "FAIL: $failures failures\n"; exit(1); }
echo "PASS: csharp_skipper (8 cases)\n";

@@[target("python_3")]

# CSharpSyntaxSkipper -- FSM for skipping C# comments and strings.
# Translated from framec's native_region_scanner/csharp_skipper.frs
#
# Handles: // line comments, /* */ block comments, # preprocessor directives,
# "..." simple strings, @"..." verbatim strings, $"..." interpolated strings,
# $"""...""" raw strings, C-like line endings, balanced parens.

@@system CSharpSyntaxSkipperFsm {
    operations:
        setup(input_bytes: list, start: int, length: int) {
            self.bytes = input_bytes
            self.pos = start
            self.scan_end = length
        }
        get_result_pos(): int {
            return self.result_pos
        }
        get_success(): int {
            return self.success
        }

    interface:
        do_skip_comment()
        do_skip_string()
        do_find_line_end()
        do_balanced_paren_end()

    machine:
        $Init {
            do_skip_comment() { -> $SkipComment }
            do_skip_string() { -> $SkipString }
            do_find_line_end() { -> $FindLineEnd }
            do_balanced_paren_end() { -> $BalancedParenEnd }
        }

        $SkipComment {
            $>() {
                i = self.pos
                end = self.scan_end
                bs = self.bytes

                # Preprocessor directive: # ... newline
                if i < end and bs[i] == ord('#'):
                    j = i + 1
                    while j < end and bs[j] != ord('\n'):
                        j += 1
                    self.result_pos = j
                    self.success = 1
                    return

                # Line comment: //
                if i + 1 < end and bs[i] == ord('/') and bs[i + 1] == ord('/'):
                    j = i + 2
                    while j < end and bs[j] != ord('\n'):
                        j += 1
                    self.result_pos = j
                    self.success = 1
                    return

                # Block comment: /* ... */
                if i + 1 < end and bs[i] == ord('/') and bs[i + 1] == ord('*'):
                    j = i + 2
                    while j + 1 < end:
                        if bs[j] == ord('*') and bs[j + 1] == ord('/'):
                            self.result_pos = j + 2
                            self.success = 1
                            return
                        j += 1
                    self.result_pos = end
                    self.success = 1
                    return

                self.success = 0
            }
        }

        $SkipString {
            $>() {
                i = self.pos
                end = self.scan_end
                bs = self.bytes

                if i >= end:
                    self.success = 0
                    return

                b0 = bs[i]

                # Verbatim string @"..." (doubled quotes for escape)
                if b0 == ord('@') and i + 1 < end and bs[i + 1] == ord('"'):
                    j = i + 2
                    while j < end:
                        if bs[j] == ord('"'):
                            if j + 1 < end and bs[j + 1] == ord('"'):
                                j += 2
                                continue
                            self.result_pos = j + 1
                            self.success = 1
                            return
                        j += 1
                    self.result_pos = end
                    self.success = 1
                    return

                # Interpolated string $"..." or $@"..." or raw $"""..."""
                if b0 == ord('$'):
                    j = i + 1
                    # Skip additional $
                    while j < end and bs[j] == ord('$'):
                        j += 1
                    # Check for @
                    if j < end and bs[j] == ord('@'):
                        j += 1
                    # Count opening quotes
                    quotes = 0
                    while j < end and bs[j] == ord('"'):
                        quotes += 1
                        j += 1
                    if quotes == 0:
                        self.success = 0
                        return
                    # Raw string (3+ quotes)
                    if quotes >= 3:
                        while j < end:
                            if bs[j] == ord('"'):
                                q = 0
                                p = j
                                while p < end and bs[p] == ord('"'):
                                    q += 1
                                    p += 1
                                if q >= quotes:
                                    self.result_pos = p
                                    self.success = 1
                                    return
                                j = p
                                continue
                            j += 1
                        self.result_pos = end
                        self.success = 1
                        return
                    # Normal interpolated string
                    while j < end:
                        if bs[j] == ord('\\'):
                            j += 2
                            continue
                        if bs[j] == ord('"'):
                            self.result_pos = j + 1
                            self.success = 1
                            return
                        j += 1
                    self.result_pos = end
                    self.success = 1
                    return

                # Simple string: " or '
                if b0 == ord('"') or b0 == ord("'"):
                    q = b0
                    j = i + 1
                    while j < end:
                        if bs[j] == ord('\\'):
                            j += 2
                            continue
                        if bs[j] == q:
                            self.result_pos = j + 1
                            self.success = 1
                            return
                        j += 1
                    self.result_pos = end
                    self.success = 1
                    return

                self.success = 0
            }
        }

        $FindLineEnd {
            $>() {
                j = self.pos
                end = self.scan_end
                bs = self.bytes

                while j < end:
                    b = bs[j]
                    if b == ord('\n') or b == ord(';'):
                        break
                    # Stop at // or /* comment
                    if b == ord('/') and j + 1 < end and (bs[j + 1] == ord('/') or bs[j + 1] == ord('*')):
                        break
                    # Stop at # preprocessor
                    if b == ord('#'):
                        break
                    j += 1

                self.result_pos = j
            }
        }

        $BalancedParenEnd {
            $>() {
                i = self.pos
                end = self.scan_end
                bs = self.bytes

                if i >= end or bs[i] != ord('('):
                    self.success = 0
                    return

                depth = 1
                j = i + 1
                while j < end and depth > 0:
                    b = bs[j]
                    if b == ord('('):
                        depth += 1
                    elif b == ord(')'):
                        depth -= 1
                    elif b == ord('"') or b == ord("'"):
                        q = b
                        j += 1
                        while j < end and bs[j] != q:
                            if bs[j] == ord('\\'):
                                j += 1
                            j += 1
                    j += 1

                if depth == 0:
                    self.result_pos = j
                    self.success = 1
                else:
                    self.result_pos = end
                    self.success = 0
            }
        }

    domain:
        bytes: list = []
        pos: int = 0
        scan_end: int = 0
        result_pos: int = 0
        success: int = 1
}

if __name__ == '__main__':
    failures = 0

    # Test 1: Skip // line comment
    s1 = @@CSharpSyntaxSkipperFsm()
    inp1 = list(b"// comment\ncode")
    s1.setup(inp1, 0, len(inp1))
    s1.do_skip_comment()
    if s1.get_success() != 1 or s1.get_result_pos() != 10:
        print(f"FAIL 1: success={s1.get_success()}, pos={s1.get_result_pos()}")
        failures += 1

    # Test 2: Skip /* */ block comment
    s2 = @@CSharpSyntaxSkipperFsm()
    inp2 = list(b"/* block */code")
    s2.setup(inp2, 0, len(inp2))
    s2.do_skip_comment()
    if s2.get_success() != 1 or s2.get_result_pos() != 11:
        print(f"FAIL 2: success={s2.get_success()}, pos={s2.get_result_pos()}")
        failures += 1

    # Test 3: Skip simple string "hello"
    s3 = @@CSharpSyntaxSkipperFsm()
    inp3 = list(b'"hello" rest')
    s3.setup(inp3, 0, len(inp3))
    s3.do_skip_string()
    if s3.get_success() != 1 or s3.get_result_pos() != 7:
        print(f"FAIL 3: success={s3.get_success()}, pos={s3.get_result_pos()}")
        failures += 1

    # Test 4: Skip verbatim string @"verbatim ""quote"""
    s4 = @@CSharpSyntaxSkipperFsm()
    inp4 = list(b'@"verbatim ""quote""" rest')
    s4.setup(inp4, 0, len(inp4))
    s4.do_skip_string()
    if s4.get_success() != 1 or s4.get_result_pos() != 21:
        print(f"FAIL 4: success={s4.get_success()}, pos={s4.get_result_pos()}")
        failures += 1

    # Test 5: Skip interpolated string $"interp {x}"
    s5 = @@CSharpSyntaxSkipperFsm()
    inp5 = list(b'$"interp {x}" rest')
    s5.setup(inp5, 0, len(inp5))
    s5.do_skip_string()
    if s5.get_success() != 1 or s5.get_result_pos() != 13:
        print(f"FAIL 5: success={s5.get_success()}, pos={s5.get_result_pos()}")
        failures += 1

    # Test 6: Find line end (stops at // comment)
    s6 = @@CSharpSyntaxSkipperFsm()
    inp6 = list(b"x + 1 // comment")
    s6.setup(inp6, 0, len(inp6))
    s6.do_find_line_end()
    if s6.get_result_pos() != 6:
        print(f"FAIL 6: pos={s6.get_result_pos()}, expected 6")
        failures += 1

    # Test 7: Balanced parens
    s7 = @@CSharpSyntaxSkipperFsm()
    inp7 = list(b"(a, f(b)) rest")
    s7.setup(inp7, 0, len(inp7))
    s7.do_balanced_paren_end()
    if s7.get_success() != 1 or s7.get_result_pos() != 9:
        print(f"FAIL 7: success={s7.get_success()}, pos={s7.get_result_pos()}")
        failures += 1

    # Test 8: Skip # preprocessor directive
    s8 = @@CSharpSyntaxSkipperFsm()
    inp8 = list(b"#region Foo\ncode")
    s8.setup(inp8, 0, len(inp8))
    s8.do_skip_comment()
    if s8.get_success() != 1 or s8.get_result_pos() != 11:
        print(f"FAIL 8: success={s8.get_success()}, pos={s8.get_result_pos()}")
        failures += 1

    if failures > 0:
        print(f"FAIL: {failures} failures")
        exit(1)
    print("PASS: csharp_skipper (8 cases)")

@@target go

package main

import "fmt"
import "os"

// TypeScriptSyntaxSkipper — FSM for skipping TS/JS comments and strings.
// Translated from framec's native_region_scanner/typescript_skipper.frs
//
// Adds template literal awareness (backtick strings with ${} interpolation)
// on top of the C-style comment and string patterns.

@@system TSSyntaxSkipperFsm {
    operations:
        Setup(input_bytes: []byte, start: int, length: int) {
            s.bytes = input_bytes
            s.pos = start
            s.scan_end = length
        }
        GetResultPos(): int {
            return s.result_pos
        }
        GetSuccess(): int {
            return s.success
        }

    interface:
        DoSkipComment()
        DoSkipString()
        DoFindLineEnd()

    machine:
        $Init {
            DoSkipComment() { -> $SkipComment }
            DoSkipString() { -> $SkipString }
            DoFindLineEnd() { -> $FindLineEnd }
        }

        $SkipComment {
            $>() {
                i := s.pos
                end := s.scan_end
                bs := s.bytes

                // // line comment
                if i+1 < end && bs[i] == '/' && bs[i+1] == '/' {
                    j := i + 2
                    for j < end && bs[j] != '\n' {
                        j++
                    }
                    s.result_pos = j
                    s.success = 1
                    return
                }

                // /* block comment */
                if i+1 < end && bs[i] == '/' && bs[i+1] == '*' {
                    j := i + 2
                    for j+1 < end {
                        if bs[j] == '*' && bs[j+1] == '/' {
                            s.result_pos = j + 2
                            s.success = 1
                            return
                        }
                        j++
                    }
                    s.result_pos = end
                    s.success = 1
                    return
                }

                s.success = 0
            }
        }

        $SkipString {
            $>() {
                i := s.pos
                end := s.scan_end
                bs := s.bytes

                // Template literal: `...${...}...`
                if i < end && bs[i] == '`' {
                    j := i + 1
                    templateDepth := 0
                    for j < end {
                        b := bs[j]
                        if b == '`' && templateDepth == 0 {
                            s.result_pos = j + 1
                            s.success = 1
                            return
                        }
                        if b == '\\' {
                            j += 2
                            continue
                        }
                        if b == '$' && j+1 < end && bs[j+1] == '{' {
                            templateDepth++
                            j += 2
                            continue
                        }
                        if b == '}' && templateDepth > 0 {
                            templateDepth--
                        }
                        j++
                    }
                    s.result_pos = end
                    s.success = 1
                    return
                }

                // Simple string: " or '
                if i < end && (bs[i] == '"' || bs[i] == '\'') {
                    q := bs[i]
                    j := i + 1
                    for j < end {
                        if bs[j] == '\\' {
                            j += 2
                            continue
                        }
                        if bs[j] == q {
                            s.result_pos = j + 1
                            s.success = 1
                            return
                        }
                        j++
                    }
                    s.result_pos = end
                    s.success = 1
                    return
                }

                s.success = 0
            }
        }

        $FindLineEnd {
            $>() {
                j := s.pos
                end := s.scan_end
                bs := s.bytes
                inTemplate := false
                templateDepth := 0

                for j < end {
                    b := bs[j]

                    if inTemplate {
                        if b == '`' && templateDepth == 0 {
                            inTemplate = false
                            j++
                            continue
                        }
                        if b == '\\' {
                            j += 2
                            continue
                        }
                        if b == '$' && j+1 < end && bs[j+1] == '{' {
                            templateDepth++
                            j += 2
                            continue
                        }
                        if b == '}' && templateDepth > 0 {
                            templateDepth--
                        }
                        j++
                        continue
                    }

                    if b == '\n' {
                        break
                    }
                    if b == ';' {
                        break
                    }
                    if b == '/' && j+1 < end && bs[j+1] == '/' {
                        break
                    }
                    if b == '/' && j+1 < end && bs[j+1] == '*' {
                        break
                    }
                    if b == '`' {
                        inTemplate = true
                        j++
                        continue
                    }
                    if b == '"' || b == '\'' {
                        q := b
                        j++
                        for j < end && bs[j] != q {
                            if bs[j] == '\\' {
                                j++
                            }
                            j++
                        }
                        if j < end {
                            j++
                        }
                        continue
                    }

                    j++
                }

                s.result_pos = j
            }
        }

    domain:
        bytes: []byte = nil
        pos: int = 0
        scan_end: int = 0
        result_pos: int = 0
        success: int = 1
}

func main() {
	failures := 0

	// Test 1: Skip // line comment
	s1 := NewTSSyntaxSkipperFsm()
	inp1 := []byte("// comment\ncode")
	s1.Setup(inp1, 0, len(inp1))
	s1.DoSkipComment()
	if s1.GetSuccess() != 1 || s1.GetResultPos() != 10 {
		fmt.Printf("FAIL 1: success=%d, pos=%d\n", s1.GetSuccess(), s1.GetResultPos())
		failures++
	}

	// Test 2: Skip /* block comment */
	s2 := NewTSSyntaxSkipperFsm()
	inp2 := []byte("/* block */code")
	s2.Setup(inp2, 0, len(inp2))
	s2.DoSkipComment()
	if s2.GetSuccess() != 1 || s2.GetResultPos() != 11 {
		fmt.Printf("FAIL 2: success=%d, pos=%d\n", s2.GetSuccess(), s2.GetResultPos())
		failures++
	}

	// Test 3: Skip template literal
	s3 := NewTSSyntaxSkipperFsm()
	inp3 := []byte("`hello ${name} world`rest")
	s3.Setup(inp3, 0, len(inp3))
	s3.DoSkipString()
	if s3.GetSuccess() != 1 || s3.GetResultPos() != 21 {
		fmt.Printf("FAIL 3: success=%d, pos=%d\n", s3.GetSuccess(), s3.GetResultPos())
		failures++
	}

	// Test 4: Skip simple double-quoted string
	s4 := NewTSSyntaxSkipperFsm()
	inp4 := []byte("\"hello\" rest")
	s4.Setup(inp4, 0, len(inp4))
	s4.DoSkipString()
	if s4.GetSuccess() != 1 || s4.GetResultPos() != 7 {
		fmt.Printf("FAIL 4: success=%d, pos=%d\n", s4.GetSuccess(), s4.GetResultPos())
		failures++
	}

	// Test 5: Skip template with nested ${}
	s5 := NewTSSyntaxSkipperFsm()
	inp5 := []byte("`${a + ${b}}`rest")
	s5.Setup(inp5, 0, len(inp5))
	s5.DoSkipString()
	if s5.GetSuccess() != 1 {
		fmt.Printf("FAIL 5: success=%d\n", s5.GetSuccess())
		failures++
	}

	// Test 6: Find line end skips over template literals
	s6 := NewTSSyntaxSkipperFsm()
	inp6 := []byte("x = `hello`;\nnext")
	s6.Setup(inp6, 0, len(inp6))
	s6.DoFindLineEnd()
	if s6.GetResultPos() != 11 {
		fmt.Printf("FAIL 6: pos=%d, expected 11 (at ;)\n", s6.GetResultPos())
		failures++
	}

	// Test 7: Not a string
	s7 := NewTSSyntaxSkipperFsm()
	inp7 := []byte("x + 1")
	s7.Setup(inp7, 0, len(inp7))
	s7.DoSkipString()
	if s7.GetSuccess() != 0 {
		fmt.Println("FAIL 7: should not be string")
		failures++
	}

	if failures > 0 {
		fmt.Printf("FAIL: %d failures\n", failures)
		os.Exit(1)
	}
	fmt.Println("PASS: ts_skipper (7 cases)")
}

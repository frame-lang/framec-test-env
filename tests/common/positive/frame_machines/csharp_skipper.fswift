@@target swift

import Foundation

// CSharpSyntaxSkipper -- FSM for skipping C# comments and strings.
// Translated from framec's native_region_scanner/csharp_skipper.frs
//
// Handles: // line comments, /* */ block comments, # preprocessor directives,
// "..." simple strings, @"..." verbatim strings, $"..." interpolated strings,
// $"""...""" raw strings, C-like line endings, balanced parens.

@@system CSharpSyntaxSkipperFsm {
    operations:
        setup(input_bytes: [UInt8], start: Int, length: Int) {
            self.bytes = input_bytes
            self.pos = start
            self.scan_end = length
        }
        get_result_pos(): Int {
            return self.result_pos
        }
        get_success(): Int {
            return self.success
        }

    interface:
        do_skip_comment()
        do_skip_string()
        do_find_line_end()
        do_balanced_paren_end()

    machine:
        $Init {
            do_skip_comment() { -> $SkipComment }
            do_skip_string() { -> $SkipString }
            do_find_line_end() { -> $FindLineEnd }
            do_balanced_paren_end() { -> $BalancedParenEnd }
        }

        $SkipComment {
            $>() {
                var i = self.pos
                let end = self.scan_end
                let bs = self.bytes

                // Preprocessor directive: # ... newline
                if i < end && bs[i] == UInt8(ascii: "#") {
                    var j = i + 1
                    while j < end && bs[j] != 0x0A {
                        j += 1
                    }
                    self.result_pos = j
                    self.success = 1
                    return
                }

                // Line comment: //
                if i + 1 < end && bs[i] == UInt8(ascii: "/") && bs[i + 1] == UInt8(ascii: "/") {
                    var j = i + 2
                    while j < end && bs[j] != 0x0A {
                        j += 1
                    }
                    self.result_pos = j
                    self.success = 1
                    return
                }

                // Block comment: /* ... */
                if i + 1 < end && bs[i] == UInt8(ascii: "/") && bs[i + 1] == UInt8(ascii: "*") {
                    var j = i + 2
                    while j + 1 < end {
                        if bs[j] == UInt8(ascii: "*") && bs[j + 1] == UInt8(ascii: "/") {
                            self.result_pos = j + 2
                            self.success = 1
                            return
                        }
                        j += 1
                    }
                    self.result_pos = end
                    self.success = 1
                    return
                }

                self.success = 0
            }
        }

        $SkipString {
            $>() {
                var i = self.pos
                let end = self.scan_end
                let bs = self.bytes

                if i >= end {
                    self.success = 0
                    return
                }

                let b0 = bs[i]

                // Verbatim string @"..." (doubled quotes for escape)
                if b0 == UInt8(ascii: "@") && i + 1 < end && bs[i + 1] == 0x22 {
                    var j = i + 2
                    while j < end {
                        if bs[j] == 0x22 {
                            if j + 1 < end && bs[j + 1] == 0x22 {
                                j += 2
                                continue
                            }
                            self.result_pos = j + 1
                            self.success = 1
                            return
                        }
                        j += 1
                    }
                    self.result_pos = end
                    self.success = 1
                    return
                }

                // Interpolated string $"..." or $@"..." or raw $"""..."""
                if b0 == UInt8(ascii: "$") {
                    var j = i + 1
                    while j < end && bs[j] == UInt8(ascii: "$") {
                        j += 1
                    }
                    if j < end && bs[j] == UInt8(ascii: "@") {
                        j += 1
                    }
                    var quotes = 0
                    while j < end && bs[j] == 0x22 {
                        quotes += 1
                        j += 1
                    }
                    if quotes == 0 {
                        self.success = 0
                        return
                    }
                    if quotes >= 3 {
                        while j < end {
                            if bs[j] == 0x22 {
                                var q = 0
                                var p = j
                                while p < end && bs[p] == 0x22 {
                                    q += 1
                                    p += 1
                                }
                                if q >= quotes {
                                    self.result_pos = p
                                    self.success = 1
                                    return
                                }
                                j = p
                                continue
                            }
                            j += 1
                        }
                        self.result_pos = end
                        self.success = 1
                        return
                    }
                    while j < end {
                        if bs[j] == UInt8(ascii: "\\") {
                            j += 2
                            continue
                        }
                        if bs[j] == 0x22 {
                            self.result_pos = j + 1
                            self.success = 1
                            return
                        }
                        j += 1
                    }
                    self.result_pos = end
                    self.success = 1
                    return
                }

                // Simple string: " or '
                if b0 == 0x22 || b0 == UInt8(ascii: "'") {
                    let q = b0
                    var j = i + 1
                    while j < end {
                        if bs[j] == UInt8(ascii: "\\") {
                            j += 2
                            continue
                        }
                        if bs[j] == q {
                            self.result_pos = j + 1
                            self.success = 1
                            return
                        }
                        j += 1
                    }
                    self.result_pos = end
                    self.success = 1
                    return
                }

                self.success = 0
            }
        }

        $FindLineEnd {
            $>() {
                var j = self.pos
                let end = self.scan_end
                let bs = self.bytes

                while j < end {
                    let b = bs[j]
                    if b == 0x0A || b == UInt8(ascii: ";") {
                        break
                    }
                    if b == UInt8(ascii: "/") && j + 1 < end && (bs[j + 1] == UInt8(ascii: "/") || bs[j + 1] == UInt8(ascii: "*")) {
                        break
                    }
                    if b == UInt8(ascii: "#") {
                        break
                    }
                    j += 1
                }

                self.result_pos = j
            }
        }

        $BalancedParenEnd {
            $>() {
                var i = self.pos
                let end = self.scan_end
                let bs = self.bytes

                if i >= end || bs[i] != UInt8(ascii: "(") {
                    self.success = 0
                    return
                }

                var depth = 1
                var j = i + 1
                while j < end && depth > 0 {
                    let b = bs[j]
                    if b == UInt8(ascii: "(") {
                        depth += 1
                    } else if b == UInt8(ascii: ")") {
                        depth -= 1
                    } else if b == 0x22 || b == UInt8(ascii: "'") {
                        let q = b
                        j += 1
                        while j < end && bs[j] != q {
                            if bs[j] == UInt8(ascii: "\\") {
                                j += 1
                            }
                            j += 1
                        }
                    }
                    j += 1
                }

                if depth == 0 {
                    self.result_pos = j
                    self.success = 1
                } else {
                    self.result_pos = end
                    self.success = 0
                }
            }
        }

    domain:
        bytes: [UInt8] = []
        pos: Int = 0
        scan_end: Int = 0
        result_pos: Int = 0
        success: Int = 1
}

// main
    var failures = 0

    // Test 1: Skip // line comment
    let s1 = @@CSharpSyntaxSkipperFsm()
    let inp1: [UInt8] = Array("// comment\ncode".utf8)
    s1.setup(inp1, 0, inp1.count)
    s1.do_skip_comment()
    if s1.get_success() != 1 || s1.get_result_pos() != 10 {
        print("FAIL 1: success=\(s1.get_success()), pos=\(s1.get_result_pos())")
        failures += 1
    }

    // Test 2: Skip /* */ block comment
    let s2 = @@CSharpSyntaxSkipperFsm()
    let inp2: [UInt8] = Array("/* block */code".utf8)
    s2.setup(inp2, 0, inp2.count)
    s2.do_skip_comment()
    if s2.get_success() != 1 || s2.get_result_pos() != 11 {
        print("FAIL 2: success=\(s2.get_success()), pos=\(s2.get_result_pos())")
        failures += 1
    }

    // Test 3: Skip simple string "hello"
    let s3 = @@CSharpSyntaxSkipperFsm()
    let inp3: [UInt8] = Array("\"hello\" rest".utf8)
    s3.setup(inp3, 0, inp3.count)
    s3.do_skip_string()
    if s3.get_success() != 1 || s3.get_result_pos() != 7 {
        print("FAIL 3: success=\(s3.get_success()), pos=\(s3.get_result_pos())")
        failures += 1
    }

    // Test 4: Skip verbatim string @"verbatim ""quote"""
    let s4 = @@CSharpSyntaxSkipperFsm()
    let inp4: [UInt8] = Array("@\"verbatim \"\"quote\"\"\" rest".utf8)
    s4.setup(inp4, 0, inp4.count)
    s4.do_skip_string()
    if s4.get_success() != 1 || s4.get_result_pos() != 21 {
        print("FAIL 4: success=\(s4.get_success()), pos=\(s4.get_result_pos())")
        failures += 1
    }

    // Test 5: Skip interpolated string $"interp {x}"
    let s5 = @@CSharpSyntaxSkipperFsm()
    let inp5: [UInt8] = Array("$\"interp {x}\" rest".utf8)
    s5.setup(inp5, 0, inp5.count)
    s5.do_skip_string()
    if s5.get_success() != 1 || s5.get_result_pos() != 13 {
        print("FAIL 5: success=\(s5.get_success()), pos=\(s5.get_result_pos())")
        failures += 1
    }

    // Test 6: Find line end (stops at // comment)
    let s6 = @@CSharpSyntaxSkipperFsm()
    let inp6: [UInt8] = Array("x + 1 // comment".utf8)
    s6.setup(inp6, 0, inp6.count)
    s6.do_find_line_end()
    if s6.get_result_pos() != 6 {
        print("FAIL 6: pos=\(s6.get_result_pos()), expected 6")
        failures += 1
    }

    // Test 7: Balanced parens
    let s7 = @@CSharpSyntaxSkipperFsm()
    let inp7: [UInt8] = Array("(a, f(b)) rest".utf8)
    s7.setup(inp7, 0, inp7.count)
    s7.do_balanced_paren_end()
    if s7.get_success() != 1 || s7.get_result_pos() != 9 {
        print("FAIL 7: success=\(s7.get_success()), pos=\(s7.get_result_pos())")
        failures += 1
    }

    // Test 8: Skip # preprocessor directive
    let s8 = @@CSharpSyntaxSkipperFsm()
    let inp8: [UInt8] = Array("#region Foo\ncode".utf8)
    s8.setup(inp8, 0, inp8.count)
    s8.do_skip_comment()
    if s8.get_success() != 1 || s8.get_result_pos() != 11 {
        print("FAIL 8: success=\(s8.get_success()), pos=\(s8.get_result_pos())")
        failures += 1
    }

    if failures > 0 {
        print("FAIL: \(failures) failures")
        exit(1)
    }
    print("PASS: csharp_skipper (8 cases)")

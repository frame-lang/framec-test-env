@@target c

#include <string.h>

// CSyntaxSkipper -- FSM for skipping C-style comments and strings.
// Translated from framec's native_region_scanner/c_skipper.frs
//
// Demonstrates the skipper pattern: dispatch on entry point, scan
// to find the end of the construct, report result via domain vars.

@@system CSyntaxSkipperFsm {
    operations:
        setup(input_bytes: unsigned char*, start: int, length: int) {
            self->bytes = input_bytes;
            self->pos = start;
            self->end = length;
        }
        get_result_pos(): int {
            return self->result_pos;
        }
        get_success(): int {
            return self->success;
        }

    interface:
        do_skip_comment()
        do_skip_string()
        do_find_line_end()
        do_balanced_paren_end()

    machine:
        $Init {
            do_skip_comment() { -> $SkipComment }
            do_skip_string() { -> $SkipString }
            do_find_line_end() { -> $FindLineEnd }
            do_balanced_paren_end() { -> $BalancedParenEnd }
        }

        $SkipComment {
            $>() {
                int i = self->pos;
                int end = self->end;
                unsigned char* bs = self->bytes;

                // Try line comment: //
                if (i + 1 < end && bs[i] == '/' && bs[i + 1] == '/') {
                    int j = i + 2;
                    while (j < end && bs[j] != '\n') {
                        j++;
                    }
                    self->result_pos = j;
                    self->success = 1;
                    return;
                }

                // Try block comment: /* ... */
                if (i + 1 < end && bs[i] == '/' && bs[i + 1] == '*') {
                    int j = i + 2;
                    while (j + 1 < end) {
                        if (bs[j] == '*' && bs[j + 1] == '/') {
                            self->result_pos = j + 2;
                            self->success = 1;
                            return;
                        }
                        j++;
                    }
                    self->result_pos = end;
                    self->success = 1;
                    return;
                }

                self->success = 0;
            }
        }

        $SkipString {
            $>() {
                int i = self->pos;
                int end = self->end;
                unsigned char* bs = self->bytes;

                if (i < end && (bs[i] == '"' || bs[i] == '\'')) {
                    char q = bs[i];
                    int j = i + 1;
                    while (j < end) {
                        if (bs[j] == '\\') {
                            j += 2;
                            continue;
                        }
                        if (bs[j] == q) {
                            self->result_pos = j + 1;
                            self->success = 1;
                            return;
                        }
                        j++;
                    }
                    self->result_pos = end;
                    self->success = 1;
                    return;
                }

                self->success = 0;
            }
        }

        $FindLineEnd {
            $>() {
                int j = self->pos;
                int end = self->end;
                unsigned char* bs = self->bytes;

                while (j < end) {
                    char b = bs[j];
                    if (b == '\n' || b == ';') {
                        break;
                    }
                    if (b == '/' && j + 1 < end && bs[j + 1] == '/') {
                        break;
                    }
                    if (b == '/' && j + 1 < end && bs[j + 1] == '*') {
                        break;
                    }
                    j++;
                }

                self->result_pos = j;
            }
        }

        $BalancedParenEnd {
            $>() {
                int i = self->pos;
                int end = self->end;
                unsigned char* bs = self->bytes;

                if (i >= end || bs[i] != '(') {
                    self->success = 0;
                    return;
                }

                int depth = 1;
                int j = i + 1;
                while (j < end && depth > 0) {
                    char b = bs[j];
                    if (b == '(') {
                        depth++;
                    } else if (b == ')') {
                        depth--;
                    } else if (b == '"' || b == '\'') {
                        char q = b;
                        j++;
                        while (j < end && bs[j] != q) {
                            if (bs[j] == '\\') {
                                j++;
                            }
                            j++;
                        }
                        // j is at closing quote
                    }
                    j++;
                }

                if (depth == 0) {
                    self->result_pos = j;
                    self->success = 1;
                } else {
                    self->result_pos = end;
                    self->success = 0;
                }
            }
        }

    domain:
        bytes: unsigned char* = NULL
        pos: int = 0
        end: int = 0
        result_pos: int = 0
        success: int = 1
}

int main() {
    int failures = 0;

    // Test 1: Skip line comment
    CSyntaxSkipperFsm* s1 = @@CSyntaxSkipperFsm();
    unsigned char t1[] = "// hello\ncode";
    CSyntaxSkipperFsm_setup(s1, t1, 0, strlen((char*)t1));
    CSyntaxSkipperFsm_do_skip_comment(s1);
    if (CSyntaxSkipperFsm_get_success(s1) != 1 || CSyntaxSkipperFsm_get_result_pos(s1) != 8) {
        printf("FAIL 1: success=%d, pos=%d\n", CSyntaxSkipperFsm_get_success(s1), CSyntaxSkipperFsm_get_result_pos(s1));
        failures++;
    }

    // Test 2: Skip block comment
    CSyntaxSkipperFsm* s2 = @@CSyntaxSkipperFsm();
    unsigned char t2[] = "/* block */code";
    CSyntaxSkipperFsm_setup(s2, t2, 0, strlen((char*)t2));
    CSyntaxSkipperFsm_do_skip_comment(s2);
    if (CSyntaxSkipperFsm_get_success(s2) != 1 || CSyntaxSkipperFsm_get_result_pos(s2) != 11) {
        printf("FAIL 2: success=%d, pos=%d\n", CSyntaxSkipperFsm_get_success(s2), CSyntaxSkipperFsm_get_result_pos(s2));
        failures++;
    }

    // Test 3: Not a comment
    CSyntaxSkipperFsm* s3 = @@CSyntaxSkipperFsm();
    unsigned char t3[] = "x + 1";
    CSyntaxSkipperFsm_setup(s3, t3, 0, strlen((char*)t3));
    CSyntaxSkipperFsm_do_skip_comment(s3);
    if (CSyntaxSkipperFsm_get_success(s3) != 0) {
        printf("FAIL 3: should not be a comment\n");
        failures++;
    }

    // Test 4: Skip double-quoted string
    CSyntaxSkipperFsm* s4 = @@CSyntaxSkipperFsm();
    unsigned char t4[] = "\"hello world\" rest";
    CSyntaxSkipperFsm_setup(s4, t4, 0, strlen((char*)t4));
    CSyntaxSkipperFsm_do_skip_string(s4);
    if (CSyntaxSkipperFsm_get_success(s4) != 1 || CSyntaxSkipperFsm_get_result_pos(s4) != 13) {
        printf("FAIL 4: success=%d, pos=%d\n", CSyntaxSkipperFsm_get_success(s4), CSyntaxSkipperFsm_get_result_pos(s4));
        failures++;
    }

    // Test 5: Skip string with escaped quote
    CSyntaxSkipperFsm* s5 = @@CSyntaxSkipperFsm();
    unsigned char t5[] = "\"he\\\"llo\" rest";
    CSyntaxSkipperFsm_setup(s5, t5, 0, strlen((char*)t5));
    CSyntaxSkipperFsm_do_skip_string(s5);
    if (CSyntaxSkipperFsm_get_success(s5) != 1 || CSyntaxSkipperFsm_get_result_pos(s5) != 9) {
        printf("FAIL 5: success=%d, pos=%d\n", CSyntaxSkipperFsm_get_success(s5), CSyntaxSkipperFsm_get_result_pos(s5));
        failures++;
    }

    // Test 6: Find line end (stops at newline)
    CSyntaxSkipperFsm* s6 = @@CSyntaxSkipperFsm();
    unsigned char t6[] = "x + 1\nmore";
    CSyntaxSkipperFsm_setup(s6, t6, 0, strlen((char*)t6));
    CSyntaxSkipperFsm_do_find_line_end(s6);
    if (CSyntaxSkipperFsm_get_result_pos(s6) != 5) {
        printf("FAIL 6: pos=%d, expected 5\n", CSyntaxSkipperFsm_get_result_pos(s6));
        failures++;
    }

    // Test 7: Find line end (stops at // comment)
    CSyntaxSkipperFsm* s7 = @@CSyntaxSkipperFsm();
    unsigned char t7[] = "x + 1 // comment";
    CSyntaxSkipperFsm_setup(s7, t7, 0, strlen((char*)t7));
    CSyntaxSkipperFsm_do_find_line_end(s7);
    if (CSyntaxSkipperFsm_get_result_pos(s7) != 6) {
        printf("FAIL 7: pos=%d, expected 6\n", CSyntaxSkipperFsm_get_result_pos(s7));
        failures++;
    }

    // Test 8: Balanced parens
    CSyntaxSkipperFsm* s8 = @@CSyntaxSkipperFsm();
    unsigned char t8[] = "(a, f(b), c) rest";
    CSyntaxSkipperFsm_setup(s8, t8, 0, strlen((char*)t8));
    CSyntaxSkipperFsm_do_balanced_paren_end(s8);
    if (CSyntaxSkipperFsm_get_success(s8) != 1 || CSyntaxSkipperFsm_get_result_pos(s8) != 12) {
        printf("FAIL 8: success=%d, pos=%d\n", CSyntaxSkipperFsm_get_success(s8), CSyntaxSkipperFsm_get_result_pos(s8));
        failures++;
    }

    CSyntaxSkipperFsm_destroy(s1);
    CSyntaxSkipperFsm_destroy(s2);
    CSyntaxSkipperFsm_destroy(s3);
    CSyntaxSkipperFsm_destroy(s4);
    CSyntaxSkipperFsm_destroy(s5);
    CSyntaxSkipperFsm_destroy(s6);
    CSyntaxSkipperFsm_destroy(s7);
    CSyntaxSkipperFsm_destroy(s8);

    if (failures > 0) {
        printf("FAIL: %d failures\n", failures);
        return 1;
    }
    printf("PASS: c_skipper (8 cases)\n");
    return 0;
}

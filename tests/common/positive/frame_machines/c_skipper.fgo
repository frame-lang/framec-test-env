@@[target("go")]

package main

import "fmt"
import "os"

// CSyntaxSkipper -- FSM for skipping C-style comments and strings.
// Translated from framec's native_region_scanner/c_skipper.frs
//
// Demonstrates the skipper pattern: dispatch on entry point, scan
// to find the end of the construct, report result via domain vars.

@@system CSyntaxSkipperFsm {
    operations:
        Setup(input_bytes: []byte, start: int, length: int) {
            s.bytes = input_bytes
            s.pos = start
            s.end = length
        }
        GetResultPos(): int {
            return s.result_pos
        }
        GetSuccess(): int {
            return s.success
        }

    interface:
        DoSkipComment()
        DoSkipString()
        DoFindLineEnd()
        DoBalancedParenEnd()

    machine:
        $Init {
            DoSkipComment() { -> $SkipComment }
            DoSkipString() { -> $SkipString }
            DoFindLineEnd() { -> $FindLineEnd }
            DoBalancedParenEnd() { -> $BalancedParenEnd }
        }

        $SkipComment {
            $>() {
                i := s.pos
                end := s.end
                bs := s.bytes

                // Try line comment: //
                if i+1 < end && bs[i] == '/' && bs[i+1] == '/' {
                    j := i + 2
                    for j < end && bs[j] != '\n' {
                        j++
                    }
                    s.result_pos = j
                    s.success = 1
                    return
                }

                // Try block comment: /* ... */
                if i+1 < end && bs[i] == '/' && bs[i+1] == '*' {
                    j := i + 2
                    for j+1 < end {
                        if bs[j] == '*' && bs[j+1] == '/' {
                            s.result_pos = j + 2
                            s.success = 1
                            return
                        }
                        j++
                    }
                    s.result_pos = end
                    s.success = 1
                    return
                }

                s.success = 0
            }
        }

        $SkipString {
            $>() {
                i := s.pos
                end := s.end
                bs := s.bytes

                if i < end && (bs[i] == '"' || bs[i] == '\'') {
                    q := bs[i]
                    j := i + 1
                    for j < end {
                        if bs[j] == '\\' {
                            j += 2
                            continue
                        }
                        if bs[j] == q {
                            s.result_pos = j + 1
                            s.success = 1
                            return
                        }
                        j++
                    }
                    s.result_pos = end
                    s.success = 1
                    return
                }

                s.success = 0
            }
        }

        $FindLineEnd {
            $>() {
                j := s.pos
                end := s.end
                bs := s.bytes

                for j < end {
                    b := bs[j]
                    if b == '\n' || b == ';' {
                        break
                    }
                    if b == '/' && j+1 < end && bs[j+1] == '/' {
                        break
                    }
                    if b == '/' && j+1 < end && bs[j+1] == '*' {
                        break
                    }
                    j++
                }

                s.result_pos = j
            }
        }

        $BalancedParenEnd {
            $>() {
                i := s.pos
                end := s.end
                bs := s.bytes

                if i >= end || bs[i] != '(' {
                    s.success = 0
                    return
                }

                depth := 1
                j := i + 1
                for j < end && depth > 0 {
                    b := bs[j]
                    if b == '(' {
                        depth++
                    } else if b == ')' {
                        depth--
                    } else if b == '"' || b == '\'' {
                        q := b
                        j++
                        for j < end && bs[j] != q {
                            if bs[j] == '\\' {
                                j++
                            }
                            j++
                        }
                        // j is at closing quote
                    }
                    j++
                }

                if depth == 0 {
                    s.result_pos = j
                    s.success = 1
                } else {
                    s.result_pos = end
                    s.success = 0
                }
            }
        }

    domain:
        bytes: []byte = nil
        pos: int = 0
        end: int = 0
        result_pos: int = 0
        success: int = 1
}

func main() {
	failures := 0

	// Test 1: Skip line comment
	s1 := NewCSyntaxSkipperFsm()
	inp1 := []byte("// hello\ncode")
	s1.Setup(inp1, 0, len(inp1))
	s1.DoSkipComment()
	if s1.GetSuccess() != 1 || s1.GetResultPos() != 8 {
		fmt.Printf("FAIL 1: success=%d, pos=%d\n", s1.GetSuccess(), s1.GetResultPos())
		failures++
	}

	// Test 2: Skip block comment
	s2 := NewCSyntaxSkipperFsm()
	inp2 := []byte("/* block */code")
	s2.Setup(inp2, 0, len(inp2))
	s2.DoSkipComment()
	if s2.GetSuccess() != 1 || s2.GetResultPos() != 11 {
		fmt.Printf("FAIL 2: success=%d, pos=%d\n", s2.GetSuccess(), s2.GetResultPos())
		failures++
	}

	// Test 3: Not a comment
	s3 := NewCSyntaxSkipperFsm()
	inp3 := []byte("x + 1")
	s3.Setup(inp3, 0, len(inp3))
	s3.DoSkipComment()
	if s3.GetSuccess() != 0 {
		fmt.Println("FAIL 3: should not be a comment")
		failures++
	}

	// Test 4: Skip double-quoted string
	s4 := NewCSyntaxSkipperFsm()
	inp4 := []byte("\"hello world\" rest")
	s4.Setup(inp4, 0, len(inp4))
	s4.DoSkipString()
	if s4.GetSuccess() != 1 || s4.GetResultPos() != 13 {
		fmt.Printf("FAIL 4: success=%d, pos=%d\n", s4.GetSuccess(), s4.GetResultPos())
		failures++
	}

	// Test 5: Skip string with escaped quote
	s5 := NewCSyntaxSkipperFsm()
	inp5 := []byte("\"he\\\"llo\" rest")
	s5.Setup(inp5, 0, len(inp5))
	s5.DoSkipString()
	if s5.GetSuccess() != 1 || s5.GetResultPos() != 9 {
		fmt.Printf("FAIL 5: success=%d, pos=%d\n", s5.GetSuccess(), s5.GetResultPos())
		failures++
	}

	// Test 6: Find line end (stops at newline)
	s6 := NewCSyntaxSkipperFsm()
	inp6 := []byte("x + 1\nmore")
	s6.Setup(inp6, 0, len(inp6))
	s6.DoFindLineEnd()
	if s6.GetResultPos() != 5 {
		fmt.Printf("FAIL 6: pos=%d, expected 5\n", s6.GetResultPos())
		failures++
	}

	// Test 7: Find line end (stops at // comment)
	s7 := NewCSyntaxSkipperFsm()
	inp7 := []byte("x + 1 // comment")
	s7.Setup(inp7, 0, len(inp7))
	s7.DoFindLineEnd()
	if s7.GetResultPos() != 6 {
		fmt.Printf("FAIL 7: pos=%d, expected 6\n", s7.GetResultPos())
		failures++
	}

	// Test 8: Balanced parens
	s8 := NewCSyntaxSkipperFsm()
	inp8 := []byte("(a, f(b), c) rest")
	s8.Setup(inp8, 0, len(inp8))
	s8.DoBalancedParenEnd()
	if s8.GetSuccess() != 1 || s8.GetResultPos() != 12 {
		fmt.Printf("FAIL 8: success=%d, pos=%d\n", s8.GetSuccess(), s8.GetResultPos())
		failures++
	}

	if failures > 0 {
		fmt.Printf("FAIL: %d failures\n", failures)
		os.Exit(1)
	}
	fmt.Println("PASS: c_skipper (8 cases)")
}

@@[target("php")]

// javascript_skipper -- FSM for skipping syntax constructs.

@@system JavaScriptSyntaxSkipperFsm {
    operations:
        setup(input_bytes: array, start: int, length: int) {
            $this->bytes = $input_bytes;
            $this->pos = $start;
            $this->scan_end = $length;
        }
        get_result_pos(): int {
            return $this->result_pos;
        }
        get_success(): int {
            return $this->success;
        }

    interface:
        do_skip_comment()
        do_skip_string()
        do_find_line_end()
        do_balanced_paren_end()

    machine:
        $Init {
            do_skip_comment() { -> $SkipComment }
            do_skip_string() { -> $SkipString }
            do_find_line_end() { -> $FindLineEnd }
            do_balanced_paren_end() { -> $BalancedParenEnd }
        }

        $SkipComment {
            $>() {
                $i = $this->pos;
                $end = $this->scan_end;
                $bs = $this->bytes;

                if ($i + 1 < $end && $bs[$i] === 0x2F && $bs[$i + 1] === 0x2F) {
                    $j = $i + 2;
                    while ($j < $end && $bs[$j] !== 0x0A) { $j++; }
                    $this->result_pos = $j; $this->success = 1; return;
                }
                if ($i + 1 < $end && $bs[$i] === 0x2F && $bs[$i + 1] === 0x2A) {
                    $j = $i + 2;
                    while ($j + 1 < $end) {
                        if ($bs[$j] === 0x2A && $bs[$j + 1] === 0x2F) {
                            $this->result_pos = $j + 2; $this->success = 1; return;
                        }
                        $j++;
                    }
                    $this->result_pos = $end; $this->success = 1; return;
                }
                $this->success = 0;
            }
        }

        $SkipString {
            $>() {
                $i = $this->pos;
                $end = $this->scan_end;
                $bs = $this->bytes;

                if ($i < $end && $bs[$i] === 0x60) {
                    $j = $i + 1; $braceDepth = 0;
                    while ($j < $end) {
                        if ($bs[$j] === 0x60 && $braceDepth === 0) { $this->result_pos = $j + 1; $this->success = 1; return; }
                        if ($bs[$j] === 0x5C) { $j += 2; continue; }
                        if ($bs[$j] === 0x24 && $j + 1 < $end && $bs[$j + 1] === 0x7B) { $braceDepth++; $j += 2; continue; }
                        if ($bs[$j] === 0x7D && $braceDepth > 0) { $braceDepth--; }
                        $j++;
                    }
                    $this->result_pos = $end; $this->success = 1; return;
                }

                if ($i < $end && ($bs[$i] === 0x22 || $bs[$i] === 0x27)) {
                    $q = $bs[$i]; $j = $i + 1;
                    while ($j < $end) {
                        if ($bs[$j] === 0x5C) { $j += 2; continue; }
                        if ($bs[$j] === $q) { $this->result_pos = $j + 1; $this->success = 1; return; }
                        $j++;
                    }
                    $this->result_pos = $end; $this->success = 1; return;
                }
                $this->success = 0;
            }
        }

        $FindLineEnd {
            $>() {
                $j = $this->pos;
                $end = $this->scan_end;
                $bs = $this->bytes;

                $inStr = 0; $inTpl = 0; $tbd = 0;
                while ($j < $end) {
                    $b = $bs[$j];
                    if ($b === 0x0A) { break; }
                    if ($inTpl !== 0) {
                        if ($b === 0x60 && $tbd === 0) { $inTpl = 0; $j++; continue; }
                        if ($b === 0x5C) { $j += 2; continue; }
                        if ($b === 0x24 && $j + 1 < $end && $bs[$j + 1] === 0x7B) { $tbd++; $j += 2; continue; }
                        if ($b === 0x7D && $tbd > 0) { $tbd--; }
                        $j++; continue;
                    }
                    if ($inStr !== 0) {
                        if ($b === 0x5C) { $j += 2; continue; }
                        if ($b === $inStr) { $inStr = 0; }
                        $j++; continue;
                    }
                    if ($b === 0x3B || $b === 0x7D) { break; }
                    if ($b === 0x2F && $j + 1 < $end && ($bs[$j + 1] === 0x2F || $bs[$j + 1] === 0x2A)) { break; }
                    if ($b === 0x27 || $b === 0x22) { $inStr = $b; $j++; continue; }
                    if ($b === 0x60) { $inTpl = 1; $j++; continue; }
                    $j++;
                }
                $this->result_pos = $j;
            }
        }

        $BalancedParenEnd {
            $>() {
                $i = $this->pos;
                $end = $this->scan_end;
                $bs = $this->bytes;

                if ($i >= $end || $bs[$i] !== 0x28) { $this->success = 0; return; }
                $depth = 0; $inStr = 0; $inTpl = 0;
                while ($i < $end) {
                    $b = $bs[$i];
                    if ($inTpl !== 0) { if ($b === 0x60) { $inTpl = 0; } if ($b === 0x5C) { $i += 2; continue; } $i++; continue; }
                    if ($inStr !== 0) { if ($b === 0x5C) { $i += 2; continue; } if ($b === $inStr) { $inStr = 0; } $i++; continue; }
                    if ($b === 0x27 || $b === 0x22) { $inStr = $b; $i++; }
                    elseif ($b === 0x60) { $inTpl = 1; $i++; }
                    elseif ($b === 0x28) { $depth++; $i++; }
                    elseif ($b === 0x29) { $depth--; $i++; if ($depth === 0) { $this->result_pos = $i; $this->success = 1; return; } }
                    else { $i++; }
                }
                $this->success = 0;
            }
        }

    domain:
        bytes = []
        pos = 0
        scan_end = 0
        result_pos = 0
        success = 1
}

function str_to_bytes(string $s): array {
    $bytes = [];
    for ($i = 0; $i < strlen($s); $i++) { $bytes[] = ord($s[$i]); }
    return $bytes;
}

$failures = 0;

$s1 = @@JavaScriptSyntaxSkipperFsm();
$inp1 = str_to_bytes("// hello\ncode");
$s1->setup($inp1, 0, count($inp1));
$s1->do_skip_comment();
if ($s1->get_success() !== 1 || $s1->get_result_pos() !== 8) {
    echo "FAIL 1: Skip line comment\n";
    $failures++;
}

$s2 = @@JavaScriptSyntaxSkipperFsm();
$inp2 = str_to_bytes("/* block */code");
$s2->setup($inp2, 0, count($inp2));
$s2->do_skip_comment();
if ($s2->get_success() !== 1 || $s2->get_result_pos() !== 11) {
    echo "FAIL 2: Skip block comment\n";
    $failures++;
}

$s3 = @@JavaScriptSyntaxSkipperFsm();
$inp3 = str_to_bytes("\"hello world\" rest");
$s3->setup($inp3, 0, count($inp3));
$s3->do_skip_string();
if ($s3->get_success() !== 1 || $s3->get_result_pos() !== 13) {
    echo "FAIL 3: Skip double-quoted string\n";
    $failures++;
}

$s4 = @@JavaScriptSyntaxSkipperFsm();
$inp4 = str_to_bytes('`template ${x}` rest');
$s4->setup($inp4, 0, count($inp4));
$s4->do_skip_string();
if ($s4->get_success() !== 1 || $s4->get_result_pos() !== 15) {
    echo "FAIL 4: Skip template literal\n";
    $failures++;
}

$s5 = @@JavaScriptSyntaxSkipperFsm();
$inp5 = str_to_bytes("x + 1\nmore");
$s5->setup($inp5, 0, count($inp5));
$s5->do_find_line_end();
if ($s5->get_result_pos() !== 5) {
    echo "FAIL 5: Find line end\n";
    $failures++;
}

$s6 = @@JavaScriptSyntaxSkipperFsm();
$inp6 = str_to_bytes("x + 1");
$s6->setup($inp6, 0, count($inp6));
$s6->do_skip_comment();
if ($s6->get_success() !== 0) {
    echo "FAIL 6: Not a comment\n";
    $failures++;
}

$s7 = @@JavaScriptSyntaxSkipperFsm();
$inp7 = str_to_bytes("(a, `t`, c) rest");
$s7->setup($inp7, 0, count($inp7));
$s7->do_balanced_paren_end();
if ($s7->get_success() !== 1 || $s7->get_result_pos() !== 11) {
    echo "FAIL 7: Balanced parens with template\n";
    $failures++;
}

$s8 = @@JavaScriptSyntaxSkipperFsm();
$inp8 = str_to_bytes("x + 1 // comment");
$s8->setup($inp8, 0, count($inp8));
$s8->do_find_line_end();
if ($s8->get_result_pos() !== 6) {
    echo "FAIL 8: Find line end at //\n";
    $failures++;
}

if ($failures > 0) { echo "FAIL: {$failures} failures\n"; exit(1); }
echo "PASS: javascript_skipper (8 cases)\n";

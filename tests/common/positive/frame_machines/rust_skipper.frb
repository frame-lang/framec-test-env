@@target ruby

# RustSyntaxSkipper — FSM for skipping Rust comments and strings.
# Translated from framec's native_region_scanner/rust_skipper.frs
#
# Handles: // line comments, /* nested block comments */,
# raw strings (r#"..."#), char literals vs lifetime annotations,
# simple strings.

@@system RustSyntaxSkipperFsm {
    operations:
        setup(input_bytes, start, length) {
            self.bytes = input_bytes
            self.pos = start
            self.scan_end = length
        }
        get_result_pos() {
            return self.result_pos
        }
        get_success() {
            return self.success
        }

    interface:
        do_skip_comment()
        do_skip_string()
        do_find_line_end()

    machine:
        $Init {
            do_skip_comment() { -> $SkipComment }
            do_skip_string() { -> $SkipString }
            do_find_line_end() { -> $FindLineEnd }
        }

        $SkipComment {
            $>() {
                i = self.pos
                the_end = self.scan_end
                bs = self.bytes

                # // line comment
                if i + 1 < the_end && bs[i] == 0x2F && bs[i + 1] == 0x2F
                    j = i + 2
                    while j < the_end && bs[j] != 0x0A
                        j += 1
                    end
                    self.result_pos = j
                    self.success = 1
                    return
                end

                # /* nested block comment */ — Rust allows nesting
                if i + 1 < the_end && bs[i] == 0x2F && bs[i + 1] == 0x2A
                    j = i + 2
                    depth = 1
                    while j + 1 < the_end && depth > 0
                        if bs[j] == 0x2F && bs[j + 1] == 0x2A
                            depth += 1
                            j += 2
                            next
                        end
                        if bs[j] == 0x2A && bs[j + 1] == 0x2F
                            depth -= 1
                            j += 2
                            next
                        end
                        j += 1
                    end
                    self.result_pos = j
                    self.success = 1
                    return
                end

                self.success = 0
            }
        }

        $SkipString {
            $>() {
                i = self.pos
                the_end = self.scan_end
                bs = self.bytes

                # Raw string: r#"..."# (count leading #s)
                if i < the_end && bs[i] == 0x72
                    j = i + 1
                    hash_count = 0
                    while j < the_end && bs[j] == 0x23
                        hash_count += 1
                        j += 1
                    end
                    if j < the_end && bs[j] == 0x22
                        j += 1
                        # Scan for closing "###
                        while j < the_end
                            if bs[j] == 0x22
                                k = 0
                                while k < hash_count && j + 1 + k < the_end && bs[j + 1 + k] == 0x23
                                    k += 1
                                end
                                if k == hash_count
                                    self.result_pos = j + 1 + hash_count
                                    self.success = 1
                                    return
                                end
                            end
                            j += 1
                        end
                        self.result_pos = the_end
                        self.success = 1
                        return
                    end
                end

                # Double-quoted string
                if i < the_end && bs[i] == 0x22
                    j = i + 1
                    while j < the_end
                        if bs[j] == 0x5C
                            j += 2
                            next
                        end
                        if bs[j] == 0x22
                            self.result_pos = j + 1
                            self.success = 1
                            return
                        end
                        j += 1
                    end
                    self.result_pos = the_end
                    self.success = 1
                    return
                end

                # Char literal: 'x' or '\n' (NOT lifetime 'a)
                if i < the_end && bs[i] == 0x27
                    if i + 2 < the_end && bs[i + 1] == 0x5C && i + 3 < the_end && bs[i + 3] == 0x27
                        self.result_pos = i + 4
                        self.success = 1
                        return
                    end
                    if i + 2 < the_end && bs[i + 2] == 0x27
                        self.result_pos = i + 3
                        self.success = 1
                        return
                    end
                    self.success = 0
                    return
                end

                self.success = 0
            }
        }

        $FindLineEnd {
            $>() {
                j = self.pos
                the_end = self.scan_end
                bs = self.bytes

                while j < the_end
                    b = bs[j]
                    if b == 0x0A || b == 0x3B
                        break
                    end
                    if b == 0x2F && j + 1 < the_end && bs[j + 1] == 0x2F
                        break
                    end
                    if b == 0x2F && j + 1 < the_end && bs[j + 1] == 0x2A
                        break
                    end
                    j += 1
                end

                self.result_pos = j
            }
        }

    domain:
        bytes = []
        pos: int = 0
        scan_end: int = 0
        result_pos: int = 0
        success: int = 1
}

failures = 0

# Test 1: Skip // comment
s1 = RustSyntaxSkipperFsm.new
inp1 = "// comment\ncode".bytes
s1.setup(inp1, 0, inp1.length)
s1.do_skip_comment()
if s1.get_success() != 1 || s1.get_result_pos() != 10
    puts("FAIL 1: success=#{s1.get_success()}, pos=#{s1.get_result_pos()}")
    failures += 1
end

# Test 2: Skip nested /* /* */ */ block comment
s2 = RustSyntaxSkipperFsm.new
inp2 = "/* outer /* inner */ */code".bytes
s2.setup(inp2, 0, inp2.length)
s2.do_skip_comment()
if s2.get_success() != 1 || s2.get_result_pos() != 23
    puts("FAIL 2: success=#{s2.get_success()}, pos=#{s2.get_result_pos()}")
    failures += 1
end

# Test 3: Skip raw string r#"hello"#
s3 = RustSyntaxSkipperFsm.new
inp3 = "r#\"hello\"#rest".bytes
s3.setup(inp3, 0, inp3.length)
s3.do_skip_string()
if s3.get_success() != 1 || s3.get_result_pos() != 10
    puts("FAIL 3: success=#{s3.get_success()}, pos=#{s3.get_result_pos()}")
    failures += 1
end

# Test 4: Skip double-quoted string
s4 = RustSyntaxSkipperFsm.new
inp4 = "\"hello\" rest".bytes
s4.setup(inp4, 0, inp4.length)
s4.do_skip_string()
if s4.get_success() != 1 || s4.get_result_pos() != 7
    puts("FAIL 4: success=#{s4.get_success()}, pos=#{s4.get_result_pos()}")
    failures += 1
end

# Test 5: Char literal 'x' — IS a string
s5 = RustSyntaxSkipperFsm.new
inp5 = "'x' rest".bytes
s5.setup(inp5, 0, inp5.length)
s5.do_skip_string()
if s5.get_success() != 1 || s5.get_result_pos() != 3
    puts("FAIL 5: success=#{s5.get_success()}, pos=#{s5.get_result_pos()}")
    failures += 1
end

# Test 6: Lifetime 'a — NOT a string
s6 = RustSyntaxSkipperFsm.new
inp6 = "'a rest".bytes
s6.setup(inp6, 0, inp6.length)
s6.do_skip_string()
if s6.get_success() != 0
    puts("FAIL 6: lifetime should not be a string")
    failures += 1
end

# Test 7: Escape char '\n'
s7 = RustSyntaxSkipperFsm.new
inp7 = "'\\n' rest".bytes
s7.setup(inp7, 0, inp7.length)
s7.do_skip_string()
if s7.get_success() != 1 || s7.get_result_pos() != 4
    puts("FAIL 7: success=#{s7.get_success()}, pos=#{s7.get_result_pos()}")
    failures += 1
end

if failures > 0
    puts("FAIL: #{failures} failures")
    exit(1)
end
puts("PASS: rust_skipper (7 cases)")

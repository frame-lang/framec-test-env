@@[target("c")]

#include <string.h>

// PythonSyntaxSkipper — FSM for skipping Python comments and strings.
// Translated from framec's native_region_scanner/python_skipper.frs
//
// Handles: # comments, triple-quoted strings, simple strings,
// Python-style line endings, balanced parens.

@@system PythonSyntaxSkipperFsm {
    operations:
        setup(input_bytes: unsigned char*, start: int, length: int) {
            self->bytes = input_bytes;
            self->pos = start;
            self->scan_end = length;
        }
        get_result_pos(): int {
            return self->result_pos;
        }
        get_success(): int {
            return self->success;
        }

    interface:
        do_skip_comment()
        do_skip_string()
        do_find_line_end()
        do_balanced_paren_end()

    machine:
        $Init {
            do_skip_comment() { -> $SkipComment }
            do_skip_string() { -> $SkipString }
            do_find_line_end() { -> $FindLineEnd }
            do_balanced_paren_end() { -> $BalancedParenEnd }
        }

        $SkipComment {
            $>() {
                int i = self->pos;
                int end = self->scan_end;
                unsigned char* bs = self->bytes;

                // Python uses # for line comments
                if (i < end && bs[i] == '#') {
                    int j = i + 1;
                    while (j < end && bs[j] != '\n') {
                        j++;
                    }
                    self->result_pos = j;
                    self->success = 1;
                    return;
                }

                self->success = 0;
            }
        }

        $SkipString {
            $>() {
                int i = self->pos;
                int end = self->scan_end;
                unsigned char* bs = self->bytes;

                // Triple-quoted strings: """ or '''
                if (i + 2 < end) {
                    if ((bs[i] == '"' && bs[i+1] == '"' && bs[i+2] == '"') ||
                        (bs[i] == '\'' && bs[i+1] == '\'' && bs[i+2] == '\'')) {
                        char q = bs[i];
                        int j = i + 3;
                        while (j + 2 < end) {
                            if (bs[j] == q && bs[j+1] == q && bs[j+2] == q) {
                                self->result_pos = j + 3;
                                self->success = 1;
                                return;
                            }
                            j++;
                        }
                        self->result_pos = end;
                        self->success = 1;
                        return;
                    }
                }

                // Simple strings: " or '
                if (i < end && (bs[i] == '"' || bs[i] == '\'')) {
                    char q = bs[i];
                    int j = i + 1;
                    while (j < end) {
                        if (bs[j] == '\\') {
                            j += 2;
                            continue;
                        }
                        if (bs[j] == q) {
                            self->result_pos = j + 1;
                            self->success = 1;
                            return;
                        }
                        j++;
                    }
                    self->result_pos = end;
                    self->success = 1;
                    return;
                }

                self->success = 0;
            }
        }

        $FindLineEnd {
            $>() {
                int j = self->pos;
                int end = self->scan_end;
                unsigned char* bs = self->bytes;

                while (j < end) {
                    char b = bs[j];
                    if (b == '\n' || b == ';') {
                        break;
                    }
                    // Stop at # comment
                    if (b == '#') {
                        break;
                    }
                    j++;
                }

                self->result_pos = j;
            }
        }

        $BalancedParenEnd {
            $>() {
                int i = self->pos;
                int end = self->scan_end;
                unsigned char* bs = self->bytes;

                if (i >= end || bs[i] != '(') {
                    self->success = 0;
                    return;
                }

                int depth = 1;
                int j = i + 1;
                while (j < end && depth > 0) {
                    char b = bs[j];
                    if (b == '(') {
                        depth++;
                    } else if (b == ')') {
                        depth--;
                    } else if (b == '"' || b == '\'') {
                        char q = b;
                        j++;
                        while (j < end && bs[j] != q) {
                            if (bs[j] == '\\') {
                                j++;
                            }
                            j++;
                        }
                    }
                    j++;
                }

                if (depth == 0) {
                    self->result_pos = j;
                    self->success = 1;
                } else {
                    self->result_pos = end;
                    self->success = 0;
                }
            }
        }

    domain:
        bytes: unsigned char* = NULL
        pos: int = 0
        scan_end: int = 0
        result_pos: int = 0
        success: int = 1
}

int main() {
    int failures = 0;

    // Test 1: Skip hash comment
    PythonSyntaxSkipperFsm* s1 = @@PythonSyntaxSkipperFsm();
    unsigned char t1[] = "# comment\ncode";
    PythonSyntaxSkipperFsm_setup(s1, t1, 0, strlen((char*)t1));
    PythonSyntaxSkipperFsm_do_skip_comment(s1);
    if (PythonSyntaxSkipperFsm_get_success(s1) != 1 || PythonSyntaxSkipperFsm_get_result_pos(s1) != 9) {
        printf("FAIL 1: success=%d, pos=%d\n", PythonSyntaxSkipperFsm_get_success(s1), PythonSyntaxSkipperFsm_get_result_pos(s1));
        failures++;
    }

    // Test 2: Not a comment
    PythonSyntaxSkipperFsm* s2 = @@PythonSyntaxSkipperFsm();
    unsigned char t2[] = "x + 1";
    PythonSyntaxSkipperFsm_setup(s2, t2, 0, strlen((char*)t2));
    PythonSyntaxSkipperFsm_do_skip_comment(s2);
    if (PythonSyntaxSkipperFsm_get_success(s2) != 0) {
        printf("FAIL 2: should not be comment\n");
        failures++;
    }

    // Test 3: Skip triple-quoted string
    PythonSyntaxSkipperFsm* s3 = @@PythonSyntaxSkipperFsm();
    unsigned char t3[] = "\"\"\"hello world\"\"\"rest";
    PythonSyntaxSkipperFsm_setup(s3, t3, 0, strlen((char*)t3));
    PythonSyntaxSkipperFsm_do_skip_string(s3);
    if (PythonSyntaxSkipperFsm_get_success(s3) != 1 || PythonSyntaxSkipperFsm_get_result_pos(s3) != 17) {
        printf("FAIL 3: success=%d, pos=%d\n", PythonSyntaxSkipperFsm_get_success(s3), PythonSyntaxSkipperFsm_get_result_pos(s3));
        failures++;
    }

    // Test 4: Skip simple string
    PythonSyntaxSkipperFsm* s4 = @@PythonSyntaxSkipperFsm();
    unsigned char t4[] = "\"hello\" rest";
    PythonSyntaxSkipperFsm_setup(s4, t4, 0, strlen((char*)t4));
    PythonSyntaxSkipperFsm_do_skip_string(s4);
    if (PythonSyntaxSkipperFsm_get_success(s4) != 1 || PythonSyntaxSkipperFsm_get_result_pos(s4) != 7) {
        printf("FAIL 4: success=%d, pos=%d\n", PythonSyntaxSkipperFsm_get_success(s4), PythonSyntaxSkipperFsm_get_result_pos(s4));
        failures++;
    }

    // Test 5: Skip string with escape
    PythonSyntaxSkipperFsm* s5 = @@PythonSyntaxSkipperFsm();
    unsigned char t5[] = "'he\\'llo' rest";
    PythonSyntaxSkipperFsm_setup(s5, t5, 0, strlen((char*)t5));
    PythonSyntaxSkipperFsm_do_skip_string(s5);
    if (PythonSyntaxSkipperFsm_get_success(s5) != 1 || PythonSyntaxSkipperFsm_get_result_pos(s5) != 9) {
        printf("FAIL 5: success=%d, pos=%d\n", PythonSyntaxSkipperFsm_get_success(s5), PythonSyntaxSkipperFsm_get_result_pos(s5));
        failures++;
    }

    // Test 6: Find line end (stops at #)
    PythonSyntaxSkipperFsm* s6 = @@PythonSyntaxSkipperFsm();
    unsigned char t6[] = "x + 1 # comment";
    PythonSyntaxSkipperFsm_setup(s6, t6, 0, strlen((char*)t6));
    PythonSyntaxSkipperFsm_do_find_line_end(s6);
    if (PythonSyntaxSkipperFsm_get_result_pos(s6) != 6) {
        printf("FAIL 6: pos=%d, expected 6\n", PythonSyntaxSkipperFsm_get_result_pos(s6));
        failures++;
    }

    // Test 7: Balanced parens
    PythonSyntaxSkipperFsm* s7 = @@PythonSyntaxSkipperFsm();
    unsigned char t7[] = "(a, f(b)) rest";
    PythonSyntaxSkipperFsm_setup(s7, t7, 0, strlen((char*)t7));
    PythonSyntaxSkipperFsm_do_balanced_paren_end(s7);
    if (PythonSyntaxSkipperFsm_get_success(s7) != 1 || PythonSyntaxSkipperFsm_get_result_pos(s7) != 9) {
        printf("FAIL 7: success=%d, pos=%d\n", PythonSyntaxSkipperFsm_get_success(s7), PythonSyntaxSkipperFsm_get_result_pos(s7));
        failures++;
    }

    PythonSyntaxSkipperFsm_destroy(s1);
    PythonSyntaxSkipperFsm_destroy(s2);
    PythonSyntaxSkipperFsm_destroy(s3);
    PythonSyntaxSkipperFsm_destroy(s4);
    PythonSyntaxSkipperFsm_destroy(s5);
    PythonSyntaxSkipperFsm_destroy(s6);
    PythonSyntaxSkipperFsm_destroy(s7);

    if (failures > 0) {
        printf("FAIL: %d failures\n", failures);
        return 1;
    }
    printf("PASS: python_skipper (7 cases)\n");
    return 0;
}

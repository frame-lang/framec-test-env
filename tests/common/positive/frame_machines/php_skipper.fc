@@target c

#include <string.h>

// PhpSyntaxSkipper -- FSM for skipping PHP comments and strings.
// Translated from framec's native_region_scanner/php_skipper.frs
//
// Handles: // line comments, # line comments, /* */ block comments,
// "..." and '...' strings, <<<EOT heredoc/nowdoc,
// PHP-style line endings, balanced parens.

@@system PhpSyntaxSkipperFsm {
    operations:
        setup(input_bytes: unsigned char*, start: int, length: int) {
            self->bytes = input_bytes;
            self->pos = start;
            self->scan_end = length;
        }
        get_result_pos(): int {
            return self->result_pos;
        }
        get_success(): int {
            return self->success;
        }

    interface:
        do_skip_comment()
        do_skip_string()
        do_find_line_end()
        do_balanced_paren_end()

    machine:
        $Init {
            do_skip_comment() { -> $SkipComment }
            do_skip_string() { -> $SkipString }
            do_find_line_end() { -> $FindLineEnd }
            do_balanced_paren_end() { -> $BalancedParenEnd }
        }

        $SkipComment {
            $>() {
                int i = self->pos;
                int end = self->scan_end;
                unsigned char* bs = self->bytes;

                // Line comment: //
                if (i + 1 < end && bs[i] == '/' && bs[i + 1] == '/') {
                    int j = i + 2;
                    while (j < end && bs[j] != '\n') {
                        j++;
                    }
                    self->result_pos = j;
                    self->success = 1;
                    return;
                }

                // Hash comment: #
                if (i < end && bs[i] == '#') {
                    int j = i + 1;
                    while (j < end && bs[j] != '\n') {
                        j++;
                    }
                    self->result_pos = j;
                    self->success = 1;
                    return;
                }

                // Block comment: /* ... */
                if (i + 1 < end && bs[i] == '/' && bs[i + 1] == '*') {
                    int j = i + 2;
                    while (j + 1 < end) {
                        if (bs[j] == '*' && bs[j + 1] == '/') {
                            self->result_pos = j + 2;
                            self->success = 1;
                            return;
                        }
                        j++;
                    }
                    self->result_pos = end;
                    self->success = 1;
                    return;
                }

                self->success = 0;
            }
        }

        $SkipString {
            $>() {
                int i = self->pos;
                int end = self->scan_end;
                unsigned char* bs = self->bytes;

                // Heredoc/nowdoc: <<<EOT ... EOT;
                if (i + 2 < end && bs[i] == '<' && bs[i + 1] == '<' && bs[i + 2] == '<') {
                    int j = i + 3;
                    // Skip optional quote for nowdoc
                    int nowdoc = 0;
                    if (j < end && bs[j] == '\'') {
                        nowdoc = 1;
                        j++;
                    }
                    // Read tag name
                    int tag_start = j;
                    while (j < end && ((bs[j] >= 'a' && bs[j] <= 'z') || (bs[j] >= 'A' && bs[j] <= 'Z') || (bs[j] >= '0' && bs[j] <= '9') || bs[j] == '_')) {
                        j++;
                    }
                    int tag_end = j;
                    if (nowdoc && j < end && bs[j] == '\'') {
                        j++;
                    }
                    int tag_len = tag_end - tag_start;
                    if (tag_len > 0) {
                        // Skip to newline
                        while (j < end && bs[j] != '\n') {
                            j++;
                        }
                        if (j < end) {
                            j++;
                        }
                        // Scan for closing tag at start of line
                        while (j < end) {
                            // Check if this line starts with the tag
                            if (j + tag_len <= end && memcmp(bs + j, bs + tag_start, tag_len) == 0) {
                                int k = j + tag_len;
                                // Optional ; and newline
                                if (k < end && bs[k] == ';') {
                                    k++;
                                }
                                if (k >= end || bs[k] == '\n') {
                                    if (k < end && bs[k] == '\n') {
                                        k++;
                                    }
                                    self->result_pos = k;
                                    self->success = 1;
                                    return;
                                }
                            }
                            // Skip to next line
                            while (j < end && bs[j] != '\n') {
                                j++;
                            }
                            if (j < end) {
                                j++;
                            }
                        }
                        self->result_pos = end;
                        self->success = 1;
                        return;
                    }
                }

                // Simple string: " or '
                if (i < end && (bs[i] == '"' || bs[i] == '\'')) {
                    unsigned char q = bs[i];
                    int j = i + 1;
                    while (j < end) {
                        if (bs[j] == '\\') {
                            j += 2;
                            continue;
                        }
                        if (bs[j] == q) {
                            self->result_pos = j + 1;
                            self->success = 1;
                            return;
                        }
                        j++;
                    }
                    self->result_pos = end;
                    self->success = 1;
                    return;
                }

                self->success = 0;
            }
        }

        $FindLineEnd {
            $>() {
                int j = self->pos;
                int end = self->scan_end;
                unsigned char* bs = self->bytes;
                int in_string = 0;

                while (j < end) {
                    unsigned char b = bs[j];
                    if (b == '\n') {
                        break;
                    }

                    // Inside string
                    if (in_string != 0) {
                        if (b == '\\') {
                            j += 2;
                            continue;
                        }
                        if (b == in_string) {
                            in_string = 0;
                        }
                        j++;
                        continue;
                    }

                    // Terminators
                    if (b == ';' || b == '}') {
                        break;
                    }
                    if (b == '/' && j + 1 < end && (bs[j + 1] == '/' || bs[j + 1] == '*')) {
                        break;
                    }
                    if (b == '#') {
                        break;
                    }

                    // String starts
                    if (b == '\'' || b == '"') {
                        in_string = b;
                        j++;
                        continue;
                    }

                    j++;
                }

                self->result_pos = j;
            }
        }

        $BalancedParenEnd {
            $>() {
                int i = self->pos;
                int end = self->scan_end;
                unsigned char* bs = self->bytes;

                if (i >= end || bs[i] != '(') {
                    self->success = 0;
                    return;
                }

                int depth = 0;
                int in_string = 0;

                while (i < end) {
                    unsigned char b = bs[i];

                    // Inside string
                    if (in_string != 0) {
                        if (b == '\\') {
                            i += 2;
                            continue;
                        }
                        if (b == in_string) {
                            in_string = 0;
                        }
                        i++;
                        continue;
                    }

                    if (b == '\'' || b == '"') {
                        in_string = b;
                        i++;
                    } else if (b == '(') {
                        depth++;
                        i++;
                    } else if (b == ')') {
                        depth--;
                        i++;
                        if (depth == 0) {
                            self->result_pos = i;
                            self->success = 1;
                            return;
                        }
                    } else {
                        i++;
                    }
                }

                self->success = 0;
            }
        }

    domain:
        bytes: unsigned char* = NULL
        pos: int = 0
        scan_end: int = 0
        result_pos: int = 0
        success: int = 1
}

int main() {
    int failures = 0;

    // Test 1: Skip // line comment
    PhpSyntaxSkipperFsm* s1 = @@PhpSyntaxSkipperFsm();
    unsigned char t1[] = "// comment\ncode";
    PhpSyntaxSkipperFsm_setup(s1, t1, 0, sizeof(t1)-1);
    PhpSyntaxSkipperFsm_do_skip_comment(s1);
    if (PhpSyntaxSkipperFsm_get_success(s1) != 1 || PhpSyntaxSkipperFsm_get_result_pos(s1) != 10) {
        printf("FAIL 1: success=%d, pos=%d\n", PhpSyntaxSkipperFsm_get_success(s1), PhpSyntaxSkipperFsm_get_result_pos(s1));
        failures++;
    }

    // Test 2: Skip # comment
    PhpSyntaxSkipperFsm* s2 = @@PhpSyntaxSkipperFsm();
    unsigned char t2[] = "# comment\ncode";
    PhpSyntaxSkipperFsm_setup(s2, t2, 0, sizeof(t2)-1);
    PhpSyntaxSkipperFsm_do_skip_comment(s2);
    if (PhpSyntaxSkipperFsm_get_success(s2) != 1 || PhpSyntaxSkipperFsm_get_result_pos(s2) != 9) {
        printf("FAIL 2: success=%d, pos=%d\n", PhpSyntaxSkipperFsm_get_success(s2), PhpSyntaxSkipperFsm_get_result_pos(s2));
        failures++;
    }

    // Test 3: Skip /* */ block comment
    PhpSyntaxSkipperFsm* s3 = @@PhpSyntaxSkipperFsm();
    unsigned char t3[] = "/* block */code";
    PhpSyntaxSkipperFsm_setup(s3, t3, 0, sizeof(t3)-1);
    PhpSyntaxSkipperFsm_do_skip_comment(s3);
    if (PhpSyntaxSkipperFsm_get_success(s3) != 1 || PhpSyntaxSkipperFsm_get_result_pos(s3) != 11) {
        printf("FAIL 3: success=%d, pos=%d\n", PhpSyntaxSkipperFsm_get_success(s3), PhpSyntaxSkipperFsm_get_result_pos(s3));
        failures++;
    }

    // Test 4: Skip double-quoted string
    PhpSyntaxSkipperFsm* s4 = @@PhpSyntaxSkipperFsm();
    unsigned char t4[] = "\"hello\" rest";
    PhpSyntaxSkipperFsm_setup(s4, t4, 0, sizeof(t4)-1);
    PhpSyntaxSkipperFsm_do_skip_string(s4);
    if (PhpSyntaxSkipperFsm_get_success(s4) != 1 || PhpSyntaxSkipperFsm_get_result_pos(s4) != 7) {
        printf("FAIL 4: success=%d, pos=%d\n", PhpSyntaxSkipperFsm_get_success(s4), PhpSyntaxSkipperFsm_get_result_pos(s4));
        failures++;
    }

    // Test 5: Skip single-quoted string
    PhpSyntaxSkipperFsm* s5 = @@PhpSyntaxSkipperFsm();
    unsigned char t5[] = "'hello' rest";
    PhpSyntaxSkipperFsm_setup(s5, t5, 0, sizeof(t5)-1);
    PhpSyntaxSkipperFsm_do_skip_string(s5);
    if (PhpSyntaxSkipperFsm_get_success(s5) != 1 || PhpSyntaxSkipperFsm_get_result_pos(s5) != 7) {
        printf("FAIL 5: success=%d, pos=%d\n", PhpSyntaxSkipperFsm_get_success(s5), PhpSyntaxSkipperFsm_get_result_pos(s5));
        failures++;
    }

    // Test 6: Skip heredoc
    PhpSyntaxSkipperFsm* s6 = @@PhpSyntaxSkipperFsm();
    unsigned char t6[] = "<<<EOT\nhello world\nEOT;\nnext";
    PhpSyntaxSkipperFsm_setup(s6, t6, 0, sizeof(t6)-1);
    PhpSyntaxSkipperFsm_do_skip_string(s6);
    if (PhpSyntaxSkipperFsm_get_success(s6) != 1 || PhpSyntaxSkipperFsm_get_result_pos(s6) != 24) {
        printf("FAIL 6: success=%d, pos=%d\n", PhpSyntaxSkipperFsm_get_success(s6), PhpSyntaxSkipperFsm_get_result_pos(s6));
        failures++;
    }

    // Test 7: Find line end (stops at ;)
    PhpSyntaxSkipperFsm* s7 = @@PhpSyntaxSkipperFsm();
    unsigned char t7[] = "$x = 1; next";
    PhpSyntaxSkipperFsm_setup(s7, t7, 0, sizeof(t7)-1);
    PhpSyntaxSkipperFsm_do_find_line_end(s7);
    if (PhpSyntaxSkipperFsm_get_result_pos(s7) != 6) {
        printf("FAIL 7: pos=%d, expected 6\n", PhpSyntaxSkipperFsm_get_result_pos(s7));
        failures++;
    }

    // Test 8: Balanced parens
    PhpSyntaxSkipperFsm* s8 = @@PhpSyntaxSkipperFsm();
    unsigned char t8[] = "(a, f(b)) rest";
    PhpSyntaxSkipperFsm_setup(s8, t8, 0, sizeof(t8)-1);
    PhpSyntaxSkipperFsm_do_balanced_paren_end(s8);
    if (PhpSyntaxSkipperFsm_get_success(s8) != 1 || PhpSyntaxSkipperFsm_get_result_pos(s8) != 9) {
        printf("FAIL 8: success=%d, pos=%d\n", PhpSyntaxSkipperFsm_get_success(s8), PhpSyntaxSkipperFsm_get_result_pos(s8));
        failures++;
    }

    PhpSyntaxSkipperFsm_destroy(s1);
    PhpSyntaxSkipperFsm_destroy(s2);
    PhpSyntaxSkipperFsm_destroy(s3);
    PhpSyntaxSkipperFsm_destroy(s4);
    PhpSyntaxSkipperFsm_destroy(s5);
    PhpSyntaxSkipperFsm_destroy(s6);
    PhpSyntaxSkipperFsm_destroy(s7);
    PhpSyntaxSkipperFsm_destroy(s8);

    if (failures > 0) {
        printf("FAIL: %d failures\n", failures);
        return 1;
    }
    printf("PASS: php_skipper (8 cases)\n");
    return 0;
}

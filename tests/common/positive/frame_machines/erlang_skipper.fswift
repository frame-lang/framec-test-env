@@[target("swift")]

import Foundation

// ErlangSyntaxSkipper -- FSM for skipping Erlang comments and strings.
// Translated from framec's native_region_scanner/erlang_skipper.frs
//
// Handles: % line comments, "..." strings, '...' quoted atoms,
// Erlang-style line endings, balanced parens.

@@system ErlangSyntaxSkipperFsm {
    operations:
        setup(input_bytes: [UInt8], start: Int, length: Int) {
            self.bytes = input_bytes
            self.pos = start
            self.scan_end = length
        }
        get_result_pos(): Int {
            return self.result_pos
        }
        get_success(): Int {
            return self.success
        }

    interface:
        do_skip_comment()
        do_skip_string()
        do_find_line_end()
        do_balanced_paren_end()

    machine:
        $Init {
            do_skip_comment() { -> $SkipComment }
            do_skip_string() { -> $SkipString }
            do_find_line_end() { -> $FindLineEnd }
            do_balanced_paren_end() { -> $BalancedParenEnd }
        }

        $SkipComment {
            $>() {
                var i = self.pos
                let end = self.scan_end
                let bs = self.bytes

                // Erlang: % line comment only
                if i < end && bs[i] == 0x25 {
                    var j = i + 1
                    while j < end && bs[j] != 0x0A {
                        j += 1
                    }
                    self.result_pos = j
                    self.success = 1
                    return
                }

                self.success = 0
            }
        }

        $SkipString {
            $>() {
                var i = self.pos
                let end = self.scan_end
                let bs = self.bytes

                // Simple string: "..."
                if i < end && bs[i] == 0x22 {
                    var j = i + 1
                    while j < end {
                        if bs[j] == 0x5C {
                            j += 2
                            continue
                        }
                        if bs[j] == 0x22 {
                            self.result_pos = j + 1
                            self.success = 1
                            return
                        }
                        j += 1
                    }
                    self.result_pos = end
                    self.success = 1
                    return
                }

                // Quoted atoms: '...'
                if i < end && bs[i] == 0x27 {
                    var j = i + 1
                    while j < end {
                        if bs[j] == 0x5C {
                            j += 2
                            continue
                        }
                        if bs[j] == 0x27 {
                            self.result_pos = j + 1
                            self.success = 1
                            return
                        }
                        j += 1
                    }
                    self.result_pos = end
                    self.success = 1
                    return
                }

                self.success = 0
            }
        }

        $FindLineEnd {
            $>() {
                var j = self.pos
                let end = self.scan_end
                let bs = self.bytes
                var in_string: UInt8 = 0

                while j < end {
                    let b = bs[j]
                    if b == 0x0A {
                        break
                    }

                    // Inside string
                    if in_string != 0 {
                        if b == 0x5C {
                            j += 2
                            continue
                        }
                        if b == in_string {
                            in_string = 0
                        }
                        j += 1
                        continue
                    }

                    // Terminators
                    if b == 0x25 {
                        break
                    }

                    // String starts
                    if b == 0x22 || b == 0x27 {
                        in_string = b
                        j += 1
                        continue
                    }

                    j += 1
                }

                self.result_pos = j
            }
        }

        $BalancedParenEnd {
            $>() {
                var i = self.pos
                let end = self.scan_end
                let bs = self.bytes

                if i >= end || bs[i] != 0x28 {
                    self.success = 0
                    return
                }

                var depth = 0
                var in_string: UInt8 = 0

                while i < end {
                    let b = bs[i]

                    // Inside string
                    if in_string != 0 {
                        if b == 0x5C {
                            i += 2
                            continue
                        }
                        if b == in_string {
                            in_string = 0
                        }
                        i += 1
                        continue
                    }

                    if b == 0x27 || b == 0x22 {
                        in_string = b
                        i += 1
                    } else if b == 0x28 {
                        depth += 1
                        i += 1
                    } else if b == 0x29 {
                        depth -= 1
                        i += 1
                        if depth == 0 {
                            self.result_pos = i
                            self.success = 1
                            return
                        }
                    } else {
                        i += 1
                    }
                }

                self.success = 0
            }
        }

    domain:
        bytes: [UInt8] = []
        pos: Int = 0
        scan_end: Int = 0
        result_pos: Int = 0
        success: Int = 1
}

// main
    var failures = 0

    // Test 1: Skip % comment
    let s1 = @@ErlangSyntaxSkipperFsm()
    let inp1: [UInt8] = Array("% comment\ncode".utf8)
    s1.setup(inp1, 0, inp1.count)
    s1.do_skip_comment()
    if s1.get_success() != 1 || s1.get_result_pos() != 9 {
        print("FAIL 1: success=\(s1.get_success()), pos=\(s1.get_result_pos())")
        failures += 1
    }

    // Test 2: Not a comment
    let s2 = @@ErlangSyntaxSkipperFsm()
    let inp2: [UInt8] = Array("x + 1".utf8)
    s2.setup(inp2, 0, inp2.count)
    s2.do_skip_comment()
    if s2.get_success() != 0 {
        print("FAIL 2: should not be comment")
        failures += 1
    }

    // Test 3: Skip double-quoted string
    let s3 = @@ErlangSyntaxSkipperFsm()
    let inp3: [UInt8] = Array("\"hello\" rest".utf8)
    s3.setup(inp3, 0, inp3.count)
    s3.do_skip_string()
    if s3.get_success() != 1 || s3.get_result_pos() != 7 {
        print("FAIL 3: success=\(s3.get_success()), pos=\(s3.get_result_pos())")
        failures += 1
    }

    // Test 4: Skip quoted atom
    let s4 = @@ErlangSyntaxSkipperFsm()
    let inp4: [UInt8] = Array("'my_atom' rest".utf8)
    s4.setup(inp4, 0, inp4.count)
    s4.do_skip_string()
    if s4.get_success() != 1 || s4.get_result_pos() != 9 {
        print("FAIL 4: success=\(s4.get_success()), pos=\(s4.get_result_pos())")
        failures += 1
    }

    // Test 5: Find line end (stops at %)
    let s5 = @@ErlangSyntaxSkipperFsm()
    let inp5: [UInt8] = Array("X + 1 % comment".utf8)
    s5.setup(inp5, 0, inp5.count)
    s5.do_find_line_end()
    if s5.get_result_pos() != 6 {
        print("FAIL 5: pos=\(s5.get_result_pos()), expected 6")
        failures += 1
    }

    // Test 6: Balanced parens
    let s6 = @@ErlangSyntaxSkipperFsm()
    let inp6: [UInt8] = Array("(a, f(b)) rest".utf8)
    s6.setup(inp6, 0, inp6.count)
    s6.do_balanced_paren_end()
    if s6.get_success() != 1 || s6.get_result_pos() != 9 {
        print("FAIL 6: success=\(s6.get_success()), pos=\(s6.get_result_pos())")
        failures += 1
    }

    // Test 7: String with escape
    let s7 = @@ErlangSyntaxSkipperFsm()
    let inp7: [UInt8] = Array("\"he\\\"llo\" rest".utf8)
    s7.setup(inp7, 0, inp7.count)
    s7.do_skip_string()
    if s7.get_success() != 1 || s7.get_result_pos() != 9 {
        print("FAIL 7: success=\(s7.get_success()), pos=\(s7.get_result_pos())")
        failures += 1
    }

    if failures > 0 {
        print("FAIL: \(failures) failures")
        exit(1)
    }
    print("PASS: erlang_skipper (7 cases)")

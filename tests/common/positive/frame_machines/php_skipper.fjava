@@[target("java")]

// PhpSyntaxSkipper -- FSM for skipping PHP comments and strings.
// Translated from framec's native_region_scanner/php_skipper.frs
//
// Handles: // line comments, # line comments, /* */ block comments,
// "..." and '...' strings, <<<EOT heredoc/nowdoc,
// PHP-style line endings, balanced parens.

@@system PhpSyntaxSkipperFsm {
    operations:
        setup(input_bytes: byte[], start: int, length: int) {
            this.bytes = input_bytes;
            this.pos = start;
            this.scan_end = length;
        }
        get_result_pos(): int {
            return this.result_pos;
        }
        get_success(): int {
            return this.success;
        }

    interface:
        do_skip_comment()
        do_skip_string()
        do_find_line_end()
        do_balanced_paren_end()

    machine:
        $Init {
            do_skip_comment() { -> $SkipComment }
            do_skip_string() { -> $SkipString }
            do_find_line_end() { -> $FindLineEnd }
            do_balanced_paren_end() { -> $BalancedParenEnd }
        }

        $SkipComment {
            $>() {
                int i = this.pos;
                int end = this.scan_end;
                byte[] bs = this.bytes;

                // Line comment: //
                if (i + 1 < end && (bs[i] & 0xFF) == '/' && (bs[i + 1] & 0xFF) == '/') {
                    int j = i + 2;
                    while (j < end && (bs[j] & 0xFF) != '\n') {
                        j++;
                    }
                    this.result_pos = j;
                    this.success = 1;
                    return;
                }

                // Hash comment: #
                if (i < end && (bs[i] & 0xFF) == '#') {
                    int j = i + 1;
                    while (j < end && (bs[j] & 0xFF) != '\n') {
                        j++;
                    }
                    this.result_pos = j;
                    this.success = 1;
                    return;
                }

                // Block comment: /* ... */
                if (i + 1 < end && (bs[i] & 0xFF) == '/' && (bs[i + 1] & 0xFF) == '*') {
                    int j = i + 2;
                    while (j + 1 < end) {
                        if ((bs[j] & 0xFF) == '*' && (bs[j + 1] & 0xFF) == '/') {
                            this.result_pos = j + 2;
                            this.success = 1;
                            return;
                        }
                        j++;
                    }
                    this.result_pos = end;
                    this.success = 1;
                    return;
                }

                this.success = 0;
            }
        }

        $SkipString {
            $>() {
                int i = this.pos;
                int end = this.scan_end;
                byte[] bs = this.bytes;

                // Heredoc/nowdoc: <<<EOT ... EOT;
                if (i + 2 < end && (bs[i] & 0xFF) == '<' && (bs[i + 1] & 0xFF) == '<' && (bs[i + 2] & 0xFF) == '<') {
                    int j = i + 3;
                    int nowdoc = 0;
                    if (j < end && (bs[j] & 0xFF) == '\'') {
                        nowdoc = 1;
                        j++;
                    }
                    int tag_start = j;
                    while (j < end && (Character.isLetterOrDigit((char)(bs[j] & 0xFF)) || (bs[j] & 0xFF) == '_')) {
                        j++;
                    }
                    int tag_end_pos = j;
                    if (nowdoc == 1 && j < end && (bs[j] & 0xFF) == '\'') {
                        j++;
                    }
                    int tag_len = tag_end_pos - tag_start;
                    if (tag_len > 0) {
                        while (j < end && (bs[j] & 0xFF) != '\n') {
                            j++;
                        }
                        if (j < end) {
                            j++;
                        }
                        while (j < end) {
                            boolean match = true;
                            if (j + tag_len <= end) {
                                for (int t = 0; t < tag_len; t++) {
                                    if (bs[j + t] != bs[tag_start + t]) {
                                        match = false;
                                        break;
                                    }
                                }
                            } else {
                                match = false;
                            }
                            if (match) {
                                int k = j + tag_len;
                                if (k < end && (bs[k] & 0xFF) == ';') {
                                    k++;
                                }
                                if (k >= end || (bs[k] & 0xFF) == '\n') {
                                    if (k < end && (bs[k] & 0xFF) == '\n') {
                                        k++;
                                    }
                                    this.result_pos = k;
                                    this.success = 1;
                                    return;
                                }
                            }
                            while (j < end && (bs[j] & 0xFF) != '\n') {
                                j++;
                            }
                            if (j < end) {
                                j++;
                            }
                        }
                        this.result_pos = end;
                        this.success = 1;
                        return;
                    }
                }

                // Simple string: " or '
                if (i < end && ((bs[i] & 0xFF) == '"' || (bs[i] & 0xFF) == '\'')) {
                    int q = bs[i] & 0xFF;
                    int j = i + 1;
                    while (j < end) {
                        if ((bs[j] & 0xFF) == '\\') {
                            j += 2;
                            continue;
                        }
                        if ((bs[j] & 0xFF) == q) {
                            this.result_pos = j + 1;
                            this.success = 1;
                            return;
                        }
                        j++;
                    }
                    this.result_pos = end;
                    this.success = 1;
                    return;
                }

                this.success = 0;
            }
        }

        $FindLineEnd {
            $>() {
                int j = this.pos;
                int end = this.scan_end;
                byte[] bs = this.bytes;
                int in_string = 0;

                while (j < end) {
                    int b = bs[j] & 0xFF;
                    if (b == '\n') {
                        break;
                    }

                    if (in_string != 0) {
                        if (b == '\\') {
                            j += 2;
                            continue;
                        }
                        if (b == in_string) {
                            in_string = 0;
                        }
                        j++;
                        continue;
                    }

                    if (b == ';' || b == '}') {
                        break;
                    }
                    if (b == '/' && j + 1 < end && ((bs[j + 1] & 0xFF) == '/' || (bs[j + 1] & 0xFF) == '*')) {
                        break;
                    }
                    if (b == '#') {
                        break;
                    }

                    if (b == '\'' || b == '"') {
                        in_string = b;
                        j++;
                        continue;
                    }

                    j++;
                }

                this.result_pos = j;
            }
        }

        $BalancedParenEnd {
            $>() {
                int i = this.pos;
                int end = this.scan_end;
                byte[] bs = this.bytes;

                if (i >= end || (bs[i] & 0xFF) != '(') {
                    this.success = 0;
                    return;
                }

                int depth = 0;
                int in_string = 0;

                while (i < end) {
                    int b = bs[i] & 0xFF;

                    if (in_string != 0) {
                        if (b == '\\') {
                            i += 2;
                            continue;
                        }
                        if (b == in_string) {
                            in_string = 0;
                        }
                        i++;
                        continue;
                    }

                    if (b == '\'' || b == '"') {
                        in_string = b;
                        i++;
                    } else if (b == '(') {
                        depth++;
                        i++;
                    } else if (b == ')') {
                        depth--;
                        i++;
                        if (depth == 0) {
                            this.result_pos = i;
                            this.success = 1;
                            return;
                        }
                    } else {
                        i++;
                    }
                }

                this.success = 0;
            }
        }

    domain:
        bytes: byte[] = null
        pos: int = 0
        scan_end: int = 0
        result_pos: int = 0
        success: int = 1
}

class Main {
    public static void main(String[] args) {
        int failures = 0;

        // Test 1: Skip // line comment
        PhpSyntaxSkipperFsm s1 = @@PhpSyntaxSkipperFsm();
        byte[] inp1 = "// comment\ncode".getBytes();
        s1.setup(inp1, 0, inp1.length);
        s1.do_skip_comment();
        if (s1.get_success() != 1 || s1.get_result_pos() != 10) {
            System.out.println("FAIL 1: success=" + s1.get_success() + ", pos=" + s1.get_result_pos());
            failures++;
        }

        // Test 2: Skip # comment
        PhpSyntaxSkipperFsm s2 = @@PhpSyntaxSkipperFsm();
        byte[] inp2 = "# comment\ncode".getBytes();
        s2.setup(inp2, 0, inp2.length);
        s2.do_skip_comment();
        if (s2.get_success() != 1 || s2.get_result_pos() != 9) {
            System.out.println("FAIL 2: success=" + s2.get_success() + ", pos=" + s2.get_result_pos());
            failures++;
        }

        // Test 3: Skip /* */ block comment
        PhpSyntaxSkipperFsm s3 = @@PhpSyntaxSkipperFsm();
        byte[] inp3 = "/* block */code".getBytes();
        s3.setup(inp3, 0, inp3.length);
        s3.do_skip_comment();
        if (s3.get_success() != 1 || s3.get_result_pos() != 11) {
            System.out.println("FAIL 3: success=" + s3.get_success() + ", pos=" + s3.get_result_pos());
            failures++;
        }

        // Test 4: Skip double-quoted string
        PhpSyntaxSkipperFsm s4 = @@PhpSyntaxSkipperFsm();
        byte[] inp4 = "\"hello\" rest".getBytes();
        s4.setup(inp4, 0, inp4.length);
        s4.do_skip_string();
        if (s4.get_success() != 1 || s4.get_result_pos() != 7) {
            System.out.println("FAIL 4: success=" + s4.get_success() + ", pos=" + s4.get_result_pos());
            failures++;
        }

        // Test 5: Skip single-quoted string
        PhpSyntaxSkipperFsm s5 = @@PhpSyntaxSkipperFsm();
        byte[] inp5 = "'hello' rest".getBytes();
        s5.setup(inp5, 0, inp5.length);
        s5.do_skip_string();
        if (s5.get_success() != 1 || s5.get_result_pos() != 7) {
            System.out.println("FAIL 5: success=" + s5.get_success() + ", pos=" + s5.get_result_pos());
            failures++;
        }

        // Test 6: Skip heredoc
        PhpSyntaxSkipperFsm s6 = @@PhpSyntaxSkipperFsm();
        byte[] inp6 = "<<<EOT\nhello world\nEOT;\nnext".getBytes();
        s6.setup(inp6, 0, inp6.length);
        s6.do_skip_string();
        if (s6.get_success() != 1 || s6.get_result_pos() != 24) {
            System.out.println("FAIL 6: success=" + s6.get_success() + ", pos=" + s6.get_result_pos());
            failures++;
        }

        // Test 7: Find line end (stops at ;)
        PhpSyntaxSkipperFsm s7 = @@PhpSyntaxSkipperFsm();
        byte[] inp7 = "$x = 1; next".getBytes();
        s7.setup(inp7, 0, inp7.length);
        s7.do_find_line_end();
        if (s7.get_result_pos() != 6) {
            System.out.println("FAIL 7: pos=" + s7.get_result_pos() + ", expected 6");
            failures++;
        }

        // Test 8: Balanced parens
        PhpSyntaxSkipperFsm s8 = @@PhpSyntaxSkipperFsm();
        byte[] inp8 = "(a, f(b)) rest".getBytes();
        s8.setup(inp8, 0, inp8.length);
        s8.do_balanced_paren_end();
        if (s8.get_success() != 1 || s8.get_result_pos() != 9) {
            System.out.println("FAIL 8: success=" + s8.get_success() + ", pos=" + s8.get_result_pos());
            failures++;
        }

        if (failures > 0) {
            System.out.println("FAIL: " + failures + " failures");
            System.exit(1);
        }
        System.out.println("PASS: php_skipper (8 cases)");
    }
}

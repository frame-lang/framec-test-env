@@[target("rust")]

// CSharpSyntaxSkipper -- FSM for skipping C# comments and strings.
// Translated from framec's native_region_scanner/csharp_skipper.frs
//
// Handles: // line comments, /* */ block comments, # preprocessor directives,
// "..." simple strings, @"..." verbatim strings, $"..." interpolated strings,
// $"""...""" raw strings, C-like line endings, balanced parens.

use std::collections::HashMap;

@@system CSharpSyntaxSkipperFsm {
    operations:
        setup(input_bytes: Vec<u8>, start: i64, length: i64) {
            self.bytes = input_bytes;
            self.pos = start;
            self.scan_end = length;
        }
        get_result_pos(): i64 {
            return self.result_pos;
        }
        get_success(): i64 {
            return self.success;
        }

    interface:
        do_skip_comment()
        do_skip_string()
        do_find_line_end()
        do_balanced_paren_end()

    machine:
        $Init {
            do_skip_comment() { -> $SkipComment }
            do_skip_string() { -> $SkipString }
            do_find_line_end() { -> $FindLineEnd }
            do_balanced_paren_end() { -> $BalancedParenEnd }
        }

        $SkipComment {
            $>() {
                let i = self.pos as usize;
                let end = self.scan_end as usize;
                let bs = &self.bytes;

                // Preprocessor directive: # ... newline
                if i < end && bs[i] == 0x23 {
                    let mut j = i + 1;
                    while j < end && bs[j] != 0x0A {
                        j += 1;
                    }
                    self.result_pos = j as i64;
                    self.success = 1;
                    return;
                }

                // Line comment: //
                if i + 1 < end && bs[i] == 0x2F && bs[i + 1] == 0x2F {
                    let mut j = i + 2;
                    while j < end && bs[j] != 0x0A {
                        j += 1;
                    }
                    self.result_pos = j as i64;
                    self.success = 1;
                    return;
                }

                // Block comment: /* ... */
                if i + 1 < end && bs[i] == 0x2F && bs[i + 1] == 0x2A {
                    let mut j = i + 2;
                    while j + 1 < end {
                        if bs[j] == 0x2A && bs[j + 1] == 0x2F {
                            self.result_pos = (j + 2) as i64;
                            self.success = 1;
                            return;
                        }
                        j += 1;
                    }
                    self.result_pos = end as i64;
                    self.success = 1;
                    return;
                }

                self.success = 0;
            }
        }

        $SkipString {
            $>() {
                let i = self.pos as usize;
                let end = self.scan_end as usize;
                let bs = &self.bytes;

                if i >= end {
                    self.success = 0;
                    return;
                }

                let b0 = bs[i];

                // Verbatim string @"..." (doubled quotes for escape)
                if b0 == 0x40 && i + 1 < end && bs[i + 1] == 0x22 {
                    let mut j = i + 2;
                    while j < end {
                        if bs[j] == 0x22 {
                            if j + 1 < end && bs[j + 1] == 0x22 {
                                j += 2;
                                continue;
                            }
                            self.result_pos = (j + 1) as i64;
                            self.success = 1;
                            return;
                        }
                        j += 1;
                    }
                    self.result_pos = end as i64;
                    self.success = 1;
                    return;
                }

                // Interpolated string $"..." or $@"..." or raw $"""..."""
                if b0 == 0x24 {
                    let mut j = i + 1;
                    // Skip additional $
                    while j < end && bs[j] == 0x24 {
                        j += 1;
                    }
                    // Check for @
                    if j < end && bs[j] == 0x40 {
                        j += 1;
                    }
                    // Count opening quotes
                    let mut quotes: i32 = 0;
                    while j < end && bs[j] == 0x22 {
                        quotes += 1;
                        j += 1;
                    }
                    if quotes == 0 {
                        self.success = 0;
                        return;
                    }
                    // Raw string (3+ quotes)
                    if quotes >= 3 {
                        while j < end {
                            if bs[j] == 0x22 {
                                let mut q: i32 = 0;
                                let mut p = j;
                                while p < end && bs[p] == 0x22 {
                                    q += 1;
                                    p += 1;
                                }
                                if q >= quotes {
                                    self.result_pos = p as i64;
                                    self.success = 1;
                                    return;
                                }
                                j = p;
                                continue;
                            }
                            j += 1;
                        }
                        self.result_pos = end as i64;
                        self.success = 1;
                        return;
                    }
                    // Normal interpolated string
                    while j < end {
                        if bs[j] == 0x5C {
                            j += 2;
                            continue;
                        }
                        if bs[j] == 0x22 {
                            self.result_pos = (j + 1) as i64;
                            self.success = 1;
                            return;
                        }
                        j += 1;
                    }
                    self.result_pos = end as i64;
                    self.success = 1;
                    return;
                }

                // Simple string: " or '
                if b0 == 0x22 || b0 == 0x27 {
                    let q = b0;
                    let mut j = i + 1;
                    while j < end {
                        if bs[j] == 0x5C {
                            j += 2;
                            continue;
                        }
                        if bs[j] == q {
                            self.result_pos = (j + 1) as i64;
                            self.success = 1;
                            return;
                        }
                        j += 1;
                    }
                    self.result_pos = end as i64;
                    self.success = 1;
                    return;
                }

                self.success = 0;
            }
        }

        $FindLineEnd {
            $>() {
                let mut j = self.pos as usize;
                let end = self.scan_end as usize;
                let bs = &self.bytes;

                while j < end {
                    let b = bs[j];
                    if b == 0x0A || b == 0x3B {
                        break;
                    }
                    // Stop at // or /* comment
                    if b == 0x2F && j + 1 < end && (bs[j + 1] == 0x2F || bs[j + 1] == 0x2A) {
                        break;
                    }
                    // Stop at # preprocessor
                    if b == 0x23 {
                        break;
                    }
                    j += 1;
                }

                self.result_pos = j as i64;
            }
        }

        $BalancedParenEnd {
            $>() {
                let mut i = self.pos as usize;
                let end = self.scan_end as usize;
                let bs = &self.bytes;

                if i >= end || bs[i] != 0x28 {
                    self.success = 0;
                    return;
                }

                let mut depth: i32 = 1;
                i += 1;
                while i < end && depth > 0 {
                    let b = bs[i];
                    if b == 0x28 {
                        depth += 1;
                    } else if b == 0x29 {
                        depth -= 1;
                    } else if b == 0x22 || b == 0x27 {
                        let q = b;
                        i += 1;
                        while i < end && bs[i] != q {
                            if bs[i] == 0x5C {
                                i += 1;
                            }
                            i += 1;
                        }
                    }
                    i += 1;
                }

                if depth == 0 {
                    self.result_pos = i as i64;
                    self.success = 1;
                } else {
                    self.result_pos = end as i64;
                    self.success = 0;
                }
            }
        }

    domain:
        bytes: Vec<u8> = Vec::new()
        pos: i64 = 0
        scan_end: i64 = 0
        result_pos: i64 = 0
        success: i64 = 1
}

fn main() {
    let mut failures = 0;

    // Test 1: Skip // line comment
    let mut s1 = @@CSharpSyntaxSkipperFsm();
    let inp1 = b"// comment\ncode".to_vec();
    s1.setup(inp1.clone(), 0, inp1.len() as i64);
    s1.do_skip_comment();
    if s1.get_success() != 1 || s1.get_result_pos() != 10 {
        println!("FAIL 1: success={}, pos={}", s1.get_success(), s1.get_result_pos());
        failures += 1;
    }

    // Test 2: Skip /* */ block comment
    let mut s2 = @@CSharpSyntaxSkipperFsm();
    let inp2 = b"/* block */code".to_vec();
    s2.setup(inp2.clone(), 0, inp2.len() as i64);
    s2.do_skip_comment();
    if s2.get_success() != 1 || s2.get_result_pos() != 11 {
        println!("FAIL 2: success={}, pos={}", s2.get_success(), s2.get_result_pos());
        failures += 1;
    }

    // Test 3: Skip simple string "hello"
    let mut s3 = @@CSharpSyntaxSkipperFsm();
    let inp3 = b"\"hello\" rest".to_vec();
    s3.setup(inp3.clone(), 0, inp3.len() as i64);
    s3.do_skip_string();
    if s3.get_success() != 1 || s3.get_result_pos() != 7 {
        println!("FAIL 3: success={}, pos={}", s3.get_success(), s3.get_result_pos());
        failures += 1;
    }

    // Test 4: Skip verbatim string @"verbatim ""quote"""
    let mut s4 = @@CSharpSyntaxSkipperFsm();
    let inp4 = b"@\"verbatim \"\"quote\"\"\" rest".to_vec();
    s4.setup(inp4.clone(), 0, inp4.len() as i64);
    s4.do_skip_string();
    if s4.get_success() != 1 || s4.get_result_pos() != 21 {
        println!("FAIL 4: success={}, pos={}", s4.get_success(), s4.get_result_pos());
        failures += 1;
    }

    // Test 5: Skip interpolated string $"interp {x}"
    let mut s5 = @@CSharpSyntaxSkipperFsm();
    let inp5 = b"$\"interp {x}\" rest".to_vec();
    s5.setup(inp5.clone(), 0, inp5.len() as i64);
    s5.do_skip_string();
    if s5.get_success() != 1 || s5.get_result_pos() != 13 {
        println!("FAIL 5: success={}, pos={}", s5.get_success(), s5.get_result_pos());
        failures += 1;
    }

    // Test 6: Find line end (stops at // comment)
    let mut s6 = @@CSharpSyntaxSkipperFsm();
    let inp6 = b"x + 1 // comment".to_vec();
    s6.setup(inp6.clone(), 0, inp6.len() as i64);
    s6.do_find_line_end();
    if s6.get_result_pos() != 6 {
        println!("FAIL 6: pos={}, expected 6", s6.get_result_pos());
        failures += 1;
    }

    // Test 7: Balanced parens
    let mut s7 = @@CSharpSyntaxSkipperFsm();
    let inp7 = b"(a, f(b)) rest".to_vec();
    s7.setup(inp7.clone(), 0, inp7.len() as i64);
    s7.do_balanced_paren_end();
    if s7.get_success() != 1 || s7.get_result_pos() != 9 {
        println!("FAIL 7: success={}, pos={}", s7.get_success(), s7.get_result_pos());
        failures += 1;
    }

    // Test 8: Skip # preprocessor directive
    let mut s8 = @@CSharpSyntaxSkipperFsm();
    let inp8 = b"#region Foo\ncode".to_vec();
    s8.setup(inp8.clone(), 0, inp8.len() as i64);
    s8.do_skip_comment();
    if s8.get_success() != 1 || s8.get_result_pos() != 11 {
        println!("FAIL 8: success={}, pos={}", s8.get_success(), s8.get_result_pos());
        failures += 1;
    }

    if failures > 0 { println!("FAIL: {} failures", failures); std::process::exit(1); }
    println!("PASS: csharp_skipper (8 cases)");
}

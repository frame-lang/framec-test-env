@@target rust

// PythonSyntaxSkipper — FSM for skipping Python comments and strings.
// Translated from framec's native_region_scanner/python_skipper.frs
//
// Handles: # comments, triple-quoted strings, simple strings,
// Python-style line endings, balanced parens.

@@system PythonSyntaxSkipperFsm {
    operations:
        setup(input_bytes: Vec<u8>, start: i64, length: i64) {
            self.bytes = input_bytes;
            self.pos = start;
            self.scan_end = length;
        }
        get_result_pos(): i64 {
            return self.result_pos;
        }
        get_success(): i64 {
            return self.success;
        }

    interface:
        do_skip_comment()
        do_skip_string()
        do_find_line_end()
        do_balanced_paren_end()

    machine:
        $Init {
            do_skip_comment() { -> $SkipComment }
            do_skip_string() { -> $SkipString }
            do_find_line_end() { -> $FindLineEnd }
            do_balanced_paren_end() { -> $BalancedParenEnd }
        }

        $SkipComment {
            $>() {
                let i = self.pos as usize;
                let end = self.scan_end as usize;
                let bs = &self.bytes;

                // Python uses # for line comments
                if i < end && bs[i] == b'#' {
                    let mut j = i + 1;
                    while j < end && bs[j] != b'\n' {
                        j += 1;
                    }
                    self.result_pos = j as i64;
                    self.success = 1;
                    return;
                }

                self.success = 0;
            }
        }

        $SkipString {
            $>() {
                let i = self.pos as usize;
                let end = self.scan_end as usize;
                let bs = &self.bytes;

                // Triple-quoted strings: """ or '''
                if i + 2 < end {
                    if (bs[i] == b'"' && bs[i+1] == b'"' && bs[i+2] == b'"') ||
                       (bs[i] == b'\'' && bs[i+1] == b'\'' && bs[i+2] == b'\'') {
                        let q = bs[i];
                        let mut j = i + 3;
                        while j + 2 < end {
                            if bs[j] == q && bs[j+1] == q && bs[j+2] == q {
                                self.result_pos = (j + 3) as i64;
                                self.success = 1;
                                return;
                            }
                            j += 1;
                        }
                        self.result_pos = end as i64;
                        self.success = 1;
                        return;
                    }
                }

                // Simple strings: " or '
                if i < end && (bs[i] == b'"' || bs[i] == b'\'') {
                    let q = bs[i];
                    let mut j = i + 1;
                    while j < end {
                        if bs[j] == b'\\' {
                            j += 2;
                            continue;
                        }
                        if bs[j] == q {
                            self.result_pos = (j + 1) as i64;
                            self.success = 1;
                            return;
                        }
                        j += 1;
                    }
                    self.result_pos = end as i64;
                    self.success = 1;
                    return;
                }

                self.success = 0;
            }
        }

        $FindLineEnd {
            $>() {
                let mut j = self.pos as usize;
                let end = self.scan_end as usize;
                let bs = &self.bytes;

                while j < end {
                    let b = bs[j];
                    if b == b'\n' || b == b';' {
                        break;
                    }
                    // Stop at # comment
                    if b == b'#' {
                        break;
                    }
                    j += 1;
                }

                self.result_pos = j as i64;
            }
        }

        $BalancedParenEnd {
            $>() {
                let i = self.pos as usize;
                let end = self.scan_end as usize;
                let bs = &self.bytes;

                if i >= end || bs[i] != b'(' {
                    self.success = 0;
                    return;
                }

                let mut depth: i32 = 1;
                let mut j = i + 1;
                while j < end && depth > 0 {
                    let b = bs[j];
                    if b == b'(' {
                        depth += 1;
                    } else if b == b')' {
                        depth -= 1;
                    } else if b == b'"' || b == b'\'' {
                        let q = b;
                        j += 1;
                        while j < end && bs[j] != q {
                            if bs[j] == b'\\' {
                                j += 1;
                            }
                            j += 1;
                        }
                    }
                    j += 1;
                }

                if depth == 0 {
                    self.result_pos = j as i64;
                    self.success = 1;
                } else {
                    self.result_pos = end as i64;
                    self.success = 0;
                }
            }
        }

    domain:
        bytes: Vec<u8> = Vec::new()
        pos: i64 = 0
        scan_end: i64 = 0
        result_pos: i64 = 0
        success: i64 = 1
}

fn main() {
    let mut failures = 0;

    // Test 1: Skip hash comment
    let mut s1 = @@PythonSyntaxSkipperFsm();
    let inp1 = b"# comment\ncode".to_vec();
    let len1 = inp1.len() as i64;
    s1.setup(inp1, 0, len1);
    s1.do_skip_comment();
    if s1.get_success() != 1 || s1.get_result_pos() != 9 {
        println!("FAIL 1: success={}, pos={}", s1.get_success(), s1.get_result_pos());
        failures += 1;
    }

    // Test 2: Not a comment
    let mut s2 = @@PythonSyntaxSkipperFsm();
    let inp2 = b"x + 1".to_vec();
    let len2 = inp2.len() as i64;
    s2.setup(inp2, 0, len2);
    s2.do_skip_comment();
    if s2.get_success() != 0 {
        println!("FAIL 2: should not be comment");
        failures += 1;
    }

    // Test 3: Skip triple-quoted string
    let mut s3 = @@PythonSyntaxSkipperFsm();
    let inp3 = b"\"\"\"hello world\"\"\"rest".to_vec();
    let len3 = inp3.len() as i64;
    s3.setup(inp3, 0, len3);
    s3.do_skip_string();
    if s3.get_success() != 1 || s3.get_result_pos() != 17 {
        println!("FAIL 3: success={}, pos={}", s3.get_success(), s3.get_result_pos());
        failures += 1;
    }

    // Test 4: Skip simple string
    let mut s4 = @@PythonSyntaxSkipperFsm();
    let inp4 = b"\"hello\" rest".to_vec();
    let len4 = inp4.len() as i64;
    s4.setup(inp4, 0, len4);
    s4.do_skip_string();
    if s4.get_success() != 1 || s4.get_result_pos() != 7 {
        println!("FAIL 4: success={}, pos={}", s4.get_success(), s4.get_result_pos());
        failures += 1;
    }

    // Test 5: Skip string with escape
    let mut s5 = @@PythonSyntaxSkipperFsm();
    let inp5 = b"'he\\'llo' rest".to_vec();
    let len5 = inp5.len() as i64;
    s5.setup(inp5, 0, len5);
    s5.do_skip_string();
    if s5.get_success() != 1 || s5.get_result_pos() != 9 {
        println!("FAIL 5: success={}, pos={}", s5.get_success(), s5.get_result_pos());
        failures += 1;
    }

    // Test 6: Find line end (stops at #)
    let mut s6 = @@PythonSyntaxSkipperFsm();
    let inp6 = b"x + 1 # comment".to_vec();
    let len6 = inp6.len() as i64;
    s6.setup(inp6, 0, len6);
    s6.do_find_line_end();
    if s6.get_result_pos() != 6 {
        println!("FAIL 6: pos={}, expected 6", s6.get_result_pos());
        failures += 1;
    }

    // Test 7: Balanced parens
    let mut s7 = @@PythonSyntaxSkipperFsm();
    let inp7 = b"(a, f(b)) rest".to_vec();
    let len7 = inp7.len() as i64;
    s7.setup(inp7, 0, len7);
    s7.do_balanced_paren_end();
    if s7.get_success() != 1 || s7.get_result_pos() != 9 {
        println!("FAIL 7: success={}, pos={}", s7.get_success(), s7.get_result_pos());
        failures += 1;
    }

    if failures > 0 {
        println!("FAIL: {} failures", failures);
        std::process::exit(1);
    }
    println!("PASS: python_skipper (7 cases)");
}

@@target erlang

%% ContextParser -- FSM for parsing @@ context constructs.
%% Translated from framec's native_region_scanner/context_parser.frs
%%
%% Parses:
%%   @@:return [= expr]     kind=2 (ContextReturn)
%%   @@:event               kind=3 (ContextEvent)
%%   @@:data.key [= expr]   kind=4 (ContextData) or kind=5 (ContextDataAssign)
%%   @@:params.key           kind=6 (ContextParams)
%%   @@SystemName()          kind=7 (TaggedInstantiation)
%%   @@:(expr)               kind=8 (ContextReturnExpr)
%%   @@:return(expr)         kind=9 (ReturnCall)
%%   @@:self.method()        kind=10 (ContextSelfCall)
%%   @@:self                 kind=11 (ContextSelf)
%%   @@:system.state         kind=12 (ContextSystemState)
%%   other                   has_result=0

@@system ContextParserFsm {
    interface:
        setup(input_bytes: binary, start: int, length: int)
        setup_with_paren_end(input_bytes: binary, start: int, length: int, p_end: int)
        do_parse()
        get_result_end(): int
        get_result_kind(): int
        get_has_result(): int

    machine:
        $Init {
            setup(input_bytes: binary, start: int, length: int) {
                self.bytes = input_bytes
                self.pos = start
                self.scan_end = length
            }
            setup_with_paren_end(input_bytes: binary, start: int, length: int, p_end: int) {
                self.bytes = input_bytes
                self.pos = start
                self.scan_end = length
                self.paren_end = p_end
            }
            do_parse() { -> $Dispatching }
            get_result_end(): int { @@:(self.result_end) }
            get_result_kind(): int { @@:(self.result_kind) }
            get_has_result(): int { @@:(self.has_result) }
        }

        $Dispatching {
            $>() {
                {RE, RK, HR} = cp_dispatch(Data#data.bytes, Data#data.pos, Data#data.scan_end, Data#data.paren_end)
                self.result_end = RE
                self.result_kind = RK
                self.has_result = HR
            }
            get_result_end(): int { @@:(self.result_end) }
            get_result_kind(): int { @@:(self.result_kind) }
            get_has_result(): int { @@:(self.has_result) }
        }

    domain:
        bytes = <<>>
        pos = 0
        scan_end = 0
        result_end = 0
        result_kind = 0
        has_result = 0
        paren_end = 0
}

%% --- dispatcher ---
cp_dispatch(Bs, I, End, ParenEnd) when I >= End ->
    {0, 0, 0};
cp_dispatch(Bs, I, End, ParenEnd) ->
    B = binary:at(Bs, I),
    if
        B =:= $: ->
            cp_dispatch_colon(Bs, I + 1, End, ParenEnd);
        B >= $A andalso B =< $Z ->
            cp_parse_instantiation(Bs, I, End, ParenEnd);
        true ->
            {I, 0, 0}
    end.

%% --- colon dispatch ---
cp_dispatch_colon(Bs, I, End, ParenEnd) ->
    case cp_try_tag(Bs, I, End, <<"return">>, 6) of
        true -> cp_parse_return(Bs, I + 6, End);
        false -> ok
    end,
    case cp_try_tag(Bs, I, End, <<"event">>, 5) of
        true -> {I + 5, 3, 1};
        false ->
            case cp_try_tag(Bs, I, End, <<"data">>, 4) of
                true -> cp_parse_data(Bs, I + 4, End);
                false ->
                    case cp_try_tag(Bs, I, End, <<"params">>, 6) of
                        true -> cp_parse_params(Bs, I + 6, End);
                        false ->
                            case cp_try_tag(Bs, I, End, <<"self">>, 4) of
                                true -> cp_parse_self(Bs, I + 4, End);
                                false ->
                                    case cp_try_tag(Bs, I, End, <<"system">>, 6) of
                                        true -> cp_parse_system(Bs, I + 6, End);
                                        false ->
                                            if
                                                I < End andalso binary_part(Bs, I, 1) =:= <<$(>> ->
                                                    cp_parse_context_return_expr(Bs, I, End);
                                                true ->
                                                    {I, 0, 0}
                                            end
                                    end
                            end
                    end
            end
    end.

cp_try_tag(Bs, I, End, Tag, Len) ->
    I + Len - 1 < End andalso binary:part(Bs, I, Len) =:= Tag.

%% --- parse return ---
cp_parse_return(Bs, I, End) ->
    I2 = cp_skip_ws(Bs, I, End),
    if
        I2 < End andalso binary_part(Bs, I2, 1) =:= <<$(>> ->
            {Pos, _} = cp_scan_balanced(Bs, I2 + 1, End, 1),
            {Pos, 9, 1};
        I2 < End andalso binary_part(Bs, I2, 1) =:= <<$=>> andalso (I2 + 1 >= End orelse binary_part(Bs, I2 + 1, 1) =/= <<$=>>) ->
            I3 = cp_skip_ws(Bs, I2 + 1, End),
            I4 = cp_scan_to_eol(Bs, I3, End),
            {I4, 2, 1};
        true ->
            {I2, 2, 1}
    end.

cp_scan_balanced(_Bs, I, End, 0) -> {I, 0};
cp_scan_balanced(_Bs, I, End, _D) when I >= End -> {End, 1};
cp_scan_balanced(Bs, I, End, D) ->
    B = binary:at(Bs, I),
    if
        B =:= $( -> cp_scan_balanced(Bs, I + 1, End, D + 1);
        B =:= $) andalso D =:= 1 -> {I + 1, 0};
        B =:= $) -> cp_scan_balanced(Bs, I + 1, End, D - 1);
        true -> cp_scan_balanced(Bs, I + 1, End, D)
    end.

%% --- parse context return expr ---
cp_parse_context_return_expr(Bs, I, End) when I < End andalso binary_part(Bs, I, 1) =:= <<$(>> ->
    I2 = cp_scan_expr_paren(Bs, I + 1, End, 1),
    {I2, 8, 1};
cp_parse_context_return_expr(_Bs, I, _End) ->
    {I, 8, 1}.

cp_scan_expr_paren(_Bs, I, End, 0) -> I;
cp_scan_expr_paren(_Bs, I, End, _D) when I >= End -> I;
cp_scan_expr_paren(Bs, I, End, D) ->
    B = binary:at(Bs, I),
    if
        B =:= $( -> cp_scan_expr_paren(Bs, I + 1, End, D + 1);
        B =:= $) -> cp_scan_expr_paren(Bs, I + 1, End, D - 1);
        B =:= $" orelse B =:= $' ->
            I2 = cp_skip_str(Bs, I + 1, End, B),
            cp_scan_expr_paren(Bs, I2 + 1, End, D);
        true -> cp_scan_expr_paren(Bs, I + 1, End, D)
    end.

cp_skip_str(_Bs, I, End, _Q) when I >= End -> End;
cp_skip_str(Bs, I, End, Q) ->
    B = binary:at(Bs, I),
    if
        B =:= $\\ andalso I + 1 < End -> cp_skip_str(Bs, I + 2, End, Q);
        B =:= Q -> I;
        true -> cp_skip_str(Bs, I + 1, End, Q)
    end.

%% --- parse data ---
cp_parse_data(Bs, I, End) ->
    I2 = cp_scan_dot_key(Bs, I, End),
    J = cp_skip_ws(Bs, I2, End),
    if
        J < End andalso binary_part(Bs, J, 1) =:= <<$=>> andalso (J + 1 >= End orelse binary_part(Bs, J + 1, 1) =/= <<$=>>) ->
            J2 = cp_skip_ws(Bs, J + 1, End),
            J3 = cp_scan_to_eol(Bs, J2, End),
            {J3, 5, 1};
        true ->
            {I2, 4, 1}
    end.

%% --- parse params ---
cp_parse_params(Bs, I, End) ->
    I2 = cp_scan_dot_key(Bs, I, End),
    {I2, 6, 1}.

%% --- parse self ---
cp_parse_self(Bs, I, End) when I < End andalso binary_part(Bs, I, 1) =:= <<$.>> ->
    I2 = cp_scan_ident(Bs, I + 1, End),
    if
        I2 < End andalso binary_part(Bs, I2, 1) =:= <<$(>> ->
            {Pos, _} = cp_scan_balanced_self(Bs, I2 + 1, End, 1),
            {Pos, 10, 1};
        true ->
            {I2, 11, 1}
    end;
cp_parse_self(_Bs, I, _End) ->
    {I, 11, 1}.

cp_scan_balanced_self(_Bs, I, End, 0) -> {I, 0};
cp_scan_balanced_self(_Bs, I, End, _D) when I >= End -> {End, 1};
cp_scan_balanced_self(Bs, I, End, D) ->
    B = binary:at(Bs, I),
    if
        B =:= $( -> cp_scan_balanced_self(Bs, I + 1, End, D + 1);
        B =:= $) andalso D =:= 1 -> {I + 1, 0};
        B =:= $) -> cp_scan_balanced_self(Bs, I + 1, End, D - 1);
        B =:= $" orelse B =:= $' ->
            I2 = cp_skip_str(Bs, I + 1, End, B),
            cp_scan_balanced_self(Bs, I2 + 1, End, D);
        true -> cp_scan_balanced_self(Bs, I + 1, End, D)
    end.

%% --- parse system ---
cp_parse_system(Bs, I, End) ->
    case cp_try_tag(Bs, I, End, <<".state">>, 6) of
        true ->
            After = I + 6,
            if
                After >= End -> {I + 6, 12, 1};
                true ->
                    C = binary:at(Bs, After),
                    IsAlnum = (C >= $0 andalso C =< $9) orelse (C >= $A andalso C =< $Z) orelse (C >= $a andalso C =< $z),
                    if
                        IsAlnum orelse C =:= $_ -> {I, 13, 1};
                        true -> {I + 6, 12, 1}
                    end
            end;
        false ->
            {I, 13, 1}
    end.

%% --- parse instantiation ---
cp_parse_instantiation(Bs, I, End, ParenEnd) ->
    I2 = cp_scan_ident(Bs, I, End),
    if
        I2 < End andalso binary_part(Bs, I2, 1) =:= <<$(>> ->
            if
                ParenEnd > 0 -> {ParenEnd, 7, 1};
                true -> {I2, 0, 0}
            end;
        true ->
            {I2, 0, 0}
    end.

%% --- helpers ---
cp_skip_ws(_Bs, I, End) when I >= End -> End;
cp_skip_ws(Bs, I, End) ->
    B = binary:at(Bs, I),
    if
        B =:= 32 orelse B =:= 9 -> cp_skip_ws(Bs, I + 1, End);
        true -> I
    end.

cp_scan_to_eol(_Bs, I, End) when I >= End -> End;
cp_scan_to_eol(Bs, I, End) ->
    B = binary:at(Bs, I),
    if
        B =:= $\n orelse B =:= $; -> I;
        true -> cp_scan_to_eol(Bs, I + 1, End)
    end.

cp_scan_dot_key(Bs, I, End) when I < End ->
    case binary:at(Bs, I) of
        $. -> cp_scan_ident(Bs, I + 1, End);
        _ -> I
    end;
cp_scan_dot_key(_Bs, I, _End) -> I.

cp_scan_ident(_Bs, I, End) when I >= End -> End;
cp_scan_ident(Bs, I, End) ->
    C = binary:at(Bs, I),
    IsAlnum = (C >= $0 andalso C =< $9) orelse (C >= $A andalso C =< $Z) orelse (C >= $a andalso C =< $z),
    if
        IsAlnum orelse C =:= $_ -> cp_scan_ident(Bs, I + 1, End);
        true -> I
    end.

main() ->
    Failures = cp_test_all(0),
    case Failures of
        0 -> io:format("PASS: context_parser (12 cases)~n");
        _ -> io:format("FAIL: ~p failures~n", [Failures]), halt(1)
    end.

cp_test_all(F0) ->
    M = context_parser_fsm,

    %% Test 1: @@:return (bare read)
    {ok, P1} = M:start_link(),
    I1 = <<":return">>,
    M:setup(P1, I1, 0, byte_size(I1)),
    M:do_parse(P1),
    F1 = case {M:get_has_result(P1), M:get_result_kind(P1)} of
        {1, 2} -> F0;
        {H1, K1} -> io:format("FAIL 1: has_result=~p, kind=~p~n", [H1, K1]), F0 + 1
    end,

    %% Test 2: @@:event
    {ok, P2} = M:start_link(),
    I2 = <<":event">>,
    M:setup(P2, I2, 0, byte_size(I2)),
    M:do_parse(P2),
    F2 = case {M:get_has_result(P2), M:get_result_kind(P2)} of
        {1, 3} -> F1;
        {H2, K2} -> io:format("FAIL 2: has_result=~p, kind=~p~n", [H2, K2]), F1 + 1
    end,

    %% Test 3: @@:data.key
    {ok, P3} = M:start_link(),
    I3 = <<":data.name rest">>,
    M:setup(P3, I3, 0, byte_size(I3)),
    M:do_parse(P3),
    F3 = case {M:get_has_result(P3), M:get_result_kind(P3)} of
        {1, 4} -> F2;
        {H3, K3} -> io:format("FAIL 3: has_result=~p, kind=~p~n", [H3, K3]), F2 + 1
    end,

    %% Test 4: @@:data.key = expr
    {ok, P4} = M:start_link(),
    I4 = <<":data.key = value\n">>,
    M:setup(P4, I4, 0, byte_size(I4)),
    M:do_parse(P4),
    F4 = case {M:get_has_result(P4), M:get_result_kind(P4)} of
        {1, 5} -> F3;
        {H4, K4} -> io:format("FAIL 4: has_result=~p, kind=~p~n", [H4, K4]), F3 + 1
    end,

    %% Test 5: @@:params.key
    {ok, P5} = M:start_link(),
    I5 = <<":params.name rest">>,
    M:setup(P5, I5, 0, byte_size(I5)),
    M:do_parse(P5),
    F5 = case {M:get_has_result(P5), M:get_result_kind(P5)} of
        {1, 6} -> F4;
        {H5, K5} -> io:format("FAIL 5: has_result=~p, kind=~p~n", [H5, K5]), F4 + 1
    end,

    %% Test 6: @@:(expr)
    {ok, P6} = M:start_link(),
    I6 = <<":(x + 1) rest">>,
    M:setup(P6, I6, 0, byte_size(I6)),
    M:do_parse(P6),
    F6 = case {M:get_has_result(P6), M:get_result_kind(P6)} of
        {1, 8} -> F5;
        {H6, K6} -> io:format("FAIL 6: has_result=~p, kind=~p~n", [H6, K6]), F5 + 1
    end,

    %% Test 7: @@:return(expr)
    {ok, P7} = M:start_link(),
    I7 = <<":return(42) rest">>,
    M:setup(P7, I7, 0, byte_size(I7)),
    M:do_parse(P7),
    F7 = case {M:get_has_result(P7), M:get_result_kind(P7)} of
        {1, 9} -> F6;
        {H7, K7} -> io:format("FAIL 7: has_result=~p, kind=~p~n", [H7, K7]), F6 + 1
    end,

    %% Test 8: @@:self (bare)
    {ok, P8} = M:start_link(),
    I8 = <<":self rest">>,
    M:setup(P8, I8, 0, byte_size(I8)),
    M:do_parse(P8),
    F8 = case {M:get_has_result(P8), M:get_result_kind(P8)} of
        {1, 11} -> F7;
        {H8, K8} -> io:format("FAIL 8: has_result=~p, kind=~p~n", [H8, K8]), F7 + 1
    end,

    %% Test 9: @@:self.method(args)
    {ok, P9} = M:start_link(),
    I9 = <<":self.doWork(x) rest">>,
    M:setup(P9, I9, 0, byte_size(I9)),
    M:do_parse(P9),
    F9 = case {M:get_has_result(P9), M:get_result_kind(P9)} of
        {1, 10} -> F8;
        {H9, K9} -> io:format("FAIL 9: has_result=~p, kind=~p~n", [H9, K9]), F8 + 1
    end,

    %% Test 10: @@:system.state
    {ok, P10} = M:start_link(),
    I10 = <<":system.state rest">>,
    M:setup(P10, I10, 0, byte_size(I10)),
    M:do_parse(P10),
    F10 = case {M:get_has_result(P10), M:get_result_kind(P10)} of
        {1, 12} -> F9;
        {H10, K10} -> io:format("FAIL 10: has_result=~p, kind=~p~n", [H10, K10]), F9 + 1
    end,

    %% Test 11: @@SystemName() with paren_end
    {ok, P11} = M:start_link(),
    I11 = <<"MySystem() rest">>,
    M:setup_with_paren_end(P11, I11, 0, byte_size(I11), 10),
    M:do_parse(P11),
    F11 = case {M:get_has_result(P11), M:get_result_kind(P11)} of
        {1, 7} -> F10;
        {H11, K11} -> io:format("FAIL 11: has_result=~p, kind=~p~n", [H11, K11]), F10 + 1
    end,

    %% Test 12: No match (lowercase, not a keyword)
    {ok, P12} = M:start_link(),
    I12 = <<"xyz">>,
    M:setup(P12, I12, 0, byte_size(I12)),
    M:do_parse(P12),
    F12 = case M:get_has_result(P12) of
        0 -> F11;
        H12 -> io:format("FAIL 12: should not match, has_result=~p~n", [H12]), F11 + 1
    end,

    F12.

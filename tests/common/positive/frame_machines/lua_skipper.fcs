@@[target("csharp")]

using System;
using System.Text;

// LuaSyntaxSkipper — FSM for skipping Lua comments and strings.
// Translated from framec's native_region_scanner/lua_skipper.frs
//
// Handles: -- line comments, --[[ block comments ]], [[ long strings ]],
// simple strings, Lua-style line endings.

@@system LuaSyntaxSkipperFsm {
    operations:
        setup(input_bytes: byte[], start: int, length: int) {
            this.bytes = input_bytes;
            this.pos = start;
            this.scan_end = length;
        }
        get_result_pos(): int {
            return this.result_pos;
        }
        get_success(): int {
            return this.success;
        }

    interface:
        do_skip_comment()
        do_skip_string()
        do_find_line_end()

    machine:
        $Init {
            do_skip_comment() { -> $SkipComment }
            do_skip_string() { -> $SkipString }
            do_find_line_end() { -> $FindLineEnd }
        }

        $SkipComment {
            $>() {
                int i = this.pos;
                int end = this.scan_end;
                byte[] bs = this.bytes;

                // Lua line comment: --
                if (i + 1 < end && bs[i] == '-' && bs[i + 1] == '-') {
                    // Check for block comment: --[[ ... ]]
                    if (i + 3 < end && bs[i + 2] == '[' && bs[i + 3] == '[') {
                        int k = i + 4;
                        while (k + 1 < end) {
                            if (bs[k] == ']' && bs[k + 1] == ']') {
                                this.result_pos = k + 2;
                                this.success = 1;
                                return;
                            }
                            k++;
                        }
                        this.result_pos = end;
                        this.success = 1;
                        return;
                    }
                    // Line comment
                    int j = i + 2;
                    while (j < end && bs[j] != '\n') {
                        j++;
                    }
                    this.result_pos = j;
                    this.success = 1;
                    return;
                }

                this.success = 0;
            }
        }

        $SkipString {
            $>() {
                int i = this.pos;
                int end = this.scan_end;
                byte[] bs = this.bytes;

                // Long string: [[ ... ]]
                if (i + 1 < end && bs[i] == '[' && bs[i + 1] == '[') {
                    int j = i + 2;
                    while (j + 1 < end) {
                        if (bs[j] == ']' && bs[j + 1] == ']') {
                            this.result_pos = j + 2;
                            this.success = 1;
                            return;
                        }
                        j++;
                    }
                    this.result_pos = end;
                    this.success = 1;
                    return;
                }

                // Simple string: " or '
                if (i < end && (bs[i] == '"' || bs[i] == '\'')) {
                    int q = bs[i];
                    int j = i + 1;
                    while (j < end) {
                        if (bs[j] == '\\') {
                            j += 2;
                            continue;
                        }
                        if (bs[j] == q) {
                            this.result_pos = j + 1;
                            this.success = 1;
                            return;
                        }
                        j++;
                    }
                    this.result_pos = end;
                    this.success = 1;
                    return;
                }

                this.success = 0;
            }
        }

        $FindLineEnd {
            $>() {
                int j = this.pos;
                int end = this.scan_end;
                byte[] bs = this.bytes;

                while (j < end) {
                    int b = bs[j];
                    if (b == '\n') {
                        break;
                    }
                    // Stop at -- comment
                    if (b == '-' && j + 1 < end && bs[j + 1] == '-') {
                        break;
                    }
                    j++;
                }

                this.result_pos = j;
            }
        }

    domain:
        bytes: byte[] = null
        pos: int = 0
        scan_end: int = 0
        result_pos: int = 0
        success: int = 1
}

class Program {
    static void Main(string[] args) {
        int failures = 0;

        // Test 1: Skip -- line comment
        var s1 = @@LuaSyntaxSkipperFsm();
        byte[] inp1 = Encoding.UTF8.GetBytes("-- comment\ncode");
        s1.setup(inp1, 0, inp1.Length);
        s1.do_skip_comment();
        if (s1.get_success() != 1 || s1.get_result_pos() != 10) {
            Console.WriteLine("FAIL 1: success=" + s1.get_success() + ", pos=" + s1.get_result_pos());
            failures++;
        }

        // Test 2: Skip --[[ block comment ]]
        var s2 = @@LuaSyntaxSkipperFsm();
        byte[] inp2 = Encoding.UTF8.GetBytes("--[[ block ]]code");
        s2.setup(inp2, 0, inp2.Length);
        s2.do_skip_comment();
        if (s2.get_success() != 1 || s2.get_result_pos() != 13) {
            Console.WriteLine("FAIL 2: success=" + s2.get_success() + ", pos=" + s2.get_result_pos());
            failures++;
        }

        // Test 3: Not a comment
        var s3 = @@LuaSyntaxSkipperFsm();
        byte[] inp3 = Encoding.UTF8.GetBytes("x + 1");
        s3.setup(inp3, 0, inp3.Length);
        s3.do_skip_comment();
        if (s3.get_success() != 0) {
            Console.WriteLine("FAIL 3: should not be comment");
            failures++;
        }

        // Test 4: Skip [[ long string ]]
        var s4 = @@LuaSyntaxSkipperFsm();
        byte[] inp4 = Encoding.UTF8.GetBytes("[[hello world]]rest");
        s4.setup(inp4, 0, inp4.Length);
        s4.do_skip_string();
        if (s4.get_success() != 1 || s4.get_result_pos() != 15) {
            Console.WriteLine("FAIL 4: success=" + s4.get_success() + ", pos=" + s4.get_result_pos());
            failures++;
        }

        // Test 5: Skip simple string
        var s5 = @@LuaSyntaxSkipperFsm();
        byte[] inp5 = Encoding.UTF8.GetBytes("\"hello\" rest");
        s5.setup(inp5, 0, inp5.Length);
        s5.do_skip_string();
        if (s5.get_success() != 1 || s5.get_result_pos() != 7) {
            Console.WriteLine("FAIL 5: success=" + s5.get_success() + ", pos=" + s5.get_result_pos());
            failures++;
        }

        // Test 6: Find line end stops at --
        var s6 = @@LuaSyntaxSkipperFsm();
        byte[] inp6 = Encoding.UTF8.GetBytes("x + 1 -- comment");
        s6.setup(inp6, 0, inp6.Length);
        s6.do_find_line_end();
        if (s6.get_result_pos() != 6) {
            Console.WriteLine("FAIL 6: pos=" + s6.get_result_pos() + ", expected 6");
            failures++;
        }

        if (failures > 0) {
            Console.WriteLine("FAIL: " + failures + " failures");
            Environment.Exit(1);
        }
        Console.WriteLine("PASS: lua_skipper (6 cases)");
    }
}

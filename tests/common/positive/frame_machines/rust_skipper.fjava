@@target java

// RustSyntaxSkipper — FSM for skipping Rust comments and strings.
// Translated from framec's native_region_scanner/rust_skipper.frs
//
// Handles: // line comments, /* nested block comments */,
// raw strings (r#"..."#), char literals vs lifetime annotations,
// simple strings.

@@system RustSyntaxSkipperFsm {
    operations:
        setup(input_bytes: byte[], start: int, length: int) {
            this.bytes = input_bytes;
            this.pos = start;
            this.scan_end = length;
        }
        get_result_pos(): int {
            return this.result_pos;
        }
        get_success(): int {
            return this.success;
        }

    interface:
        do_skip_comment()
        do_skip_string()
        do_find_line_end()

    machine:
        $Init {
            do_skip_comment() { -> $SkipComment }
            do_skip_string() { -> $SkipString }
            do_find_line_end() { -> $FindLineEnd }
        }

        $SkipComment {
            $>() {
                int i = this.pos;
                int end = this.scan_end;
                byte[] bs = this.bytes;

                // // line comment
                if (i + 1 < end && (bs[i] & 0xFF) == '/' && (bs[i + 1] & 0xFF) == '/') {
                    int j = i + 2;
                    while (j < end && (bs[j] & 0xFF) != '\n') {
                        j++;
                    }
                    this.result_pos = j;
                    this.success = 1;
                    return;
                }

                // /* nested block comment */ — Rust allows nesting
                if (i + 1 < end && (bs[i] & 0xFF) == '/' && (bs[i + 1] & 0xFF) == '*') {
                    int j = i + 2;
                    int depth = 1;
                    while (j + 1 < end && depth > 0) {
                        if ((bs[j] & 0xFF) == '/' && (bs[j + 1] & 0xFF) == '*') {
                            depth++;
                            j += 2;
                            continue;
                        }
                        if ((bs[j] & 0xFF) == '*' && (bs[j + 1] & 0xFF) == '/') {
                            depth--;
                            j += 2;
                            continue;
                        }
                        j++;
                    }
                    this.result_pos = j;
                    this.success = 1;
                    return;
                }

                this.success = 0;
            }
        }

        $SkipString {
            $>() {
                int i = this.pos;
                int end = this.scan_end;
                byte[] bs = this.bytes;

                // Raw string: r#"..."# (count leading #s)
                if (i < end && (bs[i] & 0xFF) == 'r') {
                    int j = i + 1;
                    int hash_count = 0;
                    while (j < end && (bs[j] & 0xFF) == '#') {
                        hash_count++;
                        j++;
                    }
                    if (j < end && (bs[j] & 0xFF) == '"') {
                        j++;
                        // Scan for closing "###
                        while (j < end) {
                            if ((bs[j] & 0xFF) == '"') {
                                int k = 0;
                                while (k < hash_count && j + 1 + k < end && (bs[j + 1 + k] & 0xFF) == '#') {
                                    k++;
                                }
                                if (k == hash_count) {
                                    this.result_pos = j + 1 + hash_count;
                                    this.success = 1;
                                    return;
                                }
                            }
                            j++;
                        }
                        this.result_pos = end;
                        this.success = 1;
                        return;
                    }
                }

                // Double-quoted string
                if (i < end && (bs[i] & 0xFF) == '"') {
                    int j = i + 1;
                    while (j < end) {
                        if ((bs[j] & 0xFF) == '\\') {
                            j += 2;
                            continue;
                        }
                        if ((bs[j] & 0xFF) == '"') {
                            this.result_pos = j + 1;
                            this.success = 1;
                            return;
                        }
                        j++;
                    }
                    this.result_pos = end;
                    this.success = 1;
                    return;
                }

                // Char literal: 'x' or '\n' (NOT lifetime 'a)
                if (i < end && (bs[i] & 0xFF) == '\'') {
                    if (i + 2 < end && (bs[i + 1] & 0xFF) == '\\' && i + 3 < end && (bs[i + 3] & 0xFF) == '\'') {
                        this.result_pos = i + 4;
                        this.success = 1;
                        return;
                    }
                    if (i + 2 < end && (bs[i + 2] & 0xFF) == '\'') {
                        this.result_pos = i + 3;
                        this.success = 1;
                        return;
                    }
                    this.success = 0;
                    return;
                }

                this.success = 0;
            }
        }

        $FindLineEnd {
            $>() {
                int j = this.pos;
                int end = this.scan_end;
                byte[] bs = this.bytes;

                while (j < end) {
                    int b = bs[j] & 0xFF;
                    if (b == '\n' || b == ';') {
                        break;
                    }
                    if (b == '/' && j + 1 < end && (bs[j + 1] & 0xFF) == '/') {
                        break;
                    }
                    if (b == '/' && j + 1 < end && (bs[j + 1] & 0xFF) == '*') {
                        break;
                    }
                    j++;
                }

                this.result_pos = j;
            }
        }

    domain:
        bytes: byte[] = null
        pos: int = 0
        scan_end: int = 0
        result_pos: int = 0
        success: int = 1
}

class Main {
    public static void main(String[] args) {
        int failures = 0;

        // Test 1: Skip // comment
        RustSyntaxSkipperFsm s1 = @@RustSyntaxSkipperFsm();
        byte[] inp1 = "// comment\ncode".getBytes();
        s1.setup(inp1, 0, inp1.length);
        s1.do_skip_comment();
        if (s1.get_success() != 1 || s1.get_result_pos() != 10) {
            System.out.println("FAIL 1: success=" + s1.get_success() + ", pos=" + s1.get_result_pos());
            failures++;
        }

        // Test 2: Skip nested /* /* */ */ block comment
        RustSyntaxSkipperFsm s2 = @@RustSyntaxSkipperFsm();
        byte[] inp2 = "/* outer /* inner */ */code".getBytes();
        s2.setup(inp2, 0, inp2.length);
        s2.do_skip_comment();
        if (s2.get_success() != 1 || s2.get_result_pos() != 23) {
            System.out.println("FAIL 2: success=" + s2.get_success() + ", pos=" + s2.get_result_pos());
            failures++;
        }

        // Test 3: Skip raw string r#"hello"#
        RustSyntaxSkipperFsm s3 = @@RustSyntaxSkipperFsm();
        byte[] inp3 = "r#\"hello\"#rest".getBytes();
        s3.setup(inp3, 0, inp3.length);
        s3.do_skip_string();
        if (s3.get_success() != 1 || s3.get_result_pos() != 10) {
            System.out.println("FAIL 3: success=" + s3.get_success() + ", pos=" + s3.get_result_pos());
            failures++;
        }

        // Test 4: Skip double-quoted string
        RustSyntaxSkipperFsm s4 = @@RustSyntaxSkipperFsm();
        byte[] inp4 = "\"hello\" rest".getBytes();
        s4.setup(inp4, 0, inp4.length);
        s4.do_skip_string();
        if (s4.get_success() != 1 || s4.get_result_pos() != 7) {
            System.out.println("FAIL 4: success=" + s4.get_success() + ", pos=" + s4.get_result_pos());
            failures++;
        }

        // Test 5: Char literal 'x' — IS a string
        RustSyntaxSkipperFsm s5 = @@RustSyntaxSkipperFsm();
        byte[] inp5 = "'x' rest".getBytes();
        s5.setup(inp5, 0, inp5.length);
        s5.do_skip_string();
        if (s5.get_success() != 1 || s5.get_result_pos() != 3) {
            System.out.println("FAIL 5: success=" + s5.get_success() + ", pos=" + s5.get_result_pos());
            failures++;
        }

        // Test 6: Lifetime 'a — NOT a string
        RustSyntaxSkipperFsm s6 = @@RustSyntaxSkipperFsm();
        byte[] inp6 = "'a rest".getBytes();
        s6.setup(inp6, 0, inp6.length);
        s6.do_skip_string();
        if (s6.get_success() != 0) {
            System.out.println("FAIL 6: lifetime should not be a string");
            failures++;
        }

        // Test 7: Escape char '\n'
        RustSyntaxSkipperFsm s7 = @@RustSyntaxSkipperFsm();
        byte[] inp7 = "'\\n' rest".getBytes();
        s7.setup(inp7, 0, inp7.length);
        s7.do_skip_string();
        if (s7.get_success() != 1 || s7.get_result_pos() != 4) {
            System.out.println("FAIL 7: success=" + s7.get_success() + ", pos=" + s7.get_result_pos());
            failures++;
        }

        if (failures > 0) {
            System.out.println("FAIL: " + failures + " failures");
            System.exit(1);
        }
        System.out.println("PASS: rust_skipper (7 cases)");
    }
}

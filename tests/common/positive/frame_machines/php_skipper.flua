@@[target("lua")]

-- PhpSyntaxSkipper -- FSM for skipping PHP comments and strings.
-- Translated from framec's native_region_scanner/php_skipper.frs
--
-- Handles: // line comments, # line comments, /* */ block comments,
-- "..." and '...' strings, <<<EOT heredoc/nowdoc,
-- PHP-style line endings, balanced parens.
--
-- NOTE: Lua is 1-indexed, but the scanner uses 0-indexed positions
-- internally and adjusts when accessing the byte table.

@@system PhpSyntaxSkipperFsm {
    operations:
        setup(input_bytes, start, length) {
            self.bytes = input_bytes
            self.pos = start
            self.scan_end = length
        }
        get_result_pos() {
            return self.result_pos
        }
        get_success() {
            return self.success
        }

    interface:
        do_skip_comment()
        do_skip_string()
        do_find_line_end()
        do_balanced_paren_end()

    machine:
        $Init {
            do_skip_comment() { -> $SkipComment }
            do_skip_string() { -> $SkipString }
            do_find_line_end() { -> $FindLineEnd }
            do_balanced_paren_end() { -> $BalancedParenEnd }
        }

        $SkipComment {
            $>() {
                i = self.pos
                scan_end = self.scan_end
                bs = self.bytes

                -- Line comment: //
                if i + 1 < scan_end and bs[i + 1] == 0x2F and bs[i + 2] == 0x2F then
                    j = i + 2
                    while j < scan_end and bs[j + 1] ~= 0x0A do
                        j = j + 1
                    end
                    self.result_pos = j
                    self.success = 1
                    return
                end

                -- Hash comment: #
                if i < scan_end and bs[i + 1] == 0x23 then
                    j = i + 1
                    while j < scan_end and bs[j + 1] ~= 0x0A do
                        j = j + 1
                    end
                    self.result_pos = j
                    self.success = 1
                    return
                end

                -- Block comment: /* ... */
                if i + 1 < scan_end and bs[i + 1] == 0x2F and bs[i + 2] == 0x2A then
                    j = i + 2
                    while j + 1 < scan_end do
                        if bs[j + 1] == 0x2A and bs[j + 2] == 0x2F then
                            self.result_pos = j + 2
                            self.success = 1
                            return
                        end
                        j = j + 1
                    end
                    self.result_pos = scan_end
                    self.success = 1
                    return
                end

                self.success = 0
            }
        }

        $SkipString {
            $>() {
                i = self.pos
                scan_end = self.scan_end
                bs = self.bytes

                -- Heredoc/nowdoc: <<<EOT ... EOT;
                if i + 2 < scan_end and bs[i + 1] == 0x3C and bs[i + 2] == 0x3C and bs[i + 3] == 0x3C then
                    j = i + 3
                    -- Skip optional quote for nowdoc
                    nowdoc = 0
                    if j < scan_end and bs[j + 1] == 0x27 then
                        nowdoc = 1
                        j = j + 1
                    end
                    -- Read tag name
                    tag_start = j
                    while j < scan_end and ((bs[j + 1] >= 0x61 and bs[j + 1] <= 0x7A) or (bs[j + 1] >= 0x41 and bs[j + 1] <= 0x5A) or (bs[j + 1] >= 0x30 and bs[j + 1] <= 0x39) or bs[j + 1] == 0x5F) do
                        j = j + 1
                    end
                    tag_end_pos = j
                    if nowdoc == 1 and j < scan_end and bs[j + 1] == 0x27 then
                        j = j + 1
                    end
                    tag_len = tag_end_pos - tag_start
                    if tag_len > 0 then
                        -- Skip to newline
                        while j < scan_end and bs[j + 1] ~= 0x0A do
                            j = j + 1
                        end
                        if j < scan_end then
                            j = j + 1
                        end
                        -- Scan for closing tag at start of line
                        while j < scan_end do
                            -- Check if this line starts with the tag
                            match = 1
                            if j + tag_len <= scan_end then
                                ti = 0
                                while ti < tag_len do
                                    if bs[j + ti + 1] ~= bs[tag_start + ti + 1] then
                                        match = 0
                                        break
                                    end
                                    ti = ti + 1
                                end
                            else
                                match = 0
                            end
                            if match == 1 then
                                k = j + tag_len
                                if k < scan_end and bs[k + 1] == 0x3B then
                                    k = k + 1
                                end
                                if k >= scan_end or bs[k + 1] == 0x0A then
                                    if k < scan_end and bs[k + 1] == 0x0A then
                                        k = k + 1
                                    end
                                    self.result_pos = k
                                    self.success = 1
                                    return
                                end
                            end
                            -- Skip to next line
                            while j < scan_end and bs[j + 1] ~= 0x0A do
                                j = j + 1
                            end
                            if j < scan_end then
                                j = j + 1
                            end
                        end
                        self.result_pos = scan_end
                        self.success = 1
                        return
                    end
                end

                -- Simple string: " or '
                if i < scan_end and (bs[i + 1] == 0x22 or bs[i + 1] == 0x27) then
                    q = bs[i + 1]
                    j = i + 1
                    while j < scan_end do
                        if bs[j + 1] == 0x5C then
                            j = j + 2
                            goto continue_simple
                        end
                        if bs[j + 1] == q then
                            self.result_pos = j + 1
                            self.success = 1
                            return
                        end
                        j = j + 1
                        ::continue_simple::
                    end
                    self.result_pos = scan_end
                    self.success = 1
                    return
                end

                self.success = 0
            }
        }

        $FindLineEnd {
            $>() {
                j = self.pos
                scan_end = self.scan_end
                bs = self.bytes
                in_string = 0

                while j < scan_end do
                    b = bs[j + 1]
                    if b == 0x0A then
                        break
                    end

                    -- Inside string
                    if in_string ~= 0 then
                        if b == 0x5C then
                            j = j + 2
                            goto continue_find_line
                        end
                        if b == in_string then
                            in_string = 0
                        end
                        j = j + 1
                        goto continue_find_line
                    end

                    -- Terminators
                    if b == 0x3B or b == 0x7D then
                        break
                    end
                    if b == 0x2F and j + 1 < scan_end and (bs[j + 2] == 0x2F or bs[j + 2] == 0x2A) then
                        break
                    end
                    if b == 0x23 then
                        break
                    end

                    -- String starts
                    if b == 0x27 or b == 0x22 then
                        in_string = b
                        j = j + 1
                        goto continue_find_line
                    end

                    j = j + 1
                    ::continue_find_line::
                end

                self.result_pos = j
            }
        }

        $BalancedParenEnd {
            $>() {
                i = self.pos
                scan_end = self.scan_end
                bs = self.bytes

                if i >= scan_end or bs[i + 1] ~= 0x28 then
                    self.success = 0
                    return
                end

                depth = 0
                in_string = 0

                while i < scan_end do
                    b = bs[i + 1]

                    -- Inside string
                    if in_string ~= 0 then
                        if b == 0x5C then
                            i = i + 2
                            goto continue_paren
                        end
                        if b == in_string then
                            in_string = 0
                        end
                        i = i + 1
                        goto continue_paren
                    end

                    if b == 0x27 or b == 0x22 then
                        in_string = b
                        i = i + 1
                    elseif b == 0x28 then
                        depth = depth + 1
                        i = i + 1
                    elseif b == 0x29 then
                        depth = depth - 1
                        i = i + 1
                        if depth == 0 then
                            self.result_pos = i
                            self.success = 1
                            return
                        end
                    else
                        i = i + 1
                    end
                    ::continue_paren::
                end

                self.success = 0
            }
        }

    domain:
        bytes = {}
        pos: int = 0
        scan_end: int = 0
        result_pos: int = 0
        success: int = 1
}

local function str_to_bytes(s)
    local t = {}
    for i = 1, #s do
        t[i] = string.byte(s, i)
    end
    return t
end

local failures = 0

-- Test 1: Skip // line comment
local s1 = @@PhpSyntaxSkipperFsm()
local inp1 = str_to_bytes("// comment\ncode")
s1:setup(inp1, 0, #inp1)
s1:do_skip_comment()
if s1:get_success() ~= 1 or s1:get_result_pos() ~= 10 then
    print("FAIL 1: success=" .. s1:get_success() .. ", pos=" .. s1:get_result_pos())
    failures = failures + 1
end

-- Test 2: Skip # comment
local s2 = @@PhpSyntaxSkipperFsm()
local inp2 = str_to_bytes("# comment\ncode")
s2:setup(inp2, 0, #inp2)
s2:do_skip_comment()
if s2:get_success() ~= 1 or s2:get_result_pos() ~= 9 then
    print("FAIL 2: success=" .. s2:get_success() .. ", pos=" .. s2:get_result_pos())
    failures = failures + 1
end

-- Test 3: Skip /* */ block comment
local s3 = @@PhpSyntaxSkipperFsm()
local inp3 = str_to_bytes("/* block */code")
s3:setup(inp3, 0, #inp3)
s3:do_skip_comment()
if s3:get_success() ~= 1 or s3:get_result_pos() ~= 11 then
    print("FAIL 3: success=" .. s3:get_success() .. ", pos=" .. s3:get_result_pos())
    failures = failures + 1
end

-- Test 4: Skip double-quoted string
local s4 = @@PhpSyntaxSkipperFsm()
local inp4 = str_to_bytes('"hello" rest')
s4:setup(inp4, 0, #inp4)
s4:do_skip_string()
if s4:get_success() ~= 1 or s4:get_result_pos() ~= 7 then
    print("FAIL 4: success=" .. s4:get_success() .. ", pos=" .. s4:get_result_pos())
    failures = failures + 1
end

-- Test 5: Skip single-quoted string
local s5 = @@PhpSyntaxSkipperFsm()
local inp5 = str_to_bytes("'hello' rest")
s5:setup(inp5, 0, #inp5)
s5:do_skip_string()
if s5:get_success() ~= 1 or s5:get_result_pos() ~= 7 then
    print("FAIL 5: success=" .. s5:get_success() .. ", pos=" .. s5:get_result_pos())
    failures = failures + 1
end

-- Test 6: Skip heredoc
local s6 = @@PhpSyntaxSkipperFsm()
local inp6 = str_to_bytes("<<<EOT\nhello world\nEOT;\nnext")
s6:setup(inp6, 0, #inp6)
s6:do_skip_string()
if s6:get_success() ~= 1 or s6:get_result_pos() ~= 24 then
    print("FAIL 6: success=" .. s6:get_success() .. ", pos=" .. s6:get_result_pos())
    failures = failures + 1
end

-- Test 7: Find line end (stops at ;)
local s7 = @@PhpSyntaxSkipperFsm()
local inp7 = str_to_bytes("$x = 1; next")
s7:setup(inp7, 0, #inp7)
s7:do_find_line_end()
if s7:get_result_pos() ~= 6 then
    print("FAIL 7: pos=" .. s7:get_result_pos() .. ", expected 6")
    failures = failures + 1
end

-- Test 8: Balanced parens
local s8 = @@PhpSyntaxSkipperFsm()
local inp8 = str_to_bytes("(a, f(b)) rest")
s8:setup(inp8, 0, #inp8)
s8:do_balanced_paren_end()
if s8:get_success() ~= 1 or s8:get_result_pos() ~= 9 then
    print("FAIL 8: success=" .. s8:get_success() .. ", pos=" .. s8:get_result_pos())
    failures = failures + 1
end

if failures > 0 then
    print("FAIL: " .. failures .. " failures")
    os.exit(1)
end
print("PASS: php_skipper (8 cases)")

@@[target("kotlin")]

import kotlin.system.exitProcess

// LuaSyntaxSkipper — FSM for skipping Lua comments and strings.
// Translated from framec's native_region_scanner/lua_skipper.frs
//
// Handles: -- line comments, --[[ block comments ]], [[ long strings ]],
// simple strings, Lua-style line endings.

@@system LuaSyntaxSkipperFsm {
    operations:
        setup(input_bytes: ByteArray, start: Int, length: Int) {
            this.bytes = input_bytes
            this.pos = start
            this.scan_end = length
        }
        get_result_pos(): Int {
            return this.result_pos
        }
        get_success(): Int {
            return this.success
        }

    interface:
        do_skip_comment()
        do_skip_string()
        do_find_line_end()

    machine:
        $Init {
            do_skip_comment() { -> $SkipComment }
            do_skip_string() { -> $SkipString }
            do_find_line_end() { -> $FindLineEnd }
        }

        $SkipComment {
            $>() {
                var i = this.pos
                val end = this.scan_end
                val bs = this.bytes

                // Lua line comment: --
                if (i + 1 < end && (bs[i].toInt() and 0xFF) == '-'.code && (bs[i + 1].toInt() and 0xFF) == '-'.code) {
                    // Check for block comment: --[[ ... ]]
                    if (i + 3 < end && (bs[i + 2].toInt() and 0xFF) == '['.code && (bs[i + 3].toInt() and 0xFF) == '['.code) {
                        var j = i + 4
                        while (j + 1 < end) {
                            if ((bs[j].toInt() and 0xFF) == ']'.code && (bs[j + 1].toInt() and 0xFF) == ']'.code) {
                                this.result_pos = j + 2
                                this.success = 1
                                return
                            }
                            j++
                        }
                        this.result_pos = end
                        this.success = 1
                        return
                    }
                    // Line comment
                    var j = i + 2
                    while (j < end && (bs[j].toInt() and 0xFF) != '\n'.code) {
                        j++
                    }
                    this.result_pos = j
                    this.success = 1
                    return
                }

                this.success = 0
            }
        }

        $SkipString {
            $>() {
                var i = this.pos
                val end = this.scan_end
                val bs = this.bytes

                // Long string: [[ ... ]]
                if (i + 1 < end && (bs[i].toInt() and 0xFF) == '['.code && (bs[i + 1].toInt() and 0xFF) == '['.code) {
                    var j = i + 2
                    while (j + 1 < end) {
                        if ((bs[j].toInt() and 0xFF) == ']'.code && (bs[j + 1].toInt() and 0xFF) == ']'.code) {
                            this.result_pos = j + 2
                            this.success = 1
                            return
                        }
                        j++
                    }
                    this.result_pos = end
                    this.success = 1
                    return
                }

                // Simple string: " or '
                if (i < end && ((bs[i].toInt() and 0xFF) == '"'.code || (bs[i].toInt() and 0xFF) == '\''.code)) {
                    val q = bs[i].toInt() and 0xFF
                    var j = i + 1
                    while (j < end) {
                        if ((bs[j].toInt() and 0xFF) == '\\'.code) {
                            j += 2
                            continue
                        }
                        if ((bs[j].toInt() and 0xFF) == q) {
                            this.result_pos = j + 1
                            this.success = 1
                            return
                        }
                        j++
                    }
                    this.result_pos = end
                    this.success = 1
                    return
                }

                this.success = 0
            }
        }

        $FindLineEnd {
            $>() {
                var j = this.pos
                val end = this.scan_end
                val bs = this.bytes

                while (j < end) {
                    val b = bs[j].toInt() and 0xFF
                    if (b == '\n'.code) {
                        break
                    }
                    // Stop at -- comment
                    if (b == '-'.code && j + 1 < end && (bs[j + 1].toInt() and 0xFF) == '-'.code) {
                        break
                    }
                    j++
                }

                this.result_pos = j
            }
        }

    domain:
        bytes: ByteArray = ByteArray(0)
        pos: Int = 0
        scan_end: Int = 0
        result_pos: Int = 0
        success: Int = 1
}

fun main() {
    var failures = 0

    // Test 1: Skip -- line comment
    val s1 = @@LuaSyntaxSkipperFsm()
    val inp1 = "-- comment\ncode".toByteArray()
    s1.setup(inp1, 0, inp1.size)
    s1.do_skip_comment()
    if (s1.get_success() != 1 || s1.get_result_pos() != 10) {
        println("FAIL 1: success=${s1.get_success()}, pos=${s1.get_result_pos()}")
        failures++
    }

    // Test 2: Skip --[[ block comment ]]
    val s2 = @@LuaSyntaxSkipperFsm()
    val inp2 = "--[[ block ]]code".toByteArray()
    s2.setup(inp2, 0, inp2.size)
    s2.do_skip_comment()
    if (s2.get_success() != 1 || s2.get_result_pos() != 13) {
        println("FAIL 2: success=${s2.get_success()}, pos=${s2.get_result_pos()}")
        failures++
    }

    // Test 3: Not a comment
    val s3 = @@LuaSyntaxSkipperFsm()
    val inp3 = "x + 1".toByteArray()
    s3.setup(inp3, 0, inp3.size)
    s3.do_skip_comment()
    if (s3.get_success() != 0) {
        println("FAIL 3: should not be comment")
        failures++
    }

    // Test 4: Skip [[ long string ]]
    val s4 = @@LuaSyntaxSkipperFsm()
    val inp4 = "[[hello world]]rest".toByteArray()
    s4.setup(inp4, 0, inp4.size)
    s4.do_skip_string()
    if (s4.get_success() != 1 || s4.get_result_pos() != 15) {
        println("FAIL 4: success=${s4.get_success()}, pos=${s4.get_result_pos()}")
        failures++
    }

    // Test 5: Skip simple string
    val s5 = @@LuaSyntaxSkipperFsm()
    val inp5 = "\"hello\" rest".toByteArray()
    s5.setup(inp5, 0, inp5.size)
    s5.do_skip_string()
    if (s5.get_success() != 1 || s5.get_result_pos() != 7) {
        println("FAIL 5: success=${s5.get_success()}, pos=${s5.get_result_pos()}")
        failures++
    }

    // Test 6: Find line end stops at --
    val s6 = @@LuaSyntaxSkipperFsm()
    val inp6 = "x + 1 -- comment".toByteArray()
    s6.setup(inp6, 0, inp6.size)
    s6.do_find_line_end()
    if (s6.get_result_pos() != 6) {
        println("FAIL 6: pos=${s6.get_result_pos()}, expected 6")
        failures++
    }

    if (failures > 0) {
        println("FAIL: $failures failures")
        exitProcess(1)
    }
    println("PASS: lua_skipper (6 cases)")
}

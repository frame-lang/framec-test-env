@@[target("csharp")]

using System.Text;

// RubySyntaxSkipper -- FSM for skipping Ruby comments and strings.
// Translated from framec's native_region_scanner/ruby_skipper.frs
//
// Handles: # line comments, "..." / '...' strings,
// %Q{} / %q[] / %w() etc. percent literals,
// Ruby-style line endings, balanced parens.

@@system RubySyntaxSkipperFsm {
    operations:
        setup(input_bytes: byte[], start: int, length: int) {
            this.bytes = input_bytes;
            this.pos = start;
            this.scan_end = length;
        }
        get_result_pos(): int {
            return this.result_pos;
        }
        get_success(): int {
            return this.success;
        }

    interface:
        do_skip_comment()
        do_skip_string()
        do_find_line_end()
        do_balanced_paren_end()

    machine:
        $Init {
            do_skip_comment() { -> $SkipComment }
            do_skip_string() { -> $SkipString }
            do_find_line_end() { -> $FindLineEnd }
            do_balanced_paren_end() { -> $BalancedParenEnd }
        }

        $SkipComment {
            $>() {
                int i = this.pos;
                int end = this.scan_end;
                byte[] bs = this.bytes;

                // Ruby: # line comment only
                if (i < end && bs[i] == (byte)'#') {
                    int j = i + 1;
                    while (j < end && bs[j] != (byte)'\n') {
                        j++;
                    }
                    this.result_pos = j;
                    this.success = 1;
                    return;
                }

                this.success = 0;
            }
        }

        $SkipString {
            $>() {
                int i = this.pos;
                int end = this.scan_end;
                byte[] bs = this.bytes;

                // Percent literals: %Q{...}, %q[...], %w(...), etc.
                if (i < end && bs[i] == (byte)'%') {
                    if (i + 1 < end) {
                        int c1 = bs[i + 1];
                        // Check for %Q, %q, %w, %W, %i, %I, %r, %x, %s
                        bool has_letter = (c1 == (byte)'Q' || c1 == (byte)'q' || c1 == (byte)'w' || c1 == (byte)'W' || c1 == (byte)'i' || c1 == (byte)'I' || c1 == (byte)'r' || c1 == (byte)'x' || c1 == (byte)'s');
                        int opener = 0;
                        int j = 0;
                        if (has_letter && i + 2 < end) {
                            opener = bs[i + 2];
                            j = i + 3;
                        } else if (!has_letter && !Char.IsLetterOrDigit((char)c1) && c1 != (byte)'_') {
                            // %{...} or %[...] or %<...> without letter
                            opener = c1;
                            j = i + 2;
                        } else {
                            this.success = 0;
                            return;
                        }

                        // Determine closer
                        int closer = 0;
                        if (opener == (byte)'{') {
                            closer = (byte)'}';
                        } else if (opener == (byte)'[') {
                            closer = (byte)']';
                        } else if (opener == (byte)'(') {
                            closer = (byte)')';
                        } else if (opener == (byte)'<') {
                            closer = (byte)'>';
                        } else {
                            // Non-paired delimiter (e.g. %Q!...!)
                            closer = opener;
                            // Scan to matching delimiter
                            while (j < end) {
                                if (bs[j] == (byte)'\\') {
                                    j += 2;
                                    continue;
                                }
                                if (bs[j] == closer) {
                                    this.result_pos = j + 1;
                                    this.success = 1;
                                    return;
                                }
                                j++;
                            }
                            this.result_pos = end;
                            this.success = 1;
                            return;
                        }

                        // Paired delimiter: track nesting
                        int depth = 1;
                        while (j < end && depth > 0) {
                            if (bs[j] == (byte)'\\') {
                                j += 2;
                                continue;
                            }
                            if (bs[j] == opener) {
                                depth++;
                            } else if (bs[j] == closer) {
                                depth--;
                            }
                            j++;
                        }
                        this.result_pos = j;
                        this.success = 1;
                        return;
                    }
                }

                // Simple string: " or '
                if (i < end && (bs[i] == (byte)'"' || bs[i] == (byte)'\'')) {
                    int q = bs[i];
                    int j = i + 1;
                    while (j < end) {
                        if (bs[j] == (byte)'\\') {
                            j += 2;
                            continue;
                        }
                        if (bs[j] == q) {
                            this.result_pos = j + 1;
                            this.success = 1;
                            return;
                        }
                        j++;
                    }
                    this.result_pos = end;
                    this.success = 1;
                    return;
                }

                this.success = 0;
            }
        }

        $FindLineEnd {
            $>() {
                int j = this.pos;
                int end = this.scan_end;
                byte[] bs = this.bytes;
                int in_string = 0;

                while (j < end) {
                    int b = bs[j];
                    if (b == (byte)'\n') {
                        break;
                    }

                    // Inside string
                    if (in_string != 0) {
                        if (b == (byte)'\\') {
                            j += 2;
                            continue;
                        }
                        if (b == in_string) {
                            in_string = 0;
                        }
                        j++;
                        continue;
                    }

                    // Terminators
                    if (b == (byte)'#') {
                        break;
                    }

                    // String starts
                    if (b == (byte)'\'' || b == (byte)'"') {
                        in_string = b;
                        j++;
                        continue;
                    }

                    j++;
                }

                this.result_pos = j;
            }
        }

        $BalancedParenEnd {
            $>() {
                int i = this.pos;
                int end = this.scan_end;
                byte[] bs = this.bytes;

                if (i >= end || bs[i] != (byte)'(') {
                    this.success = 0;
                    return;
                }

                int depth = 0;
                int in_string = 0;

                while (i < end) {
                    int b = bs[i];

                    // Inside string
                    if (in_string != 0) {
                        if (b == (byte)'\\') {
                            i += 2;
                            continue;
                        }
                        if (b == in_string) {
                            in_string = 0;
                        }
                        i++;
                        continue;
                    }

                    if (b == (byte)'\'' || b == (byte)'"') {
                        in_string = b;
                        i++;
                    } else if (b == (byte)'(') {
                        depth++;
                        i++;
                    } else if (b == (byte)')') {
                        depth--;
                        i++;
                        if (depth == 0) {
                            this.result_pos = i;
                            this.success = 1;
                            return;
                        }
                    } else {
                        i++;
                    }
                }

                this.success = 0;
            }
        }

    domain:
        bytes: byte[] = null
        pos: int = 0
        scan_end: int = 0
        result_pos: int = 0
        success: int = 1
}

class Program {
    static void Main(string[] args) {
        int failures = 0;

        // Test 1: Skip # comment
        var s1 = @@RubySyntaxSkipperFsm();
        byte[] inp1 = Encoding.UTF8.GetBytes("# comment\ncode");
        s1.setup(inp1, 0, inp1.Length);
        s1.do_skip_comment();
        if ((int)s1.get_success() != 1 || (int)s1.get_result_pos() != 9) {
            Console.WriteLine("FAIL 1: success=" + s1.get_success() + ", pos=" + s1.get_result_pos());
            failures++;
        }

        // Test 2: Skip double-quoted string
        var s2 = @@RubySyntaxSkipperFsm();
        byte[] inp2 = Encoding.UTF8.GetBytes("\"hello\" rest");
        s2.setup(inp2, 0, inp2.Length);
        s2.do_skip_string();
        if ((int)s2.get_success() != 1 || (int)s2.get_result_pos() != 7) {
            Console.WriteLine("FAIL 2: success=" + s2.get_success() + ", pos=" + s2.get_result_pos());
            failures++;
        }

        // Test 3: Skip single-quoted string
        var s3 = @@RubySyntaxSkipperFsm();
        byte[] inp3 = Encoding.UTF8.GetBytes("'hello' rest");
        s3.setup(inp3, 0, inp3.Length);
        s3.do_skip_string();
        if ((int)s3.get_success() != 1 || (int)s3.get_result_pos() != 7) {
            Console.WriteLine("FAIL 3: success=" + s3.get_success() + ", pos=" + s3.get_result_pos());
            failures++;
        }

        // Test 4: Skip %Q{text}
        var s4 = @@RubySyntaxSkipperFsm();
        byte[] inp4 = Encoding.UTF8.GetBytes("%Q{text} rest");
        s4.setup(inp4, 0, inp4.Length);
        s4.do_skip_string();
        if ((int)s4.get_success() != 1 || (int)s4.get_result_pos() != 8) {
            Console.WriteLine("FAIL 4: success=" + s4.get_success() + ", pos=" + s4.get_result_pos());
            failures++;
        }

        // Test 5: Skip %q[text]
        var s5 = @@RubySyntaxSkipperFsm();
        byte[] inp5 = Encoding.UTF8.GetBytes("%q[text] rest");
        s5.setup(inp5, 0, inp5.Length);
        s5.do_skip_string();
        if ((int)s5.get_success() != 1 || (int)s5.get_result_pos() != 8) {
            Console.WriteLine("FAIL 5: success=" + s5.get_success() + ", pos=" + s5.get_result_pos());
            failures++;
        }

        // Test 6: Find line end (stops at #)
        var s6 = @@RubySyntaxSkipperFsm();
        byte[] inp6 = Encoding.UTF8.GetBytes("x + 1 # comment");
        s6.setup(inp6, 0, inp6.Length);
        s6.do_find_line_end();
        if ((int)s6.get_result_pos() != 6) {
            Console.WriteLine("FAIL 6: pos=" + s6.get_result_pos() + ", expected 6");
            failures++;
        }

        // Test 7: Balanced parens
        var s7 = @@RubySyntaxSkipperFsm();
        byte[] inp7 = Encoding.UTF8.GetBytes("(a, f(b)) rest");
        s7.setup(inp7, 0, inp7.Length);
        s7.do_balanced_paren_end();
        if ((int)s7.get_success() != 1 || (int)s7.get_result_pos() != 9) {
            Console.WriteLine("FAIL 7: success=" + s7.get_success() + ", pos=" + s7.get_result_pos());
            failures++;
        }

        // Test 8: Skip %Q with nested braces
        var s8 = @@RubySyntaxSkipperFsm();
        byte[] inp8 = Encoding.UTF8.GetBytes("%Q{outer {inner} end} rest");
        s8.setup(inp8, 0, inp8.Length);
        s8.do_skip_string();
        if ((int)s8.get_success() != 1 || (int)s8.get_result_pos() != 21) {
            Console.WriteLine("FAIL 8: success=" + s8.get_success() + ", pos=" + s8.get_result_pos());
            failures++;
        }

        if (failures > 0) {
            Console.WriteLine("FAIL: " + failures + " failures");
            Environment.Exit(1);
        }
        Console.WriteLine("PASS: ruby_skipper (8 cases)");
    }
}

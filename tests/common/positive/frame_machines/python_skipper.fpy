@@[target("python_3")]

# PythonSyntaxSkipper — FSM for skipping Python comments and strings.
# Translated from framec's native_region_scanner/python_skipper.frs
#
# Handles: # comments, triple-quoted strings, simple strings,
# Python-style line endings, balanced parens.

@@system PythonSyntaxSkipperFsm {
    operations:
        setup(input_bytes: list, start: int, length: int) {
            self.bytes = input_bytes
            self.pos = start
            self.scan_end = length
        }
        get_result_pos(): int {
            return self.result_pos
        }
        get_success(): int {
            return self.success
        }

    interface:
        do_skip_comment()
        do_skip_string()
        do_find_line_end()
        do_balanced_paren_end()

    machine:
        $Init {
            do_skip_comment() { -> $SkipComment }
            do_skip_string() { -> $SkipString }
            do_find_line_end() { -> $FindLineEnd }
            do_balanced_paren_end() { -> $BalancedParenEnd }
        }

        $SkipComment {
            $>() {
                i = self.pos
                end = self.scan_end
                bs = self.bytes

                # Python uses # for line comments
                if i < end and bs[i] == ord('#'):
                    j = i + 1
                    while j < end and bs[j] != ord('\n'):
                        j += 1
                    self.result_pos = j
                    self.success = 1
                    return

                self.success = 0
            }
        }

        $SkipString {
            $>() {
                i = self.pos
                end = self.scan_end
                bs = self.bytes

                # Triple-quoted strings: """ or '''
                if i + 2 < end:
                    if (bs[i] == ord('"') and bs[i+1] == ord('"') and bs[i+2] == ord('"')) or \
                       (bs[i] == ord("'") and bs[i+1] == ord("'") and bs[i+2] == ord("'")):
                        q = bs[i]
                        j = i + 3
                        while j + 2 < end:
                            if bs[j] == q and bs[j+1] == q and bs[j+2] == q:
                                self.result_pos = j + 3
                                self.success = 1
                                return
                            j += 1
                        self.result_pos = end
                        self.success = 1
                        return

                # Simple strings: " or '
                if i < end and (bs[i] == ord('"') or bs[i] == ord("'")):
                    q = bs[i]
                    j = i + 1
                    while j < end:
                        if bs[j] == ord('\\'):
                            j += 2
                            continue
                        if bs[j] == q:
                            self.result_pos = j + 1
                            self.success = 1
                            return
                        j += 1
                    self.result_pos = end
                    self.success = 1
                    return

                self.success = 0
            }
        }

        $FindLineEnd {
            $>() {
                j = self.pos
                end = self.scan_end
                bs = self.bytes

                while j < end:
                    b = bs[j]
                    if b == ord('\n') or b == ord(';'):
                        break
                    # Stop at # comment
                    if b == ord('#'):
                        break
                    j += 1

                self.result_pos = j
            }
        }

        $BalancedParenEnd {
            $>() {
                i = self.pos
                end = self.scan_end
                bs = self.bytes

                if i >= end or bs[i] != ord('('):
                    self.success = 0
                    return

                depth = 1
                j = i + 1
                while j < end and depth > 0:
                    b = bs[j]
                    if b == ord('('):
                        depth += 1
                    elif b == ord(')'):
                        depth -= 1
                    elif b == ord('"') or b == ord("'"):
                        q = b
                        j += 1
                        while j < end and bs[j] != q:
                            if bs[j] == ord('\\'):
                                j += 1
                            j += 1
                    j += 1

                if depth == 0:
                    self.result_pos = j
                    self.success = 1
                else:
                    self.result_pos = end
                    self.success = 0
            }
        }

    domain:
        bytes: list = []
        pos: int = 0
        scan_end: int = 0
        result_pos: int = 0
        success: int = 1
}

if __name__ == '__main__':
    failures = 0

    # Test 1: Skip hash comment
    s1 = @@PythonSyntaxSkipperFsm()
    inp1 = list(b"# comment\ncode")
    s1.setup(inp1, 0, len(inp1))
    s1.do_skip_comment()
    if s1.get_success() != 1 or s1.get_result_pos() != 9:
        print(f"FAIL 1: success={s1.get_success()}, pos={s1.get_result_pos()}")
        failures += 1

    # Test 2: Not a comment
    s2 = @@PythonSyntaxSkipperFsm()
    inp2 = list(b"x + 1")
    s2.setup(inp2, 0, len(inp2))
    s2.do_skip_comment()
    if s2.get_success() != 0:
        print(f"FAIL 2: should not be comment")
        failures += 1

    # Test 3: Skip triple-quoted string
    s3 = @@PythonSyntaxSkipperFsm()
    inp3 = list(b'"""hello world"""rest')
    s3.setup(inp3, 0, len(inp3))
    s3.do_skip_string()
    if s3.get_success() != 1 or s3.get_result_pos() != 17:
        print(f"FAIL 3: success={s3.get_success()}, pos={s3.get_result_pos()}")
        failures += 1

    # Test 4: Skip simple string
    s4 = @@PythonSyntaxSkipperFsm()
    inp4 = list(b'"hello" rest')
    s4.setup(inp4, 0, len(inp4))
    s4.do_skip_string()
    if s4.get_success() != 1 or s4.get_result_pos() != 7:
        print(f"FAIL 4: success={s4.get_success()}, pos={s4.get_result_pos()}")
        failures += 1

    # Test 5: Skip string with escape
    s5 = @@PythonSyntaxSkipperFsm()
    inp5 = list(b"'he\\'llo' rest")
    s5.setup(inp5, 0, len(inp5))
    s5.do_skip_string()
    if s5.get_success() != 1 or s5.get_result_pos() != 9:
        print(f"FAIL 5: success={s5.get_success()}, pos={s5.get_result_pos()}")
        failures += 1

    # Test 6: Find line end (stops at #)
    s6 = @@PythonSyntaxSkipperFsm()
    inp6 = list(b"x + 1 # comment")
    s6.setup(inp6, 0, len(inp6))
    s6.do_find_line_end()
    if s6.get_result_pos() != 6:
        print(f"FAIL 6: pos={s6.get_result_pos()}, expected 6")
        failures += 1

    # Test 7: Balanced parens
    s7 = @@PythonSyntaxSkipperFsm()
    inp7 = list(b"(a, f(b)) rest")
    s7.setup(inp7, 0, len(inp7))
    s7.do_balanced_paren_end()
    if s7.get_success() != 1 or s7.get_result_pos() != 9:
        print(f"FAIL 7: success={s7.get_success()}, pos={s7.get_result_pos()}")
        failures += 1

    if failures > 0:
        print(f"FAIL: {failures} failures")
        exit(1)
    print("PASS: python_skipper (7 cases)")

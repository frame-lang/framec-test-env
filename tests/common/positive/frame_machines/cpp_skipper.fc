@@target c

#include <string.h>

// cpp_skipper -- FSM for skipping syntax constructs.

@@system CppSyntaxSkipperFsm {
    operations:
        setup(input_bytes: unsigned char*, start: int, length: int) {
            self->bytes = input_bytes;
            self->pos = start;
            self->scan_end = length;
        }
        get_result_pos(): int {
            return self->result_pos;
        }
        get_success(): int {
            return self->success;
        }

    interface:
        do_skip_comment()
        do_skip_string()
        do_find_line_end()
        do_balanced_paren_end()

    machine:
        $Init {
            do_skip_comment() { -> $SkipComment }
            do_skip_string() { -> $SkipString }
            do_find_line_end() { -> $FindLineEnd }
            do_balanced_paren_end() { -> $BalancedParenEnd }
        }

        $SkipComment {
            $>() {
                int i = self->pos;
                int end = self->scan_end;
                unsigned char* bs = self->bytes;

                if (i + 1 < end && bs[i] == '/' && bs[i + 1] == '/') {
                    int j = i + 2;
                    while (j < end && bs[j] != '\n') { j++; }
                    self->result_pos = j;
                    self->success = 1;
                    return;
                }

                if (i + 1 < end && bs[i] == '/' && bs[i + 1] == '*') {
                    int j = i + 2;
                    while (j + 1 < end) {
                        if (bs[j] == '*' && bs[j + 1] == '/') {
                            self->result_pos = j + 2;
                            self->success = 1;
                            return;
                        }
                        j++;
                    }
                    self->result_pos = end;
                    self->success = 1;
                    return;
                }

                self->success = 0;
            }
        }

        $SkipString {
            $>() {
                int i = self->pos;
                int end = self->scan_end;
                unsigned char* bs = self->bytes;

                // C++ raw string: R"delim(...)delim"
                if (i + 1 < end && bs[i] == 'R' && bs[i + 1] == '"') {
                    int j = i + 2;
                    unsigned char delim[33];
                    int dlen = 0;
                    while (j < end && bs[j] != '(') {
                        delim[dlen] = bs[j]; dlen++; j++;
                        if (dlen > 32) { self->success = 0; return; }
                    }
                    if (j >= end || bs[j] != '(') { self->success = 0; return; }
                    j++;
                    while (j < end) {
                        if (bs[j] == ')') {
                            int k = j + 1; int m = 0;
                            while (m < dlen && k < end && bs[k] == delim[m]) { k++; m++; }
                            if (m == dlen && k < end && bs[k] == '"') {
                                self->result_pos = k + 1;
                                self->success = 1;
                                return;
                            }
                        }
                        j++;
                    }
                    self->result_pos = end;
                    self->success = 1;
                    return;
                }

                if (i < end && (bs[i] == '"' || bs[i] == '\'')) {
                    char q = bs[i];
                    int j = i + 1;
                    while (j < end) {
                        if (bs[j] == '\\') { j += 2; continue; }
                        if (bs[j] == q) {
                            self->result_pos = j + 1;
                            self->success = 1;
                            return;
                        }
                        j++;
                    }
                    self->result_pos = end;
                    self->success = 1;
                    return;
                }

                self->success = 0;
            }
        }

        $FindLineEnd {
            $>() {
                int j = self->pos;
                int end = self->scan_end;
                unsigned char* bs = self->bytes;

                while (j < end) {
                    char b = bs[j];
                    if (b == '\n' || b == ';') { break; }
                    if (b == '/' && j + 1 < end && bs[j + 1] == '/') { break; }
                    if (b == '/' && j + 1 < end && bs[j + 1] == '*') { break; }
                    j++;
                }

                self->result_pos = j;
            }
        }

        $BalancedParenEnd {
            $>() {
                int i = self->pos;
                int end = self->scan_end;
                unsigned char* bs = self->bytes;

                if (i >= end || bs[i] != '(') {
                    self->success = 0;
                    return;
                }

                int depth = 1;
                int j = i + 1;
                while (j < end && depth > 0) {
                    char b = bs[j];
                    if (b == '(') { depth++; }
                    else if (b == ')') { depth--; }
                    else if (b == '"' || b == '\'') {
                        char q = b;
                        j++;
                        while (j < end && bs[j] != q) {
                            if (bs[j] == '\\') { j++; }
                            j++;
                        }
                    }
                    j++;
                }

                if (depth == 0) { self->result_pos = j; self->success = 1; }
                else { self->result_pos = end; self->success = 0; }
            }
        }

    domain:
        bytes: unsigned char* = NULL
        pos: int = 0
        scan_end: int = 0
        result_pos: int = 0
        success: int = 1
}

int main() {
    int failures = 0;

    // Test 1: Skip line comment
    CppSyntaxSkipperFsm* s1 = @@CppSyntaxSkipperFsm();
    unsigned char t1[] = "// hello\ncode";
    CppSyntaxSkipperFsm_setup(s1, t1, 0, strlen((char*)t1));
    CppSyntaxSkipperFsm_do_skip_comment(s1);
    if (CppSyntaxSkipperFsm_get_success(s1) != 1 || CppSyntaxSkipperFsm_get_result_pos(s1) != 8) {
        printf("FAIL 1: Skip line comment\n");
        failures++;
    }
    // Test 2: Skip block comment
    CppSyntaxSkipperFsm* s2 = @@CppSyntaxSkipperFsm();
    unsigned char t2[] = "/* block */code";
    CppSyntaxSkipperFsm_setup(s2, t2, 0, strlen((char*)t2));
    CppSyntaxSkipperFsm_do_skip_comment(s2);
    if (CppSyntaxSkipperFsm_get_success(s2) != 1 || CppSyntaxSkipperFsm_get_result_pos(s2) != 11) {
        printf("FAIL 2: Skip block comment\n");
        failures++;
    }
    // Test 3: Skip double-quoted string
    CppSyntaxSkipperFsm* s3 = @@CppSyntaxSkipperFsm();
    unsigned char t3[] = "\"hello world\" rest";
    CppSyntaxSkipperFsm_setup(s3, t3, 0, strlen((char*)t3));
    CppSyntaxSkipperFsm_do_skip_string(s3);
    if (CppSyntaxSkipperFsm_get_success(s3) != 1 || CppSyntaxSkipperFsm_get_result_pos(s3) != 13) {
        printf("FAIL 3: Skip double-quoted string\n");
        failures++;
    }
    // Test 4: C++ raw string R"(raw)"
    CppSyntaxSkipperFsm* s4 = @@CppSyntaxSkipperFsm();
    unsigned char t4[] = "R\"(raw string)\" rest";
    CppSyntaxSkipperFsm_setup(s4, t4, 0, strlen((char*)t4));
    CppSyntaxSkipperFsm_do_skip_string(s4);
    if (CppSyntaxSkipperFsm_get_success(s4) != 1 || CppSyntaxSkipperFsm_get_result_pos(s4) != 15) {
        printf("FAIL 4: C++ raw string\n");
        failures++;
    }
    // Test 5: C++ raw string with delimiter
    CppSyntaxSkipperFsm* s5 = @@CppSyntaxSkipperFsm();
    unsigned char t5[] = "R\"xyz(raw content)xyz\" rest";
    CppSyntaxSkipperFsm_setup(s5, t5, 0, strlen((char*)t5));
    CppSyntaxSkipperFsm_do_skip_string(s5);
    if (CppSyntaxSkipperFsm_get_success(s5) != 1 || CppSyntaxSkipperFsm_get_result_pos(s5) != 22) {
        printf("FAIL 5: C++ raw string with delimiter\n");
        failures++;
    }
    // Test 6: Find line end
    CppSyntaxSkipperFsm* s6 = @@CppSyntaxSkipperFsm();
    unsigned char t6[] = "x + 1\nmore";
    CppSyntaxSkipperFsm_setup(s6, t6, 0, strlen((char*)t6));
    CppSyntaxSkipperFsm_do_find_line_end(s6);
    if (CppSyntaxSkipperFsm_get_result_pos(s6) != 5) {
        printf("FAIL 6: Find line end\n");
        failures++;
    }
    // Test 7: Not a comment
    CppSyntaxSkipperFsm* s7 = @@CppSyntaxSkipperFsm();
    unsigned char t7[] = "x + 1";
    CppSyntaxSkipperFsm_setup(s7, t7, 0, strlen((char*)t7));
    CppSyntaxSkipperFsm_do_skip_comment(s7);
    if (CppSyntaxSkipperFsm_get_success(s7) != 0) {
        printf("FAIL 7: Not a comment\n");
        failures++;
    }
    // Test 8: Balanced parens
    CppSyntaxSkipperFsm* s8 = @@CppSyntaxSkipperFsm();
    unsigned char t8[] = "(a, f(b), c) rest";
    CppSyntaxSkipperFsm_setup(s8, t8, 0, strlen((char*)t8));
    CppSyntaxSkipperFsm_do_balanced_paren_end(s8);
    if (CppSyntaxSkipperFsm_get_success(s8) != 1 || CppSyntaxSkipperFsm_get_result_pos(s8) != 12) {
        printf("FAIL 8: Balanced parens\n");
        failures++;
    }

    CppSyntaxSkipperFsm_destroy(s1);
    CppSyntaxSkipperFsm_destroy(s2);
    CppSyntaxSkipperFsm_destroy(s3);
    CppSyntaxSkipperFsm_destroy(s4);
    CppSyntaxSkipperFsm_destroy(s5);
    CppSyntaxSkipperFsm_destroy(s6);
    CppSyntaxSkipperFsm_destroy(s7);
    CppSyntaxSkipperFsm_destroy(s8);

    if (failures > 0) {
        printf("FAIL: %d failures\n", failures);
        return 1;
    }
    printf("PASS: cpp_skipper (8 cases)\n");
    return 0;
}

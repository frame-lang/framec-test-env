@@[target("python_3")]

# RubySyntaxSkipper -- FSM for skipping Ruby comments and strings.
# Translated from framec's native_region_scanner/ruby_skipper.frs
#
# Handles: # line comments, "..." / '...' strings,
# %Q{} / %q[] / %w() etc. percent literals,
# Ruby-style line endings, balanced parens.

@@system RubySyntaxSkipperFsm {
    operations:
        setup(input_bytes: list, start: int, length: int) {
            self.bytes = input_bytes
            self.pos = start
            self.scan_end = length
        }
        get_result_pos(): int {
            return self.result_pos
        }
        get_success(): int {
            return self.success
        }

    interface:
        do_skip_comment()
        do_skip_string()
        do_find_line_end()
        do_balanced_paren_end()

    machine:
        $Init {
            do_skip_comment() { -> $SkipComment }
            do_skip_string() { -> $SkipString }
            do_find_line_end() { -> $FindLineEnd }
            do_balanced_paren_end() { -> $BalancedParenEnd }
        }

        $SkipComment {
            $>() {
                i = self.pos
                end = self.scan_end
                bs = self.bytes

                # Ruby: # line comment only
                if i < end and bs[i] == ord('#'):
                    j = i + 1
                    while j < end and bs[j] != ord('\n'):
                        j += 1
                    self.result_pos = j
                    self.success = 1
                    return

                self.success = 0
            }
        }

        $SkipString {
            $>() {
                i = self.pos
                end = self.scan_end
                bs = self.bytes

                # Percent literals: %Q{...}, %q[...], %w(...), etc.
                if i < end and bs[i] == ord('%'):
                    if i + 1 < end:
                        c1 = bs[i + 1]
                        # Check for %Q, %q, %w, %W, %i, %I, %r, %x, %s
                        has_letter = (c1 == ord('Q') or c1 == ord('q') or c1 == ord('w') or c1 == ord('W') or c1 == ord('i') or c1 == ord('I') or c1 == ord('r') or c1 == ord('x') or c1 == ord('s'))
                        if has_letter and i + 2 < end:
                            opener = bs[i + 2]
                            j = i + 3
                        elif not chr(c1).isalnum() and c1 != ord('_'):
                            # %{...} or %[...] or %<...> without letter
                            opener = c1
                            j = i + 2
                        else:
                            self.success = 0
                            return

                        # Determine closer
                        if opener == ord('{'):
                            closer = ord('}')
                        elif opener == ord('['):
                            closer = ord(']')
                        elif opener == ord('('):
                            closer = ord(')')
                        elif opener == ord('<'):
                            closer = ord('>')
                        else:
                            # Non-paired delimiter (e.g. %Q!...!)
                            closer = opener
                            # Scan to matching delimiter
                            while j < end:
                                if bs[j] == ord('\\'):
                                    j += 2
                                    continue
                                if bs[j] == closer:
                                    self.result_pos = j + 1
                                    self.success = 1
                                    return
                                j += 1
                            self.result_pos = end
                            self.success = 1
                            return

                        # Paired delimiter: track nesting
                        depth = 1
                        while j < end and depth > 0:
                            if bs[j] == ord('\\'):
                                j += 2
                                continue
                            if bs[j] == opener:
                                depth += 1
                            elif bs[j] == closer:
                                depth -= 1
                            j += 1
                        self.result_pos = j
                        self.success = 1
                        return

                # Simple string: " or '
                if i < end and (bs[i] == ord('"') or bs[i] == ord("'")):
                    q = bs[i]
                    j = i + 1
                    while j < end:
                        if bs[j] == ord('\\'):
                            j += 2
                            continue
                        if bs[j] == q:
                            self.result_pos = j + 1
                            self.success = 1
                            return
                        j += 1
                    self.result_pos = end
                    self.success = 1
                    return

                self.success = 0
            }
        }

        $FindLineEnd {
            $>() {
                j = self.pos
                end = self.scan_end
                bs = self.bytes
                in_string = 0

                while j < end:
                    b = bs[j]
                    if b == ord('\n'):
                        break

                    # Inside string
                    if in_string != 0:
                        if b == ord('\\'):
                            j += 2
                            continue
                        if b == in_string:
                            in_string = 0
                        j += 1
                        continue

                    # Terminators
                    if b == ord('#'):
                        break

                    # String starts
                    if b == ord("'") or b == ord('"'):
                        in_string = b
                        j += 1
                        continue

                    j += 1

                self.result_pos = j
            }
        }

        $BalancedParenEnd {
            $>() {
                i = self.pos
                end = self.scan_end
                bs = self.bytes

                if i >= end or bs[i] != ord('('):
                    self.success = 0
                    return

                depth = 0
                in_string = 0

                while i < end:
                    b = bs[i]

                    # Inside string
                    if in_string != 0:
                        if b == ord('\\'):
                            i += 2
                            continue
                        if b == in_string:
                            in_string = 0
                        i += 1
                        continue

                    if b == ord("'") or b == ord('"'):
                        in_string = b
                        i += 1
                    elif b == ord('('):
                        depth += 1
                        i += 1
                    elif b == ord(')'):
                        depth -= 1
                        i += 1
                        if depth == 0:
                            self.result_pos = i
                            self.success = 1
                            return
                    else:
                        i += 1

                self.success = 0
            }
        }

    domain:
        bytes: list = []
        pos: int = 0
        scan_end: int = 0
        result_pos: int = 0
        success: int = 1
}

if __name__ == '__main__':
    failures = 0

    # Test 1: Skip # comment
    s1 = @@RubySyntaxSkipperFsm()
    inp1 = list(b"# comment\ncode")
    s1.setup(inp1, 0, len(inp1))
    s1.do_skip_comment()
    if s1.get_success() != 1 or s1.get_result_pos() != 9:
        print(f"FAIL 1: success={s1.get_success()}, pos={s1.get_result_pos()}")
        failures += 1

    # Test 2: Skip double-quoted string
    s2 = @@RubySyntaxSkipperFsm()
    inp2 = list(b'"hello" rest')
    s2.setup(inp2, 0, len(inp2))
    s2.do_skip_string()
    if s2.get_success() != 1 or s2.get_result_pos() != 7:
        print(f"FAIL 2: success={s2.get_success()}, pos={s2.get_result_pos()}")
        failures += 1

    # Test 3: Skip single-quoted string
    s3 = @@RubySyntaxSkipperFsm()
    inp3 = list(b"'hello' rest")
    s3.setup(inp3, 0, len(inp3))
    s3.do_skip_string()
    if s3.get_success() != 1 or s3.get_result_pos() != 7:
        print(f"FAIL 3: success={s3.get_success()}, pos={s3.get_result_pos()}")
        failures += 1

    # Test 4: Skip %Q{text}
    s4 = @@RubySyntaxSkipperFsm()
    inp4 = list(b"%Q{text} rest")
    s4.setup(inp4, 0, len(inp4))
    s4.do_skip_string()
    if s4.get_success() != 1 or s4.get_result_pos() != 8:
        print(f"FAIL 4: success={s4.get_success()}, pos={s4.get_result_pos()}")
        failures += 1

    # Test 5: Skip %q[text]
    s5 = @@RubySyntaxSkipperFsm()
    inp5 = list(b"%q[text] rest")
    s5.setup(inp5, 0, len(inp5))
    s5.do_skip_string()
    if s5.get_success() != 1 or s5.get_result_pos() != 8:
        print(f"FAIL 5: success={s5.get_success()}, pos={s5.get_result_pos()}")
        failures += 1

    # Test 6: Find line end (stops at #)
    s6 = @@RubySyntaxSkipperFsm()
    inp6 = list(b"x + 1 # comment")
    s6.setup(inp6, 0, len(inp6))
    s6.do_find_line_end()
    if s6.get_result_pos() != 6:
        print(f"FAIL 6: pos={s6.get_result_pos()}, expected 6")
        failures += 1

    # Test 7: Balanced parens
    s7 = @@RubySyntaxSkipperFsm()
    inp7 = list(b"(a, f(b)) rest")
    s7.setup(inp7, 0, len(inp7))
    s7.do_balanced_paren_end()
    if s7.get_success() != 1 or s7.get_result_pos() != 9:
        print(f"FAIL 7: success={s7.get_success()}, pos={s7.get_result_pos()}")
        failures += 1

    # Test 8: Skip %Q with nested braces
    s8 = @@RubySyntaxSkipperFsm()
    inp8 = list(b"%Q{outer {inner} end} rest")
    s8.setup(inp8, 0, len(inp8))
    s8.do_skip_string()
    if s8.get_success() != 1 or s8.get_result_pos() != 21:
        print(f"FAIL 8: success={s8.get_success()}, pos={s8.get_result_pos()}")
        failures += 1

    if failures > 0:
        print(f"FAIL: {failures} failures")
        exit(1)
    print("PASS: ruby_skipper (8 cases)")

@@[target("typescript")]

// PhpSyntaxSkipper -- FSM for skipping PHP comments and strings.
// Translated from framec's native_region_scanner/php_skipper.frs
//
// Handles: // line comments, # line comments, /* */ block comments,
// "..." and '...' strings, <<<EOT heredoc/nowdoc,
// PHP-style line endings, balanced parens.

@@system PhpSyntaxSkipperFsm {
    operations:
        setup(input_bytes: number[], start: number, length: number) {
            this.bytes = input_bytes;
            this.pos = start;
            this.scan_end = length;
        }
        get_result_pos(): number {
            return this.result_pos;
        }
        get_success(): number {
            return this.success;
        }

    interface:
        do_skip_comment()
        do_skip_string()
        do_find_line_end()
        do_balanced_paren_end()

    machine:
        $Init {
            do_skip_comment() { -> $SkipComment }
            do_skip_string() { -> $SkipString }
            do_find_line_end() { -> $FindLineEnd }
            do_balanced_paren_end() { -> $BalancedParenEnd }
        }

        $SkipComment {
            $>() {
                let i = this.pos;
                const end = this.scan_end;
                const bs = this.bytes;

                // Line comment: //
                if (i + 1 < end && bs[i] === 0x2F && bs[i + 1] === 0x2F) {
                    let j = i + 2;
                    while (j < end && bs[j] !== 0x0A) {
                        j++;
                    }
                    this.result_pos = j;
                    this.success = 1;
                    return;
                }

                // Hash comment: #
                if (i < end && bs[i] === 0x23) {
                    let j = i + 1;
                    while (j < end && bs[j] !== 0x0A) {
                        j++;
                    }
                    this.result_pos = j;
                    this.success = 1;
                    return;
                }

                // Block comment: /* ... */
                if (i + 1 < end && bs[i] === 0x2F && bs[i + 1] === 0x2A) {
                    let j = i + 2;
                    while (j + 1 < end) {
                        if (bs[j] === 0x2A && bs[j + 1] === 0x2F) {
                            this.result_pos = j + 2;
                            this.success = 1;
                            return;
                        }
                        j++;
                    }
                    this.result_pos = end;
                    this.success = 1;
                    return;
                }

                this.success = 0;
            }
        }

        $SkipString {
            $>() {
                let i = this.pos;
                const end = this.scan_end;
                const bs = this.bytes;

                // Heredoc/nowdoc: <<<EOT ... EOT;
                if (i + 2 < end && bs[i] === 0x3C && bs[i + 1] === 0x3C && bs[i + 2] === 0x3C) {
                    let j = i + 3;
                    // Skip optional quote for nowdoc
                    let nowdoc = 0;
                    if (j < end && bs[j] === 0x27) {
                        nowdoc = 1;
                        j++;
                    }
                    // Read tag name
                    const tag_start = j;
                    while (j < end && ((bs[j] >= 0x30 && bs[j] <= 0x39) || (bs[j] >= 0x41 && bs[j] <= 0x5A) || (bs[j] >= 0x61 && bs[j] <= 0x7A) || bs[j] === 0x5F)) {
                        j++;
                    }
                    const tag_end = j;
                    if (nowdoc && j < end && bs[j] === 0x27) {
                        j++;
                    }
                    const tag = bs.slice(tag_start, tag_end);
                    const tag_len = tag.length;
                    if (tag_len > 0) {
                        // Skip to newline
                        while (j < end && bs[j] !== 0x0A) {
                            j++;
                        }
                        if (j < end) {
                            j++;
                        }
                        // Scan for closing tag at start of line
                        while (j < end) {
                            // Check if this line starts with the tag
                            if (j + tag_len <= end) {
                                let match = true;
                                for (let t = 0; t < tag_len; t++) {
                                    if (bs[j + t] !== tag[t]) {
                                        match = false;
                                        break;
                                    }
                                }
                                if (match) {
                                    let k = j + tag_len;
                                    // Optional ; and newline
                                    if (k < end && bs[k] === 0x3B) {
                                        k++;
                                    }
                                    if (k >= end || bs[k] === 0x0A) {
                                        if (k < end && bs[k] === 0x0A) {
                                            k++;
                                        }
                                        this.result_pos = k;
                                        this.success = 1;
                                        return;
                                    }
                                }
                            }
                            // Skip to next line
                            while (j < end && bs[j] !== 0x0A) {
                                j++;
                            }
                            if (j < end) {
                                j++;
                            }
                        }
                        this.result_pos = end;
                        this.success = 1;
                        return;
                    }
                }

                // Simple string: " or '
                if (i < end && (bs[i] === 0x22 || bs[i] === 0x27)) {
                    const q = bs[i];
                    let j = i + 1;
                    while (j < end) {
                        if (bs[j] === 0x5C) {
                            j += 2;
                            continue;
                        }
                        if (bs[j] === q) {
                            this.result_pos = j + 1;
                            this.success = 1;
                            return;
                        }
                        j++;
                    }
                    this.result_pos = end;
                    this.success = 1;
                    return;
                }

                this.success = 0;
            }
        }

        $FindLineEnd {
            $>() {
                let j = this.pos;
                const end = this.scan_end;
                const bs = this.bytes;
                let in_string = 0;

                while (j < end) {
                    const b = bs[j];
                    if (b === 0x0A) {
                        break;
                    }

                    // Inside string
                    if (in_string !== 0) {
                        if (b === 0x5C) {
                            j += 2;
                            continue;
                        }
                        if (b === in_string) {
                            in_string = 0;
                        }
                        j++;
                        continue;
                    }

                    // Terminators
                    if (b === 0x3B || b === 0x7D) {
                        break;
                    }
                    if (b === 0x2F && j + 1 < end && (bs[j + 1] === 0x2F || bs[j + 1] === 0x2A)) {
                        break;
                    }
                    if (b === 0x23) {
                        break;
                    }

                    // String starts
                    if (b === 0x27 || b === 0x22) {
                        in_string = b;
                        j++;
                        continue;
                    }

                    j++;
                }

                this.result_pos = j;
            }
        }

        $BalancedParenEnd {
            $>() {
                let i = this.pos;
                const end = this.scan_end;
                const bs = this.bytes;

                if (i >= end || bs[i] !== 0x28) {
                    this.success = 0;
                    return;
                }

                let depth = 0;
                let in_string = 0;

                while (i < end) {
                    const b = bs[i];

                    // Inside string
                    if (in_string !== 0) {
                        if (b === 0x5C) {
                            i += 2;
                            continue;
                        }
                        if (b === in_string) {
                            in_string = 0;
                        }
                        i++;
                        continue;
                    }

                    if (b === 0x27 || b === 0x22) {
                        in_string = b;
                        i++;
                    } else if (b === 0x28) {
                        depth++;
                        i++;
                    } else if (b === 0x29) {
                        depth--;
                        i++;
                        if (depth === 0) {
                            this.result_pos = i;
                            this.success = 1;
                            return;
                        }
                    } else {
                        i++;
                    }
                }

                this.success = 0;
            }
        }

    domain:
        bytes: number[] = []
        pos: number = 0
        scan_end: number = 0
        result_pos: number = 0
        success: number = 1
}

const enc = (s: string) => Array.from(Buffer.from(s));

let failures = 0;

// Test 1: Skip // line comment
const s1 = @@PhpSyntaxSkipperFsm();
const inp1 = enc("// comment\ncode");
s1.setup(inp1, 0, inp1.length);
s1.do_skip_comment();
if (s1.get_success() !== 1 || s1.get_result_pos() !== 10) {
    console.log(`FAIL 1: success=${s1.get_success()}, pos=${s1.get_result_pos()}`);
    failures++;
}

// Test 2: Skip # comment
const s2 = @@PhpSyntaxSkipperFsm();
const inp2 = enc("# comment\ncode");
s2.setup(inp2, 0, inp2.length);
s2.do_skip_comment();
if (s2.get_success() !== 1 || s2.get_result_pos() !== 9) {
    console.log(`FAIL 2: success=${s2.get_success()}, pos=${s2.get_result_pos()}`);
    failures++;
}

// Test 3: Skip /* */ block comment
const s3 = @@PhpSyntaxSkipperFsm();
const inp3 = enc("/* block */code");
s3.setup(inp3, 0, inp3.length);
s3.do_skip_comment();
if (s3.get_success() !== 1 || s3.get_result_pos() !== 11) {
    console.log(`FAIL 3: success=${s3.get_success()}, pos=${s3.get_result_pos()}`);
    failures++;
}

// Test 4: Skip double-quoted string
const s4 = @@PhpSyntaxSkipperFsm();
const inp4 = enc('"hello" rest');
s4.setup(inp4, 0, inp4.length);
s4.do_skip_string();
if (s4.get_success() !== 1 || s4.get_result_pos() !== 7) {
    console.log(`FAIL 4: success=${s4.get_success()}, pos=${s4.get_result_pos()}`);
    failures++;
}

// Test 5: Skip single-quoted string
const s5 = @@PhpSyntaxSkipperFsm();
const inp5 = enc("'hello' rest");
s5.setup(inp5, 0, inp5.length);
s5.do_skip_string();
if (s5.get_success() !== 1 || s5.get_result_pos() !== 7) {
    console.log(`FAIL 5: success=${s5.get_success()}, pos=${s5.get_result_pos()}`);
    failures++;
}

// Test 6: Skip heredoc
const s6 = @@PhpSyntaxSkipperFsm();
const inp6 = enc("<<<EOT\nhello world\nEOT;\nnext");
s6.setup(inp6, 0, inp6.length);
s6.do_skip_string();
if (s6.get_success() !== 1 || s6.get_result_pos() !== 24) {
    console.log(`FAIL 6: success=${s6.get_success()}, pos=${s6.get_result_pos()}`);
    failures++;
}

// Test 7: Find line end (stops at ;)
const s7 = @@PhpSyntaxSkipperFsm();
const inp7 = enc("$x = 1; next");
s7.setup(inp7, 0, inp7.length);
s7.do_find_line_end();
if (s7.get_result_pos() !== 6) {
    console.log(`FAIL 7: pos=${s7.get_result_pos()}, expected 6`);
    failures++;
}

// Test 8: Balanced parens
const s8 = @@PhpSyntaxSkipperFsm();
const inp8 = enc("(a, f(b)) rest");
s8.setup(inp8, 0, inp8.length);
s8.do_balanced_paren_end();
if (s8.get_success() !== 1 || s8.get_result_pos() !== 9) {
    console.log(`FAIL 8: success=${s8.get_success()}, pos=${s8.get_result_pos()}`);
    failures++;
}

if (failures > 0) { console.log("FAIL: " + failures + " failures"); process.exit(1); }
console.log("PASS: php_skipper (8 cases)");

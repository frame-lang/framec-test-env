@@target python_3

# StateVarParser — FSM for parsing $.varName and $.varName = expr
# Translated from framec's native_region_scanner/state_var_parser.frs
#
# Uses hierarchical composition: $ScanExpr creates an ExprScannerFsm
# sub-machine when it detects an assignment.

@@system ExprScannerFsm {
    operations:
        setup(input_bytes: list, start: int, length: int) {
            self.bytes = input_bytes
            self.pos = start
            self.scan_end = length
        }
        get_result(): int {
            return self.result_end
        }

    interface:
        do_scan()

    machine:
        $Init {
            do_scan() { -> $Scanning }
        }

        $Scanning {
            $>() {
                i = self.pos
                end = self.scan_end
                bs = self.bytes
                depth = 0
                in_string = None

                while i < end:
                    b = bs[i]
                    if in_string is not None:
                        if b == ord('\\') and i + 1 < end:
                            i += 2
                            continue
                        if b == in_string:
                            in_string = None
                        i += 1
                        continue
                    if b == ord('"') or b == ord("'"):
                        in_string = b
                        i += 1
                        continue
                    if b == ord('(') or b == ord('[') or b == ord('{'):
                        depth += 1
                    elif b == ord(')') or b == ord(']') or b == ord('}'):
                        depth = max(depth - 1, 0)
                    elif b == ord(';') and depth == 0:
                        i += 1
                        break
                    elif b == ord('\n') and depth == 0:
                        break
                    i += 1

                self.result_end = i
            }
        }

    domain:
        bytes: list = []
        pos: int = 0
        scan_end: int = 0
        result_end: int = 0
}

@@system StateVarParserFsm {
    operations:
        setup(input_bytes: list, start: int, length: int) {
            self.bytes = input_bytes
            self.pos = start
            self.parse_end = length
        }
        get_result_end(): int {
            return self.result_end
        }
        get_is_assignment(): bool {
            return self.is_assignment
        }

    interface:
        do_parse()

    machine:
        $Init {
            do_parse() { -> $ScanIdent }
        }

        $ScanIdent {
            $>() {
                # Skip "$." prefix and scan identifier
                i = self.pos + 2
                end = self.parse_end
                bs = self.bytes

                while i < end and (chr(bs[i]).isalnum() or bs[i] == ord('_')):
                    i += 1

                self.ident_end = i
                -> $CheckAssign
            }
        }

        $CheckAssign {
            $>() {
                # Lookahead: skip whitespace, check for = (but not == or => or =<)
                j = self.ident_end
                end = self.parse_end
                bs = self.bytes

                while j < end and (bs[j] == ord(' ') or bs[j] == ord('\t')):
                    j += 1

                if j < end and bs[j] == ord('=') and (j + 1 >= end or (bs[j + 1] != ord('=') and bs[j + 1] != ord('<') and bs[j + 1] != ord('>'))):
                    # Assignment detected
                    j += 1
                    self.pos = j
                    self.is_assignment = True
                    -> $ScanExpr
                else:
                    # Read-only access
                    self.result_end = self.ident_end
                    self.is_assignment = False
                    -> $Done
            }
        }

        $ScanExpr {
            $>() {
                # Create ExprScanner sub-machine
                expr = @@ExprScannerFsm()
                expr.setup(self.bytes, self.pos, self.parse_end)
                expr.do_scan()
                self.result_end = expr.get_result()
                -> $Done
            }
        }

        $Done {
            $>() {
                pass
            }
        }

    domain:
        bytes: list = []
        pos: int = 0
        parse_end: int = 0
        ident_end: int = 0
        result_end: int = 0
        is_assignment: bool = False
}

if __name__ == '__main__':
    failures = 0

    # Test 1: Read-only access $.count
    p1 = @@StateVarParserFsm()
    inp1 = list(b"$.count + 1")
    p1.setup(inp1, 0, len(inp1))
    p1.do_parse()
    if p1.get_is_assignment():
        print("FAIL 1: should not be assignment")
        failures += 1
    name1 = bytes(inp1[2:p1.get_result_end()]).decode()
    if name1 != "count":
        print(f"FAIL 1: name='{name1}', expected 'count'")
        failures += 1

    # Test 2: Assignment $.total = x + 1;\n
    p2 = @@StateVarParserFsm()
    inp2 = list(b"$.total = x + 1;\nmore")
    p2.setup(inp2, 0, len(inp2))
    p2.do_parse()
    if not p2.get_is_assignment():
        print("FAIL 2: should be assignment")
        failures += 1
    expr2 = bytes(inp2[0:p2.get_result_end()]).decode()
    if "x + 1;" not in expr2:
        print(f"FAIL 2: expr='{expr2}'")
        failures += 1

    # Test 3: Not assignment $.x == 5 (== is comparison, not assignment)
    p3 = @@StateVarParserFsm()
    inp3 = list(b"$.x == 5")
    p3.setup(inp3, 0, len(inp3))
    p3.do_parse()
    if p3.get_is_assignment():
        print("FAIL 3: == should not be treated as assignment")
        failures += 1

    # Test 4: Assignment with nested parens $.val = f(a, b)\n
    p4 = @@StateVarParserFsm()
    inp4 = list(b"$.val = f(a, b)\nrest")
    p4.setup(inp4, 0, len(inp4))
    p4.do_parse()
    if not p4.get_is_assignment():
        print("FAIL 4: should be assignment")
        failures += 1
    expr4 = bytes(inp4[0:p4.get_result_end()]).decode()
    if "f(a, b)" not in expr4:
        print(f"FAIL 4: expr='{expr4}'")
        failures += 1

    if failures > 0:
        print(f"FAIL: {failures} failures")
        exit(1)
    print("PASS: state_var_parser (4 cases)")

@@target c

#include <string.h>

// swift_skipper -- FSM for skipping syntax constructs.

@@system SwiftSyntaxSkipperFsm {
    operations:
        setup(input_bytes: unsigned char*, start: int, length: int) {
            self->bytes = input_bytes;
            self->pos = start;
            self->scan_end = length;
        }
        get_result_pos(): int {
            return self->result_pos;
        }
        get_success(): int {
            return self->success;
        }

    interface:
        do_skip_comment()
        do_skip_string()
        do_find_line_end()
        do_balanced_paren_end()

    machine:
        $Init {
            do_skip_comment() { -> $SkipComment }
            do_skip_string() { -> $SkipString }
            do_find_line_end() { -> $FindLineEnd }
            do_balanced_paren_end() { -> $BalancedParenEnd }
        }

        $SkipComment {
            $>() {
                int i = self->pos;
                int end = self->scan_end;
                unsigned char* bs = self->bytes;

                if (i + 1 < end && bs[i] == '/' && bs[i + 1] == '/') {
                    int j = i + 2;
                    while (j < end && bs[j] != '\n') { j++; }
                    self->result_pos = j;
                    self->success = 1;
                    return;
                }

                if (i + 1 < end && bs[i] == '/' && bs[i + 1] == '*') {
                    int j = i + 2;
                    int depth = 1;
                    while (j + 1 < end && depth > 0) {
                        if (bs[j] == '/' && bs[j + 1] == '*') { depth++; j += 2; }
                        else if (bs[j] == '*' && bs[j + 1] == '/') { depth--; j += 2; }
                        else { j++; }
                    }
                    self->result_pos = j;
                    self->success = 1;
                    return;
                }

                self->success = 0;
            }
        }

        $SkipString {
            $>() {
                int i = self->pos;
                int end = self->scan_end;
                unsigned char* bs = self->bytes;

                // Triple-quoted string
                if (i + 2 < end && bs[i] == '"' && bs[i + 1] == '"' && bs[i + 2] == '"') {
                    int j = i + 3;
                    while (j + 2 < end) {
                        if (bs[j] == '"' && bs[j + 1] == '"' && bs[j + 2] == '"') {
                            self->result_pos = j + 3;
                            self->success = 1;
                            return;
                        }
                        j++;
                    }
                    self->result_pos = end;
                    self->success = 1;
                    return;
                }

                if (i < end && (bs[i] == '"' || bs[i] == '\'')) {
                    char q = bs[i];
                    int j = i + 1;
                    while (j < end) {
                        if (bs[j] == '\\') { j += 2; continue; }
                        if (bs[j] == q) {
                            self->result_pos = j + 1;
                            self->success = 1;
                            return;
                        }
                        j++;
                    }
                    self->result_pos = end;
                    self->success = 1;
                    return;
                }

                self->success = 0;
            }
        }

        $FindLineEnd {
            $>() {
                int j = self->pos;
                int end = self->scan_end;
                unsigned char* bs = self->bytes;

                while (j < end) {
                    char b = bs[j];
                    if (b == '\n' || b == ';') { break; }
                    if (b == '/' && j + 1 < end && bs[j + 1] == '/') { break; }
                    if (b == '/' && j + 1 < end && bs[j + 1] == '*') { break; }
                    j++;
                }

                self->result_pos = j;
            }
        }

        $BalancedParenEnd {
            $>() {
                int i = self->pos;
                int end = self->scan_end;
                unsigned char* bs = self->bytes;

                if (i >= end || bs[i] != '(') {
                    self->success = 0;
                    return;
                }

                int depth = 1;
                int j = i + 1;
                while (j < end && depth > 0) {
                    char b = bs[j];
                    if (b == '(') { depth++; }
                    else if (b == ')') { depth--; }
                    else if (b == '"' || b == '\'') {
                        char q = b;
                        j++;
                        while (j < end && bs[j] != q) {
                            if (bs[j] == '\\') { j++; }
                            j++;
                        }
                    }
                    j++;
                }

                if (depth == 0) { self->result_pos = j; self->success = 1; }
                else { self->result_pos = end; self->success = 0; }
            }
        }

    domain:
        bytes: unsigned char* = NULL
        pos: int = 0
        scan_end: int = 0
        result_pos: int = 0
        success: int = 1
}

int main() {
    int failures = 0;

    // Test 1: Skip line comment
    SwiftSyntaxSkipperFsm* s1 = @@SwiftSyntaxSkipperFsm();
    unsigned char t1[] = "// hello\ncode";
    SwiftSyntaxSkipperFsm_setup(s1, t1, 0, strlen((char*)t1));
    SwiftSyntaxSkipperFsm_do_skip_comment(s1);
    if (SwiftSyntaxSkipperFsm_get_success(s1) != 1 || SwiftSyntaxSkipperFsm_get_result_pos(s1) != 8) {
        printf("FAIL 1: Skip line comment\n");
        failures++;
    }
    // Test 2: Skip block comment
    SwiftSyntaxSkipperFsm* s2 = @@SwiftSyntaxSkipperFsm();
    unsigned char t2[] = "/* block */code";
    SwiftSyntaxSkipperFsm_setup(s2, t2, 0, strlen((char*)t2));
    SwiftSyntaxSkipperFsm_do_skip_comment(s2);
    if (SwiftSyntaxSkipperFsm_get_success(s2) != 1 || SwiftSyntaxSkipperFsm_get_result_pos(s2) != 11) {
        printf("FAIL 2: Skip block comment\n");
        failures++;
    }
    // Test 3: Skip double-quoted string
    SwiftSyntaxSkipperFsm* s3 = @@SwiftSyntaxSkipperFsm();
    unsigned char t3[] = "\"hello world\" rest";
    SwiftSyntaxSkipperFsm_setup(s3, t3, 0, strlen((char*)t3));
    SwiftSyntaxSkipperFsm_do_skip_string(s3);
    if (SwiftSyntaxSkipperFsm_get_success(s3) != 1 || SwiftSyntaxSkipperFsm_get_result_pos(s3) != 13) {
        printf("FAIL 3: Skip double-quoted string\n");
        failures++;
    }
    // Test 4: Nested block comment
    SwiftSyntaxSkipperFsm* s4 = @@SwiftSyntaxSkipperFsm();
    unsigned char t4[] = "/* outer /* inner */ end */code";
    SwiftSyntaxSkipperFsm_setup(s4, t4, 0, strlen((char*)t4));
    SwiftSyntaxSkipperFsm_do_skip_comment(s4);
    if (SwiftSyntaxSkipperFsm_get_success(s4) != 1 || SwiftSyntaxSkipperFsm_get_result_pos(s4) != 27) {
        printf("FAIL 4: Nested block comment\n");
        failures++;
    }
    // Test 5: Multi-line string
    SwiftSyntaxSkipperFsm* s5 = @@SwiftSyntaxSkipperFsm();
    unsigned char t5[] = "\"\"\"multi-line\ncontent\"\"\" rest";
    SwiftSyntaxSkipperFsm_setup(s5, t5, 0, strlen((char*)t5));
    SwiftSyntaxSkipperFsm_do_skip_string(s5);
    if (SwiftSyntaxSkipperFsm_get_success(s5) != 1 || SwiftSyntaxSkipperFsm_get_result_pos(s5) != 24) {
        printf("FAIL 5: Multi-line string\n");
        failures++;
    }
    // Test 6: Find line end
    SwiftSyntaxSkipperFsm* s6 = @@SwiftSyntaxSkipperFsm();
    unsigned char t6[] = "x + 1\nmore";
    SwiftSyntaxSkipperFsm_setup(s6, t6, 0, strlen((char*)t6));
    SwiftSyntaxSkipperFsm_do_find_line_end(s6);
    if (SwiftSyntaxSkipperFsm_get_result_pos(s6) != 5) {
        printf("FAIL 6: Find line end\n");
        failures++;
    }
    // Test 7: Not a comment
    SwiftSyntaxSkipperFsm* s7 = @@SwiftSyntaxSkipperFsm();
    unsigned char t7[] = "x + 1";
    SwiftSyntaxSkipperFsm_setup(s7, t7, 0, strlen((char*)t7));
    SwiftSyntaxSkipperFsm_do_skip_comment(s7);
    if (SwiftSyntaxSkipperFsm_get_success(s7) != 0) {
        printf("FAIL 7: Not a comment\n");
        failures++;
    }
    // Test 8: Balanced parens
    SwiftSyntaxSkipperFsm* s8 = @@SwiftSyntaxSkipperFsm();
    unsigned char t8[] = "(a, f(b), c) rest";
    SwiftSyntaxSkipperFsm_setup(s8, t8, 0, strlen((char*)t8));
    SwiftSyntaxSkipperFsm_do_balanced_paren_end(s8);
    if (SwiftSyntaxSkipperFsm_get_success(s8) != 1 || SwiftSyntaxSkipperFsm_get_result_pos(s8) != 12) {
        printf("FAIL 8: Balanced parens\n");
        failures++;
    }
    // Test 9: Find line end at // comment
    SwiftSyntaxSkipperFsm* s9 = @@SwiftSyntaxSkipperFsm();
    unsigned char t9[] = "x + 1 // comment";
    SwiftSyntaxSkipperFsm_setup(s9, t9, 0, strlen((char*)t9));
    SwiftSyntaxSkipperFsm_do_find_line_end(s9);
    if (SwiftSyntaxSkipperFsm_get_result_pos(s9) != 6) {
        printf("FAIL 9: Find line end at // comment\n");
        failures++;
    }

    SwiftSyntaxSkipperFsm_destroy(s1);
    SwiftSyntaxSkipperFsm_destroy(s2);
    SwiftSyntaxSkipperFsm_destroy(s3);
    SwiftSyntaxSkipperFsm_destroy(s4);
    SwiftSyntaxSkipperFsm_destroy(s5);
    SwiftSyntaxSkipperFsm_destroy(s6);
    SwiftSyntaxSkipperFsm_destroy(s7);
    SwiftSyntaxSkipperFsm_destroy(s8);
    SwiftSyntaxSkipperFsm_destroy(s9);

    if (failures > 0) {
        printf("FAIL: %d failures\n", failures);
        return 1;
    }
    printf("PASS: swift_skipper (9 cases)\n");
    return 0;
}

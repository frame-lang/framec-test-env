@@[target("rust")]

// ContextParser -- FSM for parsing @@ context constructs.
// Translated from framec's native_region_scanner/context_parser.frs
//
// Parses:
//   @@:return [= expr]     kind=2 (ContextReturn)
//   @@:event               kind=3 (ContextEvent)
//   @@:data.key [= expr]   kind=4 (ContextData) or kind=5 (ContextDataAssign)
//   @@:params.key           kind=6 (ContextParams)
//   @@SystemName()          kind=7 (TaggedInstantiation)
//   @@:(expr)               kind=8 (ContextReturnExpr)
//   @@:return(expr)         kind=9 (ReturnCall)
//   @@:self.method()        kind=10 (ContextSelfCall)
//   @@:self                 kind=11 (ContextSelf)
//   @@:system.state         kind=12 (ContextSystemState)
//   other                   has_result=0

use std::collections::HashMap;

@@system ContextParserFsm {
    operations:
        setup(input_bytes: Vec<u8>, start: i64, length: i64) {
            self.bytes = input_bytes;
            self.pos = start;
            self.scan_end = length;
        }
        setup_with_paren_end(input_bytes: Vec<u8>, start: i64, length: i64, p_end: i64) {
            self.bytes = input_bytes;
            self.pos = start;
            self.scan_end = length;
            self.paren_end = p_end;
        }
        get_result_end(): i64 {
            return self.result_end;
        }
        get_result_kind(): i64 {
            return self.result_kind;
        }
        get_has_result(): i64 {
            return self.has_result;
        }

    interface:
        do_parse()

    machine:
        $Init {
            do_parse() { -> $Dispatching }
        }

        $Dispatching {
            $>() {
                let i = self.pos as usize;
                let end = self.scan_end as usize;
                let bs = &self.bytes;

                if i >= end {
                    self.has_result = 0;
                    -> $Done
                }

                let b = bs[i];

                if b == 0x3A {
                    self.pos = (i + 1) as i64;
                    -> $DispatchColon
                } else if b >= 0x41 && b <= 0x5A {
                    // @@SystemName -- pos stays at start of name
                    -> $ParseInstantiation
                } else {
                    self.result_end = i as i64;
                    self.has_result = 0;
                    -> $Done
                }
            }
        }

        $DispatchColon {
            $>() {
                let i = self.pos as usize;
                let end = self.scan_end as usize;
                let bs = &self.bytes;

                // Check for @@:return
                if i + 5 < end {
                    if &bs[i..i + 6] == b"return" {
                        self.pos = (i + 6) as i64;
                        -> $ParseReturn
                    }
                }

                // Check for @@:event
                if i + 4 < end {
                    if &bs[i..i + 5] == b"event" {
                        self.result_end = (i + 5) as i64;
                        self.result_kind = 3;
                        self.has_result = 1;
                        -> $Done
                    }
                }

                // Check for @@:data
                if i + 3 < end {
                    if &bs[i..i + 4] == b"data" {
                        self.pos = (i + 4) as i64;
                        -> $ParseData
                    }
                }

                // Check for @@:params
                if i + 5 < end {
                    if &bs[i..i + 6] == b"params" {
                        self.pos = (i + 6) as i64;
                        -> $ParseParams
                    }
                }

                // Check for @@:self
                if i + 3 < end {
                    if &bs[i..i + 4] == b"self" {
                        self.pos = (i + 4) as i64;
                        -> $ParseSelf
                    }
                }

                // Check for @@:system
                if i + 5 < end {
                    if &bs[i..i + 6] == b"system" {
                        self.pos = (i + 6) as i64;
                        -> $ParseSystem
                    }
                }

                // Check for @@:(expr)
                if i < end && bs[i] == 0x28 {
                    self.pos = i as i64;
                    -> $ParseContextReturnExpr
                }

                // Unknown
                self.result_end = i as i64;
                self.has_result = 0;
                -> $Done
            }
        }

        $ParseReturn {
            $>() {
                let mut i = self.pos as usize;
                let end = self.scan_end as usize;
                let bs = &self.bytes;

                // Skip whitespace
                while i < end && (bs[i] == 0x20 || bs[i] == 0x09) {
                    i += 1;
                }

                if i < end && bs[i] == 0x28 {
                    // @@:return(expr) -- scan balanced parens
                    let mut depth: i32 = 1;
                    i += 1;
                    while i < end && depth > 0 {
                        if bs[i] == 0x28 {
                            depth += 1;
                        }
                        if bs[i] == 0x29 {
                            depth -= 1;
                        }
                        if depth > 0 {
                            i += 1;
                        }
                    }
                    if depth == 0 {
                        i += 1;
                    }
                    self.result_end = i as i64;
                    self.result_kind = 9;
                    self.has_result = 1;
                    -> $Done
                } else if i < end && bs[i] == 0x3D && (i + 1 >= end || bs[i + 1] != 0x3D) {
                    // @@:return = <expr> -- scan expression
                    i += 1;
                    // Skip whitespace after =
                    while i < end && (bs[i] == 0x20 || bs[i] == 0x09) {
                        i += 1;
                    }
                    // Scan to end of expression (newline or ;)
                    while i < end && bs[i] != 0x0A && bs[i] != 0x3B {
                        i += 1;
                    }
                    self.result_end = i as i64;
                    self.result_kind = 2;
                    self.has_result = 1;
                    -> $Done
                } else {
                    // @@:return (bare read)
                    self.result_end = i as i64;
                    self.result_kind = 2;
                    self.has_result = 1;
                    -> $Done
                }
            }
        }

        $ParseContextReturnExpr {
            $>() {
                let mut i = self.pos as usize;
                let end = self.scan_end as usize;
                let bs = &self.bytes;

                if i < end && bs[i] == 0x28 {
                    let mut depth: i32 = 1;
                    i += 1;
                    while i < end && depth > 0 {
                        let b = bs[i];
                        if b == 0x28 {
                            depth += 1;
                        } else if b == 0x29 {
                            depth -= 1;
                        } else if b == 0x22 || b == 0x27 {
                            let q = b;
                            i += 1;
                            while i < end {
                                if bs[i] == 0x5C && i + 1 < end {
                                    i += 2;
                                    continue;
                                }
                                if bs[i] == q {
                                    break;
                                }
                                i += 1;
                            }
                        }
                        i += 1;
                    }
                }

                self.result_end = i as i64;
                self.result_kind = 8;
                self.has_result = 1;
                -> $Done
            }
        }

        $ParseData {
            $>() {
                let mut i = self.pos as usize;
                let end = self.scan_end as usize;
                let bs = &self.bytes;

                // Scan .key
                if i < end && bs[i] == 0x2E {
                    i += 1;
                    while i < end && (bs[i].is_ascii_alphanumeric() || bs[i] == 0x5F) {
                        i += 1;
                    }
                }

                // Check for assignment
                let mut j = i;
                while j < end && (bs[j] == 0x20 || bs[j] == 0x09) {
                    j += 1;
                }

                if j < end && bs[j] == 0x3D && (j + 1 >= end || bs[j + 1] != 0x3D) {
                    // @@:data.key = expr
                    j += 1;
                    while j < end && (bs[j] == 0x20 || bs[j] == 0x09) {
                        j += 1;
                    }
                    while j < end && bs[j] != 0x0A && bs[j] != 0x3B {
                        j += 1;
                    }
                    self.result_end = j as i64;
                    self.result_kind = 5;
                } else {
                    self.result_end = i as i64;
                    self.result_kind = 4;
                }

                self.has_result = 1;
                -> $Done
            }
        }

        $ParseParams {
            $>() {
                let mut i = self.pos as usize;
                let end = self.scan_end as usize;
                let bs = &self.bytes;

                if i < end && bs[i] == 0x2E {
                    i += 1;
                    while i < end && (bs[i].is_ascii_alphanumeric() || bs[i] == 0x5F) {
                        i += 1;
                    }
                }

                self.result_end = i as i64;
                self.result_kind = 6;
                self.has_result = 1;
                -> $Done
            }
        }

        $ParseSelf {
            $>() {
                let mut i = self.pos as usize;
                let end = self.scan_end as usize;
                let bs = &self.bytes;

                if i < end && bs[i] == 0x2E {
                    i += 1;
                    // Scan identifier
                    while i < end && (bs[i].is_ascii_alphanumeric() || bs[i] == 0x5F) {
                        i += 1;
                    }
                    if i < end && bs[i] == 0x28 {
                        // @@:self.method(args) -- scan balanced parens
                        let mut depth: i32 = 1;
                        i += 1;
                        while i < end && depth > 0 {
                            if bs[i] == 0x28 {
                                depth += 1;
                            }
                            if bs[i] == 0x29 {
                                depth -= 1;
                            }
                            if bs[i] == 0x22 || bs[i] == 0x27 {
                                let q = bs[i];
                                i += 1;
                                while i < end {
                                    if bs[i] == 0x5C && i + 1 < end {
                                        i += 2;
                                        continue;
                                    }
                                    if bs[i] == q {
                                        break;
                                    }
                                    i += 1;
                                }
                            }
                            if depth > 0 {
                                i += 1;
                            }
                        }
                        if depth == 0 {
                            i += 1;
                        }
                        self.result_end = i as i64;
                        self.result_kind = 10;
                        self.has_result = 1;
                    } else {
                        // @@:self.property
                        self.result_end = i as i64;
                        self.result_kind = 11;
                        self.has_result = 1;
                    }
                } else {
                    // bare @@:self
                    self.result_end = i as i64;
                    self.result_kind = 11;
                    self.has_result = 1;
                }

                -> $Done
            }
        }

        $ParseSystem {
            $>() {
                let i = self.pos as usize;
                let end = self.scan_end as usize;
                let bs = &self.bytes;

                if i + 5 < end {
                    if &bs[i..i + 6] == b".state" {
                        let after = i + 6;
                        if after >= end || (!bs[after].is_ascii_alphanumeric() && bs[after] != 0x5F) {
                            self.result_end = (i + 6) as i64;
                            self.result_kind = 12;
                            self.has_result = 1;
                            -> $Done
                        }
                    }
                }

                // Bare @@:system or unknown variant
                self.result_end = i as i64;
                self.result_kind = 13;
                self.has_result = 1;
                -> $Done
            }
        }

        $ParseInstantiation {
            $>() {
                let mut i = self.pos as usize;
                let end = self.scan_end as usize;
                let bs = &self.bytes;

                // Scan identifier
                while i < end && (bs[i].is_ascii_alphanumeric() || bs[i] == 0x5F) {
                    i += 1;
                }

                // Must be followed by (
                if i < end && bs[i] == 0x28 {
                    if self.paren_end > 0 {
                        i = self.paren_end as usize;
                        self.result_end = i as i64;
                        self.result_kind = 7;
                        self.has_result = 1;
                    } else {
                        self.result_end = i as i64;
                        self.has_result = 0;
                    }
                } else {
                    self.result_end = i as i64;
                    self.has_result = 0;
                }

                -> $Done
            }
        }

        $Done {
            $>() {
                // Terminal state -- results are in domain vars
            }
        }

    domain:
        bytes: Vec<u8> = Vec::new()
        pos: i64 = 0
        scan_end: i64 = 0
        result_end: i64 = 0
        result_kind: i64 = 0
        has_result: i64 = 0
        paren_end: i64 = 0
}

fn main() {
    let mut failures = 0;

    // Test 1: @@:return (bare read)
    let mut p1 = @@ContextParserFsm();
    let inp1 = b":return".to_vec();
    p1.setup(inp1.clone(), 0, inp1.len() as i64);
    p1.do_parse();
    if p1.get_has_result() != 1 || p1.get_result_kind() != 2 {
        println!("FAIL 1: has_result={}, kind={}", p1.get_has_result(), p1.get_result_kind());
        failures += 1;
    }

    // Test 2: @@:event
    let mut p2 = @@ContextParserFsm();
    let inp2 = b":event".to_vec();
    p2.setup(inp2.clone(), 0, inp2.len() as i64);
    p2.do_parse();
    if p2.get_has_result() != 1 || p2.get_result_kind() != 3 {
        println!("FAIL 2: has_result={}, kind={}", p2.get_has_result(), p2.get_result_kind());
        failures += 1;
    }

    // Test 3: @@:data.key
    let mut p3 = @@ContextParserFsm();
    let inp3 = b":data.name rest".to_vec();
    p3.setup(inp3.clone(), 0, inp3.len() as i64);
    p3.do_parse();
    if p3.get_has_result() != 1 || p3.get_result_kind() != 4 {
        println!("FAIL 3: has_result={}, kind={}", p3.get_has_result(), p3.get_result_kind());
        failures += 1;
    }

    // Test 4: @@:data.key = expr
    let mut p4 = @@ContextParserFsm();
    let inp4 = b":data.key = value\n".to_vec();
    p4.setup(inp4.clone(), 0, inp4.len() as i64);
    p4.do_parse();
    if p4.get_has_result() != 1 || p4.get_result_kind() != 5 {
        println!("FAIL 4: has_result={}, kind={}", p4.get_has_result(), p4.get_result_kind());
        failures += 1;
    }

    // Test 5: @@:params.key
    let mut p5 = @@ContextParserFsm();
    let inp5 = b":params.name rest".to_vec();
    p5.setup(inp5.clone(), 0, inp5.len() as i64);
    p5.do_parse();
    if p5.get_has_result() != 1 || p5.get_result_kind() != 6 {
        println!("FAIL 5: has_result={}, kind={}", p5.get_has_result(), p5.get_result_kind());
        failures += 1;
    }

    // Test 6: @@:(expr)
    let mut p6 = @@ContextParserFsm();
    let inp6 = b":(x + 1) rest".to_vec();
    p6.setup(inp6.clone(), 0, inp6.len() as i64);
    p6.do_parse();
    if p6.get_has_result() != 1 || p6.get_result_kind() != 8 {
        println!("FAIL 6: has_result={}, kind={}", p6.get_has_result(), p6.get_result_kind());
        failures += 1;
    }

    // Test 7: @@:return(expr)
    let mut p7 = @@ContextParserFsm();
    let inp7 = b":return(42) rest".to_vec();
    p7.setup(inp7.clone(), 0, inp7.len() as i64);
    p7.do_parse();
    if p7.get_has_result() != 1 || p7.get_result_kind() != 9 {
        println!("FAIL 7: has_result={}, kind={}", p7.get_has_result(), p7.get_result_kind());
        failures += 1;
    }

    // Test 8: @@:self (bare)
    let mut p8 = @@ContextParserFsm();
    let inp8 = b":self rest".to_vec();
    p8.setup(inp8.clone(), 0, inp8.len() as i64);
    p8.do_parse();
    if p8.get_has_result() != 1 || p8.get_result_kind() != 11 {
        println!("FAIL 8: has_result={}, kind={}", p8.get_has_result(), p8.get_result_kind());
        failures += 1;
    }

    // Test 9: @@:self.method(args)
    let mut p9 = @@ContextParserFsm();
    let inp9 = b":self.doWork(x) rest".to_vec();
    p9.setup(inp9.clone(), 0, inp9.len() as i64);
    p9.do_parse();
    if p9.get_has_result() != 1 || p9.get_result_kind() != 10 {
        println!("FAIL 9: has_result={}, kind={}", p9.get_has_result(), p9.get_result_kind());
        failures += 1;
    }

    // Test 10: @@:system.state
    let mut p10 = @@ContextParserFsm();
    let inp10 = b":system.state rest".to_vec();
    p10.setup(inp10.clone(), 0, inp10.len() as i64);
    p10.do_parse();
    if p10.get_has_result() != 1 || p10.get_result_kind() != 12 {
        println!("FAIL 10: has_result={}, kind={}", p10.get_has_result(), p10.get_result_kind());
        failures += 1;
    }

    // Test 11: @@SystemName() with paren_end
    let mut p11 = @@ContextParserFsm();
    let inp11 = b"MySystem() rest".to_vec();
    p11.setup_with_paren_end(inp11.clone(), 0, inp11.len() as i64, 10);
    p11.do_parse();
    if p11.get_has_result() != 1 || p11.get_result_kind() != 7 {
        println!("FAIL 11: has_result={}, kind={}", p11.get_has_result(), p11.get_result_kind());
        failures += 1;
    }

    // Test 12: No match (lowercase, not a keyword)
    let mut p12 = @@ContextParserFsm();
    let inp12 = b"xyz".to_vec();
    p12.setup(inp12.clone(), 0, inp12.len() as i64);
    p12.do_parse();
    if p12.get_has_result() != 0 {
        println!("FAIL 12: should not match, has_result={}", p12.get_has_result());
        failures += 1;
    }

    if failures > 0 { println!("FAIL: {} failures", failures); std::process::exit(1); }
    println!("PASS: context_parser (12 cases)");
}

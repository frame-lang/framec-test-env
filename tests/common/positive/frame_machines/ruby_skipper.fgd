@@target gdscript
extends SceneTree

# RubySyntaxSkipper -- FSM for skipping Ruby comments and strings.

@@system RubySyntaxSkipperFsm {
    operations:
        setup(input_bytes: Array, start: int, length: int) {
            self.bytes = input_bytes
            self.pos = start
            self.scan_end = length
        }
        get_result_pos(): int {
            return self.result_pos
        }
        get_success(): int {
            return self.success
        }

    interface:
        do_skip_comment()
        do_skip_string()
        do_find_line_end()
        do_balanced_paren_end()

    machine:
        $Init {
            do_skip_comment() { -> $SkipComment }
            do_skip_string() { -> $SkipString }
            do_find_line_end() { -> $FindLineEnd }
            do_balanced_paren_end() { -> $BalancedParenEnd }
        }

        $SkipComment {
            $>() {
                var i = self.pos
                var end = self.scan_end
                var bs = self.bytes

                if i < end and bs[i] == 0x23:
                    var j = i + 1
                    while j < end and bs[j] != 0x0A:
                        j += 1
                    self.result_pos = j
                    self.success = 1
                    return

                self.success = 0
            }
        }

        $SkipString {
            $>() {
                var i = self.pos
                var end = self.scan_end
                var bs = self.bytes

                # Percent literals
                if i < end and bs[i] == 0x25:
                    if i + 1 < end:
                        var c1 = bs[i + 1]
                        var has_letter = (c1 == 0x51 or c1 == 0x71 or c1 == 0x77 or c1 == 0x57 or c1 == 0x69 or c1 == 0x49 or c1 == 0x72 or c1 == 0x78 or c1 == 0x73)
                        var opener = 0
                        var j = 0
                        if has_letter and i + 2 < end:
                            opener = bs[i + 2]
                            j = i + 3
                        elif not (c1 >= 0x61 and c1 <= 0x7A or c1 >= 0x41 and c1 <= 0x5A or c1 >= 0x30 and c1 <= 0x39 or c1 == 0x5F):
                            opener = c1
                            j = i + 2
                        else:
                            self.success = 0
                            return

                        var closer = 0
                        if opener == 0x7B:
                            closer = 0x7D
                        elif opener == 0x5B:
                            closer = 0x5D
                        elif opener == 0x28:
                            closer = 0x29
                        elif opener == 0x3C:
                            closer = 0x3E
                        else:
                            closer = opener
                            while j < end:
                                if bs[j] == 0x5C:
                                    j += 2
                                    continue
                                if bs[j] == closer:
                                    self.result_pos = j + 1
                                    self.success = 1
                                    return
                                j += 1
                            self.result_pos = end
                            self.success = 1
                            return

                        var depth = 1
                        while j < end and depth > 0:
                            if bs[j] == 0x5C:
                                j += 2
                                continue
                            if bs[j] == opener:
                                depth += 1
                            elif bs[j] == closer:
                                depth -= 1
                            j += 1
                        self.result_pos = j
                        self.success = 1
                        return

                # Simple string
                if i < end and (bs[i] == 0x22 or bs[i] == 0x27):
                    var q = bs[i]
                    var j = i + 1
                    while j < end:
                        if bs[j] == 0x5C:
                            j += 2
                            continue
                        if bs[j] == q:
                            self.result_pos = j + 1
                            self.success = 1
                            return
                        j += 1
                    self.result_pos = end
                    self.success = 1
                    return

                self.success = 0
            }
        }

        $FindLineEnd {
            $>() {
                var j = self.pos
                var end = self.scan_end
                var bs = self.bytes
                var in_string = 0

                while j < end:
                    var b = bs[j]
                    if b == 0x0A:
                        break
                    if in_string != 0:
                        if b == 0x5C:
                            j += 2
                            continue
                        if b == in_string:
                            in_string = 0
                        j += 1
                        continue
                    if b == 0x23:
                        break
                    if b == 0x27 or b == 0x22:
                        in_string = b
                        j += 1
                        continue
                    j += 1

                self.result_pos = j
            }
        }

        $BalancedParenEnd {
            $>() {
                var i = self.pos
                var end = self.scan_end
                var bs = self.bytes

                if i >= end or bs[i] != 0x28:
                    self.success = 0
                    return

                var depth = 0
                var in_string = 0

                while i < end:
                    var b = bs[i]
                    if in_string != 0:
                        if b == 0x5C:
                            i += 2
                            continue
                        if b == in_string:
                            in_string = 0
                        i += 1
                        continue
                    if b == 0x27 or b == 0x22:
                        in_string = b
                        i += 1
                    elif b == 0x28:
                        depth += 1
                        i += 1
                    elif b == 0x29:
                        depth -= 1
                        i += 1
                        if depth == 0:
                            self.result_pos = i
                            self.success = 1
                            return
                    else:
                        i += 1

                self.success = 0
            }
        }

    domain:
        bytes: Array = []
        pos: int = 0
        scan_end: int = 0
        result_pos: int = 0
        success: int = 1
}

func str_to_bytes(s: String) -> Array:
    var arr = []
    var buf = s.to_utf8_buffer()
    for i in range(buf.size()):
        arr.append(buf[i])
    return arr

func main():
    var failures = 0

    var s1 = @@RubySyntaxSkipperFsm()
    var inp1 = str_to_bytes("# comment\ncode")
    s1.setup(inp1, 0, inp1.size())
    s1.do_skip_comment()
    if s1.get_success() != 1 or s1.get_result_pos() != 9:
        print("FAIL 1: success=" + str(s1.get_success()) + ", pos=" + str(s1.get_result_pos()))
        failures += 1

    var s2 = @@RubySyntaxSkipperFsm()
    var inp2 = str_to_bytes("\"hello\" rest")
    s2.setup(inp2, 0, inp2.size())
    s2.do_skip_string()
    if s2.get_success() != 1 or s2.get_result_pos() != 7:
        print("FAIL 2: success=" + str(s2.get_success()) + ", pos=" + str(s2.get_result_pos()))
        failures += 1

    var s3 = @@RubySyntaxSkipperFsm()
    var inp3 = str_to_bytes("'hello' rest")
    s3.setup(inp3, 0, inp3.size())
    s3.do_skip_string()
    if s3.get_success() != 1 or s3.get_result_pos() != 7:
        print("FAIL 3: success=" + str(s3.get_success()) + ", pos=" + str(s3.get_result_pos()))
        failures += 1

    var s4 = @@RubySyntaxSkipperFsm()
    var inp4 = str_to_bytes("%Q{text} rest")
    s4.setup(inp4, 0, inp4.size())
    s4.do_skip_string()
    if s4.get_success() != 1 or s4.get_result_pos() != 8:
        print("FAIL 4: success=" + str(s4.get_success()) + ", pos=" + str(s4.get_result_pos()))
        failures += 1

    var s5 = @@RubySyntaxSkipperFsm()
    var inp5 = str_to_bytes("%q[text] rest")
    s5.setup(inp5, 0, inp5.size())
    s5.do_skip_string()
    if s5.get_success() != 1 or s5.get_result_pos() != 8:
        print("FAIL 5: success=" + str(s5.get_success()) + ", pos=" + str(s5.get_result_pos()))
        failures += 1

    var s6 = @@RubySyntaxSkipperFsm()
    var inp6 = str_to_bytes("x + 1 # comment")
    s6.setup(inp6, 0, inp6.size())
    s6.do_find_line_end()
    if s6.get_result_pos() != 6:
        print("FAIL 6: pos=" + str(s6.get_result_pos()) + ", expected 6")
        failures += 1

    var s7 = @@RubySyntaxSkipperFsm()
    var inp7 = str_to_bytes("(a, f(b)) rest")
    s7.setup(inp7, 0, inp7.size())
    s7.do_balanced_paren_end()
    if s7.get_success() != 1 or s7.get_result_pos() != 9:
        print("FAIL 7: success=" + str(s7.get_success()) + ", pos=" + str(s7.get_result_pos()))
        failures += 1

    var s8 = @@RubySyntaxSkipperFsm()
    var inp8 = str_to_bytes("%Q{outer {inner} end} rest")
    s8.setup(inp8, 0, inp8.size())
    s8.do_skip_string()
    if s8.get_success() != 1 or s8.get_result_pos() != 21:
        print("FAIL 8: success=" + str(s8.get_success()) + ", pos=" + str(s8.get_result_pos()))
        failures += 1

    if failures > 0:
        print("FAIL: " + str(failures) + " failures")
        push_error(str(failures) + " test(s) failed")
    else:
        print("PASS: ruby_skipper (8 cases)")

func _init():
    main()
    quit()

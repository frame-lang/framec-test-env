@@target java

// javascript_skipper -- FSM for skipping syntax constructs.

@@system JavaScriptSyntaxSkipperFsm {
    operations:
        setup(input_bytes: byte[], start: int, length: int) {
            this.bytes = input_bytes;
            this.pos = start;
            this.scan_end = length;
        }
        get_result_pos(): int {
            return this.result_pos;
        }
        get_success(): int {
            return this.success;
        }

    interface:
        do_skip_comment()
        do_skip_string()
        do_find_line_end()
        do_balanced_paren_end()

    machine:
        $Init {
            do_skip_comment() { -> $SkipComment }
            do_skip_string() { -> $SkipString }
            do_find_line_end() { -> $FindLineEnd }
            do_balanced_paren_end() { -> $BalancedParenEnd }
        }

        $SkipComment {
            $>() {
                int i = this.pos;
                int end = this.scan_end;
                byte[] bs = this.bytes;

                if (i + 1 < end && (bs[i] & 0xFF) == '/' && (bs[i + 1] & 0xFF) == '/') {
                    int j = i + 2;
                    while (j < end && (bs[j] & 0xFF) != '\n') { j++; }
                    this.result_pos = j; this.success = 1; return;
                }
                if (i + 1 < end && (bs[i] & 0xFF) == '/' && (bs[i + 1] & 0xFF) == '*') {
                    int j = i + 2;
                    while (j + 1 < end) {
                        if ((bs[j] & 0xFF) == '*' && (bs[j + 1] & 0xFF) == '/') {
                            this.result_pos = j + 2; this.success = 1; return;
                        }
                        j++;
                    }
                    this.result_pos = end; this.success = 1; return;
                }
                this.success = 0;
            }
        }

        $SkipString {
            $>() {
                int i = this.pos;
                int end = this.scan_end;
                byte[] bs = this.bytes;

                if (i < end && (bs[i] & 0xFF) == '`') {
                    int j = i + 1; int braceDepth = 0;
                    while (j < end) {
                        if ((bs[j] & 0xFF) == '`' && braceDepth == 0) { this.result_pos = j + 1; this.success = 1; return; }
                        if ((bs[j] & 0xFF) == '\\') { j += 2; continue; }
                        if ((bs[j] & 0xFF) == '$' && j+1 < end && (bs[j+1] & 0xFF) == '{') { braceDepth++; j += 2; continue; }
                        if ((bs[j] & 0xFF) == '}' && braceDepth > 0) { braceDepth--; }
                        j++;
                    }
                    this.result_pos = end; this.success = 1; return;
                }

                if (i < end && ((bs[i] & 0xFF) == '"' || (bs[i] & 0xFF) == '\'')) {
                    int q = bs[i] & 0xFF;
                    int j = i + 1;
                    while (j < end) {
                        if ((bs[j] & 0xFF) == '\\') { j += 2; continue; }
                        if ((bs[j] & 0xFF) == q) { this.result_pos = j + 1; this.success = 1; return; }
                        j++;
                    }
                    this.result_pos = end; this.success = 1; return;
                }
                this.success = 0;
            }
        }

        $FindLineEnd {
            $>() {
                int j = this.pos;
                int end = this.scan_end;
                byte[] bs = this.bytes;

                int inString = 0; int inTemplate = 0; int tplBraceDepth = 0;
                while (j < end) {
                    int b = bs[j] & 0xFF;
                    if (b == '\n') { break; }
                    if (inTemplate != 0) {
                        if (b == '`' && tplBraceDepth == 0) { inTemplate = 0; j++; continue; }
                        if (b == '\\') { j += 2; continue; }
                        if (b == '$' && j+1 < end && (bs[j+1] & 0xFF) == '{') { tplBraceDepth++; j += 2; continue; }
                        if (b == '}' && tplBraceDepth > 0) { tplBraceDepth--; }
                        j++; continue;
                    }
                    if (inString != 0) {
                        if (b == '\\') { j += 2; continue; }
                        if (b == inString) { inString = 0; }
                        j++; continue;
                    }
                    if (b == ';' || b == '}') { break; }
                    if (b == '/' && j+1 < end && ((bs[j+1] & 0xFF) == '/' || (bs[j+1] & 0xFF) == '*')) { break; }
                    if (b == '\'' || b == '"') { inString = b; j++; continue; }
                    if (b == '`') { inTemplate = 1; j++; continue; }
                    j++;
                }
                this.result_pos = j;
            }
        }

        $BalancedParenEnd {
            $>() {
                int i = this.pos;
                int end = this.scan_end;
                byte[] bs = this.bytes;

                if (i >= end || (bs[i] & 0xFF) != '(') { this.success = 0; return; }
                int depth = 0; int inString = 0; int inTemplate = 0;
                while (i < end) {
                    int b = bs[i] & 0xFF;
                    if (inTemplate != 0) { if (b == '`') { inTemplate = 0; } if (b == '\\') { i += 2; continue; } i++; continue; }
                    if (inString != 0) { if (b == '\\') { i += 2; continue; } if (b == inString) { inString = 0; } i++; continue; }
                    if (b == '\'' || b == '"') { inString = b; i++; }
                    else if (b == '`') { inTemplate = 1; i++; }
                    else if (b == '(') { depth++; i++; }
                    else if (b == ')') { depth--; i++; if (depth == 0) { this.result_pos = i; this.success = 1; return; } }
                    else { i++; }
                }
                this.success = 0;
            }
        }

    domain:
        bytes: byte[] = null
        pos: int = 0
        scan_end: int = 0
        result_pos: int = 0
        success: int = 1
}

class Main {
    public static void main(String[] args) {
        int failures = 0;

        JavaScriptSyntaxSkipperFsm s1 = @@JavaScriptSyntaxSkipperFsm();
        byte[] inp1 = "// hello\ncode".getBytes();
        s1.setup(inp1, 0, inp1.length);
        s1.do_skip_comment();
        if (s1.get_success() != 1 || s1.get_result_pos() != 8) {
            System.out.println("FAIL 1: Skip line comment");
            failures++;
        }

        JavaScriptSyntaxSkipperFsm s2 = @@JavaScriptSyntaxSkipperFsm();
        byte[] inp2 = "/* block */code".getBytes();
        s2.setup(inp2, 0, inp2.length);
        s2.do_skip_comment();
        if (s2.get_success() != 1 || s2.get_result_pos() != 11) {
            System.out.println("FAIL 2: Skip block comment");
            failures++;
        }

        JavaScriptSyntaxSkipperFsm s3 = @@JavaScriptSyntaxSkipperFsm();
        byte[] inp3 = "\"hello world\" rest".getBytes();
        s3.setup(inp3, 0, inp3.length);
        s3.do_skip_string();
        if (s3.get_success() != 1 || s3.get_result_pos() != 13) {
            System.out.println("FAIL 3: Skip double-quoted string");
            failures++;
        }

        JavaScriptSyntaxSkipperFsm s4 = @@JavaScriptSyntaxSkipperFsm();
        byte[] inp4 = "`template ${x}` rest".getBytes();
        s4.setup(inp4, 0, inp4.length);
        s4.do_skip_string();
        if (s4.get_success() != 1 || s4.get_result_pos() != 15) {
            System.out.println("FAIL 4: Skip template literal");
            failures++;
        }

        JavaScriptSyntaxSkipperFsm s5 = @@JavaScriptSyntaxSkipperFsm();
        byte[] inp5 = "x + 1\nmore".getBytes();
        s5.setup(inp5, 0, inp5.length);
        s5.do_find_line_end();
        if (s5.get_result_pos() != 5) {
            System.out.println("FAIL 5: Find line end");
            failures++;
        }

        JavaScriptSyntaxSkipperFsm s6 = @@JavaScriptSyntaxSkipperFsm();
        byte[] inp6 = "x + 1".getBytes();
        s6.setup(inp6, 0, inp6.length);
        s6.do_skip_comment();
        if (s6.get_success() != 0) {
            System.out.println("FAIL 6: Not a comment");
            failures++;
        }

        JavaScriptSyntaxSkipperFsm s7 = @@JavaScriptSyntaxSkipperFsm();
        byte[] inp7 = "(a, `t`, c) rest".getBytes();
        s7.setup(inp7, 0, inp7.length);
        s7.do_balanced_paren_end();
        if (s7.get_success() != 1 || s7.get_result_pos() != 11) {
            System.out.println("FAIL 7: Balanced parens with template");
            failures++;
        }

        JavaScriptSyntaxSkipperFsm s8 = @@JavaScriptSyntaxSkipperFsm();
        byte[] inp8 = "x + 1 // comment".getBytes();
        s8.setup(inp8, 0, inp8.length);
        s8.do_find_line_end();
        if (s8.get_result_pos() != 6) {
            System.out.println("FAIL 8: Find line end at //");
            failures++;
        }

        if (failures > 0) { System.out.println("FAIL: " + failures + " failures"); System.exit(1); }
        System.out.println("PASS: javascript_skipper (8 cases)");
    }
}

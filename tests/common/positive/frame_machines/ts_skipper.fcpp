@@[target("cpp_17")]

#include <iostream>
#include <cstdint>
#include <algorithm>

// TypeScriptSyntaxSkipper — FSM for skipping TS/JS comments and strings.
// Translated from framec's native_region_scanner/typescript_skipper.frs
//
// Adds template literal awareness (backtick strings with ${} interpolation)
// on top of the C-style comment and string patterns.

@@system TSSyntaxSkipperFsm {
    operations:
        setup(input_bytes: std::vector<uint8_t>, start: int, length: int) {
            this->bytes = input_bytes;
            this->pos = start;
            this->scan_end = length;
        }
        get_result_pos(): int {
            return this->result_pos;
        }
        get_success(): int {
            return this->success;
        }

    interface:
        do_skip_comment()
        do_skip_string()
        do_find_line_end()

    machine:
        $Init {
            do_skip_comment() { -> $SkipComment }
            do_skip_string() { -> $SkipString }
            do_find_line_end() { -> $FindLineEnd }
        }

        $SkipComment {
            $>() {
                int i = this->pos;
                int end = this->scan_end;
                const std::vector<uint8_t>& bs = this->bytes;

                // // line comment
                if (i + 1 < end && bs[i] == '/' && bs[i + 1] == '/') {
                    int j = i + 2;
                    while (j < end && bs[j] != '\n') {
                        j++;
                    }
                    this->result_pos = j;
                    this->success = 1;
                    return;
                }

                // /* block comment */
                if (i + 1 < end && bs[i] == '/' && bs[i + 1] == '*') {
                    int j = i + 2;
                    while (j + 1 < end) {
                        if (bs[j] == '*' && bs[j + 1] == '/') {
                            this->result_pos = j + 2;
                            this->success = 1;
                            return;
                        }
                        j++;
                    }
                    this->result_pos = end;
                    this->success = 1;
                    return;
                }

                this->success = 0;
            }
        }

        $SkipString {
            $>() {
                int i = this->pos;
                int end = this->scan_end;
                const std::vector<uint8_t>& bs = this->bytes;

                // Template literal: `...${...}...`
                if (i < end && bs[i] == '`') {
                    int j = i + 1;
                    int template_depth = 0;
                    while (j < end) {
                        int b = bs[j];
                        if (b == '`' && template_depth == 0) {
                            this->result_pos = j + 1;
                            this->success = 1;
                            return;
                        }
                        if (b == '\\') {
                            j += 2;
                            continue;
                        }
                        if (b == '$' && j + 1 < end && bs[j + 1] == '{') {
                            template_depth++;
                            j += 2;
                            continue;
                        }
                        if (b == '}' && template_depth > 0) {
                            template_depth--;
                        }
                        j++;
                    }
                    this->result_pos = end;
                    this->success = 1;
                    return;
                }

                // Simple string: " or '
                if (i < end && (bs[i] == '"' || bs[i] == '\'')) {
                    int q = bs[i];
                    int j = i + 1;
                    while (j < end) {
                        if (bs[j] == '\\') {
                            j += 2;
                            continue;
                        }
                        if (bs[j] == q) {
                            this->result_pos = j + 1;
                            this->success = 1;
                            return;
                        }
                        j++;
                    }
                    this->result_pos = end;
                    this->success = 1;
                    return;
                }

                this->success = 0;
            }
        }

        $FindLineEnd {
            $>() {
                int j = this->pos;
                int end = this->scan_end;
                const std::vector<uint8_t>& bs = this->bytes;
                bool in_template = false;
                int template_depth = 0;

                while (j < end) {
                    int b = bs[j];

                    if (in_template) {
                        if (b == '`' && template_depth == 0) {
                            in_template = false;
                            j++;
                            continue;
                        }
                        if (b == '\\') {
                            j += 2;
                            continue;
                        }
                        if (b == '$' && j + 1 < end && bs[j + 1] == '{') {
                            template_depth++;
                            j += 2;
                            continue;
                        }
                        if (b == '}' && template_depth > 0) {
                            template_depth--;
                        }
                        j++;
                        continue;
                    }

                    if (b == '\n' || b == ';') { break; }
                    if (b == '/' && j + 1 < end && bs[j + 1] == '/') { break; }
                    if (b == '/' && j + 1 < end && bs[j + 1] == '*') { break; }
                    if (b == '`') {
                        in_template = true;
                        j++;
                        continue;
                    }
                    if (b == '"' || b == '\'') {
                        int q = b;
                        j++;
                        while (j < end && bs[j] != q) {
                            if (bs[j] == '\\') { j++; }
                            j++;
                        }
                        if (j < end) { j++; }
                        continue;
                    }

                    j++;
                }

                this->result_pos = j;
            }
        }

    domain:
        bytes: std::vector<uint8_t> = {}
        pos: int = 0
        scan_end: int = 0
        result_pos: int = 0
        success: int = 1
}

int main() {
    int failures = 0;

    auto to_bytes = [](const std::string& s) -> std::vector<uint8_t> {
        return std::vector<uint8_t>(s.begin(), s.end());
    };

    // Test 1: Skip // line comment
    auto s1 = @@TSSyntaxSkipperFsm();
    auto inp1 = to_bytes("// comment\ncode");
    s1.setup(inp1, 0, inp1.size());
    s1.do_skip_comment();
    if (s1.get_success() != 1 || s1.get_result_pos() != 10) {
        printf("FAIL 1: success=%d, pos=%d\n", s1.get_success(), s1.get_result_pos());
        failures++;
    }

    // Test 2: Skip /* block comment */
    auto s2 = @@TSSyntaxSkipperFsm();
    auto inp2 = to_bytes("/* block */code");
    s2.setup(inp2, 0, inp2.size());
    s2.do_skip_comment();
    if (s2.get_success() != 1 || s2.get_result_pos() != 11) {
        printf("FAIL 2: success=%d, pos=%d\n", s2.get_success(), s2.get_result_pos());
        failures++;
    }

    // Test 3: Skip template literal
    auto s3 = @@TSSyntaxSkipperFsm();
    auto inp3 = to_bytes("`hello ${name} world`rest");
    s3.setup(inp3, 0, inp3.size());
    s3.do_skip_string();
    if (s3.get_success() != 1 || s3.get_result_pos() != 21) {
        printf("FAIL 3: success=%d, pos=%d\n", s3.get_success(), s3.get_result_pos());
        failures++;
    }

    // Test 4: Skip simple double-quoted string
    auto s4 = @@TSSyntaxSkipperFsm();
    auto inp4 = to_bytes("\"hello\" rest");
    s4.setup(inp4, 0, inp4.size());
    s4.do_skip_string();
    if (s4.get_success() != 1 || s4.get_result_pos() != 7) {
        printf("FAIL 4: success=%d, pos=%d\n", s4.get_success(), s4.get_result_pos());
        failures++;
    }

    // Test 5: Skip template with nested ${}
    auto s5 = @@TSSyntaxSkipperFsm();
    auto inp5 = to_bytes("`${a + ${b}}`rest");
    s5.setup(inp5, 0, inp5.size());
    s5.do_skip_string();
    if (s5.get_success() != 1) {
        printf("FAIL 5: success=%d\n", s5.get_success());
        failures++;
    }

    // Test 6: Find line end skips over template literals
    auto s6 = @@TSSyntaxSkipperFsm();
    auto inp6 = to_bytes("x = `hello`;\nnext");
    s6.setup(inp6, 0, inp6.size());
    s6.do_find_line_end();
    if (s6.get_result_pos() != 11) {
        printf("FAIL 6: pos=%d, expected 11 (at ;)\n", s6.get_result_pos());
        failures++;
    }

    // Test 7: Not a string
    auto s7 = @@TSSyntaxSkipperFsm();
    auto inp7 = to_bytes("x + 1");
    s7.setup(inp7, 0, inp7.size());
    s7.do_skip_string();
    if (s7.get_success() != 0) {
        printf("FAIL 7: should not be string\n");
        failures++;
    }

    if (failures > 0) {
        printf("FAIL: %d failures\n", failures);
        return 1;
    }
    printf("PASS: ts_skipper (7 cases)\n");
    return 0;
}

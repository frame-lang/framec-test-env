@@[target("ruby")]

# javascript_skipper -- FSM for skipping syntax constructs.

@@system JavaScriptSyntaxSkipperFsm {
    operations:
        setup(input_bytes, start, length) {
            self.bytes = input_bytes
            self.pos = start
            self.scan_end = length
        }
        get_result_pos() {
            return self.result_pos
        }
        get_success() {
            return self.success
        }

    interface:
        do_skip_comment()
        do_skip_string()
        do_find_line_end()
        do_balanced_paren_end()

    machine:
        $Init {
            do_skip_comment() { -> $SkipComment }
            do_skip_string() { -> $SkipString }
            do_find_line_end() { -> $FindLineEnd }
            do_balanced_paren_end() { -> $BalancedParenEnd }
        }

        $SkipComment {
            $>() {
                i = self.pos
                the_end = self.scan_end
                bs = self.bytes

                if i + 1 < the_end && bs[i] == 0x2F && bs[i + 1] == 0x2F
                    j = i + 2
                    while j < the_end && bs[j] != 0x0A
                        j += 1
                    end
                    self.result_pos = j
                    self.success = 1
                    return
                end
                if i + 1 < the_end && bs[i] == 0x2F && bs[i + 1] == 0x2A
                    j = i + 2
                    while j + 1 < the_end
                        if bs[j] == 0x2A && bs[j + 1] == 0x2F
                            self.result_pos = j + 2
                            self.success = 1
                            return
                        end
                        j += 1
                    end
                    self.result_pos = the_end
                    self.success = 1
                    return
                end
                self.success = 0
            }
        }

        $SkipString {
            $>() {
                i = self.pos
                the_end = self.scan_end
                bs = self.bytes

                if i < the_end && bs[i] == 0x60
                    j = i + 1
                    brace_depth = 0
                    while j < the_end
                        if bs[j] == 0x60 && brace_depth == 0
                            self.result_pos = j + 1
                            self.success = 1
                            return
                        end
                        if bs[j] == 0x5C
                            j += 2
                            next
                        end
                        if bs[j] == 0x24 && j + 1 < the_end && bs[j + 1] == 0x7B
                            brace_depth += 1
                            j += 2
                            next
                        end
                        if bs[j] == 0x7D && brace_depth > 0
                            brace_depth -= 1
                        end
                        j += 1
                    end
                    self.result_pos = the_end
                    self.success = 1
                    return
                end

                if i < the_end && (bs[i] == 0x22 || bs[i] == 0x27)
                    q = bs[i]
                    j = i + 1
                    while j < the_end
                        if bs[j] == 0x5C
                            j += 2
                            next
                        end
                        if bs[j] == q
                            self.result_pos = j + 1
                            self.success = 1
                            return
                        end
                        j += 1
                    end
                    self.result_pos = the_end
                    self.success = 1
                    return
                end
                self.success = 0
            }
        }

        $FindLineEnd {
            $>() {
                j = self.pos
                the_end = self.scan_end
                bs = self.bytes

                in_string = 0
                in_template = 0
                template_brace_depth = 0
                while j < the_end
                    b = bs[j]
                    if b == 0x0A
                        break
                    end
                    if in_template != 0
                        if b == 0x60 && template_brace_depth == 0
                            in_template = 0
                            j += 1
                            next
                        end
                        if b == 0x5C
                            j += 2
                            next
                        end
                        if b == 0x24 && j + 1 < the_end && bs[j + 1] == 0x7B
                            template_brace_depth += 1
                            j += 2
                            next
                        end
                        if b == 0x7D && template_brace_depth > 0
                            template_brace_depth -= 1
                        end
                        j += 1
                        next
                    end
                    if in_string != 0
                        if b == 0x5C
                            j += 2
                            next
                        end
                        if b == in_string
                            in_string = 0
                        end
                        j += 1
                        next
                    end
                    if b == 0x3B || b == 0x7D
                        break
                    end
                    if b == 0x2F && j + 1 < the_end && (bs[j + 1] == 0x2F || bs[j + 1] == 0x2A)
                        break
                    end
                    if b == 0x27 || b == 0x22
                        in_string = b
                        j += 1
                        next
                    end
                    if b == 0x60
                        in_template = 1
                        j += 1
                        next
                    end
                    j += 1
                end
                self.result_pos = j
            }
        }

        $BalancedParenEnd {
            $>() {
                i = self.pos
                the_end = self.scan_end
                bs = self.bytes

                if i >= the_end || bs[i] != 0x28
                    self.success = 0
                    return
                end
                depth = 0
                in_string = 0
                in_template = 0
                while i < the_end
                    b = bs[i]
                    if in_template != 0
                        if b == 0x60
                            in_template = 0
                        end
                        if b == 0x5C
                            i += 2
                            next
                        end
                        i += 1
                        next
                    end
                    if in_string != 0
                        if b == 0x5C
                            i += 2
                            next
                        end
                        if b == in_string
                            in_string = 0
                        end
                        i += 1
                        next
                    end
                    if b == 0x27 || b == 0x22
                        in_string = b
                        i += 1
                    elsif b == 0x60
                        in_template = 1
                        i += 1
                    elsif b == 0x28
                        depth += 1
                        i += 1
                    elsif b == 0x29
                        depth -= 1
                        i += 1
                        if depth == 0
                            self.result_pos = i
                            self.success = 1
                            return
                        end
                    else
                        i += 1
                    end
                end
                self.success = 0
            }
        }

    domain:
        bytes = []
        pos: int = 0
        scan_end: int = 0
        result_pos: int = 0
        success: int = 1
}

failures = 0

s1 = JavaScriptSyntaxSkipperFsm.new
inp1 = "// hello\ncode".bytes
s1.setup(inp1, 0, inp1.length)
s1.do_skip_comment()
if s1.get_success() != 1 || s1.get_result_pos() != 8
    puts("FAIL 1: Skip line comment")
    failures += 1
end

s2 = JavaScriptSyntaxSkipperFsm.new
inp2 = "/* block */code".bytes
s2.setup(inp2, 0, inp2.length)
s2.do_skip_comment()
if s2.get_success() != 1 || s2.get_result_pos() != 11
    puts("FAIL 2: Skip block comment")
    failures += 1
end

s3 = JavaScriptSyntaxSkipperFsm.new
inp3 = "\"hello world\" rest".bytes
s3.setup(inp3, 0, inp3.length)
s3.do_skip_string()
if s3.get_success() != 1 || s3.get_result_pos() != 13
    puts("FAIL 3: Skip double-quoted string")
    failures += 1
end

s4 = JavaScriptSyntaxSkipperFsm.new
inp4 = "`template ${x}` rest".bytes
s4.setup(inp4, 0, inp4.length)
s4.do_skip_string()
if s4.get_success() != 1 || s4.get_result_pos() != 15
    puts("FAIL 4: Skip template literal")
    failures += 1
end

s5 = JavaScriptSyntaxSkipperFsm.new
inp5 = "x + 1\nmore".bytes
s5.setup(inp5, 0, inp5.length)
s5.do_find_line_end()
if s5.get_result_pos() != 5
    puts("FAIL 5: Find line end")
    failures += 1
end

s6 = JavaScriptSyntaxSkipperFsm.new
inp6 = "x + 1".bytes
s6.setup(inp6, 0, inp6.length)
s6.do_skip_comment()
if s6.get_success() != 0
    puts("FAIL 6: Not a comment")
    failures += 1
end

s7 = JavaScriptSyntaxSkipperFsm.new
inp7 = "(a, `t`, c) rest".bytes
s7.setup(inp7, 0, inp7.length)
s7.do_balanced_paren_end()
if s7.get_success() != 1 || s7.get_result_pos() != 11
    puts("FAIL 7: Balanced parens with template")
    failures += 1
end

s8 = JavaScriptSyntaxSkipperFsm.new
inp8 = "x + 1 // comment".bytes
s8.setup(inp8, 0, inp8.length)
s8.do_find_line_end()
if s8.get_result_pos() != 6
    puts("FAIL 8: Find line end at //")
    failures += 1
end

if failures > 0
    puts("FAIL: #{failures} failures")
    exit(1)
end
puts("PASS: javascript_skipper (8 cases)")

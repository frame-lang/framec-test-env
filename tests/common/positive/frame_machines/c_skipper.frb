@@[target("ruby")]

# CSyntaxSkipper -- FSM for skipping C-style comments and strings.
# Translated from framec's native_region_scanner/c_skipper.frs
#
# Demonstrates the skipper pattern: dispatch on entry point, scan
# to find the end of the construct, report result via domain vars.

@@system CSyntaxSkipperFsm {
    operations:
        setup(input_bytes, start, length) {
            self.bytes = input_bytes
            self.pos = start
            self.end = length
        }
        get_result_pos() {
            return self.result_pos
        }
        get_success() {
            return self.success
        }

    interface:
        do_skip_comment()
        do_skip_string()
        do_find_line_end()
        do_balanced_paren_end()

    machine:
        $Init {
            do_skip_comment() { -> $SkipComment }
            do_skip_string() { -> $SkipString }
            do_find_line_end() { -> $FindLineEnd }
            do_balanced_paren_end() { -> $BalancedParenEnd }
        }

        $SkipComment {
            $>() {
                i = self.pos
                the_end = self.end
                bs = self.bytes

                # Try line comment: //
                if i + 1 < the_end && bs[i] == 0x2F && bs[i + 1] == 0x2F
                    j = i + 2
                    while j < the_end && bs[j] != 0x0A
                        j += 1
                    end
                    self.result_pos = j
                    self.success = 1
                    return
                end

                # Try block comment: /* ... */
                if i + 1 < the_end && bs[i] == 0x2F && bs[i + 1] == 0x2A
                    j = i + 2
                    while j + 1 < the_end
                        if bs[j] == 0x2A && bs[j + 1] == 0x2F
                            self.result_pos = j + 2
                            self.success = 1
                            return
                        end
                        j += 1
                    end
                    self.result_pos = the_end
                    self.success = 1
                    return
                end

                self.success = 0
            }
        }

        $SkipString {
            $>() {
                i = self.pos
                the_end = self.end
                bs = self.bytes

                if i < the_end && (bs[i] == 0x22 || bs[i] == 0x27)
                    q = bs[i]
                    j = i + 1
                    while j < the_end
                        if bs[j] == 0x5C
                            j += 2
                            next
                        end
                        if bs[j] == q
                            self.result_pos = j + 1
                            self.success = 1
                            return
                        end
                        j += 1
                    end
                    self.result_pos = the_end
                    self.success = 1
                    return
                end

                self.success = 0
            }
        }

        $FindLineEnd {
            $>() {
                j = self.pos
                the_end = self.end
                bs = self.bytes

                while j < the_end
                    b = bs[j]
                    if b == 0x0A || b == 0x3B
                        break
                    end
                    if b == 0x2F && j + 1 < the_end && bs[j + 1] == 0x2F
                        break
                    end
                    if b == 0x2F && j + 1 < the_end && bs[j + 1] == 0x2A
                        break
                    end
                    j += 1
                end

                self.result_pos = j
            }
        }

        $BalancedParenEnd {
            $>() {
                i = self.pos
                the_end = self.end
                bs = self.bytes

                if i >= the_end || bs[i] != 0x28
                    self.success = 0
                    return
                end

                depth = 1
                j = i + 1
                while j < the_end && depth > 0
                    b = bs[j]
                    if b == 0x28
                        depth += 1
                    elsif b == 0x29
                        depth -= 1
                    elsif b == 0x22 || b == 0x27
                        q = b
                        j += 1
                        while j < the_end && bs[j] != q
                            if bs[j] == 0x5C
                                j += 1
                            end
                            j += 1
                        end
                        # j is at closing quote
                    end
                    j += 1
                end

                if depth == 0
                    self.result_pos = j
                    self.success = 1
                else
                    self.result_pos = the_end
                    self.success = 0
                end
            }
        }

    domain:
        bytes = []
        pos: int = 0
        end: int = 0
        result_pos: int = 0
        success: int = 1
}

failures = 0

# Test 1: Skip line comment
s1 = CSyntaxSkipperFsm.new
inp1 = "// hello\ncode".bytes
s1.setup(inp1, 0, inp1.length)
s1.do_skip_comment()
if s1.get_success() != 1 || s1.get_result_pos() != 8
    puts("FAIL 1: success=#{s1.get_success()}, pos=#{s1.get_result_pos()}")
    failures += 1
end

# Test 2: Skip block comment
s2 = CSyntaxSkipperFsm.new
inp2 = "/* block */code".bytes
s2.setup(inp2, 0, inp2.length)
s2.do_skip_comment()
if s2.get_success() != 1 || s2.get_result_pos() != 11
    puts("FAIL 2: success=#{s2.get_success()}, pos=#{s2.get_result_pos()}")
    failures += 1
end

# Test 3: Not a comment
s3 = CSyntaxSkipperFsm.new
inp3 = "x + 1".bytes
s3.setup(inp3, 0, inp3.length)
s3.do_skip_comment()
if s3.get_success() != 0
    puts("FAIL 3: should not be a comment")
    failures += 1
end

# Test 4: Skip double-quoted string
s4 = CSyntaxSkipperFsm.new
inp4 = "\"hello world\" rest".bytes
s4.setup(inp4, 0, inp4.length)
s4.do_skip_string()
if s4.get_success() != 1 || s4.get_result_pos() != 13
    puts("FAIL 4: success=#{s4.get_success()}, pos=#{s4.get_result_pos()}")
    failures += 1
end

# Test 5: Skip string with escaped quote
s5 = CSyntaxSkipperFsm.new
inp5 = "\"he\\\"llo\" rest".bytes
s5.setup(inp5, 0, inp5.length)
s5.do_skip_string()
if s5.get_success() != 1 || s5.get_result_pos() != 9
    puts("FAIL 5: success=#{s5.get_success()}, pos=#{s5.get_result_pos()}")
    failures += 1
end

# Test 6: Find line end (stops at newline)
s6 = CSyntaxSkipperFsm.new
inp6 = "x + 1\nmore".bytes
s6.setup(inp6, 0, inp6.length)
s6.do_find_line_end()
if s6.get_result_pos() != 5
    puts("FAIL 6: pos=#{s6.get_result_pos()}, expected 5")
    failures += 1
end

# Test 7: Find line end (stops at // comment)
s7 = CSyntaxSkipperFsm.new
inp7 = "x + 1 // comment".bytes
s7.setup(inp7, 0, inp7.length)
s7.do_find_line_end()
if s7.get_result_pos() != 6
    puts("FAIL 7: pos=#{s7.get_result_pos()}, expected 6")
    failures += 1
end

# Test 8: Balanced parens
s8 = CSyntaxSkipperFsm.new
inp8 = "(a, f(b), c) rest".bytes
s8.setup(inp8, 0, inp8.length)
s8.do_balanced_paren_end()
if s8.get_success() != 1 || s8.get_result_pos() != 12
    puts("FAIL 8: success=#{s8.get_success()}, pos=#{s8.get_result_pos()}")
    failures += 1
end

if failures > 0
    puts("FAIL: #{failures} failures")
    exit(1)
end
puts("PASS: c_skipper (8 cases)")

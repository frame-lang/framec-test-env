@@[target("kotlin")]

import kotlin.system.exitProcess

// TypeScriptSyntaxSkipper — FSM for skipping TS/JS comments and strings.
// Translated from framec's native_region_scanner/typescript_skipper.frs
//
// Adds template literal awareness (backtick strings with ${} interpolation)
// on top of the C-style comment and string patterns.

@@system TSSyntaxSkipperFsm {
    operations:
        setup(input_bytes: ByteArray, start: Int, length: Int) {
            this.bytes = input_bytes
            this.pos = start
            this.scan_end = length
        }
        get_result_pos(): Int {
            return this.result_pos
        }
        get_success(): Int {
            return this.success
        }

    interface:
        do_skip_comment()
        do_skip_string()
        do_find_line_end()

    machine:
        $Init {
            do_skip_comment() { -> $SkipComment }
            do_skip_string() { -> $SkipString }
            do_find_line_end() { -> $FindLineEnd }
        }

        $SkipComment {
            $>() {
                var i = this.pos
                val end = this.scan_end
                val bs = this.bytes

                // // line comment
                if (i + 1 < end && (bs[i].toInt() and 0xFF) == '/'.code && (bs[i + 1].toInt() and 0xFF) == '/'.code) {
                    var j = i + 2
                    while (j < end && (bs[j].toInt() and 0xFF) != '\n'.code) {
                        j++
                    }
                    this.result_pos = j
                    this.success = 1
                    return
                }

                // /* block comment */
                if (i + 1 < end && (bs[i].toInt() and 0xFF) == '/'.code && (bs[i + 1].toInt() and 0xFF) == '*'.code) {
                    var j = i + 2
                    while (j + 1 < end) {
                        if ((bs[j].toInt() and 0xFF) == '*'.code && (bs[j + 1].toInt() and 0xFF) == '/'.code) {
                            this.result_pos = j + 2
                            this.success = 1
                            return
                        }
                        j++
                    }
                    this.result_pos = end
                    this.success = 1
                    return
                }

                this.success = 0
            }
        }

        $SkipString {
            $>() {
                var i = this.pos
                val end = this.scan_end
                val bs = this.bytes

                // Template literal: `...${...}...`
                if (i < end && (bs[i].toInt() and 0xFF) == '`'.code) {
                    var j = i + 1
                    var templateDepth = 0
                    while (j < end) {
                        val b = bs[j].toInt() and 0xFF
                        if (b == '`'.code && templateDepth == 0) {
                            this.result_pos = j + 1
                            this.success = 1
                            return
                        }
                        if (b == '\\'.code) {
                            j += 2
                            continue
                        }
                        if (b == '$'.code && j + 1 < end && (bs[j + 1].toInt() and 0xFF) == '{'.code) {
                            templateDepth++
                            j += 2
                            continue
                        }
                        if (b == '}'.code && templateDepth > 0) {
                            templateDepth--
                        }
                        j++
                    }
                    this.result_pos = end
                    this.success = 1
                    return
                }

                // Simple string: " or '
                if (i < end && ((bs[i].toInt() and 0xFF) == '"'.code || (bs[i].toInt() and 0xFF) == '\''.code)) {
                    val q = bs[i].toInt() and 0xFF
                    var j = i + 1
                    while (j < end) {
                        if ((bs[j].toInt() and 0xFF) == '\\'.code) {
                            j += 2
                            continue
                        }
                        if ((bs[j].toInt() and 0xFF) == q) {
                            this.result_pos = j + 1
                            this.success = 1
                            return
                        }
                        j++
                    }
                    this.result_pos = end
                    this.success = 1
                    return
                }

                this.success = 0
            }
        }

        $FindLineEnd {
            $>() {
                var j = this.pos
                val end = this.scan_end
                val bs = this.bytes
                var inTemplate = false
                var templateDepth = 0

                while (j < end) {
                    val b = bs[j].toInt() and 0xFF

                    if (inTemplate) {
                        if (b == '`'.code && templateDepth == 0) {
                            inTemplate = false
                            j++
                            continue
                        }
                        if (b == '\\'.code) {
                            j += 2
                            continue
                        }
                        if (b == '$'.code && j + 1 < end && (bs[j + 1].toInt() and 0xFF) == '{'.code) {
                            templateDepth++
                            j += 2
                            continue
                        }
                        if (b == '}'.code && templateDepth > 0) {
                            templateDepth--
                        }
                        j++
                        continue
                    }

                    if (b == '\n'.code || b == ';'.code) { break }
                    if (b == '/'.code && j + 1 < end && (bs[j + 1].toInt() and 0xFF) == '/'.code) { break }
                    if (b == '/'.code && j + 1 < end && (bs[j + 1].toInt() and 0xFF) == '*'.code) { break }
                    if (b == '`'.code) {
                        inTemplate = true
                        j++
                        continue
                    }
                    if (b == '"'.code || b == '\''.code) {
                        val q = b
                        j++
                        while (j < end && (bs[j].toInt() and 0xFF) != q) {
                            if ((bs[j].toInt() and 0xFF) == '\\'.code) { j++ }
                            j++
                        }
                        if (j < end) { j++ }
                        continue
                    }

                    j++
                }

                this.result_pos = j
            }
        }

    domain:
        bytes: ByteArray = ByteArray(0)
        pos: Int = 0
        scan_end: Int = 0
        result_pos: Int = 0
        success: Int = 1
}

fun main() {
    var failures = 0

    // Test 1: Skip // line comment
    val s1 = @@TSSyntaxSkipperFsm()
    val inp1 = "// comment\ncode".toByteArray()
    s1.setup(inp1, 0, inp1.size)
    s1.do_skip_comment()
    if (s1.get_success() != 1 || s1.get_result_pos() != 10) {
        println("FAIL 1: success=${s1.get_success()}, pos=${s1.get_result_pos()}")
        failures++
    }

    // Test 2: Skip /* block comment */
    val s2 = @@TSSyntaxSkipperFsm()
    val inp2 = "/* block */code".toByteArray()
    s2.setup(inp2, 0, inp2.size)
    s2.do_skip_comment()
    if (s2.get_success() != 1 || s2.get_result_pos() != 11) {
        println("FAIL 2: success=${s2.get_success()}, pos=${s2.get_result_pos()}")
        failures++
    }

    // Test 3: Skip template literal
    val s3 = @@TSSyntaxSkipperFsm()
    val inp3 = "`hello \${name} world`rest".toByteArray()
    s3.setup(inp3, 0, inp3.size)
    s3.do_skip_string()
    if (s3.get_success() != 1 || s3.get_result_pos() != 21) {
        println("FAIL 3: success=${s3.get_success()}, pos=${s3.get_result_pos()}")
        failures++
    }

    // Test 4: Skip simple double-quoted string
    val s4 = @@TSSyntaxSkipperFsm()
    val inp4 = "\"hello\" rest".toByteArray()
    s4.setup(inp4, 0, inp4.size)
    s4.do_skip_string()
    if (s4.get_success() != 1 || s4.get_result_pos() != 7) {
        println("FAIL 4: success=${s4.get_success()}, pos=${s4.get_result_pos()}")
        failures++
    }

    // Test 5: Skip template with nested ${}
    val s5 = @@TSSyntaxSkipperFsm()
    val inp5 = "`\${a + \${b}}`rest".toByteArray()
    s5.setup(inp5, 0, inp5.size)
    s5.do_skip_string()
    if (s5.get_success() != 1) {
        println("FAIL 5: success=${s5.get_success()}")
        failures++
    }

    // Test 6: Find line end skips over template literals
    val s6 = @@TSSyntaxSkipperFsm()
    val inp6 = "x = `hello`;\nnext".toByteArray()
    s6.setup(inp6, 0, inp6.size)
    s6.do_find_line_end()
    if (s6.get_result_pos() != 11) {
        println("FAIL 6: pos=${s6.get_result_pos()}, expected 11 (at ;)")
        failures++
    }

    // Test 7: Not a string
    val s7 = @@TSSyntaxSkipperFsm()
    val inp7 = "x + 1".toByteArray()
    s7.setup(inp7, 0, inp7.size)
    s7.do_skip_string()
    if (s7.get_success() != 0) {
        println("FAIL 7: should not be string")
        failures++
    }

    if (failures > 0) {
        println("FAIL: $failures failures")
        exitProcess(1)
    }
    println("PASS: ts_skipper (7 cases)")
}

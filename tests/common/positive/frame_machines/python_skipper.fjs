@@target javascript

// PythonSyntaxSkipper — FSM for skipping Python comments and strings.
// Translated from framec's native_region_scanner/python_skipper.frs
//
// Handles: # comments, triple-quoted strings, simple strings,
// Python-style line endings, balanced parens.

@@system PythonSyntaxSkipperFsm {
    operations:
        setup(input_bytes, start, length) {
            this.bytes = input_bytes;
            this.pos = start;
            this.scan_end = length;
        }
        get_result_pos() {
            return this.result_pos;
        }
        get_success() {
            return this.success;
        }

    interface:
        do_skip_comment()
        do_skip_string()
        do_find_line_end()
        do_balanced_paren_end()

    machine:
        $Init {
            do_skip_comment() { -> $SkipComment }
            do_skip_string() { -> $SkipString }
            do_find_line_end() { -> $FindLineEnd }
            do_balanced_paren_end() { -> $BalancedParenEnd }
        }

        $SkipComment {
            $>() {
                let i = this.pos;
                const end = this.scan_end;
                const bs = this.bytes;

                if (i < end && bs[i] === 0x23) {
                    let j = i + 1;
                    while (j < end && bs[j] !== 0x0A) { j++; }
                    this.result_pos = j;
                    this.success = 1;
                    return;
                }

                this.success = 0;
            }
        }

        $SkipString {
            $>() {
                let i = this.pos;
                const end = this.scan_end;
                const bs = this.bytes;

                if (i + 2 < end) {
                    if ((bs[i] === 0x22 && bs[i+1] === 0x22 && bs[i+2] === 0x22) ||
                        (bs[i] === 0x27 && bs[i+1] === 0x27 && bs[i+2] === 0x27)) {
                        const q = bs[i];
                        let j = i + 3;
                        while (j + 2 < end) {
                            if (bs[j] === q && bs[j+1] === q && bs[j+2] === q) {
                                this.result_pos = j + 3;
                                this.success = 1;
                                return;
                            }
                            j++;
                        }
                        this.result_pos = end;
                        this.success = 1;
                        return;
                    }
                }

                if (i < end && (bs[i] === 0x22 || bs[i] === 0x27)) {
                    const q = bs[i];
                    let j = i + 1;
                    while (j < end) {
                        if (bs[j] === 0x5C) { j += 2; continue; }
                        if (bs[j] === q) {
                            this.result_pos = j + 1;
                            this.success = 1;
                            return;
                        }
                        j++;
                    }
                    this.result_pos = end;
                    this.success = 1;
                    return;
                }

                this.success = 0;
            }
        }

        $FindLineEnd {
            $>() {
                let j = this.pos;
                const end = this.scan_end;
                const bs = this.bytes;

                while (j < end) {
                    const b = bs[j];
                    if (b === 0x0A || b === 0x3B) { break; }
                    if (b === 0x23) { break; }
                    j++;
                }

                this.result_pos = j;
            }
        }

        $BalancedParenEnd {
            $>() {
                let i = this.pos;
                const end = this.scan_end;
                const bs = this.bytes;

                if (i >= end || bs[i] !== 0x28) {
                    this.success = 0;
                    return;
                }

                let depth = 1;
                let j = i + 1;
                while (j < end && depth > 0) {
                    const b = bs[j];
                    if (b === 0x28) { depth++; }
                    else if (b === 0x29) { depth--; }
                    else if (b === 0x22 || b === 0x27) {
                        const q = b;
                        j++;
                        while (j < end && bs[j] !== q) {
                            if (bs[j] === 0x5C) { j++; }
                            j++;
                        }
                    }
                    j++;
                }

                if (depth === 0) {
                    this.result_pos = j;
                    this.success = 1;
                } else {
                    this.result_pos = end;
                    this.success = 0;
                }
            }
        }

    domain:
        bytes = []
        pos = 0
        scan_end = 0
        result_pos = 0
        success = 1
}

const enc = s => Array.from(Buffer.from(s));

let failures = 0;

// Test 1: Skip hash comment
const s1 = @@PythonSyntaxSkipperFsm();
const inp1 = enc("# comment\ncode");
s1.setup(inp1, 0, inp1.length);
s1.do_skip_comment();
if (s1.get_success() !== 1 || s1.get_result_pos() !== 9) {
    console.log("FAIL 1: success=" + s1.get_success() + ", pos=" + s1.get_result_pos());
    failures++;
}

// Test 2: Not a comment
const s2 = @@PythonSyntaxSkipperFsm();
const inp2 = enc("x + 1");
s2.setup(inp2, 0, inp2.length);
s2.do_skip_comment();
if (s2.get_success() !== 0) {
    console.log("FAIL 2: should not be comment");
    failures++;
}

// Test 3: Skip triple-quoted string
const s3 = @@PythonSyntaxSkipperFsm();
const inp3 = enc('"""hello world"""rest');
s3.setup(inp3, 0, inp3.length);
s3.do_skip_string();
if (s3.get_success() !== 1 || s3.get_result_pos() !== 17) {
    console.log("FAIL 3: success=" + s3.get_success() + ", pos=" + s3.get_result_pos());
    failures++;
}

// Test 4: Skip simple string
const s4 = @@PythonSyntaxSkipperFsm();
const inp4 = enc('"hello" rest');
s4.setup(inp4, 0, inp4.length);
s4.do_skip_string();
if (s4.get_success() !== 1 || s4.get_result_pos() !== 7) {
    console.log("FAIL 4: success=" + s4.get_success() + ", pos=" + s4.get_result_pos());
    failures++;
}

// Test 5: Skip string with escape
const s5 = @@PythonSyntaxSkipperFsm();
const inp5 = enc("'he\\'llo' rest");
s5.setup(inp5, 0, inp5.length);
s5.do_skip_string();
if (s5.get_success() !== 1 || s5.get_result_pos() !== 9) {
    console.log("FAIL 5: success=" + s5.get_success() + ", pos=" + s5.get_result_pos());
    failures++;
}

// Test 6: Find line end (stops at #)
const s6 = @@PythonSyntaxSkipperFsm();
const inp6 = enc("x + 1 # comment");
s6.setup(inp6, 0, inp6.length);
s6.do_find_line_end();
if (s6.get_result_pos() !== 6) {
    console.log("FAIL 6: pos=" + s6.get_result_pos() + ", expected 6");
    failures++;
}

// Test 7: Balanced parens
const s7 = @@PythonSyntaxSkipperFsm();
const inp7 = enc("(a, f(b)) rest");
s7.setup(inp7, 0, inp7.length);
s7.do_balanced_paren_end();
if (s7.get_success() !== 1 || s7.get_result_pos() !== 9) {
    console.log("FAIL 7: success=" + s7.get_success() + ", pos=" + s7.get_result_pos());
    failures++;
}

if (failures > 0) { console.log("FAIL: " + failures + " failures"); process.exit(1); }
console.log("PASS: python_skipper (7 cases)");

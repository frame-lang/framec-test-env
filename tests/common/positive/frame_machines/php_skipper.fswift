@@[target("swift")]

import Foundation

// PhpSyntaxSkipper -- FSM for skipping PHP comments and strings.

@@system PhpSyntaxSkipperFsm {
    operations:
        setup(input_bytes: [UInt8], start: Int, length: Int) {
            self.bytes = input_bytes
            self.pos = start
            self.scan_end = length
        }
        get_result_pos(): Int {
            return self.result_pos
        }
        get_success(): Int {
            return self.success
        }

    interface:
        do_skip_comment()
        do_skip_string()
        do_find_line_end()
        do_balanced_paren_end()

    machine:
        $Init {
            do_skip_comment() { -> $SkipComment }
            do_skip_string() { -> $SkipString }
            do_find_line_end() { -> $FindLineEnd }
            do_balanced_paren_end() { -> $BalancedParenEnd }
        }

        $SkipComment {
            $>() {
                var i = self.pos
                let end = self.scan_end
                let bs = self.bytes

                // Line comment: //
                if i + 1 < end && bs[i] == UInt8(ascii: "/") && bs[i + 1] == UInt8(ascii: "/") {
                    var j = i + 2
                    while j < end && bs[j] != 0x0A {
                        j += 1
                    }
                    self.result_pos = j
                    self.success = 1
                    return
                }

                // Hash comment: #
                if i < end && bs[i] == UInt8(ascii: "#") {
                    var j = i + 1
                    while j < end && bs[j] != 0x0A {
                        j += 1
                    }
                    self.result_pos = j
                    self.success = 1
                    return
                }

                // Block comment: /* ... */
                if i + 1 < end && bs[i] == UInt8(ascii: "/") && bs[i + 1] == UInt8(ascii: "*") {
                    var j = i + 2
                    while j + 1 < end {
                        if bs[j] == UInt8(ascii: "*") && bs[j + 1] == UInt8(ascii: "/") {
                            self.result_pos = j + 2
                            self.success = 1
                            return
                        }
                        j += 1
                    }
                    self.result_pos = end
                    self.success = 1
                    return
                }

                self.success = 0
            }
        }

        $SkipString {
            $>() {
                var i = self.pos
                let end = self.scan_end
                let bs = self.bytes

                // Heredoc/nowdoc: <<<EOT ... EOT;
                if i + 2 < end && bs[i] == UInt8(ascii: "<") && bs[i + 1] == UInt8(ascii: "<") && bs[i + 2] == UInt8(ascii: "<") {
                    var j = i + 3
                    var nowdoc = 0
                    if j < end && bs[j] == UInt8(ascii: "'") {
                        nowdoc = 1
                        j += 1
                    }
                    let tag_start = j
                    while j < end && (Character(UnicodeScalar(bs[j])).isLetter || Character(UnicodeScalar(bs[j])).isNumber || bs[j] == UInt8(ascii: "_")) {
                        j += 1
                    }
                    let tag_end_pos = j
                    if nowdoc == 1 && j < end && bs[j] == UInt8(ascii: "'") {
                        j += 1
                    }
                    let tag_len = tag_end_pos - tag_start
                    if tag_len > 0 {
                        while j < end && bs[j] != 0x0A {
                            j += 1
                        }
                        if j < end {
                            j += 1
                        }
                        while j < end {
                            var match = true
                            if j + tag_len <= end {
                                for t in 0..<tag_len {
                                    if bs[j + t] != bs[tag_start + t] {
                                        match = false
                                        break
                                    }
                                }
                            } else {
                                match = false
                            }
                            if match {
                                var k = j + tag_len
                                if k < end && bs[k] == UInt8(ascii: ";") {
                                    k += 1
                                }
                                if k >= end || bs[k] == 0x0A {
                                    if k < end && bs[k] == 0x0A {
                                        k += 1
                                    }
                                    self.result_pos = k
                                    self.success = 1
                                    return
                                }
                            }
                            while j < end && bs[j] != 0x0A {
                                j += 1
                            }
                            if j < end {
                                j += 1
                            }
                        }
                        self.result_pos = end
                        self.success = 1
                        return
                    }
                }

                // Simple string: " or '
                if i < end && (bs[i] == 0x22 || bs[i] == UInt8(ascii: "'")) {
                    let q = bs[i]
                    var j = i + 1
                    while j < end {
                        if bs[j] == UInt8(ascii: "\\") {
                            j += 2
                            continue
                        }
                        if bs[j] == q {
                            self.result_pos = j + 1
                            self.success = 1
                            return
                        }
                        j += 1
                    }
                    self.result_pos = end
                    self.success = 1
                    return
                }

                self.success = 0
            }
        }

        $FindLineEnd {
            $>() {
                var j = self.pos
                let end = self.scan_end
                let bs = self.bytes
                var in_string = 0

                while j < end {
                    let b = Int(bs[j])
                    if b == 0x0A {
                        break
                    }

                    if in_string != 0 {
                        if b == Int(UInt8(ascii: "\\")) {
                            j += 2
                            continue
                        }
                        if b == in_string {
                            in_string = 0
                        }
                        j += 1
                        continue
                    }

                    if b == Int(UInt8(ascii: ";")) || b == Int(UInt8(ascii: "}")) {
                        break
                    }
                    if b == Int(UInt8(ascii: "/")) && j + 1 < end && (bs[j + 1] == UInt8(ascii: "/") || bs[j + 1] == UInt8(ascii: "*")) {
                        break
                    }
                    if b == Int(UInt8(ascii: "#")) {
                        break
                    }

                    if b == Int(UInt8(ascii: "'")) || b == 0x22 {
                        in_string = b
                        j += 1
                        continue
                    }

                    j += 1
                }

                self.result_pos = j
            }
        }

        $BalancedParenEnd {
            $>() {
                var i = self.pos
                let end = self.scan_end
                let bs = self.bytes

                if i >= end || bs[i] != UInt8(ascii: "(") {
                    self.success = 0
                    return
                }

                var depth = 0
                var in_string = 0

                while i < end {
                    let b = Int(bs[i])

                    if in_string != 0 {
                        if b == Int(UInt8(ascii: "\\")) {
                            i += 2
                            continue
                        }
                        if b == in_string {
                            in_string = 0
                        }
                        i += 1
                        continue
                    }

                    if b == Int(UInt8(ascii: "'")) || b == 0x22 {
                        in_string = b
                        i += 1
                    } else if b == Int(UInt8(ascii: "(")) {
                        depth += 1
                        i += 1
                    } else if b == Int(UInt8(ascii: ")")) {
                        depth -= 1
                        i += 1
                        if depth == 0 {
                            self.result_pos = i
                            self.success = 1
                            return
                        }
                    } else {
                        i += 1
                    }
                }

                self.success = 0
            }
        }

    domain:
        bytes: [UInt8] = []
        pos: Int = 0
        scan_end: Int = 0
        result_pos: Int = 0
        success: Int = 1
}

// main
    var failures = 0

    // Test 1: Skip // line comment
    let s1 = @@PhpSyntaxSkipperFsm()
    let inp1: [UInt8] = Array("// comment\ncode".utf8)
    s1.setup(inp1, 0, inp1.count)
    s1.do_skip_comment()
    if s1.get_success() != 1 || s1.get_result_pos() != 10 {
        print("FAIL 1: success=\(s1.get_success()), pos=\(s1.get_result_pos())")
        failures += 1
    }

    // Test 2: Skip # comment
    let s2 = @@PhpSyntaxSkipperFsm()
    let inp2: [UInt8] = Array("# comment\ncode".utf8)
    s2.setup(inp2, 0, inp2.count)
    s2.do_skip_comment()
    if s2.get_success() != 1 || s2.get_result_pos() != 9 {
        print("FAIL 2: success=\(s2.get_success()), pos=\(s2.get_result_pos())")
        failures += 1
    }

    // Test 3: Skip /* */ block comment
    let s3 = @@PhpSyntaxSkipperFsm()
    let inp3: [UInt8] = Array("/* block */code".utf8)
    s3.setup(inp3, 0, inp3.count)
    s3.do_skip_comment()
    if s3.get_success() != 1 || s3.get_result_pos() != 11 {
        print("FAIL 3: success=\(s3.get_success()), pos=\(s3.get_result_pos())")
        failures += 1
    }

    // Test 4: Skip double-quoted string
    let s4 = @@PhpSyntaxSkipperFsm()
    let inp4: [UInt8] = Array("\"hello\" rest".utf8)
    s4.setup(inp4, 0, inp4.count)
    s4.do_skip_string()
    if s4.get_success() != 1 || s4.get_result_pos() != 7 {
        print("FAIL 4: success=\(s4.get_success()), pos=\(s4.get_result_pos())")
        failures += 1
    }

    // Test 5: Skip single-quoted string
    let s5 = @@PhpSyntaxSkipperFsm()
    let inp5: [UInt8] = Array("'hello' rest".utf8)
    s5.setup(inp5, 0, inp5.count)
    s5.do_skip_string()
    if s5.get_success() != 1 || s5.get_result_pos() != 7 {
        print("FAIL 5: success=\(s5.get_success()), pos=\(s5.get_result_pos())")
        failures += 1
    }

    // Test 6: Skip heredoc
    let s6 = @@PhpSyntaxSkipperFsm()
    let inp6: [UInt8] = Array("<<<EOT\nhello world\nEOT;\nnext".utf8)
    s6.setup(inp6, 0, inp6.count)
    s6.do_skip_string()
    if s6.get_success() != 1 || s6.get_result_pos() != 24 {
        print("FAIL 6: success=\(s6.get_success()), pos=\(s6.get_result_pos())")
        failures += 1
    }

    // Test 7: Find line end (stops at ;)
    let s7 = @@PhpSyntaxSkipperFsm()
    let inp7: [UInt8] = Array("$x = 1; next".utf8)
    s7.setup(inp7, 0, inp7.count)
    s7.do_find_line_end()
    if s7.get_result_pos() != 6 {
        print("FAIL 7: pos=\(s7.get_result_pos()), expected 6")
        failures += 1
    }

    // Test 8: Balanced parens
    let s8 = @@PhpSyntaxSkipperFsm()
    let inp8: [UInt8] = Array("(a, f(b)) rest".utf8)
    s8.setup(inp8, 0, inp8.count)
    s8.do_balanced_paren_end()
    if s8.get_success() != 1 || s8.get_result_pos() != 9 {
        print("FAIL 8: success=\(s8.get_success()), pos=\(s8.get_result_pos())")
        failures += 1
    }

    if failures > 0 {
        print("FAIL: \(failures) failures")
        exit(1)
    }
    print("PASS: php_skipper (8 cases)")

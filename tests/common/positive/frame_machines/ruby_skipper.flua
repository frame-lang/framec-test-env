@@[target("lua")]

-- RubySyntaxSkipper -- FSM for skipping Ruby comments and strings.
-- Translated from framec's native_region_scanner/ruby_skipper.frs
--
-- Handles: # line comments, "..." / '...' strings,
-- %Q{} / %q[] / %w() etc. percent literals,
-- Ruby-style line endings, balanced parens.
--
-- NOTE: Lua is 1-indexed, but the scanner uses 0-indexed positions
-- internally and adjusts when accessing the byte table.

@@system RubySyntaxSkipperFsm {
    operations:
        setup(input_bytes, start, length) {
            self.bytes = input_bytes
            self.pos = start
            self.scan_end = length
        }
        get_result_pos() {
            return self.result_pos
        }
        get_success() {
            return self.success
        }

    interface:
        do_skip_comment()
        do_skip_string()
        do_find_line_end()
        do_balanced_paren_end()

    machine:
        $Init {
            do_skip_comment() { -> $SkipComment }
            do_skip_string() { -> $SkipString }
            do_find_line_end() { -> $FindLineEnd }
            do_balanced_paren_end() { -> $BalancedParenEnd }
        }

        $SkipComment {
            $>() {
                i = self.pos
                scan_end = self.scan_end
                bs = self.bytes

                -- Ruby: # line comment only
                if i < scan_end and bs[i + 1] == 0x23 then
                    j = i + 1
                    while j < scan_end and bs[j + 1] ~= 0x0A do
                        j = j + 1
                    end
                    self.result_pos = j
                    self.success = 1
                    return
                end

                self.success = 0
            }
        }

        $SkipString {
            $>() {
                i = self.pos
                scan_end = self.scan_end
                bs = self.bytes

                -- Percent literals: %Q{...}, %q[...], %w(...), etc.
                if i < scan_end and bs[i + 1] == 0x25 then
                    if i + 1 < scan_end then
                        c1 = bs[i + 2]
                        has_letter = (c1 == 0x51 or c1 == 0x71 or c1 == 0x77 or c1 == 0x57 or c1 == 0x69 or c1 == 0x49 or c1 == 0x72 or c1 == 0x78 or c1 == 0x73)
                        if has_letter and i + 2 < scan_end then
                            opener = bs[i + 3]
                            j = i + 3
                        elseif not ((c1 >= 0x61 and c1 <= 0x7A) or (c1 >= 0x41 and c1 <= 0x5A) or (c1 >= 0x30 and c1 <= 0x39) or c1 == 0x5F) then
                            opener = c1
                            j = i + 2
                        else
                            self.success = 0
                            return
                        end

                        -- Determine closer
                        if opener == 0x7B then
                            closer = 0x7D
                        elseif opener == 0x5B then
                            closer = 0x5D
                        elseif opener == 0x28 then
                            closer = 0x29
                        elseif opener == 0x3C then
                            closer = 0x3E
                        else
                            closer = opener
                            while j < scan_end do
                                if bs[j + 1] == 0x5C then
                                    j = j + 2
                                    goto continue_nonpaired
                                end
                                if bs[j + 1] == closer then
                                    self.result_pos = j + 1
                                    self.success = 1
                                    return
                                end
                                j = j + 1
                                ::continue_nonpaired::
                            end
                            self.result_pos = scan_end
                            self.success = 1
                            return
                        end

                        -- Paired delimiter: track nesting
                        depth = 1
                        while j < scan_end and depth > 0 do
                            if bs[j + 1] == 0x5C then
                                j = j + 2
                                goto continue_paired
                            end
                            if bs[j + 1] == opener then
                                depth = depth + 1
                            elseif bs[j + 1] == closer then
                                depth = depth - 1
                            end
                            j = j + 1
                            ::continue_paired::
                        end
                        self.result_pos = j
                        self.success = 1
                        return
                    end
                end

                -- Simple string: " or '
                if i < scan_end and (bs[i + 1] == 0x22 or bs[i + 1] == 0x27) then
                    q = bs[i + 1]
                    j = i + 1
                    while j < scan_end do
                        if bs[j + 1] == 0x5C then
                            j = j + 2
                            goto continue_simple
                        end
                        if bs[j + 1] == q then
                            self.result_pos = j + 1
                            self.success = 1
                            return
                        end
                        j = j + 1
                        ::continue_simple::
                    end
                    self.result_pos = scan_end
                    self.success = 1
                    return
                end

                self.success = 0
            }
        }

        $FindLineEnd {
            $>() {
                j = self.pos
                scan_end = self.scan_end
                bs = self.bytes
                in_string = 0

                while j < scan_end do
                    b = bs[j + 1]
                    if b == 0x0A then
                        break
                    end

                    -- Inside string
                    if in_string ~= 0 then
                        if b == 0x5C then
                            j = j + 2
                            goto continue_find_line
                        end
                        if b == in_string then
                            in_string = 0
                        end
                        j = j + 1
                        goto continue_find_line
                    end

                    -- Terminators
                    if b == 0x23 then
                        break
                    end

                    -- String starts
                    if b == 0x27 or b == 0x22 then
                        in_string = b
                        j = j + 1
                        goto continue_find_line
                    end

                    j = j + 1
                    ::continue_find_line::
                end

                self.result_pos = j
            }
        }

        $BalancedParenEnd {
            $>() {
                i = self.pos
                scan_end = self.scan_end
                bs = self.bytes

                if i >= scan_end or bs[i + 1] ~= 0x28 then
                    self.success = 0
                    return
                end

                depth = 0
                in_string = 0

                while i < scan_end do
                    b = bs[i + 1]

                    -- Inside string
                    if in_string ~= 0 then
                        if b == 0x5C then
                            i = i + 2
                            goto continue_paren
                        end
                        if b == in_string then
                            in_string = 0
                        end
                        i = i + 1
                        goto continue_paren
                    end

                    if b == 0x27 or b == 0x22 then
                        in_string = b
                        i = i + 1
                    elseif b == 0x28 then
                        depth = depth + 1
                        i = i + 1
                    elseif b == 0x29 then
                        depth = depth - 1
                        i = i + 1
                        if depth == 0 then
                            self.result_pos = i
                            self.success = 1
                            return
                        end
                    else
                        i = i + 1
                    end
                    ::continue_paren::
                end

                self.success = 0
            }
        }

    domain:
        bytes = {}
        pos: int = 0
        scan_end: int = 0
        result_pos: int = 0
        success: int = 1
}

local function str_to_bytes(s)
    local t = {}
    for i = 1, #s do
        t[i] = string.byte(s, i)
    end
    return t
end

local failures = 0

-- Test 1: Skip # comment
local s1 = @@RubySyntaxSkipperFsm()
local inp1 = str_to_bytes("# comment\ncode")
s1:setup(inp1, 0, #inp1)
s1:do_skip_comment()
if s1:get_success() ~= 1 or s1:get_result_pos() ~= 9 then
    print("FAIL 1: success=" .. s1:get_success() .. ", pos=" .. s1:get_result_pos())
    failures = failures + 1
end

-- Test 2: Skip double-quoted string
local s2 = @@RubySyntaxSkipperFsm()
local inp2 = str_to_bytes('"hello" rest')
s2:setup(inp2, 0, #inp2)
s2:do_skip_string()
if s2:get_success() ~= 1 or s2:get_result_pos() ~= 7 then
    print("FAIL 2: success=" .. s2:get_success() .. ", pos=" .. s2:get_result_pos())
    failures = failures + 1
end

-- Test 3: Skip single-quoted string
local s3 = @@RubySyntaxSkipperFsm()
local inp3 = str_to_bytes("'hello' rest")
s3:setup(inp3, 0, #inp3)
s3:do_skip_string()
if s3:get_success() ~= 1 or s3:get_result_pos() ~= 7 then
    print("FAIL 3: success=" .. s3:get_success() .. ", pos=" .. s3:get_result_pos())
    failures = failures + 1
end

-- Test 4: Skip %Q{text}
local s4 = @@RubySyntaxSkipperFsm()
local inp4 = str_to_bytes("%Q{text} rest")
s4:setup(inp4, 0, #inp4)
s4:do_skip_string()
if s4:get_success() ~= 1 or s4:get_result_pos() ~= 8 then
    print("FAIL 4: success=" .. s4:get_success() .. ", pos=" .. s4:get_result_pos())
    failures = failures + 1
end

-- Test 5: Skip %q[text]
local s5 = @@RubySyntaxSkipperFsm()
local inp5 = str_to_bytes("%q[text] rest")
s5:setup(inp5, 0, #inp5)
s5:do_skip_string()
if s5:get_success() ~= 1 or s5:get_result_pos() ~= 8 then
    print("FAIL 5: success=" .. s5:get_success() .. ", pos=" .. s5:get_result_pos())
    failures = failures + 1
end

-- Test 6: Find line end (stops at #)
local s6 = @@RubySyntaxSkipperFsm()
local inp6 = str_to_bytes("x + 1 # comment")
s6:setup(inp6, 0, #inp6)
s6:do_find_line_end()
if s6:get_result_pos() ~= 6 then
    print("FAIL 6: pos=" .. s6:get_result_pos() .. ", expected 6")
    failures = failures + 1
end

-- Test 7: Balanced parens
local s7 = @@RubySyntaxSkipperFsm()
local inp7 = str_to_bytes("(a, f(b)) rest")
s7:setup(inp7, 0, #inp7)
s7:do_balanced_paren_end()
if s7:get_success() ~= 1 or s7:get_result_pos() ~= 9 then
    print("FAIL 7: success=" .. s7:get_success() .. ", pos=" .. s7:get_result_pos())
    failures = failures + 1
end

-- Test 8: Skip %Q with nested braces
local s8 = @@RubySyntaxSkipperFsm()
local inp8 = str_to_bytes("%Q{outer {inner} end} rest")
s8:setup(inp8, 0, #inp8)
s8:do_skip_string()
if s8:get_success() ~= 1 or s8:get_result_pos() ~= 21 then
    print("FAIL 8: success=" .. s8:get_success() .. ", pos=" .. s8:get_result_pos())
    failures = failures + 1
end

if failures > 0 then
    print("FAIL: " .. failures .. " failures")
    os.exit(1)
end
print("PASS: ruby_skipper (8 cases)")

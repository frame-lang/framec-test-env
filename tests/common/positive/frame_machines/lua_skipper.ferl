@@[target("erlang")]

%% LuaSyntaxSkipper — FSM for skipping Lua comments and strings.
%% Translated from framec's native_region_scanner/lua_skipper.frs
%%
%% Handles: -- line comments, --[[ block comments ]], [[ long strings ]],
%% simple strings, Lua-style line endings.

@@system LuaSyntaxSkipperFsm {
    interface:
        setup(input_bytes: binary, start: int, length: int)
        do_skip_comment()
        do_skip_string()
        do_find_line_end()
        get_result_pos(): int
        get_success(): int

    machine:
        $Init {
            setup(input_bytes: binary, start: int, length: int) {
                self.bytes = input_bytes
                self.pos = start
                self.scan_end = length
            }
            do_skip_comment() { -> $SkipComment }
            do_skip_string() { -> $SkipString }
            do_find_line_end() { -> $FindLineEnd }
            get_result_pos(): int { @@:(self.result_pos) }
            get_success(): int { @@:(self.success) }
        }

        $SkipComment {
            $>() {
                {ResultPos, Success} = scan_comment(Data#data.bytes, Data#data.pos, Data#data.scan_end),
                self.result_pos = ResultPos
                self.success = Success
            }
            get_result_pos(): int { @@:(self.result_pos) }
            get_success(): int { @@:(self.success) }
        }

        $SkipString {
            $>() {
                {ResultPos, Success} = scan_string(Data#data.bytes, Data#data.pos, Data#data.scan_end),
                self.result_pos = ResultPos
                self.success = Success
            }
            get_result_pos(): int { @@:(self.result_pos) }
            get_success(): int { @@:(self.success) }
        }

        $FindLineEnd {
            $>() {
                self.result_pos = scan_line_end(Data#data.bytes, Data#data.pos, Data#data.scan_end)
            }
            get_result_pos(): int { @@:(self.result_pos) }
            get_success(): int { @@:(self.success) }
        }

    domain:
        bytes = <<>>
        pos = 0
        scan_end = 0
        result_pos = 0
        success = 1
}

%% --- Skip comment helper ---
%% Lua line comment: --
scan_comment(Bs, I, End) when I + 1 < End ->
    case {binary:at(Bs, I), binary:at(Bs, I + 1)} of
        {$-, $-} ->
            %% Check for block comment: --[[ ... ]]
            case I + 3 < End andalso binary:at(Bs, I + 2) =:= $[ andalso binary:at(Bs, I + 3) =:= $[ of
                true ->
                    scan_block_comment(Bs, I + 4, End);
                false ->
                    J = scan_to_newline(Bs, I + 2, End),
                    {J, 1}
            end;
        _ ->
            {0, 0}
    end;
scan_comment(_Bs, _I, _End) ->
    {0, 0}.

scan_block_comment(Bs, J, End) when J + 1 < End ->
    case {binary:at(Bs, J), binary:at(Bs, J + 1)} of
        {$], $]} -> {J + 2, 1};
        _ -> scan_block_comment(Bs, J + 1, End)
    end;
scan_block_comment(_Bs, _J, End) ->
    {End, 1}.

scan_to_newline(_Bs, J, End) when J >= End -> J;
scan_to_newline(Bs, J, End) ->
    case binary:at(Bs, J) of
        $\n -> J;
        _ -> scan_to_newline(Bs, J + 1, End)
    end.

%% --- Skip string helper ---
%% Long string: [[ ... ]]  or simple string: " or '
scan_string(Bs, I, End) when I + 1 < End ->
    case {binary:at(Bs, I), binary:at(Bs, I + 1)} of
        {$[, $[} ->
            scan_long_string(Bs, I + 2, End);
        _ ->
            scan_simple_string(Bs, I, End)
    end;
scan_string(Bs, I, End) when I < End ->
    scan_simple_string(Bs, I, End);
scan_string(_Bs, _I, _End) ->
    {0, 0}.

scan_long_string(Bs, J, End) when J + 1 < End ->
    case {binary:at(Bs, J), binary:at(Bs, J + 1)} of
        {$], $]} -> {J + 2, 1};
        _ -> scan_long_string(Bs, J + 1, End)
    end;
scan_long_string(_Bs, _J, End) ->
    {End, 1}.

scan_simple_string(Bs, I, End) when I < End ->
    C = binary:at(Bs, I),
    case C =:= $" orelse C =:= $' of
        true ->
            scan_simple_str_loop(Bs, I + 1, End, C);
        false ->
            {0, 0}
    end;
scan_simple_string(_Bs, _I, _End) ->
    {0, 0}.

scan_simple_str_loop(_Bs, J, End, _Q) when J >= End ->
    {End, 1};
scan_simple_str_loop(Bs, J, End, Q) ->
    B = binary:at(Bs, J),
    if
        B =:= $\\ ->
            scan_simple_str_loop(Bs, J + 2, End, Q);
        B =:= Q ->
            {J + 1, 1};
        true ->
            scan_simple_str_loop(Bs, J + 1, End, Q)
    end.

%% --- Find line end helper ---
%% Stop at \n or -- comment
scan_line_end(_Bs, J, End) when J >= End -> J;
scan_line_end(Bs, J, End) ->
    B = binary:at(Bs, J),
    if
        B =:= $\n -> J;
        B =:= $- andalso J + 1 < End ->
            case binary:at(Bs, J + 1) of
                $- -> J;
                _ -> scan_line_end(Bs, J + 1, End)
            end;
        true -> scan_line_end(Bs, J + 1, End)
    end.

main() ->
    Failures = test_all(0),
    case Failures of
        0 -> io:format("PASS: lua_skipper (6 cases)~n");
        _ -> io:format("FAIL: ~p failures~n", [Failures]), halt(1)
    end.

test_all(F0) ->
    M = lua_syntax_skipper_fsm,

    %% Test 1: Skip -- line comment
    {ok, P1} = M:start_link(),
    I1 = <<"-- comment\ncode">>,
    M:setup(P1, I1, 0, byte_size(I1)),
    M:do_skip_comment(P1),
    F1 = case {M:get_success(P1), M:get_result_pos(P1)} of
        {1, 10} -> F0;
        {S1, R1} -> io:format("FAIL 1: success=~p, pos=~p~n", [S1, R1]), F0 + 1
    end,

    %% Test 2: Skip --[[ block comment ]]
    {ok, P2} = M:start_link(),
    I2 = <<"--[[ block ]]code">>,
    M:setup(P2, I2, 0, byte_size(I2)),
    M:do_skip_comment(P2),
    F2 = case {M:get_success(P2), M:get_result_pos(P2)} of
        {1, 13} -> F1;
        {S2, R2} -> io:format("FAIL 2: success=~p, pos=~p~n", [S2, R2]), F1 + 1
    end,

    %% Test 3: Not a comment
    {ok, P3} = M:start_link(),
    I3 = <<"x + 1">>,
    M:setup(P3, I3, 0, byte_size(I3)),
    M:do_skip_comment(P3),
    F3 = case M:get_success(P3) of
        0 -> F2;
        _ -> io:format("FAIL 3: should not be comment~n"), F2 + 1
    end,

    %% Test 4: Skip [[ long string ]]
    {ok, P4} = M:start_link(),
    I4 = <<"[[hello world]]rest">>,
    M:setup(P4, I4, 0, byte_size(I4)),
    M:do_skip_string(P4),
    F4 = case {M:get_success(P4), M:get_result_pos(P4)} of
        {1, 15} -> F3;
        {S4, R4} -> io:format("FAIL 4: success=~p, pos=~p~n", [S4, R4]), F3 + 1
    end,

    %% Test 5: Skip simple double-quoted string
    {ok, P5} = M:start_link(),
    I5 = <<"\"hello\" rest">>,
    M:setup(P5, I5, 0, byte_size(I5)),
    M:do_skip_string(P5),
    F5 = case {M:get_success(P5), M:get_result_pos(P5)} of
        {1, 7} -> F4;
        {S5, R5} -> io:format("FAIL 5: success=~p, pos=~p~n", [S5, R5]), F4 + 1
    end,

    %% Test 6: Find line end (stops at --)
    {ok, P6} = M:start_link(),
    I6 = <<"x + 1 -- comment">>,
    M:setup(P6, I6, 0, byte_size(I6)),
    M:do_find_line_end(P6),
    F6 = case M:get_result_pos(P6) of
        6 -> F5;
        R6 -> io:format("FAIL 6: pos=~p, expected 6~n", [R6]), F5 + 1
    end,

    F6.

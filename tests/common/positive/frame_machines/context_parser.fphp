@@[target("php")]

// ContextParser -- FSM for parsing @@ context constructs.
// Translated from framec's native_region_scanner/context_parser.frs

@@system ContextParserFsm {
    operations:
        setup(input_bytes: array, start: int, length: int) {
            $this->bytes = $input_bytes;
            $this->pos = $start;
            $this->scan_end = $length;
        }
        setup_with_paren_end(input_bytes: array, start: int, length: int, p_end: int) {
            $this->bytes = $input_bytes;
            $this->pos = $start;
            $this->scan_end = $length;
            $this->paren_end = $p_end;
        }
        get_result_end(): int {
            return $this->result_end;
        }
        get_result_kind(): int {
            return $this->result_kind;
        }
        get_has_result(): int {
            return $this->has_result;
        }

    interface:
        do_parse()

    machine:
        $Init {
            do_parse() { -> $Dispatching }
        }

        $Dispatching {
            $>() {
                $i = $this->pos;
                $end = $this->scan_end;
                $bs = $this->bytes;

                if ($i >= $end) {
                    $this->has_result = 0;
                    -> $Done
                }

                $b = $bs[$i];

                if ($b === 0x3A) {
                    $this->pos = $i + 1;
                    -> $DispatchColon
                } elseif ($b >= 0x41 && $b <= 0x5A) {
                    -> $ParseInstantiation
                } else {
                    $this->result_end = $i;
                    $this->has_result = 0;
                    -> $Done
                }
            }
        }

        $DispatchColon {
            $>() {
                $i = $this->pos;
                $end = $this->scan_end;
                $bs = $this->bytes;

                // Check for @@:return
                if ($i + 5 < $end) {
                    $tag = array_slice($bs, $i, 6);
                    if ($tag === [0x72, 0x65, 0x74, 0x75, 0x72, 0x6E]) {
                        $this->pos = $i + 6;
                        -> $ParseReturn
                    }
                }

                // Check for @@:event
                if ($i + 4 < $end) {
                    $tag = array_slice($bs, $i, 5);
                    if ($tag === [0x65, 0x76, 0x65, 0x6E, 0x74]) {
                        $this->result_end = $i + 5;
                        $this->result_kind = 3;
                        $this->has_result = 1;
                        -> $Done
                    }
                }

                // Check for @@:data
                if ($i + 3 < $end) {
                    $tag = array_slice($bs, $i, 4);
                    if ($tag === [0x64, 0x61, 0x74, 0x61]) {
                        $this->pos = $i + 4;
                        -> $ParseData
                    }
                }

                // Check for @@:params
                if ($i + 5 < $end) {
                    $tag = array_slice($bs, $i, 6);
                    if ($tag === [0x70, 0x61, 0x72, 0x61, 0x6D, 0x73]) {
                        $this->pos = $i + 6;
                        -> $ParseParams
                    }
                }

                // Check for @@:self
                if ($i + 3 < $end) {
                    $tag = array_slice($bs, $i, 4);
                    if ($tag === [0x73, 0x65, 0x6C, 0x66]) {
                        $this->pos = $i + 4;
                        -> $ParseSelf
                    }
                }

                // Check for @@:system
                if ($i + 5 < $end) {
                    $tag = array_slice($bs, $i, 6);
                    if ($tag === [0x73, 0x79, 0x73, 0x74, 0x65, 0x6D]) {
                        $this->pos = $i + 6;
                        -> $ParseSystem
                    }
                }

                // Check for @@:(expr)
                if ($i < $end && $bs[$i] === 0x28) {
                    $this->pos = $i;
                    -> $ParseContextReturnExpr
                }

                // Unknown
                $this->result_end = $i;
                $this->has_result = 0;
                -> $Done
            }
        }

        $ParseReturn {
            $>() {
                $i = $this->pos;
                $end = $this->scan_end;
                $bs = $this->bytes;

                while ($i < $end && ($bs[$i] === 0x20 || $bs[$i] === 0x09)) {
                    $i++;
                }

                if ($i < $end && $bs[$i] === 0x28) {
                    $depth = 1;
                    $i++;
                    while ($i < $end && $depth > 0) {
                        if ($bs[$i] === 0x28) {
                            $depth++;
                        }
                        if ($bs[$i] === 0x29) {
                            $depth--;
                        }
                        if ($depth > 0) {
                            $i++;
                        }
                    }
                    if ($depth === 0) {
                        $i++;
                    }
                    $this->result_end = $i;
                    $this->result_kind = 9;
                    $this->has_result = 1;
                    -> $Done
                } elseif ($i < $end && $bs[$i] === 0x3D && ($i + 1 >= $end || $bs[$i + 1] !== 0x3D)) {
                    $i++;
                    while ($i < $end && ($bs[$i] === 0x20 || $bs[$i] === 0x09)) {
                        $i++;
                    }
                    while ($i < $end && $bs[$i] !== 0x0A && $bs[$i] !== 0x3B) {
                        $i++;
                    }
                    $this->result_end = $i;
                    $this->result_kind = 2;
                    $this->has_result = 1;
                    -> $Done
                } else {
                    $this->result_end = $i;
                    $this->result_kind = 2;
                    $this->has_result = 1;
                    -> $Done
                }
            }
        }

        $ParseContextReturnExpr {
            $>() {
                $i = $this->pos;
                $end = $this->scan_end;
                $bs = $this->bytes;

                if ($i < $end && $bs[$i] === 0x28) {
                    $depth = 1;
                    $i++;
                    while ($i < $end && $depth > 0) {
                        $b = $bs[$i];
                        if ($b === 0x28) {
                            $depth++;
                        } elseif ($b === 0x29) {
                            $depth--;
                        } elseif ($b === 0x22 || $b === 0x27) {
                            $q = $b;
                            $i++;
                            while ($i < $end) {
                                if ($bs[$i] === 0x5C && $i + 1 < $end) {
                                    $i += 2;
                                    continue;
                                }
                                if ($bs[$i] === $q) {
                                    break;
                                }
                                $i++;
                            }
                        }
                        $i++;
                    }
                }

                $this->result_end = $i;
                $this->result_kind = 8;
                $this->has_result = 1;
                -> $Done
            }
        }

        $ParseData {
            $>() {
                $i = $this->pos;
                $end = $this->scan_end;
                $bs = $this->bytes;

                if ($i < $end && $bs[$i] === 0x2E) {
                    $i++;
                    while ($i < $end && (($bs[$i] >= 0x61 && $bs[$i] <= 0x7A) || ($bs[$i] >= 0x41 && $bs[$i] <= 0x5A) || ($bs[$i] >= 0x30 && $bs[$i] <= 0x39) || $bs[$i] === 0x5F)) {
                        $i++;
                    }
                }

                $j = $i;
                while ($j < $end && ($bs[$j] === 0x20 || $bs[$j] === 0x09)) {
                    $j++;
                }

                if ($j < $end && $bs[$j] === 0x3D && ($j + 1 >= $end || $bs[$j + 1] !== 0x3D)) {
                    $j++;
                    while ($j < $end && ($bs[$j] === 0x20 || $bs[$j] === 0x09)) {
                        $j++;
                    }
                    while ($j < $end && $bs[$j] !== 0x0A && $bs[$j] !== 0x3B) {
                        $j++;
                    }
                    $this->result_end = $j;
                    $this->result_kind = 5;
                } else {
                    $this->result_end = $i;
                    $this->result_kind = 4;
                }

                $this->has_result = 1;
                -> $Done
            }
        }

        $ParseParams {
            $>() {
                $i = $this->pos;
                $end = $this->scan_end;
                $bs = $this->bytes;

                if ($i < $end && $bs[$i] === 0x2E) {
                    $i++;
                    while ($i < $end && (($bs[$i] >= 0x61 && $bs[$i] <= 0x7A) || ($bs[$i] >= 0x41 && $bs[$i] <= 0x5A) || ($bs[$i] >= 0x30 && $bs[$i] <= 0x39) || $bs[$i] === 0x5F)) {
                        $i++;
                    }
                }

                $this->result_end = $i;
                $this->result_kind = 6;
                $this->has_result = 1;
                -> $Done
            }
        }

        $ParseSelf {
            $>() {
                $i = $this->pos;
                $end = $this->scan_end;
                $bs = $this->bytes;

                if ($i < $end && $bs[$i] === 0x2E) {
                    $i++;
                    while ($i < $end && (($bs[$i] >= 0x61 && $bs[$i] <= 0x7A) || ($bs[$i] >= 0x41 && $bs[$i] <= 0x5A) || ($bs[$i] >= 0x30 && $bs[$i] <= 0x39) || $bs[$i] === 0x5F)) {
                        $i++;
                    }
                    if ($i < $end && $bs[$i] === 0x28) {
                        $depth = 1;
                        $i++;
                        while ($i < $end && $depth > 0) {
                            if ($bs[$i] === 0x28) {
                                $depth++;
                            }
                            if ($bs[$i] === 0x29) {
                                $depth--;
                            }
                            if ($bs[$i] === 0x22 || $bs[$i] === 0x27) {
                                $q = $bs[$i];
                                $i++;
                                while ($i < $end) {
                                    if ($bs[$i] === 0x5C && $i + 1 < $end) {
                                        $i += 2;
                                        continue;
                                    }
                                    if ($bs[$i] === $q) {
                                        break;
                                    }
                                    $i++;
                                }
                            }
                            if ($depth > 0) {
                                $i++;
                            }
                        }
                        if ($depth === 0) {
                            $i++;
                        }
                        $this->result_end = $i;
                        $this->result_kind = 10;
                        $this->has_result = 1;
                    } else {
                        $this->result_end = $i;
                        $this->result_kind = 11;
                        $this->has_result = 1;
                    }
                } else {
                    $this->result_end = $i;
                    $this->result_kind = 11;
                    $this->has_result = 1;
                }

                -> $Done
            }
        }

        $ParseSystem {
            $>() {
                $i = $this->pos;
                $end = $this->scan_end;
                $bs = $this->bytes;

                if ($i + 5 < $end) {
                    $tag = array_slice($bs, $i, 6);
                    if ($tag === [0x2E, 0x73, 0x74, 0x61, 0x74, 0x65]) {
                        $after = $i + 6;
                        if ($after >= $end || !(($bs[$after] >= 0x61 && $bs[$after] <= 0x7A) || ($bs[$after] >= 0x41 && $bs[$after] <= 0x5A) || ($bs[$after] >= 0x30 && $bs[$after] <= 0x39) || $bs[$after] === 0x5F)) {
                            $this->result_end = $i + 6;
                            $this->result_kind = 12;
                            $this->has_result = 1;
                            -> $Done
                        }
                    }
                }

                $this->result_end = $i;
                $this->result_kind = 13;
                $this->has_result = 1;
                -> $Done
            }
        }

        $ParseInstantiation {
            $>() {
                $i = $this->pos;
                $end = $this->scan_end;
                $bs = $this->bytes;

                while ($i < $end && (($bs[$i] >= 0x61 && $bs[$i] <= 0x7A) || ($bs[$i] >= 0x41 && $bs[$i] <= 0x5A) || ($bs[$i] >= 0x30 && $bs[$i] <= 0x39) || $bs[$i] === 0x5F)) {
                    $i++;
                }

                if ($i < $end && $bs[$i] === 0x28) {
                    if ($this->paren_end > 0) {
                        $i = $this->paren_end;
                        $this->result_end = $i;
                        $this->result_kind = 7;
                        $this->has_result = 1;
                    } else {
                        $this->result_end = $i;
                        $this->has_result = 0;
                    }
                } else {
                    $this->result_end = $i;
                    $this->has_result = 0;
                }

                -> $Done
            }
        }

        $Done {
            $>() {
                // Terminal state
            }
        }

    domain:
        bytes = []
        pos = 0
        scan_end = 0
        result_end = 0
        result_kind = 0
        has_result = 0
        paren_end = 0
}

function str_to_bytes(string $s): array {
    return array_values(unpack('C*', $s));
}

$failures = 0;

// Test 1: @@:return (bare read)
$p1 = @@ContextParserFsm();
$inp1 = str_to_bytes(":return");
$p1->setup($inp1, 0, count($inp1));
$p1->do_parse();
if ($p1->get_has_result() !== 1 || $p1->get_result_kind() !== 2) {
    echo 'FAIL 1: has_result=' . $p1->get_has_result() . ', kind=' . $p1->get_result_kind() . "\n";
    $failures++;
}

// Test 2: @@:event
$p2 = @@ContextParserFsm();
$inp2 = str_to_bytes(":event");
$p2->setup($inp2, 0, count($inp2));
$p2->do_parse();
if ($p2->get_has_result() !== 1 || $p2->get_result_kind() !== 3) {
    echo 'FAIL 2: has_result=' . $p2->get_has_result() . ', kind=' . $p2->get_result_kind() . "\n";
    $failures++;
}

// Test 3: @@:data.key
$p3 = @@ContextParserFsm();
$inp3 = str_to_bytes(":data.name rest");
$p3->setup($inp3, 0, count($inp3));
$p3->do_parse();
if ($p3->get_has_result() !== 1 || $p3->get_result_kind() !== 4) {
    echo 'FAIL 3: has_result=' . $p3->get_has_result() . ', kind=' . $p3->get_result_kind() . "\n";
    $failures++;
}

// Test 4: @@:data.key = expr
$p4 = @@ContextParserFsm();
$inp4 = str_to_bytes(":data.key = value\n");
$p4->setup($inp4, 0, count($inp4));
$p4->do_parse();
if ($p4->get_has_result() !== 1 || $p4->get_result_kind() !== 5) {
    echo 'FAIL 4: has_result=' . $p4->get_has_result() . ', kind=' . $p4->get_result_kind() . "\n";
    $failures++;
}

// Test 5: @@:params.key
$p5 = @@ContextParserFsm();
$inp5 = str_to_bytes(":params.name rest");
$p5->setup($inp5, 0, count($inp5));
$p5->do_parse();
if ($p5->get_has_result() !== 1 || $p5->get_result_kind() !== 6) {
    echo 'FAIL 5: has_result=' . $p5->get_has_result() . ', kind=' . $p5->get_result_kind() . "\n";
    $failures++;
}

// Test 6: @@:(expr)
$p6 = @@ContextParserFsm();
$inp6 = str_to_bytes(":(x + 1) rest");
$p6->setup($inp6, 0, count($inp6));
$p6->do_parse();
if ($p6->get_has_result() !== 1 || $p6->get_result_kind() !== 8) {
    echo 'FAIL 6: has_result=' . $p6->get_has_result() . ', kind=' . $p6->get_result_kind() . "\n";
    $failures++;
}

// Test 7: @@:return(expr)
$p7 = @@ContextParserFsm();
$inp7 = str_to_bytes(":return(42) rest");
$p7->setup($inp7, 0, count($inp7));
$p7->do_parse();
if ($p7->get_has_result() !== 1 || $p7->get_result_kind() !== 9) {
    echo 'FAIL 7: has_result=' . $p7->get_has_result() . ', kind=' . $p7->get_result_kind() . "\n";
    $failures++;
}

// Test 8: @@:self (bare)
$p8 = @@ContextParserFsm();
$inp8 = str_to_bytes(":self rest");
$p8->setup($inp8, 0, count($inp8));
$p8->do_parse();
if ($p8->get_has_result() !== 1 || $p8->get_result_kind() !== 11) {
    echo 'FAIL 8: has_result=' . $p8->get_has_result() . ', kind=' . $p8->get_result_kind() . "\n";
    $failures++;
}

// Test 9: @@:self.method(args)
$p9 = @@ContextParserFsm();
$inp9 = str_to_bytes(":self.doWork(x) rest");
$p9->setup($inp9, 0, count($inp9));
$p9->do_parse();
if ($p9->get_has_result() !== 1 || $p9->get_result_kind() !== 10) {
    echo 'FAIL 9: has_result=' . $p9->get_has_result() . ', kind=' . $p9->get_result_kind() . "\n";
    $failures++;
}

// Test 10: @@:system.state
$p10 = @@ContextParserFsm();
$inp10 = str_to_bytes(":system.state rest");
$p10->setup($inp10, 0, count($inp10));
$p10->do_parse();
if ($p10->get_has_result() !== 1 || $p10->get_result_kind() !== 12) {
    echo 'FAIL 10: has_result=' . $p10->get_has_result() . ', kind=' . $p10->get_result_kind() . "\n";
    $failures++;
}

// Test 11: @@SystemName() with paren_end
$p11 = @@ContextParserFsm();
$inp11 = str_to_bytes("MySystem() rest");
$p11->setup_with_paren_end($inp11, 0, count($inp11), 10);
$p11->do_parse();
if ($p11->get_has_result() !== 1 || $p11->get_result_kind() !== 7) {
    echo 'FAIL 11: has_result=' . $p11->get_has_result() . ', kind=' . $p11->get_result_kind() . "\n";
    $failures++;
}

// Test 12: No match (lowercase, not a keyword)
$p12 = @@ContextParserFsm();
$inp12 = str_to_bytes("xyz");
$p12->setup($inp12, 0, count($inp12));
$p12->do_parse();
if ($p12->get_has_result() !== 0) {
    echo 'FAIL 12: should not match, has_result=' . $p12->get_has_result() . "\n";
    $failures++;
}

if ($failures > 0) { echo "FAIL: $failures failures\n"; exit(1); }
echo "PASS: context_parser (12 cases)\n";

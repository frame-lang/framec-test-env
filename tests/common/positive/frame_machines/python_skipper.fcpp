@@target cpp_17

#include <iostream>
#include <string>
#include <vector>
#include <cstdint>
#include <algorithm>

// PythonSyntaxSkipper — FSM for skipping Python comments and strings.
// Translated from framec's native_region_scanner/python_skipper.frs
//
// Handles: # comments, triple-quoted strings, simple strings,
// Python-style line endings, balanced parens.

@@system PythonSyntaxSkipperFsm {
    operations:
        setup(input_bytes: std::vector<uint8_t>, start: int, length: int) {
            this->bytes = input_bytes;
            this->pos = start;
            this->scan_end = length;
        }
        get_result_pos(): int {
            return this->result_pos;
        }
        get_success(): int {
            return this->success;
        }

    interface:
        do_skip_comment()
        do_skip_string()
        do_find_line_end()
        do_balanced_paren_end()

    machine:
        $Init {
            do_skip_comment() { -> $SkipComment }
            do_skip_string() { -> $SkipString }
            do_find_line_end() { -> $FindLineEnd }
            do_balanced_paren_end() { -> $BalancedParenEnd }
        }

        $SkipComment {
            $>() {
                int i = this->pos;
                int end = this->scan_end;
                const std::vector<uint8_t>& bs = this->bytes;

                // Python uses # for line comments
                if (i < end && bs[i] == '#') {
                    int j = i + 1;
                    while (j < end && bs[j] != '\n') {
                        j++;
                    }
                    this->result_pos = j;
                    this->success = 1;
                    return;
                }

                this->success = 0;
            }
        }

        $SkipString {
            $>() {
                int i = this->pos;
                int end = this->scan_end;
                const std::vector<uint8_t>& bs = this->bytes;

                // Triple-quoted strings: """ or '''
                if (i + 2 < end) {
                    if ((bs[i] == '"' && bs[i+1] == '"' && bs[i+2] == '"') ||
                        (bs[i] == '\'' && bs[i+1] == '\'' && bs[i+2] == '\'')) {
                        int q = bs[i];
                        int j = i + 3;
                        while (j + 2 < end) {
                            if (bs[j] == q && bs[j+1] == q && bs[j+2] == q) {
                                this->result_pos = j + 3;
                                this->success = 1;
                                return;
                            }
                            j++;
                        }
                        this->result_pos = end;
                        this->success = 1;
                        return;
                    }
                }

                // Simple strings: " or '
                if (i < end && (bs[i] == '"' || bs[i] == '\'')) {
                    int q = bs[i];
                    int j = i + 1;
                    while (j < end) {
                        if (bs[j] == '\\') {
                            j += 2;
                            continue;
                        }
                        if (bs[j] == q) {
                            this->result_pos = j + 1;
                            this->success = 1;
                            return;
                        }
                        j++;
                    }
                    this->result_pos = end;
                    this->success = 1;
                    return;
                }

                this->success = 0;
            }
        }

        $FindLineEnd {
            $>() {
                int j = this->pos;
                int end = this->scan_end;
                const std::vector<uint8_t>& bs = this->bytes;

                while (j < end) {
                    int b = bs[j];
                    if (b == '\n' || b == ';') {
                        break;
                    }
                    // Stop at # comment
                    if (b == '#') {
                        break;
                    }
                    j++;
                }

                this->result_pos = j;
            }
        }

        $BalancedParenEnd {
            $>() {
                int i = this->pos;
                int end = this->scan_end;
                const std::vector<uint8_t>& bs = this->bytes;

                if (i >= end || bs[i] != '(') {
                    this->success = 0;
                    return;
                }

                int depth = 1;
                int j = i + 1;
                while (j < end && depth > 0) {
                    int b = bs[j];
                    if (b == '(') {
                        depth++;
                    } else if (b == ')') {
                        depth--;
                    } else if (b == '"' || b == '\'') {
                        int q = b;
                        j++;
                        while (j < end && bs[j] != q) {
                            if (bs[j] == '\\') {
                                j++;
                            }
                            j++;
                        }
                    }
                    j++;
                }

                if (depth == 0) {
                    this->result_pos = j;
                    this->success = 1;
                } else {
                    this->result_pos = end;
                    this->success = 0;
                }
            }
        }

    domain:
        bytes: std::vector<uint8_t> = {}
        pos: int = 0
        scan_end: int = 0
        result_pos: int = 0
        success: int = 1
}

int main() {
    int failures = 0;

    auto to_bytes = [](const std::string& s) -> std::vector<uint8_t> {
        return std::vector<uint8_t>(s.begin(), s.end());
    };

    // Test 1: Skip hash comment
    auto s1 = PythonSyntaxSkipperFsm();
    auto inp1 = to_bytes("# comment\ncode");
    s1.setup(inp1, 0, inp1.size());
    s1.do_skip_comment();
    if (s1.get_success() != 1 || s1.get_result_pos() != 9) {
        printf("FAIL 1: success=%d, pos=%d\n", s1.get_success(), s1.get_result_pos());
        failures++;
    }

    // Test 2: Not a comment
    auto s2 = PythonSyntaxSkipperFsm();
    auto inp2 = to_bytes("x + 1");
    s2.setup(inp2, 0, inp2.size());
    s2.do_skip_comment();
    if (s2.get_success() != 0) {
        printf("FAIL 2: should not be comment\n");
        failures++;
    }

    // Test 3: Skip triple-quoted string
    auto s3 = PythonSyntaxSkipperFsm();
    auto inp3 = to_bytes("\"\"\"hello world\"\"\"rest");
    s3.setup(inp3, 0, inp3.size());
    s3.do_skip_string();
    if (s3.get_success() != 1 || s3.get_result_pos() != 17) {
        printf("FAIL 3: success=%d, pos=%d\n", s3.get_success(), s3.get_result_pos());
        failures++;
    }

    // Test 4: Skip simple string
    auto s4 = PythonSyntaxSkipperFsm();
    auto inp4 = to_bytes("\"hello\" rest");
    s4.setup(inp4, 0, inp4.size());
    s4.do_skip_string();
    if (s4.get_success() != 1 || s4.get_result_pos() != 7) {
        printf("FAIL 4: success=%d, pos=%d\n", s4.get_success(), s4.get_result_pos());
        failures++;
    }

    // Test 5: Skip string with escape
    auto s5 = PythonSyntaxSkipperFsm();
    auto inp5 = to_bytes("'he\\'llo' rest");
    s5.setup(inp5, 0, inp5.size());
    s5.do_skip_string();
    if (s5.get_success() != 1 || s5.get_result_pos() != 9) {
        printf("FAIL 5: success=%d, pos=%d\n", s5.get_success(), s5.get_result_pos());
        failures++;
    }

    // Test 6: Find line end (stops at #)
    auto s6 = PythonSyntaxSkipperFsm();
    auto inp6 = to_bytes("x + 1 # comment");
    s6.setup(inp6, 0, inp6.size());
    s6.do_find_line_end();
    if (s6.get_result_pos() != 6) {
        printf("FAIL 6: pos=%d, expected 6\n", s6.get_result_pos());
        failures++;
    }

    // Test 7: Balanced parens
    auto s7 = PythonSyntaxSkipperFsm();
    auto inp7 = to_bytes("(a, f(b)) rest");
    s7.setup(inp7, 0, inp7.size());
    s7.do_balanced_paren_end();
    if (s7.get_success() != 1 || s7.get_result_pos() != 9) {
        printf("FAIL 7: success=%d, pos=%d\n", s7.get_success(), s7.get_result_pos());
        failures++;
    }

    if (failures > 0) {
        printf("FAIL: %d failures\n", failures);
        return 1;
    }
    printf("PASS: python_skipper (7 cases)\n");
    return 0;
}

@@target rust

// ErlangSyntaxSkipper -- FSM for skipping Erlang comments and strings.
// Translated from framec's native_region_scanner/erlang_skipper.frs
//
// Handles: % line comments, "..." strings, '...' quoted atoms,
// Erlang-style line endings, balanced parens.

use std::collections::HashMap;

@@system ErlangSyntaxSkipperFsm {
    operations:
        setup(input_bytes: Vec<u8>, start: i64, length: i64) {
            self.bytes = input_bytes;
            self.pos = start;
            self.scan_end = length;
        }
        get_result_pos(): i64 {
            return self.result_pos;
        }
        get_success(): i64 {
            return self.success;
        }

    interface:
        do_skip_comment()
        do_skip_string()
        do_find_line_end()
        do_balanced_paren_end()

    machine:
        $Init {
            do_skip_comment() { -> $SkipComment }
            do_skip_string() { -> $SkipString }
            do_find_line_end() { -> $FindLineEnd }
            do_balanced_paren_end() { -> $BalancedParenEnd }
        }

        $SkipComment {
            $>() {
                let i = self.pos as usize;
                let end = self.scan_end as usize;
                let bs = &self.bytes;

                // Erlang: % line comment only
                if i < end && bs[i] == 0x25 {
                    let mut j = i + 1;
                    while j < end && bs[j] != 0x0A {
                        j += 1;
                    }
                    self.result_pos = j as i64;
                    self.success = 1;
                    return;
                }

                self.success = 0;
            }
        }

        $SkipString {
            $>() {
                let i = self.pos as usize;
                let end = self.scan_end as usize;
                let bs = &self.bytes;

                // Simple string: "..."
                if i < end && bs[i] == 0x22 {
                    let mut j = i + 1;
                    while j < end {
                        if bs[j] == 0x5C {
                            j += 2;
                            continue;
                        }
                        if bs[j] == 0x22 {
                            self.result_pos = (j + 1) as i64;
                            self.success = 1;
                            return;
                        }
                        j += 1;
                    }
                    self.result_pos = end as i64;
                    self.success = 1;
                    return;
                }

                // Quoted atoms: '...'
                if i < end && bs[i] == 0x27 {
                    let mut j = i + 1;
                    while j < end {
                        if bs[j] == 0x5C {
                            j += 2;
                            continue;
                        }
                        if bs[j] == 0x27 {
                            self.result_pos = (j + 1) as i64;
                            self.success = 1;
                            return;
                        }
                        j += 1;
                    }
                    self.result_pos = end as i64;
                    self.success = 1;
                    return;
                }

                self.success = 0;
            }
        }

        $FindLineEnd {
            $>() {
                let mut j = self.pos as usize;
                let end = self.scan_end as usize;
                let bs = &self.bytes;
                let mut in_string: u8 = 0;

                while j < end {
                    let b = bs[j];
                    if b == 0x0A {
                        break;
                    }

                    // Inside string
                    if in_string != 0 {
                        if b == 0x5C {
                            j += 2;
                            continue;
                        }
                        if b == in_string {
                            in_string = 0;
                        }
                        j += 1;
                        continue;
                    }

                    // Terminators
                    if b == 0x25 {
                        break;
                    }

                    // String starts
                    if b == 0x22 || b == 0x27 {
                        in_string = b;
                        j += 1;
                        continue;
                    }

                    j += 1;
                }

                self.result_pos = j as i64;
            }
        }

        $BalancedParenEnd {
            $>() {
                let mut i = self.pos as usize;
                let end = self.scan_end as usize;
                let bs = &self.bytes;

                if i >= end || bs[i] != 0x28 {
                    self.success = 0;
                    return;
                }

                let mut depth: i32 = 0;
                let mut in_string: u8 = 0;

                while i < end {
                    let b = bs[i];

                    // Inside string
                    if in_string != 0 {
                        if b == 0x5C {
                            i += 2;
                            continue;
                        }
                        if b == in_string {
                            in_string = 0;
                        }
                        i += 1;
                        continue;
                    }

                    if b == 0x22 || b == 0x27 {
                        in_string = b;
                        i += 1;
                    } else if b == 0x28 {
                        depth += 1;
                        i += 1;
                    } else if b == 0x29 {
                        depth -= 1;
                        i += 1;
                        if depth == 0 {
                            self.result_pos = i as i64;
                            self.success = 1;
                            return;
                        }
                    } else {
                        i += 1;
                    }
                }

                self.success = 0;
            }
        }

    domain:
        bytes: Vec<u8> = Vec::new()
        pos: i64 = 0
        scan_end: i64 = 0
        result_pos: i64 = 0
        success: i64 = 1
}

fn main() {
    let mut failures = 0;

    // Test 1: Skip % comment
    let mut s1 = @@ErlangSyntaxSkipperFsm();
    let inp1 = b"% comment\ncode".to_vec();
    s1.setup(inp1.clone(), 0, inp1.len() as i64);
    s1.do_skip_comment();
    if s1.get_success() != 1 || s1.get_result_pos() != 9 {
        println!("FAIL 1: success={}, pos={}", s1.get_success(), s1.get_result_pos());
        failures += 1;
    }

    // Test 2: Not a comment
    let mut s2 = @@ErlangSyntaxSkipperFsm();
    let inp2 = b"x + 1".to_vec();
    s2.setup(inp2.clone(), 0, inp2.len() as i64);
    s2.do_skip_comment();
    if s2.get_success() != 0 {
        println!("FAIL 2: should not be comment");
        failures += 1;
    }

    // Test 3: Skip double-quoted string
    let mut s3 = @@ErlangSyntaxSkipperFsm();
    let inp3 = b"\"hello\" rest".to_vec();
    s3.setup(inp3.clone(), 0, inp3.len() as i64);
    s3.do_skip_string();
    if s3.get_success() != 1 || s3.get_result_pos() != 7 {
        println!("FAIL 3: success={}, pos={}", s3.get_success(), s3.get_result_pos());
        failures += 1;
    }

    // Test 4: Skip quoted atom
    let mut s4 = @@ErlangSyntaxSkipperFsm();
    let inp4 = b"'my_atom' rest".to_vec();
    s4.setup(inp4.clone(), 0, inp4.len() as i64);
    s4.do_skip_string();
    if s4.get_success() != 1 || s4.get_result_pos() != 9 {
        println!("FAIL 4: success={}, pos={}", s4.get_success(), s4.get_result_pos());
        failures += 1;
    }

    // Test 5: Find line end (stops at %)
    let mut s5 = @@ErlangSyntaxSkipperFsm();
    let inp5 = b"X + 1 % comment".to_vec();
    s5.setup(inp5.clone(), 0, inp5.len() as i64);
    s5.do_find_line_end();
    if s5.get_result_pos() != 6 {
        println!("FAIL 5: pos={}, expected 6", s5.get_result_pos());
        failures += 1;
    }

    // Test 6: Balanced parens
    let mut s6 = @@ErlangSyntaxSkipperFsm();
    let inp6 = b"(a, f(b)) rest".to_vec();
    s6.setup(inp6.clone(), 0, inp6.len() as i64);
    s6.do_balanced_paren_end();
    if s6.get_success() != 1 || s6.get_result_pos() != 9 {
        println!("FAIL 6: success={}, pos={}", s6.get_success(), s6.get_result_pos());
        failures += 1;
    }

    // Test 7: String with escape
    let mut s7 = @@ErlangSyntaxSkipperFsm();
    let inp7 = b"\"he\\\"llo\" rest".to_vec();
    s7.setup(inp7.clone(), 0, inp7.len() as i64);
    s7.do_skip_string();
    if s7.get_success() != 1 || s7.get_result_pos() != 9 {
        println!("FAIL 7: success={}, pos={}", s7.get_success(), s7.get_result_pos());
        failures += 1;
    }

    if failures > 0 { println!("FAIL: {} failures", failures); std::process::exit(1); }
    println!("PASS: erlang_skipper (7 cases)");
}

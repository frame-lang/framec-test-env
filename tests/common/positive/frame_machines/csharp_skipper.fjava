@@target java

// CSharpSyntaxSkipper -- FSM for skipping C# comments and strings.
// Translated from framec's native_region_scanner/csharp_skipper.frs
//
// Handles: // line comments, /* */ block comments, # preprocessor directives,
// "..." simple strings, @"..." verbatim strings, $"..." interpolated strings,
// $"""...""" raw strings, C-like line endings, balanced parens.

@@system CSharpSyntaxSkipperFsm {
    operations:
        setup(input_bytes: byte[], start: int, length: int) {
            this.bytes = input_bytes;
            this.pos = start;
            this.scan_end = length;
        }
        get_result_pos(): int {
            return this.result_pos;
        }
        get_success(): int {
            return this.success;
        }

    interface:
        do_skip_comment()
        do_skip_string()
        do_find_line_end()
        do_balanced_paren_end()

    machine:
        $Init {
            do_skip_comment() { -> $SkipComment }
            do_skip_string() { -> $SkipString }
            do_find_line_end() { -> $FindLineEnd }
            do_balanced_paren_end() { -> $BalancedParenEnd }
        }

        $SkipComment {
            $>() {
                int i = this.pos;
                int end = this.scan_end;
                byte[] bs = this.bytes;

                // Preprocessor directive: # ... newline
                if (i < end && (bs[i] & 0xFF) == '#') {
                    int j = i + 1;
                    while (j < end && (bs[j] & 0xFF) != '\n') {
                        j++;
                    }
                    this.result_pos = j;
                    this.success = 1;
                    return;
                }

                // Line comment: //
                if (i + 1 < end && (bs[i] & 0xFF) == '/' && (bs[i + 1] & 0xFF) == '/') {
                    int j = i + 2;
                    while (j < end && (bs[j] & 0xFF) != '\n') {
                        j++;
                    }
                    this.result_pos = j;
                    this.success = 1;
                    return;
                }

                // Block comment: /* ... */
                if (i + 1 < end && (bs[i] & 0xFF) == '/' && (bs[i + 1] & 0xFF) == '*') {
                    int j = i + 2;
                    while (j + 1 < end) {
                        if ((bs[j] & 0xFF) == '*' && (bs[j + 1] & 0xFF) == '/') {
                            this.result_pos = j + 2;
                            this.success = 1;
                            return;
                        }
                        j++;
                    }
                    this.result_pos = end;
                    this.success = 1;
                    return;
                }

                this.success = 0;
            }
        }

        $SkipString {
            $>() {
                int i = this.pos;
                int end = this.scan_end;
                byte[] bs = this.bytes;

                if (i >= end) {
                    this.success = 0;
                    return;
                }

                int b0 = bs[i] & 0xFF;

                // Verbatim string @"..." (doubled quotes for escape)
                if (b0 == '@' && i + 1 < end && (bs[i + 1] & 0xFF) == '"') {
                    int j = i + 2;
                    while (j < end) {
                        if ((bs[j] & 0xFF) == '"') {
                            if (j + 1 < end && (bs[j + 1] & 0xFF) == '"') {
                                j += 2;
                                continue;
                            }
                            this.result_pos = j + 1;
                            this.success = 1;
                            return;
                        }
                        j++;
                    }
                    this.result_pos = end;
                    this.success = 1;
                    return;
                }

                // Interpolated string $"..." or $@"..." or raw $"""..."""
                if (b0 == '$') {
                    int j = i + 1;
                    while (j < end && (bs[j] & 0xFF) == '$') {
                        j++;
                    }
                    if (j < end && (bs[j] & 0xFF) == '@') {
                        j++;
                    }
                    int quotes = 0;
                    while (j < end && (bs[j] & 0xFF) == '"') {
                        quotes++;
                        j++;
                    }
                    if (quotes == 0) {
                        this.success = 0;
                        return;
                    }
                    if (quotes >= 3) {
                        while (j < end) {
                            if ((bs[j] & 0xFF) == '"') {
                                int q = 0;
                                int p = j;
                                while (p < end && (bs[p] & 0xFF) == '"') {
                                    q++;
                                    p++;
                                }
                                if (q >= quotes) {
                                    this.result_pos = p;
                                    this.success = 1;
                                    return;
                                }
                                j = p;
                                continue;
                            }
                            j++;
                        }
                        this.result_pos = end;
                        this.success = 1;
                        return;
                    }
                    while (j < end) {
                        if ((bs[j] & 0xFF) == '\\') {
                            j += 2;
                            continue;
                        }
                        if ((bs[j] & 0xFF) == '"') {
                            this.result_pos = j + 1;
                            this.success = 1;
                            return;
                        }
                        j++;
                    }
                    this.result_pos = end;
                    this.success = 1;
                    return;
                }

                // Simple string: " or '
                if (b0 == '"' || b0 == '\'') {
                    int q = b0;
                    int j = i + 1;
                    while (j < end) {
                        if ((bs[j] & 0xFF) == '\\') {
                            j += 2;
                            continue;
                        }
                        if ((bs[j] & 0xFF) == q) {
                            this.result_pos = j + 1;
                            this.success = 1;
                            return;
                        }
                        j++;
                    }
                    this.result_pos = end;
                    this.success = 1;
                    return;
                }

                this.success = 0;
            }
        }

        $FindLineEnd {
            $>() {
                int j = this.pos;
                int end = this.scan_end;
                byte[] bs = this.bytes;

                while (j < end) {
                    int b = bs[j] & 0xFF;
                    if (b == '\n' || b == ';') {
                        break;
                    }
                    if (b == '/' && j + 1 < end && ((bs[j + 1] & 0xFF) == '/' || (bs[j + 1] & 0xFF) == '*')) {
                        break;
                    }
                    if (b == '#') {
                        break;
                    }
                    j++;
                }

                this.result_pos = j;
            }
        }

        $BalancedParenEnd {
            $>() {
                int i = this.pos;
                int end = this.scan_end;
                byte[] bs = this.bytes;

                if (i >= end || (bs[i] & 0xFF) != '(') {
                    this.success = 0;
                    return;
                }

                int depth = 1;
                int j = i + 1;
                while (j < end && depth > 0) {
                    int b = bs[j] & 0xFF;
                    if (b == '(') {
                        depth++;
                    } else if (b == ')') {
                        depth--;
                    } else if (b == '"' || b == '\'') {
                        int q = b;
                        j++;
                        while (j < end && (bs[j] & 0xFF) != q) {
                            if ((bs[j] & 0xFF) == '\\') {
                                j++;
                            }
                            j++;
                        }
                    }
                    j++;
                }

                if (depth == 0) {
                    this.result_pos = j;
                    this.success = 1;
                } else {
                    this.result_pos = end;
                    this.success = 0;
                }
            }
        }

    domain:
        bytes: byte[] = null
        pos: int = 0
        scan_end: int = 0
        result_pos: int = 0
        success: int = 1
}

class Main {
    public static void main(String[] args) {
        int failures = 0;

        // Test 1: Skip // line comment
        CSharpSyntaxSkipperFsm s1 = @@CSharpSyntaxSkipperFsm();
        byte[] inp1 = "// comment\ncode".getBytes();
        s1.setup(inp1, 0, inp1.length);
        s1.do_skip_comment();
        if (s1.get_success() != 1 || s1.get_result_pos() != 10) {
            System.out.println("FAIL 1: success=" + s1.get_success() + ", pos=" + s1.get_result_pos());
            failures++;
        }

        // Test 2: Skip /* */ block comment
        CSharpSyntaxSkipperFsm s2 = @@CSharpSyntaxSkipperFsm();
        byte[] inp2 = "/* block */code".getBytes();
        s2.setup(inp2, 0, inp2.length);
        s2.do_skip_comment();
        if (s2.get_success() != 1 || s2.get_result_pos() != 11) {
            System.out.println("FAIL 2: success=" + s2.get_success() + ", pos=" + s2.get_result_pos());
            failures++;
        }

        // Test 3: Skip simple string "hello"
        CSharpSyntaxSkipperFsm s3 = @@CSharpSyntaxSkipperFsm();
        byte[] inp3 = "\"hello\" rest".getBytes();
        s3.setup(inp3, 0, inp3.length);
        s3.do_skip_string();
        if (s3.get_success() != 1 || s3.get_result_pos() != 7) {
            System.out.println("FAIL 3: success=" + s3.get_success() + ", pos=" + s3.get_result_pos());
            failures++;
        }

        // Test 4: Skip verbatim string @"verbatim ""quote"""
        CSharpSyntaxSkipperFsm s4 = @@CSharpSyntaxSkipperFsm();
        byte[] inp4 = "@\"verbatim \"\"quote\"\"\" rest".getBytes();
        s4.setup(inp4, 0, inp4.length);
        s4.do_skip_string();
        if (s4.get_success() != 1 || s4.get_result_pos() != 21) {
            System.out.println("FAIL 4: success=" + s4.get_success() + ", pos=" + s4.get_result_pos());
            failures++;
        }

        // Test 5: Skip interpolated string $"interp {x}"
        CSharpSyntaxSkipperFsm s5 = @@CSharpSyntaxSkipperFsm();
        byte[] inp5 = "$\"interp {x}\" rest".getBytes();
        s5.setup(inp5, 0, inp5.length);
        s5.do_skip_string();
        if (s5.get_success() != 1 || s5.get_result_pos() != 13) {
            System.out.println("FAIL 5: success=" + s5.get_success() + ", pos=" + s5.get_result_pos());
            failures++;
        }

        // Test 6: Find line end (stops at // comment)
        CSharpSyntaxSkipperFsm s6 = @@CSharpSyntaxSkipperFsm();
        byte[] inp6 = "x + 1 // comment".getBytes();
        s6.setup(inp6, 0, inp6.length);
        s6.do_find_line_end();
        if (s6.get_result_pos() != 6) {
            System.out.println("FAIL 6: pos=" + s6.get_result_pos() + ", expected 6");
            failures++;
        }

        // Test 7: Balanced parens
        CSharpSyntaxSkipperFsm s7 = @@CSharpSyntaxSkipperFsm();
        byte[] inp7 = "(a, f(b)) rest".getBytes();
        s7.setup(inp7, 0, inp7.length);
        s7.do_balanced_paren_end();
        if (s7.get_success() != 1 || s7.get_result_pos() != 9) {
            System.out.println("FAIL 7: success=" + s7.get_success() + ", pos=" + s7.get_result_pos());
            failures++;
        }

        // Test 8: Skip # preprocessor directive
        CSharpSyntaxSkipperFsm s8 = @@CSharpSyntaxSkipperFsm();
        byte[] inp8 = "#region Foo\ncode".getBytes();
        s8.setup(inp8, 0, inp8.length);
        s8.do_skip_comment();
        if (s8.get_success() != 1 || s8.get_result_pos() != 11) {
            System.out.println("FAIL 8: success=" + s8.get_success() + ", pos=" + s8.get_result_pos());
            failures++;
        }

        if (failures > 0) {
            System.out.println("FAIL: " + failures + " failures");
            System.exit(1);
        }
        System.out.println("PASS: csharp_skipper (8 cases)");
    }
}

@@[target("c")]

#include <string.h>

// CSharpSyntaxSkipper -- FSM for skipping C# comments and strings.
// Translated from framec's native_region_scanner/csharp_skipper.frs
//
// Handles: // line comments, /* */ block comments, # preprocessor directives,
// "..." simple strings, @"..." verbatim strings, $"..." interpolated strings,
// $"""...""" raw strings, C-like line endings, balanced parens.

@@system CSharpSyntaxSkipperFsm {
    operations:
        setup(input_bytes: unsigned char*, start: int, length: int) {
            self->bytes = input_bytes;
            self->pos = start;
            self->scan_end = length;
        }
        get_result_pos(): int {
            return self->result_pos;
        }
        get_success(): int {
            return self->success;
        }

    interface:
        do_skip_comment()
        do_skip_string()
        do_find_line_end()
        do_balanced_paren_end()

    machine:
        $Init {
            do_skip_comment() { -> $SkipComment }
            do_skip_string() { -> $SkipString }
            do_find_line_end() { -> $FindLineEnd }
            do_balanced_paren_end() { -> $BalancedParenEnd }
        }

        $SkipComment {
            $>() {
                int i = self->pos;
                int end = self->scan_end;
                unsigned char* bs = self->bytes;

                // Preprocessor directive: # ... newline
                if (i < end && bs[i] == '#') {
                    int j = i + 1;
                    while (j < end && bs[j] != '\n') {
                        j++;
                    }
                    self->result_pos = j;
                    self->success = 1;
                    return;
                }

                // Line comment: //
                if (i + 1 < end && bs[i] == '/' && bs[i + 1] == '/') {
                    int j = i + 2;
                    while (j < end && bs[j] != '\n') {
                        j++;
                    }
                    self->result_pos = j;
                    self->success = 1;
                    return;
                }

                // Block comment: /* ... */
                if (i + 1 < end && bs[i] == '/' && bs[i + 1] == '*') {
                    int j = i + 2;
                    while (j + 1 < end) {
                        if (bs[j] == '*' && bs[j + 1] == '/') {
                            self->result_pos = j + 2;
                            self->success = 1;
                            return;
                        }
                        j++;
                    }
                    self->result_pos = end;
                    self->success = 1;
                    return;
                }

                self->success = 0;
            }
        }

        $SkipString {
            $>() {
                int i = self->pos;
                int end = self->scan_end;
                unsigned char* bs = self->bytes;

                if (i >= end) {
                    self->success = 0;
                    return;
                }

                unsigned char b0 = bs[i];

                // Verbatim string @"..." (doubled quotes for escape)
                if (b0 == '@' && i + 1 < end && bs[i + 1] == '"') {
                    int j = i + 2;
                    while (j < end) {
                        if (bs[j] == '"') {
                            if (j + 1 < end && bs[j + 1] == '"') {
                                j += 2;
                                continue;
                            }
                            self->result_pos = j + 1;
                            self->success = 1;
                            return;
                        }
                        j++;
                    }
                    self->result_pos = end;
                    self->success = 1;
                    return;
                }

                // Interpolated string $"..." or $@"..." or raw $"""..."""
                if (b0 == '$') {
                    int j = i + 1;
                    // Skip additional $
                    while (j < end && bs[j] == '$') {
                        j++;
                    }
                    // Check for @
                    if (j < end && bs[j] == '@') {
                        j++;
                    }
                    // Count opening quotes
                    int quotes = 0;
                    while (j < end && bs[j] == '"') {
                        quotes++;
                        j++;
                    }
                    if (quotes == 0) {
                        self->success = 0;
                        return;
                    }
                    // Raw string (3+ quotes)
                    if (quotes >= 3) {
                        while (j < end) {
                            if (bs[j] == '"') {
                                int q = 0;
                                int p = j;
                                while (p < end && bs[p] == '"') {
                                    q++;
                                    p++;
                                }
                                if (q >= quotes) {
                                    self->result_pos = p;
                                    self->success = 1;
                                    return;
                                }
                                j = p;
                                continue;
                            }
                            j++;
                        }
                        self->result_pos = end;
                        self->success = 1;
                        return;
                    }
                    // Normal interpolated string
                    while (j < end) {
                        if (bs[j] == '\\') {
                            j += 2;
                            continue;
                        }
                        if (bs[j] == '"') {
                            self->result_pos = j + 1;
                            self->success = 1;
                            return;
                        }
                        j++;
                    }
                    self->result_pos = end;
                    self->success = 1;
                    return;
                }

                // Simple string: " or '
                if (b0 == '"' || b0 == '\'') {
                    unsigned char q = b0;
                    int j = i + 1;
                    while (j < end) {
                        if (bs[j] == '\\') {
                            j += 2;
                            continue;
                        }
                        if (bs[j] == q) {
                            self->result_pos = j + 1;
                            self->success = 1;
                            return;
                        }
                        j++;
                    }
                    self->result_pos = end;
                    self->success = 1;
                    return;
                }

                self->success = 0;
            }
        }

        $FindLineEnd {
            $>() {
                int j = self->pos;
                int end = self->scan_end;
                unsigned char* bs = self->bytes;

                while (j < end) {
                    unsigned char b = bs[j];
                    if (b == '\n' || b == ';') {
                        break;
                    }
                    // Stop at // or /* comment
                    if (b == '/' && j + 1 < end && (bs[j + 1] == '/' || bs[j + 1] == '*')) {
                        break;
                    }
                    // Stop at # preprocessor
                    if (b == '#') {
                        break;
                    }
                    j++;
                }

                self->result_pos = j;
            }
        }

        $BalancedParenEnd {
            $>() {
                int i = self->pos;
                int end = self->scan_end;
                unsigned char* bs = self->bytes;

                if (i >= end || bs[i] != '(') {
                    self->success = 0;
                    return;
                }

                int depth = 1;
                int j = i + 1;
                while (j < end && depth > 0) {
                    unsigned char b = bs[j];
                    if (b == '(') {
                        depth++;
                    } else if (b == ')') {
                        depth--;
                    } else if (b == '"' || b == '\'') {
                        unsigned char q = b;
                        j++;
                        while (j < end && bs[j] != q) {
                            if (bs[j] == '\\') {
                                j++;
                            }
                            j++;
                        }
                    }
                    j++;
                }

                if (depth == 0) {
                    self->result_pos = j;
                    self->success = 1;
                } else {
                    self->result_pos = end;
                    self->success = 0;
                }
            }
        }

    domain:
        bytes: unsigned char* = NULL
        pos: int = 0
        scan_end: int = 0
        result_pos: int = 0
        success: int = 1
}

int main() {
    int failures = 0;

    // Test 1: Skip // line comment
    CSharpSyntaxSkipperFsm* s1 = @@CSharpSyntaxSkipperFsm();
    unsigned char t1[] = "// comment\ncode";
    CSharpSyntaxSkipperFsm_setup(s1, t1, 0, sizeof(t1)-1);
    CSharpSyntaxSkipperFsm_do_skip_comment(s1);
    if (CSharpSyntaxSkipperFsm_get_success(s1) != 1 || CSharpSyntaxSkipperFsm_get_result_pos(s1) != 10) {
        printf("FAIL 1: success=%d, pos=%d\n", CSharpSyntaxSkipperFsm_get_success(s1), CSharpSyntaxSkipperFsm_get_result_pos(s1));
        failures++;
    }

    // Test 2: Skip /* */ block comment
    CSharpSyntaxSkipperFsm* s2 = @@CSharpSyntaxSkipperFsm();
    unsigned char t2[] = "/* block */code";
    CSharpSyntaxSkipperFsm_setup(s2, t2, 0, sizeof(t2)-1);
    CSharpSyntaxSkipperFsm_do_skip_comment(s2);
    if (CSharpSyntaxSkipperFsm_get_success(s2) != 1 || CSharpSyntaxSkipperFsm_get_result_pos(s2) != 11) {
        printf("FAIL 2: success=%d, pos=%d\n", CSharpSyntaxSkipperFsm_get_success(s2), CSharpSyntaxSkipperFsm_get_result_pos(s2));
        failures++;
    }

    // Test 3: Skip simple string "hello"
    CSharpSyntaxSkipperFsm* s3 = @@CSharpSyntaxSkipperFsm();
    unsigned char t3[] = "\"hello\" rest";
    CSharpSyntaxSkipperFsm_setup(s3, t3, 0, sizeof(t3)-1);
    CSharpSyntaxSkipperFsm_do_skip_string(s3);
    if (CSharpSyntaxSkipperFsm_get_success(s3) != 1 || CSharpSyntaxSkipperFsm_get_result_pos(s3) != 7) {
        printf("FAIL 3: success=%d, pos=%d\n", CSharpSyntaxSkipperFsm_get_success(s3), CSharpSyntaxSkipperFsm_get_result_pos(s3));
        failures++;
    }

    // Test 4: Skip verbatim string @"verbatim ""quote"""
    CSharpSyntaxSkipperFsm* s4 = @@CSharpSyntaxSkipperFsm();
    unsigned char t4[] = "@\"verbatim \"\"quote\"\"\" rest";
    CSharpSyntaxSkipperFsm_setup(s4, t4, 0, sizeof(t4)-1);
    CSharpSyntaxSkipperFsm_do_skip_string(s4);
    if (CSharpSyntaxSkipperFsm_get_success(s4) != 1 || CSharpSyntaxSkipperFsm_get_result_pos(s4) != 21) {
        printf("FAIL 4: success=%d, pos=%d\n", CSharpSyntaxSkipperFsm_get_success(s4), CSharpSyntaxSkipperFsm_get_result_pos(s4));
        failures++;
    }

    // Test 5: Skip interpolated string $"interp {x}"
    CSharpSyntaxSkipperFsm* s5 = @@CSharpSyntaxSkipperFsm();
    unsigned char t5[] = "$\"interp {x}\" rest";
    CSharpSyntaxSkipperFsm_setup(s5, t5, 0, sizeof(t5)-1);
    CSharpSyntaxSkipperFsm_do_skip_string(s5);
    if (CSharpSyntaxSkipperFsm_get_success(s5) != 1 || CSharpSyntaxSkipperFsm_get_result_pos(s5) != 13) {
        printf("FAIL 5: success=%d, pos=%d\n", CSharpSyntaxSkipperFsm_get_success(s5), CSharpSyntaxSkipperFsm_get_result_pos(s5));
        failures++;
    }

    // Test 6: Find line end (stops at // comment)
    CSharpSyntaxSkipperFsm* s6 = @@CSharpSyntaxSkipperFsm();
    unsigned char t6[] = "x + 1 // comment";
    CSharpSyntaxSkipperFsm_setup(s6, t6, 0, sizeof(t6)-1);
    CSharpSyntaxSkipperFsm_do_find_line_end(s6);
    if (CSharpSyntaxSkipperFsm_get_result_pos(s6) != 6) {
        printf("FAIL 6: pos=%d, expected 6\n", CSharpSyntaxSkipperFsm_get_result_pos(s6));
        failures++;
    }

    // Test 7: Balanced parens
    CSharpSyntaxSkipperFsm* s7 = @@CSharpSyntaxSkipperFsm();
    unsigned char t7[] = "(a, f(b)) rest";
    CSharpSyntaxSkipperFsm_setup(s7, t7, 0, sizeof(t7)-1);
    CSharpSyntaxSkipperFsm_do_balanced_paren_end(s7);
    if (CSharpSyntaxSkipperFsm_get_success(s7) != 1 || CSharpSyntaxSkipperFsm_get_result_pos(s7) != 9) {
        printf("FAIL 7: success=%d, pos=%d\n", CSharpSyntaxSkipperFsm_get_success(s7), CSharpSyntaxSkipperFsm_get_result_pos(s7));
        failures++;
    }

    // Test 8: Skip # preprocessor directive
    CSharpSyntaxSkipperFsm* s8 = @@CSharpSyntaxSkipperFsm();
    unsigned char t8[] = "#region Foo\ncode";
    CSharpSyntaxSkipperFsm_setup(s8, t8, 0, sizeof(t8)-1);
    CSharpSyntaxSkipperFsm_do_skip_comment(s8);
    if (CSharpSyntaxSkipperFsm_get_success(s8) != 1 || CSharpSyntaxSkipperFsm_get_result_pos(s8) != 11) {
        printf("FAIL 8: success=%d, pos=%d\n", CSharpSyntaxSkipperFsm_get_success(s8), CSharpSyntaxSkipperFsm_get_result_pos(s8));
        failures++;
    }

    CSharpSyntaxSkipperFsm_destroy(s1);
    CSharpSyntaxSkipperFsm_destroy(s2);
    CSharpSyntaxSkipperFsm_destroy(s3);
    CSharpSyntaxSkipperFsm_destroy(s4);
    CSharpSyntaxSkipperFsm_destroy(s5);
    CSharpSyntaxSkipperFsm_destroy(s6);
    CSharpSyntaxSkipperFsm_destroy(s7);
    CSharpSyntaxSkipperFsm_destroy(s8);

    if (failures > 0) {
        printf("FAIL: %d failures\n", failures);
        return 1;
    }
    printf("PASS: csharp_skipper (8 cases)\n");
    return 0;
}

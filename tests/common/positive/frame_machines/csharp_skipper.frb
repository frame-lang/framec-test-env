@@target ruby

# CSharpSyntaxSkipper -- FSM for skipping C# comments and strings.
# Translated from framec's native_region_scanner/csharp_skipper.frs
#
# Handles: // line comments, /* */ block comments, # preprocessor directives,
# "..." simple strings, @"..." verbatim strings, $"..." interpolated strings,
# $"""...""" raw strings, C-like line endings, balanced parens.

@@system CSharpSyntaxSkipperFsm {
    operations:
        setup(input_bytes, start, length) {
            self.bytes = input_bytes
            self.pos = start
            self.scan_end = length
        }
        get_result_pos() {
            return self.result_pos
        }
        get_success() {
            return self.success
        }

    interface:
        do_skip_comment()
        do_skip_string()
        do_find_line_end()
        do_balanced_paren_end()

    machine:
        $Init {
            do_skip_comment() { -> $SkipComment }
            do_skip_string() { -> $SkipString }
            do_find_line_end() { -> $FindLineEnd }
            do_balanced_paren_end() { -> $BalancedParenEnd }
        }

        $SkipComment {
            $>() {
                i = self.pos
                scan_end = self.scan_end
                bs = self.bytes

                # Preprocessor directive: # ... newline
                if i < scan_end && bs[i] == 0x23
                    j = i + 1
                    while j < scan_end && bs[j] != 0x0A
                        j += 1
                    end
                    self.result_pos = j
                    self.success = 1
                    return
                end

                # Line comment: //
                if i + 1 < scan_end && bs[i] == 0x2F && bs[i + 1] == 0x2F
                    j = i + 2
                    while j < scan_end && bs[j] != 0x0A
                        j += 1
                    end
                    self.result_pos = j
                    self.success = 1
                    return
                end

                # Block comment: /* ... */
                if i + 1 < scan_end && bs[i] == 0x2F && bs[i + 1] == 0x2A
                    j = i + 2
                    while j + 1 < scan_end
                        if bs[j] == 0x2A && bs[j + 1] == 0x2F
                            self.result_pos = j + 2
                            self.success = 1
                            return
                        end
                        j += 1
                    end
                    self.result_pos = scan_end
                    self.success = 1
                    return
                end

                self.success = 0
            }
        }

        $SkipString {
            $>() {
                i = self.pos
                scan_end = self.scan_end
                bs = self.bytes

                if i >= scan_end
                    self.success = 0
                    return
                end

                b0 = bs[i]

                # Verbatim string @"..." (doubled quotes for escape)
                if b0 == 0x40 && i + 1 < scan_end && bs[i + 1] == 0x22
                    j = i + 2
                    while j < scan_end
                        if bs[j] == 0x22
                            if j + 1 < scan_end && bs[j + 1] == 0x22
                                j += 2
                                next
                            end
                            self.result_pos = j + 1
                            self.success = 1
                            return
                        end
                        j += 1
                    end
                    self.result_pos = scan_end
                    self.success = 1
                    return
                end

                # Interpolated string $"..." or $@"..." or raw $"""..."""
                if b0 == 0x24
                    j = i + 1
                    # Skip additional $
                    while j < scan_end && bs[j] == 0x24
                        j += 1
                    end
                    # Check for @
                    if j < scan_end && bs[j] == 0x40
                        j += 1
                    end
                    # Count opening quotes
                    quotes = 0
                    while j < scan_end && bs[j] == 0x22
                        quotes += 1
                        j += 1
                    end
                    if quotes == 0
                        self.success = 0
                        return
                    end
                    # Raw string (3+ quotes)
                    if quotes >= 3
                        while j < scan_end
                            if bs[j] == 0x22
                                q = 0
                                p = j
                                while p < scan_end && bs[p] == 0x22
                                    q += 1
                                    p += 1
                                end
                                if q >= quotes
                                    self.result_pos = p
                                    self.success = 1
                                    return
                                end
                                j = p
                                next
                            end
                            j += 1
                        end
                        self.result_pos = scan_end
                        self.success = 1
                        return
                    end
                    # Normal interpolated string
                    while j < scan_end
                        if bs[j] == 0x5C
                            j += 2
                            next
                        end
                        if bs[j] == 0x22
                            self.result_pos = j + 1
                            self.success = 1
                            return
                        end
                        j += 1
                    end
                    self.result_pos = scan_end
                    self.success = 1
                    return
                end

                # Simple string: " or '
                if b0 == 0x22 || b0 == 0x27
                    q = b0
                    j = i + 1
                    while j < scan_end
                        if bs[j] == 0x5C
                            j += 2
                            next
                        end
                        if bs[j] == q
                            self.result_pos = j + 1
                            self.success = 1
                            return
                        end
                        j += 1
                    end
                    self.result_pos = scan_end
                    self.success = 1
                    return
                end

                self.success = 0
            }
        }

        $FindLineEnd {
            $>() {
                j = self.pos
                scan_end = self.scan_end
                bs = self.bytes

                while j < scan_end
                    b = bs[j]
                    if b == 0x0A || b == 0x3B
                        break
                    end
                    # Stop at // or /* comment
                    if b == 0x2F && j + 1 < scan_end && (bs[j + 1] == 0x2F || bs[j + 1] == 0x2A)
                        break
                    end
                    # Stop at # preprocessor
                    if b == 0x23
                        break
                    end
                    j += 1
                end

                self.result_pos = j
            }
        }

        $BalancedParenEnd {
            $>() {
                i = self.pos
                scan_end = self.scan_end
                bs = self.bytes

                if i >= scan_end || bs[i] != 0x28
                    self.success = 0
                    return
                end

                depth = 1
                j = i + 1
                while j < scan_end && depth > 0
                    b = bs[j]
                    if b == 0x28
                        depth += 1
                    elsif b == 0x29
                        depth -= 1
                    elsif b == 0x22 || b == 0x27
                        q = b
                        j += 1
                        while j < scan_end && bs[j] != q
                            if bs[j] == 0x5C
                                j += 1
                            end
                            j += 1
                        end
                    end
                    j += 1
                end

                if depth == 0
                    self.result_pos = j
                    self.success = 1
                else
                    self.result_pos = scan_end
                    self.success = 0
                end
            }
        }

    domain:
        bytes = []
        pos: int = 0
        scan_end: int = 0
        result_pos: int = 0
        success: int = 1
}

failures = 0

# Test 1: Skip // line comment
s1 = CSharpSyntaxSkipperFsm.new
inp1 = "// comment\ncode".bytes
s1.setup(inp1, 0, inp1.length)
s1.do_skip_comment()
if s1.get_success() != 1 || s1.get_result_pos() != 10
    puts("FAIL 1: success=#{s1.get_success()}, pos=#{s1.get_result_pos()}")
    failures += 1
end

# Test 2: Skip /* */ block comment
s2 = CSharpSyntaxSkipperFsm.new
inp2 = "/* block */code".bytes
s2.setup(inp2, 0, inp2.length)
s2.do_skip_comment()
if s2.get_success() != 1 || s2.get_result_pos() != 11
    puts("FAIL 2: success=#{s2.get_success()}, pos=#{s2.get_result_pos()}")
    failures += 1
end

# Test 3: Skip simple string "hello"
s3 = CSharpSyntaxSkipperFsm.new
inp3 = "\"hello\" rest".bytes
s3.setup(inp3, 0, inp3.length)
s3.do_skip_string()
if s3.get_success() != 1 || s3.get_result_pos() != 7
    puts("FAIL 3: success=#{s3.get_success()}, pos=#{s3.get_result_pos()}")
    failures += 1
end

# Test 4: Skip verbatim string @"verbatim ""quote"""
s4 = CSharpSyntaxSkipperFsm.new
inp4 = "@\"verbatim \"\"quote\"\"\" rest".bytes
s4.setup(inp4, 0, inp4.length)
s4.do_skip_string()
if s4.get_success() != 1 || s4.get_result_pos() != 21
    puts("FAIL 4: success=#{s4.get_success()}, pos=#{s4.get_result_pos()}")
    failures += 1
end

# Test 5: Skip interpolated string $"interp {x}"
s5 = CSharpSyntaxSkipperFsm.new
inp5 = "$\"interp {x}\" rest".bytes
s5.setup(inp5, 0, inp5.length)
s5.do_skip_string()
if s5.get_success() != 1 || s5.get_result_pos() != 13
    puts("FAIL 5: success=#{s5.get_success()}, pos=#{s5.get_result_pos()}")
    failures += 1
end

# Test 6: Find line end (stops at // comment)
s6 = CSharpSyntaxSkipperFsm.new
inp6 = "x + 1 // comment".bytes
s6.setup(inp6, 0, inp6.length)
s6.do_find_line_end()
if s6.get_result_pos() != 6
    puts("FAIL 6: pos=#{s6.get_result_pos()}, expected 6")
    failures += 1
end

# Test 7: Balanced parens
s7 = CSharpSyntaxSkipperFsm.new
inp7 = "(a, f(b)) rest".bytes
s7.setup(inp7, 0, inp7.length)
s7.do_balanced_paren_end()
if s7.get_success() != 1 || s7.get_result_pos() != 9
    puts("FAIL 7: success=#{s7.get_success()}, pos=#{s7.get_result_pos()}")
    failures += 1
end

# Test 8: Skip # preprocessor directive
s8 = CSharpSyntaxSkipperFsm.new
inp8 = "#region Foo\ncode".bytes
s8.setup(inp8, 0, inp8.length)
s8.do_skip_comment()
if s8.get_success() != 1 || s8.get_result_pos() != 11
    puts("FAIL 8: success=#{s8.get_success()}, pos=#{s8.get_result_pos()}")
    failures += 1
end

if failures > 0
    puts("FAIL: #{failures} failures")
    exit(1)
end
puts("PASS: csharp_skipper (8 cases)")

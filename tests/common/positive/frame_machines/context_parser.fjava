@@target java

// ContextParser -- FSM for parsing @@ context constructs.
// Translated from framec's native_region_scanner/context_parser.frs
//
// Parses:
//   @@:return [= expr]     kind=2 (ContextReturn)
//   @@:event               kind=3 (ContextEvent)
//   @@:data.key [= expr]   kind=4 (ContextData) or kind=5 (ContextDataAssign)
//   @@:params.key           kind=6 (ContextParams)
//   @@SystemName()          kind=7 (TaggedInstantiation)
//   @@:(expr)               kind=8 (ContextReturnExpr)
//   @@:return(expr)         kind=9 (ReturnCall)
//   @@:self.method()        kind=10 (ContextSelfCall)
//   @@:self                 kind=11 (ContextSelf)
//   @@:system.state         kind=12 (ContextSystemState)
//   other                   has_result=0

@@system ContextParserFsm {
    operations:
        setup(input_bytes: byte[], start: int, length: int) {
            this.bytes = input_bytes;
            this.pos = start;
            this.scan_end = length;
        }
        setup_with_paren_end(input_bytes: byte[], start: int, length: int, p_end: int) {
            this.bytes = input_bytes;
            this.pos = start;
            this.scan_end = length;
            this.paren_end = p_end;
        }
        get_result_end(): int {
            return this.result_end;
        }
        get_result_kind(): int {
            return this.result_kind;
        }
        get_has_result(): int {
            return this.has_result;
        }

    interface:
        do_parse()

    machine:
        $Init {
            do_parse() { -> $Dispatching }
        }

        $Dispatching {
            $>() {
                int i = this.pos;
                int end = this.scan_end;
                byte[] bs = this.bytes;

                if (i >= end) {
                    this.has_result = 0;
                    -> $Done
                }

                int b = bs[i] & 0xFF;

                if (b == ':') {
                    this.pos = i + 1;
                    -> $DispatchColon
                } else if (b >= 'A' && b <= 'Z') {
                    // @@SystemName -- pos stays at start of name
                    -> $ParseInstantiation
                } else {
                    this.result_end = i;
                    this.has_result = 0;
                    -> $Done
                }
            }
        }

        $DispatchColon {
            $>() {
                int i = this.pos;
                int end = this.scan_end;
                byte[] bs = this.bytes;

                // Check for @@:return
                if (i + 5 < end) {
                    String tag = new String(bs, i, 6);
                    if (tag.equals("return")) {
                        this.pos = i + 6;
                        -> $ParseReturn
                    }
                }

                // Check for @@:event
                if (i + 4 < end) {
                    String tag = new String(bs, i, 5);
                    if (tag.equals("event")) {
                        this.result_end = i + 5;
                        this.result_kind = 3;
                        this.has_result = 1;
                        -> $Done
                    }
                }

                // Check for @@:data
                if (i + 3 < end) {
                    String tag = new String(bs, i, 4);
                    if (tag.equals("data")) {
                        this.pos = i + 4;
                        -> $ParseData
                    }
                }

                // Check for @@:params
                if (i + 5 < end) {
                    String tag = new String(bs, i, 6);
                    if (tag.equals("params")) {
                        this.pos = i + 6;
                        -> $ParseParams
                    }
                }

                // Check for @@:self
                if (i + 3 < end) {
                    String tag = new String(bs, i, 4);
                    if (tag.equals("self")) {
                        this.pos = i + 4;
                        -> $ParseSelf
                    }
                }

                // Check for @@:system
                if (i + 5 < end) {
                    String tag = new String(bs, i, 6);
                    if (tag.equals("system")) {
                        this.pos = i + 6;
                        -> $ParseSystem
                    }
                }

                // Check for @@:(expr)
                if (i < end && (bs[i] & 0xFF) == '(') {
                    this.pos = i;
                    -> $ParseContextReturnExpr
                }

                // Unknown
                this.result_end = i;
                this.has_result = 0;
                -> $Done
            }
        }

        $ParseReturn {
            $>() {
                int i = this.pos;
                int end = this.scan_end;
                byte[] bs = this.bytes;

                // Skip whitespace
                while (i < end && ((bs[i] & 0xFF) == ' ' || (bs[i] & 0xFF) == '\t')) {
                    i++;
                }

                if (i < end && (bs[i] & 0xFF) == '(') {
                    // @@:return(expr) -- scan balanced parens
                    int depth = 1;
                    i++;
                    while (i < end && depth > 0) {
                        if ((bs[i] & 0xFF) == '(') {
                            depth++;
                        }
                        if ((bs[i] & 0xFF) == ')') {
                            depth--;
                        }
                        if (depth > 0) {
                            i++;
                        }
                    }
                    if (depth == 0) {
                        i++;
                    }
                    this.result_end = i;
                    this.result_kind = 9;
                    this.has_result = 1;
                    -> $Done
                } else if (i < end && (bs[i] & 0xFF) == '=' && (i + 1 >= end || (bs[i + 1] & 0xFF) != '=')) {
                    // @@:return = <expr> -- scan expression
                    i++;
                    // Skip whitespace after =
                    while (i < end && ((bs[i] & 0xFF) == ' ' || (bs[i] & 0xFF) == '\t')) {
                        i++;
                    }
                    // Scan to end of expression (newline or ;)
                    while (i < end && (bs[i] & 0xFF) != '\n' && (bs[i] & 0xFF) != ';') {
                        i++;
                    }
                    this.result_end = i;
                    this.result_kind = 2;
                    this.has_result = 1;
                    -> $Done
                } else {
                    // @@:return (bare read)
                    this.result_end = i;
                    this.result_kind = 2;
                    this.has_result = 1;
                    -> $Done
                }
            }
        }

        $ParseContextReturnExpr {
            $>() {
                int i = this.pos;
                int end = this.scan_end;
                byte[] bs = this.bytes;

                if (i < end && (bs[i] & 0xFF) == '(') {
                    int depth = 1;
                    i++;
                    while (i < end && depth > 0) {
                        int b = bs[i] & 0xFF;
                        if (b == '(') {
                            depth++;
                        } else if (b == ')') {
                            depth--;
                        } else if (b == '"' || b == '\'') {
                            int q = b;
                            i++;
                            while (i < end) {
                                if ((bs[i] & 0xFF) == '\\' && i + 1 < end) {
                                    i += 2;
                                    continue;
                                }
                                if ((bs[i] & 0xFF) == q) {
                                    break;
                                }
                                i++;
                            }
                        }
                        i++;
                    }
                }

                this.result_end = i;
                this.result_kind = 8;
                this.has_result = 1;
                -> $Done
            }
        }

        $ParseData {
            $>() {
                int i = this.pos;
                int end = this.scan_end;
                byte[] bs = this.bytes;

                // Scan .key
                if (i < end && (bs[i] & 0xFF) == '.') {
                    i++;
                    while (i < end && (Character.isLetterOrDigit(bs[i] & 0xFF) || (bs[i] & 0xFF) == '_')) {
                        i++;
                    }
                }

                // Check for assignment
                int j = i;
                while (j < end && ((bs[j] & 0xFF) == ' ' || (bs[j] & 0xFF) == '\t')) {
                    j++;
                }

                if (j < end && (bs[j] & 0xFF) == '=' && (j + 1 >= end || (bs[j + 1] & 0xFF) != '=')) {
                    // @@:data.key = expr
                    j++;
                    while (j < end && ((bs[j] & 0xFF) == ' ' || (bs[j] & 0xFF) == '\t')) {
                        j++;
                    }
                    while (j < end && (bs[j] & 0xFF) != '\n' && (bs[j] & 0xFF) != ';') {
                        j++;
                    }
                    this.result_end = j;
                    this.result_kind = 5;
                } else {
                    this.result_end = i;
                    this.result_kind = 4;
                }

                this.has_result = 1;
                -> $Done
            }
        }

        $ParseParams {
            $>() {
                int i = this.pos;
                int end = this.scan_end;
                byte[] bs = this.bytes;

                if (i < end && (bs[i] & 0xFF) == '.') {
                    i++;
                    while (i < end && (Character.isLetterOrDigit(bs[i] & 0xFF) || (bs[i] & 0xFF) == '_')) {
                        i++;
                    }
                }

                this.result_end = i;
                this.result_kind = 6;
                this.has_result = 1;
                -> $Done
            }
        }

        $ParseSelf {
            $>() {
                int i = this.pos;
                int end = this.scan_end;
                byte[] bs = this.bytes;

                if (i < end && (bs[i] & 0xFF) == '.') {
                    i++;
                    // Scan identifier
                    while (i < end && (Character.isLetterOrDigit(bs[i] & 0xFF) || (bs[i] & 0xFF) == '_')) {
                        i++;
                    }
                    if (i < end && (bs[i] & 0xFF) == '(') {
                        // @@:self.method(args) -- scan balanced parens
                        int depth = 1;
                        i++;
                        while (i < end && depth > 0) {
                            if ((bs[i] & 0xFF) == '(') {
                                depth++;
                            }
                            if ((bs[i] & 0xFF) == ')') {
                                depth--;
                            }
                            if ((bs[i] & 0xFF) == '"' || (bs[i] & 0xFF) == '\'') {
                                int q = bs[i] & 0xFF;
                                i++;
                                while (i < end) {
                                    if ((bs[i] & 0xFF) == '\\' && i + 1 < end) {
                                        i += 2;
                                        continue;
                                    }
                                    if ((bs[i] & 0xFF) == q) {
                                        break;
                                    }
                                    i++;
                                }
                            }
                            if (depth > 0) {
                                i++;
                            }
                        }
                        if (depth == 0) {
                            i++;
                        }
                        this.result_end = i;
                        this.result_kind = 10;
                        this.has_result = 1;
                    } else {
                        // @@:self.property
                        this.result_end = i;
                        this.result_kind = 11;
                        this.has_result = 1;
                    }
                } else {
                    // bare @@:self
                    this.result_end = i;
                    this.result_kind = 11;
                    this.has_result = 1;
                }

                -> $Done
            }
        }

        $ParseSystem {
            $>() {
                int i = this.pos;
                int end = this.scan_end;
                byte[] bs = this.bytes;

                if (i + 5 < end) {
                    String tag = new String(bs, i, 6);
                    if (tag.equals(".state")) {
                        int after = i + 6;
                        if (after >= end || (!Character.isLetterOrDigit(bs[after] & 0xFF) && (bs[after] & 0xFF) != '_')) {
                            this.result_end = i + 6;
                            this.result_kind = 12;
                            this.has_result = 1;
                            -> $Done
                        }
                    }
                }

                // Bare @@:system or unknown variant
                this.result_end = i;
                this.result_kind = 13;
                this.has_result = 1;
                -> $Done
            }
        }

        $ParseInstantiation {
            $>() {
                int i = this.pos;
                int end = this.scan_end;
                byte[] bs = this.bytes;

                // Scan identifier
                while (i < end && (Character.isLetterOrDigit(bs[i] & 0xFF) || (bs[i] & 0xFF) == '_')) {
                    i++;
                }

                // Must be followed by (
                if (i < end && (bs[i] & 0xFF) == '(') {
                    if (this.paren_end > 0) {
                        i = this.paren_end;
                        this.result_end = i;
                        this.result_kind = 7;
                        this.has_result = 1;
                    } else {
                        this.result_end = i;
                        this.has_result = 0;
                    }
                } else {
                    this.result_end = i;
                    this.has_result = 0;
                }

                -> $Done
            }
        }

        $Done {
            $>() {
                // Terminal state -- results are in domain vars
            }
        }

    domain:
        bytes: byte[] = null
        pos: int = 0
        scan_end: int = 0
        result_end: int = 0
        result_kind: int = 0
        has_result: int = 0
        paren_end: int = 0
}

class Main {
    public static void main(String[] args) {
        int failures = 0;

        // Test 1: @@:return (bare read)
        ContextParserFsm p1 = @@ContextParserFsm();
        byte[] inp1 = ":return".getBytes();
        p1.setup(inp1, 0, inp1.length);
        p1.do_parse();
        if (p1.get_has_result() != 1 || p1.get_result_kind() != 2) {
            System.out.println("FAIL 1: has_result=" + p1.get_has_result() + ", kind=" + p1.get_result_kind());
            failures++;
        }

        // Test 2: @@:event
        ContextParserFsm p2 = @@ContextParserFsm();
        byte[] inp2 = ":event".getBytes();
        p2.setup(inp2, 0, inp2.length);
        p2.do_parse();
        if (p2.get_has_result() != 1 || p2.get_result_kind() != 3) {
            System.out.println("FAIL 2: has_result=" + p2.get_has_result() + ", kind=" + p2.get_result_kind());
            failures++;
        }

        // Test 3: @@:data.key
        ContextParserFsm p3 = @@ContextParserFsm();
        byte[] inp3 = ":data.name rest".getBytes();
        p3.setup(inp3, 0, inp3.length);
        p3.do_parse();
        if (p3.get_has_result() != 1 || p3.get_result_kind() != 4) {
            System.out.println("FAIL 3: has_result=" + p3.get_has_result() + ", kind=" + p3.get_result_kind());
            failures++;
        }

        // Test 4: @@:data.key = expr
        ContextParserFsm p4 = @@ContextParserFsm();
        byte[] inp4 = ":data.key = value\n".getBytes();
        p4.setup(inp4, 0, inp4.length);
        p4.do_parse();
        if (p4.get_has_result() != 1 || p4.get_result_kind() != 5) {
            System.out.println("FAIL 4: has_result=" + p4.get_has_result() + ", kind=" + p4.get_result_kind());
            failures++;
        }

        // Test 5: @@:params.key
        ContextParserFsm p5 = @@ContextParserFsm();
        byte[] inp5 = ":params.name rest".getBytes();
        p5.setup(inp5, 0, inp5.length);
        p5.do_parse();
        if (p5.get_has_result() != 1 || p5.get_result_kind() != 6) {
            System.out.println("FAIL 5: has_result=" + p5.get_has_result() + ", kind=" + p5.get_result_kind());
            failures++;
        }

        // Test 6: @@:(expr)
        ContextParserFsm p6 = @@ContextParserFsm();
        byte[] inp6 = ":(x + 1) rest".getBytes();
        p6.setup(inp6, 0, inp6.length);
        p6.do_parse();
        if (p6.get_has_result() != 1 || p6.get_result_kind() != 8) {
            System.out.println("FAIL 6: has_result=" + p6.get_has_result() + ", kind=" + p6.get_result_kind());
            failures++;
        }

        // Test 7: @@:return(expr)
        ContextParserFsm p7 = @@ContextParserFsm();
        byte[] inp7 = ":return(42) rest".getBytes();
        p7.setup(inp7, 0, inp7.length);
        p7.do_parse();
        if (p7.get_has_result() != 1 || p7.get_result_kind() != 9) {
            System.out.println("FAIL 7: has_result=" + p7.get_has_result() + ", kind=" + p7.get_result_kind());
            failures++;
        }

        // Test 8: @@:self (bare)
        ContextParserFsm p8 = @@ContextParserFsm();
        byte[] inp8 = ":self rest".getBytes();
        p8.setup(inp8, 0, inp8.length);
        p8.do_parse();
        if (p8.get_has_result() != 1 || p8.get_result_kind() != 11) {
            System.out.println("FAIL 8: has_result=" + p8.get_has_result() + ", kind=" + p8.get_result_kind());
            failures++;
        }

        // Test 9: @@:self.method(args)
        ContextParserFsm p9 = @@ContextParserFsm();
        byte[] inp9 = ":self.doWork(x) rest".getBytes();
        p9.setup(inp9, 0, inp9.length);
        p9.do_parse();
        if (p9.get_has_result() != 1 || p9.get_result_kind() != 10) {
            System.out.println("FAIL 9: has_result=" + p9.get_has_result() + ", kind=" + p9.get_result_kind());
            failures++;
        }

        // Test 10: @@:system.state
        ContextParserFsm p10 = @@ContextParserFsm();
        byte[] inp10 = ":system.state rest".getBytes();
        p10.setup(inp10, 0, inp10.length);
        p10.do_parse();
        if (p10.get_has_result() != 1 || p10.get_result_kind() != 12) {
            System.out.println("FAIL 10: has_result=" + p10.get_has_result() + ", kind=" + p10.get_result_kind());
            failures++;
        }

        // Test 11: @@SystemName() with paren_end
        ContextParserFsm p11 = @@ContextParserFsm();
        byte[] inp11 = "MySystem() rest".getBytes();
        p11.setup_with_paren_end(inp11, 0, inp11.length, 10);
        p11.do_parse();
        if (p11.get_has_result() != 1 || p11.get_result_kind() != 7) {
            System.out.println("FAIL 11: has_result=" + p11.get_has_result() + ", kind=" + p11.get_result_kind());
            failures++;
        }

        // Test 12: No match (lowercase, not a keyword)
        ContextParserFsm p12 = @@ContextParserFsm();
        byte[] inp12 = "xyz".getBytes();
        p12.setup(inp12, 0, inp12.length);
        p12.do_parse();
        if (p12.get_has_result() != 0) {
            System.out.println("FAIL 12: should not match, has_result=" + p12.get_has_result());
            failures++;
        }

        if (failures > 0) {
            System.out.println("FAIL: " + failures + " failures");
            System.exit(1);
        }
        System.out.println("PASS: context_parser (12 cases)");
    }
}

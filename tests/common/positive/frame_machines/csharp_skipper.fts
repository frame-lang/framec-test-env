@@target typescript

// CSharpSyntaxSkipper -- FSM for skipping C# comments and strings.
// Translated from framec's native_region_scanner/csharp_skipper.frs
//
// Handles: // line comments, /* */ block comments, # preprocessor directives,
// "..." simple strings, @"..." verbatim strings, $"..." interpolated strings,
// $"""...""" raw strings, C-like line endings, balanced parens.

@@system CSharpSyntaxSkipperFsm {
    operations:
        setup(input_bytes: number[], start: number, length: number) {
            this.bytes = input_bytes;
            this.pos = start;
            this.scan_end = length;
        }
        get_result_pos(): number {
            return this.result_pos;
        }
        get_success(): number {
            return this.success;
        }

    interface:
        do_skip_comment()
        do_skip_string()
        do_find_line_end()
        do_balanced_paren_end()

    machine:
        $Init {
            do_skip_comment() { -> $SkipComment }
            do_skip_string() { -> $SkipString }
            do_find_line_end() { -> $FindLineEnd }
            do_balanced_paren_end() { -> $BalancedParenEnd }
        }

        $SkipComment {
            $>() {
                let i = this.pos;
                const end = this.scan_end;
                const bs = this.bytes;

                // Preprocessor directive: # ... newline
                if (i < end && bs[i] === 0x23) {
                    let j = i + 1;
                    while (j < end && bs[j] !== 0x0A) {
                        j++;
                    }
                    this.result_pos = j;
                    this.success = 1;
                    return;
                }

                // Line comment: //
                if (i + 1 < end && bs[i] === 0x2F && bs[i + 1] === 0x2F) {
                    let j = i + 2;
                    while (j < end && bs[j] !== 0x0A) {
                        j++;
                    }
                    this.result_pos = j;
                    this.success = 1;
                    return;
                }

                // Block comment: /* ... */
                if (i + 1 < end && bs[i] === 0x2F && bs[i + 1] === 0x2A) {
                    let j = i + 2;
                    while (j + 1 < end) {
                        if (bs[j] === 0x2A && bs[j + 1] === 0x2F) {
                            this.result_pos = j + 2;
                            this.success = 1;
                            return;
                        }
                        j++;
                    }
                    this.result_pos = end;
                    this.success = 1;
                    return;
                }

                this.success = 0;
            }
        }

        $SkipString {
            $>() {
                let i = this.pos;
                const end = this.scan_end;
                const bs = this.bytes;

                if (i >= end) {
                    this.success = 0;
                    return;
                }

                const b0 = bs[i];

                // Verbatim string @"..." (doubled quotes for escape)
                if (b0 === 0x40 && i + 1 < end && bs[i + 1] === 0x22) {
                    let j = i + 2;
                    while (j < end) {
                        if (bs[j] === 0x22) {
                            if (j + 1 < end && bs[j + 1] === 0x22) {
                                j += 2;
                                continue;
                            }
                            this.result_pos = j + 1;
                            this.success = 1;
                            return;
                        }
                        j++;
                    }
                    this.result_pos = end;
                    this.success = 1;
                    return;
                }

                // Interpolated string $"..." or $@"..." or raw $"""..."""
                if (b0 === 0x24) {
                    let j = i + 1;
                    // Skip additional $
                    while (j < end && bs[j] === 0x24) {
                        j++;
                    }
                    // Check for @
                    if (j < end && bs[j] === 0x40) {
                        j++;
                    }
                    // Count opening quotes
                    let quotes = 0;
                    while (j < end && bs[j] === 0x22) {
                        quotes++;
                        j++;
                    }
                    if (quotes === 0) {
                        this.success = 0;
                        return;
                    }
                    // Raw string (3+ quotes)
                    if (quotes >= 3) {
                        while (j < end) {
                            if (bs[j] === 0x22) {
                                let q = 0;
                                let p = j;
                                while (p < end && bs[p] === 0x22) {
                                    q++;
                                    p++;
                                }
                                if (q >= quotes) {
                                    this.result_pos = p;
                                    this.success = 1;
                                    return;
                                }
                                j = p;
                                continue;
                            }
                            j++;
                        }
                        this.result_pos = end;
                        this.success = 1;
                        return;
                    }
                    // Normal interpolated string
                    while (j < end) {
                        if (bs[j] === 0x5C) {
                            j += 2;
                            continue;
                        }
                        if (bs[j] === 0x22) {
                            this.result_pos = j + 1;
                            this.success = 1;
                            return;
                        }
                        j++;
                    }
                    this.result_pos = end;
                    this.success = 1;
                    return;
                }

                // Simple string: " or '
                if (b0 === 0x22 || b0 === 0x27) {
                    const q = b0;
                    let j = i + 1;
                    while (j < end) {
                        if (bs[j] === 0x5C) {
                            j += 2;
                            continue;
                        }
                        if (bs[j] === q) {
                            this.result_pos = j + 1;
                            this.success = 1;
                            return;
                        }
                        j++;
                    }
                    this.result_pos = end;
                    this.success = 1;
                    return;
                }

                this.success = 0;
            }
        }

        $FindLineEnd {
            $>() {
                let j = this.pos;
                const end = this.scan_end;
                const bs = this.bytes;

                while (j < end) {
                    const b = bs[j];
                    if (b === 0x0A || b === 0x3B) {
                        break;
                    }
                    // Stop at // or /* comment
                    if (b === 0x2F && j + 1 < end && (bs[j + 1] === 0x2F || bs[j + 1] === 0x2A)) {
                        break;
                    }
                    // Stop at # preprocessor
                    if (b === 0x23) {
                        break;
                    }
                    j++;
                }

                this.result_pos = j;
            }
        }

        $BalancedParenEnd {
            $>() {
                let i = this.pos;
                const end = this.scan_end;
                const bs = this.bytes;

                if (i >= end || bs[i] !== 0x28) {
                    this.success = 0;
                    return;
                }

                let depth = 1;
                i++;
                while (i < end && depth > 0) {
                    const b = bs[i];
                    if (b === 0x28) {
                        depth++;
                    } else if (b === 0x29) {
                        depth--;
                    } else if (b === 0x22 || b === 0x27) {
                        const q = b;
                        i++;
                        while (i < end && bs[i] !== q) {
                            if (bs[i] === 0x5C) {
                                i++;
                            }
                            i++;
                        }
                    }
                    i++;
                }

                if (depth === 0) {
                    this.result_pos = i;
                    this.success = 1;
                } else {
                    this.result_pos = end;
                    this.success = 0;
                }
            }
        }

    domain:
        bytes: number[] = []
        pos: number = 0
        scan_end: number = 0
        result_pos: number = 0
        success: number = 1
}

const enc = (s: string) => Array.from(Buffer.from(s));

let failures = 0;

// Test 1: Skip // line comment
const s1 = @@CSharpSyntaxSkipperFsm();
const inp1 = enc("// comment\ncode");
s1.setup(inp1, 0, inp1.length);
s1.do_skip_comment();
if (s1.get_success() !== 1 || s1.get_result_pos() !== 10) {
    console.log(`FAIL 1: success=${s1.get_success()}, pos=${s1.get_result_pos()}`);
    failures++;
}

// Test 2: Skip /* */ block comment
const s2 = @@CSharpSyntaxSkipperFsm();
const inp2 = enc("/* block */code");
s2.setup(inp2, 0, inp2.length);
s2.do_skip_comment();
if (s2.get_success() !== 1 || s2.get_result_pos() !== 11) {
    console.log(`FAIL 2: success=${s2.get_success()}, pos=${s2.get_result_pos()}`);
    failures++;
}

// Test 3: Skip simple string "hello"
const s3 = @@CSharpSyntaxSkipperFsm();
const inp3 = enc('"hello" rest');
s3.setup(inp3, 0, inp3.length);
s3.do_skip_string();
if (s3.get_success() !== 1 || s3.get_result_pos() !== 7) {
    console.log(`FAIL 3: success=${s3.get_success()}, pos=${s3.get_result_pos()}`);
    failures++;
}

// Test 4: Skip verbatim string @"verbatim ""quote"""
const s4 = @@CSharpSyntaxSkipperFsm();
const inp4 = enc('@"verbatim ""quote""" rest');
s4.setup(inp4, 0, inp4.length);
s4.do_skip_string();
if (s4.get_success() !== 1 || s4.get_result_pos() !== 21) {
    console.log(`FAIL 4: success=${s4.get_success()}, pos=${s4.get_result_pos()}`);
    failures++;
}

// Test 5: Skip interpolated string $"interp {x}"
const s5 = @@CSharpSyntaxSkipperFsm();
const inp5 = enc('$"interp {x}" rest');
s5.setup(inp5, 0, inp5.length);
s5.do_skip_string();
if (s5.get_success() !== 1 || s5.get_result_pos() !== 13) {
    console.log(`FAIL 5: success=${s5.get_success()}, pos=${s5.get_result_pos()}`);
    failures++;
}

// Test 6: Find line end (stops at // comment)
const s6 = @@CSharpSyntaxSkipperFsm();
const inp6 = enc("x + 1 // comment");
s6.setup(inp6, 0, inp6.length);
s6.do_find_line_end();
if (s6.get_result_pos() !== 6) {
    console.log(`FAIL 6: pos=${s6.get_result_pos()}, expected 6`);
    failures++;
}

// Test 7: Balanced parens
const s7 = @@CSharpSyntaxSkipperFsm();
const inp7 = enc("(a, f(b)) rest");
s7.setup(inp7, 0, inp7.length);
s7.do_balanced_paren_end();
if (s7.get_success() !== 1 || s7.get_result_pos() !== 9) {
    console.log(`FAIL 7: success=${s7.get_success()}, pos=${s7.get_result_pos()}`);
    failures++;
}

// Test 8: Skip # preprocessor directive
const s8 = @@CSharpSyntaxSkipperFsm();
const inp8 = enc("#region Foo\ncode");
s8.setup(inp8, 0, inp8.length);
s8.do_skip_comment();
if (s8.get_success() !== 1 || s8.get_result_pos() !== 11) {
    console.log(`FAIL 8: success=${s8.get_success()}, pos=${s8.get_result_pos()}`);
    failures++;
}

if (failures > 0) { console.log("FAIL: " + failures + " failures"); process.exit(1); }
console.log("PASS: csharp_skipper (8 cases)");

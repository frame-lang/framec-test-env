@@[target("python_3")]

# ContextParser -- FSM for parsing @@ context constructs.
# Translated from framec's native_region_scanner/context_parser.frs
#
# Parses:
#   @@:return [= expr]     kind=2 (ContextReturn)
#   @@:event               kind=3 (ContextEvent)
#   @@:data.key [= expr]   kind=4 (ContextData) or kind=5 (ContextDataAssign)
#   @@:params.key           kind=6 (ContextParams)
#   @@SystemName()          kind=7 (TaggedInstantiation)
#   @@:(expr)               kind=8 (ContextReturnExpr)
#   @@:return(expr)         kind=9 (ReturnCall)
#   @@:self.method()        kind=10 (ContextSelfCall)
#   @@:self                 kind=11 (ContextSelf)
#   @@:system.state         kind=12 (ContextSystemState)
#   other                   has_result=0

@@system ContextParserFsm {
    operations:
        setup(input_bytes: list, start: int, length: int) {
            self.bytes = input_bytes
            self.pos = start
            self.scan_end = length
        }
        setup_with_paren_end(input_bytes: list, start: int, length: int, p_end: int) {
            self.bytes = input_bytes
            self.pos = start
            self.scan_end = length
            self.paren_end = p_end
        }
        get_result_end(): int {
            return self.result_end
        }
        get_result_kind(): int {
            return self.result_kind
        }
        get_has_result(): int {
            return self.has_result
        }

    interface:
        do_parse()

    machine:
        $Init {
            do_parse() { -> $Dispatching }
        }

        $Dispatching {
            $>() {
                i = self.pos
                end = self.scan_end
                bs = self.bytes

                if i >= end:
                    self.has_result = 0
                    -> $Done

                b = bs[i]

                if b == ord(':'):
                    self.pos = i + 1
                    -> $DispatchColon
                elif chr(b).isupper():
                    # @@SystemName -- pos stays at start of name
                    -> $ParseInstantiation
                else:
                    self.result_end = i
                    self.has_result = 0
                    -> $Done
            }
        }

        $DispatchColon {
            $>() {
                i = self.pos
                end = self.scan_end
                bs = self.bytes

                # Check for @@:return
                if i + 5 < end:
                    tag = bytes(bs[i:i + 6])
                    if tag == b"return":
                        self.pos = i + 6
                        -> $ParseReturn

                # Check for @@:event
                if i + 4 < end:
                    tag = bytes(bs[i:i + 5])
                    if tag == b"event":
                        self.result_end = i + 5
                        self.result_kind = 3
                        self.has_result = 1
                        -> $Done

                # Check for @@:data
                if i + 3 < end:
                    tag = bytes(bs[i:i + 4])
                    if tag == b"data":
                        self.pos = i + 4
                        -> $ParseData

                # Check for @@:params
                if i + 5 < end:
                    tag = bytes(bs[i:i + 6])
                    if tag == b"params":
                        self.pos = i + 6
                        -> $ParseParams

                # Check for @@:self
                if i + 3 < end:
                    tag = bytes(bs[i:i + 4])
                    if tag == b"self":
                        self.pos = i + 4
                        -> $ParseSelf

                # Check for @@:system
                if i + 5 < end:
                    tag = bytes(bs[i:i + 6])
                    if tag == b"system":
                        self.pos = i + 6
                        -> $ParseSystem

                # Check for @@:(expr)
                if i < end and bs[i] == ord('('):
                    self.pos = i
                    -> $ParseContextReturnExpr

                # Unknown
                self.result_end = i
                self.has_result = 0
                -> $Done
            }
        }

        $ParseReturn {
            $>() {
                i = self.pos
                end = self.scan_end
                bs = self.bytes

                # Skip whitespace
                while i < end and (bs[i] == ord(' ') or bs[i] == ord('\t')):
                    i += 1

                if i < end and bs[i] == ord('('):
                    # @@:return(expr) -- scan balanced parens
                    depth = 1
                    i += 1
                    while i < end and depth > 0:
                        if bs[i] == ord('('):
                            depth += 1
                        if bs[i] == ord(')'):
                            depth -= 1
                        if depth > 0:
                            i += 1
                    if depth == 0:
                        i += 1
                    self.result_end = i
                    self.result_kind = 9
                    self.has_result = 1
                    -> $Done
                elif i < end and bs[i] == ord('=') and (i + 1 >= end or bs[i + 1] != ord('=')):
                    # @@:return = <expr> -- scan expression
                    i += 1
                    # Skip whitespace after =
                    while i < end and (bs[i] == ord(' ') or bs[i] == ord('\t')):
                        i += 1
                    # Scan to end of expression (newline or ;)
                    while i < end and bs[i] != ord('\n') and bs[i] != ord(';'):
                        i += 1
                    self.result_end = i
                    self.result_kind = 2
                    self.has_result = 1
                    -> $Done
                else:
                    # @@:return (bare read)
                    self.result_end = i
                    self.result_kind = 2
                    self.has_result = 1
                    -> $Done
            }
        }

        $ParseContextReturnExpr {
            $>() {
                i = self.pos
                end = self.scan_end
                bs = self.bytes

                if i < end and bs[i] == ord('('):
                    depth = 1
                    i += 1
                    while i < end and depth > 0:
                        b = bs[i]
                        if b == ord('('):
                            depth += 1
                        elif b == ord(')'):
                            depth -= 1
                        elif b == ord('"') or b == ord("'"):
                            q = b
                            i += 1
                            while i < end:
                                if bs[i] == ord('\\') and i + 1 < end:
                                    i += 2
                                    continue
                                if bs[i] == q:
                                    break
                                i += 1
                        i += 1

                self.result_end = i
                self.result_kind = 8
                self.has_result = 1
                -> $Done
            }
        }

        $ParseData {
            $>() {
                i = self.pos
                end = self.scan_end
                bs = self.bytes

                # Scan .key
                if i < end and bs[i] == ord('.'):
                    i += 1
                    while i < end and (chr(bs[i]).isalnum() or bs[i] == ord('_')):
                        i += 1

                # Check for assignment
                j = i
                while j < end and (bs[j] == ord(' ') or bs[j] == ord('\t')):
                    j += 1

                if j < end and bs[j] == ord('=') and (j + 1 >= end or bs[j + 1] != ord('=')):
                    # @@:data.key = expr
                    j += 1
                    while j < end and (bs[j] == ord(' ') or bs[j] == ord('\t')):
                        j += 1
                    while j < end and bs[j] != ord('\n') and bs[j] != ord(';'):
                        j += 1
                    self.result_end = j
                    self.result_kind = 5
                else:
                    self.result_end = i
                    self.result_kind = 4

                self.has_result = 1
                -> $Done
            }
        }

        $ParseParams {
            $>() {
                i = self.pos
                end = self.scan_end
                bs = self.bytes

                if i < end and bs[i] == ord('.'):
                    i += 1
                    while i < end and (chr(bs[i]).isalnum() or bs[i] == ord('_')):
                        i += 1

                self.result_end = i
                self.result_kind = 6
                self.has_result = 1
                -> $Done
            }
        }

        $ParseSelf {
            $>() {
                i = self.pos
                end = self.scan_end
                bs = self.bytes

                if i < end and bs[i] == ord('.'):
                    i += 1
                    # Scan identifier
                    while i < end and (chr(bs[i]).isalnum() or bs[i] == ord('_')):
                        i += 1
                    if i < end and bs[i] == ord('('):
                        # @@:self.method(args) -- scan balanced parens
                        depth = 1
                        i += 1
                        while i < end and depth > 0:
                            if bs[i] == ord('('):
                                depth += 1
                            if bs[i] == ord(')'):
                                depth -= 1
                            if bs[i] == ord('"') or bs[i] == ord("'"):
                                q = bs[i]
                                i += 1
                                while i < end:
                                    if bs[i] == ord('\\') and i + 1 < end:
                                        i += 2
                                        continue
                                    if bs[i] == q:
                                        break
                                    i += 1
                            if depth > 0:
                                i += 1
                        if depth == 0:
                            i += 1
                        self.result_end = i
                        self.result_kind = 10
                        self.has_result = 1
                    else:
                        # @@:self.property
                        self.result_end = i
                        self.result_kind = 11
                        self.has_result = 1
                else:
                    # bare @@:self
                    self.result_end = i
                    self.result_kind = 11
                    self.has_result = 1

                -> $Done
            }
        }

        $ParseSystem {
            $>() {
                i = self.pos
                end = self.scan_end
                bs = self.bytes

                if i + 5 < end:
                    tag = bytes(bs[i:i + 6])
                    if tag == b".state":
                        after = i + 6
                        if after >= end or (not chr(bs[after]).isalnum() and bs[after] != ord('_')):
                            self.result_end = i + 6
                            self.result_kind = 12
                            self.has_result = 1
                            -> $Done

                # Bare @@:system or unknown variant
                self.result_end = i
                self.result_kind = 13
                self.has_result = 1
                -> $Done
            }
        }

        $ParseInstantiation {
            $>() {
                i = self.pos
                end = self.scan_end
                bs = self.bytes

                # Scan identifier
                while i < end and (chr(bs[i]).isalnum() or bs[i] == ord('_')):
                    i += 1

                # Must be followed by (
                if i < end and bs[i] == ord('('):
                    if self.paren_end > 0:
                        i = self.paren_end
                        self.result_end = i
                        self.result_kind = 7
                        self.has_result = 1
                    else:
                        self.result_end = i
                        self.has_result = 0
                else:
                    self.result_end = i
                    self.has_result = 0

                -> $Done
            }
        }

        $Done {
            $>() {
                # Terminal state -- results are in domain vars
                pass
            }
        }

    domain:
        bytes: list = []
        pos: int = 0
        scan_end: int = 0
        result_end: int = 0
        result_kind: int = 0
        has_result: int = 0
        paren_end: int = 0
}

if __name__ == '__main__':
    failures = 0

    # Test 1: @@:return (bare read)
    p1 = @@ContextParserFsm()
    inp1 = list(b":return")
    p1.setup(inp1, 0, len(inp1))
    p1.do_parse()
    if p1.get_has_result() != 1 or p1.get_result_kind() != 2:
        print(f"FAIL 1: has_result={p1.get_has_result()}, kind={p1.get_result_kind()}")
        failures += 1

    # Test 2: @@:event
    p2 = @@ContextParserFsm()
    inp2 = list(b":event")
    p2.setup(inp2, 0, len(inp2))
    p2.do_parse()
    if p2.get_has_result() != 1 or p2.get_result_kind() != 3:
        print(f"FAIL 2: has_result={p2.get_has_result()}, kind={p2.get_result_kind()}")
        failures += 1

    # Test 3: @@:data.key
    p3 = @@ContextParserFsm()
    inp3 = list(b":data.name rest")
    p3.setup(inp3, 0, len(inp3))
    p3.do_parse()
    if p3.get_has_result() != 1 or p3.get_result_kind() != 4:
        print(f"FAIL 3: has_result={p3.get_has_result()}, kind={p3.get_result_kind()}")
        failures += 1

    # Test 4: @@:data.key = expr
    p4 = @@ContextParserFsm()
    inp4 = list(b":data.key = value\n")
    p4.setup(inp4, 0, len(inp4))
    p4.do_parse()
    if p4.get_has_result() != 1 or p4.get_result_kind() != 5:
        print(f"FAIL 4: has_result={p4.get_has_result()}, kind={p4.get_result_kind()}")
        failures += 1

    # Test 5: @@:params.key
    p5 = @@ContextParserFsm()
    inp5 = list(b":params.name rest")
    p5.setup(inp5, 0, len(inp5))
    p5.do_parse()
    if p5.get_has_result() != 1 or p5.get_result_kind() != 6:
        print(f"FAIL 5: has_result={p5.get_has_result()}, kind={p5.get_result_kind()}")
        failures += 1

    # Test 6: @@:(expr)
    p6 = @@ContextParserFsm()
    inp6 = list(b":(x + 1) rest")
    p6.setup(inp6, 0, len(inp6))
    p6.do_parse()
    if p6.get_has_result() != 1 or p6.get_result_kind() != 8:
        print(f"FAIL 6: has_result={p6.get_has_result()}, kind={p6.get_result_kind()}")
        failures += 1

    # Test 7: @@:return(expr)
    p7 = @@ContextParserFsm()
    inp7 = list(b":return(42) rest")
    p7.setup(inp7, 0, len(inp7))
    p7.do_parse()
    if p7.get_has_result() != 1 or p7.get_result_kind() != 9:
        print(f"FAIL 7: has_result={p7.get_has_result()}, kind={p7.get_result_kind()}")
        failures += 1

    # Test 8: @@:self (bare)
    p8 = @@ContextParserFsm()
    inp8 = list(b":self rest")
    p8.setup(inp8, 0, len(inp8))
    p8.do_parse()
    if p8.get_has_result() != 1 or p8.get_result_kind() != 11:
        print(f"FAIL 8: has_result={p8.get_has_result()}, kind={p8.get_result_kind()}")
        failures += 1

    # Test 9: @@:self.method(args)
    p9 = @@ContextParserFsm()
    inp9 = list(b":self.doWork(x) rest")
    p9.setup(inp9, 0, len(inp9))
    p9.do_parse()
    if p9.get_has_result() != 1 or p9.get_result_kind() != 10:
        print(f"FAIL 9: has_result={p9.get_has_result()}, kind={p9.get_result_kind()}")
        failures += 1

    # Test 10: @@:system.state
    p10 = @@ContextParserFsm()
    inp10 = list(b":system.state rest")
    p10.setup(inp10, 0, len(inp10))
    p10.do_parse()
    if p10.get_has_result() != 1 or p10.get_result_kind() != 12:
        print(f"FAIL 10: has_result={p10.get_has_result()}, kind={p10.get_result_kind()}")
        failures += 1

    # Test 11: @@SystemName() with paren_end
    p11 = @@ContextParserFsm()
    inp11 = list(b"MySystem() rest")
    p11.setup_with_paren_end(inp11, 0, len(inp11), 10)
    p11.do_parse()
    if p11.get_has_result() != 1 or p11.get_result_kind() != 7:
        print(f"FAIL 11: has_result={p11.get_has_result()}, kind={p11.get_result_kind()}")
        failures += 1

    # Test 12: No match (lowercase, not a keyword)
    p12 = @@ContextParserFsm()
    inp12 = list(b"xyz")
    p12.setup(inp12, 0, len(inp12))
    p12.do_parse()
    if p12.get_has_result() != 0:
        print(f"FAIL 12: should not match, has_result={p12.get_has_result()}")
        failures += 1

    if failures > 0:
        print(f"FAIL: {failures} failures")
        exit(1)
    print("PASS: context_parser (12 cases)")

@@target gdscript
extends SceneTree

# ErlangSyntaxSkipper -- FSM for skipping Erlang comments and strings.
# Translated from framec's native_region_scanner/erlang_skipper.frs
#
# Handles: % line comments, "..." strings, '...' quoted atoms,
# Erlang-style line endings, balanced parens.

@@system ErlangSyntaxSkipperFsm {
    operations:
        setup(input_bytes: Array, start: int, length: int) {
            self.bytes = input_bytes
            self.pos = start
            self.scan_end = length
        }
        get_result_pos(): int {
            return self.result_pos
        }
        get_success(): int {
            return self.success
        }

    interface:
        do_skip_comment()
        do_skip_string()
        do_find_line_end()
        do_balanced_paren_end()

    machine:
        $Init {
            do_skip_comment() { -> $SkipComment }
            do_skip_string() { -> $SkipString }
            do_find_line_end() { -> $FindLineEnd }
            do_balanced_paren_end() { -> $BalancedParenEnd }
        }

        $SkipComment {
            $>() {
                var i = self.pos
                var scan_end = self.scan_end
                var bs = self.bytes

                # Erlang: % line comment only
                if i < scan_end and bs[i] == 0x25:
                    var j = i + 1
                    while j < scan_end and bs[j] != 0x0A:
                        j += 1
                    self.result_pos = j
                    self.success = 1
                    return

                self.success = 0
            }
        }

        $SkipString {
            $>() {
                var i = self.pos
                var scan_end = self.scan_end
                var bs = self.bytes

                # Simple string: "..."
                if i < scan_end and bs[i] == 0x22:
                    var j = i + 1
                    while j < scan_end:
                        if bs[j] == 0x5C:
                            j += 2
                            continue
                        if bs[j] == 0x22:
                            self.result_pos = j + 1
                            self.success = 1
                            return
                        j += 1
                    self.result_pos = scan_end
                    self.success = 1
                    return

                # Quoted atoms: '...'
                if i < scan_end and bs[i] == 0x27:
                    var j = i + 1
                    while j < scan_end:
                        if bs[j] == 0x5C:
                            j += 2
                            continue
                        if bs[j] == 0x27:
                            self.result_pos = j + 1
                            self.success = 1
                            return
                        j += 1
                    self.result_pos = scan_end
                    self.success = 1
                    return

                self.success = 0
            }
        }

        $FindLineEnd {
            $>() {
                var j = self.pos
                var scan_end = self.scan_end
                var bs = self.bytes
                var in_string = 0

                while j < scan_end:
                    var b = bs[j]
                    if b == 0x0A:
                        break

                    # Inside string
                    if in_string != 0:
                        if b == 0x5C:
                            j += 2
                            continue
                        if b == in_string:
                            in_string = 0
                        j += 1
                        continue

                    # Terminators
                    if b == 0x25:
                        break

                    # String starts
                    if b == 0x22 or b == 0x27:
                        in_string = b
                        j += 1
                        continue

                    j += 1

                self.result_pos = j
            }
        }

        $BalancedParenEnd {
            $>() {
                var i = self.pos
                var scan_end = self.scan_end
                var bs = self.bytes

                if i >= scan_end or bs[i] != 0x28:
                    self.success = 0
                    return

                var depth = 0
                var in_string = 0

                while i < scan_end:
                    var b = bs[i]

                    # Inside string
                    if in_string != 0:
                        if b == 0x5C:
                            i += 2
                            continue
                        if b == in_string:
                            in_string = 0
                        i += 1
                        continue

                    if b == 0x27 or b == 0x22:
                        in_string = b
                        i += 1
                    elif b == 0x28:
                        depth += 1
                        i += 1
                    elif b == 0x29:
                        depth -= 1
                        i += 1
                        if depth == 0:
                            self.result_pos = i
                            self.success = 1
                            return
                    else:
                        i += 1

                self.success = 0
            }
        }

    domain:
        bytes: Array = []
        pos: int = 0
        scan_end: int = 0
        result_pos: int = 0
        success: int = 1
}

func str_to_bytes(s: String) -> Array:
    var arr = []
    var buf = s.to_utf8_buffer()
    for i in range(buf.size()):
        arr.append(buf[i])
    return arr

func main():
    var failures = 0

    # Test 1: Skip % comment
    var s1 = @@ErlangSyntaxSkipperFsm()
    var inp1 = str_to_bytes("% comment\ncode")
    s1.setup(inp1, 0, inp1.size())
    s1.do_skip_comment()
    if s1.get_success() != 1 or s1.get_result_pos() != 9:
        print("FAIL 1: success=" + str(s1.get_success()) + ", pos=" + str(s1.get_result_pos()))
        failures += 1

    # Test 2: Not a comment
    var s2 = @@ErlangSyntaxSkipperFsm()
    var inp2 = str_to_bytes("x + 1")
    s2.setup(inp2, 0, inp2.size())
    s2.do_skip_comment()
    if s2.get_success() != 0:
        print("FAIL 2: should not be comment")
        failures += 1

    # Test 3: Skip double-quoted string
    var s3 = @@ErlangSyntaxSkipperFsm()
    var inp3 = str_to_bytes("\"hello\" rest")
    s3.setup(inp3, 0, inp3.size())
    s3.do_skip_string()
    if s3.get_success() != 1 or s3.get_result_pos() != 7:
        print("FAIL 3: success=" + str(s3.get_success()) + ", pos=" + str(s3.get_result_pos()))
        failures += 1

    # Test 4: Skip quoted atom
    var s4 = @@ErlangSyntaxSkipperFsm()
    var inp4 = str_to_bytes("'my_atom' rest")
    s4.setup(inp4, 0, inp4.size())
    s4.do_skip_string()
    if s4.get_success() != 1 or s4.get_result_pos() != 9:
        print("FAIL 4: success=" + str(s4.get_success()) + ", pos=" + str(s4.get_result_pos()))
        failures += 1

    # Test 5: Find line end (stops at %)
    var s5 = @@ErlangSyntaxSkipperFsm()
    var inp5 = str_to_bytes("X + 1 % comment")
    s5.setup(inp5, 0, inp5.size())
    s5.do_find_line_end()
    if s5.get_result_pos() != 6:
        print("FAIL 5: pos=" + str(s5.get_result_pos()) + ", expected 6")
        failures += 1

    # Test 6: Balanced parens
    var s6 = @@ErlangSyntaxSkipperFsm()
    var inp6 = str_to_bytes("(a, f(b)) rest")
    s6.setup(inp6, 0, inp6.size())
    s6.do_balanced_paren_end()
    if s6.get_success() != 1 or s6.get_result_pos() != 9:
        print("FAIL 6: success=" + str(s6.get_success()) + ", pos=" + str(s6.get_result_pos()))
        failures += 1

    # Test 7: String with escape
    var s7 = @@ErlangSyntaxSkipperFsm()
    var inp7 = str_to_bytes("\"he\\\"llo\" rest")
    s7.setup(inp7, 0, inp7.size())
    s7.do_skip_string()
    if s7.get_success() != 1 or s7.get_result_pos() != 9:
        print("FAIL 7: success=" + str(s7.get_success()) + ", pos=" + str(s7.get_result_pos()))
        failures += 1

    if failures > 0:
        print("FAIL: " + str(failures) + " failures")
        push_error(str(failures) + " test(s) failed")
    else:
        print("PASS: erlang_skipper (7 cases)")

func _init():
    main()
    quit()

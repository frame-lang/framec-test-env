@@target csharp

using System;
using System.Text;

// javascript_skipper -- FSM for skipping syntax constructs.

@@system JavaScriptSyntaxSkipperFsm {
    operations:
        setup(input_bytes: byte[], start: int, length: int) {
            this.bytes = input_bytes;
            this.pos = start;
            this.scan_end = length;
        }
        get_result_pos(): int {
            return this.result_pos;
        }
        get_success(): int {
            return this.success;
        }

    interface:
        do_skip_comment()
        do_skip_string()
        do_find_line_end()
        do_balanced_paren_end()

    machine:
        $Init {
            do_skip_comment() { -> $SkipComment }
            do_skip_string() { -> $SkipString }
            do_find_line_end() { -> $FindLineEnd }
            do_balanced_paren_end() { -> $BalancedParenEnd }
        }

        $SkipComment {
            $>() {
                int i = this.pos;
                int end = this.scan_end;
                byte[] bs = this.bytes;

                if (i + 1 < end && bs[i] == (byte)'/' && bs[i + 1] == (byte)'/') {
                    int j = i + 2;
                    while (j < end && bs[j] != (byte)'\n') { j++; }
                    this.result_pos = j;
                    this.success = 1;
                    return;
                }

                if (i + 1 < end && bs[i] == (byte)'/' && bs[i + 1] == (byte)'*') {
                    int j = i + 2;
                    while (j + 1 < end) {
                        if (bs[j] == (byte)'*' && bs[j + 1] == (byte)'/') {
                            this.result_pos = j + 2;
                            this.success = 1;
                            return;
                        }
                        j++;
                    }
                    this.result_pos = end;
                    this.success = 1;
                    return;
                }

                this.success = 0;
            }
        }

        $SkipString {
            $>() {
                int i = this.pos;
                int end = this.scan_end;
                byte[] bs = this.bytes;

                // Template literal: `...${expr}...`
                if (i < end && bs[i] == (byte)'`') {
                    int j = i + 1;
                    int brace_depth = 0;
                    while (j < end) {
                        if (bs[j] == (byte)'`' && brace_depth == 0) {
                            this.result_pos = j + 1;
                            this.success = 1;
                            return;
                        }
                        if (bs[j] == (byte)'\\') { j += 2; continue; }
                        if (bs[j] == (byte)'$' && j + 1 < end && bs[j + 1] == (byte)'{') {
                            brace_depth++; j += 2; continue;
                        }
                        if (bs[j] == (byte)'}' && brace_depth > 0) { brace_depth--; }
                        j++;
                    }
                    this.result_pos = end;
                    this.success = 1;
                    return;
                }

                if (i < end && (bs[i] == (byte)'"' || bs[i] == (byte)'\'')) {
                    int q = bs[i];
                    int j = i + 1;
                    while (j < end) {
                        if (bs[j] == (byte)'\\') { j += 2; continue; }
                        if (bs[j] == q) {
                            this.result_pos = j + 1;
                            this.success = 1;
                            return;
                        }
                        j++;
                    }
                    this.result_pos = end;
                    this.success = 1;
                    return;
                }

                this.success = 0;
            }
        }

        $FindLineEnd {
            $>() {
                int j = this.pos;
                int end = this.scan_end;
                byte[] bs = this.bytes;

                int in_string = 0;
                int in_template = 0;
                int template_brace_depth = 0;

                while (j < end) {
                    int b = bs[j];
                    if (b == (byte)'\n') { break; }

                    if (in_template != 0) {
                        if (b == (byte)'`' && template_brace_depth == 0) { in_template = 0; j++; continue; }
                        if (b == (byte)'\\') { j += 2; continue; }
                        if (b == (byte)'$' && j + 1 < end && bs[j + 1] == (byte)'{') { template_brace_depth++; j += 2; continue; }
                        if (b == (byte)'}' && template_brace_depth > 0) { template_brace_depth--; }
                        j++; continue;
                    }

                    if (in_string != 0) {
                        if (b == (byte)'\\') { j += 2; continue; }
                        if (b == in_string) { in_string = 0; }
                        j++; continue;
                    }

                    if (b == (byte)';' || b == (byte)'}') { break; }
                    if (b == (byte)'/' && j + 1 < end && (bs[j + 1] == (byte)'/' || bs[j + 1] == (byte)'*')) { break; }
                    if (b == (byte)'\'' || b == (byte)'"') { in_string = b; j++; continue; }
                    if (b == (byte)'`') { in_template = 1; j++; continue; }
                    j++;
                }

                this.result_pos = j;
            }
        }

        $BalancedParenEnd {
            $>() {
                int i = this.pos;
                int end = this.scan_end;
                byte[] bs = this.bytes;

                if (i >= end || bs[i] != (byte)'(') {
                    this.success = 0;
                    return;
                }

                int depth = 0;
                int in_string = 0;
                int in_template = 0;

                while (i < end) {
                    int b = bs[i];

                    if (in_template != 0) {
                        if (b == (byte)'`') { in_template = 0; }
                        if (b == (byte)'\\') { i += 2; continue; }
                        i++; continue;
                    }

                    if (in_string != 0) {
                        if (b == (byte)'\\') { i += 2; continue; }
                        if (b == in_string) { in_string = 0; }
                        i++; continue;
                    }

                    if (b == (byte)'\'' || b == (byte)'"') { in_string = b; i++; }
                    else if (b == (byte)'`') { in_template = 1; i++; }
                    else if (b == (byte)'(') { depth++; i++; }
                    else if (b == (byte)')') {
                        depth--;
                        i++;
                        if (depth == 0) {
                            this.result_pos = i;
                            this.success = 1;
                            return;
                        }
                    }
                    else { i++; }
                }

                this.success = 0;
            }
        }

    domain:
        bytes: byte[] = null
        pos: int = 0
        scan_end: int = 0
        result_pos: int = 0
        success: int = 1
}

class Program {
    static void Main(string[] args) {
        int failures = 0;

        var s1 = new JavaScriptSyntaxSkipperFsm();
        byte[] inp1 = Encoding.UTF8.GetBytes("// hello\ncode");
        s1.setup(inp1, 0, inp1.Length);
        s1.do_skip_comment();
        if (s1.get_success() != 1 || s1.get_result_pos() != 8) {
            Console.WriteLine("FAIL 1: Skip line comment");
            failures++;
        }

        var s2 = new JavaScriptSyntaxSkipperFsm();
        byte[] inp2 = Encoding.UTF8.GetBytes("/* block */code");
        s2.setup(inp2, 0, inp2.Length);
        s2.do_skip_comment();
        if (s2.get_success() != 1 || s2.get_result_pos() != 11) {
            Console.WriteLine("FAIL 2: Skip block comment");
            failures++;
        }

        var s3 = new JavaScriptSyntaxSkipperFsm();
        byte[] inp3 = Encoding.UTF8.GetBytes("\"hello world\" rest");
        s3.setup(inp3, 0, inp3.Length);
        s3.do_skip_string();
        if (s3.get_success() != 1 || s3.get_result_pos() != 13) {
            Console.WriteLine("FAIL 3: Skip double-quoted string");
            failures++;
        }

        var s4 = new JavaScriptSyntaxSkipperFsm();
        byte[] inp4 = Encoding.UTF8.GetBytes("`template ${x}` rest");
        s4.setup(inp4, 0, inp4.Length);
        s4.do_skip_string();
        if (s4.get_success() != 1 || s4.get_result_pos() != 15) {
            Console.WriteLine("FAIL 4: Skip template literal");
            failures++;
        }

        var s5 = new JavaScriptSyntaxSkipperFsm();
        byte[] inp5 = Encoding.UTF8.GetBytes("x + 1\nmore");
        s5.setup(inp5, 0, inp5.Length);
        s5.do_find_line_end();
        if (s5.get_result_pos() != 5) {
            Console.WriteLine("FAIL 5: Find line end");
            failures++;
        }

        var s6 = new JavaScriptSyntaxSkipperFsm();
        byte[] inp6 = Encoding.UTF8.GetBytes("x + 1");
        s6.setup(inp6, 0, inp6.Length);
        s6.do_skip_comment();
        if (s6.get_success() != 0) {
            Console.WriteLine("FAIL 6: Not a comment");
            failures++;
        }

        var s7 = new JavaScriptSyntaxSkipperFsm();
        byte[] inp7 = Encoding.UTF8.GetBytes("(a, `t`, c) rest");
        s7.setup(inp7, 0, inp7.Length);
        s7.do_balanced_paren_end();
        if (s7.get_success() != 1 || s7.get_result_pos() != 11) {
            Console.WriteLine("FAIL 7: Balanced parens with template");
            failures++;
        }

        var s8 = new JavaScriptSyntaxSkipperFsm();
        byte[] inp8 = Encoding.UTF8.GetBytes("x + 1 // comment");
        s8.setup(inp8, 0, inp8.Length);
        s8.do_find_line_end();
        if (s8.get_result_pos() != 6) {
            Console.WriteLine("FAIL 8: Find line end at //");
            failures++;
        }

        if (failures > 0) { Console.WriteLine("FAIL: " + failures + " failures"); Environment.Exit(1); }
        Console.WriteLine("PASS: javascript_skipper (8 cases)");
    }
}

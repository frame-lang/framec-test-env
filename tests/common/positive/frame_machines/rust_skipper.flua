@@target lua

-- RustSyntaxSkipper — FSM for skipping Rust comments and strings.
-- Translated from framec's native_region_scanner/rust_skipper.frs
--
-- Handles: // line comments, /* nested block comments */,
-- raw strings (r#"..."#), char literals vs lifetime annotations,
-- simple strings.
--
-- NOTE: Lua is 1-indexed, but the scanner uses 0-indexed positions
-- internally and adjusts when accessing the byte table.

@@system RustSyntaxSkipperFsm {
    operations:
        setup(input_bytes, start, length) {
            self.bytes = input_bytes
            self.pos = start
            self.scan_end = length
        }
        get_result_pos() {
            return self.result_pos
        }
        get_success() {
            return self.success
        }

    interface:
        do_skip_comment()
        do_skip_string()
        do_find_line_end()

    machine:
        $Init {
            do_skip_comment() { -> $SkipComment }
            do_skip_string() { -> $SkipString }
            do_find_line_end() { -> $FindLineEnd }
        }

        $SkipComment {
            $>() {
                i = self.pos
                scan_end = self.scan_end
                bs = self.bytes

                -- // line comment
                if i + 1 < scan_end and bs[i + 1] == 0x2F and bs[i + 2] == 0x2F then
                    j = i + 2
                    while j < scan_end and bs[j + 1] ~= 0x0A do
                        j = j + 1
                    end
                    self.result_pos = j
                    self.success = 1
                    return
                end

                -- /* nested block comment */ — Rust allows nesting
                if i + 1 < scan_end and bs[i + 1] == 0x2F and bs[i + 2] == 0x2A then
                    j = i + 2
                    depth = 1
                    while j + 1 < scan_end and depth > 0 do
                        if bs[j + 1] == 0x2F and bs[j + 2] == 0x2A then
                            depth = depth + 1
                            j = j + 2
                            goto continue_block
                        end
                        if bs[j + 1] == 0x2A and bs[j + 2] == 0x2F then
                            depth = depth - 1
                            j = j + 2
                            goto continue_block
                        end
                        j = j + 1
                        ::continue_block::
                    end
                    self.result_pos = j
                    self.success = 1
                    return
                end

                self.success = 0
            }
        }

        $SkipString {
            $>() {
                i = self.pos
                scan_end = self.scan_end
                bs = self.bytes

                -- Raw string: r#"..."# (count leading #s)
                if i < scan_end and bs[i + 1] == 0x72 then
                    j = i + 1
                    hash_count = 0
                    while j < scan_end and bs[j + 1] == 0x23 do
                        hash_count = hash_count + 1
                        j = j + 1
                    end
                    if j < scan_end and bs[j + 1] == 0x22 then
                        j = j + 1
                        -- Scan for closing "###
                        while j < scan_end do
                            if bs[j + 1] == 0x22 then
                                k = 0
                                while k < hash_count and j + 1 + k < scan_end and bs[j + 1 + k + 1] == 0x23 do
                                    k = k + 1
                                end
                                if k == hash_count then
                                    self.result_pos = j + 1 + hash_count
                                    self.success = 1
                                    return
                                end
                            end
                            j = j + 1
                        end
                        self.result_pos = scan_end
                        self.success = 1
                        return
                    end
                end

                -- Double-quoted string
                if i < scan_end and bs[i + 1] == 0x22 then
                    j = i + 1
                    while j < scan_end do
                        if bs[j + 1] == 0x5C then
                            j = j + 2
                            goto continue_dq
                        end
                        if bs[j + 1] == 0x22 then
                            self.result_pos = j + 1
                            self.success = 1
                            return
                        end
                        j = j + 1
                        ::continue_dq::
                    end
                    self.result_pos = scan_end
                    self.success = 1
                    return
                end

                -- Char literal: 'x' or '\n' (NOT lifetime 'a)
                if i < scan_end and bs[i + 1] == 0x27 then
                    if i + 2 < scan_end and bs[i + 2] == 0x5C and i + 3 < scan_end and bs[i + 4] == 0x27 then
                        self.result_pos = i + 4
                        self.success = 1
                        return
                    end
                    if i + 2 < scan_end and bs[i + 3] == 0x27 then
                        self.result_pos = i + 3
                        self.success = 1
                        return
                    end
                    self.success = 0
                    return
                end

                self.success = 0
            }
        }

        $FindLineEnd {
            $>() {
                j = self.pos
                scan_end = self.scan_end
                bs = self.bytes

                while j < scan_end do
                    b = bs[j + 1]
                    if b == 0x0A or b == 0x3B then
                        break
                    end
                    if b == 0x2F and j + 1 < scan_end and bs[j + 2] == 0x2F then
                        break
                    end
                    if b == 0x2F and j + 1 < scan_end and bs[j + 2] == 0x2A then
                        break
                    end
                    j = j + 1
                end

                self.result_pos = j
            }
        }

    domain:
        bytes = {}
        pos: int = 0
        scan_end: int = 0
        result_pos: int = 0
        success: int = 1
}

local function str_to_bytes(s)
    local t = {}
    for i = 1, #s do
        t[i] = string.byte(s, i)
    end
    return t
end

local failures = 0

-- Test 1: Skip // comment
local s1 = RustSyntaxSkipperFsm.new()
local inp1 = str_to_bytes("// comment\ncode")
s1:setup(inp1, 0, #inp1)
s1:do_skip_comment()
if s1:get_success() ~= 1 or s1:get_result_pos() ~= 10 then
    print("FAIL 1: success=" .. s1:get_success() .. ", pos=" .. s1:get_result_pos())
    failures = failures + 1
end

-- Test 2: Skip nested /* /* */ */ block comment
local s2 = RustSyntaxSkipperFsm.new()
local inp2 = str_to_bytes("/* outer /* inner */ */code")
s2:setup(inp2, 0, #inp2)
s2:do_skip_comment()
if s2:get_success() ~= 1 or s2:get_result_pos() ~= 23 then
    print("FAIL 2: success=" .. s2:get_success() .. ", pos=" .. s2:get_result_pos())
    failures = failures + 1
end

-- Test 3: Skip raw string r#"hello"#
local s3 = RustSyntaxSkipperFsm.new()
local inp3 = str_to_bytes('r#"hello"#rest')
s3:setup(inp3, 0, #inp3)
s3:do_skip_string()
if s3:get_success() ~= 1 or s3:get_result_pos() ~= 10 then
    print("FAIL 3: success=" .. s3:get_success() .. ", pos=" .. s3:get_result_pos())
    failures = failures + 1
end

-- Test 4: Skip double-quoted string
local s4 = RustSyntaxSkipperFsm.new()
local inp4 = str_to_bytes('"hello" rest')
s4:setup(inp4, 0, #inp4)
s4:do_skip_string()
if s4:get_success() ~= 1 or s4:get_result_pos() ~= 7 then
    print("FAIL 4: success=" .. s4:get_success() .. ", pos=" .. s4:get_result_pos())
    failures = failures + 1
end

-- Test 5: Char literal 'x' — IS a string
local s5 = RustSyntaxSkipperFsm.new()
local inp5 = str_to_bytes("'x' rest")
s5:setup(inp5, 0, #inp5)
s5:do_skip_string()
if s5:get_success() ~= 1 or s5:get_result_pos() ~= 3 then
    print("FAIL 5: success=" .. s5:get_success() .. ", pos=" .. s5:get_result_pos())
    failures = failures + 1
end

-- Test 6: Lifetime 'a — NOT a string
local s6 = RustSyntaxSkipperFsm.new()
local inp6 = str_to_bytes("'a rest")
s6:setup(inp6, 0, #inp6)
s6:do_skip_string()
if s6:get_success() ~= 0 then
    print("FAIL 6: lifetime should not be a string")
    failures = failures + 1
end

-- Test 7: Escape char '\n'
local s7 = RustSyntaxSkipperFsm.new()
local inp7 = str_to_bytes("'\\n' rest")
s7:setup(inp7, 0, #inp7)
s7:do_skip_string()
if s7:get_success() ~= 1 or s7:get_result_pos() ~= 4 then
    print("FAIL 7: success=" .. s7:get_success() .. ", pos=" .. s7:get_result_pos())
    failures = failures + 1
end

if failures > 0 then
    print("FAIL: " .. failures .. " failures")
    os.exit(1)
end
print("PASS: rust_skipper (7 cases)")

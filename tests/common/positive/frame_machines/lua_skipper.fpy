@@[target("python_3")]

# LuaSyntaxSkipper — FSM for skipping Lua comments and strings.
# Translated from framec's native_region_scanner/lua_skipper.frs
#
# Handles: -- line comments, --[[ block comments ]], [[ long strings ]],
# simple strings, Lua-style line endings.

@@system LuaSyntaxSkipperFsm {
    operations:
        setup(input_bytes: list, start: int, length: int) {
            self.bytes = input_bytes
            self.pos = start
            self.scan_end = length
        }
        get_result_pos(): int {
            return self.result_pos
        }
        get_success(): int {
            return self.success
        }

    interface:
        do_skip_comment()
        do_skip_string()
        do_find_line_end()

    machine:
        $Init {
            do_skip_comment() { -> $SkipComment }
            do_skip_string() { -> $SkipString }
            do_find_line_end() { -> $FindLineEnd }
        }

        $SkipComment {
            $>() {
                i = self.pos
                end = self.scan_end
                bs = self.bytes

                # Lua line comment: --
                if i + 1 < end and bs[i] == ord('-') and bs[i + 1] == ord('-'):
                    # Check for block comment: --[[ ... ]]
                    if i + 3 < end and bs[i + 2] == ord('[') and bs[i + 3] == ord('['):
                        j = i + 4
                        while j + 1 < end:
                            if bs[j] == ord(']') and bs[j + 1] == ord(']'):
                                self.result_pos = j + 2
                                self.success = 1
                                return
                            j += 1
                        self.result_pos = end
                        self.success = 1
                        return
                    # Line comment
                    j = i + 2
                    while j < end and bs[j] != ord('\n'):
                        j += 1
                    self.result_pos = j
                    self.success = 1
                    return

                self.success = 0
            }
        }

        $SkipString {
            $>() {
                i = self.pos
                end = self.scan_end
                bs = self.bytes

                # Long string: [[ ... ]]
                if i + 1 < end and bs[i] == ord('[') and bs[i + 1] == ord('['):
                    j = i + 2
                    while j + 1 < end:
                        if bs[j] == ord(']') and bs[j + 1] == ord(']'):
                            self.result_pos = j + 2
                            self.success = 1
                            return
                        j += 1
                    self.result_pos = end
                    self.success = 1
                    return

                # Simple string: " or '
                if i < end and (bs[i] == ord('"') or bs[i] == ord("'")):
                    q = bs[i]
                    j = i + 1
                    while j < end:
                        if bs[j] == ord('\\'):
                            j += 2
                            continue
                        if bs[j] == q:
                            self.result_pos = j + 1
                            self.success = 1
                            return
                        j += 1
                    self.result_pos = end
                    self.success = 1
                    return

                self.success = 0
            }
        }

        $FindLineEnd {
            $>() {
                j = self.pos
                end = self.scan_end
                bs = self.bytes

                while j < end:
                    b = bs[j]
                    if b == ord('\n'):
                        break
                    # Stop at -- comment
                    if b == ord('-') and j + 1 < end and bs[j + 1] == ord('-'):
                        break
                    j += 1

                self.result_pos = j
            }
        }

    domain:
        bytes: list = []
        pos: int = 0
        scan_end: int = 0
        result_pos: int = 0
        success: int = 1
}

if __name__ == '__main__':
    failures = 0

    # Test 1: Skip -- line comment
    s1 = @@LuaSyntaxSkipperFsm()
    inp1 = list(b"-- comment\ncode")
    s1.setup(inp1, 0, len(inp1))
    s1.do_skip_comment()
    if s1.get_success() != 1 or s1.get_result_pos() != 10:
        print(f"FAIL 1: success={s1.get_success()}, pos={s1.get_result_pos()}")
        failures += 1

    # Test 2: Skip --[[ block comment ]]
    s2 = @@LuaSyntaxSkipperFsm()
    inp2 = list(b"--[[ block ]]code")
    s2.setup(inp2, 0, len(inp2))
    s2.do_skip_comment()
    if s2.get_success() != 1 or s2.get_result_pos() != 13:
        print(f"FAIL 2: success={s2.get_success()}, pos={s2.get_result_pos()}")
        failures += 1

    # Test 3: Not a comment
    s3 = @@LuaSyntaxSkipperFsm()
    inp3 = list(b"x + 1")
    s3.setup(inp3, 0, len(inp3))
    s3.do_skip_comment()
    if s3.get_success() != 0:
        print(f"FAIL 3: should not be comment")
        failures += 1

    # Test 4: Skip [[ long string ]]
    s4 = @@LuaSyntaxSkipperFsm()
    inp4 = list(b"[[hello world]]rest")
    s4.setup(inp4, 0, len(inp4))
    s4.do_skip_string()
    if s4.get_success() != 1 or s4.get_result_pos() != 15:
        print(f"FAIL 4: success={s4.get_success()}, pos={s4.get_result_pos()}")
        failures += 1

    # Test 5: Skip simple string
    s5 = @@LuaSyntaxSkipperFsm()
    inp5 = list(b'"hello" rest')
    s5.setup(inp5, 0, len(inp5))
    s5.do_skip_string()
    if s5.get_success() != 1 or s5.get_result_pos() != 7:
        print(f"FAIL 5: success={s5.get_success()}, pos={s5.get_result_pos()}")
        failures += 1

    # Test 6: Find line end stops at --
    s6 = @@LuaSyntaxSkipperFsm()
    inp6 = list(b"x + 1 -- comment")
    s6.setup(inp6, 0, len(inp6))
    s6.do_find_line_end()
    if s6.get_result_pos() != 6:
        print(f"FAIL 6: pos={s6.get_result_pos()}, expected 6")
        failures += 1

    if failures > 0:
        print(f"FAIL: {failures} failures")
        exit(1)
    print("PASS: lua_skipper (6 cases)")

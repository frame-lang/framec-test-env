@@target kotlin

import kotlin.system.exitProcess

// PythonSyntaxSkipper — FSM for skipping Python comments and strings.
// Translated from framec's native_region_scanner/python_skipper.frs
//
// Handles: # comments, triple-quoted strings, simple strings,
// Python-style line endings, balanced parens.

@@system PythonSyntaxSkipperFsm {
    operations:
        setup(input_bytes: ByteArray, start: Int, length: Int) {
            this.bytes = input_bytes
            this.pos = start
            this.scan_end = length
        }
        get_result_pos(): Int {
            return this.result_pos
        }
        get_success(): Int {
            return this.success
        }

    interface:
        do_skip_comment()
        do_skip_string()
        do_find_line_end()
        do_balanced_paren_end()

    machine:
        $Init {
            do_skip_comment() { -> $SkipComment }
            do_skip_string() { -> $SkipString }
            do_find_line_end() { -> $FindLineEnd }
            do_balanced_paren_end() { -> $BalancedParenEnd }
        }

        $SkipComment {
            $>() {
                var i = this.pos
                val end = this.scan_end
                val bs = this.bytes

                // Python uses # for line comments
                if (i < end && (bs[i].toInt() and 0xFF) == '#'.code) {
                    var j = i + 1
                    while (j < end && (bs[j].toInt() and 0xFF) != '\n'.code) {
                        j++
                    }
                    this.result_pos = j
                    this.success = 1
                    return
                }

                this.success = 0
            }
        }

        $SkipString {
            $>() {
                var i = this.pos
                val end = this.scan_end
                val bs = this.bytes

                // Triple-quoted strings: """ or '''
                if (i + 2 < end) {
                    val c0 = bs[i].toInt() and 0xFF
                    val c1 = bs[i+1].toInt() and 0xFF
                    val c2 = bs[i+2].toInt() and 0xFF
                    if ((c0 == '"'.code && c1 == '"'.code && c2 == '"'.code) ||
                        (c0 == '\''.code && c1 == '\''.code && c2 == '\''.code)) {
                        val q = c0
                        var j = i + 3
                        while (j + 2 < end) {
                            if ((bs[j].toInt() and 0xFF) == q && (bs[j+1].toInt() and 0xFF) == q && (bs[j+2].toInt() and 0xFF) == q) {
                                this.result_pos = j + 3
                                this.success = 1
                                return
                            }
                            j++
                        }
                        this.result_pos = end
                        this.success = 1
                        return
                    }
                }

                // Simple strings: " or '
                if (i < end && ((bs[i].toInt() and 0xFF) == '"'.code || (bs[i].toInt() and 0xFF) == '\''.code)) {
                    val q = bs[i].toInt() and 0xFF
                    var j = i + 1
                    while (j < end) {
                        if ((bs[j].toInt() and 0xFF) == '\\'.code) {
                            j += 2
                            continue
                        }
                        if ((bs[j].toInt() and 0xFF) == q) {
                            this.result_pos = j + 1
                            this.success = 1
                            return
                        }
                        j++
                    }
                    this.result_pos = end
                    this.success = 1
                    return
                }

                this.success = 0
            }
        }

        $FindLineEnd {
            $>() {
                var j = this.pos
                val end = this.scan_end
                val bs = this.bytes

                while (j < end) {
                    val b = bs[j].toInt() and 0xFF
                    if (b == '\n'.code || b == ';'.code) {
                        break
                    }
                    // Stop at # comment
                    if (b == '#'.code) {
                        break
                    }
                    j++
                }

                this.result_pos = j
            }
        }

        $BalancedParenEnd {
            $>() {
                var i = this.pos
                val end = this.scan_end
                val bs = this.bytes

                if (i >= end || (bs[i].toInt() and 0xFF) != '('.code) {
                    this.success = 0
                    return
                }

                var depth = 1
                var j = i + 1
                while (j < end && depth > 0) {
                    val b = bs[j].toInt() and 0xFF
                    if (b == '('.code) {
                        depth++
                    } else if (b == ')'.code) {
                        depth--
                    } else if (b == '"'.code || b == '\''.code) {
                        val q = b
                        j++
                        while (j < end && (bs[j].toInt() and 0xFF) != q) {
                            if ((bs[j].toInt() and 0xFF) == '\\'.code) {
                                j++
                            }
                            j++
                        }
                    }
                    j++
                }

                if (depth == 0) {
                    this.result_pos = j
                    this.success = 1
                } else {
                    this.result_pos = end
                    this.success = 0
                }
            }
        }

    domain:
        bytes: ByteArray = ByteArray(0)
        pos: Int = 0
        scan_end: Int = 0
        result_pos: Int = 0
        success: Int = 1
}

fun main() {
    var failures = 0

    // Test 1: Skip hash comment
    val s1 = @@PythonSyntaxSkipperFsm()
    val inp1 = "# comment\ncode".toByteArray()
    s1.setup(inp1, 0, inp1.size)
    s1.do_skip_comment()
    if (s1.get_success() != 1 || s1.get_result_pos() != 9) {
        println("FAIL 1: success=${s1.get_success()}, pos=${s1.get_result_pos()}")
        failures++
    }

    // Test 2: Not a comment
    val s2 = @@PythonSyntaxSkipperFsm()
    val inp2 = "x + 1".toByteArray()
    s2.setup(inp2, 0, inp2.size)
    s2.do_skip_comment()
    if (s2.get_success() != 0) {
        println("FAIL 2: should not be comment")
        failures++
    }

    // Test 3: Skip triple-quoted string
    val s3 = @@PythonSyntaxSkipperFsm()
    val inp3 = "\"\"\"hello world\"\"\"rest".toByteArray()
    s3.setup(inp3, 0, inp3.size)
    s3.do_skip_string()
    if (s3.get_success() != 1 || s3.get_result_pos() != 17) {
        println("FAIL 3: success=${s3.get_success()}, pos=${s3.get_result_pos()}")
        failures++
    }

    // Test 4: Skip simple string
    val s4 = @@PythonSyntaxSkipperFsm()
    val inp4 = "\"hello\" rest".toByteArray()
    s4.setup(inp4, 0, inp4.size)
    s4.do_skip_string()
    if (s4.get_success() != 1 || s4.get_result_pos() != 7) {
        println("FAIL 4: success=${s4.get_success()}, pos=${s4.get_result_pos()}")
        failures++
    }

    // Test 5: Skip string with escape
    val s5 = @@PythonSyntaxSkipperFsm()
    val inp5 = "'he\\'llo' rest".toByteArray()
    s5.setup(inp5, 0, inp5.size)
    s5.do_skip_string()
    if (s5.get_success() != 1 || s5.get_result_pos() != 9) {
        println("FAIL 5: success=${s5.get_success()}, pos=${s5.get_result_pos()}")
        failures++
    }

    // Test 6: Find line end (stops at #)
    val s6 = @@PythonSyntaxSkipperFsm()
    val inp6 = "x + 1 # comment".toByteArray()
    s6.setup(inp6, 0, inp6.size)
    s6.do_find_line_end()
    if (s6.get_result_pos() != 6) {
        println("FAIL 6: pos=${s6.get_result_pos()}, expected 6")
        failures++
    }

    // Test 7: Balanced parens
    val s7 = @@PythonSyntaxSkipperFsm()
    val inp7 = "(a, f(b)) rest".toByteArray()
    s7.setup(inp7, 0, inp7.size)
    s7.do_balanced_paren_end()
    if (s7.get_success() != 1 || s7.get_result_pos() != 9) {
        println("FAIL 7: success=${s7.get_success()}, pos=${s7.get_result_pos()}")
        failures++
    }

    if (failures > 0) {
        println("FAIL: $failures failures")
        exitProcess(1)
    }
    println("PASS: python_skipper (7 cases)")
}

@@[target("go")]

package main

import "fmt"
import "os"

// ExprScanner — PDA for scanning assignment RHS expressions.
// Translated from framec's native_region_scanner/expr_scanner.frs
//
// Scans from pos (after =) to a terminator (; or \n) at depth 0,
// respecting nested ()[]{}  and string literals with escape handling.

@@system ExprScannerFsm {
    operations:
        Setup(input_bytes: []byte, start: int, length: int) {
            s.bytes = input_bytes
            s.pos = start
            s.end = length
        }
        GetResult(): int {
            return s.result_end
        }

    interface:
        DoScan()

    machine:
        $Init {
            DoScan() { -> $Scanning }
        }

        $Scanning {
            $>() {
                i := s.pos
                end := s.end
                bs := s.bytes
                depth := 0
                inString := byte(0)

                for i < end {
                    b := bs[i]

                    if inString != 0 {
                        if b == '\\' && i+1 < end {
                            i += 2
                            continue
                        }
                        if b == inString {
                            inString = 0
                        }
                        i++
                        continue
                    }

                    if b == '"' || b == '\'' {
                        inString = b
                        i++
                        continue
                    }

                    if b == '(' || b == '[' || b == '{' {
                        depth++
                    } else if b == ')' || b == ']' || b == '}' {
                        depth--
                        if depth < 0 {
                            depth = 0
                        }
                    } else if b == ';' && depth == 0 {
                        i++
                        break
                    } else if b == '\n' && depth == 0 {
                        break
                    }

                    i++
                }

                s.result_end = i
            }
        }

    domain:
        bytes: []byte = nil
        pos: int = 0
        end: int = 0
        result_end: int = 0
}

func main() {
	failures := 0

	// Test 1: simple expression terminated by newline
	e1 := @@ExprScannerFsm()
	inp1 := []byte(" x + 1\nfoo")
	e1.Setup(inp1, 0, len(inp1))
	e1.DoScan()
	r1 := e1.GetResult()
	expr1 := string(inp1[0:r1])
	if expr1 != " x + 1" {
		fmt.Printf("FAIL 1: got '%s'\n", expr1)
		failures++
	}

	// Test 2: expression with semicolon terminator
	e2 := @@ExprScannerFsm()
	inp2 := []byte(" x + 1; y = 2")
	e2.Setup(inp2, 0, len(inp2))
	e2.DoScan()
	r2 := e2.GetResult()
	expr2 := string(inp2[0:r2])
	if expr2 != " x + 1;" {
		fmt.Printf("FAIL 2: got '%s'\n", expr2)
		failures++
	}

	// Test 3: nested parens not treated as terminator
	e3 := @@ExprScannerFsm()
	inp3 := []byte(" f(x, g(y))\nz")
	e3.Setup(inp3, 0, len(inp3))
	e3.DoScan()
	r3 := e3.GetResult()
	expr3 := string(inp3[0:r3])
	if expr3 != " f(x, g(y))" {
		fmt.Printf("FAIL 3: got '%s'\n", expr3)
		failures++
	}

	// Test 4: string with escaped quote
	e4 := @@ExprScannerFsm()
	inp4 := []byte(" \"hello\\\"world\"\n")
	e4.Setup(inp4, 0, len(inp4))
	e4.DoScan()
	r4 := e4.GetResult()
	expr4 := string(inp4[0:r4])
	if expr4 != " \"hello\\\"world\"" {
		fmt.Printf("FAIL 4: got '%s'\n", expr4)
		failures++
	}

	// Test 5: semicolon inside string (should not terminate)
	e5 := @@ExprScannerFsm()
	inp5 := []byte(" \"a;b\"\n")
	e5.Setup(inp5, 0, len(inp5))
	e5.DoScan()
	r5 := e5.GetResult()
	expr5 := string(inp5[0:r5])
	if expr5 != " \"a;b\"" {
		fmt.Printf("FAIL 5: got '%s'\n", expr5)
		failures++
	}

	if failures > 0 {
		fmt.Printf("FAIL: %d failures\n", failures)
		os.Exit(1)
	}
	fmt.Println("PASS: expr_scanner (5 cases)")
}

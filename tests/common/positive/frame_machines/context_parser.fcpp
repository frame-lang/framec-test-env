@@[target("cpp_17")]

#include <iostream>
#include <string>
#include <vector>
#include <cstdint>
#include <algorithm>

// ContextParser -- FSM for parsing @@ context constructs.
// Translated from framec's native_region_scanner/context_parser.frs
//
// Parses:
//   @@:return [= expr]     kind=2 (ContextReturn)
//   @@:event               kind=3 (ContextEvent)
//   @@:data.key [= expr]   kind=4 (ContextData) or kind=5 (ContextDataAssign)
//   @@:params.key           kind=6 (ContextParams)
//   @@SystemName()          kind=7 (TaggedInstantiation)
//   @@:(expr)               kind=8 (ContextReturnExpr)
//   @@:return(expr)         kind=9 (ReturnCall)
//   @@:self.method()        kind=10 (ContextSelfCall)
//   @@:self                 kind=11 (ContextSelf)
//   @@:system.state         kind=12 (ContextSystemState)
//   other                   has_result=0

@@system ContextParserFsm {
    operations:
        setup(input_bytes: std::vector<uint8_t>, start: int, length: int) {
            this->bytes = input_bytes;
            this->pos = start;
            this->scan_end = length;
        }
        setup_with_paren_end(input_bytes: std::vector<uint8_t>, start: int, length: int, p_end: int) {
            this->bytes = input_bytes;
            this->pos = start;
            this->scan_end = length;
            this->paren_end = p_end;
        }
        get_result_end(): int {
            return this->result_end;
        }
        get_result_kind(): int {
            return this->result_kind;
        }
        get_has_result(): int {
            return this->has_result;
        }

    interface:
        do_parse()

    machine:
        $Init {
            do_parse() { -> $Dispatching }
        }

        $Dispatching {
            $>() {
                int i = this->pos;
                int end = this->scan_end;
                const std::vector<uint8_t>& bs = this->bytes;

                if (i >= end) {
                    this->has_result = 0;
                    -> $Done
                }

                int b = bs[i];

                if (b == ':') {
                    this->pos = i + 1;
                    -> $DispatchColon
                } else if (b >= 'A' && b <= 'Z') {
                    // @@SystemName -- pos stays at start of name
                    -> $ParseInstantiation
                } else {
                    this->result_end = i;
                    this->has_result = 0;
                    -> $Done
                }
            }
        }

        $DispatchColon {
            $>() {
                int i = this->pos;
                int end = this->scan_end;
                const std::vector<uint8_t>& bs = this->bytes;

                // Check for @@:return
                if (i + 5 < end) {
                    std::string tag(bs.begin() + i, bs.begin() + i + 6);
                    if (tag == "return") {
                        this->pos = i + 6;
                        -> $ParseReturn
                    }
                }

                // Check for @@:event
                if (i + 4 < end) {
                    std::string tag(bs.begin() + i, bs.begin() + i + 5);
                    if (tag == "event") {
                        this->result_end = i + 5;
                        this->result_kind = 3;
                        this->has_result = 1;
                        -> $Done
                    }
                }

                // Check for @@:data
                if (i + 3 < end) {
                    std::string tag(bs.begin() + i, bs.begin() + i + 4);
                    if (tag == "data") {
                        this->pos = i + 4;
                        -> $ParseData
                    }
                }

                // Check for @@:params
                if (i + 5 < end) {
                    std::string tag(bs.begin() + i, bs.begin() + i + 6);
                    if (tag == "params") {
                        this->pos = i + 6;
                        -> $ParseParams
                    }
                }

                // Check for @@:self
                if (i + 3 < end) {
                    std::string tag(bs.begin() + i, bs.begin() + i + 4);
                    if (tag == "self") {
                        this->pos = i + 4;
                        -> $ParseSelf
                    }
                }

                // Check for @@:system
                if (i + 5 < end) {
                    std::string tag(bs.begin() + i, bs.begin() + i + 6);
                    if (tag == "system") {
                        this->pos = i + 6;
                        -> $ParseSystem
                    }
                }

                // Check for @@:(expr)
                if (i < end && bs[i] == '(') {
                    this->pos = i;
                    -> $ParseContextReturnExpr
                }

                // Unknown
                this->result_end = i;
                this->has_result = 0;
                -> $Done
            }
        }

        $ParseReturn {
            $>() {
                int i = this->pos;
                int end = this->scan_end;
                const std::vector<uint8_t>& bs = this->bytes;

                // Skip whitespace
                while (i < end && (bs[i] == ' ' || bs[i] == '\t')) {
                    i++;
                }

                if (i < end && bs[i] == '(') {
                    // @@:return(expr) -- scan balanced parens
                    int depth = 1;
                    i++;
                    while (i < end && depth > 0) {
                        if (bs[i] == '(') {
                            depth++;
                        }
                        if (bs[i] == ')') {
                            depth--;
                        }
                        if (depth > 0) {
                            i++;
                        }
                    }
                    if (depth == 0) {
                        i++;
                    }
                    this->result_end = i;
                    this->result_kind = 9;
                    this->has_result = 1;
                    -> $Done
                } else if (i < end && bs[i] == '=' && (i + 1 >= end || bs[i + 1] != '=')) {
                    // @@:return = <expr> -- scan expression
                    i++;
                    // Skip whitespace after =
                    while (i < end && (bs[i] == ' ' || bs[i] == '\t')) {
                        i++;
                    }
                    // Scan to end of expression (newline or ;)
                    while (i < end && bs[i] != '\n' && bs[i] != ';') {
                        i++;
                    }
                    this->result_end = i;
                    this->result_kind = 2;
                    this->has_result = 1;
                    -> $Done
                } else {
                    // @@:return (bare read)
                    this->result_end = i;
                    this->result_kind = 2;
                    this->has_result = 1;
                    -> $Done
                }
            }
        }

        $ParseContextReturnExpr {
            $>() {
                int i = this->pos;
                int end = this->scan_end;
                const std::vector<uint8_t>& bs = this->bytes;

                if (i < end && bs[i] == '(') {
                    int depth = 1;
                    i++;
                    while (i < end && depth > 0) {
                        int b = bs[i];
                        if (b == '(') {
                            depth++;
                        } else if (b == ')') {
                            depth--;
                        } else if (b == '"' || b == '\'') {
                            int q = b;
                            i++;
                            while (i < end) {
                                if (bs[i] == '\\' && i + 1 < end) {
                                    i += 2;
                                    continue;
                                }
                                if (bs[i] == q) {
                                    break;
                                }
                                i++;
                            }
                        }
                        i++;
                    }
                }

                this->result_end = i;
                this->result_kind = 8;
                this->has_result = 1;
                -> $Done
            }
        }

        $ParseData {
            $>() {
                int i = this->pos;
                int end = this->scan_end;
                const std::vector<uint8_t>& bs = this->bytes;

                // Scan .key
                if (i < end && bs[i] == '.') {
                    i++;
                    while (i < end && (std::isalnum(bs[i]) || bs[i] == '_')) {
                        i++;
                    }
                }

                // Check for assignment
                int j = i;
                while (j < end && (bs[j] == ' ' || bs[j] == '\t')) {
                    j++;
                }

                if (j < end && bs[j] == '=' && (j + 1 >= end || bs[j + 1] != '=')) {
                    // @@:data.key = expr
                    j++;
                    while (j < end && (bs[j] == ' ' || bs[j] == '\t')) {
                        j++;
                    }
                    while (j < end && bs[j] != '\n' && bs[j] != ';') {
                        j++;
                    }
                    this->result_end = j;
                    this->result_kind = 5;
                } else {
                    this->result_end = i;
                    this->result_kind = 4;
                }

                this->has_result = 1;
                -> $Done
            }
        }

        $ParseParams {
            $>() {
                int i = this->pos;
                int end = this->scan_end;
                const std::vector<uint8_t>& bs = this->bytes;

                if (i < end && bs[i] == '.') {
                    i++;
                    while (i < end && (std::isalnum(bs[i]) || bs[i] == '_')) {
                        i++;
                    }
                }

                this->result_end = i;
                this->result_kind = 6;
                this->has_result = 1;
                -> $Done
            }
        }

        $ParseSelf {
            $>() {
                int i = this->pos;
                int end = this->scan_end;
                const std::vector<uint8_t>& bs = this->bytes;

                if (i < end && bs[i] == '.') {
                    i++;
                    // Scan identifier
                    while (i < end && (std::isalnum(bs[i]) || bs[i] == '_')) {
                        i++;
                    }
                    if (i < end && bs[i] == '(') {
                        // @@:self.method(args) -- scan balanced parens
                        int depth = 1;
                        i++;
                        while (i < end && depth > 0) {
                            if (bs[i] == '(') {
                                depth++;
                            }
                            if (bs[i] == ')') {
                                depth--;
                            }
                            if (bs[i] == '"' || bs[i] == '\'') {
                                int q = bs[i];
                                i++;
                                while (i < end) {
                                    if (bs[i] == '\\' && i + 1 < end) {
                                        i += 2;
                                        continue;
                                    }
                                    if (bs[i] == q) {
                                        break;
                                    }
                                    i++;
                                }
                            }
                            if (depth > 0) {
                                i++;
                            }
                        }
                        if (depth == 0) {
                            i++;
                        }
                        this->result_end = i;
                        this->result_kind = 10;
                        this->has_result = 1;
                    } else {
                        // @@:self.property
                        this->result_end = i;
                        this->result_kind = 11;
                        this->has_result = 1;
                    }
                } else {
                    // bare @@:self
                    this->result_end = i;
                    this->result_kind = 11;
                    this->has_result = 1;
                }

                -> $Done
            }
        }

        $ParseSystem {
            $>() {
                int i = this->pos;
                int end = this->scan_end;
                const std::vector<uint8_t>& bs = this->bytes;

                if (i + 5 < end) {
                    std::string tag(bs.begin() + i, bs.begin() + i + 6);
                    if (tag == ".state") {
                        int after = i + 6;
                        if (after >= end || (!std::isalnum(bs[after]) && bs[after] != '_')) {
                            this->result_end = i + 6;
                            this->result_kind = 12;
                            this->has_result = 1;
                            -> $Done
                        }
                    }
                }

                // Bare @@:system or unknown variant
                this->result_end = i;
                this->result_kind = 13;
                this->has_result = 1;
                -> $Done
            }
        }

        $ParseInstantiation {
            $>() {
                int i = this->pos;
                int end = this->scan_end;
                const std::vector<uint8_t>& bs = this->bytes;

                // Scan identifier
                while (i < end && (std::isalnum(bs[i]) || bs[i] == '_')) {
                    i++;
                }

                // Must be followed by (
                if (i < end && bs[i] == '(') {
                    if (this->paren_end > 0) {
                        i = this->paren_end;
                        this->result_end = i;
                        this->result_kind = 7;
                        this->has_result = 1;
                    } else {
                        this->result_end = i;
                        this->has_result = 0;
                    }
                } else {
                    this->result_end = i;
                    this->has_result = 0;
                }

                -> $Done
            }
        }

        $Done {
            $>() {
                // Terminal state -- results are in domain vars
            }
        }

    domain:
        bytes: std::vector<uint8_t> = {}
        pos: int = 0
        scan_end: int = 0
        result_end: int = 0
        result_kind: int = 0
        has_result: int = 0
        paren_end: int = 0
}

int main() {
    int failures = 0;

    auto to_bytes = [](const std::string& s) -> std::vector<uint8_t> {
        return std::vector<uint8_t>(s.begin(), s.end());
    };

    // Test 1: @@:return (bare read)
    auto p1 = ContextParserFsm();
    auto inp1 = to_bytes(":return");
    p1.setup(inp1, 0, inp1.size());
    p1.do_parse();
    if (p1.get_has_result() != 1 || p1.get_result_kind() != 2) {
        printf("FAIL 1: has_result=%d, kind=%d\n", p1.get_has_result(), p1.get_result_kind());
        failures++;
    }

    // Test 2: @@:event
    auto p2 = ContextParserFsm();
    auto inp2 = to_bytes(":event");
    p2.setup(inp2, 0, inp2.size());
    p2.do_parse();
    if (p2.get_has_result() != 1 || p2.get_result_kind() != 3) {
        printf("FAIL 2: has_result=%d, kind=%d\n", p2.get_has_result(), p2.get_result_kind());
        failures++;
    }

    // Test 3: @@:data.key
    auto p3 = ContextParserFsm();
    auto inp3 = to_bytes(":data.name rest");
    p3.setup(inp3, 0, inp3.size());
    p3.do_parse();
    if (p3.get_has_result() != 1 || p3.get_result_kind() != 4) {
        printf("FAIL 3: has_result=%d, kind=%d\n", p3.get_has_result(), p3.get_result_kind());
        failures++;
    }

    // Test 4: @@:data.key = expr
    auto p4 = ContextParserFsm();
    auto inp4 = to_bytes(":data.key = value\n");
    p4.setup(inp4, 0, inp4.size());
    p4.do_parse();
    if (p4.get_has_result() != 1 || p4.get_result_kind() != 5) {
        printf("FAIL 4: has_result=%d, kind=%d\n", p4.get_has_result(), p4.get_result_kind());
        failures++;
    }

    // Test 5: @@:params.key
    auto p5 = ContextParserFsm();
    auto inp5 = to_bytes(":params.name rest");
    p5.setup(inp5, 0, inp5.size());
    p5.do_parse();
    if (p5.get_has_result() != 1 || p5.get_result_kind() != 6) {
        printf("FAIL 5: has_result=%d, kind=%d\n", p5.get_has_result(), p5.get_result_kind());
        failures++;
    }

    // Test 6: @@:(expr)
    auto p6 = ContextParserFsm();
    auto inp6 = to_bytes(":(x + 1) rest");
    p6.setup(inp6, 0, inp6.size());
    p6.do_parse();
    if (p6.get_has_result() != 1 || p6.get_result_kind() != 8) {
        printf("FAIL 6: has_result=%d, kind=%d\n", p6.get_has_result(), p6.get_result_kind());
        failures++;
    }

    // Test 7: @@:return(expr)
    auto p7 = ContextParserFsm();
    auto inp7 = to_bytes(":return(42) rest");
    p7.setup(inp7, 0, inp7.size());
    p7.do_parse();
    if (p7.get_has_result() != 1 || p7.get_result_kind() != 9) {
        printf("FAIL 7: has_result=%d, kind=%d\n", p7.get_has_result(), p7.get_result_kind());
        failures++;
    }

    // Test 8: @@:self (bare)
    auto p8 = ContextParserFsm();
    auto inp8 = to_bytes(":self rest");
    p8.setup(inp8, 0, inp8.size());
    p8.do_parse();
    if (p8.get_has_result() != 1 || p8.get_result_kind() != 11) {
        printf("FAIL 8: has_result=%d, kind=%d\n", p8.get_has_result(), p8.get_result_kind());
        failures++;
    }

    // Test 9: @@:self.method(args)
    auto p9 = ContextParserFsm();
    auto inp9 = to_bytes(":self.doWork(x) rest");
    p9.setup(inp9, 0, inp9.size());
    p9.do_parse();
    if (p9.get_has_result() != 1 || p9.get_result_kind() != 10) {
        printf("FAIL 9: has_result=%d, kind=%d\n", p9.get_has_result(), p9.get_result_kind());
        failures++;
    }

    // Test 10: @@:system.state
    auto p10 = ContextParserFsm();
    auto inp10 = to_bytes(":system.state rest");
    p10.setup(inp10, 0, inp10.size());
    p10.do_parse();
    if (p10.get_has_result() != 1 || p10.get_result_kind() != 12) {
        printf("FAIL 10: has_result=%d, kind=%d\n", p10.get_has_result(), p10.get_result_kind());
        failures++;
    }

    // Test 11: @@SystemName() with paren_end
    auto p11 = ContextParserFsm();
    auto inp11 = to_bytes("MySystem() rest");
    p11.setup_with_paren_end(inp11, 0, inp11.size(), 10);
    p11.do_parse();
    if (p11.get_has_result() != 1 || p11.get_result_kind() != 7) {
        printf("FAIL 11: has_result=%d, kind=%d\n", p11.get_has_result(), p11.get_result_kind());
        failures++;
    }

    // Test 12: No match (lowercase, not a keyword)
    auto p12 = ContextParserFsm();
    auto inp12 = to_bytes("xyz");
    p12.setup(inp12, 0, inp12.size());
    p12.do_parse();
    if (p12.get_has_result() != 0) {
        printf("FAIL 12: should not match, has_result=%d\n", p12.get_has_result());
        failures++;
    }

    if (failures > 0) {
        printf("FAIL: %d failures\n", failures);
        return 1;
    }
    printf("PASS: context_parser (12 cases)\n");
    return 0;
}

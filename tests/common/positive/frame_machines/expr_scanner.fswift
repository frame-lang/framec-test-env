@@[target("swift")]

import Foundation

// ExprScanner — PDA for scanning assignment RHS expressions.
// Translated from framec's native_region_scanner/expr_scanner.frs
//
// Scans from pos (after =) to a terminator (; or \n) at depth 0,
// respecting nested ()[]{}  and string literals with escape handling.

@@system ExprScannerFsm {
    operations:
        setup(input_bytes: [UInt8], start: Int, length: Int) {
            self.bytes = input_bytes
            self.pos = start
            self.end = length
        }
        get_result(): Int {
            return self.result_end
        }

    interface:
        do_scan()

    machine:
        $Init {
            do_scan() { -> $Scanning }
        }

        $Scanning {
            $>() {
                var i = self.pos
                let end = self.end
                let bs = self.bytes
                var depth = 0
                var inString: UInt8? = nil

                while i < end {
                    let b = bs[i]

                    if let q = inString {
                        if b == UInt8(ascii: "\\") && i + 1 < end {
                            i += 2
                            continue
                        }
                        if b == q {
                            inString = nil
                        }
                        i += 1
                        continue
                    }

                    if b == UInt8(ascii: "\"") || b == UInt8(ascii: "'") {
                        inString = b
                        i += 1
                        continue
                    }

                    if b == UInt8(ascii: "(") || b == UInt8(ascii: "[") || b == UInt8(ascii: "{") {
                        depth += 1
                    } else if b == UInt8(ascii: ")") || b == UInt8(ascii: "]") || b == UInt8(ascii: "}") {
                        depth = max(depth - 1, 0)
                    } else if b == UInt8(ascii: ";") && depth == 0 {
                        i += 1
                        break
                    } else if b == 0x0A && depth == 0 {
                        break
                    }

                    i += 1
                }

                self.result_end = i
            }
        }

    domain:
        bytes: [UInt8] = []
        pos: Int = 0
        end: Int = 0
        result_end: Int = 0
}

// main
    var failures = 0

    // Test 1: simple expression terminated by newline
    let e1 = @@ExprScannerFsm()
    let inp1: [UInt8] = Array(" x + 1\nfoo".utf8)
    e1.setup(inp1, 0, inp1.count)
    e1.do_scan()
    let r1 = e1.get_result() as! Int
    let expr1 = String(bytes: Array(inp1[0..<r1]), encoding: .utf8)!
    if expr1 != " x + 1" {
        print("FAIL 1: got '\(expr1)'")
        failures += 1
    }

    // Test 2: expression with semicolon terminator
    let e2 = @@ExprScannerFsm()
    let inp2: [UInt8] = Array(" x + 1; y = 2".utf8)
    e2.setup(inp2, 0, inp2.count)
    e2.do_scan()
    let r2 = e2.get_result() as! Int
    let expr2 = String(bytes: Array(inp2[0..<r2]), encoding: .utf8)!
    if expr2 != " x + 1;" {
        print("FAIL 2: got '\(expr2)'")
        failures += 1
    }

    // Test 3: nested parens not treated as terminator
    let e3 = @@ExprScannerFsm()
    let inp3: [UInt8] = Array(" f(x, g(y))\nz".utf8)
    e3.setup(inp3, 0, inp3.count)
    e3.do_scan()
    let r3 = e3.get_result() as! Int
    let expr3 = String(bytes: Array(inp3[0..<r3]), encoding: .utf8)!
    if expr3 != " f(x, g(y))" {
        print("FAIL 3: got '\(expr3)'")
        failures += 1
    }

    // Test 4: string with escaped quote
    let e4 = @@ExprScannerFsm()
    let inp4: [UInt8] = Array(" \"hello\\\"world\"\n".utf8)
    e4.setup(inp4, 0, inp4.count)
    e4.do_scan()
    let r4 = e4.get_result() as! Int
    let expr4 = String(bytes: Array(inp4[0..<r4]), encoding: .utf8)!
    if expr4 != " \"hello\\\"world\"" {
        print("FAIL 4: got '\(expr4)'")
        failures += 1
    }

    // Test 5: semicolon inside string (should not terminate)
    let e5 = @@ExprScannerFsm()
    let inp5: [UInt8] = Array(" \"a;b\"\n".utf8)
    e5.setup(inp5, 0, inp5.count)
    e5.do_scan()
    let r5 = e5.get_result() as! Int
    let expr5 = String(bytes: Array(inp5[0..<r5]), encoding: .utf8)!
    if expr5 != " \"a;b\"" {
        print("FAIL 5: got '\(expr5)'")
        failures += 1
    }

    if failures > 0 {
        print("FAIL: \(failures) failures")
        exit(1)
    }
    print("PASS: expr_scanner (5 cases)")

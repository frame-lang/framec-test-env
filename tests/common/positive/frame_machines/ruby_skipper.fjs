@@target javascript

// RubySyntaxSkipper -- FSM for skipping Ruby comments and strings.

@@system RubySyntaxSkipperFsm {
    operations:
        setup(input_bytes, start, length) {
            this.bytes = input_bytes;
            this.pos = start;
            this.scan_end = length;
        }
        get_result_pos() {
            return this.result_pos;
        }
        get_success() {
            return this.success;
        }

    interface:
        do_skip_comment()
        do_skip_string()
        do_find_line_end()
        do_balanced_paren_end()

    machine:
        $Init {
            do_skip_comment() { -> $SkipComment }
            do_skip_string() { -> $SkipString }
            do_find_line_end() { -> $FindLineEnd }
            do_balanced_paren_end() { -> $BalancedParenEnd }
        }

        $SkipComment {
            $>() {
                let i = this.pos;
                const end = this.scan_end;
                const bs = this.bytes;

                if (i < end && bs[i] === 0x23) {
                    let j = i + 1;
                    while (j < end && bs[j] !== 0x0A) { j++; }
                    this.result_pos = j;
                    this.success = 1;
                    return;
                }

                this.success = 0;
            }
        }

        $SkipString {
            $>() {
                let i = this.pos;
                const end = this.scan_end;
                const bs = this.bytes;

                // Percent literals
                if (i < end && bs[i] === 0x25) {
                    if (i + 1 < end) {
                        const c1 = bs[i + 1];
                        const has_letter = (c1 === 0x51 || c1 === 0x71 || c1 === 0x77 || c1 === 0x57 || c1 === 0x69 || c1 === 0x49 || c1 === 0x72 || c1 === 0x78 || c1 === 0x73);
                        let opener;
                        let j;
                        if (has_letter && i + 2 < end) {
                            opener = bs[i + 2];
                            j = i + 3;
                        } else if (!(/[a-zA-Z0-9_]/).test(String.fromCharCode(c1))) {
                            opener = c1;
                            j = i + 2;
                        } else {
                            this.success = 0;
                            return;
                        }

                        let closer;
                        if (opener === 0x7B) { closer = 0x7D; }
                        else if (opener === 0x5B) { closer = 0x5D; }
                        else if (opener === 0x28) { closer = 0x29; }
                        else if (opener === 0x3C) { closer = 0x3E; }
                        else {
                            closer = opener;
                            while (j < end) {
                                if (bs[j] === 0x5C) { j += 2; continue; }
                                if (bs[j] === closer) {
                                    this.result_pos = j + 1;
                                    this.success = 1;
                                    return;
                                }
                                j++;
                            }
                            this.result_pos = end;
                            this.success = 1;
                            return;
                        }

                        let depth = 1;
                        while (j < end && depth > 0) {
                            if (bs[j] === 0x5C) { j += 2; continue; }
                            if (bs[j] === opener) { depth++; }
                            else if (bs[j] === closer) { depth--; }
                            j++;
                        }
                        this.result_pos = j;
                        this.success = 1;
                        return;
                    }
                }

                // Simple string: " or '
                if (i < end && (bs[i] === 0x22 || bs[i] === 0x27)) {
                    const q = bs[i];
                    let j = i + 1;
                    while (j < end) {
                        if (bs[j] === 0x5C) { j += 2; continue; }
                        if (bs[j] === q) {
                            this.result_pos = j + 1;
                            this.success = 1;
                            return;
                        }
                        j++;
                    }
                    this.result_pos = end;
                    this.success = 1;
                    return;
                }

                this.success = 0;
            }
        }

        $FindLineEnd {
            $>() {
                let j = this.pos;
                const end = this.scan_end;
                const bs = this.bytes;
                let in_string = 0;

                while (j < end) {
                    const b = bs[j];
                    if (b === 0x0A) { break; }

                    if (in_string !== 0) {
                        if (b === 0x5C) { j += 2; continue; }
                        if (b === in_string) { in_string = 0; }
                        j++;
                        continue;
                    }

                    if (b === 0x23) { break; }
                    if (b === 0x27 || b === 0x22) { in_string = b; j++; continue; }
                    j++;
                }

                this.result_pos = j;
            }
        }

        $BalancedParenEnd {
            $>() {
                let i = this.pos;
                const end = this.scan_end;
                const bs = this.bytes;

                if (i >= end || bs[i] !== 0x28) {
                    this.success = 0;
                    return;
                }

                let depth = 0;
                let in_string = 0;

                while (i < end) {
                    const b = bs[i];

                    if (in_string !== 0) {
                        if (b === 0x5C) { i += 2; continue; }
                        if (b === in_string) { in_string = 0; }
                        i++;
                        continue;
                    }

                    if (b === 0x27 || b === 0x22) { in_string = b; i++; }
                    else if (b === 0x28) { depth++; i++; }
                    else if (b === 0x29) {
                        depth--;
                        i++;
                        if (depth === 0) { this.result_pos = i; this.success = 1; return; }
                    } else { i++; }
                }

                this.success = 0;
            }
        }

    domain:
        bytes = []
        pos = 0
        scan_end = 0
        result_pos = 0
        success = 1
}

const enc = s => Array.from(Buffer.from(s));

let failures = 0;

// Test 1: Skip # comment
const s1 = @@RubySyntaxSkipperFsm();
const inp1 = enc("# comment\ncode");
s1.setup(inp1, 0, inp1.length);
s1.do_skip_comment();
if (s1.get_success() !== 1 || s1.get_result_pos() !== 9) {
    console.log("FAIL 1: success=" + s1.get_success() + ", pos=" + s1.get_result_pos());
    failures++;
}

// Test 2: Skip double-quoted string
const s2 = @@RubySyntaxSkipperFsm();
const inp2 = enc('"hello" rest');
s2.setup(inp2, 0, inp2.length);
s2.do_skip_string();
if (s2.get_success() !== 1 || s2.get_result_pos() !== 7) {
    console.log("FAIL 2: success=" + s2.get_success() + ", pos=" + s2.get_result_pos());
    failures++;
}

// Test 3: Skip single-quoted string
const s3 = @@RubySyntaxSkipperFsm();
const inp3 = enc("'hello' rest");
s3.setup(inp3, 0, inp3.length);
s3.do_skip_string();
if (s3.get_success() !== 1 || s3.get_result_pos() !== 7) {
    console.log("FAIL 3: success=" + s3.get_success() + ", pos=" + s3.get_result_pos());
    failures++;
}

// Test 4: Skip %Q{text}
const s4 = @@RubySyntaxSkipperFsm();
const inp4 = enc("%Q{text} rest");
s4.setup(inp4, 0, inp4.length);
s4.do_skip_string();
if (s4.get_success() !== 1 || s4.get_result_pos() !== 8) {
    console.log("FAIL 4: success=" + s4.get_success() + ", pos=" + s4.get_result_pos());
    failures++;
}

// Test 5: Skip %q[text]
const s5 = @@RubySyntaxSkipperFsm();
const inp5 = enc("%q[text] rest");
s5.setup(inp5, 0, inp5.length);
s5.do_skip_string();
if (s5.get_success() !== 1 || s5.get_result_pos() !== 8) {
    console.log("FAIL 5: success=" + s5.get_success() + ", pos=" + s5.get_result_pos());
    failures++;
}

// Test 6: Find line end (stops at #)
const s6 = @@RubySyntaxSkipperFsm();
const inp6 = enc("x + 1 # comment");
s6.setup(inp6, 0, inp6.length);
s6.do_find_line_end();
if (s6.get_result_pos() !== 6) {
    console.log("FAIL 6: pos=" + s6.get_result_pos() + ", expected 6");
    failures++;
}

// Test 7: Balanced parens
const s7 = @@RubySyntaxSkipperFsm();
const inp7 = enc("(a, f(b)) rest");
s7.setup(inp7, 0, inp7.length);
s7.do_balanced_paren_end();
if (s7.get_success() !== 1 || s7.get_result_pos() !== 9) {
    console.log("FAIL 7: success=" + s7.get_success() + ", pos=" + s7.get_result_pos());
    failures++;
}

// Test 8: Skip %Q with nested braces
const s8 = @@RubySyntaxSkipperFsm();
const inp8 = enc("%Q{outer {inner} end} rest");
s8.setup(inp8, 0, inp8.length);
s8.do_skip_string();
if (s8.get_success() !== 1 || s8.get_result_pos() !== 21) {
    console.log("FAIL 8: success=" + s8.get_success() + ", pos=" + s8.get_result_pos());
    failures++;
}

if (failures > 0) { console.log("FAIL: " + failures + " failures"); process.exit(1); }
console.log("PASS: ruby_skipper (8 cases)");

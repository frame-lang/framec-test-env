@@target cpp_17

#include <iostream>
#include <string>
#include <vector>
#include <cstdint>
#include <algorithm>

// RustSyntaxSkipper — FSM for skipping Rust comments and strings.
// Translated from framec's native_region_scanner/rust_skipper.frs
//
// Handles: // line comments, /* nested block comments */,
// raw strings (r#"..."#), char literals vs lifetime annotations,
// simple strings.

@@system RustSyntaxSkipperFsm {
    operations:
        setup(input_bytes: std::vector<uint8_t>, start: int, length: int) {
            this->bytes = input_bytes;
            this->pos = start;
            this->scan_end = length;
        }
        get_result_pos(): int {
            return this->result_pos;
        }
        get_success(): int {
            return this->success;
        }

    interface:
        do_skip_comment()
        do_skip_string()
        do_find_line_end()

    machine:
        $Init {
            do_skip_comment() { -> $SkipComment }
            do_skip_string() { -> $SkipString }
            do_find_line_end() { -> $FindLineEnd }
        }

        $SkipComment {
            $>() {
                int i = this->pos;
                int end = this->scan_end;
                const std::vector<uint8_t>& bs = this->bytes;

                // // line comment
                if (i + 1 < end && bs[i] == '/' && bs[i + 1] == '/') {
                    int j = i + 2;
                    while (j < end && bs[j] != '\n') {
                        j++;
                    }
                    this->result_pos = j;
                    this->success = 1;
                    return;
                }

                // /* nested block comment */ — Rust allows nesting
                if (i + 1 < end && bs[i] == '/' && bs[i + 1] == '*') {
                    int j = i + 2;
                    int depth = 1;
                    while (j + 1 < end && depth > 0) {
                        if (bs[j] == '/' && bs[j + 1] == '*') {
                            depth++;
                            j += 2;
                            continue;
                        }
                        if (bs[j] == '*' && bs[j + 1] == '/') {
                            depth--;
                            j += 2;
                            continue;
                        }
                        j++;
                    }
                    this->result_pos = j;
                    this->success = 1;
                    return;
                }

                this->success = 0;
            }
        }

        $SkipString {
            $>() {
                int i = this->pos;
                int end = this->scan_end;
                const std::vector<uint8_t>& bs = this->bytes;

                // Raw string: r#"..."# (count leading #s)
                if (i < end && bs[i] == 'r') {
                    int j = i + 1;
                    int hash_count = 0;
                    while (j < end && bs[j] == '#') {
                        hash_count++;
                        j++;
                    }
                    if (j < end && bs[j] == '"') {
                        j++;
                        while (j < end) {
                            if (bs[j] == '"') {
                                int k = 0;
                                while (k < hash_count && j + 1 + k < end && bs[j + 1 + k] == '#') {
                                    k++;
                                }
                                if (k == hash_count) {
                                    this->result_pos = j + 1 + hash_count;
                                    this->success = 1;
                                    return;
                                }
                            }
                            j++;
                        }
                        this->result_pos = end;
                        this->success = 1;
                        return;
                    }
                }

                // Double-quoted string
                if (i < end && bs[i] == '"') {
                    int j = i + 1;
                    while (j < end) {
                        if (bs[j] == '\\') {
                            j += 2;
                            continue;
                        }
                        if (bs[j] == '"') {
                            this->result_pos = j + 1;
                            this->success = 1;
                            return;
                        }
                        j++;
                    }
                    this->result_pos = end;
                    this->success = 1;
                    return;
                }

                // Char literal: 'x' or '\n' (NOT lifetime 'a)
                if (i < end && bs[i] == '\'') {
                    if (i + 2 < end && bs[i + 1] == '\\' && i + 3 < end && bs[i + 3] == '\'') {
                        this->result_pos = i + 4;
                        this->success = 1;
                        return;
                    }
                    if (i + 2 < end && bs[i + 2] == '\'') {
                        this->result_pos = i + 3;
                        this->success = 1;
                        return;
                    }
                    this->success = 0;
                    return;
                }

                this->success = 0;
            }
        }

        $FindLineEnd {
            $>() {
                int j = this->pos;
                int end = this->scan_end;
                const std::vector<uint8_t>& bs = this->bytes;

                while (j < end) {
                    int b = bs[j];
                    if (b == '\n' || b == ';') {
                        break;
                    }
                    if (b == '/' && j + 1 < end && bs[j + 1] == '/') {
                        break;
                    }
                    if (b == '/' && j + 1 < end && bs[j + 1] == '*') {
                        break;
                    }
                    j++;
                }

                this->result_pos = j;
            }
        }

    domain:
        bytes: std::vector<uint8_t> = {}
        pos: int = 0
        scan_end: int = 0
        result_pos: int = 0
        success: int = 1
}

int main() {
    int failures = 0;

    auto to_bytes = [](const std::string& s) -> std::vector<uint8_t> {
        return std::vector<uint8_t>(s.begin(), s.end());
    };

    // Test 1: Skip // comment
    auto s1 = RustSyntaxSkipperFsm();
    auto inp1 = to_bytes("// comment\ncode");
    s1.setup(inp1, 0, inp1.size());
    s1.do_skip_comment();
    if (s1.get_success() != 1 || s1.get_result_pos() != 10) {
        printf("FAIL 1: success=%d, pos=%d\n", s1.get_success(), s1.get_result_pos());
        failures++;
    }

    // Test 2: Skip nested /* /* */ */ block comment
    auto s2 = RustSyntaxSkipperFsm();
    auto inp2 = to_bytes("/* outer /* inner */ */code");
    s2.setup(inp2, 0, inp2.size());
    s2.do_skip_comment();
    if (s2.get_success() != 1 || s2.get_result_pos() != 23) {
        printf("FAIL 2: success=%d, pos=%d\n", s2.get_success(), s2.get_result_pos());
        failures++;
    }

    // Test 3: Skip raw string r#"hello"#
    auto s3 = RustSyntaxSkipperFsm();
    auto inp3 = to_bytes("r#\"hello\"#rest");
    s3.setup(inp3, 0, inp3.size());
    s3.do_skip_string();
    if (s3.get_success() != 1 || s3.get_result_pos() != 10) {
        printf("FAIL 3: success=%d, pos=%d\n", s3.get_success(), s3.get_result_pos());
        failures++;
    }

    // Test 4: Skip double-quoted string
    auto s4 = RustSyntaxSkipperFsm();
    auto inp4 = to_bytes("\"hello\" rest");
    s4.setup(inp4, 0, inp4.size());
    s4.do_skip_string();
    if (s4.get_success() != 1 || s4.get_result_pos() != 7) {
        printf("FAIL 4: success=%d, pos=%d\n", s4.get_success(), s4.get_result_pos());
        failures++;
    }

    // Test 5: Char literal 'x' — IS a string
    auto s5 = RustSyntaxSkipperFsm();
    auto inp5 = to_bytes("'x' rest");
    s5.setup(inp5, 0, inp5.size());
    s5.do_skip_string();
    if (s5.get_success() != 1 || s5.get_result_pos() != 3) {
        printf("FAIL 5: success=%d, pos=%d\n", s5.get_success(), s5.get_result_pos());
        failures++;
    }

    // Test 6: Lifetime 'a — NOT a string
    auto s6 = RustSyntaxSkipperFsm();
    auto inp6 = to_bytes("'a rest");
    s6.setup(inp6, 0, inp6.size());
    s6.do_skip_string();
    if (s6.get_success() != 0) {
        printf("FAIL 6: lifetime should not be a string\n");
        failures++;
    }

    // Test 7: Escape char '\n'
    auto s7 = RustSyntaxSkipperFsm();
    auto inp7 = to_bytes("'\\n' rest");
    s7.setup(inp7, 0, inp7.size());
    s7.do_skip_string();
    if (s7.get_success() != 1 || s7.get_result_pos() != 4) {
        printf("FAIL 7: success=%d, pos=%d\n", s7.get_success(), s7.get_result_pos());
        failures++;
    }

    if (failures > 0) {
        printf("FAIL: %d failures\n", failures);
        return 1;
    }
    printf("PASS: rust_skipper (7 cases)\n");
    return 0;
}

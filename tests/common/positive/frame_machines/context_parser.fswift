@@[target("swift")]

import Foundation

// ContextParser -- FSM for parsing @@ context constructs.
// Translated from framec's native_region_scanner/context_parser.frs
//
// Parses:
//   @@:return [= expr]     kind=2 (ContextReturn)
//   @@:event               kind=3 (ContextEvent)
//   @@:data.key [= expr]   kind=4 (ContextData) or kind=5 (ContextDataAssign)
//   @@:params.key           kind=6 (ContextParams)
//   @@SystemName()          kind=7 (TaggedInstantiation)
//   @@:(expr)               kind=8 (ContextReturnExpr)
//   @@:return(expr)         kind=9 (ReturnCall)
//   @@:self.method()        kind=10 (ContextSelfCall)
//   @@:self                 kind=11 (ContextSelf)
//   @@:system.state         kind=12 (ContextSystemState)
//   other                   has_result=0

@@system ContextParserFsm {
    operations:
        setup(input_bytes: [UInt8], start: Int, length: Int) {
            self.bytes = input_bytes
            self.pos = start
            self.scan_end = length
        }
        setup_with_paren_end(input_bytes: [UInt8], start: Int, length: Int, p_end: Int) {
            self.bytes = input_bytes
            self.pos = start
            self.scan_end = length
            self.paren_end = p_end
        }
        get_result_end(): Int {
            return self.result_end
        }
        get_result_kind(): Int {
            return self.result_kind
        }
        get_has_result(): Int {
            return self.has_result
        }

    interface:
        do_parse()

    machine:
        $Init {
            do_parse() { -> $Dispatching }
        }

        $Dispatching {
            $>() {
                var i = self.pos
                let end = self.scan_end
                let bs = self.bytes

                if i >= end {
                    self.has_result = 0
                    -> $Done
                }

                let b = bs[i]

                if b == UInt8(ascii: ":") {
                    self.pos = i + 1
                    -> $DispatchColon
                } else if b >= 0x41 && b <= 0x5A {
                    // @@SystemName -- pos stays at start of name
                    -> $ParseInstantiation
                } else {
                    self.result_end = i
                    self.has_result = 0
                    -> $Done
                }
            }
        }

        $DispatchColon {
            $>() {
                var i = self.pos
                let end = self.scan_end
                let bs = self.bytes

                // Check for @@:return
                if i + 5 < end {
                    let tag = String(bytes: bs[i..<i+6], encoding: .utf8)!
                    if tag == "return" {
                        self.pos = i + 6
                        -> $ParseReturn
                    }
                }

                // Check for @@:event
                if i + 4 < end {
                    let tag = String(bytes: bs[i..<i+5], encoding: .utf8)!
                    if tag == "event" {
                        self.result_end = i + 5
                        self.result_kind = 3
                        self.has_result = 1
                        -> $Done
                    }
                }

                // Check for @@:data
                if i + 3 < end {
                    let tag = String(bytes: bs[i..<i+4], encoding: .utf8)!
                    if tag == "data" {
                        self.pos = i + 4
                        -> $ParseData
                    }
                }

                // Check for @@:params
                if i + 5 < end {
                    let tag = String(bytes: bs[i..<i+6], encoding: .utf8)!
                    if tag == "params" {
                        self.pos = i + 6
                        -> $ParseParams
                    }
                }

                // Check for @@:self
                if i + 3 < end {
                    let tag = String(bytes: bs[i..<i+4], encoding: .utf8)!
                    if tag == "self" {
                        self.pos = i + 4
                        -> $ParseSelf
                    }
                }

                // Check for @@:system
                if i + 5 < end {
                    let tag = String(bytes: bs[i..<i+6], encoding: .utf8)!
                    if tag == "system" {
                        self.pos = i + 6
                        -> $ParseSystem
                    }
                }

                // Check for @@:(expr)
                if i < end && bs[i] == UInt8(ascii: "(") {
                    self.pos = i
                    -> $ParseContextReturnExpr
                }

                // Unknown
                self.result_end = i
                self.has_result = 0
                -> $Done
            }
        }

        $ParseReturn {
            $>() {
                var i = self.pos
                let end = self.scan_end
                let bs = self.bytes

                // Skip whitespace
                while i < end && (bs[i] == UInt8(ascii: " ") || bs[i] == 0x09) {
                    i += 1
                }

                if i < end && bs[i] == UInt8(ascii: "(") {
                    // @@:return(expr) -- scan balanced parens
                    var depth = 1
                    i += 1
                    while i < end && depth > 0 {
                        if bs[i] == UInt8(ascii: "(") {
                            depth += 1
                        }
                        if bs[i] == UInt8(ascii: ")") {
                            depth -= 1
                        }
                        if depth > 0 {
                            i += 1
                        }
                    }
                    if depth == 0 {
                        i += 1
                    }
                    self.result_end = i
                    self.result_kind = 9
                    self.has_result = 1
                    -> $Done
                } else if i < end && bs[i] == UInt8(ascii: "=") && (i + 1 >= end || bs[i + 1] != UInt8(ascii: "=")) {
                    // @@:return = <expr> -- scan expression
                    i += 1
                    // Skip whitespace after =
                    while i < end && (bs[i] == UInt8(ascii: " ") || bs[i] == 0x09) {
                        i += 1
                    }
                    // Scan to end of expression (newline or ;)
                    while i < end && bs[i] != 0x0A && bs[i] != UInt8(ascii: ";") {
                        i += 1
                    }
                    self.result_end = i
                    self.result_kind = 2
                    self.has_result = 1
                    -> $Done
                } else {
                    // @@:return (bare read)
                    self.result_end = i
                    self.result_kind = 2
                    self.has_result = 1
                    -> $Done
                }
            }
        }

        $ParseContextReturnExpr {
            $>() {
                var i = self.pos
                let end = self.scan_end
                let bs = self.bytes

                if i < end && bs[i] == UInt8(ascii: "(") {
                    var depth = 1
                    i += 1
                    while i < end && depth > 0 {
                        let b = bs[i]
                        if b == UInt8(ascii: "(") {
                            depth += 1
                        } else if b == UInt8(ascii: ")") {
                            depth -= 1
                        } else if b == 0x22 || b == UInt8(ascii: "'") {
                            let q = b
                            i += 1
                            while i < end {
                                if bs[i] == UInt8(ascii: "\\") && i + 1 < end {
                                    i += 2
                                    continue
                                }
                                if bs[i] == q {
                                    break
                                }
                                i += 1
                            }
                        }
                        i += 1
                    }
                }

                self.result_end = i
                self.result_kind = 8
                self.has_result = 1
                -> $Done
            }
        }

        $ParseData {
            $>() {
                var i = self.pos
                let end = self.scan_end
                let bs = self.bytes

                // Scan .key
                if i < end && bs[i] == UInt8(ascii: ".") {
                    i += 1
                    while i < end && (Character(UnicodeScalar(bs[i])).isLetter || Character(UnicodeScalar(bs[i])).isNumber || bs[i] == UInt8(ascii: "_")) {
                        i += 1
                    }
                }

                // Check for assignment
                var j = i
                while j < end && (bs[j] == UInt8(ascii: " ") || bs[j] == 0x09) {
                    j += 1
                }

                if j < end && bs[j] == UInt8(ascii: "=") && (j + 1 >= end || bs[j + 1] != UInt8(ascii: "=")) {
                    // @@:data.key = expr
                    j += 1
                    while j < end && (bs[j] == UInt8(ascii: " ") || bs[j] == 0x09) {
                        j += 1
                    }
                    while j < end && bs[j] != 0x0A && bs[j] != UInt8(ascii: ";") {
                        j += 1
                    }
                    self.result_end = j
                    self.result_kind = 5
                } else {
                    self.result_end = i
                    self.result_kind = 4
                }

                self.has_result = 1
                -> $Done
            }
        }

        $ParseParams {
            $>() {
                var i = self.pos
                let end = self.scan_end
                let bs = self.bytes

                if i < end && bs[i] == UInt8(ascii: ".") {
                    i += 1
                    while i < end && (Character(UnicodeScalar(bs[i])).isLetter || Character(UnicodeScalar(bs[i])).isNumber || bs[i] == UInt8(ascii: "_")) {
                        i += 1
                    }
                }

                self.result_end = i
                self.result_kind = 6
                self.has_result = 1
                -> $Done
            }
        }

        $ParseSelf {
            $>() {
                var i = self.pos
                let end = self.scan_end
                let bs = self.bytes

                if i < end && bs[i] == UInt8(ascii: ".") {
                    i += 1
                    // Scan identifier
                    while i < end && (Character(UnicodeScalar(bs[i])).isLetter || Character(UnicodeScalar(bs[i])).isNumber || bs[i] == UInt8(ascii: "_")) {
                        i += 1
                    }
                    if i < end && bs[i] == UInt8(ascii: "(") {
                        // @@:self.method(args) -- scan balanced parens
                        var depth = 1
                        i += 1
                        while i < end && depth > 0 {
                            if bs[i] == UInt8(ascii: "(") {
                                depth += 1
                            }
                            if bs[i] == UInt8(ascii: ")") {
                                depth -= 1
                            }
                            if bs[i] == 0x22 || bs[i] == UInt8(ascii: "'") {
                                let q = bs[i]
                                i += 1
                                while i < end {
                                    if bs[i] == UInt8(ascii: "\\") && i + 1 < end {
                                        i += 2
                                        continue
                                    }
                                    if bs[i] == q {
                                        break
                                    }
                                    i += 1
                                }
                            }
                            if depth > 0 {
                                i += 1
                            }
                        }
                        if depth == 0 {
                            i += 1
                        }
                        self.result_end = i
                        self.result_kind = 10
                        self.has_result = 1
                    } else {
                        // @@:self.property
                        self.result_end = i
                        self.result_kind = 11
                        self.has_result = 1
                    }
                } else {
                    // bare @@:self
                    self.result_end = i
                    self.result_kind = 11
                    self.has_result = 1
                }

                -> $Done
            }
        }

        $ParseSystem {
            $>() {
                var i = self.pos
                let end = self.scan_end
                let bs = self.bytes

                if i + 5 < end {
                    let tag = String(bytes: bs[i..<i+6], encoding: .utf8)!
                    if tag == ".state" {
                        let after = i + 6
                        if after >= end || (!Character(UnicodeScalar(bs[after])).isLetter && !Character(UnicodeScalar(bs[after])).isNumber && bs[after] != UInt8(ascii: "_")) {
                            self.result_end = i + 6
                            self.result_kind = 12
                            self.has_result = 1
                            -> $Done
                        }
                    }
                }

                // Bare @@:system or unknown variant
                self.result_end = i
                self.result_kind = 13
                self.has_result = 1
                -> $Done
            }
        }

        $ParseInstantiation {
            $>() {
                var i = self.pos
                let end = self.scan_end
                let bs = self.bytes

                // Scan identifier
                while i < end && (Character(UnicodeScalar(bs[i])).isLetter || Character(UnicodeScalar(bs[i])).isNumber || bs[i] == UInt8(ascii: "_")) {
                    i += 1
                }

                // Must be followed by (
                if i < end && bs[i] == UInt8(ascii: "(") {
                    if self.paren_end > 0 {
                        i = self.paren_end
                        self.result_end = i
                        self.result_kind = 7
                        self.has_result = 1
                    } else {
                        self.result_end = i
                        self.has_result = 0
                    }
                } else {
                    self.result_end = i
                    self.has_result = 0
                }

                -> $Done
            }
        }

        $Done {
            $>() {
                // Terminal state -- results are in domain vars
            }
        }

    domain:
        bytes: [UInt8] = []
        pos: Int = 0
        scan_end: Int = 0
        result_end: Int = 0
        result_kind: Int = 0
        has_result: Int = 0
        paren_end: Int = 0
}

// main
    var failures = 0

    // Test 1: @@:return (bare read)
    let p1 = @@ContextParserFsm()
    let inp1: [UInt8] = Array(":return".utf8)
    p1.setup(inp1, 0, inp1.count)
    p1.do_parse()
    if p1.get_has_result() != 1 || p1.get_result_kind() != 2 {
        print("FAIL 1: has_result=\(p1.get_has_result()), kind=\(p1.get_result_kind())")
        failures += 1
    }

    // Test 2: @@:event
    let p2 = @@ContextParserFsm()
    let inp2: [UInt8] = Array(":event".utf8)
    p2.setup(inp2, 0, inp2.count)
    p2.do_parse()
    if p2.get_has_result() != 1 || p2.get_result_kind() != 3 {
        print("FAIL 2: has_result=\(p2.get_has_result()), kind=\(p2.get_result_kind())")
        failures += 1
    }

    // Test 3: @@:data.key
    let p3 = @@ContextParserFsm()
    let inp3: [UInt8] = Array(":data.name rest".utf8)
    p3.setup(inp3, 0, inp3.count)
    p3.do_parse()
    if p3.get_has_result() != 1 || p3.get_result_kind() != 4 {
        print("FAIL 3: has_result=\(p3.get_has_result()), kind=\(p3.get_result_kind())")
        failures += 1
    }

    // Test 4: @@:data.key = expr
    let p4 = @@ContextParserFsm()
    let inp4: [UInt8] = Array(":data.key = value\n".utf8)
    p4.setup(inp4, 0, inp4.count)
    p4.do_parse()
    if p4.get_has_result() != 1 || p4.get_result_kind() != 5 {
        print("FAIL 4: has_result=\(p4.get_has_result()), kind=\(p4.get_result_kind())")
        failures += 1
    }

    // Test 5: @@:params.key
    let p5 = @@ContextParserFsm()
    let inp5: [UInt8] = Array(":params.name rest".utf8)
    p5.setup(inp5, 0, inp5.count)
    p5.do_parse()
    if p5.get_has_result() != 1 || p5.get_result_kind() != 6 {
        print("FAIL 5: has_result=\(p5.get_has_result()), kind=\(p5.get_result_kind())")
        failures += 1
    }

    // Test 6: @@:(expr)
    let p6 = @@ContextParserFsm()
    let inp6: [UInt8] = Array(":(x + 1) rest".utf8)
    p6.setup(inp6, 0, inp6.count)
    p6.do_parse()
    if p6.get_has_result() != 1 || p6.get_result_kind() != 8 {
        print("FAIL 6: has_result=\(p6.get_has_result()), kind=\(p6.get_result_kind())")
        failures += 1
    }

    // Test 7: @@:return(expr)
    let p7 = @@ContextParserFsm()
    let inp7: [UInt8] = Array(":return(42) rest".utf8)
    p7.setup(inp7, 0, inp7.count)
    p7.do_parse()
    if p7.get_has_result() != 1 || p7.get_result_kind() != 9 {
        print("FAIL 7: has_result=\(p7.get_has_result()), kind=\(p7.get_result_kind())")
        failures += 1
    }

    // Test 8: @@:self (bare)
    let p8 = @@ContextParserFsm()
    let inp8: [UInt8] = Array(":self rest".utf8)
    p8.setup(inp8, 0, inp8.count)
    p8.do_parse()
    if p8.get_has_result() != 1 || p8.get_result_kind() != 11 {
        print("FAIL 8: has_result=\(p8.get_has_result()), kind=\(p8.get_result_kind())")
        failures += 1
    }

    // Test 9: @@:self.method(args)
    let p9 = @@ContextParserFsm()
    let inp9: [UInt8] = Array(":self.doWork(x) rest".utf8)
    p9.setup(inp9, 0, inp9.count)
    p9.do_parse()
    if p9.get_has_result() != 1 || p9.get_result_kind() != 10 {
        print("FAIL 9: has_result=\(p9.get_has_result()), kind=\(p9.get_result_kind())")
        failures += 1
    }

    // Test 10: @@:system.state
    let p10 = @@ContextParserFsm()
    let inp10: [UInt8] = Array(":system.state rest".utf8)
    p10.setup(inp10, 0, inp10.count)
    p10.do_parse()
    if p10.get_has_result() != 1 || p10.get_result_kind() != 12 {
        print("FAIL 10: has_result=\(p10.get_has_result()), kind=\(p10.get_result_kind())")
        failures += 1
    }

    // Test 11: @@SystemName() with paren_end
    let p11 = @@ContextParserFsm()
    let inp11: [UInt8] = Array("MySystem() rest".utf8)
    p11.setup_with_paren_end(inp11, 0, inp11.count, 10)
    p11.do_parse()
    if p11.get_has_result() != 1 || p11.get_result_kind() != 7 {
        print("FAIL 11: has_result=\(p11.get_has_result()), kind=\(p11.get_result_kind())")
        failures += 1
    }

    // Test 12: No match (lowercase, not a keyword)
    let p12 = @@ContextParserFsm()
    let inp12: [UInt8] = Array("xyz".utf8)
    p12.setup(inp12, 0, inp12.count)
    p12.do_parse()
    if p12.get_has_result() != 0 {
        print("FAIL 12: should not match, has_result=\(p12.get_has_result())")
        failures += 1
    }

    if failures > 0 {
        print("FAIL: \(failures) failures")
        exit(1)
    }
    print("PASS: context_parser (12 cases)")

@@[target("javascript")]

// PhpSyntaxSkipper -- FSM for skipping PHP comments and strings.

@@system PhpSyntaxSkipperFsm {
    operations:
        setup(input_bytes, start, length) {
            this.bytes = input_bytes;
            this.pos = start;
            this.scan_end = length;
        }
        get_result_pos() {
            return this.result_pos;
        }
        get_success() {
            return this.success;
        }

    interface:
        do_skip_comment()
        do_skip_string()
        do_find_line_end()
        do_balanced_paren_end()

    machine:
        $Init {
            do_skip_comment() { -> $SkipComment }
            do_skip_string() { -> $SkipString }
            do_find_line_end() { -> $FindLineEnd }
            do_balanced_paren_end() { -> $BalancedParenEnd }
        }

        $SkipComment {
            $>() {
                let i = this.pos;
                const end = this.scan_end;
                const bs = this.bytes;

                if (i + 1 < end && bs[i] === 0x2F && bs[i + 1] === 0x2F) {
                    let j = i + 2;
                    while (j < end && bs[j] !== 0x0A) { j++; }
                    this.result_pos = j;
                    this.success = 1;
                    return;
                }

                if (i < end && bs[i] === 0x23) {
                    let j = i + 1;
                    while (j < end && bs[j] !== 0x0A) { j++; }
                    this.result_pos = j;
                    this.success = 1;
                    return;
                }

                if (i + 1 < end && bs[i] === 0x2F && bs[i + 1] === 0x2A) {
                    let j = i + 2;
                    while (j + 1 < end) {
                        if (bs[j] === 0x2A && bs[j + 1] === 0x2F) {
                            this.result_pos = j + 2;
                            this.success = 1;
                            return;
                        }
                        j++;
                    }
                    this.result_pos = end;
                    this.success = 1;
                    return;
                }

                this.success = 0;
            }
        }

        $SkipString {
            $>() {
                let i = this.pos;
                const end = this.scan_end;
                const bs = this.bytes;

                // Heredoc/nowdoc
                if (i + 2 < end && bs[i] === 0x3C && bs[i + 1] === 0x3C && bs[i + 2] === 0x3C) {
                    let j = i + 3;
                    let nowdoc = 0;
                    if (j < end && bs[j] === 0x27) { nowdoc = 1; j++; }
                    const tag_start = j;
                    while (j < end && (/[a-zA-Z0-9_]/).test(String.fromCharCode(bs[j]))) { j++; }
                    const tag_end_pos = j;
                    if (nowdoc === 1 && j < end && bs[j] === 0x27) { j++; }
                    const tag_len = tag_end_pos - tag_start;
                    if (tag_len > 0) {
                        while (j < end && bs[j] !== 0x0A) { j++; }
                        if (j < end) { j++; }
                        while (j < end) {
                            let match = true;
                            if (j + tag_len <= end) {
                                for (let t = 0; t < tag_len; t++) {
                                    if (bs[j + t] !== bs[tag_start + t]) { match = false; break; }
                                }
                            } else { match = false; }
                            if (match) {
                                let k = j + tag_len;
                                if (k < end && bs[k] === 0x3B) { k++; }
                                if (k >= end || bs[k] === 0x0A) {
                                    if (k < end && bs[k] === 0x0A) { k++; }
                                    this.result_pos = k;
                                    this.success = 1;
                                    return;
                                }
                            }
                            while (j < end && bs[j] !== 0x0A) { j++; }
                            if (j < end) { j++; }
                        }
                        this.result_pos = end;
                        this.success = 1;
                        return;
                    }
                }

                if (i < end && (bs[i] === 0x22 || bs[i] === 0x27)) {
                    const q = bs[i];
                    let j = i + 1;
                    while (j < end) {
                        if (bs[j] === 0x5C) { j += 2; continue; }
                        if (bs[j] === q) {
                            this.result_pos = j + 1;
                            this.success = 1;
                            return;
                        }
                        j++;
                    }
                    this.result_pos = end;
                    this.success = 1;
                    return;
                }

                this.success = 0;
            }
        }

        $FindLineEnd {
            $>() {
                let j = this.pos;
                const end = this.scan_end;
                const bs = this.bytes;
                let in_string = 0;

                while (j < end) {
                    const b = bs[j];
                    if (b === 0x0A) { break; }

                    if (in_string !== 0) {
                        if (b === 0x5C) { j += 2; continue; }
                        if (b === in_string) { in_string = 0; }
                        j++;
                        continue;
                    }

                    if (b === 0x3B || b === 0x7D) { break; }
                    if (b === 0x2F && j + 1 < end && (bs[j + 1] === 0x2F || bs[j + 1] === 0x2A)) { break; }
                    if (b === 0x23) { break; }

                    if (b === 0x27 || b === 0x22) {
                        in_string = b;
                        j++;
                        continue;
                    }

                    j++;
                }

                this.result_pos = j;
            }
        }

        $BalancedParenEnd {
            $>() {
                let i = this.pos;
                const end = this.scan_end;
                const bs = this.bytes;

                if (i >= end || bs[i] !== 0x28) {
                    this.success = 0;
                    return;
                }

                let depth = 0;
                let in_string = 0;

                while (i < end) {
                    const b = bs[i];

                    if (in_string !== 0) {
                        if (b === 0x5C) { i += 2; continue; }
                        if (b === in_string) { in_string = 0; }
                        i++;
                        continue;
                    }

                    if (b === 0x27 || b === 0x22) {
                        in_string = b;
                        i++;
                    } else if (b === 0x28) {
                        depth++;
                        i++;
                    } else if (b === 0x29) {
                        depth--;
                        i++;
                        if (depth === 0) {
                            this.result_pos = i;
                            this.success = 1;
                            return;
                        }
                    } else {
                        i++;
                    }
                }

                this.success = 0;
            }
        }

    domain:
        bytes = []
        pos = 0
        scan_end = 0
        result_pos = 0
        success = 1
}

const enc = s => Array.from(Buffer.from(s));

let failures = 0;

const s1 = @@PhpSyntaxSkipperFsm();
const inp1 = enc("// comment\ncode");
s1.setup(inp1, 0, inp1.length);
s1.do_skip_comment();
if (s1.get_success() !== 1 || s1.get_result_pos() !== 10) {
    console.log("FAIL 1: success=" + s1.get_success() + ", pos=" + s1.get_result_pos());
    failures++;
}

const s2 = @@PhpSyntaxSkipperFsm();
const inp2 = enc("# comment\ncode");
s2.setup(inp2, 0, inp2.length);
s2.do_skip_comment();
if (s2.get_success() !== 1 || s2.get_result_pos() !== 9) {
    console.log("FAIL 2: success=" + s2.get_success() + ", pos=" + s2.get_result_pos());
    failures++;
}

const s3 = @@PhpSyntaxSkipperFsm();
const inp3 = enc("/* block */code");
s3.setup(inp3, 0, inp3.length);
s3.do_skip_comment();
if (s3.get_success() !== 1 || s3.get_result_pos() !== 11) {
    console.log("FAIL 3: success=" + s3.get_success() + ", pos=" + s3.get_result_pos());
    failures++;
}

const s4 = @@PhpSyntaxSkipperFsm();
const inp4 = enc('"hello" rest');
s4.setup(inp4, 0, inp4.length);
s4.do_skip_string();
if (s4.get_success() !== 1 || s4.get_result_pos() !== 7) {
    console.log("FAIL 4: success=" + s4.get_success() + ", pos=" + s4.get_result_pos());
    failures++;
}

const s5 = @@PhpSyntaxSkipperFsm();
const inp5 = enc("'hello' rest");
s5.setup(inp5, 0, inp5.length);
s5.do_skip_string();
if (s5.get_success() !== 1 || s5.get_result_pos() !== 7) {
    console.log("FAIL 5: success=" + s5.get_success() + ", pos=" + s5.get_result_pos());
    failures++;
}

const s6 = @@PhpSyntaxSkipperFsm();
const inp6 = enc("<<<EOT\nhello world\nEOT;\nnext");
s6.setup(inp6, 0, inp6.length);
s6.do_skip_string();
if (s6.get_success() !== 1 || s6.get_result_pos() !== 24) {
    console.log("FAIL 6: success=" + s6.get_success() + ", pos=" + s6.get_result_pos());
    failures++;
}

const s7 = @@PhpSyntaxSkipperFsm();
const inp7 = enc("$x = 1; next");
s7.setup(inp7, 0, inp7.length);
s7.do_find_line_end();
if (s7.get_result_pos() !== 6) {
    console.log("FAIL 7: pos=" + s7.get_result_pos() + ", expected 6");
    failures++;
}

const s8 = @@PhpSyntaxSkipperFsm();
const inp8 = enc("(a, f(b)) rest");
s8.setup(inp8, 0, inp8.length);
s8.do_balanced_paren_end();
if (s8.get_success() !== 1 || s8.get_result_pos() !== 9) {
    console.log("FAIL 8: success=" + s8.get_success() + ", pos=" + s8.get_result_pos());
    failures++;
}

if (failures > 0) { console.log("FAIL: " + failures + " failures"); process.exit(1); }
console.log("PASS: php_skipper (8 cases)");

@@[target("go")]

package main

import "fmt"
import "os"

// CSharpSyntaxSkipper -- FSM for skipping C# comments and strings.
// Translated from framec's native_region_scanner/csharp_skipper.frs
//
// Handles: // line comments, /* */ block comments, # preprocessor directives,
// "..." simple strings, @"..." verbatim strings, $"..." interpolated strings,
// $"""...""" raw strings, C-like line endings, balanced parens.

@@system CSharpSyntaxSkipperFsm {
    operations:
        Setup(input_bytes: []byte, start: int, length: int) {
            s.bytes = input_bytes
            s.pos = start
            s.scan_end = length
        }
        GetResultPos(): int {
            return s.result_pos
        }
        GetSuccess(): int {
            return s.success
        }

    interface:
        DoSkipComment()
        DoSkipString()
        DoFindLineEnd()
        DoBalancedParenEnd()

    machine:
        $Init {
            DoSkipComment() { -> $SkipComment }
            DoSkipString() { -> $SkipString }
            DoFindLineEnd() { -> $FindLineEnd }
            DoBalancedParenEnd() { -> $BalancedParenEnd }
        }

        $SkipComment {
            $>() {
                i := s.pos
                end := s.scan_end
                bs := s.bytes

                // Preprocessor directive: # ... newline
                if i < end && bs[i] == '#' {
                    j := i + 1
                    for j < end && bs[j] != '\n' {
                        j++
                    }
                    s.result_pos = j
                    s.success = 1
                    return
                }

                // Line comment: //
                if i+1 < end && bs[i] == '/' && bs[i+1] == '/' {
                    j := i + 2
                    for j < end && bs[j] != '\n' {
                        j++
                    }
                    s.result_pos = j
                    s.success = 1
                    return
                }

                // Block comment: /* ... */
                if i+1 < end && bs[i] == '/' && bs[i+1] == '*' {
                    j := i + 2
                    for j+1 < end {
                        if bs[j] == '*' && bs[j+1] == '/' {
                            s.result_pos = j + 2
                            s.success = 1
                            return
                        }
                        j++
                    }
                    s.result_pos = end
                    s.success = 1
                    return
                }

                s.success = 0
            }
        }

        $SkipString {
            $>() {
                i := s.pos
                end := s.scan_end
                bs := s.bytes

                if i >= end {
                    s.success = 0
                    return
                }

                b0 := bs[i]

                // Verbatim string @"..." (doubled quotes for escape)
                if b0 == '@' && i+1 < end && bs[i+1] == '"' {
                    j := i + 2
                    for j < end {
                        if bs[j] == '"' {
                            if j+1 < end && bs[j+1] == '"' {
                                j += 2
                                continue
                            }
                            s.result_pos = j + 1
                            s.success = 1
                            return
                        }
                        j++
                    }
                    s.result_pos = end
                    s.success = 1
                    return
                }

                // Interpolated string $"..." or $@"..." or raw $"""..."""
                if b0 == '$' {
                    j := i + 1
                    // Skip additional $
                    for j < end && bs[j] == '$' {
                        j++
                    }
                    // Check for @
                    if j < end && bs[j] == '@' {
                        j++
                    }
                    // Count opening quotes
                    quotes := 0
                    for j < end && bs[j] == '"' {
                        quotes++
                        j++
                    }
                    if quotes == 0 {
                        s.success = 0
                        return
                    }
                    // Raw string (3+ quotes)
                    if quotes >= 3 {
                        for j < end {
                            if bs[j] == '"' {
                                q := 0
                                p := j
                                for p < end && bs[p] == '"' {
                                    q++
                                    p++
                                }
                                if q >= quotes {
                                    s.result_pos = p
                                    s.success = 1
                                    return
                                }
                                j = p
                                continue
                            }
                            j++
                        }
                        s.result_pos = end
                        s.success = 1
                        return
                    }
                    // Normal interpolated string
                    for j < end {
                        if bs[j] == '\\' {
                            j += 2
                            continue
                        }
                        if bs[j] == '"' {
                            s.result_pos = j + 1
                            s.success = 1
                            return
                        }
                        j++
                    }
                    s.result_pos = end
                    s.success = 1
                    return
                }

                // Simple string: " or '
                if b0 == '"' || b0 == '\'' {
                    q := b0
                    j := i + 1
                    for j < end {
                        if bs[j] == '\\' {
                            j += 2
                            continue
                        }
                        if bs[j] == q {
                            s.result_pos = j + 1
                            s.success = 1
                            return
                        }
                        j++
                    }
                    s.result_pos = end
                    s.success = 1
                    return
                }

                s.success = 0
            }
        }

        $FindLineEnd {
            $>() {
                j := s.pos
                end := s.scan_end
                bs := s.bytes

                for j < end {
                    b := bs[j]
                    if b == '\n' || b == ';' {
                        break
                    }
                    // Stop at // or /* comment
                    if b == '/' && j+1 < end && (bs[j+1] == '/' || bs[j+1] == '*') {
                        break
                    }
                    // Stop at # preprocessor
                    if b == '#' {
                        break
                    }
                    j++
                }

                s.result_pos = j
            }
        }

        $BalancedParenEnd {
            $>() {
                i := s.pos
                end := s.scan_end
                bs := s.bytes

                if i >= end || bs[i] != '(' {
                    s.success = 0
                    return
                }

                depth := 1
                i++
                for i < end && depth > 0 {
                    b := bs[i]
                    if b == '(' {
                        depth++
                    } else if b == ')' {
                        depth--
                    } else if b == '"' || b == '\'' {
                        q := b
                        i++
                        for i < end && bs[i] != q {
                            if bs[i] == '\\' {
                                i++
                            }
                            i++
                        }
                    }
                    i++
                }

                if depth == 0 {
                    s.result_pos = i
                    s.success = 1
                } else {
                    s.result_pos = end
                    s.success = 0
                }
            }
        }

    domain:
        bytes: []byte = nil
        pos: int = 0
        scan_end: int = 0
        result_pos: int = 0
        success: int = 1
}

func main() {
	failures := 0

	// Test 1: Skip // line comment
	s1 := @@CSharpSyntaxSkipperFsm()
	inp1 := []byte("// comment\ncode")
	s1.Setup(inp1, 0, len(inp1))
	s1.DoSkipComment()
	if s1.GetSuccess() != 1 || s1.GetResultPos() != 10 {
		fmt.Printf("FAIL 1: success=%d, pos=%d\n", s1.GetSuccess(), s1.GetResultPos())
		failures++
	}

	// Test 2: Skip /* */ block comment
	s2 := @@CSharpSyntaxSkipperFsm()
	inp2 := []byte("/* block */code")
	s2.Setup(inp2, 0, len(inp2))
	s2.DoSkipComment()
	if s2.GetSuccess() != 1 || s2.GetResultPos() != 11 {
		fmt.Printf("FAIL 2: success=%d, pos=%d\n", s2.GetSuccess(), s2.GetResultPos())
		failures++
	}

	// Test 3: Skip simple string "hello"
	s3 := @@CSharpSyntaxSkipperFsm()
	inp3 := []byte("\"hello\" rest")
	s3.Setup(inp3, 0, len(inp3))
	s3.DoSkipString()
	if s3.GetSuccess() != 1 || s3.GetResultPos() != 7 {
		fmt.Printf("FAIL 3: success=%d, pos=%d\n", s3.GetSuccess(), s3.GetResultPos())
		failures++
	}

	// Test 4: Skip verbatim string @"verbatim ""quote"""
	s4 := @@CSharpSyntaxSkipperFsm()
	inp4 := []byte("@\"verbatim \"\"quote\"\"\" rest")
	s4.Setup(inp4, 0, len(inp4))
	s4.DoSkipString()
	if s4.GetSuccess() != 1 || s4.GetResultPos() != 21 {
		fmt.Printf("FAIL 4: success=%d, pos=%d\n", s4.GetSuccess(), s4.GetResultPos())
		failures++
	}

	// Test 5: Skip interpolated string $"interp {x}"
	s5 := @@CSharpSyntaxSkipperFsm()
	inp5 := []byte("$\"interp {x}\" rest")
	s5.Setup(inp5, 0, len(inp5))
	s5.DoSkipString()
	if s5.GetSuccess() != 1 || s5.GetResultPos() != 13 {
		fmt.Printf("FAIL 5: success=%d, pos=%d\n", s5.GetSuccess(), s5.GetResultPos())
		failures++
	}

	// Test 6: Find line end (stops at // comment)
	s6 := @@CSharpSyntaxSkipperFsm()
	inp6 := []byte("x + 1 // comment")
	s6.Setup(inp6, 0, len(inp6))
	s6.DoFindLineEnd()
	if s6.GetResultPos() != 6 {
		fmt.Printf("FAIL 6: pos=%d, expected 6\n", s6.GetResultPos())
		failures++
	}

	// Test 7: Balanced parens
	s7 := @@CSharpSyntaxSkipperFsm()
	inp7 := []byte("(a, f(b)) rest")
	s7.Setup(inp7, 0, len(inp7))
	s7.DoBalancedParenEnd()
	if s7.GetSuccess() != 1 || s7.GetResultPos() != 9 {
		fmt.Printf("FAIL 7: success=%d, pos=%d\n", s7.GetSuccess(), s7.GetResultPos())
		failures++
	}

	// Test 8: Skip # preprocessor directive
	s8 := @@CSharpSyntaxSkipperFsm()
	inp8 := []byte("#region Foo\ncode")
	s8.Setup(inp8, 0, len(inp8))
	s8.DoSkipComment()
	if s8.GetSuccess() != 1 || s8.GetResultPos() != 11 {
		fmt.Printf("FAIL 8: success=%d, pos=%d\n", s8.GetSuccess(), s8.GetResultPos())
		failures++
	}

	if failures > 0 {
		fmt.Printf("FAIL: %d failures\n", failures)
		os.Exit(1)
	}
	fmt.Println("PASS: csharp_skipper (8 cases)")
}

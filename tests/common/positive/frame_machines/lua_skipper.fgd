@@target gdscript
extends SceneTree

# LuaSyntaxSkipper — FSM for skipping Lua comments and strings.
# Translated from framec's native_region_scanner/lua_skipper.frs
#
# Handles: -- line comments, --[[ block comments ]], [[ long strings ]],
# simple strings, Lua-style line endings.

@@system LuaSyntaxSkipperFsm {
    operations:
        setup(input_bytes: Array, start: int, length: int) {
            self.bytes = input_bytes
            self.pos = start
            self.scan_end = length
        }
        get_result_pos(): int {
            return self.result_pos
        }
        get_success(): int {
            return self.success
        }

    interface:
        do_skip_comment()
        do_skip_string()
        do_find_line_end()

    machine:
        $Init {
            do_skip_comment() { -> $SkipComment }
            do_skip_string() { -> $SkipString }
            do_find_line_end() { -> $FindLineEnd }
        }

        $SkipComment {
            $>() {
                var i = self.pos
                var scan_end = self.scan_end
                var bs = self.bytes

                # Lua line comment: -- (0x2D)
                if i + 1 < scan_end and bs[i] == 0x2D and bs[i + 1] == 0x2D:
                    # Check for block comment: --[[ ... ]]
                    if i + 3 < scan_end and bs[i + 2] == 0x5B and bs[i + 3] == 0x5B:
                        var j = i + 4
                        while j + 1 < scan_end:
                            if bs[j] == 0x5D and bs[j + 1] == 0x5D:
                                self.result_pos = j + 2
                                self.success = 1
                                return
                            j += 1
                        self.result_pos = scan_end
                        self.success = 1
                        return
                    # Line comment
                    var j = i + 2
                    while j < scan_end and bs[j] != 0x0A:
                        j += 1
                    self.result_pos = j
                    self.success = 1
                    return

                self.success = 0
            }
        }

        $SkipString {
            $>() {
                var i = self.pos
                var scan_end = self.scan_end
                var bs = self.bytes

                # Long string: [[ ... ]]
                if i + 1 < scan_end and bs[i] == 0x5B and bs[i + 1] == 0x5B:
                    var j = i + 2
                    while j + 1 < scan_end:
                        if bs[j] == 0x5D and bs[j + 1] == 0x5D:
                            self.result_pos = j + 2
                            self.success = 1
                            return
                        j += 1
                    self.result_pos = scan_end
                    self.success = 1
                    return

                # Simple string: " or '
                if i < scan_end and (bs[i] == 0x22 or bs[i] == 0x27):
                    var q = bs[i]
                    var j = i + 1
                    while j < scan_end:
                        if bs[j] == 0x5C:
                            j += 2
                            continue
                        if bs[j] == q:
                            self.result_pos = j + 1
                            self.success = 1
                            return
                        j += 1
                    self.result_pos = scan_end
                    self.success = 1
                    return

                self.success = 0
            }
        }

        $FindLineEnd {
            $>() {
                var j = self.pos
                var scan_end = self.scan_end
                var bs = self.bytes

                while j < scan_end:
                    var b = bs[j]
                    if b == 0x0A:
                        break
                    if b == 0x2D and j + 1 < scan_end and bs[j + 1] == 0x2D:
                        break
                    j += 1

                self.result_pos = j
            }
        }

    domain:
        bytes: Array = []
        pos: int = 0
        scan_end: int = 0
        result_pos: int = 0
        success: int = 1
}

func str_to_bytes(s: String) -> Array:
    var arr = []
    var buf = s.to_utf8_buffer()
    for i in range(buf.size()):
        arr.append(buf[i])
    return arr

func main():
    var failures = 0

    # Test 1: Skip -- line comment
    var s1 = @@LuaSyntaxSkipperFsm()
    var inp1 = str_to_bytes("-- comment\ncode")
    s1.setup(inp1, 0, inp1.size())
    s1.do_skip_comment()
    if s1.get_success() != 1 or s1.get_result_pos() != 10:
        print("FAIL 1: success=" + str(s1.get_success()) + ", pos=" + str(s1.get_result_pos()))
        failures += 1

    # Test 2: Skip --[[ block comment ]]
    var s2 = @@LuaSyntaxSkipperFsm()
    var inp2 = str_to_bytes("--[[ block ]]code")
    s2.setup(inp2, 0, inp2.size())
    s2.do_skip_comment()
    if s2.get_success() != 1 or s2.get_result_pos() != 13:
        print("FAIL 2: success=" + str(s2.get_success()) + ", pos=" + str(s2.get_result_pos()))
        failures += 1

    # Test 3: Not a comment
    var s3 = @@LuaSyntaxSkipperFsm()
    var inp3 = str_to_bytes("x + 1")
    s3.setup(inp3, 0, inp3.size())
    s3.do_skip_comment()
    if s3.get_success() != 0:
        print("FAIL 3: should not be comment")
        failures += 1

    # Test 4: Skip [[ long string ]]
    var s4 = @@LuaSyntaxSkipperFsm()
    var inp4 = str_to_bytes("[[hello world]]rest")
    s4.setup(inp4, 0, inp4.size())
    s4.do_skip_string()
    if s4.get_success() != 1 or s4.get_result_pos() != 15:
        print("FAIL 4: success=" + str(s4.get_success()) + ", pos=" + str(s4.get_result_pos()))
        failures += 1

    # Test 5: Skip simple string
    var s5 = @@LuaSyntaxSkipperFsm()
    var inp5 = str_to_bytes("\"hello\" rest")
    s5.setup(inp5, 0, inp5.size())
    s5.do_skip_string()
    if s5.get_success() != 1 or s5.get_result_pos() != 7:
        print("FAIL 5: success=" + str(s5.get_success()) + ", pos=" + str(s5.get_result_pos()))
        failures += 1

    # Test 6: Find line end stops at --
    var s6 = @@LuaSyntaxSkipperFsm()
    var inp6 = str_to_bytes("x + 1 -- comment")
    s6.setup(inp6, 0, inp6.size())
    s6.do_find_line_end()
    if s6.get_result_pos() != 6:
        print("FAIL 6: pos=" + str(s6.get_result_pos()) + ", expected 6")
        failures += 1

    if failures > 0:
        print("FAIL: " + str(failures) + " failures")
        push_error(str(failures) + " test(s) failed")
    else:
        print("PASS: lua_skipper (6 cases)")

func _init():
    main()
    quit()

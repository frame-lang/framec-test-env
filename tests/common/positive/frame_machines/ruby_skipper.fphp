<?php
@@[target("php")]

// RubySyntaxSkipper -- FSM for skipping Ruby comments and strings.
// Translated from framec's native_region_scanner/ruby_skipper.frs
//
// Handles: # line comments, "..." / '...' strings,
// %Q{} / %q[] / %w() etc. percent literals,
// Ruby-style line endings, balanced parens.

@@system RubySyntaxSkipperFsm {
    operations:
        setup(input_bytes: array, start: int, length: int) {
            $this->bytes = $input_bytes;
            $this->pos = $start;
            $this->scan_end = $length;
        }
        get_result_pos(): int {
            return $this->result_pos;
        }
        get_success(): int {
            return $this->success;
        }

    interface:
        do_skip_comment()
        do_skip_string()
        do_find_line_end()
        do_balanced_paren_end()

    machine:
        $Init {
            do_skip_comment() { -> $SkipComment }
            do_skip_string() { -> $SkipString }
            do_find_line_end() { -> $FindLineEnd }
            do_balanced_paren_end() { -> $BalancedParenEnd }
        }

        $SkipComment {
            $>() {
                $i = $this->pos;
                $end = $this->scan_end;
                $bs = $this->bytes;

                // Ruby: # line comment only
                if ($i < $end && $bs[$i] === 0x23) {
                    $j = $i + 1;
                    while ($j < $end && $bs[$j] !== 0x0A) {
                        $j++;
                    }
                    $this->result_pos = $j;
                    $this->success = 1;
                    return;
                }

                $this->success = 0;
            }
        }

        $SkipString {
            $>() {
                $i = $this->pos;
                $end = $this->scan_end;
                $bs = $this->bytes;

                // Percent literals: %Q{...}, %q[...], %w(...), etc.
                if ($i < $end && $bs[$i] === 0x25) {
                    if ($i + 1 < $end) {
                        $c1 = $bs[$i + 1];
                        $has_letter = ($c1 === 0x51 || $c1 === 0x71 || $c1 === 0x77 || $c1 === 0x57 || $c1 === 0x69 || $c1 === 0x49 || $c1 === 0x72 || $c1 === 0x78 || $c1 === 0x73);
                        if ($has_letter && $i + 2 < $end) {
                            $opener = $bs[$i + 2];
                            $j = $i + 3;
                        } elseif (!(($c1 >= 0x61 && $c1 <= 0x7A) || ($c1 >= 0x41 && $c1 <= 0x5A) || ($c1 >= 0x30 && $c1 <= 0x39) || $c1 === 0x5F)) {
                            $opener = $c1;
                            $j = $i + 2;
                        } else {
                            $this->success = 0;
                            return;
                        }

                        // Determine closer
                        if ($opener === 0x7B) {
                            $closer = 0x7D;
                        } elseif ($opener === 0x5B) {
                            $closer = 0x5D;
                        } elseif ($opener === 0x28) {
                            $closer = 0x29;
                        } elseif ($opener === 0x3C) {
                            $closer = 0x3E;
                        } else {
                            $closer = $opener;
                            while ($j < $end) {
                                if ($bs[$j] === 0x5C) {
                                    $j += 2;
                                    continue;
                                }
                                if ($bs[$j] === $closer) {
                                    $this->result_pos = $j + 1;
                                    $this->success = 1;
                                    return;
                                }
                                $j++;
                            }
                            $this->result_pos = $end;
                            $this->success = 1;
                            return;
                        }

                        // Paired delimiter: track nesting
                        $depth = 1;
                        while ($j < $end && $depth > 0) {
                            if ($bs[$j] === 0x5C) {
                                $j += 2;
                                continue;
                            }
                            if ($bs[$j] === $opener) {
                                $depth++;
                            } elseif ($bs[$j] === $closer) {
                                $depth--;
                            }
                            $j++;
                        }
                        $this->result_pos = $j;
                        $this->success = 1;
                        return;
                    }
                }

                // Simple string: " or '
                if ($i < $end && ($bs[$i] === 0x22 || $bs[$i] === 0x27)) {
                    $q = $bs[$i];
                    $j = $i + 1;
                    while ($j < $end) {
                        if ($bs[$j] === 0x5C) {
                            $j += 2;
                            continue;
                        }
                        if ($bs[$j] === $q) {
                            $this->result_pos = $j + 1;
                            $this->success = 1;
                            return;
                        }
                        $j++;
                    }
                    $this->result_pos = $end;
                    $this->success = 1;
                    return;
                }

                $this->success = 0;
            }
        }

        $FindLineEnd {
            $>() {
                $j = $this->pos;
                $end = $this->scan_end;
                $bs = $this->bytes;
                $in_string = 0;

                while ($j < $end) {
                    $b = $bs[$j];
                    if ($b === 0x0A) {
                        break;
                    }

                    // Inside string
                    if ($in_string !== 0) {
                        if ($b === 0x5C) {
                            $j += 2;
                            continue;
                        }
                        if ($b === $in_string) {
                            $in_string = 0;
                        }
                        $j++;
                        continue;
                    }

                    // Terminators
                    if ($b === 0x23) {
                        break;
                    }

                    // String starts
                    if ($b === 0x27 || $b === 0x22) {
                        $in_string = $b;
                        $j++;
                        continue;
                    }

                    $j++;
                }

                $this->result_pos = $j;
            }
        }

        $BalancedParenEnd {
            $>() {
                $i = $this->pos;
                $end = $this->scan_end;
                $bs = $this->bytes;

                if ($i >= $end || $bs[$i] !== 0x28) {
                    $this->success = 0;
                    return;
                }

                $depth = 0;
                $in_string = 0;

                while ($i < $end) {
                    $b = $bs[$i];

                    // Inside string
                    if ($in_string !== 0) {
                        if ($b === 0x5C) {
                            $i += 2;
                            continue;
                        }
                        if ($b === $in_string) {
                            $in_string = 0;
                        }
                        $i++;
                        continue;
                    }

                    if ($b === 0x27 || $b === 0x22) {
                        $in_string = $b;
                        $i++;
                    } elseif ($b === 0x28) {
                        $depth++;
                        $i++;
                    } elseif ($b === 0x29) {
                        $depth--;
                        $i++;
                        if ($depth === 0) {
                            $this->result_pos = $i;
                            $this->success = 1;
                            return;
                        }
                    } else {
                        $i++;
                    }
                }

                $this->success = 0;
            }
        }

    domain:
        bytes = []
        pos = 0
        scan_end = 0
        result_pos = 0
        success = 1
}

function str_to_bytes(string $s): array {
    return array_values(unpack('C*', $s));
}

$failures = 0;

// Test 1: Skip # comment
$s1 = new RubySyntaxSkipperFsm();
$inp1 = str_to_bytes("# comment\ncode");
$s1->setup($inp1, 0, count($inp1));
$s1->do_skip_comment();
if ($s1->get_success() !== 1 || $s1->get_result_pos() !== 9) {
    echo 'FAIL 1: success=' . $s1->get_success() . ', pos=' . $s1->get_result_pos() . "\n";
    $failures++;
}

// Test 2: Skip double-quoted string
$s2 = new RubySyntaxSkipperFsm();
$inp2 = str_to_bytes("\"hello\" rest");
$s2->setup($inp2, 0, count($inp2));
$s2->do_skip_string();
if ($s2->get_success() !== 1 || $s2->get_result_pos() !== 7) {
    echo 'FAIL 2: success=' . $s2->get_success() . ', pos=' . $s2->get_result_pos() . "\n";
    $failures++;
}

// Test 3: Skip single-quoted string
$s3 = new RubySyntaxSkipperFsm();
$inp3 = str_to_bytes("'hello' rest");
$s3->setup($inp3, 0, count($inp3));
$s3->do_skip_string();
if ($s3->get_success() !== 1 || $s3->get_result_pos() !== 7) {
    echo 'FAIL 3: success=' . $s3->get_success() . ', pos=' . $s3->get_result_pos() . "\n";
    $failures++;
}

// Test 4: Skip %Q{text}
$s4 = new RubySyntaxSkipperFsm();
$inp4 = str_to_bytes("%Q{text} rest");
$s4->setup($inp4, 0, count($inp4));
$s4->do_skip_string();
if ($s4->get_success() !== 1 || $s4->get_result_pos() !== 8) {
    echo 'FAIL 4: success=' . $s4->get_success() . ', pos=' . $s4->get_result_pos() . "\n";
    $failures++;
}

// Test 5: Skip %q[text]
$s5 = new RubySyntaxSkipperFsm();
$inp5 = str_to_bytes("%q[text] rest");
$s5->setup($inp5, 0, count($inp5));
$s5->do_skip_string();
if ($s5->get_success() !== 1 || $s5->get_result_pos() !== 8) {
    echo 'FAIL 5: success=' . $s5->get_success() . ', pos=' . $s5->get_result_pos() . "\n";
    $failures++;
}

// Test 6: Find line end (stops at #)
$s6 = new RubySyntaxSkipperFsm();
$inp6 = str_to_bytes("x + 1 # comment");
$s6->setup($inp6, 0, count($inp6));
$s6->do_find_line_end();
if ($s6->get_result_pos() !== 6) {
    echo 'FAIL 6: pos=' . $s6->get_result_pos() . ", expected 6\n";
    $failures++;
}

// Test 7: Balanced parens
$s7 = new RubySyntaxSkipperFsm();
$inp7 = str_to_bytes("(a, f(b)) rest");
$s7->setup($inp7, 0, count($inp7));
$s7->do_balanced_paren_end();
if ($s7->get_success() !== 1 || $s7->get_result_pos() !== 9) {
    echo 'FAIL 7: success=' . $s7->get_success() . ', pos=' . $s7->get_result_pos() . "\n";
    $failures++;
}

// Test 8: Skip %Q with nested braces
$s8 = new RubySyntaxSkipperFsm();
$inp8 = str_to_bytes("%Q{outer {inner} end} rest");
$s8->setup($inp8, 0, count($inp8));
$s8->do_skip_string();
if ($s8->get_success() !== 1 || $s8->get_result_pos() !== 21) {
    echo 'FAIL 8: success=' . $s8->get_success() . ', pos=' . $s8->get_result_pos() . "\n";
    $failures++;
}

if ($failures > 0) { echo "FAIL: $failures failures\n"; exit(1); }
echo "PASS: ruby_skipper (8 cases)\n";

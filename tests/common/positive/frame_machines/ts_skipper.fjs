@@target javascript

// TypeScriptSyntaxSkipper — FSM for skipping TS/JS comments and strings.
// Translated from framec's native_region_scanner/typescript_skipper.frs
//
// Adds template literal awareness (backtick strings with ${} interpolation)
// on top of the C-style comment and string patterns.

@@system TSSyntaxSkipperFsm {
    operations:
        setup(input_bytes, start, length) {
            this.bytes = input_bytes;
            this.pos = start;
            this.scan_end = length;
        }
        get_result_pos() {
            return this.result_pos;
        }
        get_success() {
            return this.success;
        }

    interface:
        do_skip_comment()
        do_skip_string()
        do_find_line_end()

    machine:
        $Init {
            do_skip_comment() { -> $SkipComment }
            do_skip_string() { -> $SkipString }
            do_find_line_end() { -> $FindLineEnd }
        }

        $SkipComment {
            $>() {
                let i = this.pos;
                const end = this.scan_end;
                const bs = this.bytes;

                // // line comment
                if (i + 1 < end && bs[i] === 0x2F && bs[i + 1] === 0x2F) {
                    let j = i + 2;
                    while (j < end && bs[j] !== 0x0A) {
                        j++;
                    }
                    this.result_pos = j;
                    this.success = 1;
                    return;
                }

                // /* block comment */
                if (i + 1 < end && bs[i] === 0x2F && bs[i + 1] === 0x2A) {
                    let j = i + 2;
                    while (j + 1 < end) {
                        if (bs[j] === 0x2A && bs[j + 1] === 0x2F) {
                            this.result_pos = j + 2;
                            this.success = 1;
                            return;
                        }
                        j++;
                    }
                    this.result_pos = end;
                    this.success = 1;
                    return;
                }

                this.success = 0;
            }
        }

        $SkipString {
            $>() {
                let i = this.pos;
                const end = this.scan_end;
                const bs = this.bytes;

                // Template literal: `...${...}...`
                if (i < end && bs[i] === 0x60) {
                    let j = i + 1;
                    let template_depth = 0;
                    while (j < end) {
                        const b = bs[j];
                        if (b === 0x60 && template_depth === 0) {
                            this.result_pos = j + 1;
                            this.success = 1;
                            return;
                        }
                        if (b === 0x5C) {
                            j += 2;
                            continue;
                        }
                        if (b === 0x24 && j + 1 < end && bs[j + 1] === 0x7B) {
                            template_depth++;
                            j += 2;
                            continue;
                        }
                        if (b === 0x7D && template_depth > 0) {
                            template_depth--;
                        }
                        j++;
                    }
                    this.result_pos = end;
                    this.success = 1;
                    return;
                }

                // Simple string: " or '
                if (i < end && (bs[i] === 0x22 || bs[i] === 0x27)) {
                    const q = bs[i];
                    let j = i + 1;
                    while (j < end) {
                        if (bs[j] === 0x5C) { j += 2; continue; }
                        if (bs[j] === q) {
                            this.result_pos = j + 1;
                            this.success = 1;
                            return;
                        }
                        j++;
                    }
                    this.result_pos = end;
                    this.success = 1;
                    return;
                }

                this.success = 0;
            }
        }

        $FindLineEnd {
            $>() {
                let j = this.pos;
                const end = this.scan_end;
                const bs = this.bytes;
                let in_template = false;
                let template_depth = 0;

                while (j < end) {
                    const b = bs[j];

                    if (in_template) {
                        if (b === 0x60 && template_depth === 0) {
                            in_template = false;
                            j++;
                            continue;
                        }
                        if (b === 0x5C) {
                            j += 2;
                            continue;
                        }
                        if (b === 0x24 && j + 1 < end && bs[j + 1] === 0x7B) {
                            template_depth++;
                            j += 2;
                            continue;
                        }
                        if (b === 0x7D && template_depth > 0) {
                            template_depth--;
                        }
                        j++;
                        continue;
                    }

                    if (b === 0x0A) { break; }
                    if (b === 0x3B) { break; }
                    if (b === 0x2F && j + 1 < end && bs[j + 1] === 0x2F) { break; }
                    if (b === 0x2F && j + 1 < end && bs[j + 1] === 0x2A) { break; }
                    if (b === 0x60) {
                        in_template = true;
                        j++;
                        continue;
                    }
                    if (b === 0x22 || b === 0x27) {
                        const q = b;
                        j++;
                        while (j < end && bs[j] !== q) {
                            if (bs[j] === 0x5C) { j++; }
                            j++;
                        }
                        if (j < end) { j++; }
                        continue;
                    }

                    j++;
                }

                this.result_pos = j;
            }
        }

    domain:
        bytes = []
        pos = 0
        scan_end = 0
        result_pos = 0
        success = 1
}

const enc = s => Array.from(Buffer.from(s));

let failures = 0;

// Test 1: Skip // line comment
const s1 = @@TSSyntaxSkipperFsm();
const inp1 = enc("// comment\ncode");
s1.setup(inp1, 0, inp1.length);
s1.do_skip_comment();
if (s1.get_success() !== 1 || s1.get_result_pos() !== 10) {
    console.log("FAIL 1: success=" + s1.get_success() + ", pos=" + s1.get_result_pos());
    failures++;
}

// Test 2: Skip /* block comment */
const s2 = @@TSSyntaxSkipperFsm();
const inp2 = enc("/* block */code");
s2.setup(inp2, 0, inp2.length);
s2.do_skip_comment();
if (s2.get_success() !== 1 || s2.get_result_pos() !== 11) {
    console.log("FAIL 2: success=" + s2.get_success() + ", pos=" + s2.get_result_pos());
    failures++;
}

// Test 3: Skip template literal
const s3 = @@TSSyntaxSkipperFsm();
const inp3 = enc("`hello ${name} world`rest");
s3.setup(inp3, 0, inp3.length);
s3.do_skip_string();
if (s3.get_success() !== 1 || s3.get_result_pos() !== 21) {
    console.log("FAIL 3: success=" + s3.get_success() + ", pos=" + s3.get_result_pos());
    failures++;
}

// Test 4: Skip simple double-quoted string
const s4 = @@TSSyntaxSkipperFsm();
const inp4 = enc('"hello" rest');
s4.setup(inp4, 0, inp4.length);
s4.do_skip_string();
if (s4.get_success() !== 1 || s4.get_result_pos() !== 7) {
    console.log("FAIL 4: success=" + s4.get_success() + ", pos=" + s4.get_result_pos());
    failures++;
}

// Test 5: Skip template with nested ${}
const s5 = @@TSSyntaxSkipperFsm();
const inp5 = enc("`${a + ${b}}`rest");
s5.setup(inp5, 0, inp5.length);
s5.do_skip_string();
if (s5.get_success() !== 1) {
    console.log("FAIL 5: success=" + s5.get_success());
    failures++;
}

// Test 6: Find line end skips over template literals
const s6 = @@TSSyntaxSkipperFsm();
const inp6 = enc("x = `hello`;\nnext");
s6.setup(inp6, 0, inp6.length);
s6.do_find_line_end();
if (s6.get_result_pos() !== 11) {
    console.log("FAIL 6: pos=" + s6.get_result_pos() + ", expected 11 (at ;)");
    failures++;
}

// Test 7: Not a string
const s7 = @@TSSyntaxSkipperFsm();
const inp7 = enc("x + 1");
s7.setup(inp7, 0, inp7.length);
s7.do_skip_string();
if (s7.get_success() !== 0) {
    console.log("FAIL 7: should not be string");
    failures++;
}

if (failures > 0) { console.log("FAIL: " + failures + " failures"); process.exit(1); }
console.log("PASS: ts_skipper (7 cases)");

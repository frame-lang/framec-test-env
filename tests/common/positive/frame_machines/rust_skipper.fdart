@@[target("dart")]

import 'dart:io';

// RustSyntaxSkipper — FSM for skipping Rust comments and strings.
// Translated from framec's native_region_scanner/rust_skipper.frs
//
// Handles: // line comments, /* nested block comments */,
// raw strings (r#"..."#), char literals vs lifetime annotations,
// simple strings.

@@system RustSyntaxSkipperFsm {
    operations:
        setup(input_bytes: List<int>, start: int, length: int) {
            this.bytes = input_bytes;
            this.pos = start;
            this.scan_end = length;
        }
        get_result_pos(): int {
            return this.result_pos;
        }
        get_success(): int {
            return this.success;
        }

    interface:
        do_skip_comment()
        do_skip_string()
        do_find_line_end()

    machine:
        $Init {
            do_skip_comment() { -> $SkipComment }
            do_skip_string() { -> $SkipString }
            do_find_line_end() { -> $FindLineEnd }
        }

        $SkipComment {
            $>() {
                int i = this.pos;
                int end = this.scan_end;
                List<int> bs = this.bytes;

                // // line comment
                if (i + 1 < end && bs[i] == 0x2F && bs[i + 1] == 0x2F) { // /
                    int j = i + 2;
                    while (j < end && bs[j] != 0x0A) { // \n
                        j++;
                    }
                    this.result_pos = j;
                    this.success = 1;
                    return;
                }

                // /* nested block comment */ — Rust allows nesting
                if (i + 1 < end && bs[i] == 0x2F && bs[i + 1] == 0x2A) { // / *
                    int j = i + 2;
                    int depth = 1;
                    while (j + 1 < end && depth > 0) {
                        if (bs[j] == 0x2F && bs[j + 1] == 0x2A) {
                            depth++;
                            j += 2;
                            continue;
                        }
                        if (bs[j] == 0x2A && bs[j + 1] == 0x2F) {
                            depth--;
                            j += 2;
                            continue;
                        }
                        j++;
                    }
                    this.result_pos = j;
                    this.success = 1;
                    return;
                }

                this.success = 0;
            }
        }

        $SkipString {
            $>() {
                int i = this.pos;
                int end = this.scan_end;
                List<int> bs = this.bytes;

                // Raw string: r#"..."# (count leading #s)
                if (i < end && bs[i] == 0x72) { // r
                    int j = i + 1;
                    int hash_count = 0;
                    while (j < end && bs[j] == 0x23) { // #
                        hash_count++;
                        j++;
                    }
                    if (j < end && bs[j] == 0x22) { // "
                        j++;
                        while (j < end) {
                            if (bs[j] == 0x22) {
                                int k = 0;
                                while (k < hash_count && j + 1 + k < end && bs[j + 1 + k] == 0x23) {
                                    k++;
                                }
                                if (k == hash_count) {
                                    this.result_pos = j + 1 + hash_count;
                                    this.success = 1;
                                    return;
                                }
                            }
                            j++;
                        }
                        this.result_pos = end;
                        this.success = 1;
                        return;
                    }
                }

                // Double-quoted string
                if (i < end && bs[i] == 0x22) { // "
                    int j = i + 1;
                    while (j < end) {
                        if (bs[j] == 0x5C) { // backslash
                            j += 2;
                            continue;
                        }
                        if (bs[j] == 0x22) {
                            this.result_pos = j + 1;
                            this.success = 1;
                            return;
                        }
                        j++;
                    }
                    this.result_pos = end;
                    this.success = 1;
                    return;
                }

                // Char literal: 'x' or '\n' (NOT lifetime 'a)
                if (i < end && bs[i] == 0x27) { // '
                    if (i + 2 < end && bs[i + 1] == 0x5C && i + 3 < end && bs[i + 3] == 0x27) {
                        this.result_pos = i + 4;
                        this.success = 1;
                        return;
                    }
                    if (i + 2 < end && bs[i + 2] == 0x27) {
                        this.result_pos = i + 3;
                        this.success = 1;
                        return;
                    }
                    this.success = 0;
                    return;
                }

                this.success = 0;
            }
        }

        $FindLineEnd {
            $>() {
                int j = this.pos;
                int end = this.scan_end;
                List<int> bs = this.bytes;

                while (j < end) {
                    int b = bs[j];
                    if (b == 0x0A || b == 0x3B) { // \n or ;
                        break;
                    }
                    if (b == 0x2F && j + 1 < end && bs[j + 1] == 0x2F) { // //
                        break;
                    }
                    if (b == 0x2F && j + 1 < end && bs[j + 1] == 0x2A) { // /*
                        break;
                    }
                    j++;
                }

                this.result_pos = j;
            }
        }

    domain:
        bytes: List<int> = []
        pos: int = 0
        scan_end: int = 0
        result_pos: int = 0
        success: int = 1
}

void main() {
    int failures = 0;

    // Test 1: Skip // comment
    final s1 = @@RustSyntaxSkipperFsm();
    final inp1 = "// comment\ncode".codeUnits;
    s1.setup(inp1, 0, inp1.length);
    s1.do_skip_comment();
    if ((s1.get_success() as int) != 1 || (s1.get_result_pos() as int) != 10) {
        print("FAIL 1: success=\${s1.get_success()}, pos=\${s1.get_result_pos()}");
        failures++;
    }

    // Test 2: Skip nested /* /* */ */ block comment
    final s2 = @@RustSyntaxSkipperFsm();
    final inp2 = "/* outer /* inner */ */code".codeUnits;
    s2.setup(inp2, 0, inp2.length);
    s2.do_skip_comment();
    if ((s2.get_success() as int) != 1 || (s2.get_result_pos() as int) != 23) {
        print("FAIL 2: success=\${s2.get_success()}, pos=\${s2.get_result_pos()}");
        failures++;
    }

    // Test 3: Skip raw string r#"hello"#
    final s3 = @@RustSyntaxSkipperFsm();
    final inp3 = 'r#"hello"#rest'.codeUnits;
    s3.setup(inp3, 0, inp3.length);
    s3.do_skip_string();
    if ((s3.get_success() as int) != 1 || (s3.get_result_pos() as int) != 10) {
        print("FAIL 3: success=\${s3.get_success()}, pos=\${s3.get_result_pos()}");
        failures++;
    }

    // Test 4: Skip double-quoted string
    final s4 = @@RustSyntaxSkipperFsm();
    final inp4 = '"hello" rest'.codeUnits;
    s4.setup(inp4, 0, inp4.length);
    s4.do_skip_string();
    if ((s4.get_success() as int) != 1 || (s4.get_result_pos() as int) != 7) {
        print("FAIL 4: success=\${s4.get_success()}, pos=\${s4.get_result_pos()}");
        failures++;
    }

    // Test 5: Char literal 'x' — IS a string
    final s5 = @@RustSyntaxSkipperFsm();
    final inp5 = "'x' rest".codeUnits;
    s5.setup(inp5, 0, inp5.length);
    s5.do_skip_string();
    if ((s5.get_success() as int) != 1 || (s5.get_result_pos() as int) != 3) {
        print("FAIL 5: success=\${s5.get_success()}, pos=\${s5.get_result_pos()}");
        failures++;
    }

    // Test 6: Lifetime 'a — NOT a string
    final s6 = @@RustSyntaxSkipperFsm();
    final inp6 = "'a rest".codeUnits;
    s6.setup(inp6, 0, inp6.length);
    s6.do_skip_string();
    if ((s6.get_success() as int) != 0) {
        print("FAIL 6: lifetime should not be a string");
        failures++;
    }

    // Test 7: Escape char '\n'
    final s7 = @@RustSyntaxSkipperFsm();
    final inp7 = "'\\n' rest".codeUnits;
    s7.setup(inp7, 0, inp7.length);
    s7.do_skip_string();
    if ((s7.get_success() as int) != 1 || (s7.get_result_pos() as int) != 4) {
        print("FAIL 7: success=\${s7.get_success()}, pos=\${s7.get_result_pos()}");
        failures++;
    }

    if (failures > 0) {
        print("FAIL: \$failures failures");
        exit(1);
    }
    print("PASS: rust_skipper (7 cases)");
}

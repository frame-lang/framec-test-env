@@target gdscript
extends SceneTree

# CSharpSyntaxSkipper -- FSM for skipping C# comments and strings.
# Translated from framec's native_region_scanner/csharp_skipper.frs
#
# Handles: // line comments, /* */ block comments, # preprocessor directives,
# "..." simple strings, @"..." verbatim strings, $"..." interpolated strings,
# $"""...""" raw strings, C-like line endings, balanced parens.

@@system CSharpSyntaxSkipperFsm {
    operations:
        setup(input_bytes: Array, start: int, length: int) {
            self.bytes = input_bytes
            self.pos = start
            self.scan_end = length
        }
        get_result_pos(): int {
            return self.result_pos
        }
        get_success(): int {
            return self.success
        }

    interface:
        do_skip_comment()
        do_skip_string()
        do_find_line_end()
        do_balanced_paren_end()

    machine:
        $Init {
            do_skip_comment() { -> $SkipComment }
            do_skip_string() { -> $SkipString }
            do_find_line_end() { -> $FindLineEnd }
            do_balanced_paren_end() { -> $BalancedParenEnd }
        }

        $SkipComment {
            $>() {
                var i = self.pos
                var end = self.scan_end
                var bs = self.bytes

                # Preprocessor directive: # ... newline
                if i < end and bs[i] == 0x23:
                    var j = i + 1
                    while j < end and bs[j] != 0x0A:
                        j += 1
                    self.result_pos = j
                    self.success = 1
                    return

                # Line comment: //
                if i + 1 < end and bs[i] == 0x2F and bs[i + 1] == 0x2F:
                    var j = i + 2
                    while j < end and bs[j] != 0x0A:
                        j += 1
                    self.result_pos = j
                    self.success = 1
                    return

                # Block comment: /* ... */
                if i + 1 < end and bs[i] == 0x2F and bs[i + 1] == 0x2A:
                    var j = i + 2
                    while j + 1 < end:
                        if bs[j] == 0x2A and bs[j + 1] == 0x2F:
                            self.result_pos = j + 2
                            self.success = 1
                            return
                        j += 1
                    self.result_pos = end
                    self.success = 1
                    return

                self.success = 0
            }
        }

        $SkipString {
            $>() {
                var i = self.pos
                var end = self.scan_end
                var bs = self.bytes

                if i >= end:
                    self.success = 0
                    return

                var b0 = bs[i]

                # Verbatim string @"..." (doubled quotes for escape)
                if b0 == 0x40 and i + 1 < end and bs[i + 1] == 0x22:
                    var j = i + 2
                    while j < end:
                        if bs[j] == 0x22:
                            if j + 1 < end and bs[j + 1] == 0x22:
                                j += 2
                                continue
                            self.result_pos = j + 1
                            self.success = 1
                            return
                        j += 1
                    self.result_pos = end
                    self.success = 1
                    return

                # Interpolated string $"..." or $@"..." or raw $"""..."""
                if b0 == 0x24:
                    var j = i + 1
                    while j < end and bs[j] == 0x24:
                        j += 1
                    if j < end and bs[j] == 0x40:
                        j += 1
                    var quotes = 0
                    while j < end and bs[j] == 0x22:
                        quotes += 1
                        j += 1
                    if quotes == 0:
                        self.success = 0
                        return
                    if quotes >= 3:
                        while j < end:
                            if bs[j] == 0x22:
                                var q = 0
                                var p = j
                                while p < end and bs[p] == 0x22:
                                    q += 1
                                    p += 1
                                if q >= quotes:
                                    self.result_pos = p
                                    self.success = 1
                                    return
                                j = p
                                continue
                            j += 1
                        self.result_pos = end
                        self.success = 1
                        return
                    while j < end:
                        if bs[j] == 0x5C:
                            j += 2
                            continue
                        if bs[j] == 0x22:
                            self.result_pos = j + 1
                            self.success = 1
                            return
                        j += 1
                    self.result_pos = end
                    self.success = 1
                    return

                # Simple string: " or '
                if b0 == 0x22 or b0 == 0x27:
                    var q = b0
                    var j = i + 1
                    while j < end:
                        if bs[j] == 0x5C:
                            j += 2
                            continue
                        if bs[j] == q:
                            self.result_pos = j + 1
                            self.success = 1
                            return
                        j += 1
                    self.result_pos = end
                    self.success = 1
                    return

                self.success = 0
            }
        }

        $FindLineEnd {
            $>() {
                var j = self.pos
                var end = self.scan_end
                var bs = self.bytes

                while j < end:
                    var b = bs[j]
                    if b == 0x0A or b == 0x3B:
                        break
                    if b == 0x2F and j + 1 < end and (bs[j + 1] == 0x2F or bs[j + 1] == 0x2A):
                        break
                    if b == 0x23:
                        break
                    j += 1

                self.result_pos = j
            }
        }

        $BalancedParenEnd {
            $>() {
                var i = self.pos
                var end = self.scan_end
                var bs = self.bytes

                if i >= end or bs[i] != 0x28:
                    self.success = 0
                    return

                var depth = 1
                var j = i + 1
                while j < end and depth > 0:
                    var b = bs[j]
                    if b == 0x28:
                        depth += 1
                    elif b == 0x29:
                        depth -= 1
                    elif b == 0x22 or b == 0x27:
                        var q = b
                        j += 1
                        while j < end and bs[j] != q:
                            if bs[j] == 0x5C:
                                j += 1
                            j += 1
                    j += 1

                if depth == 0:
                    self.result_pos = j
                    self.success = 1
                else:
                    self.result_pos = end
                    self.success = 0
            }
        }

    domain:
        bytes: Array = []
        pos: int = 0
        scan_end: int = 0
        result_pos: int = 0
        success: int = 1
}

func str_to_bytes(s: String) -> Array:
    var arr = []
    var buf = s.to_utf8_buffer()
    for i in range(buf.size()):
        arr.append(buf[i])
    return arr

func main():
    var failures = 0

    # Test 1: Skip // line comment
    var s1 = @@CSharpSyntaxSkipperFsm()
    var inp1 = str_to_bytes("// comment\ncode")
    s1.setup(inp1, 0, inp1.size())
    s1.do_skip_comment()
    if s1.get_success() != 1 or s1.get_result_pos() != 10:
        print("FAIL 1: success=" + str(s1.get_success()) + ", pos=" + str(s1.get_result_pos()))
        failures += 1

    # Test 2: Skip /* */ block comment
    var s2 = @@CSharpSyntaxSkipperFsm()
    var inp2 = str_to_bytes("/* block */code")
    s2.setup(inp2, 0, inp2.size())
    s2.do_skip_comment()
    if s2.get_success() != 1 or s2.get_result_pos() != 11:
        print("FAIL 2: success=" + str(s2.get_success()) + ", pos=" + str(s2.get_result_pos()))
        failures += 1

    # Test 3: Skip simple string "hello"
    var s3 = @@CSharpSyntaxSkipperFsm()
    var inp3 = str_to_bytes("\"hello\" rest")
    s3.setup(inp3, 0, inp3.size())
    s3.do_skip_string()
    if s3.get_success() != 1 or s3.get_result_pos() != 7:
        print("FAIL 3: success=" + str(s3.get_success()) + ", pos=" + str(s3.get_result_pos()))
        failures += 1

    # Test 4: Skip verbatim string @"verbatim ""quote"""
    var s4 = @@CSharpSyntaxSkipperFsm()
    var inp4 = str_to_bytes("@\"verbatim \"\"quote\"\"\" rest")
    s4.setup(inp4, 0, inp4.size())
    s4.do_skip_string()
    if s4.get_success() != 1 or s4.get_result_pos() != 21:
        print("FAIL 4: success=" + str(s4.get_success()) + ", pos=" + str(s4.get_result_pos()))
        failures += 1

    # Test 5: Skip interpolated string $"interp {x}"
    var s5 = @@CSharpSyntaxSkipperFsm()
    var inp5 = str_to_bytes("$\"interp {x}\" rest")
    s5.setup(inp5, 0, inp5.size())
    s5.do_skip_string()
    if s5.get_success() != 1 or s5.get_result_pos() != 13:
        print("FAIL 5: success=" + str(s5.get_success()) + ", pos=" + str(s5.get_result_pos()))
        failures += 1

    # Test 6: Find line end (stops at // comment)
    var s6 = @@CSharpSyntaxSkipperFsm()
    var inp6 = str_to_bytes("x + 1 // comment")
    s6.setup(inp6, 0, inp6.size())
    s6.do_find_line_end()
    if s6.get_result_pos() != 6:
        print("FAIL 6: pos=" + str(s6.get_result_pos()) + ", expected 6")
        failures += 1

    # Test 7: Balanced parens
    var s7 = @@CSharpSyntaxSkipperFsm()
    var inp7 = str_to_bytes("(a, f(b)) rest")
    s7.setup(inp7, 0, inp7.size())
    s7.do_balanced_paren_end()
    if s7.get_success() != 1 or s7.get_result_pos() != 9:
        print("FAIL 7: success=" + str(s7.get_success()) + ", pos=" + str(s7.get_result_pos()))
        failures += 1

    # Test 8: Skip # preprocessor directive
    var s8 = @@CSharpSyntaxSkipperFsm()
    var inp8 = str_to_bytes("#region Foo\ncode")
    s8.setup(inp8, 0, inp8.size())
    s8.do_skip_comment()
    if s8.get_success() != 1 or s8.get_result_pos() != 11:
        print("FAIL 8: success=" + str(s8.get_success()) + ", pos=" + str(s8.get_result_pos()))
        failures += 1

    if failures > 0:
        print("FAIL: " + str(failures) + " failures")
        push_error(str(failures) + " test(s) failed")
    else:
        print("PASS: csharp_skipper (8 cases)")

func _init():
    main()
    quit()

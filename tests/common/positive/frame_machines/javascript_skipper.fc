@@target c

#include <string.h>

// javascript_skipper -- FSM for skipping syntax constructs.

@@system JavaScriptSyntaxSkipperFsm {
    operations:
        setup(input_bytes: unsigned char*, start: int, length: int) {
            self->bytes = input_bytes;
            self->pos = start;
            self->scan_end = length;
        }
        get_result_pos(): int {
            return self->result_pos;
        }
        get_success(): int {
            return self->success;
        }

    interface:
        do_skip_comment()
        do_skip_string()
        do_find_line_end()
        do_balanced_paren_end()

    machine:
        $Init {
            do_skip_comment() { -> $SkipComment }
            do_skip_string() { -> $SkipString }
            do_find_line_end() { -> $FindLineEnd }
            do_balanced_paren_end() { -> $BalancedParenEnd }
        }

        $SkipComment {
            $>() {
                int i = self->pos;
                int end = self->scan_end;
                unsigned char* bs = self->bytes;

                if (i + 1 < end && bs[i] == '/' && bs[i + 1] == '/') {
                    int j = i + 2;
                    while (j < end && bs[j] != '\n') { j++; }
                    self->result_pos = j;
                    self->success = 1;
                    return;
                }

                if (i + 1 < end && bs[i] == '/' && bs[i + 1] == '*') {
                    int j = i + 2;
                    while (j + 1 < end) {
                        if (bs[j] == '*' && bs[j + 1] == '/') {
                            self->result_pos = j + 2;
                            self->success = 1;
                            return;
                        }
                        j++;
                    }
                    self->result_pos = end;
                    self->success = 1;
                    return;
                }

                self->success = 0;
            }
        }

        $SkipString {
            $>() {
                int i = self->pos;
                int end = self->scan_end;
                unsigned char* bs = self->bytes;

                // Template literal: `...${expr}...`
                if (i < end && bs[i] == '`') {
                    int j = i + 1;
                    int brace_depth = 0;
                    while (j < end) {
                        if (bs[j] == '`' && brace_depth == 0) {
                            self->result_pos = j + 1;
                            self->success = 1;
                            return;
                        }
                        if (bs[j] == '\\') { j += 2; continue; }
                        if (bs[j] == '$' && j + 1 < end && bs[j + 1] == '{') {
                            brace_depth++; j += 2; continue;
                        }
                        if (bs[j] == '}' && brace_depth > 0) { brace_depth--; }
                        j++;
                    }
                    self->result_pos = end;
                    self->success = 1;
                    return;
                }

                if (i < end && (bs[i] == '"' || bs[i] == '\'')) {
                    char q = bs[i];
                    int j = i + 1;
                    while (j < end) {
                        if (bs[j] == '\\') { j += 2; continue; }
                        if (bs[j] == q) {
                            self->result_pos = j + 1;
                            self->success = 1;
                            return;
                        }
                        j++;
                    }
                    self->result_pos = end;
                    self->success = 1;
                    return;
                }

                self->success = 0;
            }
        }

        $FindLineEnd {
            $>() {
                int j = self->pos;
                int end = self->scan_end;
                unsigned char* bs = self->bytes;

                int in_string = 0;
                int in_template = 0;
                int template_brace_depth = 0;

                while (j < end) {
                    char b = bs[j];
                    if (b == '\n') { break; }

                    if (in_template) {
                        if (b == '`' && template_brace_depth == 0) { in_template = 0; j++; continue; }
                        if (b == '\\') { j += 2; continue; }
                        if (b == '$' && j + 1 < end && bs[j + 1] == '{') { template_brace_depth++; j += 2; continue; }
                        if (b == '}' && template_brace_depth > 0) { template_brace_depth--; }
                        j++; continue;
                    }

                    if (in_string) {
                        if (b == '\\') { j += 2; continue; }
                        if (b == in_string) { in_string = 0; }
                        j++; continue;
                    }

                    if (b == ';' || b == '}') { break; }
                    if (b == '/' && j + 1 < end && (bs[j + 1] == '/' || bs[j + 1] == '*')) { break; }
                    if (b == '\'' || b == '"') { in_string = b; j++; continue; }
                    if (b == '`') { in_template = 1; j++; continue; }
                    j++;
                }

                self->result_pos = j;
            }
        }

        $BalancedParenEnd {
            $>() {
                int i = self->pos;
                int end = self->scan_end;
                unsigned char* bs = self->bytes;

                if (i >= end || bs[i] != '(') {
                    self->success = 0;
                    return;
                }

                int depth = 0;
                int in_string = 0;
                int in_template = 0;

                while (i < end) {
                    char b = bs[i];

                    if (in_template) {
                        if (b == '`') { in_template = 0; }
                        if (b == '\\') { i += 2; continue; }
                        i++; continue;
                    }

                    if (in_string) {
                        if (b == '\\') { i += 2; continue; }
                        if (b == in_string) { in_string = 0; }
                        i++; continue;
                    }

                    if (b == '\'' || b == '"') { in_string = b; i++; }
                    else if (b == '`') { in_template = 1; i++; }
                    else if (b == '(') { depth++; i++; }
                    else if (b == ')') {
                        depth--;
                        i++;
                        if (depth == 0) {
                            self->result_pos = i;
                            self->success = 1;
                            return;
                        }
                    }
                    else { i++; }
                }

                self->success = 0;
            }
        }

    domain:
        bytes: unsigned char* = NULL
        pos: int = 0
        scan_end: int = 0
        result_pos: int = 0
        success: int = 1
}

int main() {
    int failures = 0;

    // Test 1: Skip line comment
    JavaScriptSyntaxSkipperFsm* s1 = @@JavaScriptSyntaxSkipperFsm();
    unsigned char t1[] = "// hello\ncode";
    JavaScriptSyntaxSkipperFsm_setup(s1, t1, 0, strlen((char*)t1));
    JavaScriptSyntaxSkipperFsm_do_skip_comment(s1);
    if (JavaScriptSyntaxSkipperFsm_get_success(s1) != 1 || JavaScriptSyntaxSkipperFsm_get_result_pos(s1) != 8) {
        printf("FAIL 1: Skip line comment\n");
        failures++;
    }
    // Test 2: Skip block comment
    JavaScriptSyntaxSkipperFsm* s2 = @@JavaScriptSyntaxSkipperFsm();
    unsigned char t2[] = "/* block */code";
    JavaScriptSyntaxSkipperFsm_setup(s2, t2, 0, strlen((char*)t2));
    JavaScriptSyntaxSkipperFsm_do_skip_comment(s2);
    if (JavaScriptSyntaxSkipperFsm_get_success(s2) != 1 || JavaScriptSyntaxSkipperFsm_get_result_pos(s2) != 11) {
        printf("FAIL 2: Skip block comment\n");
        failures++;
    }
    // Test 3: Skip double-quoted string
    JavaScriptSyntaxSkipperFsm* s3 = @@JavaScriptSyntaxSkipperFsm();
    unsigned char t3[] = "\"hello world\" rest";
    JavaScriptSyntaxSkipperFsm_setup(s3, t3, 0, strlen((char*)t3));
    JavaScriptSyntaxSkipperFsm_do_skip_string(s3);
    if (JavaScriptSyntaxSkipperFsm_get_success(s3) != 1 || JavaScriptSyntaxSkipperFsm_get_result_pos(s3) != 13) {
        printf("FAIL 3: Skip double-quoted string\n");
        failures++;
    }
    // Test 4: Skip template literal
    JavaScriptSyntaxSkipperFsm* s4 = @@JavaScriptSyntaxSkipperFsm();
    unsigned char t4[] = "`template ${x}` rest";
    JavaScriptSyntaxSkipperFsm_setup(s4, t4, 0, strlen((char*)t4));
    JavaScriptSyntaxSkipperFsm_do_skip_string(s4);
    if (JavaScriptSyntaxSkipperFsm_get_success(s4) != 1 || JavaScriptSyntaxSkipperFsm_get_result_pos(s4) != 15) {
        printf("FAIL 4: Skip template literal\n");
        failures++;
    }
    // Test 5: Find line end
    JavaScriptSyntaxSkipperFsm* s5 = @@JavaScriptSyntaxSkipperFsm();
    unsigned char t5[] = "x + 1\nmore";
    JavaScriptSyntaxSkipperFsm_setup(s5, t5, 0, strlen((char*)t5));
    JavaScriptSyntaxSkipperFsm_do_find_line_end(s5);
    if (JavaScriptSyntaxSkipperFsm_get_result_pos(s5) != 5) {
        printf("FAIL 5: Find line end\n");
        failures++;
    }
    // Test 6: Not a comment
    JavaScriptSyntaxSkipperFsm* s6 = @@JavaScriptSyntaxSkipperFsm();
    unsigned char t6[] = "x + 1";
    JavaScriptSyntaxSkipperFsm_setup(s6, t6, 0, strlen((char*)t6));
    JavaScriptSyntaxSkipperFsm_do_skip_comment(s6);
    if (JavaScriptSyntaxSkipperFsm_get_success(s6) != 0) {
        printf("FAIL 6: Not a comment\n");
        failures++;
    }
    // Test 7: Balanced parens with template
    JavaScriptSyntaxSkipperFsm* s7 = @@JavaScriptSyntaxSkipperFsm();
    unsigned char t7[] = "(a, `t`, c) rest";
    JavaScriptSyntaxSkipperFsm_setup(s7, t7, 0, strlen((char*)t7));
    JavaScriptSyntaxSkipperFsm_do_balanced_paren_end(s7);
    if (JavaScriptSyntaxSkipperFsm_get_success(s7) != 1 || JavaScriptSyntaxSkipperFsm_get_result_pos(s7) != 11) {
        printf("FAIL 7: Balanced parens with template\n");
        failures++;
    }
    // Test 8: Find line end at // comment
    JavaScriptSyntaxSkipperFsm* s8 = @@JavaScriptSyntaxSkipperFsm();
    unsigned char t8[] = "x + 1 // comment";
    JavaScriptSyntaxSkipperFsm_setup(s8, t8, 0, strlen((char*)t8));
    JavaScriptSyntaxSkipperFsm_do_find_line_end(s8);
    if (JavaScriptSyntaxSkipperFsm_get_result_pos(s8) != 6) {
        printf("FAIL 8: Find line end at // comment\n");
        failures++;
    }

    JavaScriptSyntaxSkipperFsm_destroy(s1);
    JavaScriptSyntaxSkipperFsm_destroy(s2);
    JavaScriptSyntaxSkipperFsm_destroy(s3);
    JavaScriptSyntaxSkipperFsm_destroy(s4);
    JavaScriptSyntaxSkipperFsm_destroy(s5);
    JavaScriptSyntaxSkipperFsm_destroy(s6);
    JavaScriptSyntaxSkipperFsm_destroy(s7);
    JavaScriptSyntaxSkipperFsm_destroy(s8);

    if (failures > 0) {
        printf("FAIL: %d failures\n", failures);
        return 1;
    }
    printf("PASS: javascript_skipper (8 cases)\n");
    return 0;
}

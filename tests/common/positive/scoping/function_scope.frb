@@[target("ruby")]
@@exec-ok

@@system S {
    machine:
        $A => $P {
            e() {
                f = lambda { return 1 }
                => $^
                f.call()
            }
        }
        $P { }
}

puts("TAP version 14")
puts("1..1")
begin
    s = @@S()
    if s.respond_to?(:e)
        s.e()
    end
    puts("ok 1 - function_scope")
rescue => ex
    puts("not ok 1 - function_scope # #{ex}")
end

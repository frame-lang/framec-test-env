@@[target("php")]
@@exec-ok

@@system S {
    machine:
        $A => $P {
            e() {
                $f = function() {
                    return 1;
                };
                => $^
                $f();
            }
        }
        $P { }
}

function native() {}
function x() {}

echo "TAP version 14" . "\n";
echo "1..1" . "\n";
try {
    $s = @@S();
    if (method_exists($s, 'e')) { $s->e(); }
    echo "ok 1 - function_scope" . "\n";
} catch (\Exception $ex) {
    echo "not ok 1 - function_scope # " . $ex->getMessage() . "\n";
}

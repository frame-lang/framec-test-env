@@[target("go")]

package main

import "fmt"

@@system S {
    machine:
        $A => $P {
            E() {
                // Go supports anonymous functions
                f := func() int { return 1 }
                => $^
                _ = f()
            }
        }
        $P { }
}

func main() {
	fmt.Println("TAP version 14")
	fmt.Println("1..1")
	s := NewS()
	s.E()
	fmt.Println("ok 1 - function_scope")
}

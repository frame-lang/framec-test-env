@@[target("ruby")]
@@exec-ok

@@system S {
    machine:
        $A => $P {
            e() {
                x = 1
                if true
                    x = 2
                    => $^
                end
                x = 3
            }
        }
        $P { }
}

puts("TAP version 14")
puts("1..1")
begin
    s = S.new
    if s.respond_to?(:e)
        s.e()
    end
    puts("ok 1 - shadowing")
rescue => ex
    puts("not ok 1 - shadowing # #{ex}")
end

@@[target("dart")]
@@exec-ok

@@system S {
    machine:
        $A => $P {
            e() {
                var x = 1;
                if (true) {
                    x = 2;
                    => $^
                }
                x = 3;
            }
        }
        $P { }
}

// Stub functions for placeholder calls
void native() {}
void x() {}

// TAP test harness
void main() {
    print("TAP version 14");
    print("1..1");
    try {
        final s = @@S();
        if (true) {
            s.e();
        }
        print("ok 1 - shadowing");
    } catch (ex) {
        print("not ok 1 - shadowing # ${ex}");
    }
}

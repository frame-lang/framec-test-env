@@[target("java")]

import java.util.*;

@@system S {
    machine:
        $A => $P {
            e() {
                // Java doesn't support nested functions; use a lambda instead
                java.util.function.Supplier<Integer> f = () -> 1;
                => $^
                f.get();
            }
        }
        $P { }
}

class Main {
    public static void main(String[] args) {
        System.out.println("TAP version 14");
        System.out.println("1..1");
        try {
            S s = new S();
            s.e();
            System.out.println("ok 1 - function_scope");
        } catch (Exception ex) {
            System.out.println("not ok 1 - function_scope # " + ex);
        }
    }
}

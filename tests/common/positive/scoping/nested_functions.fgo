@@[target("go")]

package main

import "fmt"

@@system S {
    machine:
        $A => $P {
            E() {
                // Go supports nested anonymous functions
                v := 1
                inner := func() int { return v + 1 }
                outer := func() int { return inner() }
                => $^
                _ = outer()
            }
        }
        $P { }
}

func main() {
	fmt.Println("TAP version 14")
	fmt.Println("1..1")
	s := @@S()
	s.E()
	fmt.Println("ok 1 - nested_functions")
}

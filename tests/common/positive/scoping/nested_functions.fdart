@@target dart
@@exec-ok

@@system S {
    machine:
        $A => $P {
            e() {
                def outer():
                    v = 1
                    def inner():
                        return v + 1
                    return inner()
                => $^
                outer()
            }
        }
        $P { }
}

// Stub functions for placeholder calls

// TAP test harness
void main() {
    print("TAP version 14");
    print("1..1");
    try:
        var s = @@S();
        if // hasattr check: 'e'):
            s.e();
        print("ok 1 - nested_functions");
    except Exception as ex:
        print("not ok 1 - nested_functions // {ex}");

}

@@[target("dart")]
@@exec-ok

@@system S {
    machine:
        $A => $P {
            e() {
                int outer() {
                    var v = 1;
                    int inner() {
                        return v + 1;
                    }
                    return inner();
                }
                => $^
                outer();
            }
        }
        $P { }
}

void main() {
    print("TAP version 14");
    print("1..1");
    try {
        var s = @@S();
        s.e();
        print("ok 1 - nested_functions");
    } catch (ex) {
        print("not ok 1 - nested_functions # $ex");
    }
}

@@[target("python")]
@@exec-ok

@@system S {
    machine:
        $A => $P {
            e() {
                x = 1
                if True:
                    x = 2
                    => $^
                x = 3
            }
        }
        $P { }
}

# Stub functions for placeholder calls
def native(): pass
def x(): pass

# TAP test harness
if __name__ == "__main__":
    print("TAP version 14")
    print("1..1")
    try:
        s = @@S()
        if hasattr(s, 'e'):
            s.e()
        print("ok 1 - shadowing")
    except Exception as ex:
        print(f"not ok 1 - shadowing # {ex}")

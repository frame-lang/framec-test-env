@@[target("kotlin")]

import kotlin.system.exitProcess

@@system S {
    machine:
        $A => $P {
            e() {
                var x = 1
                if (true) {
                    x = 2
                    => $^
                }
                x = 3
            }
        }
        $P { }
}

fun main() {
    println("TAP version 14")
    println("1..1")
    try {
        val s = S()
        s.e()
        println("ok 1 - shadowing")
    } catch (ex: Exception) {
        println("not ok 1 - shadowing # $ex")
    }
}

@@target dart
@@exec-ok

@@system S {
    machine:
        $A => $P {
            e() {
                def f():
                    return 1
                => $^
                f()
            }
        }
        $P { }
}

// Stub functions for placeholder calls

// TAP test harness
void main() {
    print("TAP version 14");
    print("1..1");
    try:
        var s = @@S();
        if // hasattr check: 'e'):
            s.e();
        print("ok 1 - function_scope");
    except Exception as ex:
        print("not ok 1 - function_scope // {ex}");

}

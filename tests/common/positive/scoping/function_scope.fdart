@@[target("dart")]
@@exec-ok

@@system S {
    machine:
        $A => $P {
            e() {
                // Dart supports nested functions natively
                int f() { return 1; }
                => $^
                f();
            }
        }
        $P { }
}

void main() {
    print("TAP version 14");
    print("1..1");
    try {
        var s = @@S();
        s.e();
        print("ok 1 - function_scope");
    } catch (ex) {
        print("not ok 1 - function_scope # $ex");
    }
}

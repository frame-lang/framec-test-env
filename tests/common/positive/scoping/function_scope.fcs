@@[target("csharp")]

using System;
using System.Collections.Generic;

@@system S {
    machine:
        $A => $P {
            e() {
                // C# supports local functions
                int f() { return 1; }
                => $^
                f();
            }
        }
        $P { }
}

class Program {
    static void Main(string[] args) {
        Console.WriteLine("TAP version 14");
        Console.WriteLine("1..1");
        try {
            S s = @@S();
            s.e();
            Console.WriteLine("ok 1 - function_scope");
        } catch (Exception ex) {
            Console.WriteLine("not ok 1 - function_scope # " + ex);
        }
    }
}

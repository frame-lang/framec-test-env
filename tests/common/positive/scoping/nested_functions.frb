@@[target("ruby")]
@@exec-ok

@@system S {
    machine:
        $A => $P {
            e() {
                outer = lambda {
                    v = 1
                    inner = lambda { v + 1 }
                    inner.call()
                }
                => $^
                outer.call()
            }
        }
        $P { }
}

puts("TAP version 14")
puts("1..1")
begin
    s = S.new
    if s.respond_to?(:e)
        s.e()
    end
    puts("ok 1 - nested_functions")
rescue => ex
    puts("not ok 1 - nested_functions # #{ex}")
end

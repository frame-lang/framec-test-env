@@target kotlin

import kotlin.system.exitProcess

@@system S {
    machine:
        $A => $P {
            e() {
                // Kotlin supports nested functions natively
                val v = 1
                fun inner(): Int = v + 1
                fun outer(): Int = inner()
                => $^
                outer()
            }
        }
        $P { }
}

fun main() {
    println("TAP version 14")
    println("1..1")
    try {
        val s = S()
        s.e()
        println("ok 1 - nested_functions")
    } catch (ex: Exception) {
        println("not ok 1 - nested_functions # $ex")
    }
}

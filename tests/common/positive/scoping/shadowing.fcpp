@@[target("cpp_17")]
@@exec-ok

#include <iostream>
#include <string>
#include <cassert>

@@system S {
    machine:
        $A => $P {
            e() {
                int x = 1;
                if (true) {
                    x = 2;
                    => $^
                }
                x = 3;
            }
        }
        $P { }
}

// TAP test harness
int main() {
    printf("TAP version 14\n");
    printf("1..1\n");
    try {
        S s;
        s.e();
        printf("ok 1 - shadowing\n");
    } catch (...) {
        printf("not ok 1 - shadowing\n");
    }
    return 0;
}

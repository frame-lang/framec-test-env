@@target gdscript
extends SceneTree
@@exec-ok

@@system S {
    machine:
        $A => $P {
            e() {
                var outer = func():
                    var v = 1
                    var inner = func():
                        return v + 1
                    return inner.call()
                => $^
                outer.call()
            }
        }
        $P { }
}

# Stub functions for placeholder calls
func native(): pass
func x(): pass

# TAP test harness
func _init():
    print("TAP version 14")
    print("1..1")
    var s = @@S()
    if s.has_method("e"):
        s.e()
    print("ok 1 - nested_functions")
    quit()

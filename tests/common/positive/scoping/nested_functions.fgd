@@target gdscript
extends SceneTree
@@exec-ok

@@system S {
    machine:
        $A => $P {
            e() {
                func outer():
                    var v = 1
                    func inner():
                        return v + 1
                    return inner()
                => $^
                outer()
            }
        }
        $P { }
}

# Stub functions for placeholder calls

# TAP test harness
func _init():
    print("TAP version 14")
    print("1..1")
    var s = @@S()
    if s.has_method("e"):
        s.e()
    print("ok 1 - nested_functions")
    quit()

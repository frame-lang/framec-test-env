@@target csharp

using System;
using System.Collections.Generic;

@@system S {
    machine:
        $A => $P {
            e() {
                // C# supports local functions and nesting
                int v = 1;
                int inner() { return v + 1; }
                int outer() { return inner(); }
                => $^
                outer();
            }
        }
        $P { }
}

class Program {
    static void Main(string[] args) {
        Console.WriteLine("TAP version 14");
        Console.WriteLine("1..1");
        try {
            S s = new S();
            s.e();
            Console.WriteLine("ok 1 - nested_functions");
        } catch (Exception ex) {
            Console.WriteLine("not ok 1 - nested_functions # " + ex);
        }
    }
}

@@target gdscript
extends SceneTree
@@exec-ok

@@system S {
    machine:
        $A => $P {
            e() {
                func f():
                    return 1
                => $^
                f()
            }
        }
        $P { }
}

# Stub functions for placeholder calls

# TAP test harness
func _init():
    print("TAP version 14")
    print("1..1")
    var s = @@S()
    if s.has_method("e"):
        s.e()
    print("ok 1 - function_scope")
    quit()

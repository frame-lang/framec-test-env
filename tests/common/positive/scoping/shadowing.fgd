@@target gdscript
@@exec-ok

@@system S {
    machine:
        $A => $P {
            e() {
                x = 1
                if true:
                    x = 2
                    => $^
                x = 3
            }
        }
        $P { }
}

# Stub functions for placeholder calls

# TAP test harness
func _ready():
    print("TAP version 14")
    print("1..1")
    s = @@S()
    if s.has_method("e"):
        s.e()
    print("ok 1 - shadowing")
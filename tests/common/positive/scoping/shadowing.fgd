@@[target("gdscript")]
extends SceneTree
@@exec-ok

@@system S {
    machine:
        $A => $P {
            e() {
                var x = 1
                if true:
                    x = 2
                    => $^
                x = 3
            }
        }
        $P { }
}

# Stub functions for placeholder calls
func native(): pass
func x(): pass

# TAP test harness
func _init():
    print("TAP version 14")
    print("1..1")
    var s = @@S()
    if s.has_method("e"):
        s.e()
    print("ok 1 - shadowing")
    quit()

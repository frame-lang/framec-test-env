@@[target("c")]

// Note: C does not support nested functions in standard C.
// This test uses a workaround with static helper functions.

static int inner_v = 0;

static int inner() {
    return inner_v + 1;
}

static int outer() {
    inner_v = 1;
    return inner();
}

@@system S {
    interface:
        e(): void

    machine:
        $A => $P {
            e() {
                => $^
                outer();
            }
        }
        $P { }
}

int main() {
    printf("=== Test: nested_functions ===\n");
    S* s = @@S();

    // Test that we can call e() without errors
    S_e(s);

    // Verify outer() works (nested function behavior via static)
    int result = outer();
    if (result != 2) {
        printf("FAIL: Expected outer() to return 2, got %d\n", result);
        S_destroy(s);
        return 1;
    }

    printf("PASS: nested_functions test completed successfully\n");
    S_destroy(s);
    return 0;
}

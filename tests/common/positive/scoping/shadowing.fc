@@[target("c")]

@@system S {
    interface:
        e(): void

    machine:
        $A => $P {
            e() {
                int x = 1;
                if (1) {
                    x = 2;
                    => $^
                }
                x = 3;
            }
        }
        $P { }
}

int main() {
    printf("=== Test: shadowing ===\n");
    S* s = @@S();

    // Test that we can call e() without errors
    S_e(s);

    printf("PASS: shadowing test completed successfully\n");
    S_destroy(s);
    return 0;
}

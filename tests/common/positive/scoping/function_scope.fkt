@@[target("kotlin")]

import kotlin.system.exitProcess

@@system S {
    machine:
        $A => $P {
            e() {
                // Kotlin supports nested functions natively
                fun f(): Int = 1
                => $^
                f()
            }
        }
        $P { }
}

fun main() {
    println("TAP version 14")
    println("1..1")
    try {
        val s = @@S()
        s.e()
        println("ok 1 - function_scope")
    } catch (ex: Exception) {
        println("not ok 1 - function_scope # $ex")
    }
}

@@[target("java")]

import java.util.*;

@@system S {
    machine:
        $A => $P {
            e() {
                // Java doesn't support nested functions; use lambdas
                int v = 1;
                java.util.function.Supplier<Integer> inner = () -> v + 1;
                java.util.function.Supplier<Integer> outer = () -> inner.get();
                => $^
                outer.get();
            }
        }
        $P { }
}

class Main {
    public static void main(String[] args) {
        System.out.println("TAP version 14");
        System.out.println("1..1");
        try {
            S s = @@S();
            s.e();
            System.out.println("ok 1 - nested_functions");
        } catch (Exception ex) {
            System.out.println("not ok 1 - nested_functions # " + ex);
        }
    }
}

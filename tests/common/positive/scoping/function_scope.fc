@@target c

// C helper function (replaces Python nested def)
static int f() {
    return 1;
}

@@system S {
    interface:
        e(): void

    machine:
        $A => $P {
            e() {
                => $^
                f();
            }
        }
        $P { }
}

int main() {
    printf("=== Test: function_scope ===\n");
    S* s = @@S();

    // Test that we can call e() without errors
    S_e(s);

    // Verify f() returns expected value
    int result = f();
    if (result != 1) {
        printf("FAIL: Expected f() to return 1, got %d\n", result);
        S_destroy(s);
        return 1;
    }

    printf("PASS: function_scope test completed successfully\n");
    S_destroy(s);
    return 0;
}

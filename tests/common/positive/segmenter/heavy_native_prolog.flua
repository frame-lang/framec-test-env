@@target lua

-- Test: Heavy native prolog and epilog with edge-case Lua syntax.
-- Verifies the segmenter correctly identifies @@system boundaries
-- when surrounded by complex native code.

-- Function that mentions "system" in comments (not @@)
local function log_calls(func)
    return function(...)
        print("Calling function")
        return func(...)
    end
end

-- Table with braces and Frame-like strings
local NativeHelper = {}
NativeHelper.__index = NativeHelper

function NativeHelper.new()
    local self = setmetatable({}, NativeHelper)
    self.data = {}
    return self
end

NativeHelper.TEMPLATE = [[
    {
        "@@target": "not_real",
        "-> $State": "just a string",
        "push$": true
    }
]]

function NativeHelper:process(data)
    -- Comment with -> $Transition and => $^ and push$
    local result = "processed"
    return result
end

-- Global with @@ in string
local GLOBAL_CONFIG = {
    description = "Config with @@system-like syntax",
    pattern = "-> $Start",
}

@@system HeavyNativeProlog {
    interface:
        run_test()

    machine:
        $Start {
            run_test() {
                local h = NativeHelper.new()
                local result = h:process(GLOBAL_CONFIG)
                if result ~= nil then
                    print("PASS: Heavy native prolog handled correctly")
                else
                    error("FAIL")
                end
            }
        }
}

-- Heavy epilog
local PostSystem = {}
PostSystem.__index = PostSystem

function PostSystem.new()
    local self = setmetatable({}, PostSystem)
    self.data = {["@@system"] = "in dict", ["-> $State"] = "in dict"}
    return self
end

function PostSystem:run()
    -- -> $NotATransition
    -- => $^
    return true
end

local s = @@HeavyNativeProlog()
s:run_test()
local p = PostSystem.new()
if not p:run() then
    error("epilog failed")
end
@@target erlang

%% Frame tokens inside Erlang comments should NOT be recognized as Frame syntax.

%% @@system FakeSystem { }
%% -> $FakeTransition
%% => $^
%% push$

@@system FrameTokensInComments {
    interface:
        run_test()

    machine:
        $Start {
            run_test() {
                % These comments contain Frame tokens — should be ignored
                % -> $FakeState
                % => $^
                % push$
                % pop$
                % $.var = 42
                % @@:return = 99
                ok
            }
        }
}
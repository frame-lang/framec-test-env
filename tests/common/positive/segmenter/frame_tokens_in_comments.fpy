@@target python_3

# Test: Frame tokens inside Python comments should NOT be recognized as Frame syntax.
# The segmenter must not treat commented-out Frame constructs as real.

# @@system FakeSystem { }
# @@target typescript
# -> $FakeTransition
# => $^
# push$
# pop$
# $.fake = 0
# @@:return = 42

@@system FrameTokensInComments {
    interface:
        run_test()

    machine:
        $Start {
            # -> $NotATransition
            # => $^
            # push$
            run_test() {
                # These comments contain Frame tokens — should be ignored
                # -> $FakeState
                # => $^
                # push$
                # pop$
                # $.var = 42
                # @@:return = 99
                x = 1  # -> $InlineComment
                y = 2  # @@system Inline { }
                print("PASS: Frame tokens in comments correctly ignored")
            }
        }
}

if __name__ == '__main__':
    s = @@FrameTokensInComments()
    s.run_test()

@@target typescript

// Test: Frame tokens inside TypeScript strings should NOT be recognized as Frame syntax.

@@system FrameTokensInStrings {
    interface:
        run_test()

    machine:
        $Start {
            run_test() {
                // Regular strings
                const a: string = "-> $FakeState";
                const b: string = '=> $^';
                const c: string = "push$ and pop$";
                const d: string = "$.fake_var = 42";
                const e: string = "@@target typescript";
                const f: string = "@@system NotReal { }";
                const g: string = "@@:return = 99";

                // Template literals
                const h: string = `-> $Transition in template`;
                const i: string = `@@system ${a} template`;
                const j: string = `
                    => $^
                    push$
                    @@system MultiLine { }
                `;

                console.log("PASS: Frame tokens in strings correctly ignored");
            }
        }
}

const s = new FrameTokensInStrings();
s.run_test();

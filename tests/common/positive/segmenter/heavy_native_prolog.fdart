@@target dart

// Test: Heavy native prolog and epilog with edge-case TypeScript syntax.

interface NativeInterface {
    process(data: Record<string, any>): String | null;
}

class NativeHelper implements NativeInterface {
    // Mentions @@system and -> $State in comments
    // These should NOT be parsed as Frame

    static TEMPLATE: String = "
    {
        "@@target": "not_real",
        "-> $State": "just a string",
        "push$": true
    }
    ";

    process(data: Record<string, any>): String | null {
        final result = jsonEncode({"key": "value with { braces }"});
        // Comment with -> $Transition and => $^ and push$
        return result;
    }
}

// Global with @@ in string
final GLOBAL_CONFIG: Record<string, string> = {
    "description": "Config with @@system-like syntax",
    "pattern": "-> $Start",
};

@@system HeavyNativeProlog {
    interface:
        run_test()

    machine:
        $Start {
            run_test() {
                final h = NativeHelper();
                final result = h.process(GLOBAL_CONFIG);
                if (result != null) {
                    print("PASS: Heavy native prolog handled correctly");
                } else {
                    throw Exception("FAIL");
                }
            }
        }
}

// Heavy epilog
class PostSystem {
    data: Record<string, string> = {"@@system": "in dict", "-> $State": "in dict"};

    run(): bool {
        // -> $NotATransition
        // => $^
        return true;
    }
}

final s = @@HeavyNativeProlog();
s.run_test();
final p = PostSystem();
if (!p.run()) { throw Exception("epilog failed"); }

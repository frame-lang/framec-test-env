@@target dart
import 'dart:convert';
// Test: Heavy native prolog and epilog with edge-case Dart syntax.

abstract class NativeInterface {
    String? process(Map<String, dynamic> data);
}

class NativeHelper implements NativeInterface {
    // Mentions @@system and -> $State in comments
    // These should NOT be parsed as Frame

    static final TEMPLATE = '''
    {
        "@@target": "not_real",
        "-> \$State": "just a string",
        "push\$": true
    }
    ''';

    @override
    String? process(Map<String, dynamic> data) {
        final result = jsonEncode({"key": "value with { braces }"});
        // Comment with -> $Transition and => $^ and push$
        return result;
    }
}

// Global with @@ in string
final Map<String, String> GLOBAL_CONFIG = {
    "description": "Config with @@system-like syntax",
    "pattern": "-> \$Start",
};

@@system HeavyNativeProlog {
    interface:
        run_test()

    machine:
        $Start {
            run_test() {
                final h = NativeHelper();
                final result = h.process(GLOBAL_CONFIG);
                if (result != null) {
                    print("PASS: Heavy native prolog handled correctly");
                } else {
                    throw Exception("FAIL");
                }
            }
        }
}

// Heavy epilog
class PostSystem {
    Map<String, String> data = {"@@system": "in dict", "-> \$State": "in dict"};

    bool run() {
        // -> $NotATransition
        // => $^
        return true;
    }
}

void main() {
    final s = @@HeavyNativeProlog();
    s.run_test();
    final p = PostSystem();
    if (!p.run()) { throw Exception("epilog failed"); }
}
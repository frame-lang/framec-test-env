@@target lua
@@system NestedBraces {
    interface:
        run_test()

    machine:
        $Start {
            run_test() {
                -- Dict with nested braces
                d = {"outer": {"inner": {"deep": 1}}}

                -- String containing braces
                s1 = "string with { braces }"
                s2 = "nested { { { braces } } }"
                s3 = '{"json": "in string"}'

                -- f-string with braces
                name = "world"
                s4 = "hello " .. tostring(name) .. " with " .. tostring({ escaped braces ) .. "}"
                s5 = tostring({'key': {d) .. "}}"

                -- Multi-level nesting
                result = {}
                for i in range(3):
                    result[str(i)] = {"level": i, "data": {"items": [1, 2, 3]}}

                if #result == 3 {
                    -- print
                } else {
                    -- print
                    error("runtime error")
                }
            }
        }
}

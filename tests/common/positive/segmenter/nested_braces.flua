@@target lua
@@system NestedBraces {
    interface:
        run_test()

    machine:
        $Start {
            run_test() {
                -- Table with nested braces
                local d = {outer = {inner = {deep = 1}}}

                -- String containing braces
                local s1 = "string with { braces }"
                local s2 = "nested { { { braces } } }"

                -- Multi-level nesting
                local result = {}
                result["0"] = {level = 0, data = {items = {1, 2, 3}}}
                result["1"] = {level = 1, data = {items = {1, 2, 3}}}
                result["2"] = {level = 2, data = {items = {1, 2, 3}}}
            }
        }
}
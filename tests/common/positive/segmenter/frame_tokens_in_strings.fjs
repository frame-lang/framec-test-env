// @@skip — Known bug: => $^ inside handler string triggers E403 (JS scanner issue)
@@target javascript

// Test: Frame tokens inside JavaScript strings should NOT be recognized as Frame syntax.

@@system FrameTokensInStrings {
    interface:
        run_test()

    machine:
        $Start {
            run_test() {
                // Regular strings
                const a = "-> $FakeState";
                const b = "=> $^";
                const c = "push$ and pop$";
                const d = "$.fake_var = 42";
                const e = "@@target javascript";
                const f = "@@system NotReal { }";
                const g = "@@:return = 99";

                // Template literals
                const h = `-> $Transition in template`;
                const i = `@@system ${a} template`;
                const j = `
                    => $^
                    push$
                    @@system MultiLine { }
                `;

                console.log("PASS: Frame tokens in strings correctly ignored");
            }
        }
}

const s = @@FrameTokensInStrings();
s.run_test();

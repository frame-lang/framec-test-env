@@target cpp_17

#include <iostream>
#include <string>
#include <cassert>

// Test: Frame tokens inside C++ comments should NOT be recognized as Frame syntax.

// @@system FakeSystem { }
// @@target python_3
// -> $FakeTransition
/* @@system BlockComment { } */
/*
 * -> $MultiLine
 * => $^
 * push$
 * @@target rust
 */

@@system FrameTokensInComments {
    interface:
        run_test()

    machine:
        $Start {
            run_test() {
                // -> $FakeState
                // => $^
                // push$
                /* -> $BlockTransition */
                /* @@:return = 99 */
                int x = 1; // -> $InlineComment
                printf("PASS: Frame tokens in comments correctly ignored\n");
            }
        }
}

int main() {
    FrameTokensInComments s;
    s.run_test();
    return 0;
}

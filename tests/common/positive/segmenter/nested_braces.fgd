@@target gdscript

# Test: Deeply nested braces and braces-in-strings should not confuse the body closer.

@@system NestedBraces {
    interface:
        run_test()

    machine:
        $Start {
            run_test() {
                # Dict with nested braces
                d = {"outer": {"inner": {"deep": 1}}}

                # String containing braces
                s1 = "string with { braces }"
                s2 = "nested { { { braces } } }"
                s3 = '{"json": "in string"}'

                # f-string with braces
                name = "world"
                s4 = "hello " + str(name) + " with { escaped braces }"
                s5 = "{'key': " + str(d) + "}"

                # Multi-level nesting
                result = {}
                for i in range(3):
                    result[str(i)] = {"level": i, "data": {"items": [1, 2, 3]}}

                if result.size() == 3:
                    print("PASS: Nested braces handled correctly")
                else:
                    print("FAIL: Wrong result count")
                    push_error("test failed")
            }
        }
}

func _ready():
    s = @@NestedBraces()
    s.run_test()

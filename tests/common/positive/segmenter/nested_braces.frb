@@[target("ruby")]

# Test: Deeply nested braces and braces-in-strings should not confuse the body closer.

@@system NestedBraces {
    interface:
        run_test()

    machine:
        $Start {
            run_test() {
                # Hash with nested braces
                d = {"outer" => {"inner" => {"deep" => 1}}}

                # String containing braces
                s1 = "string with { braces }"
                s2 = "nested { { { braces } } }"
                s3 = '{"json": "in string"}'

                # String interpolation with braces
                name = "world"
                s4 = "hello #{name} with braces"

                # Multi-level nesting
                result = {}
                3.times do |i|
                    result[i.to_s] = {"level" => i, "data" => {"items" => [1, 2, 3]}}
                end

                if result.length == 3
                    puts("PASS: Nested braces handled correctly")
                else
                    puts("FAIL: Wrong result count")
                    raise "test failed"
                end
            }
        }
}

s = @@NestedBraces()
s.run_test()

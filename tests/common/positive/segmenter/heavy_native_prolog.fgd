@@target gdscript
extends SceneTree

# Test: Heavy native prolog and epilog with edge-case syntax.
# Verifies the segmenter correctly identifies @@system boundaries
# when surrounded by complex native code.


# Function that mentions "system" and uses @ (not @@)
func log_message(msg: String) -> void:
    # Note the @ symbol is NOT @@
    print("Log: " + msg)

# Class with braces in strings and complex syntax
class NativeHelper:
    var TEMPLATE = '{"@@target": "not_real", "-> $State": "just a string", "push$": true}'

    func process(data: Dictionary) -> String:
        var result = JSON.stringify({"key": "value with braces"})
        # Comment with -> $Transition and => $^ and push$
        return result

    func method_with_log() -> String:
        return "logged"

# Global with @@ in string
var GLOBAL_CONFIG = {
    "description": "Config with @@system-like syntax",
    "pattern": "-> $Start",
}

@@system HeavyNativeProlog {
    interface:
        run_test()

    machine:
        $Start {
            run_test() {
                var result = JSON.stringify({"key": "value with braces"})
                if result != null:
                    print("PASS: Heavy native prolog handled correctly")
                else:
                    push_error("FAIL")
            }
        }
}

# Heavy epilog
class PostSystem:
    var data
    func _init():
        self.data = {"@@system": "in dict", "-> $State": "in dict"}

    func run() -> bool:
        # This mentions Frame constructs but is native code
        # -> $NotATransition
        # => $^
        return true

func epilog_function() -> bool:
    var p = PostSystem.new()
    return p.run()

func _init():
    var s = @@HeavyNativeProlog()
    s.run_test()
    assert(epilog_function() == true)
    quit()
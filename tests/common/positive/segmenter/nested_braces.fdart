@@target dart

// Test: Deeply nested braces and braces-in-strings should not confuse the body closer.

@@system NestedBraces {
    interface:
        run_test()

    machine:
        $Start {
            run_test() {
                // Object with nested braces
                final d: dynamic = {outer: {inner: {deep: 1}}};

                // String containing braces
                final s1: String = "string with { braces }";
                final s2: String = "nested { { { braces } } }";
                final s3: String = '{"json": "in string"}';

                // Template literal with braces
                final name: String = "world";
                final s4: String = "hello ${name} with { braces }";
                final s5: String = "${{key: "value"}}";

                // Multi-level nesting
                final result: dynamic = {};
                for (var i = 0; i < 3; i++) {
                    result[String(i)] = {level: i, data: {items: [1, 2, 3]}};
                }

                if (Object.keys(result).length == 3) {
                    print("PASS: Nested braces handled correctly");
                } else {
                    print("FAIL: Wrong result count");
                    throw Exception("test failed");
                }
            }
        }
}

final s = @@NestedBraces();
s.run_test();

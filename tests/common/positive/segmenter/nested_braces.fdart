@@target dart
// Test: Deeply nested braces and braces-in-strings should not confuse the body closer.

@@system NestedBraces {
    interface:
        run_test()

    machine:
        $Start {
            run_test() {
                // Map with nested braces
                final Map<String, dynamic> d = {"outer": {"inner": {"deep": 1}}};

                // String containing braces
                final s1 = "string with { braces }";
                final s2 = "nested { { { braces } } }";
                final s3 = '{"json": "in string"}';

                // String interpolation with braces
                final name = "world";
                final s4 = "hello ${name} with { braces }";

                // Multi-level nesting
                final Map<String, dynamic> result = {};
                for (var i = 0; i < 3; i++) {
                    result[i.toString()] = {"level": i, "data": {"items": [1, 2, 3]}};
                }

                if (result.keys.length == 3) {
                    print("PASS: Nested braces handled correctly");
                } else {
                    print("FAIL: Wrong result count");
                    throw Exception("test failed");
                }
            }
        }
}

void main() {
    final s = @@NestedBraces();
    s.run_test();
}
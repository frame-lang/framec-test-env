@@[target("c")]

// Test: Deeply nested braces and braces-in-strings should not confuse the body closer.

#include <stdio.h>
#include <string.h>

@@system NestedBraces {
    interface:
        run_test()

    machine:
        $Start {
            run_test() {
                // String containing braces
                const char* s1 = "string with { braces }";
                const char* s2 = "nested { { { braces } } }";
                const char* s3 = "{\"json\": \"in string\"}";

                // Nested blocks
                int count = 0;
                for (int i = 0; i < 3; i++) {
                    if (i > 0) {
                        if (i > 1) {
                            count += 1;
                        }
                    }
                    count += 1;
                }

                if (count == 4) {
                    printf("PASS: Nested braces handled correctly\n");
                } else {
                    printf("FAIL: Wrong count %d\n", count);
                    return;
                }
            }
        }
}

int main() {
    NestedBraces* s = @@NestedBraces();
    NestedBraces_run_test(s);
    NestedBraces_destroy(s);
    return 0;
}

@@target rust

// Test: Deeply nested braces and braces-in-strings should not confuse the body closer.

use std::collections::HashMap;

@@system NestedBraces {
    interface:
        run_test()

    machine:
        $Start {
            run_test() {
                // String containing braces
                let s1 = "string with { braces }";
                let s2 = "nested { { { braces } } }";
                let s3 = r#"{"json": "in string"}"#;

                // Nested blocks
                let mut count = 0;
                for i in 0..3 {
                    if i > 0 {
                        if i > 1 {
                            count += 1;
                        }
                    }
                    count += 1;
                }

                if count == 4 {
                    println!("PASS: Nested braces handled correctly");
                } else {
                    panic!("FAIL: Wrong count {}", count);
                }
            }
        }
}

fn main() {
    let mut s = NestedBraces::new();
    s.run_test();
}

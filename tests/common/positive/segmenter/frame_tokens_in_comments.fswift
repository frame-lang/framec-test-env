@@[target("swift")]

// Test: Frame tokens inside Swift comments should NOT be recognized as Frame syntax.

// @@system FakeSystem { }
// @@target python_3
// -> $FakeTransition
/* @@system BlockComment { } */
/*
 * -> $MultiLine
 * => $^
 * push$
 * @@target rust
 */

@@system FrameTokensInComments {
    interface:
        run_test()

    machine:
        $Start {
            run_test() {
                // -> $FakeState
                // => $^
                // push$
                /* -> $BlockTransition */
                /* @@:return = 99 */
                let x = 1 // -> $InlineComment
                print("PASS: Frame tokens in comments correctly ignored")
            }
        }
}

let s = @@FrameTokensInComments()
s.run_test()

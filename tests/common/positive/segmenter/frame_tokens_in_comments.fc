@@[target("c")]

// Test: Frame tokens inside C comments should NOT be recognized as Frame syntax.

#include <stdio.h>

// @@system FakeSystem { }
// @@target python_3
// -> $FakeTransition
/* @@system BlockComment { } */
/*
 * -> $MultiLine
 * => $^
 * push$
 * @@target rust
 */

@@system FrameTokensInComments {
    interface:
        run_test()

    machine:
        $Start {
            run_test() {
                // -> $FakeState
                // => $^
                /* push$ */
                /* @@:return = 99 */
                int x = 1; // -> $InlineComment
                printf("PASS: Frame tokens in comments correctly ignored\n");
            }
        }
}

int main() {
    FrameTokensInComments* s = @@FrameTokensInComments();
    FrameTokensInComments_run_test(s);
    FrameTokensInComments_destroy(s);
    return 0;
}

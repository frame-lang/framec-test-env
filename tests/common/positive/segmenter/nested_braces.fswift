@@[target("swift")]

// Test: Deeply nested braces and braces-in-strings should not confuse the body closer.

@@system NestedBraces {
    interface:
        run_test()

    machine:
        $Start {
            run_test() {
                // Dictionary with nested structure
                var d: [String: Any] = ["outer": ["inner": ["deep": 1]]]

                // String containing braces
                let s1 = "string with { braces }"
                let s2 = "nested { { { braces } } }"
                let s3 = "{\"json\": \"in string\"}"

                // String interpolation with braces
                let name = "world"
                let s4 = "hello \(name) with { braces }"

                // Multi-level nesting
                var result: [String: Any] = [:]
                for i in 0..<3 {
                    result[String(i)] = ["level": i, "data": ["items": [1, 2, 3]]]
                }

                if result.count == 3 {
                    print("PASS: Nested braces handled correctly")
                } else {
                    print("FAIL: Wrong result count")
                    fatalError("test failed")
                }
            }
        }
}

let s = @@NestedBraces()
s.run_test()

@@target rust

// Test: Frame tokens inside Rust comments should NOT be recognized as Frame syntax.

// @@system FakeSystem { }
// @@target python_3
// -> $FakeTransition
/* @@system BlockComment { } */
/*
 * -> $MultiLine
 * => $^
 * push$
 * @@target c
 */

@@system FrameTokensInComments {
    interface:
        run_test()

    machine:
        $Start {
            run_test() {
                // -> $FakeState
                // => $^
                /* push$ */
                /* @@:return = 99 */
                let x: i32 = 1; // -> $InlineComment
                println!("PASS: Frame tokens in comments correctly ignored");
            }
        }
}

fn main() {
    let mut s = @@FrameTokensInComments();
    s.run_test();
}

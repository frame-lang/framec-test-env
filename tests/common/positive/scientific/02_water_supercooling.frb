@@[target("ruby")]

# Cookbook 73: Water with Supercooling

@@system Water {
    interface:
        cool(delta)
        heat(delta)
        nucleate()
        shake()
        temperature()
        phase()

    machine:
        $Liquid {
            cool(delta) {
                @temp = @temp - delta
                if @temp < 0.0
                    -> $Supercooled
                end
            }
            heat(delta) { @temp = @temp + delta }
            temperature() { @@:(@temp) }
            phase() { @@:("liquid") }
        }

        $Supercooled {
            cool(delta) {
                @temp = @temp - delta
                if @temp <= -42.0
                    -> $Ice
                end
            }
            heat(delta) {
                @temp = @temp + delta
                if @temp >= 0.0
                    -> $Liquid
                end
            }
            nucleate() { -> $Ice }
            shake() { -> $Ice }
            temperature() { @@:(@temp) }
            phase() { @@:("supercooled liquid") }
        }

        $Ice {
            heat(delta) {
                @temp = @temp + delta
                if @temp >= 0.0
                    -> $Liquid
                end
            }
            cool(delta) { @temp = @temp - delta }
            temperature() { @@:(@temp) }
            phase() { @@:("ice") }
        }

    domain:
        temp = 25.0
}

def check(label, actual, expected)
    if actual != expected
        puts "FAIL: #{label} expected '#{expected}', got '#{actual}'"
        exit(1)
    end
end
def check_f(label, actual, expected)
    if (actual - expected).abs > 1e-9
        puts "FAIL: #{label} expected #{expected}, got #{actual}"
        exit(1)
    end
end

w = @@Water()
check("start", w.phase, "liquid")
w.cool(30.0)
check("after big cool", w.phase, "supercooled liquid")
w.shake
check("shaken", w.phase, "ice")

w2 = @@Water()
w2.cool(30.0)
check("w2 supercooled", w2.phase, "supercooled liquid")
check_f("same temp", w.temperature, w2.temperature)
if w.phase == w2.phase
    puts "FAIL: phases should differ"
    exit(1)
end

w3 = @@Water()
w3.cool(30.0)
w3.nucleate
check("nucleated", w3.phase, "ice")

w4 = @@Water()
w4.cool(30.0)
check("w4 supercooled", w4.phase, "supercooled liquid")
w4.cool(40.0)
check("deep cool", w4.phase, "ice")
w4.heat(50.0)
check("melted", w4.phase, "liquid")

w5 = @@Water()
w5.shake
check("liquid shake ignored", w5.phase, "liquid")
w6 = @@Water()
w6.cool(30.0)
w6.cool(40.0)
check("w6 is ice", w6.phase, "ice")
w6.shake
check("ice shake ignored", w6.phase, "ice")

puts "PASS: water_supercooling"

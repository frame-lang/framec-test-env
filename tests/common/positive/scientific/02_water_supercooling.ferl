@@[target("erlang")]

%% Cookbook 73: Water with Supercooling

@@system Water {
    interface:
        cool(delta: float)
        heat(delta: float)
        nucleate()
        shake()
        temperature(): float
        phase(): string

    machine:
        $Liquid {
            cool(delta: float) {
                self.temp = self.temp - Delta,
                case self.temp < 0.0 of
                    true -> -> $Supercooled;
                    false -> ok
                end
            }
            heat(delta: float) { self.temp = self.temp + Delta }
            temperature(): float { @@:(self.temp) }
            phase(): string { @@:("liquid") }
        }

        $Supercooled {
            cool(delta: float) {
                self.temp = self.temp - Delta,
                case self.temp =< -42.0 of
                    true -> -> $Ice;
                    false -> ok
                end
            }
            heat(delta: float) {
                self.temp = self.temp + Delta,
                case self.temp >= 0.0 of
                    true -> -> $Liquid;
                    false -> ok
                end
            }
            nucleate() { -> $Ice }
            shake() { -> $Ice }
            temperature(): float { @@:(self.temp) }
            phase(): string { @@:("supercooled liquid") }
        }

        $Ice {
            heat(delta: float) {
                self.temp = self.temp + Delta,
                case self.temp >= 0.0 of
                    true -> -> $Liquid;
                    false -> ok
                end
            }
            cool(delta: float) { self.temp = self.temp - Delta }
            temperature(): float { @@:(self.temp) }
            phase(): string { @@:("ice") }
        }

    domain:
        temp: float = 25.0
}

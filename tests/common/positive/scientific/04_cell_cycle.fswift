@@[target("swift")]

// Cookbook 75: Cell Cycle with Checkpoints

import Foundation

@@system CellCycle {
    interface:
        tick()
        dna_damage_detected()
        damage_repaired()
        nutrients_low()
        nutrients_restored()
        spindle_misaligned()
        spindle_aligned()
        apoptosis_signal()
        phase(): String

    machine:
        $G1 => $Cycling {
            $>() { self.mass = self.mass * 1.1 }
            tick() {
                if self.mass >= self.g1_threshold {
                    -> $S
                }
            }
            phase(): String { @@:("G1") }
            => $^
        }

        $S => $Cycling {
            $>() { self.dna_content = 1.0 }
            tick() {
                self.dna_content = self.dna_content + 0.1
                if self.dna_content >= 2.0 {
                    self.dna_content = 2.0
                    -> $G2
                }
            }
            phase(): String { @@:("S") }
            => $^
        }

        $G2 => $Cycling {
            tick() {
                self.g2_counter = self.g2_counter + 1
                if self.g2_counter >= 3 {
                    self.g2_counter = 0
                    -> $M
                }
            }
            phase(): String { @@:("G2") }
            => $^
        }

        $M => $Cycling {
            tick() {
                self.mass = self.mass / 2.0
                self.dna_content = 1.0
                -> $G1
            }
            spindle_misaligned() { -> $M_Arrested }
            phase(): String { @@:("M") }
            => $^
        }

        $Cycling {
            dna_damage_detected() { -> $G1_Arrested }
            nutrients_low() { -> $G0_Quiescent }
            apoptosis_signal() { -> $Apoptotic }
        }

        $G1_Arrested {
            damage_repaired() { -> $G1 }
            apoptosis_signal() { -> $Apoptotic }
            phase(): String { @@:("G1-arrested") }
        }

        $M_Arrested {
            spindle_aligned() { -> $M }
            apoptosis_signal() { -> $Apoptotic }
            phase(): String { @@:("M-arrested") }
        }

        $G0_Quiescent {
            nutrients_restored() { -> $G1 }
            phase(): String { @@:("G0") }
        }

        $Apoptotic {
            phase(): String { @@:("apoptotic") }
        }

    domain:
        mass: Double = 1.0
        g1_threshold: Double = 1.8
        dna_content: Double = 1.0
        g2_counter: Int = 0
}

func check(_ label: String, _ actual: String, _ expected: String) {
    if actual != expected {
        print("FAIL: \(label) expected '\(expected)', got '\(actual)'")
        exit(1)
    }
}

let c = @@CellCycle()
check("initial G1", c.phase() as! String, "G1")
c.dna_damage_detected()
check("arrested on damage", c.phase() as! String, "G1-arrested")
c.tick()
check("tick while arrested is a no-op", c.phase() as! String, "G1-arrested")
c.damage_repaired()
check("repaired -> G1", c.phase() as! String, "G1")
c.nutrients_low()
check("quiescent on starve", c.phase() as! String, "G0")
c.nutrients_restored()
check("nourished -> G1", c.phase() as! String, "G1")
c.apoptosis_signal()
check("apoptotic", c.phase() as! String, "apoptotic")
c.tick()
c.nutrients_restored()
c.damage_repaired()
check("apoptotic absorbs everything", c.phase() as! String, "apoptotic")

let c2 = @@CellCycle()
c2.spindle_misaligned()
check("spindle signal in G1 ignored", c2.phase() as! String, "G1")

print("PASS: cell_cycle")

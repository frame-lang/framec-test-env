@@[target("python_3")]

# Cookbook 75: Cell Cycle with Checkpoints
# HSM: $Cycling is the abstract parent holding damage/nutrient/
# apoptosis handlers; concrete phases G1/S/G2/M forward via `=> $^`.
# Arrest states are dispatch stop-signs.

@@system CellCycle {
    interface:
        tick()
        dna_damage_detected()
        damage_repaired()
        nutrients_low()
        nutrients_restored()
        spindle_misaligned()
        spindle_aligned()
        apoptosis_signal()
        phase(): str

    machine:
        $G1 => $Cycling {
            $>() { self.mass = self.mass * 1.1 }
            tick() {
                if self.mass >= self.g1_threshold:
                    -> $S
            }
            phase(): str { @@:("G1") }
            => $^
        }

        $S => $Cycling {
            $>() { self.dna_content = 1.0 }
            tick() {
                self.dna_content = self.dna_content + 0.1
                if self.dna_content >= 2.0:
                    self.dna_content = 2.0
                    -> $G2
            }
            phase(): str { @@:("S") }
            => $^
        }

        $G2 => $Cycling {
            tick() {
                self.g2_counter = self.g2_counter + 1
                if self.g2_counter >= 3:
                    self.g2_counter = 0
                    -> $M
            }
            phase(): str { @@:("G2") }
            => $^
        }

        $M => $Cycling {
            tick() {
                self.mass = self.mass / 2.0
                self.dna_content = 1.0
                -> $G1
            }
            spindle_misaligned() { -> $M_Arrested }
            phase(): str { @@:("M") }
            => $^
        }

        $Cycling {
            dna_damage_detected() { -> $G1_Arrested }
            nutrients_low() { -> $G0_Quiescent }
            apoptosis_signal() { -> $Apoptotic }
        }

        $G1_Arrested {
            damage_repaired() { -> $G1 }
            apoptosis_signal() { -> $Apoptotic }
            phase(): str { @@:("G1-arrested") }
        }

        $M_Arrested {
            spindle_aligned() { -> $M }
            apoptosis_signal() { -> $Apoptotic }
            phase(): str { @@:("M-arrested") }
        }

        $G0_Quiescent {
            nutrients_restored() { -> $G1 }
            phase(): str { @@:("G0") }
        }

        $Apoptotic {
            phase(): str { @@:("apoptotic") }
        }

    domain:
        mass: float = 1.0
        g1_threshold: float = 1.8
        dna_content: float = 1.0
        g2_counter: int = 0
}


def check(label, actual, expected):
    if actual != expected:
        print(f"FAIL: {label} expected '{expected}', got '{actual}'")
        import sys
        sys.exit(1)


if __name__ == '__main__':
    c = @@CellCycle()

    # Initial state is $G1 (first declared state in machine).
    # G1's $>() ran once at init: mass 1.0 -> 1.1.
    check("initial G1", c.phase(), "G1")

    # Drive G1 toward S: needs mass >= 1.8. Each tick does nothing to
    # mass directly in $G1; the $>() firing on re-entry grows it.
    # In the original recipe mass only grows on G1 entry, so with
    # entry mass 1.1 we'd need to re-enter G1 several times. For a
    # deterministic single-pass test we exercise the damage checkpoint
    # via the HSM parent instead, which works even from the first G1.

    # TC1: DNA damage from G1 propagates up to $Cycling via `=> $^`
    # and arrests the cycle at $G1_Arrested.
    c.dna_damage_detected()
    check("arrested on damage", c.phase(), "G1-arrested")

    # TC2: While arrested, tick() is not forwarded anywhere (arrest
    # states don't declare tick()), so the cell cannot advance out.
    c.tick()
    check("tick while arrested is a no-op", c.phase(), "G1-arrested")

    # TC3: damage_repaired returns to G1 (re-fires G1:$> enter).
    c.damage_repaired()
    check("repaired -> G1", c.phase(), "G1")

    # TC4: Nutrients low anywhere in Cycling -> G0 quiescent
    c.nutrients_low()
    check("quiescent on starve", c.phase(), "G0")

    # TC5: nutrients_restored returns to G1
    c.nutrients_restored()
    check("nourished -> G1", c.phase(), "G1")

    # TC6: apoptosis is terminal — no handler fires from $Apoptotic.
    c.apoptosis_signal()
    check("apoptotic", c.phase(), "apoptotic")
    c.tick()
    c.nutrients_restored()
    c.damage_repaired()
    check("apoptotic absorbs everything", c.phase(), "apoptotic")

    # TC7: spindle_misaligned only handled in $M, not in $G1.
    # From $G1 it should be silently ignored.
    c2 = @@CellCycle()
    c2.spindle_misaligned()
    check("spindle signal in G1 ignored", c2.phase(), "G1")

    print("PASS: cell_cycle")

@@[target("go")]

// Cookbook 75: Cell Cycle with Checkpoints

package main

import (
    "fmt"
    "os"
)

@@system CellCycle {
    interface:
        tick()
        dna_damage_detected()
        damage_repaired()
        nutrients_low()
        nutrients_restored()
        spindle_misaligned()
        spindle_aligned()
        apoptosis_signal()
        phase(): string

    machine:
        $G1 => $Cycling {
            $>() { s.mass = s.mass * 1.1 }
            tick() {
                if s.mass >= s.g1_threshold {
                    -> $S
                }
            }
            phase(): string { @@:("G1") }
            => $^
        }

        $S => $Cycling {
            $>() { s.dna_content = 1.0 }
            tick() {
                s.dna_content = s.dna_content + 0.1
                if s.dna_content >= 2.0 {
                    s.dna_content = 2.0
                    -> $G2
                }
            }
            phase(): string { @@:("S") }
            => $^
        }

        $G2 => $Cycling {
            tick() {
                s.g2_counter = s.g2_counter + 1
                if s.g2_counter >= 3 {
                    s.g2_counter = 0
                    -> $M
                }
            }
            phase(): string { @@:("G2") }
            => $^
        }

        $M => $Cycling {
            tick() {
                s.mass = s.mass / 2.0
                s.dna_content = 1.0
                -> $G1
            }
            spindle_misaligned() { -> $M_Arrested }
            phase(): string { @@:("M") }
            => $^
        }

        $Cycling {
            dna_damage_detected() { -> $G1_Arrested }
            nutrients_low() { -> $G0_Quiescent }
            apoptosis_signal() { -> $Apoptotic }
        }

        $G1_Arrested {
            damage_repaired() { -> $G1 }
            apoptosis_signal() { -> $Apoptotic }
            phase(): string { @@:("G1-arrested") }
        }

        $M_Arrested {
            spindle_aligned() { -> $M }
            apoptosis_signal() { -> $Apoptotic }
            phase(): string { @@:("M-arrested") }
        }

        $G0_Quiescent {
            nutrients_restored() { -> $G1 }
            phase(): string { @@:("G0") }
        }

        $Apoptotic {
            phase(): string { @@:("apoptotic") }
        }

    domain:
        mass: float64 = 1.0
        g1_threshold: float64 = 1.8
        dna_content: float64 = 1.0
        g2_counter: int = 0
}

func check(label, actual, expected string) {
    if actual != expected {
        fmt.Printf("FAIL: %s expected '%s', got '%s'\n", label, expected, actual)
        os.Exit(1)
    }
}

func main() {
    c := @@CellCycle()
    check("initial G1", c.phase().(string), "G1")
    c.dna_damage_detected()
    check("arrested on damage", c.phase().(string), "G1-arrested")
    c.tick()
    check("tick while arrested is a no-op", c.phase().(string), "G1-arrested")
    c.damage_repaired()
    check("repaired -> G1", c.phase().(string), "G1")
    c.nutrients_low()
    check("quiescent on starve", c.phase().(string), "G0")
    c.nutrients_restored()
    check("nourished -> G1", c.phase().(string), "G1")
    c.apoptosis_signal()
    check("apoptotic", c.phase().(string), "apoptotic")
    c.tick()
    c.nutrients_restored()
    c.damage_repaired()
    check("apoptotic absorbs everything", c.phase().(string), "apoptotic")

    c2 := @@CellCycle()
    c2.spindle_misaligned()
    check("spindle signal in G1 ignored", c2.phase().(string), "G1")

    fmt.Println("PASS: cell_cycle")
}

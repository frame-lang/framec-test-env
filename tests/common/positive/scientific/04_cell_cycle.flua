@@[target("lua")]

-- Cookbook 75: Cell Cycle with Checkpoints

@@system CellCycle {
    interface:
        tick()
        dna_damage_detected()
        damage_repaired()
        nutrients_low()
        nutrients_restored()
        spindle_misaligned()
        spindle_aligned()
        apoptosis_signal()
        phase()

    machine:
        $G1 => $Cycling {
            $>() { self.mass = self.mass * 1.1 }
            tick() {
                if self.mass >= self.g1_threshold then
                    -> $S
                end
            }
            phase() { @@:("G1") }
            => $^
        }

        $S => $Cycling {
            $>() { self.dna_content = 1.0 }
            tick() {
                self.dna_content = self.dna_content + 0.1
                if self.dna_content >= 2.0 then
                    self.dna_content = 2.0
                    -> $G2
                end
            }
            phase() { @@:("S") }
            => $^
        }

        $G2 => $Cycling {
            tick() {
                self.g2_counter = self.g2_counter + 1
                if self.g2_counter >= 3 then
                    self.g2_counter = 0
                    -> $M
                end
            }
            phase() { @@:("G2") }
            => $^
        }

        $M => $Cycling {
            tick() {
                self.mass = self.mass / 2.0
                self.dna_content = 1.0
                -> $G1
            }
            spindle_misaligned() { -> $M_Arrested }
            phase() { @@:("M") }
            => $^
        }

        $Cycling {
            dna_damage_detected() { -> $G1_Arrested }
            nutrients_low() { -> $G0_Quiescent }
            apoptosis_signal() { -> $Apoptotic }
        }

        $G1_Arrested {
            damage_repaired() { -> $G1 }
            apoptosis_signal() { -> $Apoptotic }
            phase() { @@:("G1-arrested") }
        }

        $M_Arrested {
            spindle_aligned() { -> $M }
            apoptosis_signal() { -> $Apoptotic }
            phase() { @@:("M-arrested") }
        }

        $G0_Quiescent {
            nutrients_restored() { -> $G1 }
            phase() { @@:("G0") }
        }

        $Apoptotic {
            phase() { @@:("apoptotic") }
        }

    domain:
        mass = 1.0
        g1_threshold = 1.8
        dna_content = 1.0
        g2_counter = 0
}

local function check(label, actual, expected)
    if actual ~= expected then
        print("FAIL: " .. label .. " expected '" .. tostring(expected) .. "', got '" .. tostring(actual) .. "'")
        os.exit(1)
    end
end

local c = @@CellCycle()
check("initial G1", c:phase(), "G1")
c:dna_damage_detected()
check("arrested on damage", c:phase(), "G1-arrested")
c:tick()
check("tick while arrested is a no-op", c:phase(), "G1-arrested")
c:damage_repaired()
check("repaired -> G1", c:phase(), "G1")
c:nutrients_low()
check("quiescent on starve", c:phase(), "G0")
c:nutrients_restored()
check("nourished -> G1", c:phase(), "G1")
c:apoptosis_signal()
check("apoptotic", c:phase(), "apoptotic")
c:tick()
c:nutrients_restored()
c:damage_repaired()
check("apoptotic absorbs everything", c:phase(), "apoptotic")

local c2 = @@CellCycle()
c2:spindle_misaligned()
check("spindle signal in G1 ignored", c2:phase(), "G1")

print("PASS: cell_cycle")

@@[target("java")]

// Cookbook 79: Titration Protocol

@@system Titration {
    interface:
        add_drop(volume_mL: double)
        observe_color(color: String)
        record_endpoint()
        new_trial()
        result_mL(): double = 0.0
        status(): String
        volume_mL(): double

    machine:
        $Setup {
            add_drop(volume_mL: double) {
                this.volume = 0.0;
                -> $Titrating
            }
            volume_mL(): double { @@:(this.volume) }
            status(): String { @@:("setup") }
        }

        $Titrating {
            add_drop(volume_mL: double) { this.volume = this.volume + volume_mL; }
            observe_color(color: String) {
                if (color.equals("pink")) {
                    -> $NearEndpoint
                }
            }
            volume_mL(): double { @@:(this.volume) }
            status(): String { @@:("titrating") }
        }

        $NearEndpoint {
            add_drop(volume_mL: double) { this.volume = this.volume + volume_mL; }
            observe_color(color: String) {
                if (color.equals("clear")) {
                    -> $Titrating
                }
            }
            record_endpoint() { -> $Complete }
            volume_mL(): double { @@:(this.volume) }
            status(): String { @@:("near endpoint") }
        }

        $Complete {
            new_trial() {
                this.volume = 0.0;
                -> $Setup
            }
            result_mL(): double { @@:(this.volume) }
            volume_mL(): double { @@:(this.volume) }
            status(): String { @@:("complete") }
        }

    domain:
        volume: double = 0.0
}

public class Titration08Test {
    static void check(String label, String actual, String expected) {
        if (!actual.equals(expected)) {
            System.out.println("FAIL: " + label + " expected '" + expected + "', got '" + actual + "'");
            System.exit(1);
        }
    }
    static void checkF(String label, double actual, double expected) {
        if (Math.abs(actual - expected) > 1e-9) {
            System.out.println("FAIL: " + label + " expected " + expected + ", got " + actual);
            System.exit(1);
        }
    }

    public static void main(String[] args) {
        Titration t = @@Titration();
        check("start setup", (String) t.status(), "setup");
        t.add_drop(1.0);
        check("titrating", (String) t.status(), "titrating");
        checkF("volume zeroed on first", (double) t.volume_mL(), 0.0);
        t.add_drop(5.0);
        t.add_drop(3.0);
        checkF("accumulating", (double) t.volume_mL(), 8.0);
        t.observe_color("pink");
        check("near endpoint", (String) t.status(), "near endpoint");
        t.observe_color("clear");
        check("back to titrating", (String) t.status(), "titrating");
        t.observe_color("pink");
        check("near endpoint 2", (String) t.status(), "near endpoint");
        t.add_drop(0.05);
        t.record_endpoint();
        check("complete", (String) t.status(), "complete");
        checkF("recorded volume", (double) t.result_mL(), 8.05);
        t.add_drop(10.0);
        checkF("endpoint locked", (double) t.result_mL(), 8.05);
        t.add_drop(5.0);
        checkF("endpoint still locked", (double) t.result_mL(), 8.05);
        t.observe_color("pink");
        t.record_endpoint();
        checkF("still locked after ignored events", (double) t.result_mL(), 8.05);
        t.new_trial();
        check("new trial back to setup", (String) t.status(), "setup");
        checkF("volume cleared", (double) t.volume_mL(), 0.0);
        t.add_drop(2.0);
        t.add_drop(1.5);
        t.observe_color("pink");
        t.record_endpoint();
        checkF("second endpoint", (double) t.result_mL(), 1.5);
        System.out.println("PASS: titration");
    }
}

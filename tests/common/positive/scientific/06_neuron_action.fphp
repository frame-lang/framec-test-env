@@[target("php")]

// Cookbook 77: Neuron Action Potential

@@system Neuron {
    interface:
        stimulate(input)
        tick()
        voltage()
        phase()

    machine:
        $Resting {
            stimulate(input) {
                $this->v = $this->v + $input;
                if ($this->v >= $this->threshold) {
                    -> $Depolarizing
                }
            }
            tick() { $this->v = $this->v + ($this->v_rest - $this->v) * 0.2; }
            voltage() { @@:($this->v) }
            phase() { @@:("resting") }
        }

        $Depolarizing {
            $>() { $this->v = $this->v_peak; }
            tick() { -> $Repolarizing }
            voltage() { @@:($this->v) }
            phase() { @@:("spike") }
        }

        $Repolarizing {
            tick() {
                $this->v = $this->v_hyper;
                -> $Refractory
            }
            voltage() { @@:($this->v) }
            phase() { @@:("repolarizing") }
        }

        $Refractory {
            stimulate(input) { }
            tick() {
                $this->ref_ticks = $this->ref_ticks + 1;
                if ($this->ref_ticks >= 3) {
                    $this->ref_ticks = 0;
                    -> $Resting
                }
            }
            voltage() { @@:($this->v) }
            phase() { @@:("refractory") }
        }

    domain:
        v = -70.0
        v_rest = -70.0
        v_peak = 40.0
        v_hyper = -80.0
        threshold = -55.0
        ref_ticks = 0
}

function check($label, $actual, $expected) {
    if ($actual !== $expected) {
        echo "FAIL: $label expected '$expected', got '$actual'\n";
        exit(1);
    }
}
function check_f($label, $actual, $expected) {
    if (abs($actual - $expected) > 1e-9) {
        echo "FAIL: $label expected $expected, got $actual\n";
        exit(1);
    }
}

$n = @@Neuron();
check("start resting", $n->phase(), "resting");
check_f("start voltage", $n->voltage(), -70.0);
$n->stimulate(5.0);
check("sub-threshold stays resting", $n->phase(), "resting");
check_f("sub-threshold voltage", $n->voltage(), -65.0);
$n->stimulate(5.0);
check("still resting", $n->phase(), "resting");
$n->stimulate(6.0);
check("spike", $n->phase(), "spike");
check_f("peak voltage", $n->voltage(), 40.0);
$n->tick();
check("repolarizing", $n->phase(), "repolarizing");
$n->tick();
check("refractory", $n->phase(), "refractory");
check_f("hyperpolarized", $n->voltage(), -80.0);
$n->stimulate(100.0);
check("refractory absorbs stim", $n->phase(), "refractory");
check_f("refractory voltage unchanged", $n->voltage(), -80.0);
$n->tick();
check("still refractory t+1", $n->phase(), "refractory");
$n->tick();
check("still refractory t+2", $n->phase(), "refractory");
$n->tick();
check("resting after t+3", $n->phase(), "resting");
$n->stimulate(30.0);
check("second spike", $n->phase(), "spike");
echo "PASS: neuron_action\n";

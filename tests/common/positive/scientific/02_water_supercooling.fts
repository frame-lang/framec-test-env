@@[target("typescript")]

// Cookbook 73: Water with Supercooling

@@system Water {
    interface:
        cool(delta: number)
        heat(delta: number)
        nucleate()
        shake()
        temperature(): number
        phase(): string

    machine:
        $Liquid {
            cool(delta: number) {
                this.temp = this.temp - delta;
                if (this.temp < 0.0) {
                    -> $Supercooled
                }
            }
            heat(delta: number) { this.temp = this.temp + delta; }
            temperature(): number { @@:(this.temp) }
            phase(): string { @@:("liquid") }
        }

        $Supercooled {
            cool(delta: number) {
                this.temp = this.temp - delta;
                if (this.temp <= -42.0) {
                    -> $Ice
                }
            }
            heat(delta: number) {
                this.temp = this.temp + delta;
                if (this.temp >= 0.0) {
                    -> $Liquid
                }
            }
            nucleate() { -> $Ice }
            shake() { -> $Ice }
            temperature(): number { @@:(this.temp) }
            phase(): string { @@:("supercooled liquid") }
        }

        $Ice {
            heat(delta: number) {
                this.temp = this.temp + delta;
                if (this.temp >= 0.0) {
                    -> $Liquid
                }
            }
            cool(delta: number) { this.temp = this.temp - delta; }
            temperature(): number { @@:(this.temp) }
            phase(): string { @@:("ice") }
        }

    domain:
        temp: number = 25.0
}

function check(label: string, actual: any, expected: any): void {
    if (actual !== expected) {
        console.log("FAIL: " + label + " expected '" + expected + "', got '" + actual + "'");
        process.exit(1);
    }
}
function checkF(label: string, actual: number, expected: number): void {
    if (Math.abs(actual - expected) > 1e-9) {
        console.log("FAIL: " + label + " expected " + expected + ", got " + actual);
        process.exit(1);
    }
}

const w = @@Water();
check("start", w.phase(), "liquid");
w.cool(30.0);
check("after big cool", w.phase(), "supercooled liquid");
w.shake();
check("shaken", w.phase(), "ice");

const w2 = @@Water();
w2.cool(30.0);
check("w2 supercooled", w2.phase(), "supercooled liquid");
checkF("same temp", w.temperature(), w2.temperature());
if (w.phase() === w2.phase()) {
    console.log("FAIL: phases should differ");
    process.exit(1);
}

const w3 = @@Water();
w3.cool(30.0);
w3.nucleate();
check("nucleated", w3.phase(), "ice");

const w4 = @@Water();
w4.cool(30.0);
check("w4 supercooled", w4.phase(), "supercooled liquid");
w4.cool(40.0);
check("deep cool", w4.phase(), "ice");
w4.heat(50.0);
check("melted", w4.phase(), "liquid");

const w5 = @@Water();
w5.shake();
check("liquid shake ignored", w5.phase(), "liquid");
const w6 = @@Water();
w6.cool(30.0);
w6.cool(40.0);
check("w6 is ice", w6.phase(), "ice");
w6.shake();
check("ice shake ignored", w6.phase(), "ice");

console.log("PASS: water_supercooling");

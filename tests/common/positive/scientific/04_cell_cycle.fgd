@@[target("gdscript")]

# Cookbook 75: Cell Cycle with Checkpoints

@@system CellCycle : RefCounted {
    interface:
        tick()
        dna_damage_detected()
        damage_repaired()
        nutrients_low()
        nutrients_restored()
        spindle_misaligned()
        spindle_aligned()
        apoptosis_signal()
        phase(): String

    machine:
        $G1 => $Cycling {
            $>() { self.mass = self.mass * 1.1 }
            tick() {
                if self.mass >= self.g1_threshold:
                    -> $S
            }
            phase(): String { @@:("G1") }
            => $^
        }

        $S => $Cycling {
            $>() { self.dna_content = 1.0 }
            tick() {
                self.dna_content = self.dna_content + 0.1
                if self.dna_content >= 2.0:
                    self.dna_content = 2.0
                    -> $G2
            }
            phase(): String { @@:("S") }
            => $^
        }

        $G2 => $Cycling {
            tick() {
                self.g2_counter = self.g2_counter + 1
                if self.g2_counter >= 3:
                    self.g2_counter = 0
                    -> $M
            }
            phase(): String { @@:("G2") }
            => $^
        }

        $M => $Cycling {
            tick() {
                self.mass = self.mass / 2.0
                self.dna_content = 1.0
                -> $G1
            }
            spindle_misaligned() { -> $M_Arrested }
            phase(): String { @@:("M") }
            => $^
        }

        $Cycling {
            dna_damage_detected() { -> $G1_Arrested }
            nutrients_low() { -> $G0_Quiescent }
            apoptosis_signal() { -> $Apoptotic }
        }

        $G1_Arrested {
            damage_repaired() { -> $G1 }
            apoptosis_signal() { -> $Apoptotic }
            phase(): String { @@:("G1-arrested") }
        }

        $M_Arrested {
            spindle_aligned() { -> $M }
            apoptosis_signal() { -> $Apoptotic }
            phase(): String { @@:("M-arrested") }
        }

        $G0_Quiescent {
            nutrients_restored() { -> $G1 }
            phase(): String { @@:("G0") }
        }

        $Apoptotic {
            phase(): String { @@:("apoptotic") }
        }

    domain:
        mass: float = 1.0
        g1_threshold: float = 1.8
        dna_content: float = 1.0
        g2_counter: int = 0
}

func check_str(label: String, actual: String, expected: String) -> void:
    if actual != expected:
        print("FAIL: %s expected '%s', got '%s'" % [label, expected, actual])
        quit(1)

func _init() -> void:
    var c = @@CellCycle()
    check_str("initial G1", c.phase(), "G1")
    c.dna_damage_detected()
    check_str("arrested on damage", c.phase(), "G1-arrested")
    c.tick()
    check_str("tick while arrested is a no-op", c.phase(), "G1-arrested")
    c.damage_repaired()
    check_str("repaired -> G1", c.phase(), "G1")
    c.nutrients_low()
    check_str("quiescent on starve", c.phase(), "G0")
    c.nutrients_restored()
    check_str("nourished -> G1", c.phase(), "G1")
    c.apoptosis_signal()
    check_str("apoptotic", c.phase(), "apoptotic")
    c.tick()
    c.nutrients_restored()
    c.damage_repaired()
    check_str("apoptotic absorbs everything", c.phase(), "apoptotic")

    var c2 = @@CellCycle()
    c2.spindle_misaligned()
    check_str("spindle signal in G1 ignored", c2.phase(), "G1")

    print("PASS: cell_cycle")
    quit(0)

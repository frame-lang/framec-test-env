@@[target("c")]

// Cookbook 75: Cell Cycle with Checkpoints

@@system CellCycle {
    interface:
        tick()
        dna_damage_detected()
        damage_repaired()
        nutrients_low()
        nutrients_restored()
        spindle_misaligned()
        spindle_aligned()
        apoptosis_signal()
        phase(): string

    machine:
        $G1 => $Cycling {
            $>() { self->mass = self->mass * 1.1; }
            tick() {
                if (self->mass >= self->g1_threshold) {
                    -> $S
                }
            }
            phase(): string { @@:("G1") }
            => $^
        }

        $S => $Cycling {
            $>() { self->dna_content = 1.0; }
            tick() {
                self->dna_content = self->dna_content + 0.1;
                if (self->dna_content >= 2.0) {
                    self->dna_content = 2.0;
                    -> $G2
                }
            }
            phase(): string { @@:("S") }
            => $^
        }

        $G2 => $Cycling {
            tick() {
                self->g2_counter = self->g2_counter + 1;
                if (self->g2_counter >= 3) {
                    self->g2_counter = 0;
                    -> $M
                }
            }
            phase(): string { @@:("G2") }
            => $^
        }

        $M => $Cycling {
            tick() {
                self->mass = self->mass / 2.0;
                self->dna_content = 1.0;
                -> $G1
            }
            spindle_misaligned() { -> $M_Arrested }
            phase(): string { @@:("M") }
            => $^
        }

        $Cycling {
            dna_damage_detected() { -> $G1_Arrested }
            nutrients_low() { -> $G0_Quiescent }
            apoptosis_signal() { -> $Apoptotic }
        }

        $G1_Arrested {
            damage_repaired() { -> $G1 }
            apoptosis_signal() { -> $Apoptotic }
            phase(): string { @@:("G1-arrested") }
        }

        $M_Arrested {
            spindle_aligned() { -> $M }
            apoptosis_signal() { -> $Apoptotic }
            phase(): string { @@:("M-arrested") }
        }

        $G0_Quiescent {
            nutrients_restored() { -> $G1 }
            phase(): string { @@:("G0") }
        }

        $Apoptotic {
            phase(): string { @@:("apoptotic") }
        }

    domain:
        mass: double = 1.0
        g1_threshold: double = 1.8
        dna_content: double = 1.0
        g2_counter: int = 0
}

#include <stdio.h>
#include <stdlib.h>
#include <string.h>

static void check_str(const char* label, const char* actual, const char* expected) {
    if (strcmp(actual, expected) != 0) {
        printf("FAIL: %s expected '%s', got '%s'\n", label, expected, actual);
        exit(1);
    }
}

int main(void) {
    CellCycle* c = @@CellCycle();
    check_str("initial G1", CellCycle_phase(c), "G1");
    CellCycle_dna_damage_detected(c);
    check_str("arrested on damage", CellCycle_phase(c), "G1-arrested");
    CellCycle_tick(c);
    check_str("tick while arrested is a no-op", CellCycle_phase(c), "G1-arrested");
    CellCycle_damage_repaired(c);
    check_str("repaired -> G1", CellCycle_phase(c), "G1");
    CellCycle_nutrients_low(c);
    check_str("quiescent on starve", CellCycle_phase(c), "G0");
    CellCycle_nutrients_restored(c);
    check_str("nourished -> G1", CellCycle_phase(c), "G1");
    CellCycle_apoptosis_signal(c);
    check_str("apoptotic", CellCycle_phase(c), "apoptotic");
    CellCycle_tick(c);
    CellCycle_nutrients_restored(c);
    CellCycle_damage_repaired(c);
    check_str("apoptotic absorbs everything", CellCycle_phase(c), "apoptotic");

    CellCycle* c2 = @@CellCycle();
    CellCycle_spindle_misaligned(c2);
    check_str("spindle signal in G1 ignored", CellCycle_phase(c2), "G1");

    printf("PASS: cell_cycle\n");
    CellCycle_destroy(c);
    CellCycle_destroy(c2);
    return 0;
}

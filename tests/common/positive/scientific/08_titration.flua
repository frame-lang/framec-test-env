@@[target("lua")]

-- Cookbook 79: Titration Protocol

@@system Titration {
    interface:
        add_drop(volume_mL)
        observe_color(color)
        record_endpoint()
        new_trial()
        result_mL() = 0.0
        status()
        volume_mL()

    machine:
        $Setup {
            add_drop(volume_mL) {
                self.volume = 0.0
                -> $Titrating
            }
            volume_mL() { @@:(self.volume) }
            status() { @@:("setup") }
        }

        $Titrating {
            add_drop(volume_mL) { self.volume = self.volume + volume_mL }
            observe_color(color) {
                if color == "pink" then
                    -> $NearEndpoint
                end
            }
            volume_mL() { @@:(self.volume) }
            status() { @@:("titrating") }
        }

        $NearEndpoint {
            add_drop(volume_mL) { self.volume = self.volume + volume_mL }
            observe_color(color) {
                if color == "clear" then
                    -> $Titrating
                end
            }
            record_endpoint() { -> $Complete }
            volume_mL() { @@:(self.volume) }
            status() { @@:("near endpoint") }
        }

        $Complete {
            new_trial() {
                self.volume = 0.0
                -> $Setup
            }
            result_mL() { @@:(self.volume) }
            volume_mL() { @@:(self.volume) }
            status() { @@:("complete") }
        }

    domain:
        volume = 0.0
}

local function check(label, actual, expected)
    if actual ~= expected then
        print("FAIL: " .. label .. " expected '" .. tostring(expected) .. "', got '" .. tostring(actual) .. "'")
        os.exit(1)
    end
end
local function check_f(label, actual, expected)
    if math.abs(actual - expected) > 1e-9 then
        print("FAIL: " .. label .. " expected " .. tostring(expected) .. ", got " .. tostring(actual))
        os.exit(1)
    end
end

local t = @@Titration()
check("start setup", t:status(), "setup")
t:add_drop(1.0)
check("titrating", t:status(), "titrating")
check_f("volume zeroed on first", t:volume_mL(), 0.0)
t:add_drop(5.0)
t:add_drop(3.0)
check_f("accumulating", t:volume_mL(), 8.0)
t:observe_color("pink")
check("near endpoint", t:status(), "near endpoint")
t:observe_color("clear")
check("back to titrating", t:status(), "titrating")
t:observe_color("pink")
check("near endpoint 2", t:status(), "near endpoint")
t:add_drop(0.05)
t:record_endpoint()
check("complete", t:status(), "complete")
check_f("recorded volume", t:result_mL(), 8.05)
t:add_drop(10.0)
check_f("endpoint locked", t:result_mL(), 8.05)
t:add_drop(5.0)
check_f("endpoint still locked", t:result_mL(), 8.05)
t:observe_color("pink")
t:record_endpoint()
check_f("still locked after ignored events", t:result_mL(), 8.05)
t:new_trial()
check("new trial back to setup", t:status(), "setup")
check_f("volume cleared", t:volume_mL(), 0.0)
t:add_drop(2.0)
t:add_drop(1.5)
t:observe_color("pink")
t:record_endpoint()
check_f("second endpoint", t:result_mL(), 1.5)
print("PASS: titration")

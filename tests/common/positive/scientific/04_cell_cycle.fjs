@@[target("javascript")]

// Cookbook 75: Cell Cycle with Checkpoints

@@system CellCycle {
    interface:
        tick()
        dna_damage_detected()
        damage_repaired()
        nutrients_low()
        nutrients_restored()
        spindle_misaligned()
        spindle_aligned()
        apoptosis_signal()
        phase()

    machine:
        $G1 => $Cycling {
            $>() { this.mass = this.mass * 1.1; }
            tick() {
                if (this.mass >= this.g1_threshold) {
                    -> $S
                }
            }
            phase() { @@:("G1") }
            => $^
        }

        $S => $Cycling {
            $>() { this.dna_content = 1.0; }
            tick() {
                this.dna_content = this.dna_content + 0.1;
                if (this.dna_content >= 2.0) {
                    this.dna_content = 2.0;
                    -> $G2
                }
            }
            phase() { @@:("S") }
            => $^
        }

        $G2 => $Cycling {
            tick() {
                this.g2_counter = this.g2_counter + 1;
                if (this.g2_counter >= 3) {
                    this.g2_counter = 0;
                    -> $M
                }
            }
            phase() { @@:("G2") }
            => $^
        }

        $M => $Cycling {
            tick() {
                this.mass = this.mass / 2.0;
                this.dna_content = 1.0;
                -> $G1
            }
            spindle_misaligned() { -> $M_Arrested }
            phase() { @@:("M") }
            => $^
        }

        $Cycling {
            dna_damage_detected() { -> $G1_Arrested }
            nutrients_low() { -> $G0_Quiescent }
            apoptosis_signal() { -> $Apoptotic }
        }

        $G1_Arrested {
            damage_repaired() { -> $G1 }
            apoptosis_signal() { -> $Apoptotic }
            phase() { @@:("G1-arrested") }
        }

        $M_Arrested {
            spindle_aligned() { -> $M }
            apoptosis_signal() { -> $Apoptotic }
            phase() { @@:("M-arrested") }
        }

        $G0_Quiescent {
            nutrients_restored() { -> $G1 }
            phase() { @@:("G0") }
        }

        $Apoptotic {
            phase() { @@:("apoptotic") }
        }

    domain:
        mass = 1.0
        g1_threshold = 1.8
        dna_content = 1.0
        g2_counter = 0
}

function check(label, actual, expected) {
    if (actual !== expected) {
        console.log("FAIL: " + label + " expected '" + expected + "', got '" + actual + "'");
        process.exit(1);
    }
}

const c = @@CellCycle();
check("initial G1", c.phase(), "G1");
c.dna_damage_detected();
check("arrested on damage", c.phase(), "G1-arrested");
c.tick();
check("tick while arrested is a no-op", c.phase(), "G1-arrested");
c.damage_repaired();
check("repaired -> G1", c.phase(), "G1");
c.nutrients_low();
check("quiescent on starve", c.phase(), "G0");
c.nutrients_restored();
check("nourished -> G1", c.phase(), "G1");
c.apoptosis_signal();
check("apoptotic", c.phase(), "apoptotic");
c.tick();
c.nutrients_restored();
c.damage_repaired();
check("apoptotic absorbs everything", c.phase(), "apoptotic");

const c2 = @@CellCycle();
c2.spindle_misaligned();
check("spindle signal in G1 ignored", c2.phase(), "G1");

console.log("PASS: cell_cycle");

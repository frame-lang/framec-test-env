@@[target("csharp")]

// Cookbook 75: Cell Cycle with Checkpoints

using System;

@@system CellCycle {
    interface:
        tick()
        dna_damage_detected()
        damage_repaired()
        nutrients_low()
        nutrients_restored()
        spindle_misaligned()
        spindle_aligned()
        apoptosis_signal()
        phase(): string

    machine:
        $G1 => $Cycling {
            $>() { this.mass = this.mass * 1.1; }
            tick() {
                if (this.mass >= this.g1_threshold) {
                    -> $S
                }
            }
            phase(): string { @@:("G1") }
            => $^
        }

        $S => $Cycling {
            $>() { this.dna_content = 1.0; }
            tick() {
                this.dna_content = this.dna_content + 0.1;
                if (this.dna_content >= 2.0) {
                    this.dna_content = 2.0;
                    -> $G2
                }
            }
            phase(): string { @@:("S") }
            => $^
        }

        $G2 => $Cycling {
            tick() {
                this.g2_counter = this.g2_counter + 1;
                if (this.g2_counter >= 3) {
                    this.g2_counter = 0;
                    -> $M
                }
            }
            phase(): string { @@:("G2") }
            => $^
        }

        $M => $Cycling {
            tick() {
                this.mass = this.mass / 2.0;
                this.dna_content = 1.0;
                -> $G1
            }
            spindle_misaligned() { -> $M_Arrested }
            phase(): string { @@:("M") }
            => $^
        }

        $Cycling {
            dna_damage_detected() { -> $G1_Arrested }
            nutrients_low() { -> $G0_Quiescent }
            apoptosis_signal() { -> $Apoptotic }
        }

        $G1_Arrested {
            damage_repaired() { -> $G1 }
            apoptosis_signal() { -> $Apoptotic }
            phase(): string { @@:("G1-arrested") }
        }

        $M_Arrested {
            spindle_aligned() { -> $M }
            apoptosis_signal() { -> $Apoptotic }
            phase(): string { @@:("M-arrested") }
        }

        $G0_Quiescent {
            nutrients_restored() { -> $G1 }
            phase(): string { @@:("G0") }
        }

        $Apoptotic {
            phase(): string { @@:("apoptotic") }
        }

    domain:
        mass: double = 1.0
        g1_threshold: double = 1.8
        dna_content: double = 1.0
        g2_counter: int = 0
}

public class Program {
    static void Check(string label, string actual, string expected) {
        if (actual != expected) {
            Console.WriteLine($"FAIL: {label} expected '{expected}', got '{actual}'");
            Environment.Exit(1);
        }
    }

    public static void Main() {
        var c = @@CellCycle();
        Check("initial G1", (string)c.phase(), "G1");
        c.dna_damage_detected();
        Check("arrested on damage", (string)c.phase(), "G1-arrested");
        c.tick();
        Check("tick while arrested is a no-op", (string)c.phase(), "G1-arrested");
        c.damage_repaired();
        Check("repaired -> G1", (string)c.phase(), "G1");
        c.nutrients_low();
        Check("quiescent on starve", (string)c.phase(), "G0");
        c.nutrients_restored();
        Check("nourished -> G1", (string)c.phase(), "G1");
        c.apoptosis_signal();
        Check("apoptotic", (string)c.phase(), "apoptotic");
        c.tick();
        c.nutrients_restored();
        c.damage_repaired();
        Check("apoptotic absorbs everything", (string)c.phase(), "apoptotic");

        var c2 = @@CellCycle();
        c2.spindle_misaligned();
        Check("spindle signal in G1 ignored", (string)c2.phase(), "G1");

        Console.WriteLine("PASS: cell_cycle");
    }
}

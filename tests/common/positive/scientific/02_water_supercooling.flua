@@[target("lua")]

-- Cookbook 73: Water with Supercooling

@@system Water {
    interface:
        cool(delta)
        heat(delta)
        nucleate()
        shake()
        temperature()
        phase()

    machine:
        $Liquid {
            cool(delta) {
                self.temp = self.temp - delta
                if self.temp < 0.0 then
                    -> $Supercooled
                end
            }
            heat(delta) { self.temp = self.temp + delta }
            temperature() { @@:(self.temp) }
            phase() { @@:("liquid") }
        }

        $Supercooled {
            cool(delta) {
                self.temp = self.temp - delta
                if self.temp <= -42.0 then
                    -> $Ice
                end
            }
            heat(delta) {
                self.temp = self.temp + delta
                if self.temp >= 0.0 then
                    -> $Liquid
                end
            }
            nucleate() { -> $Ice }
            shake() { -> $Ice }
            temperature() { @@:(self.temp) }
            phase() { @@:("supercooled liquid") }
        }

        $Ice {
            heat(delta) {
                self.temp = self.temp + delta
                if self.temp >= 0.0 then
                    -> $Liquid
                end
            }
            cool(delta) { self.temp = self.temp - delta }
            temperature() { @@:(self.temp) }
            phase() { @@:("ice") }
        }

    domain:
        temp = 25.0
}

local function check(label, actual, expected)
    if actual ~= expected then
        print("FAIL: " .. label .. " expected '" .. tostring(expected) .. "', got '" .. tostring(actual) .. "'")
        os.exit(1)
    end
end
local function check_f(label, actual, expected)
    if math.abs(actual - expected) > 1e-9 then
        print("FAIL: " .. label .. " expected " .. tostring(expected) .. ", got " .. tostring(actual))
        os.exit(1)
    end
end

local w = @@Water()
check("start", w:phase(), "liquid")
w:cool(30.0)
check("after big cool", w:phase(), "supercooled liquid")
w:shake()
check("shaken", w:phase(), "ice")

local w2 = @@Water()
w2:cool(30.0)
check("w2 supercooled", w2:phase(), "supercooled liquid")
check_f("same temp", w:temperature(), w2:temperature())
if w:phase() == w2:phase() then
    print("FAIL: phases should differ")
    os.exit(1)
end

local w3 = @@Water()
w3:cool(30.0)
w3:nucleate()
check("nucleated", w3:phase(), "ice")

local w4 = @@Water()
w4:cool(30.0)
check("w4 supercooled", w4:phase(), "supercooled liquid")
w4:cool(40.0)
check("deep cool", w4:phase(), "ice")
w4:heat(50.0)
check("melted", w4:phase(), "liquid")

local w5 = @@Water()
w5:shake()
check("liquid shake ignored", w5:phase(), "liquid")
local w6 = @@Water()
w6:cool(30.0)
w6:cool(40.0)
check("w6 is ice", w6:phase(), "ice")
w6:shake()
check("ice shake ignored", w6:phase(), "ice")

print("PASS: water_supercooling")

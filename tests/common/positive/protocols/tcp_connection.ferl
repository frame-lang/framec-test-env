@@target erlang
@@skip -- Erlang requires one module per file; multi-system tested via other targets
@@system TcpServer {
    interface:
        listen()
        receive_syn()
        receive_ack()
        receive_fin()
        receive_data(data: str)
        close()
        get_state(): str = "Unknown"
        get_last_data(): str = ""

    machine:
        $Closed {
            get_state(): str {
                @@:("Closed")
            }

            listen() {
                -> $Listen
            }
        }

        $Listen {
            get_state(): str {
                @@:("Listen")
            }

            receive_syn() {
                % Send SYN-ACK (implicit -- client will call receive_syn_ack)
                -> $SynReceived
            }
        }

        $SynReceived {
            get_state(): str {
                @@:("SynReceived")
            }

            receive_ack() {
                -> $Established
            }
        }

        $Established {
            get_state(): str {
                @@:("Established")
            }
            get_last_data(): str {
                @@:(self.last_data)
            }

            receive_data(data: str) {
                self.last_data = data
            }

            receive_fin() {
                % Client initiated close
                -> $CloseWait
            }

            close() {
                % Server initiates close
                -> $FinWait1
            }
        }

        $CloseWait {
            get_state(): str {
                @@:("CloseWait")
            }

            close() {
                % Server sends FIN
                -> $LastAck
            }
        }

        $LastAck {
            get_state(): str {
                @@:("LastAck")
            }

            receive_ack() {
                -> $Closed
            }
        }

        $FinWait1 {
            get_state(): str {
                @@:("FinWait1")
            }

            receive_ack() {
                -> $FinWait2
            }

            receive_fin() {
                % Simultaneous close
                -> $Closing
            }
        }

        $FinWait2 {
            get_state(): str {
                @@:("FinWait2")
            }

            receive_fin() {
                -> $TimeWait
            }
        }

        $Closing {
            get_state(): str {
                @@:("Closing")
            }

            receive_ack() {
                -> $TimeWait
            }
        }

        $TimeWait {
            get_state(): str {
                @@:("TimeWait")
            }

            // In real TCP, wait 2*MSL then close. We simulate with explicit call.
            receive_ack() {
                -> $Closed
            }
        }

    domain:
        last_data = ""
}
@@system TcpClient {
    interface:
        connect()
        receive_syn_ack()
        receive_ack()
        receive_fin()
        send_data(data: str)
        close()
        get_state(): str = "Unknown"

    machine:
        $Closed {
            get_state(): str {
                @@:("Closed")
            }

            connect() {
                % Send SYN (implicit -- server will receive via receive_syn)
                -> $SynSent
            }
        }

        $SynSent {
            get_state(): str {
                @@:("SynSent")
            }

            receive_syn_ack() {
                % Send ACK (implicit -- server will receive via receive_ack)
                -> $Established
            }
        }

        $Established {
            get_state(): str {
                @@:("Established")
            }

            send_data(data: str) {
                % Data sent -- server will receive via receive_data
                self.sent_count = self.sent_count + 1
            }

            close() {
                % Send FIN
                -> $FinWait1
            }

            receive_fin() {
                % Server initiated close
                -> $CloseWait
            }
        }

        $FinWait1 {
            get_state(): str {
                @@:("FinWait1")
            }

            receive_ack() {
                -> $FinWait2
            }

            receive_fin() {
                % Simultaneous close
                -> $Closing
            }
        }

        $FinWait2 {
            get_state(): str {
                @@:("FinWait2")
            }

            receive_fin() {
                -> $TimeWait
            }
        }

        $Closing {
            get_state(): str {
                @@:("Closing")
            }

            receive_ack() {
                -> $TimeWait
            }
        }

        $TimeWait {
            get_state(): str {
                @@:("TimeWait")
            }

            receive_ack() {
                -> $Closed
            }
        }

        $CloseWait {
            get_state(): str {
                @@:("CloseWait")
            }

            close() {
                -> $LastAck
            }
        }

        $LastAck {
            get_state(): str {
                @@:("LastAck")
            }

            receive_ack() {
                -> $Closed
            }
        }

    domain:
        sent_count = 0
}

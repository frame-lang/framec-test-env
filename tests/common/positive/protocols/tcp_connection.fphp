<?php
@@target php

@@system TcpServer {
    interface:
        listen()
        receive_syn()
        receive_ack()
        receive_fin()
        receive_data(data: str)
        close()
        get_state(): str = "Unknown"
        get_last_data(): str = ""

    machine:
        $Closed {
            get_state(): str {
                @@:("Closed")
            }
            listen() { -> $Listen }
        }
        $Listen {
            get_state(): str {
                @@:("Listen")
            }
            receive_syn() { -> $SynReceived }
        }
        $SynReceived {
            get_state(): str {
                @@:("SynReceived")
            }
            receive_ack() { -> $Established }
        }
        $Established {
            get_state(): str {
                @@:("Established")
            }
            get_last_data(): str {
                @@:($this->last_data)
            }
            receive_data(data: str) { $this->last_data = $data; }
            receive_fin() { -> $CloseWait }
            close() { -> $FinWait1 }
        }
        $CloseWait {
            get_state(): str {
                @@:("CloseWait")
            }
            close() { -> $LastAck }
        }
        $LastAck {
            get_state(): str {
                @@:("LastAck")
            }
            receive_ack() { -> $Closed }
        }
        $FinWait1 {
            get_state(): str {
                @@:("FinWait1")
            }
            receive_ack() { -> $FinWait2 }
            receive_fin() { -> $Closing }
        }
        $FinWait2 {
            get_state(): str {
                @@:("FinWait2")
            }
            receive_fin() { -> $TimeWait }
        }
        $Closing {
            get_state(): str {
                @@:("Closing")
            }
            receive_ack() { -> $TimeWait }
        }
        $TimeWait {
            get_state(): str {
                @@:("TimeWait")
            }
            receive_ack() { -> $Closed }
        }

    domain:
        last_data = ""
}

@@system TcpClient {
    interface:
        connect()
        receive_syn_ack()
        receive_ack()
        receive_fin()
        send_data(data: str)
        close()
        get_state(): str = "Unknown"

    machine:
        $Closed {
            get_state(): str {
                @@:("Closed")
            }
            connect() { -> $SynSent }
        }
        $SynSent {
            get_state(): str {
                @@:("SynSent")
            }
            receive_syn_ack() { -> $Established }
        }
        $Established {
            get_state(): str {
                @@:("Established")
            }
            send_data(data: str) { $this->sent_count = $this->sent_count + 1; }
            close() { -> $FinWait1 }
            receive_fin() { -> $CloseWait }
        }
        $FinWait1 {
            get_state(): str {
                @@:("FinWait1")
            }
            receive_ack() { -> $FinWait2 }
            receive_fin() { -> $Closing }
        }
        $FinWait2 {
            get_state(): str {
                @@:("FinWait2")
            }
            receive_fin() { -> $TimeWait }
        }
        $Closing {
            get_state(): str {
                @@:("Closing")
            }
            receive_ack() { -> $TimeWait }
        }
        $TimeWait {
            get_state(): str {
                @@:("TimeWait")
            }
            receive_ack() { -> $Closed }
        }
        $CloseWait {
            get_state(): str {
                @@:("CloseWait")
            }
            close() { -> $LastAck }
        }
        $LastAck {
            get_state(): str {
                @@:("LastAck")
            }
            receive_ack() { -> $Closed }
        }

    domain:
        sent_count = 0
}

function assert_tcp_state($system, $expected, $label) {
    $actual = $system->get_state();
    if ($actual !== $expected) {
        echo "FAIL: {$label} - expected '{$expected}', got '{$actual}'" . "\n";
        throw new \Exception("State assertion failed: {$label}");
    }
}

// test_happy_path
$server = new TcpServer();
$client = new TcpClient();
assert_tcp_state($server, "Closed", "server initial");
assert_tcp_state($client, "Closed", "client initial");
$server->listen();
assert_tcp_state($server, "Listen", "server listen");
$client->connect();
assert_tcp_state($client, "SynSent", "client syn sent");
$server->receive_syn();
assert_tcp_state($server, "SynReceived", "server syn received");
$client->receive_syn_ack();
assert_tcp_state($client, "Established", "client established");
$server->receive_ack();
assert_tcp_state($server, "Established", "server established");
$client->send_data("hello");
$server->receive_data("hello");
$client->close();
assert_tcp_state($client, "FinWait1", "client fin wait 1");
$server->receive_fin();
assert_tcp_state($server, "CloseWait", "server close wait");
$client->receive_ack();
assert_tcp_state($client, "FinWait2", "client fin wait 2");
$server->close();
assert_tcp_state($server, "LastAck", "server last ack");
$client->receive_fin();
assert_tcp_state($client, "TimeWait", "client time wait");
$server->receive_ack();
assert_tcp_state($server, "Closed", "server closed");
$client->receive_ack();
assert_tcp_state($client, "Closed", "client closed");
echo "PASS: TCP happy path" . "\n";

// test_simultaneous_close
$server = new TcpServer();
$client = new TcpClient();
$server->listen();
$client->connect();
$server->receive_syn();
$client->receive_syn_ack();
$server->receive_ack();
$client->close();
$server->close();
assert_tcp_state($client, "FinWait1", "client fin wait 1");
assert_tcp_state($server, "FinWait1", "server fin wait 1");
$client->receive_fin();
$server->receive_fin();
assert_tcp_state($client, "Closing", "client closing");
assert_tcp_state($server, "Closing", "server closing");
$client->receive_ack();
$server->receive_ack();
assert_tcp_state($client, "TimeWait", "client time wait");
assert_tcp_state($server, "TimeWait", "server time wait");
$client->receive_ack();
$server->receive_ack();
assert_tcp_state($client, "Closed", "client closed");
assert_tcp_state($server, "Closed", "server closed");
echo "PASS: TCP simultaneous close" . "\n";

echo "PASS: All TCP connection tests passed" . "\n";

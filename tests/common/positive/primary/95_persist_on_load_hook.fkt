@@[target("kotlin")]

@@[persist]
@@system Counter {
    operations:
        @@[save]
        save_state(): String {}

        @@[load]
        restore_state(data: String) {}

        @@[on_load]
        rebuild_derived() {
            this.doubled = this.n * 2
            this.was_restored = true
        }

    interface:
        bump()
        readN(): Int
        readDoubled(): Int
        wasLoaded(): Boolean

    machine:
        $Active {
            bump() { this.n = this.n + 1 }
            readN(): Int { @@:(this.n) }
            readDoubled(): Int { @@:(this.doubled) }
            wasLoaded(): Boolean { @@:(this.was_restored) }
        }

    domain:
        n: Int = 0
        doubled: Int = 0
        was_restored: Boolean = false
}

fun main() {
    val c1 = Counter()
    c1.bump(); c1.bump(); c1.bump()
    if (c1.wasLoaded()) { println("FAIL: was_restored should be false pre-restore"); return }
    if (c1.readDoubled() != 0) { println("FAIL: doubled should be 0, got ${c1.readDoubled()}"); return }

    val data = c1.save_state()

    val c2 = Counter()
    c2.restore_state(data)
    if (!c2.wasLoaded()) { println("FAIL: was_restored should be true after on_load"); return }
    if (c2.readN() != 3) { println("FAIL: n should be 3, got ${c2.readN()}"); return }
    if (c2.readDoubled() != 6) { println("FAIL: doubled should be 6, got ${c2.readDoubled()}"); return }

    println("PASS: 95_persist_on_load_hook")
}

@@target c

#include <stdio.h>
#include <stdlib.h>
#include <string.h>
#include <cjson/cJSON.h>

@@[persist]
@@system PersistMultiEvent {
    interface:
        seed(v: int)
        bump()
        get_slot(): int

    machine:
        $Idle {
            seed(v: int) {
                -> $Active(v)
            }
            bump() {
                @@:(-1)
            }
            get_slot(): int {
                @@:(-1)
            }
        }

        $Active(slot: int) {
            seed(v: int) {
                -> $Active(v)
            }
            bump() {
                -> $Active(slot + 100)
            }
            get_slot(): int {
                @@:(slot)
            }
        }
    domain:
        v : int = 0
}

int main(void) {
    printf("=== Test 59: Persist × multi-event boundary (C) ===\n");
    PersistMultiEvent* s1 = PersistMultiEvent_new();
    PersistMultiEvent_seed(s1, 42);
    int pre = PersistMultiEvent_get_slot(s1);
    if (pre != 42) { printf("FAIL: pre %d\n", pre); return 1; }
    printf("1. Pre-save slot=%d\n", pre);

    char* snap = PersistMultiEvent_save_state(s1);
    PersistMultiEvent* s2 = PersistMultiEvent_restore_state(snap);
    int post = PersistMultiEvent_get_slot(s2);
    if (post != 42) { printf("FAIL: post %d\n", post); return 1; }
    printf("2. Post-restore slot=%d\n", post);

    PersistMultiEvent_bump(s2);
    int bumped = PersistMultiEvent_get_slot(s2);
    if (bumped != 142) { printf("FAIL: bumped %d\n", bumped); return 1; }
    printf("3. After post-restore bump slot=%d\n", bumped);

    PersistMultiEvent_bump(s2);
    int twice = PersistMultiEvent_get_slot(s2);
    if (twice != 242) { printf("FAIL: twice %d\n", twice); return 1; }
    printf("4. After second bump slot=%d\n", twice);

    printf("PASS: 59_persist_multi_event\n");
    free(snap);
    PersistMultiEvent_destroy(s1);
    PersistMultiEvent_destroy(s2);
    return 0;
}

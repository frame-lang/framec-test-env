@@[target("python_3")]

@@[persist(bytes)]
@@[save(save_state)]
@@[load(restore_state)]
@@system DictOfList {
    interface:
        configure(m: dict)
        get_at(key: str, idx: int): int

    machine:
        $Idle {
            configure(m: dict) { -> $Active(m) }
            get_at(key: str, idx: int): int { @@:(-1); return }
        }
        $Active(m: dict) {
            configure(m: dict) { -> $Active(m) }
            get_at(key: str, idx: int): int {
                @@:(m.get(key, [])[idx] if key in m and idx < len(m[key]) else -1)
                return
            }
        }
    domain:
        n: int = 0
}

def main():
    s1 = DictOfList()
    s1.configure({"a": [10, 20], "b": [30, 40, 50]})
    assert s1.get_at("a", 0) == 10
    assert s1.get_at("b", 2) == 50
    snap = s1.save_state()
    s2 = DictOfList()

    s2.restore_state(snap)
    assert s2.get_at("a", 0) == 10
    assert s2.get_at("a", 1) == 20
    assert s2.get_at("b", 2) == 50
    print("PASS: 79_dict_of_list_state_arg")

if __name__ == '__main__':
    main()

@@[target("typescript")]

@@[persist(string)]
@@[save(saveState)]
@@[load(restoreState)]
@@system ListOfDict {
    interface:
        configure(rows: Record<string, number>[])
        get_at(idx: number, key: string): number

    machine:
        $Idle {
            configure(rows: Record<string, number>[]) { -> $Active(rows) }
            get_at(idx: number, key: string): number { @@:(-1) }
        }
        $Active(rows: Record<string, number>[]) {
            configure(rows: Record<string, number>[]) { -> $Active(rows) }
            get_at(idx: number, key: string): number {
                @@:(idx < rows.length && rows[idx][key] !== undefined ? rows[idx][key] : -1)
            }
        }
    domain:
        n: number = 0
}

const s1 = @@ListOfDict();
s1.configure([{"x": 1, "y": 2}, {"z": 3}]);
if (s1.get_at(0, "x") !== 1) { console.log("FAIL pre 0.x"); process.exit(1); }
if (s1.get_at(1, "z") !== 3) { console.log("FAIL pre 1.z"); process.exit(1); }
const snap = s1.saveState();
const s2 = @@ListOfDict();

s2.restoreState(snap);
if (s2.get_at(0, "x") !== 1) { console.log("FAIL post 0.x"); process.exit(1); }
if (s2.get_at(0, "y") !== 2) { console.log("FAIL post 0.y"); process.exit(1); }
if (s2.get_at(1, "z") !== 3) { console.log("FAIL post 1.z"); process.exit(1); }
console.log("PASS: 80_list_of_dict_state_arg");

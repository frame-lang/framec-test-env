@@[target("kotlin")]

import kotlin.system.exitProcess

@@system EventForwardTest {
    interface:
        process()
        get_log(): MutableList<Any?>

    machine:
        $Idle {
            process() {
                this.log.add("idle:process:before")
                -> => $Working
                // This should NOT execute because -> => returns after dispatch
                this.log.add("idle:process:after")
            }

            get_log(): MutableList<Any?> {
                @@:(this.log)
                return;
            }
        }

        $Working {
            process() {
                this.log.add("working:process")
            }

            get_log(): MutableList<Any?> {
                @@:(this.log)
                return;
            }
        }
    domain:
        log = mutableListOf<String>()
}

fun main() {
    println("=== Test 19: Transition Forward (Kotlin) ===")
    val s = @@EventForwardTest()
    s.process()
    val log = s.get_log() as MutableList<*>
    println("Log: $log")

    if (!log.contains("idle:process:before")) {
        println("FAIL: Expected 'idle:process:before' in log: $log")
        exitProcess(1)
    }
    if (!log.contains("working:process")) {
        println("FAIL: Expected 'working:process' in log: $log")
        exitProcess(1)
    }
    if (log.contains("idle:process:after")) {
        println("FAIL: Should NOT have 'idle:process:after' in log: $log")
        exitProcess(1)
    }

    println("PASS: Transition forward works correctly")
}

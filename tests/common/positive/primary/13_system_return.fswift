@@target swift

@@system SystemReturnTest {
    interface:
        add(a: number, b: number): number
        multiply(a: number, b: number): number
        greet(name: string): string
        get_value(): number

    machine:
        $Calculator {
            $.value: number = 0

            add(a: number, b: number): number {
                return a + b
            }

            multiply(a: number, b: number): number {
                @@:return = a * b
            }

            greet(name: string): string {
                return "Hello, " + name + "!"
            }

            get_value(): number {
                $.value = 42
                return $.value
            }
        }
}

// main
    print("=== Test 13: System Return ===")
    let calc = @@SystemReturnTest()

    // Test return sugar
    var result = calc.add(3, 5)
    if result != 8 {
        fatalError("Expected 8, got \(result)")
    }
    print("add(3, 5) = \(result)")

    // Test @@:return = expr
    result = calc.multiply(4, 7)
    if result != 28 {
        fatalError("Expected 28, got \(result)")
    }
    print("multiply(4, 7) = \(result)")

    // Test string return
    let greeting = calc.greet("World")
    if greeting != "Hello, World!" {
        fatalError("Expected 'Hello, World!', got '\(greeting)'")
    }
    print("greet('World') = \(greeting)")

    // Test return with state variable
    let value = calc.get_value()
    if value != 42 {
        fatalError("Expected 42, got \(value)")
    }
    print("get_value() = \(value)")

    print("PASS: System return works correctly")

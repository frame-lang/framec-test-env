@@[target("cpp_17")]

#include <iostream>
#include <nlohmann/json.hpp>

// Test 100: @@[no_persist] domain fields (RFC-0016.1)

@@[persist(std::string)]
@@[save(save_op)]
@@[load(load_op)]
@@system NoPersistField {
    interface:
        bump()
        set_cache(v: int)
        set_note(s: std::string)
        get_n(): int
        get_cache(): int
        get_note(): std::string

    machine:
        $Active {
            bump() { this->n = this->n + 1; }
            set_cache(v: int) { this->cache = v; }
            set_note(s: std::string) { this->note = s; }
            get_n(): int { @@:(this->n) }
            get_cache(): int { @@:(this->cache) }
            get_note(): std::string { @@:(this->note) }
        }

    domain:
        n: int = 0
        @@[no_persist]
        cache: int = -1
        note: std::string = "fresh"
}

int main() {
    auto c1 = @@NoPersistField();
    c1.bump();
    c1.bump();
    c1.bump();
    c1.set_cache(99);
    c1.set_note("hello");
    std::string data = c1.save_op();

    auto c2 = @@NoPersistField();
    c2.load_op(data);

    if (c2.get_n() != 3) {
        std::cout << "FAIL: expected n=3, got " << c2.get_n() << std::endl;
        return 1;
    }
    if (c2.get_note() != "hello") {
        std::cout << "FAIL: expected note=hello, got " << c2.get_note() << std::endl;
        return 1;
    }
    if (c2.get_cache() != -1) {
        std::cout << "FAIL: expected cache=-1 (domain default; @@[no_persist] field not restored), got " << c2.get_cache() << std::endl;
        return 1;
    }
    std::cout << "PASS: 100_no_persist_field" << std::endl;
    return 0;
}

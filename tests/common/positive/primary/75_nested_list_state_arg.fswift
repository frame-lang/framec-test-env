@@target swift

import Foundation

@@persist
@@system NestedList {
    interface:
        configure(rows: [[Int]])
        first_first(): Int
        outer_size(): Int

    machine:
        $Idle {
            configure(rows: [[Int]]) { -> $Active(rows) }
            first_first(): Int { @@:(-1) }
            outer_size(): Int { @@:(0) }
        }
        $Active(rows: [[Int]]) {
            configure(rows: [[Int]]) { -> $Active(rows) }
            first_first(): Int { @@:(rows[0][0]) }
            outer_size(): Int { @@:(rows.count) }
        }
    domain:
        n : Int = 0
}

let s1 = NestedList()
s1.configure([[10, 20], [30, 40]])
if s1.first_first() != 10 { print("FAIL pre"); exit(1) }
if s1.outer_size() != 2 { print("FAIL size"); exit(1) }
let snap = s1.saveState()
let s2 = NestedList.restoreState(snap)
if s2.first_first() != 10 { print("FAIL post"); exit(1) }
if s2.outer_size() != 2 { print("FAIL post size"); exit(1) }
print("PASS: 75_nested_list_state_arg")

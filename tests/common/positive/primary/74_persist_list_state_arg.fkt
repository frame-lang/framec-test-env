@@[target("kotlin")]

@@[persist(String)]
@@[save(save_state)]
@@[load(restore_state)]
@@system PersistList {
    interface:
        configure(items: List<Int>)
        first_item(): Int
        size(): Int

    machine:
        $Idle {
            configure(items: List<Int>) {
                -> $Active(items)
            }
            first_item(): Int { @@:(-1) }
            size(): Int { @@:(0) }
        }
        $Active(items: List<Int>) {
            configure(items: List<Int>) {
                -> $Active(items)
            }
            first_item(): Int { @@:(items[0]) }
            size(): Int { @@:(items.size) }
        }
    domain:
        n : Int = 0
}

fun main() {
    val s1 = PersistList()
    s1.configure(listOf(10, 20, 30))
    if (s1.first_item() != 10) { println("FAIL pre"); kotlin.system.exitProcess(1) }
    val snap = s1.save_state()

    val s2 = PersistList()


    s2.restore_state(snap)
    if (s2.first_item() != 10) { println("FAIL restored first_item"); kotlin.system.exitProcess(1) }
    if (s2.size() != 3) { println("FAIL restored size"); kotlin.system.exitProcess(1) }
    println("PASS: 74_persist_list_state_arg")
}

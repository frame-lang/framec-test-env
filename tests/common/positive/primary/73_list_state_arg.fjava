@@[target("java")]

import java.util.List;
import java.util.Arrays;

@@system ListStateArg {
    interface:
        configure(items: java.util.List<Integer>)
        first_item(): int
        size(): int

    machine:
        $Idle {
            configure(items: java.util.List<Integer>) {
                -> $Active(items)
            }
            first_item(): int {
                @@:(-1)
            }
            size(): int {
                @@:(0)
            }
        }
        $Active(items: java.util.List<Integer>) {
            configure(items: java.util.List<Integer>) {
                -> $Active(items)
            }
            first_item(): int {
                @@:(items.get(0))
            }
            size(): int {
                @@:(items.size())
            }
        }
    domain:
        n: int = 0
}

class Main {
    public static void main(String[] args) {
        ListStateArg s = new ListStateArg();
        if (s.first_item() != -1) { System.out.println("FAIL idle first_item"); System.exit(1); }
        if (s.size() != 0) { System.out.println("FAIL idle size"); System.exit(1); }
        s.configure(Arrays.asList(10, 20, 30));
        if (s.first_item() != 10) { System.out.println("FAIL active first_item"); System.exit(1); }
        if (s.size() != 3) { System.out.println("FAIL active size"); System.exit(1); }
        s.configure(Arrays.asList(7));
        if (s.first_item() != 7) { System.out.println("FAIL retransition first_item"); System.exit(1); }
        if (s.size() != 1) { System.out.println("FAIL retransition size"); System.exit(1); }
        System.out.println("PASS: 73_list_state_arg");
    }
}

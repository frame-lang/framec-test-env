@@[target("php")]

<?php

@@[persist(string)]
@@[save(save_state)]
@@[load(restore_state)]
@@system Inner {
    interface:
        cycle()
        get_state(): string
        get_count(): int

    machine:
        $A {
            cycle() { $this->n = $this->n + 1; -> $B }
            get_state(): string { @@:("A") }
            get_count(): int { @@:($this->n) }
        }
        $B => $A {
            cycle() { -> $A }
            get_state(): string { @@:("B") }
            get_count(): int { => $^ }
        }
    domain:
        n: int = 0
}

@@system Mid {
    operations:
        @@[save]
        save_state(): string {}

        @@[load]
        restore_state(data: string) {}

    interface:
        cycle()
        cycle_inner()
        get_state(): string
        get_inner_state(): string
        get_inner_count(): int
        get_m(): int

    machine:
        $P {
            cycle() { $this->m = $this->m + 1; -> $Q }
            cycle_inner() { $this->inner->cycle(); }
            get_state(): string { @@:("P") }
            get_inner_state(): string { @@:($this->inner->get_state()) }
            get_inner_count(): int { @@:($this->inner->get_count()) }
            get_m(): int { @@:($this->m) }
        }
        $Q => $P {
            cycle() { -> $P }
            get_state(): string { @@:("Q") }
            cycle_inner() { => $^ }
            get_inner_state(): string { => $^ }
            get_inner_count(): int { => $^ }
            get_m(): int { => $^ }
        }
    domain:
        m: int = 0
        inner = @@Inner()
}

@@[main]
@@system Outer {
    operations:
        @@[save]
        save_state(): string {}

        @@[load]
        restore_state(data: string) {}

    interface:
        tick()
        cycle_mid()
        cycle_inner()
        get_outer_state(): string
        get_mid_state(): string
        get_inner_state(): string
        get_inner_count(): int
        get_m(): int
        get_k(): int

    machine:
        $Idle {
            tick() { $this->k = $this->k + 1; -> $Active }
            cycle_mid() { $this->mid->cycle(); }
            cycle_inner() { $this->mid->cycle_inner(); }
            get_outer_state(): string { @@:("Idle") }
            get_mid_state(): string { @@:($this->mid->get_state()) }
            get_inner_state(): string { @@:($this->mid->get_inner_state()) }
            get_inner_count(): int { @@:($this->mid->get_inner_count()) }
            get_m(): int { @@:($this->mid->get_m()) }
            get_k(): int { @@:($this->k) }
        }
        $Active => $Idle {
            tick() { -> $Idle }
            get_outer_state(): string { @@:("Active") }
            cycle_mid() { => $^ }
            cycle_inner() { => $^ }
            get_mid_state(): string { => $^ }
            get_inner_state(): string { => $^ }
            get_inner_count(): int { => $^ }
            get_m(): int { => $^ }
            get_k(): int { => $^ }
        }
    domain:
        k: int = 0
        mid = @@Mid()
}

function fmtProbe($o) {
    return $o->get_outer_state() . "/" . $o->get_mid_state() . "/" . $o->get_inner_state() . "/" . $o->get_inner_count() . "/" . $o->get_m() . "/" . $o->get_k();
}

function must($label, $o, $expected) {
    $actual = fmtProbe($o);
    if ($actual !== $expected) { echo "FAIL $label: $actual expected $expected\n"; exit(1); }
}

$o = new Outer();
must("T0 fresh", $o, "Idle/P/A/0/0/0");
$snap0 = $o->save_state();
$r0 = new Outer();

$r0->restore_state($snap0);
must("T0 restored", $r0, "Idle/P/A/0/0/0");

$o->tick();
must("T1", $o, "Active/P/A/0/0/1");
$snap1 = $o->save_state();
$r1 = new Outer();

$r1->restore_state($snap1);
must("T1 restored", $r1, "Active/P/A/0/0/1");

$o->cycle_mid();
$o->cycle_inner();
must("T2", $o, "Active/Q/B/1/1/1");
$snap2 = $o->save_state();
$r2 = new Outer();

$r2->restore_state($snap2);
must("T2 restored", $r2, "Active/Q/B/1/1/1");

$snap2b = $r2->save_state();
$r2b = new Outer();

$r2b->restore_state($snap2b);
if (fmtProbe($r2b) !== fmtProbe($r2)) { echo "FAIL idempotence: " . fmtProbe($r2b) . " != " . fmtProbe($r2) . "\n"; exit(1); }

$r2->cycle_inner();
must("continue1", $r2, "Active/Q/A/1/1/1");
$r2->cycle_mid();
must("continue2", $r2, "Active/P/A/1/1/1");
$r2->tick();
must("continue3", $r2, "Idle/P/A/1/1/1");
$r2->tick();
must("continue4", $r2, "Active/P/A/1/1/2");

echo "PASS: 85_persist_three_level_nested\n";

@@[target("dart")]
import 'dart:convert';

// Test 48: HSM Exit Cascade
//
// Tests the HSM exit cascade per docs/frame_runtime_introduction.md
// Step 21+. When exiting an HSM child, the kernel fires <$ on every
// layer of the source chain bottom-up (child first, parent last).

@@system HSMExitHandlers {
    interface:
        go_to_other()
        go_to_parent()
        go_to_child()
        get_log(): List<String>
        get_state(): str
        get_child_var(): int

    machine:
        $Child => $Parent {
            $.child_var: int = 42

            $>() {
                this.log.add("Child:enter");
            }

            <$() {
                var val = $.child_var;
                this.log.add("Child:exit(var=${val})");
            }

            go_to_other() { -> $Other }
            go_to_parent() { -> $Parent }
            get_log(): list { @@:(this.log) }
            get_state(): str { @@:("Child") }
            get_child_var(): int { @@:($.child_var) }
        }

        $Parent {
            $>() {
                this.log.add("Parent:enter");
            }

            <$() {
                this.log.add("Parent:exit");
            }

            go_to_child() { -> $Child }
            go_to_other() { -> $Other }
            get_log(): list { @@:(this.log) }
            get_state(): str { @@:("Parent") }
            get_child_var(): int { @@:(-1) }
        }

        $Other {
            $>() {
                this.log.add("Other:enter");
            }
            go_to_child() { -> $Child }
            go_to_parent() { -> $Parent }
            get_log(): list { @@:(this.log) }
            get_state(): str { @@:("Other") }
            get_child_var(): int { @@:(-1) }
        }
    domain:
        log : List<String> = []
}

void main() {
    print("=== Test 48: HSM Exit Cascade ===");
    final s = @@HSMExitHandlers();

    var log = s.get_log();
    if (!log.contains("Parent:enter")) throw Exception("Expected Parent:enter on init cascade");
    if (!log.contains("Child:enter")) throw Exception("Expected Child:enter on init");
    if (s.get_state() != "Child") throw Exception("Expected Child");
    print("TC1: Initial entry cascades through Parent then Child - PASS");

    s.go_to_other();
    log = s.get_log();
    if (!log.contains("Child:exit(var=42)")) throw Exception("Expected Child:exit(var=42)");
    if (!log.contains("Parent:exit")) throw Exception("Expected Parent:exit (cascade)");
    if (!log.contains("Other:enter")) throw Exception("Expected Other:enter");
    final cei = log.indexOf("Child:exit(var=42)");
    final pei = log.indexOf("Parent:exit");
    if (cei >= pei) throw Exception("Child:exit must precede Parent:exit (bottom-up)");
    print("TC2: Child:exit fires before Parent:exit (bottom-up cascade) - PASS");

    print("TC3: Exit handler accesses state var (var=42) - PASS");

    s.go_to_child();
    log = s.get_log();
    if (log.where((x) => x == "Parent:enter").length != 2) throw Exception("Expected 2 Parent:enter");
    if (log.where((x) => x == "Child:enter").length != 2) throw Exception("Expected 2 Child:enter");
    print("TC4: Re-entering Child cascades Parent.\$> then Child.\$> - PASS");

    print("PASS: HSM exit cascade fires Child.<\$ then Parent.<\$");
}

@@[target("ruby")]

require 'json'

@@[persist(String)]
@@[save(save_state)]
@@[load(restore_state)]
@@system PersistMultiEvent {
    interface:
        seed(v: int)
        bump()
        get_slot(): int

    machine:
        $Idle {
            seed(v: int) {
                -> $Active(v)
            }
            bump() {
                @@:(-1)
                return
            }
            get_slot(): int {
                @@:(-1)
                return
            }
        }

        $Active(slot: int) {
            seed(v: int) {
                -> $Active(v)
            }
            bump() {
                -> $Active(slot + 100)
            }
            get_slot(): int {
                @@:(slot)
                return
            }
        }
    domain:
        v: int = 0
}

puts("=== Test 59: Persist × multi-event boundary (Ruby) ===")
s1 = @@PersistMultiEvent()
s1.seed(42)
pre = s1.get_slot()
raise "Expected 42 pre-save, got #{pre}" unless pre == 42
puts("1. Pre-save slot=#{pre}")

snap = s1.save_state()
s2 = @@PersistMultiEvent()
s2.restore_state(snap)
post = s2.get_slot()
raise "Expected 42 post-restore, got #{post}" unless post == 42
puts("2. Post-restore slot=#{post}")

s2.bump()
bumped = s2.get_slot()
raise "Expected 142 after bump, got #{bumped}" unless bumped == 142
puts("3. After post-restore bump slot=#{bumped}")

s2.bump()
twice = s2.get_slot()
raise "Expected 242 after second bump, got #{twice}" unless twice == 242
puts("4. After second bump slot=#{twice}")

puts("PASS: 59_persist_multi_event")

@@[target("ruby")]

@@system BoolStateArg {
    interface:
        configure(active: bool)
        is_active(): bool

    machine:
        $Idle {
            configure(active: bool) {
                -> $Active(active)
            }
            is_active(): bool {
                @@:(false)
                return
            }
        }

        $Active => $Frame(flag: bool) {
            configure(active: bool) {
                -> $Active(active)
            }
            is_active(): bool {
                => $^
            }
        }

        $Frame {
            is_active(): bool {
                @@:(flag)
                return
            }
        }
    domain:
        n: int = 0
}

s = @@BoolStateArg()
raise "FAIL idle" unless s.is_active == false
s.configure(true)
raise "FAIL true" unless s.is_active == true
s.configure(false)
raise "FAIL false" unless s.is_active == false
s.configure(true)
raise "FAIL re-true" unless s.is_active == true
puts "PASS: 67_hsm_bool_state_args"

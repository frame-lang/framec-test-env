@@[target("swift")]

// NOTE: Default return value syntax (method(): type = default) not yet implemented.
// This test validates behavior when handler doesn't set @@:return.

@@system SystemReturnDefaultTest {
    interface:
        handler_sets_value(): string
        handler_no_return(): string | nil
        get_count(): number

    machine:
        $Start {
            $.count: number = 0

            handler_sets_value(): string {
                @@:("set_by_handler")
                return;
            }

            handler_no_return(): string | nil {
                // Does not set return - should return nil
                $.count = $.count + 1
            }

            get_count(): number {
                @@:($.count)
                return;
            }
        }
}

// main
    print("=== Test 14: System Return Default Behavior ===")
    let s = @@SystemReturnDefaultTest()

    // Test 1: Handler explicitly sets return value
    let result1 = s.handler_sets_value()
    if result1 != "set_by_handler" {
        fatalError("Expected 'set_by_handler', got '\(result1)'")
    }
    print("1. handler_sets_value() = '\(result1)'")

    // Test 2: Handler does NOT set return - should return nil
    let result2 = s.handler_no_return()
    if result2 != nil {
        fatalError("Expected nil, got '\(String(describing: result2))'")
    }
    print("2. handler_no_return() = \(String(describing: result2))")

    // Test 3: Verify handler was called (side effect check)
    var count = s.get_count()
    if count != 1 {
        fatalError("Expected count=1, got \(count)")
    }
    print("3. Handler was called, count = \(count)")

    // Test 4: Call again to verify idempotence
    let result4 = s.handler_no_return()
    if result4 != nil {
        fatalError("Expected nil again, got '\(String(describing: result4))'")
    }
    count = s.get_count()
    if count != 2 {
        fatalError("Expected count=2, got \(count)")
    }
    print("4. Second call: result=\(String(describing: result4)), count=\(count)")

    print("PASS: System return default behavior works correctly")

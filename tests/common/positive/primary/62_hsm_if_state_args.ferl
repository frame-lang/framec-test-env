@@target erlang
@@system HsmIfStateArgs {
    interface:
        enterActive(t: int)
        classify(v: int): int
    machine:
        $Idle {
            enterActive(t: int) {
                -> $Active(t)
            }
            classify(v: int): int {
                @@:(-1)
            }
        }
        $Active => $Frame(threshold: int) {
            enterActive(t: int) {
                -> $Active(t)
            }
            classify(v: int): int {
                if v > threshold {
                    @@:(1)
                } else {
                    @@:(0)
                }
            }
        }
        $Frame {
        }
    domain:
        n = 0
}

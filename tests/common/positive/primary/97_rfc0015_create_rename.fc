@@[target("c")]

#include <stdio.h>

@@[create(make)]
@@system Counter(seed: int) {
    interface:
        bump()
        get_value(): int

    machine:
        $A {
            bump() { self->count = self->count + 1; }
            get_value(): int { @@:(self->count) }
        }

    domain:
        seed: int = seed
        count: int = 0
}

int main() {
    Counter* c1 = Counter_new(42);
    Counter_bump(c1);
    Counter_bump(c1);
    if (Counter_get_value(c1) != 2) {
        printf("FAIL: via Counter_new expected 2, got %d\n", Counter_get_value(c1));
        Counter_destroy(c1);
        return 1;
    }

    Counter* c2 = Counter_make(99);
    Counter_bump(c2);
    if (Counter_get_value(c2) != 1) {
        printf("FAIL: via Counter_make expected 1, got %d\n", Counter_get_value(c2));
        Counter_destroy(c1);
        Counter_destroy(c2);
        return 1;
    }

    printf("PASS: rfc0015_create_rename\n");
    Counter_destroy(c1);
    Counter_destroy(c2);
    return 0;
}

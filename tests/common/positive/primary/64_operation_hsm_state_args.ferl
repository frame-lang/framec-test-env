@@[target("erlang")]
@@system OpHsmStateArgs {
    operations:
        addOffset(x: int, off: int): int {
            X + Off
        }
    interface:
        enterActive(t: int)
        classify(v: int): int
    machine:
        $Idle {
            enterActive(t: int) {
                -> $Active(t)
            }
            classify(v: int): int {
                @@:(-1)
            }
        }
        $Active => $Frame(threshold: int) {
            enterActive(t: int) {
                -> $Active(t)
            }
            classify(v: int): int {
                R = addOffset(Data, V, Threshold)
                @@:(R)
            }
        }
        $Frame {
        }
    domain:
        n = 0
}

// @@skip
// Persist tests need System.Text.Json pipeline support for C#
@@target csharp

using System;
using System.Collections.Generic;

@@persist
@@system PersistTest {
    interface:
        set_value(v: int)
        get_value(): int
        go_active()
        go_idle()

    machine:
        $Idle {
            set_value(v: int) { value = v; }
            get_value(): int { return value; }
            go_active() { -> $Active }
            go_idle() { }
        }

        $Active {
            set_value(v: int) { value = v * 2; }
            get_value(): int { return value; }
            go_active() { }
            go_idle() { -> $Idle }
        }
    domain:
        int value = 0
        string name = "default"
}

class Program {
    static void Main(string[] args) {
        Console.WriteLine("=== Test 23: Persist Basic (C#) ===");
        Console.WriteLine("SKIP: Persist tests need System.Text.Json pipeline support");
    }
}

@@[target("go")]

// RFC-0017 regression: see .fpy header.

@@system Counter(seed: int) {
    interface:
        bump()
        get_value(): int
    machine:
        $S {
            $> { s.n = s.seed }
            bump() { s.n = s.n + 1 }
            get_value(): int { @@:(s.n) }
        }
    domain:
        seed: int = seed
        n: int = 0
}

@@[main]
@@system World {
    interface:
        bump_c()
        bump_d()
        get_c(): int
        get_d(): int
    machine:
        $S {
            bump_c() { s.c.bump() }
            bump_d() { s.d.bump() }
            get_c(): int { @@:(s.c.get_value()) }
            get_d(): int { @@:(s.d.get_value()) }
        }
    domain:
        c: *Counter = @@Counter(7)
        d: *Counter = @@Counter(11)
}

func main() {
    w := @@World()
    if w.get_c() != 7 { fmt.Printf("FAIL initial c: %d\n", w.get_c()); os.Exit(1) }
    if w.get_d() != 11 { fmt.Printf("FAIL initial d: %d\n", w.get_d()); os.Exit(1) }
    w.bump_c()
    w.bump_d()
    if w.get_c() != 8 { fmt.Printf("FAIL bump_c: %d\n", w.get_c()); os.Exit(1) }
    if w.get_d() != 12 { fmt.Printf("FAIL bump_d: %d\n", w.get_d()); os.Exit(1) }
    fmt.Println("PASS: 98_param_child_domain_init")
}

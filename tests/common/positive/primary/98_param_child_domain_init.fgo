@@[target("go")]

package main

import "fmt"
import "os"

// RFC-0017 regression: see .fpy header.
// Interface methods are PascalCase here so Go's export rule
// (framec uppercases the first letter) leaves the cross-system
// call sites — `s.c.Bump()`, `w.GetC()` — referencing the names
// Go actually generated.

@@system Counter(seed: int) {
    interface:
        Bump()
        GetValue(): int
    machine:
        $S {
            $> { s.n = s.seed }
            Bump() { s.n = s.n + 1 }
            GetValue(): int { @@:(s.n) }
        }
    domain:
        seed: int = seed
        n: int = 0
}

@@[main]
@@system World {
    interface:
        BumpC()
        BumpD()
        GetC(): int
        GetD(): int
    machine:
        $S {
            BumpC() { s.c.Bump() }
            BumpD() { s.d.Bump() }
            GetC(): int { @@:(s.c.GetValue()) }
            GetD(): int { @@:(s.d.GetValue()) }
        }
    domain:
        c: *Counter = @@Counter(7)
        d: *Counter = @@Counter(11)
}

func main() {
    w := @@World()
    if w.GetC() != 7 { fmt.Printf("FAIL initial c: %d\n", w.GetC()); os.Exit(1) }
    if w.GetD() != 11 { fmt.Printf("FAIL initial d: %d\n", w.GetD()); os.Exit(1) }
    w.BumpC()
    w.BumpD()
    if w.GetC() != 8 { fmt.Printf("FAIL bump_c: %d\n", w.GetC()); os.Exit(1) }
    if w.GetD() != 12 { fmt.Printf("FAIL bump_d: %d\n", w.GetD()); os.Exit(1) }
    fmt.Println("PASS: 98_param_child_domain_init")
}

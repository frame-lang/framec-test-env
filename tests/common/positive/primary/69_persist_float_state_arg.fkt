@@[target("kotlin")]

import kotlin.math.abs

@@[persist(String)]
@@[save(save_state)]
@@[load(restore_state)]
@@system PFloat {
    interface:
        configure(rate: double)
        get_rate(): double

    machine:
        $Idle {
            configure(rate: Double) {
                -> $Active(rate)
            }
            get_rate(): Double {
                @@:(0.0)
            }
        }

        $Active(rate: Double) {
            get_rate(): Double {
                @@:(rate)
            }
        }
    domain:
        n : int = 0
}

fun main() {
    val s = PFloat()
    s.configure(3.14159)
    val snap = s.save_state() as String
    val s2 = PFloat()

    s2.restore_state(snap)
    val r = s2.get_rate()
    if (abs(r - 3.14159) > 1e-9) { println("FAIL $r"); kotlin.system.exitProcess(1) }
    println("PASS: 69_persist_float_state_arg, rate=$r")
}

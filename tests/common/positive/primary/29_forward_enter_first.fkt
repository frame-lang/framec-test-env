@@[target("kotlin")]

import kotlin.system.exitProcess

@@system ForwardEnterFirst {
    interface:
        process()
        get_counter(): Int
        get_log(): MutableList<Any?>

    machine:
        $Idle {
            process() {
                -> => $Working
            }

            get_counter(): Int {
                @@:(-1)
                return;
            }

            get_log(): MutableList<Any?> {
                @@:(this.log)
                return;
            }
        }

        $Working {
            $.counter: Int = 100

            $>() {
                this.log.add("Working:enter")
            }

            process() {
                this.log.add("Working:process:counter=" + $.counter)
                $.counter = $.counter + 1
            }

            get_counter(): Int {
                @@:($.counter)
                return;
            }

            get_log(): MutableList<Any?> {
                @@:(this.log)
                return;
            }
        }
    domain:
        log = mutableListOf<String>()
}

fun main() {
    println("=== Test 29: Forward Enter First ===")
    val s = @@ForwardEnterFirst()

    if ((s.get_counter() as Int) != -1) {
        println("FAIL: Expected -1 in Idle")
        exitProcess(1)
    }

    s.process()

    val counter = s.get_counter() as Int
    val log = s.get_log() as MutableList<*>
    println("Counter after forward: $counter")
    println("Log: $log")

    if (!log.contains("Working:enter")) {
        println("FAIL: Expected 'Working:enter' in log: $log")
        exitProcess(1)
    }

    if (!log.contains("Working:process:counter=100")) {
        println("FAIL: Expected 'Working:process:counter=100' in log: $log")
        exitProcess(1)
    }

    if (counter != 101) {
        println("FAIL: Expected counter=101, got $counter")
        exitProcess(1)
    }

    val enterIdx = log.indexOf("Working:enter")
    val processIdx = log.indexOf("Working:process:counter=100")
    if (enterIdx >= processIdx) {
        println("FAIL: \$> should run before process: $log")
        exitProcess(1)
    }

    println("PASS: Forward sends \$> first for non-\$> events")
}

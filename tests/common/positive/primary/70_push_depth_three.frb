@@[target("ruby")]

@@system PushDeep {
    interface:
        descend()
        ascend()
        get_depth(): int

    machine:
        $Idle {
            descend() {
                push$
                -> $Modal1
            }
            get_depth(): int {
                @@:(0)
                return
            }
        }

        $Modal1 {
            descend() {
                push$
                -> $Modal2
            }
            ascend() {
                -> pop$
            }
            get_depth(): int {
                @@:(1)
                return
            }
        }

        $Modal2 {
            descend() {
                push$
                -> $Modal3
            }
            ascend() {
                -> pop$
            }
            get_depth(): int {
                @@:(2)
                return
            }
        }

        $Modal3 {
            ascend() {
                -> pop$
            }
            get_depth(): int {
                @@:(3)
                return
            }
        }
    domain:
        n: int = 0
}

s = @@PushDeep()
raise "FAIL idle" unless s.get_depth == 0
s.descend
raise "FAIL d1" unless s.get_depth == 1
s.descend
raise "FAIL d2" unless s.get_depth == 2
s.descend
raise "FAIL d3" unless s.get_depth == 3
s.ascend
raise "FAIL a1" unless s.get_depth == 2
s.ascend
raise "FAIL a2" unless s.get_depth == 1
s.ascend
raise "FAIL a3" unless s.get_depth == 0
puts "PASS: 70_push_depth_three"

@@[target("swift")]

// Test 105: @@:self.method() from lifecycle handlers (F1 regression)

@@system LifecycleSelfCall {
    interface:
        tick()
        go()
        get_count(): int

    machine:
        $A {
            $>() { @@:self.tick() }
            <$() { @@:self.tick() }
            go() { -> $B }
            tick() { self.count = self.count + 1 }
            get_count(): int { @@:(self.count) }
        }

        $B {
            $>() { @@:self.tick() }
            tick() { self.count = self.count + 1 }
            get_count(): int { @@:(self.count) }
        }

    domain:
        count: Int = 0
}

// main
    print("=== Test 105: @@:self.method() from lifecycle handlers (F1 regression) ===")
    let s = @@LifecycleSelfCall()
    if s.get_count() != 1 { fatalError("Expected 1") }
    print("TC1: @@:self from start state $> - PASS")
    s.go()
    if s.get_count() != 3 { fatalError("Expected 3") }
    print("TC2/TC3: @@:self from <$ + post-transition $> - PASS")
    print("PASS: F1 regression")

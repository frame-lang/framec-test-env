<?php
@@target php

@@system TransitionExitArgs {
    interface:
        leave()
        get_log(): list

    machine:
        $Active {
            <$(reason: str, code: int) {
                $this->log[] = "exit:{$reason}:{$code}";
            }

            leave() {
                $this->log[] = "leaving";
                ("cleanup", 42) -> $Done
            }

            get_log(): list {
                @@:($this->log)
                return;
            }
        }

        $Done {
            $>() {
                $this->log[] = "enter:done";
            }

            get_log(): list {
                @@:($this->log)
                return;
            }
        }
    domain:
        log = []
}

echo "=== Test 18: Transition Exit Args ===" . "\n";
$s = new TransitionExitArgs();

$log = $s->get_log();
if (count($log) !== 0) { echo "FAIL: Expected empty log\n"; exit(1); }

$s->leave();
$log = $s->get_log();
if (!in_array("leaving", $log)) { echo "FAIL: Expected 'leaving' in log\n"; exit(1); }
if (!in_array("exit:cleanup:42", $log)) { echo "FAIL: Expected 'exit:cleanup:42' in log\n"; exit(1); }
if (!in_array("enter:done", $log)) { echo "FAIL: Expected 'enter:done' in log\n"; exit(1); }
echo "Log after transition: " . implode(", ", $log) . "\n";

echo "PASS: Transition exit args work correctly" . "\n";

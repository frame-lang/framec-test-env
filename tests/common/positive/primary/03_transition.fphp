<?php
@@target php

@@system WithTransition {
    interface:
        next()
        get_state(): str

    machine:
        $First {
            next() {
                echo "Transitioning: First -> Second\n";
                -> $Second
            }

            get_state(): str {
                return "First";
            }
        }

        $Second {
            next() {
                echo "Transitioning: Second -> First\n";
                -> $First
            }

            get_state(): str {
                return "Second";
            }
        }
}

echo "=== Test 03: State Transitions ===" . "\n";
$s = new WithTransition();

$state = $s->get_state();
if ($state !== "First") { echo "FAIL: Expected 'First', got '{$state}'\n"; exit(1); }
echo "Initial state: {$state}" . "\n";

$s->next();
$state = $s->get_state();
if ($state !== "Second") { echo "FAIL: Expected 'Second', got '{$state}'\n"; exit(1); }
echo "After first next(): {$state}" . "\n";

$s->next();
$state = $s->get_state();
if ($state !== "First") { echo "FAIL: Expected 'First', got '{$state}'\n"; exit(1); }
echo "After second next(): {$state}" . "\n";

echo "PASS: State transitions work correctly" . "\n";

@@[target("lua")]
@@system HSMDefaultForward {
    interface:
        handled_event()
        unhandled_event()
        get_log(): list

    machine:
        $Child => $Parent {
            handled_event() {
                self.log[#self.log + 1] = "Child:handled_event"
            }

            get_log(): list {
                @@:(self.log)
                return
            }

            => $^
        }

        $Parent {
            handled_event() {
                self.log[#self.log + 1] = "Parent:handled_event"
            }

            unhandled_event() {
                self.log[#self.log + 1] = "Parent:unhandled_event"
            }

            get_log(): list {
                @@:(self.log)
                return
            }
        }
    domain:
        log: list = []
}

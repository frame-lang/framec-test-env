@@target lua
@@system HSMOmittedHandlers {
    interface:
        handled_by_child()
        forwarded_explicitly()
        unhandled_no_forward()
        get_log(): list
        get_state(): str

    machine:
        $Child => $Parent {
            handled_by_child() {
                self.log[#self.log + 1] = "Child:handled_by_child"
            }

            forwarded_explicitly() {
                self.log[#self.log + 1] = "Child:before_forward"
                => $^
            }

            get_log(): list {
                return self.log
            }

            get_state(): str {
                return "Child"
            }
        }

        $Parent {
            handled_by_child() {
                self.log[#self.log + 1] = "Parent:handled_by_child"
            }

            forwarded_explicitly() {
                self.log[#self.log + 1] = "Parent:forwarded_explicitly"
            }

            unhandled_no_forward() {
                self.log[#self.log + 1] = "Parent:unhandled_no_forward"
            }

            get_log(): list {
                return self.log
            }

            get_state(): str {
                return "Parent"
            }
        }
    domain:
        log: list = []
}
@@system HSMDefaultForward {
    interface:
        child_handled()
        parent_handled()
        both_respond()
        get_log(): list

    machine:
        $Child => $Parent {
            child_handled() {
                self.log[#self.log + 1] = "Child:child_handled"
            }

            get_log(): list {
                return self.log
            }

            => $^
        }

        $Parent {
            child_handled() {
                self.log[#self.log + 1] = "Parent:child_handled"
            }

            parent_handled() {
                self.log[#self.log + 1] = "Parent:parent_handled"
            }

            both_respond() {
                self.log[#self.log + 1] = "Parent:both_respond"
            }

            get_log(): list {
                return self.log
            }
        }
    domain:
        log: list = []
}

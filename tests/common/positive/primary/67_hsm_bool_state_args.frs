@@target rust

@@system BoolStateArg {
    interface:
        configure(active: bool)
        is_active(): bool

    machine:
        $Idle {
            configure(active: bool) {
                -> $Active(active)
            }
            is_active(): bool {
                @@:(false)
                return;
            }
        }

        $Active => $Frame(flag: bool) {
            configure(active: bool) {
                -> $Active(active)
            }
            is_active(): bool {
                => $^
            }
        }

        $Frame {
            is_active(): bool {
                @@:(flag)
                return;
            }
        }
    domain:
        n: i32
}

fn main() {
    let mut s = @@BoolStateArg();
    if s.is_active() != false { println!("FAIL idle"); std::process::exit(1); }
    s.configure(true);
    if s.is_active() != true { println!("FAIL true"); std::process::exit(1); }
    s.configure(false);
    if s.is_active() != false { println!("FAIL false"); std::process::exit(1); }
    s.configure(true);
    if s.is_active() != true { println!("FAIL re-true"); std::process::exit(1); }
    println!("PASS: 67_hsm_bool_state_args");
}

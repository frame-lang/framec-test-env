@@target gdscript
extends SceneTree

# Test 49: HSM Enter/Exit with Parameters
#
# Tests enter and exit handlers with parameters in HSM context:
# - Exit params passed correctly
# - Enter params passed to target state
# - Transition syntax: (exit_args) -> (enter_args) $Target

@@system HSMEnterExitParams {
    interface:
        go_to_a()
        go_to_sibling()
        go_back()
        get_log(): list
        get_state(): String

    machine:
        $Start {
            go_to_a() {
                -> ("starting") $ChildA
            }

            get_log(): list {
                @@:(self.log)
                return
            }

            get_state(): String {
                @@:("Start")
                return
            }
        }

        $ChildA => $Parent {
            $>(msg: String) {
                self.log.append("ChildA:enter(" + str(msg) + ")")
            }

            <$(reason: str) {
                self.log.append("ChildA:exit(" + str(reason) + ")")
            }

            go_to_sibling() {
                ("leaving_A") -> ("arriving_B") $ChildB
            }

            get_log(): list {
                @@:(self.log)
                return
            }

            get_state(): String {
                @@:("ChildA")
                return
            }
        }

        $ChildB => $Parent {
            $>(msg: String) {
                self.log.append("ChildB:enter(" + str(msg) + ")")
            }

            <$(reason: str) {
                self.log.append("ChildB:exit(" + str(reason) + ")")
            }

            go_back() {
                ("leaving_B") -> ("returning_A") $ChildA
            }

            get_log(): list {
                @@:(self.log)
                return
            }

            get_state(): String {
                @@:("ChildB")
                return
            }
        }

        $Parent {
            get_log(): list {
                @@:(self.log)
                return
            }

            get_state(): String {
                @@:("Parent")
                return
            }
        }
    domain:
        log: list = []
}

func main():
    print("=== Test 49: HSM Enter/Exit with Params ===")
    var s = @@HSMEnterExitParams()

    # First go to ChildA with enter params
    s.go_to_a()
    var log = s.get_log()
    assert("ChildA:enter(starting)" in log, "Expected ChildA:enter(starting), got " + str(log))
    print("TC2.5.0: Initial transition with enter params - PASS")

    # TC2.5.1: Exit params passed correctly
    s.go_to_sibling()
    log = s.get_log()
    assert("ChildA:exit(leaving_A)" in log, "Expected exit with param, got " + str(log))
    print("TC2.5.1: Exit params passed correctly - PASS")

    # TC2.5.2: Enter params passed to target state
    assert("ChildB:enter(arriving_B)" in log, "Expected enter with param, got " + str(log))
    assert(s.get_state() == "ChildB", "Expected ChildB, got " + str(s.get_state()))
    print("TC2.5.2: Enter params passed to target - PASS")

    # TC2.5.3: Return transition with different params
    s.go_back()
    log = s.get_log()
    assert("ChildB:exit(leaving_B)" in log, "Expected ChildB exit, got " + str(log))
    assert("ChildA:enter(returning_A)" in log, "Expected ChildA enter, got " + str(log))
    print("TC2.5.3: Return transition with params - PASS")

    print("PASS: HSM enter/exit with params works correctly")

func _init():
    main()
    quit()

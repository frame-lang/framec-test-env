@@[target("dart")]

import 'dart:io';
import 'dart:convert';

@@[persist(String)]
@@[save(saveState)]
@@[load(restoreState)]
@@system PersistPushpopStateArgs {
    interface:
        push_modal(v: int)
        pop_modal()
        get_slot(): int

    machine:
        $Idle {
            push_modal(v: int) {
                push$
                -> $Modal(v)
            }
            pop_modal() {
                -> pop$
            }
            get_slot(): int {
                @@:(-99)
                return;
            }
        }

        $Modal(slot: int) {
            push_modal(v: int) {
                push$
                -> $Modal(v)
            }
            pop_modal() {
                -> pop$
            }
            get_slot(): int {
                @@:(slot)
                return;
            }
        }
    domain:
        v: int = 0
}

void main() {
    print("=== Test 58: Persist × push/pop × state-args (Dart) ===");
    final s1 = PersistPushpopStateArgs();
    s1.push_modal(42);
    s1.push_modal(77);
    final pre = s1.get_slot();
    if (pre != 77) { print("FAIL: pre $pre"); exit(1); }
    print("1. Pre-save top slot=$pre");

    final snap = s1.saveState();
    final s2 = PersistPushpopStateArgs();

    s2.restoreState(snap);
    final post = s2.get_slot();
    if (post != 77) { print("FAIL: post $post"); exit(1); }
    print("2. Post-restore top slot=$post");

    s2.pop_modal();
    final mid = s2.get_slot();
    if (mid != 42) { print("FAIL: mid $mid"); exit(1); }
    print("3. After first pop slot=$mid");

    s2.pop_modal();
    final bottom = s2.get_slot();
    if (bottom != -99) { print("FAIL: bottom $bottom"); exit(1); }
    print("4. After second pop slot=$bottom");

    print("PASS: 58_persist_pushpop_state_args");
}

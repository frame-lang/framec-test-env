@@[target("java")]

import java.util.List;
import java.util.Arrays;
import java.util.ArrayList;

@@[persist(String)]
@@[save(save_state)]
@@[load(restore_state)]
@@system NestedList {
    interface:
        configure(rows: java.util.List<java.util.List<Integer>>)
        first_first(): int
        outer_size(): int

    machine:
        $Idle {
            configure(rows: java.util.List<java.util.List<Integer>>) {
                -> $Active(rows)
            }
            first_first(): int { @@:(-1) }
            outer_size(): int { @@:(0) }
        }
        $Active(rows: java.util.List<java.util.List<Integer>>) {
            configure(rows: java.util.List<java.util.List<Integer>>) {
                -> $Active(rows)
            }
            first_first(): int { @@:(((java.util.List<Integer>)rows.get(0)).get(0)) }
            outer_size(): int { @@:(rows.size()) }
        }
    domain:
        n: int = 0
}

class Main {
    public static void main(String[] args) throws Exception {
        NestedList s1 = @@NestedList();
        java.util.List<java.util.List<Integer>> data = new ArrayList<>();
        data.add(Arrays.asList(10, 20));
        data.add(Arrays.asList(30, 40));
        s1.configure(data);
        if (s1.first_first() != 10) { System.out.println("FAIL pre"); System.exit(1); }
        if (s1.outer_size() != 2) { System.out.println("FAIL size"); System.exit(1); }
        String snap = s1.save_state();
        NestedList s2 = @@NestedList();

        s2.restore_state(snap);
        if (s2.first_first() != 10) { System.out.println("FAIL post got " + s2.first_first()); System.exit(1); }
        if (s2.outer_size() != 2) { System.out.println("FAIL post size"); System.exit(1); }
        System.out.println("PASS: 75_nested_list_state_arg");
    }
}

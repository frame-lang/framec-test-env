@@target typescript

// Test 48: HSM Exit Cascade
//
// Tests the HSM exit cascade per docs/frame_runtime_introduction.md
// Step 21+. When exiting an HSM child, the kernel fires <$ on every
// layer of the source chain bottom-up (child first, parent last).

@@system HSMExitHandlers {
    interface:
        go_to_other()
        go_to_parent()
        go_to_child()
        get_log(): string[]
        get_state(): str
        get_child_var(): int

    machine:
        $Child => $Parent {
            $.child_var: int = 42

            $>() {
                this.log.push("Child:enter")
            }

            <$() {
                let val = $.child_var
                this.log.push(`Child:exit(var=${val})`)
            }

            go_to_other() {
                -> $Other
            }

            go_to_parent() {
                -> $Parent
            }

            get_log(): list {
                @@:(this.log)
                return;
            }

            get_state(): str {
                @@:("Child")
                return;
            }

            get_child_var(): int {
                @@:($.child_var)
                return;
            }
        }

        $Parent {
            $>() {
                this.log.push("Parent:enter")
            }

            <$() {
                this.log.push("Parent:exit")
            }

            go_to_child() {
                -> $Child
            }

            go_to_other() {
                -> $Other
            }

            get_log(): list {
                @@:(this.log)
                return;
            }

            get_state(): str {
                @@:("Parent")
                return;
            }

            get_child_var(): int {
                @@:(-1)
                return;
            }
        }

        $Other {
            $>() {
                this.log.push("Other:enter")
            }

            go_to_child() {
                -> $Child
            }

            go_to_parent() {
                -> $Parent
            }

            get_log(): list {
                @@:(this.log)
                return;
            }

            get_state(): str {
                @@:("Other")
                return;
            }

            get_child_var(): int {
                @@:(-1)
                return;
            }
        }
    domain:
        log: string[] = []
}

function main() {
    console.log("=== Test 48: HSM Exit Cascade ===");
    const s = @@HSMExitHandlers();

    // Initial state is Child. Cascade fires Parent.$> then Child.$>.
    let log = s.get_log();
    if (!log.includes("Parent:enter")) throw new Error(`Expected Parent:enter on init cascade, got ${JSON.stringify(log)}`);
    if (!log.includes("Child:enter")) throw new Error(`Expected Child:enter on init, got ${JSON.stringify(log)}`);
    if (s.get_state() !== "Child") throw new Error(`Expected Child, got ${s.get_state()}`);
    console.log("TC1: Initial entry cascades through Parent then Child - PASS");

    // TC2: Exiting Child to Other fires Child.<$ then Parent.<$ (bottom-up).
    s.go_to_other();
    log = s.get_log();
    if (!log.includes("Child:exit(var=42)")) throw new Error(`Expected Child:exit(var=42), got ${JSON.stringify(log)}`);
    if (!log.includes("Parent:exit")) throw new Error(`Expected Parent:exit (cascade), got ${JSON.stringify(log)}`);
    if (!log.includes("Other:enter")) throw new Error(`Expected Other:enter, got ${JSON.stringify(log)}`);
    const childExitIdx = log.indexOf("Child:exit(var=42)");
    const parentExitIdx = log.indexOf("Parent:exit");
    if (childExitIdx >= parentExitIdx) throw new Error(`Child:exit should fire BEFORE Parent:exit (bottom-up), got ${JSON.stringify(log)}`);
    console.log("TC2: Child:exit fires before Parent:exit (bottom-up cascade) - PASS");

    // TC3: Exit handler can access child's state variables (verified by var=42 in log).
    console.log("TC3: Exit handler accesses state var (var=42) - PASS");

    // TC4: Re-entering child fires the entry cascade again.
    s.go_to_child();
    log = s.get_log();
    const parentEnterCount = log.filter((x: string) => x === "Parent:enter").length;
    const childEnterCount = log.filter((x: string) => x === "Child:enter").length;
    if (parentEnterCount !== 2) throw new Error(`Expected 2 Parent:enter, got ${parentEnterCount}: ${JSON.stringify(log)}`);
    if (childEnterCount !== 2) throw new Error(`Expected 2 Child:enter, got ${childEnterCount}: ${JSON.stringify(log)}`);
    console.log("TC4: Re-entering Child cascades Parent.$> then Child.$> - PASS");

    console.log("PASS: HSM exit cascade fires Child.<$ then Parent.<$");
}

main();

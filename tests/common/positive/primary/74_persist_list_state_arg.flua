@@target lua

@@[persist]
@@system PersistList {
    interface:
        configure(items: table)
        first_item(): int
        size(): int

    machine:
        $Idle {
            configure(items: table) {
                -> $Active(items)
            }
            first_item(): int { @@:(-1) }
            size(): int { @@:(0) }
        }
        $Active(items: table) {
            configure(items: table) {
                -> $Active(items)
            }
            first_item(): int { @@:(items[1]) }
            size(): int { @@:(#items) }
        }
    domain:
        n: int = 0
}

local s1 = PersistList:new()
s1:configure({10, 20, 30})
if s1:first_item() ~= 10 then print("FAIL pre"); os.exit(1) end
local snap = s1:save_state()

local s2 = PersistList.restore_state(snap)
if s2:first_item() ~= 10 then print("FAIL restored first_item"); os.exit(1) end
if s2:size() ~= 3 then print("FAIL restored size"); os.exit(1) end
print("PASS: 74_persist_list_state_arg")

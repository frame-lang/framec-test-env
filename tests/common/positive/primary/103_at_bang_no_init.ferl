@@[target("erlang")]
@@[persist]
@@[save(save_state)]
@@[load(restore_state)]
@@system Counter {
    interface:
        inc()
        get_n(): int
        get_lc(): int
    machine:
        $Active {
            $> { self.lifecycle_count = self.lifecycle_count + 1 }
            inc() { self.n = self.n + 1 }
            get_n(): int { @@:(self.n) }
            get_lc(): int { @@:(self.lifecycle_count) }
        }
    domain:
        n = 0
        lifecycle_count = 0
}

@@[target("lua")]

@@[persist(string)]
@@[save(save_state)]
@@[load(restore_state)]
@@system DictOfList {
    interface:
        configure(m: table)
        get_at(key: String, idx: int): int

    machine:
        $Idle {
            configure(m: table) { -> $Active(m) }
            get_at(key: String, idx: int): int { @@:(-1) }
        }
        $Active(m: table) {
            configure(m: table) { -> $Active(m) }
            get_at(key: String, idx: int): int {
                local __l = m[key]
                if __l and __l[idx + 1] then @@:(__l[idx + 1]) else @@:(-1) end
            }
        }
    domain:
        n: int = 0
}

local s1 = DictOfList:new()
s1:configure({a = {10, 20}, b = {30, 40, 50}})
if s1:get_at("a", 0) ~= 10 then print("FAIL pre a.0"); os.exit(1) end
if s1:get_at("b", 2) ~= 50 then print("FAIL pre b.2"); os.exit(1) end
local snap = s1:save_state()
local s2 = DictOfList:new()

s2:restore_state(snap)
if s2:get_at("a", 0) ~= 10 then print("FAIL post a.0"); os.exit(1) end
if s2:get_at("a", 1) ~= 20 then print("FAIL post a.1"); os.exit(1) end
if s2:get_at("b", 2) ~= 50 then print("FAIL post b.2"); os.exit(1) end
print("PASS: 79_dict_of_list_state_arg")

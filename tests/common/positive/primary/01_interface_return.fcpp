@@target cpp_17

#include <iostream>
#include <string>
#include <cassert>

@@system InterfaceReturnTest {
    interface:
        get_value(): int
        get_name(): str

    machine:
        $Ready {
            get_value(): int {
                return 42
            }

            get_name(): str {
                return std::string("Frame")
            }
        }
}

int main() {
    InterfaceReturnTest s;
    assert(s.get_value() == 42);
    assert(s.get_name() == "Frame");
    std::cout << "PASS: 01 interface return" << std::endl;
    return 0;
}

@@[target("ruby")]

# Tests that nested interface calls maintain separate return contexts

@@system SystemReturnReentrantTest {
    interface:
        outer_call(): str
        inner_call(): str
        nested_call(): str
        get_log(): str

    machine:
        $Start {
            $.log: str = ""

            outer_call(): str {
                $.log = $.log + "outer_start,"
                # Call inner method - this creates nested return context
                inner_result = self.inner_call()
                $.log = $.log + "outer_after_inner,"
                # Our return should be independent of inner's return
                @@:("outer_result:" + inner_result)
                return
            }

            inner_call(): str {
                $.log = $.log + "inner,"
                @@:("inner_result")
                return
            }

            nested_call(): str {
                $.log = $.log + "nested_start,"
                # Two levels of nesting
                result1 = self.inner_call()
                result2 = self.outer_call()
                $.log = $.log + "nested_end,"
                @@:("nested:" + result1 + "+" + result2)
                return
            }

            get_log(): str {
                @@:($.log)
                return
            }
        }
}

puts("=== Test 16: System Return Reentrant (Nested Calls) ===")

# Test 1: Simple inner call
s1 = SystemReturnReentrantTest.new
result = s1.inner_call()
raise "Expected 'inner_result', got '#{result}'" unless result == "inner_result"
puts("1. inner_call() = '#{result}'")

# Test 2: Outer calls inner - return contexts should be separate
s2 = SystemReturnReentrantTest.new
result = s2.outer_call()
raise "Expected 'outer_result:inner_result', got '#{result}'" unless result == "outer_result:inner_result"
log = s2.get_log()
raise "Missing outer_start in log: #{log}" unless log.include?("outer_start")
raise "Missing inner in log: #{log}" unless log.include?("inner")
raise "Missing outer_after_inner in log: #{log}" unless log.include?("outer_after_inner")
puts("2. outer_call() = '#{result}'")
puts("   Log: '#{log}'")

# Test 3: Deeply nested calls
s3 = SystemReturnReentrantTest.new
result = s3.nested_call()
expected = "nested:inner_result+outer_result:inner_result"
raise "Expected '#{expected}', got '#{result}'" unless result == expected
puts("3. nested_call() = '#{result}'")

puts("PASS: System return reentrant (nested calls) works correctly")

@@[target("gdscript")]
extends SceneTree

@@system HsmSelfCall {
    interface:
        drive_via_child(): int
        compute(): int
        get_trace(): str

    machine:
        $Child => $Parent {
            drive_via_child(): int {
                self.trace = self.trace + "child:before;"
                @@:self.compute()
                self.trace = self.trace + "child:after;"
                @@:(self.scratch)
            }
            compute(): int {
                self.trace = self.trace + "compute@child;"
                => $^
            }
            get_trace(): String {
                @@:(self.trace)
            }
        }

        $Parent {
            compute(): int {
                self.trace = self.trace + "compute@parent;"
                self.scratch = 42
                @@:(42)
            }
        }
    domain:
        trace: String = ""
        scratch: int = 0
}

func _initialize():
    print("=== Test 63: HSM cascade × @@:self (GDScript) ===")
    var s = @@HsmSelfCall()
    var r = s.drive_via_child()
    var trace = s.get_trace()
    print("1. drive_via_child returned " + str(r) + ", trace=" + trace)

    var expected = "child:before;compute@child;compute@parent;child:after;"
    if trace != expected:
        print("FAIL: trace=" + trace)
        quit(1)
        return
    if r != 42:
        print("FAIL: r=" + str(r))
        quit(1)
        return

    print("PASS: 63_hsm_self_call")
    quit(0)

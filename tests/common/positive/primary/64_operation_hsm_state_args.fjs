@@target javascript

@@system OpHsmStateArgs {
    operations:
        add_offset(x: int, off: int): int {
            return x + off;
        }

    interface:
        enter_active(t: int)
        classify(v: int): int

    machine:
        $Idle {
            enter_active(t: number) {
                -> $Active(t)
            }
            classify(v: number): number {
                @@:(-1)
                return
            }
        }

        $Active => $Frame(threshold: number) {
            enter_active(t: number) {
                -> $Active(t)
            }
            classify(v: number): number {
                @@:(this.add_offset(v, threshold))
                return
            }
        }

        $Frame {
        }
    domain:
        n: number = 0
}

console.log("=== Test 64: Operations × HSM × state-args (JS) ===");
const s = new OpHsmStateArgs();

const pre = s.classify(5);
if (pre !== -1) { console.log("FAIL: pre " + pre); process.exit(1); }
console.log(`1. Idle classify(5) = ${pre}`);

s.enter_active(10);
const r = s.classify(5);
if (r !== 15) { console.log("FAIL: r " + r); process.exit(1); }
console.log(`2. classify(5) with threshold=10 → ${r}`);

const r2 = s.classify(7);
if (r2 !== 17) { console.log("FAIL: r2 " + r2); process.exit(1); }
console.log(`3. classify(7) with threshold=10 → ${r2}`);

s.enter_active(100);
const r3 = s.classify(5);
if (r3 !== 105) { console.log("FAIL: r3 " + r3); process.exit(1); }
console.log(`4. classify(5) with threshold=100 → ${r3}`);

console.log("PASS: 64_operation_hsm_state_args");

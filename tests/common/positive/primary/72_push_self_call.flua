@@[target("lua")]

@@system PushSelf {
    interface:
        enter_modal()
        ping(): int
        exit_modal()
        compute(): int

    machine:
        $Idle {
            enter_modal() { push$; -> $Modal }
            ping(): int { @@:(0); return }
            compute(): int { @@:(99); return }
        }
        $Modal {
            ping(): int { @@:(self:compute() + 1); return }
            compute(): int { @@:(10); return }
            exit_modal() { -> pop$ }
        }
    domain: n: int = 0
}

local s = @@PushSelf()
if s:ping() ~= 0 then error("FAIL idle: " .. tostring(s:ping())) end
s:enter_modal()
if s:ping() ~= 11 then error("FAIL modal: " .. tostring(s:ping())) end
s:exit_modal()
if s:ping() ~= 0 then error("FAIL back") end
print("PASS: 72_push_self_call")

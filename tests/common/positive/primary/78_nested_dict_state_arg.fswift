@@[target("swift")]

import Foundation

@@[persist]
@@system NestedDict {
    interface:
        configure(m: [String: [String: Int]])
        get_inner(outer_key: String, inner_key: String): Int

    machine:
        $Idle {
            configure(m: [String: [String: Int]]) { -> $Active(m) }
            get_inner(outer_key: String, inner_key: String): Int { @@:(-1) }
        }
        $Active(m: [String: [String: Int]]) {
            configure(m: [String: [String: Int]]) { -> $Active(m) }
            get_inner(outer_key: String, inner_key: String): Int {
                @@:(m[outer_key]?[inner_key] ?? -1)
            }
        }
    domain:
        n : Int = 0
}

let s1 = NestedDict()
s1.configure(["u": ["x": 1, "y": 2], "v": ["z": 3]])
if s1.get_inner("u", "x") != 1 { print("FAIL pre"); exit(1) }
let snap = s1.saveState()
let s2 = NestedDict.restoreState(snap)
if s2.get_inner("u", "x") != 1 { print("FAIL post u.x"); exit(1) }
if s2.get_inner("u", "y") != 2 { print("FAIL post u.y"); exit(1) }
if s2.get_inner("v", "z") != 3 { print("FAIL post v.z"); exit(1) }
print("PASS: 78_nested_dict_state_arg")

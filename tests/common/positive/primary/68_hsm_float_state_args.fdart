@@target dart

import 'dart:io';
import 'dart:math';

@@system FloatStateArg {
    interface:
        configure(rate: float)
        scale(v: float): float

    machine:
        $Idle {
            configure(rate: double) {
                -> $Active(rate)
            }
            scale(v: double): double {
                @@:(v)
                return;
            }
        }

        $Active => $Frame(rate: double) {
            configure(rate: double) {
                -> $Active(rate)
            }
            scale(v: double): double {
                => $^
            }
        }

        $Frame {
            scale(v: double): double {
                @@:(v * rate)
                return;
            }
        }
    domain:
        n: int = 0
}

void main() {
    final s = FloatStateArg();
    if ((s.scale(2.0) - 2.0).abs() > 1e-9) { print("FAIL idle"); exit(1); }
    s.configure(0.5);
    if ((s.scale(10.0) - 5.0).abs() > 1e-9) { print("FAIL 0.5"); exit(1); }
    s.configure(2.5);
    if ((s.scale(4.0) - 10.0).abs() > 1e-9) { print("FAIL 2.5"); exit(1); }
    print("PASS: 68_hsm_float_state_args");
}

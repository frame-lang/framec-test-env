@@[target("csharp")]

using System;

@@[persist(string)]
@@[save(SaveState)]
@@[load(RestoreState)]
@@system PersistPushpopStateArgs {
    interface:
        push_modal(v: int)
        pop_modal()
        get_slot(): int

    machine:
        $Idle {
            push_modal(v: int) {
                push$
                -> $Modal(v)
            }
            pop_modal() {
                -> pop$
            }
            get_slot(): int {
                @@:(-99)
            }
        }

        $Modal(slot: int) {
            push_modal(v: int) {
                push$
                -> $Modal(v)
            }
            pop_modal() {
                -> pop$
            }
            get_slot(): int {
                @@:(slot)
            }
        }
    domain:
        v : int = 0
}

class Program {
    static void Main(string[] args) {
        Console.WriteLine("=== Test 58: Persist × push/pop × state-args (C#) ===");
        var s1 = @@PersistPushpopStateArgs();
        s1.push_modal(42);
        s1.push_modal(77);
        int pre = s1.get_slot();
        if (pre != 77) { Console.WriteLine($"FAIL: pre {pre}"); Environment.Exit(1); }
        Console.WriteLine($"1. Pre-save top slot={pre}");

        var snap = s1.SaveState();
        var s2 = @@PersistPushpopStateArgs();

        s2.RestoreState(snap);
        int post = s2.get_slot();
        if (post != 77) { Console.WriteLine($"FAIL: post {post}"); Environment.Exit(1); }
        Console.WriteLine($"2. Post-restore top slot={post}");

        s2.pop_modal();
        int mid = s2.get_slot();
        if (mid != 42) { Console.WriteLine($"FAIL: mid {mid}"); Environment.Exit(1); }
        Console.WriteLine($"3. After first pop slot={mid}");

        s2.pop_modal();
        int bottom = s2.get_slot();
        if (bottom != -99) { Console.WriteLine($"FAIL: bottom {bottom}"); Environment.Exit(1); }
        Console.WriteLine($"4. After second pop slot={bottom}");

        Console.WriteLine("PASS: 58_persist_pushpop_state_args");
    }
}

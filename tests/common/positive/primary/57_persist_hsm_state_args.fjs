@@[target("javascript")]

@@[persist(string)]
@@[save(saveState)]
@@[load(restoreState)]
@@system PersistHsmStateArgs {
    interface:
        drive(p: int)
        get_x(): int

    machine:
        $Start {
            drive(p: number) {
                -> $Child(p)
            }
            get_x(): number {
                @@:(-1)
                return
            }
        }

        $Child => $Parent(x: number) {
            drive(p: number) {
                -> $Child(p)
            }
            get_x(): number {
                @@:(x)
                return
            }
        }

        $Parent {
        }
    domain:
        v: number = 0
}

console.log("=== Test 57: Persist HSM × State-Args Round-Trip (JS) ===");
const s1 = @@PersistHsmStateArgs();
s1.drive(42);
const pre = s1.get_x();
if (pre !== 42) { console.log("FAIL: pre " + pre); process.exit(1); }
console.log(`1. Pre-save x=${pre}`);

const snap = s1.saveState();
const s2 = @@PersistHsmStateArgs();

s2.restoreState(snap);
const post = s2.get_x();
if (post !== 42) { console.log("FAIL: post " + post); process.exit(1); }
console.log(`2. Post-restore x=${post}`);

s2.drive(99);
const post2 = s2.get_x();
if (post2 !== 99) { console.log("FAIL: post2 " + post2); process.exit(1); }
console.log(`3. Post-restore-drive x=${post2}`);

console.log("PASS: 57_persist_hsm_state_args");

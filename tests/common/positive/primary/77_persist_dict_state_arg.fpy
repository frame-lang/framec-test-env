@@[target("python_3")]

@@[persist]
@@system PersistDict {
    operations:
        @@[save]
        save_state(): bytes {}

        @@[load]
        restore_state(data: bytes) {}

    interface:
        configure(m: dict)
        get_v(key: str): int

    machine:
        $Idle {
            configure(m: dict) { -> $Active(m) }
            get_v(key: str): int { @@:(-1); return }
        }
        $Active(m: dict) {
            configure(m: dict) { -> $Active(m) }
            get_v(key: str): int { @@:(m.get(key, -1)); return }
        }
    domain:
        n: int = 0
}

def main():
    s1 = PersistDict()
    s1.configure({"a": 10, "b": 20})
    assert s1.get_v("a") == 10
    snap = s1.save_state()
    s2 = PersistDict()

    s2.restore_state(snap)
    assert s2.get_v("a") == 10
    assert s2.get_v("b") == 20
    print("PASS: 77_persist_dict_state_arg")

if __name__ == '__main__':
    main()

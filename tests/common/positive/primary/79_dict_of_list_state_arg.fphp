@@[target("php")]

<?php

@@[persist(string)]
@@[save(save_state)]
@@[load(restore_state)]
@@system DictOfList {
    interface:
        configure(m: array)
        get_at(key: string, idx: int): int

    machine:
        $Idle {
            configure(m: array) { -> $Active(m) }
            get_at(key: string, idx: int): int { @@:(-1) }
        }
        $Active(m: array) {
            configure(m: array) { -> $Active(m) }
            get_at(key: string, idx: int): int {
                @@:(isset($m[$key]) && $idx < count($m[$key]) ? $m[$key][$idx] : -1)
            }
        }
    domain:
        n: int = 0
}

$s1 = @@DictOfList();
$s1->configure(["a" => [10, 20], "b" => [30, 40, 50]]);
if ($s1->get_at("a", 0) !== 10) { echo "FAIL pre a.0\n"; exit(1); }
if ($s1->get_at("b", 2) !== 50) { echo "FAIL pre b.2\n"; exit(1); }
$snap = $s1->save_state();
$s2 = @@DictOfList();

$s2->restore_state($snap);
if ($s2->get_at("a", 0) !== 10) { echo "FAIL post a.0\n"; exit(1); }
if ($s2->get_at("a", 1) !== 20) { echo "FAIL post a.1\n"; exit(1); }
if ($s2->get_at("b", 2) !== 50) { echo "FAIL post b.2\n"; exit(1); }
echo "PASS: 79_dict_of_list_state_arg\n";

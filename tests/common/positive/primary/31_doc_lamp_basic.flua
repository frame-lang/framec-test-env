@@[target("lua")]
@@system Lamp {
    interface:
        turnOn()
        turnOff()
        getColor(): str
        setColor(color: str)

    machine:
        $Off {
            turnOn() {
                -> $On
            }
            getColor(): str {
                @@:(self.color)
                return
            }
            setColor(color: str) {
                self.color = color
            }
        }

        $On {
            $>() {
                self.closeSwitch()
            }
            <$() {
                self.openSwitch()
            }
            turnOff() {
                -> $Off
            }
            getColor(): str {
                @@:(self.color)
                return
            }
            setColor(color: str) {
                self.color = color
            }
        }

    actions:
        closeSwitch() {
            self.switch_closed = true
        }
        openSwitch() {
            self.switch_closed = false
        }

    domain:
        color: str = "white"
        switch_closed: bool = False
}

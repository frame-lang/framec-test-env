@@target lua
@@system InterfaceReturn {
    interface:
        bool_return(): bool
        int_return(): int
        string_return(): str
        conditional_return(x: int): str
        computed_return(a: int, b: int): int
        explicit_bool(): bool
        explicit_int(): int
        explicit_string(): str
        explicit_conditional(x: int): str
        explicit_computed(a: int, b: int): int

    machine:
        $Active {
            bool_return(): bool {
                return true
            }

            int_return(): int {
                return 42
            }

            string_return(): str {
                return "Frame"
            }

            conditional_return(x: int): str {
                if x < 0 {
                    return "negative"
                } elseif x == 0 {
                    return "zero"
                } else {
                    return "positive"
                }
            }

            computed_return(a: int, b: int): int {
                result = a * b + 10
                return result
            }

            explicit_bool(): bool {
                @@:return = True
            }

            explicit_int(): int {
                @@:return = 42
            }

            explicit_string(): str {
                @@:return = "Frame"
            }

            explicit_conditional(x: int): str {
                    @@:return = "negative"
                    @@:return = "zero"
                    @@:return = "positive"
                if x < 0 {
                    return
                } elseif x == 0 {
                    return
                } else {
                }
            }

            explicit_computed(a: int, b: int): int {
                @@:return = result
                result = a * b + 10
            }
        }
}

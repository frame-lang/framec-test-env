@@[target("erlang")]
@@system HSMThreeLevels {
    interface:
        handleAtGrandchild()
        forwardToChild()
        forwardToParent()
        getLog(): str
    machine:
        $Grandchild => $Child {
            handleAtGrandchild() {
                self.log = self.log ++ ",gc_handled"
            }
            forwardToChild() {
                self.log = self.log ++ ",gc_fwd"
                => $^
            }
            forwardToParent() {
                self.log = self.log ++ ",gc_fwd"
                => $^
            }
            getLog(): str {
                @@:(self.log)
            }
        }
        $Child => $Parent {
            forwardToChild() {
                self.log = self.log ++ ",child_handled"
            }
            forwardToParent() {
                self.log = self.log ++ ",child_fwd"
                => $^
            }
            getLog(): str {
                @@:(self.log)
            }
        }
        $Parent {
            forwardToParent() {
                self.log = self.log ++ ",parent_handled"
            }
            getLog(): str {
                @@:(self.log)
            }
        }
    domain:
        log = "init"
}

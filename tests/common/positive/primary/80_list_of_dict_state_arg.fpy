@@[target("python_3")]

@@[persist]
@@system ListOfDict {
    operations:
        @@[save]
        save_state(): bytes {}

        @@[load]
        restore_state(data: bytes) {}

    interface:
        configure(rows: list)
        get_at(idx: int, key: str): int

    machine:
        $Idle {
            configure(rows: list) { -> $Active(rows) }
            get_at(idx: int, key: str): int { @@:(-1); return }
        }
        $Active(rows: list) {
            configure(rows: list) { -> $Active(rows) }
            get_at(idx: int, key: str): int {
                @@:(rows[idx].get(key, -1) if idx < len(rows) else -1)
                return
            }
        }
    domain:
        n: int = 0
}

def main():
    s1 = ListOfDict()
    s1.configure([{"x": 1, "y": 2}, {"z": 3}])
    assert s1.get_at(0, "x") == 1
    assert s1.get_at(1, "z") == 3
    snap = s1.save_state()
    s2 = ListOfDict()

    s2.restore_state(snap)
    assert s2.get_at(0, "x") == 1
    assert s2.get_at(0, "y") == 2
    assert s2.get_at(1, "z") == 3
    print("PASS: 80_list_of_dict_state_arg")

if __name__ == '__main__':
    main()

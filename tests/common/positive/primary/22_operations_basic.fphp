<?php
@@[target("php")]

@@system OperationsTest {
    operations:
        add(x: int, y: int): int {
            return $x + $y;
        }

        multiply(x: int, y: int): int {
            return $x * $y;
        }

        static factorial(n: int): int {
            if ($n <= 1) {
                return 1;
            }
            return $n * OperationsTest::factorial($n - 1);
        }

        static is_even(n: int): bool {
            return $n % 2 == 0;
        }

    interface:
        compute(a: int, b: int): int
        get_last_result(): int

    machine:
        $Ready {
            compute(a: int, b: int): int {
                $sum_val = $this->add($a, $b);
                $prod_val = $this->multiply($a, $b);
                $last_result = $sum_val + $prod_val;
                @@:($last_result)
                return;
            }

            get_last_result(): int {
                @@:($last_result)
                return;
            }
        }

    domain:
        last_result = 0

}

echo "=== Test 22: Operations Basic ===" . "\n";
$s = new OperationsTest();

$result = $s->add(3, 4);
if ($result !== 7) { echo "FAIL: Expected 7, got {$result}\n"; exit(1); }
echo "1. add(3, 4) = {$result}" . "\n";

$result = $s->multiply(3, 4);
if ($result !== 12) { echo "FAIL: Expected 12, got {$result}\n"; exit(1); }
echo "2. multiply(3, 4) = {$result}" . "\n";

$result = $s->compute(3, 4);
if ($result !== 19) { echo "FAIL: Expected 19, got {$result}\n"; exit(1); }
echo "3. compute(3, 4) = {$result}" . "\n";

$result = OperationsTest::factorial(5);
if ($result !== 120) { echo "FAIL: Expected 120, got {$result}\n"; exit(1); }
echo "4. factorial(5) = {$result}" . "\n";

$result = OperationsTest::is_even(4);
if ($result !== true) { echo "FAIL: Expected true\n"; exit(1); }
echo "5. is_even(4) = " . var_export($result, true) . "\n";

$result = OperationsTest::is_even(7);
if ($result !== false) { echo "FAIL: Expected false\n"; exit(1); }
echo "6. is_even(7) = " . var_export($result, true) . "\n";

$result = $s->factorial(4);
if ($result !== 24) { echo "FAIL: Expected 24, got {$result}\n"; exit(1); }
echo "7. instance->factorial(4) = {$result}" . "\n";

echo "PASS: Operations basic works correctly" . "\n";

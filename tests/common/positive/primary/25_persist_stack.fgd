@@[target("gdscript")]
extends SceneTree

@@[persist(String)]
@@[save(save_state)]
@@[load(restore_state)]
@@system PersistStack {
    interface:
        push_and_go()
        pop_back()
        get_state(): String
        get_depth(): int

    machine:
        $Start {
            push_and_go() {
                self.depth = self.depth + 1
                push$
                -> $Middle
            }

            pop_back() {
                pass  # nothing to pop
            }

            get_state(): String {
                @@:("start")
                return
            }

            get_depth(): int {
                @@:(self.depth)
                return
            }
        }

        $Middle {
            push_and_go() {
                self.depth = self.depth + 1
                push$
                -> $End
            }

            pop_back() {
                self.depth = self.depth - 1
                -> pop$
            }

            get_state(): String {
                @@:("middle")
                return
            }

            get_depth(): int {
                @@:(self.depth)
                return
            }
        }

        $End {
            push_and_go() {
                pass  # can't go further
            }

            pop_back() {
                self.depth = self.depth - 1
                -> pop$
            }

            get_state(): String {
                @@:("end")
                return
            }

            get_depth(): int {
                @@:(self.depth)
                return
            }
        }
    domain:
        depth: int = 0
}

func main():
    print("=== Test 25: Persist Stack (var_to_bytes) ===")

    # Test 1: Build up a stack
    var s1 = @@PersistStack()
    assert(s1.get_state() == "start", "Expected start, got " + str(s1.get_state()))

    s1.push_and_go()  # Start -> Middle (push Start)
    assert(s1.get_state() == "middle", "Expected middle, got " + str(s1.get_state()))
    assert(s1.get_depth() == 1, "Expected depth 1, got " + str(s1.get_depth()))

    s1.push_and_go()  # Middle -> End (push Middle)
    assert(s1.get_state() == "end", "Expected end, got " + str(s1.get_state()))
    assert(s1.get_depth() == 2, "Expected depth 2, got " + str(s1.get_depth()))

    print("1. Built stack: state=" + str(s1.get_state()) + ", depth=" + str(s1.get_depth()))

    # Test 2: Save state (should include stack)
    var data = s1.save_state()
    assert(typeof(data) == TYPE_PACKED_BYTE_ARRAY, "Expected bytes, got " + str(typeof(data)))
    print("2. Saved: " + str(data.size()) + " bytes")

    # Test 3: Restore and verify stack works
    var s2 = PersistStack.new()

    s2.restore_state(data)
    assert(s2.get_state() == "end", "Restored: expected end, got " + str(s2.get_state()))
    assert(s2.get_depth() == 2, "Restored: expected depth 2, got " + str(s2.get_depth()))
    print("3. Restored: state=" + str(s2.get_state()) + ", depth=" + str(s2.get_depth()))

    # Test 4: Pop should work after restore
    s2.pop_back()  # End -> Middle (pop)
    assert(s2.get_state() == "middle", "After pop: expected middle, got " + str(s2.get_state()))
    assert(s2.get_depth() == 1, "After pop: expected depth 1, got " + str(s2.get_depth()))
    print("4. After pop: state=" + str(s2.get_state()) + ", depth=" + str(s2.get_depth()))

    # Test 5: Pop again
    s2.pop_back()  # Middle -> Start (pop)
    assert(s2.get_state() == "start", "After 2nd pop: expected start, got " + str(s2.get_state()))
    assert(s2.get_depth() == 0, "After 2nd pop: expected depth 0, got " + str(s2.get_depth()))
    print("5. After 2nd pop: state=" + str(s2.get_state()) + ", depth=" + str(s2.get_depth()))

    print("PASS: Persist stack works correctly")

func _init():
    main()
    quit()

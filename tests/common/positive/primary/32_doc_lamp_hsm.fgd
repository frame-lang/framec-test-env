@@target gdscript
extends SceneTree

# Documentation Example: HSM Lamp with color behavior factored out

@@system LampHSM {
    interface:
        turnOn()
        turnOff()
        getColor(): String
        setColor(color: str)

    machine:
        $Off => $ColorBehavior {
            turnOn() {
                -> $On
            }
            => $^
        }

        $On => $ColorBehavior {
            $>() {
                self.turnOnLamp()
            }
            <$() {
                self.turnOffLamp()
            }
            turnOff() {
                -> $Off
            }
            => $^
        }

        $ColorBehavior {
            getColor(): String {
                @@:(self.color)
                return
            }
            setColor(color: str) {
                self.color = color
            }
        }

    actions:
        turnOnLamp() {
            self.lamp_on = true
        }
        turnOffLamp() {
            self.lamp_on = false
        }

    domain:
        color: str = "white"
        lamp_on: bool = false
}

func main():
    print("=== Test 32: Doc Lamp HSM ===")
    var lamp = @@LampHSM()

    # Color behavior available in both states
    assert(lamp.getColor() == "white", "Expected 'white', got '" + str(lamp.getColor()) + "'")
    lamp.setColor("red")
    assert(lamp.getColor() == "red", "Expected 'red', got '" + str(lamp.getColor()) + "'")

    # Turn on
    lamp.turnOn()
    assert(lamp.lamp_on == true, "Lamp should be on")

    # Color still works when on
    lamp.setColor("green")
    assert(lamp.getColor() == "green", "Expected 'green', got '" + str(lamp.getColor()) + "'")

    # Turn off
    lamp.turnOff()
    assert(lamp.lamp_on == false, "Lamp should be off")

    # Color still works when off
    assert(lamp.getColor() == "green", "Expected 'green', got '" + str(lamp.getColor()) + "'")

    print("PASS: HSM lamp works correctly")

func _init():
    main()
    quit()

@@[target("lua")]

@@system FloatStateArg {
    interface:
        configure(rate: float)
        scale(v: float): float

    machine:
        $Idle {
            configure(rate: float) {
                -> $Active(rate)
            }
            scale(v: float): float {
                @@:(v)
                return
            }
        }

        $Active => $Frame(rate: float) {
            configure(rate: float) {
                -> $Active(rate)
            }
            scale(v: float): float {
                => $^
            }
        }

        $Frame {
            scale(v: float): float {
                @@:(v * rate)
                return
            }
        }
    domain:
        n: int = 0
}

local s = FloatStateArg.new()
if s:scale(2.0) ~= 2.0 then error("FAIL idle") end
s:configure(0.5)
if math.abs(s:scale(10.0) - 5.0) > 1e-9 then error("FAIL 0.5") end
s:configure(2.5)
if math.abs(s:scale(4.0) - 10.0) > 1e-9 then error("FAIL 2.5") end
print("PASS: 68_hsm_float_state_args")

@@[target("kotlin")]

@@system HsmIfStateArgs {
    interface:
        enter_active(t: int)
        classify(v: int): int

    machine:
        $Idle {
            enter_active(t: int) {
                -> $Active(t)
            }
            classify(v: int): int {
                @@:(-1)
            }
        }

        $Active => $Frame(threshold: int) {
            enter_active(t: int) {
                -> $Active(t)
            }
            classify(v: int): int {
                if (v > threshold) {
                    @@:(1)
                } else {
                    @@:(0)
                }
            }
        }

        $Frame {
        }
    domain:
        n : int = 0
}

fun main() {
    println("=== Test 62: HSM × if × state-args (Kotlin) ===")
    val s = HsmIfStateArgs()

    val pre = s.classify(5)
    if (pre != -1) { println("FAIL: pre $pre"); kotlin.system.exitProcess(1) }
    println("1. Idle classify(5) = $pre")

    s.enter_active(10)
    val under = s.classify(5)
    if (under != 0) { println("FAIL: under $under"); kotlin.system.exitProcess(1) }
    println("2. classify(5) with threshold=10 → $under")

    val over = s.classify(15)
    if (over != 1) { println("FAIL: over $over"); kotlin.system.exitProcess(1) }
    println("3. classify(15) with threshold=10 → $over")

    val eq = s.classify(10)
    if (eq != 0) { println("FAIL: eq $eq"); kotlin.system.exitProcess(1) }
    println("4. classify(10) with threshold=10 → $eq")

    s.enter_active(50)
    val newUnder = s.classify(15)
    if (newUnder != 0) { println("FAIL: newUnder $newUnder"); kotlin.system.exitProcess(1) }
    println("5. classify(15) with threshold=50 → $newUnder")

    println("PASS: 62_hsm_if_state_args")
}

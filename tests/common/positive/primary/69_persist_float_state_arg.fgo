@@[target("go")]

@@[persist]

package main

import (
	"encoding/json"
	"fmt"
	"math"
	"os"
)

var _ = json.Marshal

@@system PFloat {
    interface:
        Configure(rate: float)
        GetRate(): float

    machine:
        $Idle {
            Configure(rate: float64) {
                -> $Active(rate)
            }
            GetRate(): float64 {
                @@:(0.0)
                return;
            }
        }

        $Active(rate: float64) {
            GetRate(): float64 {
                @@:(rate)
                return;
            }
        }
    domain:
        n: int = 0
}

func main() {
    s := NewPFloat()
    s.Configure(3.14159)
    snap := s.SaveState()
    s2 := RestorePFloat(snap)
    r := s2.GetRate()
    if math.Abs(r - 3.14159) > 1e-9 { fmt.Printf("FAIL %f\n", r); os.Exit(1) }
    fmt.Printf("PASS: 69_persist_float_state_arg, rate=%f\n", r)
}

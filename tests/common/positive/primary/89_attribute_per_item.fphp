@@[target("php")]

<?php

@@system Demo {
    interface:
        common(): string
        @@[target("python_3")] only_py(): string
        @@[target("php")] only_php(): string

    machine:
        $S {
            common(): string { @@:("common") }
            @@[target("python_3")] only_py(): string { @@:("only_py_present") }
            @@[target("php")] only_php(): string { @@:("only_php_present") }
        }
}

$d = @@Demo();
if ($d->common() !== "common") { echo "FAIL common: " . $d->common() . "\n"; exit(1); }
if ($d->only_php() !== "only_php_present") { echo "FAIL only_php: " . $d->only_php() . "\n"; exit(1); }
if (method_exists($d, "only_py")) { echo "FAIL: only_py should have been filtered out by @@[target(\"python_3\")]\n"; exit(1); }
echo "PASS: 89_attribute_per_item\n";

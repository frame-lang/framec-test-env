@@[target("typescript")]

@@system PushDeep {
    interface:
        descend()
        ascend()
        get_depth(): int

    machine:
        $Idle {
            descend() {
                push$
                -> $Modal1
            }
            get_depth(): number {
                @@:(0)
                return
            }
        }

        $Modal1 {
            descend() {
                push$
                -> $Modal2
            }
            ascend() {
                -> pop$
            }
            get_depth(): number {
                @@:(1)
                return
            }
        }

        $Modal2 {
            descend() {
                push$
                -> $Modal3
            }
            ascend() {
                -> pop$
            }
            get_depth(): number {
                @@:(2)
                return
            }
        }

        $Modal3 {
            ascend() {
                -> pop$
            }
            get_depth(): number {
                @@:(3)
                return
            }
        }
    domain:
        n: number = 0
}

const s = @@PushDeep();
if (s.get_depth() !== 0) { console.log("FAIL idle " + s.get_depth()); process.exit(1); }
s.descend();
if (s.get_depth() !== 1) { console.log("FAIL d1"); process.exit(1); }
s.descend();
if (s.get_depth() !== 2) { console.log("FAIL d2"); process.exit(1); }
s.descend();
if (s.get_depth() !== 3) { console.log("FAIL d3"); process.exit(1); }
s.ascend();
if (s.get_depth() !== 2) { console.log("FAIL a1"); process.exit(1); }
s.ascend();
if (s.get_depth() !== 1) { console.log("FAIL a2"); process.exit(1); }
s.ascend();
if (s.get_depth() !== 0) { console.log("FAIL a3"); process.exit(1); }
console.log("PASS: 70_push_depth_three");

<?php
@@target php

// Test 53: Self-call transition guard
//
// Verifies the automatic transition guard contract: when a handler
// self-calls a method that triggers a transition, code after the
// self-call must NOT execute. The trace must equal exactly
// ["run:before-self-call", "do_transition:body", "Done:enter"].

@@system TransitionGuard {

    interface:
        run()
        do_transition()
        get_trace(): list

    machine:
        $Active {
            run() {
                $this->trace[] = "run:before-self-call";
                @@:self.do_transition();
                $this->trace[] = "run:after-self-call";
            }

            do_transition() {
                $this->trace[] = "do_transition:body";
                -> $Done
            }

            get_trace(): list {
                @@:($this->trace)
            }
        }

        $Done {
            $>() {
                $this->trace[] = "Done:enter";
            }

            get_trace(): list {
                @@:($this->trace)
            }
        }

    domain:
        trace = []
}

echo "=== Test 53: Self-call transition guard ===" . "\n";
$t = new TransitionGuard();
$t->run();
$trace = $t->get_trace();

if (!in_array("run:before-self-call", $trace)) { echo "FAIL TC1\n"; exit(1); }
echo "TC1: pre-call statement executed - PASS\n";

if (!in_array("do_transition:body", $trace)) { echo "FAIL TC2\n"; exit(1); }
echo "TC2: self-called handler body executed - PASS\n";

if (!in_array("Done:enter", $trace)) { echo "FAIL TC3\n"; exit(1); }
echo "TC3: target state \$> handler fired - PASS\n";

if (in_array("run:after-self-call", $trace)) { echo "FAIL TC4\n"; exit(1); }
echo "TC4: post-call statement suppressed by automatic guard - PASS\n";

$expected = ["run:before-self-call", "do_transition:body", "Done:enter"];
if ($trace !== $expected) {
    echo "FAIL TC5: got " . implode(",", $trace) . ", expected " . implode(",", $expected) . "\n";
    exit(1);
}
echo "TC5: trace order is exactly [before, body, enter] - PASS\n";

echo "PASS: automatic transition guard suppresses post-self-call code\n";

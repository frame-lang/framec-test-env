@@target lua
@@system HSMThreeLevels {
    interface:
        handle_at_grandchild()
        forward_to_child()
        forward_to_parent()
        forward_through_all()
        get_log(): list

    machine:
        $Grandchild => $Child {
            $.grandchild_var: int = 1

            handle_at_grandchild() {
                val = $.grandchild_var
                self.log[#self.log + 1] = "Grandchild:handled(var=" .. tostring(val) .. ")"
            }

            forward_to_child() {
                self.log[#self.log + 1] = "Grandchild:forward_to_child"
                => $^
            }

            forward_to_parent() {
                self.log[#self.log + 1] = "Grandchild:forward_to_parent"
                => $^
            }

            forward_through_all() {
                self.log[#self.log + 1] = "Grandchild:forward_through_all"
                => $^
            }

            get_log(): list {
                @@:(self.log)
                return
            }
        }

        $Child => $Parent {
            $.child_var: int = 10

            forward_to_child() {
                val = $.child_var
                self.log[#self.log + 1] = "Child:handled(var=" .. tostring(val) .. ")"
            }

            forward_to_parent() {
                val = $.child_var
                self.log[#self.log + 1] = "Child:forward_to_parent(var=" .. tostring(val) .. ")"
                => $^
            }

            forward_through_all() {
                val = $.child_var
                self.log[#self.log + 1] = "Child:forward_through_all(var=" .. tostring(val) .. ")"
                => $^
            }

            get_log(): list {
                @@:(self.log)
                return
            }
        }

        $Parent {
            $.parent_var: int = 100

            forward_to_parent() {
                val = $.parent_var
                self.log[#self.log + 1] = "Parent:handled(var=" .. tostring(val) .. ")"
            }

            forward_through_all() {
                val = $.parent_var
                self.log[#self.log + 1] = "Parent:forward_through_all(var=" .. tostring(val) .. ")"
            }

            get_log(): list {
                @@:(self.log)
                return
            }
        }
    domain:
        log: list = []
}

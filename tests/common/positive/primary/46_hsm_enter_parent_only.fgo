@@[target("go")]

package main

import "fmt"
import "os"

// Test 46: HSM Enter Cascade — Parent has $>, Child does not

@@system HSMEnterParentOnly {
    interface:
        GoToChild()
        GoToParent()
        GetLog(): []string
        GetState(): string

    machine:
        $Start {
            GoToChild() { -> $Child }
            GoToParent() { -> $Parent }
            GetLog(): []string { @@:(s.log) }
            GetState(): string { @@:("Start") }
        }

        $Child => $Parent {
            GoToParent() { -> $Parent }
            GetLog(): []string { @@:(s.log) }
            GetState(): string { @@:("Child") }
            => $^   // RFC-0019: forward the unhandled $> to $Parent
        }

        $Parent {
            $>() {
                s.log = append(s.log, "Parent:enter")
            }
            GoToChild() { -> $Child }
            GetLog(): []string { @@:(s.log) }
            GetState(): string { @@:("Parent") }
        }
    domain:
        log : []string
}

func contains(slice []string, item string) bool {
	for _, v := range slice {
		if v == item {
			return true
		}
	}
	return false
}

func countOccurrences(slice []string, item string) int {
	count := 0
	for _, v := range slice {
		if v == item {
			count++
		}
	}
	return count
}

func main() {
	fmt.Println("=== Test 46: HSM Enter Cascade — Parent only ===")
	sm := @@HSMEnterParentOnly()

	sm.GoToChild()
	if sm.GetState() != "Child" { fmt.Println("FAIL"); os.Exit(1) }
	log := sm.GetLog()
	if !contains(log, "Parent:enter") { fmt.Println("FAIL: Expected Parent:enter on cascade"); os.Exit(1) }
	fmt.Println("TC1: Parent's $> fires on cascade entry to Child - PASS")

	sm.GoToParent()
	log = sm.GetLog()
	if countOccurrences(log, "Parent:enter") != 2 { fmt.Println("FAIL: Expected 2 Parent:enter"); os.Exit(1) }
	fmt.Println("TC2: Parent's $> fires again when transitioning directly to Parent - PASS")

	sm.GoToChild()
	log = sm.GetLog()
	if countOccurrences(log, "Parent:enter") != 3 { fmt.Println("FAIL: Expected 3 Parent:enter"); os.Exit(1) }
	fmt.Println("TC3: Re-entering Child cascades through Parent again - PASS")

	fmt.Println("PASS: HSM enter cascade fires Parent's $> on child entry")
}

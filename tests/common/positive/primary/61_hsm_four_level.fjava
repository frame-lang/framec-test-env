@@[target("java")]

@@system HsmFourLevel {
    interface:
        drive(): int
        write_at_level(level: int)
        get_n(): int

    machine:
        $Leaf => $Mid {
            drive(): int {
                => $^
            }
            write_at_level(level: int) {
                n = n + level * 1;
                => $^
            }
            get_n(): int {
                @@:(n)
            }
        }

        $Mid => $Branch {
            drive(): int {
                => $^
            }
            write_at_level(level: int) {
                n = n + level * 10;
                => $^
            }
        }

        $Branch => $Root {
            drive(): int {
                => $^
            }
            write_at_level(level: int) {
                n = n + level * 100;
                => $^
            }
        }

        $Root {
            drive(): int {
                @@:(n)
            }
            write_at_level(level: int) {
                n = n + level * 1000;
            }
        }
    domain:
        n : int = 0
}

class Main {
    public static void main(String[] args) {
        System.out.println("=== Test 61: 4-level HSM cascade (Java) ===");
        var s = new HsmFourLevel();

        int initial = s.drive();
        if (initial != 0) { System.out.println("FAIL: initial " + initial); System.exit(1); }
        System.out.println("1. Initial drive returned " + initial);

        s.write_at_level(2);
        int after = s.get_n();
        if (after != 2222) { System.out.println("FAIL: after " + after); System.exit(1); }
        System.out.println("2. After cascading write: n=" + after);

        int finalVal = s.drive();
        if (finalVal != 2222) { System.out.println("FAIL: final " + finalVal); System.exit(1); }
        System.out.println("3. Drive after write returned " + finalVal);

        System.out.println("PASS: 61_hsm_four_level");
    }
}

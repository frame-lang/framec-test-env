@@target lua

@@persist
@@system Inner {
    interface:
        cycle()
        get_state(): string
        get_count(): int

    machine:
        $A {
            cycle() { self.n = self.n + 1; -> $B }
            get_state(): string { @@:("A") }
            get_count(): int { @@:(self.n) }
        }
        $B => $A {
            cycle() { -> $A }
            get_state(): string { @@:("B") }
            get_count(): int { => $^ }
        }
    domain:
        n: int = 0
}

@@system Mid {
    interface:
        cycle()
        cycle_inner()
        get_state(): string
        get_inner_state(): string
        get_inner_count(): int
        get_m(): int

    machine:
        $P {
            cycle() { self.m = self.m + 1; -> $Q }
            cycle_inner() { self.inner:cycle() }
            get_state(): string { @@:("P") }
            get_inner_state(): string { @@:(self.inner:get_state()) }
            get_inner_count(): int { @@:(self.inner:get_count()) }
            get_m(): int { @@:(self.m) }
        }
        $Q => $P {
            cycle() { -> $P }
            get_state(): string { @@:("Q") }
            cycle_inner() { => $^ }
            get_inner_state(): string { => $^ }
            get_inner_count(): int { => $^ }
            get_m(): int { => $^ }
        }
    domain:
        m: int = 0
        inner = @@Inner()
}

@@system Outer {
    interface:
        tick()
        cycle_mid()
        cycle_inner()
        get_outer_state(): string
        get_mid_state(): string
        get_inner_state(): string
        get_inner_count(): int
        get_m(): int
        get_k(): int

    machine:
        $Idle {
            tick() { self.k = self.k + 1; -> $Active }
            cycle_mid() { self.mid:cycle() }
            cycle_inner() { self.mid:cycle_inner() }
            get_outer_state(): string { @@:("Idle") }
            get_mid_state(): string { @@:(self.mid:get_state()) }
            get_inner_state(): string { @@:(self.mid:get_inner_state()) }
            get_inner_count(): int { @@:(self.mid:get_inner_count()) }
            get_m(): int { @@:(self.mid:get_m()) }
            get_k(): int { @@:(self.k) }
        }
        $Active => $Idle {
            tick() { -> $Idle }
            get_outer_state(): string { @@:("Active") }
            cycle_mid() { => $^ }
            cycle_inner() { => $^ }
            get_mid_state(): string { => $^ }
            get_inner_state(): string { => $^ }
            get_inner_count(): int { => $^ }
            get_m(): int { => $^ }
            get_k(): int { => $^ }
        }
    domain:
        k: int = 0
        mid = @@Mid()
}

local function fmtProbe(o)
    return o:get_outer_state() .. "/" .. o:get_mid_state() .. "/" .. o:get_inner_state() ..
        "/" .. tostring(o:get_inner_count()) .. "/" .. tostring(o:get_m()) .. "/" .. tostring(o:get_k())
end

local function must(label, o, expected)
    local actual = fmtProbe(o)
    if actual ~= expected then
        print("FAIL " .. label .. ": " .. actual .. " expected " .. expected)
        os.exit(1)
    end
end

local o = Outer:new()
must("T0 fresh", o, "Idle/P/A/0/0/0")
local snap0 = o:save_state()
local r0 = Outer.restore_state(snap0)
must("T0 restored", r0, "Idle/P/A/0/0/0")

o:tick()
must("T1", o, "Active/P/A/0/0/1")
local snap1 = o:save_state()
local r1 = Outer.restore_state(snap1)
must("T1 restored", r1, "Active/P/A/0/0/1")

o:cycle_mid()
o:cycle_inner()
must("T2", o, "Active/Q/B/1/1/1")
local snap2 = o:save_state()
local r2 = Outer.restore_state(snap2)
must("T2 restored", r2, "Active/Q/B/1/1/1")

local snap2b = r2:save_state()
local r2b = Outer.restore_state(snap2b)
if fmtProbe(r2b) ~= fmtProbe(r2) then
    print("FAIL idempotence: " .. fmtProbe(r2b) .. " != " .. fmtProbe(r2))
    os.exit(1)
end

r2:cycle_inner()
must("continue1", r2, "Active/Q/A/1/1/1")
r2:cycle_mid()
must("continue2", r2, "Active/P/A/1/1/1")
r2:tick()
must("continue3", r2, "Idle/P/A/1/1/1")
r2:tick()
must("continue4", r2, "Active/P/A/1/1/2")

print("PASS: 85_persist_three_level_nested")

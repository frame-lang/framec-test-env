@@[target("dart")]

// Test 105: @@:self.method() from lifecycle handlers (F1 regression)

@@system LifecycleSelfCall {
    interface:
        tick()
        go()
        get_count(): int

    machine:
        $A {
            $>() { @@:self.tick() }
            <$() { @@:self.tick() }
            go() { -> $B }
            tick() { this.count = this.count + 1; }
            get_count(): int { @@:(this.count) }
        }

        $B {
            $>() { @@:self.tick() }
            tick() { this.count = this.count + 1; }
            get_count(): int { @@:(this.count) }
        }

    domain:
        count : int = 0
}

void main() {
    print("=== Test 105: @@:self.method() from lifecycle handlers (F1 regression) ===");
    final s = @@LifecycleSelfCall();
    if (s.get_count() != 1) throw Exception("Expected 1, got ${s.get_count()}");
    print("TC1: @@:self from start state \$> - PASS");
    s.go();
    if (s.get_count() != 3) throw Exception("Expected 3, got ${s.get_count()}");
    print("TC2/TC3: @@:self from <\$ + post-transition \$> - PASS");
    print("PASS: F1 regression");
}

@@target ruby

@@system HSMExitHandlers {
    interface:
        go_to_other()
        go_to_parent()
        go_to_child()
        get_log(): list
        get_state(): str
        get_child_var(): int

    machine:
        $Child => $Parent {
            $.child_var: int = 42
            $>() { self.log.push("Child:enter") }
            <$() { val = $.child_var; self.log.push("Child:exit(var=#{val})") }
            go_to_other() { -> $Other }
            go_to_parent() { -> $Parent }
            get_log(): list {
                @@:(self.log)
            }
            get_state(): str {
                @@:("Child")
            }
            get_child_var(): int {
                @@:($.child_var)
            }
        }

        $Parent {
            $>() { self.log.push("Parent:enter") }
            <$() { self.log.push("Parent:exit") }
            go_to_child() { -> $Child }
            go_to_other() { -> $Other }
            get_log(): list {
                @@:(self.log)
            }
            get_state(): str {
                @@:("Parent")
            }
            get_child_var(): int {
                @@:(-1)
            }
        }

        $Other {
            $>() { self.log.push("Other:enter") }
            go_to_child() { -> $Child }
            go_to_parent() { -> $Parent }
            get_log(): list {
                @@:(self.log)
            }
            get_state(): str {
                @@:("Other")
            }
            get_child_var(): int {
                @@:(-1)
            }
        }
    domain:
        log: list = []
}

puts("=== Test 48: HSM Exit Handlers ===")
s = HSMExitHandlers.new

log = s.get_log()
raise "Expected Child:enter on init, got #{log}" unless log.include?("Child:enter")
raise "Expected Child, got #{s.get_state()}" unless s.get_state() == "Child"
puts("TC2.4.0: Initial state is Child with enter - PASS")

s.go_to_other()
log = s.get_log()
raise "Expected Child:exit, got #{log}" unless log.include?("Child:exit(var=42)")
raise "Expected Other:enter, got #{log}" unless log.include?("Other:enter")
puts("TC2.4.1: Child exit fires when transitioning out - PASS")

raise "Parent:exit should NOT fire for child exit, got #{log}" if log.include?("Parent:exit")
puts("TC2.4.2: Parent exit NOT fired for child exit - PASS")
puts("TC2.4.3: Exit handler accesses state var (var=42) - PASS")

s.go_to_parent()
log = s.get_log()
raise "Expected Parent:enter, got #{log}" unless log.include?("Parent:enter")

s.go_to_other()
log = s.get_log()
raise "Expected Parent:exit, got #{log}" unless log.include?("Parent:exit")
puts("TC2.4.4: Parent exit fires when leaving parent - PASS")

puts("PASS: HSM exit handlers work correctly")

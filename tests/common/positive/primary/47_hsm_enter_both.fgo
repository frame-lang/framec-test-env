@@[target("go")]

package main

import "fmt"
import "os"

// Test 47: HSM Enter Cascade — Both Parent and Child have $>

@@system HSMEnterBoth {
    interface:
        GoToChild()
        GoToParent()
        GetLog(): []string
        GetState(): string

    machine:
        $Start {
            GoToChild() { -> $Child }
            GoToParent() { -> $Parent }
            GetLog(): []string { @@:(s.log) }
            GetState(): string { @@:("Start") }
        }

        $Child => $Parent {
            $>() {
                => $^
                s.log = append(s.log, "Child:enter")
            }
            GoToParent() { -> $Parent }
            GetLog(): []string { @@:(s.log) }
            GetState(): string { @@:("Child") }
        }

        $Parent {
            $>() {
                s.log = append(s.log, "Parent:enter")
            }
            GoToChild() { -> $Child }
            GetLog(): []string { @@:(s.log) }
            GetState(): string { @@:("Parent") }
        }
    domain:
        log : []string
}

func indexOf(slice []string, item string) int {
	for i, v := range slice {
		if v == item {
			return i
		}
	}
	return -1
}

func countOccurrences(slice []string, item string) int {
	count := 0
	for _, v := range slice {
		if v == item {
			count++
		}
	}
	return count
}

func main() {
	fmt.Println("=== Test 47: HSM Enter Cascade — Both ===")
	sm := @@HSMEnterBoth()

	sm.GoToChild()
	log := sm.GetLog()
	if sm.GetState() != "Child" { fmt.Println("FAIL"); os.Exit(1) }
	pi := indexOf(log, "Parent:enter")
	ci := indexOf(log, "Child:enter")
	if pi == -1 { fmt.Println("FAIL: Expected Parent:enter"); os.Exit(1) }
	if ci == -1 { fmt.Println("FAIL: Expected Child:enter"); os.Exit(1) }
	if pi >= ci { fmt.Println("FAIL: Parent:enter must precede Child:enter"); os.Exit(1) }
	fmt.Println("TC1: Parent's $> fires before Child's $> on cascade entry - PASS")

	sm.GoToParent()
	log = sm.GetLog()
	if sm.GetState() != "Parent" { fmt.Println("FAIL"); os.Exit(1) }
	if countOccurrences(log, "Parent:enter") != 2 { fmt.Println("FAIL: Expected 2 Parent:enter"); os.Exit(1) }
	if countOccurrences(log, "Child:enter") != 1 { fmt.Println("FAIL: Expected still 1 Child:enter"); os.Exit(1) }
	fmt.Println("TC2: Direct Parent entry fires only Parent's $> - PASS")

	sm.GoToChild()
	log = sm.GetLog()
	if countOccurrences(log, "Parent:enter") != 3 { fmt.Println("FAIL: Expected 3 Parent:enter"); os.Exit(1) }
	if countOccurrences(log, "Child:enter") != 2 { fmt.Println("FAIL: Expected 2 Child:enter"); os.Exit(1) }
	fmt.Println("TC3: Re-entering Child cascades through Parent again - PASS")

	fmt.Println("PASS: HSM enter cascade fires both layers top-down")
}

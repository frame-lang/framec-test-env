@@target dart
// NOTE: Default return value syntax (method(): type = default) not yet implemented.
// This test validates behavior when handler doesn't set @@:return.

@@system SystemReturnDefaultTest {
    interface:
        handler_sets_value(): String
        handler_no_return(): dynamic
        get_count(): num

    machine:
        $Start {
            $.count: num = 0

            handler_sets_value(): String {
                @@:("set_by_handler")
                return;
            }

            handler_no_return(): dynamic {
                // Does not set return - should return null/undefined
                $.count = $.count + 1;
            }

            get_count(): num {
                @@:($.count)
                return;
            }
        }
}

void main() {
    print("== Test 14: System Return Default Behavior ==");
    final s = @@SystemReturnDefaultTest();

    // Test 1: Handler explicitly sets return value
    final result1 = s.handler_sets_value();
    if (result1 != "set_by_handler") {
        throw Exception("Expected 'set_by_handler', got '${result1}'");
    }
    print("1. handler_sets_value() = '${result1}'");

    // Test 2: Handler does NOT set return - should return null/undefined
    final result2 = s.handler_no_return();
    if (result2 != null) {
        throw Exception("Expected null/undefined, got '${result2}'");
    }
    print("2. handler_no_return() = ${result2}");

    // Test 3: Verify handler was called (side effect check)
    var count = s.get_count();
    if (count != 1) {
        throw Exception("Expected count=1, got ${count}");
    }
    print("3. Handler was called, count = ${count}");

    // Test 4: Call again to verify idempotence
    final result4 = s.handler_no_return();
    if (result4 != null) {
        throw Exception("Expected null/undefined again, got '${result4}'");
    }
    count = s.get_count();
    if (count != 2) {
        throw Exception("Expected count=2, got ${count}");
    }
    print("4. Second call: result=${result4}, count=${count}");

    print("PASS: System return default behavior works correctly");
}


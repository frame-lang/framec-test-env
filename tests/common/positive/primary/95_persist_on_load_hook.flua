@@[target("lua")]

@@[persist]
@@system Counter {
    operations:
        @@[save]
        save_state(): string {}

        @@[load]
        restore_state(data: string) {}

        @@[on_load]
        rebuild_derived() {
            self.doubled = self.n * 2
            self.was_restored = true
        }

    interface:
        bump()
        get_n(): number
        get_doubled(): number
        was_loaded(): boolean

    machine:
        $Active {
            bump() { self.n = self.n + 1 }
            get_n(): number { @@:(self.n) }
            get_doubled(): number { @@:(self.doubled) }
            was_loaded(): boolean { @@:(self.was_restored) }
        }

    domain:
        n: number = 0
        doubled: number = 0
        was_restored: boolean = false
}

local c1 = Counter:new()
c1:bump(); c1:bump(); c1:bump()
if c1:was_loaded() then print("FAIL: was_restored should be false pre-restore"); return end
if c1:get_doubled() ~= 0 then print("FAIL: doubled should be 0, got " .. c1:get_doubled()); return end

local data = c1:save_state()

local c2 = Counter:new()
c2:restore_state(data)
if not c2:was_loaded() then print("FAIL: was_restored should be true after on_load"); return end
if c2:get_n() ~= 3 then print("FAIL: n should be 3, got " .. c2:get_n()); return end
if c2:get_doubled() ~= 6 then print("FAIL: doubled should be 6, got " .. c2:get_doubled()); return end

print("PASS: 95_persist_on_load_hook")

@@target erlang

@@system StackOps {
    interface:
        pushAndGo()
        popBack()
        doWork(): str
        getState(): str

    machine:
        $Main {
            pushAndGo() {
                push$
                -> $Sub
            }
            popBack() { }
            doWork(): str {
                return "Working in Main"
            }
            getState(): str {
                return "Main"
            }
        }

        $Sub {
            pushAndGo() { }
            popBack() {
                -> pop$
            }
            doWork(): str {
                return "Working in Sub"
            }
            getState(): str {
                return "Sub"
            }
        }
}

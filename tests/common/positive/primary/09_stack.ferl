@@[target("erlang")]

@@system StackOps {
    interface:
        pushAndGo()
        popBack()
        doWork(): str
        getState(): str

    machine:
        $Main {
            pushAndGo() {
                push$
                -> $Sub
            }
            popBack() { }
            doWork(): str {
                @@:("Working in Main")
                return
            }
            getState(): str {
                @@:("Main")
                return
            }
        }

        $Sub {
            pushAndGo() { }
            popBack() {
                -> pop$
            }
            doWork(): str {
                @@:("Working in Sub")
                return
            }
            getState(): str {
                @@:("Sub")
                return
            }
        }
}

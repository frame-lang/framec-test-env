@@[target("lua")]

@@system BoolStateArg {
    interface:
        configure(active: bool)
        is_active(): bool

    machine:
        $Idle {
            configure(active: bool) {
                -> $Active(active)
            }
            is_active(): bool {
                @@:(false)
                return
            }
        }

        $Active => $Frame(flag: bool) {
            configure(active: bool) {
                -> $Active(active)
            }
            is_active(): bool {
                => $^
            }
        }

        $Frame {
            is_active(): bool {
                @@:(flag)
                return
            }
        }
    domain:
        n: int = 0
}

local s = BoolStateArg.new()
if s:is_active() ~= false then error("FAIL idle: " .. tostring(s:is_active())) end
s:configure(true)
if s:is_active() ~= true then error("FAIL true: " .. tostring(s:is_active())) end
s:configure(false)
if s:is_active() ~= false then error("FAIL false: " .. tostring(s:is_active())) end
s:configure(true)
if s:is_active() ~= true then error("FAIL re-true: " .. tostring(s:is_active())) end
print("PASS: 67_hsm_bool_state_args")

@@[target("lua")]

@@[persist]
@@system PersistHsmPushpop {
    operations:
        @@[save]
        save_state(): string {}

        @@[load]
        restore_state(data: string) {}

    interface:
        push_modal(v: int)
        pop_modal()
        get_x(): int

    machine:
        $Idle {
            push_modal(v: int) {
                push$
                -> $Modal(v)
            }
            pop_modal() {
                -> pop$
            }
            get_x(): int {
                @@:(-99)
                return
            }
        }

        $Modal => $Frame(x: int) {
            push_modal(v: int) {
                push$
                -> $Modal(v)
            }
            pop_modal() {
                -> pop$
            }
            get_x(): int {
                @@:(x)
                return
            }
        }

        $Frame {
        }
    domain:
        v: int = 0
}

print("=== Test 60: Persist × HSM × push/pop (Lua) ===")
local s1 = PersistHsmPushpop.new()
s1:push_modal(42)
s1:push_modal(99)
local pre = s1:get_x()
if pre ~= 99 then error("Expected 99 pre-save, got " .. tostring(pre)) end
print("1. Pre-save top x=" .. tostring(pre))

local snap = s1:save_state()
local s2 = PersistHsmPushpop:new()

s2:restore_state(snap)
local post = s2:get_x()
if post ~= 99 then error("Expected 99 post-restore, got " .. tostring(post)) end
print("2. Post-restore top x=" .. tostring(post))

s2:pop_modal()
local mid = s2:get_x()
if mid ~= 42 then error("Expected 42 after first pop, got " .. tostring(mid)) end
print("3. After first pop x=" .. tostring(mid))

s2:pop_modal()
local bottom = s2:get_x()
if bottom ~= -99 then error("Expected -99 after second pop, got " .. tostring(bottom)) end
print("4. After second pop x=" .. tostring(bottom))

print("PASS: 60_persist_hsm_pushpop")

@@[target("csharp")]


@@[persist(string)]
@@[save(SaveState)]
@@[load(RestoreState)]
@@system Inner {
    interface:
        bump_int()
        bump_float()
        flip_bool()
        get_n_int(): int
        get_n_float(): double
        get_n_bool(): bool
        get_n_str(): string

    machine:
        $S {
            bump_int() { this.n_int = this.n_int + 1; }
            bump_float() { this.n_float = this.n_float + 0.25; }
            flip_bool() { this.n_bool = !this.n_bool; }
            get_n_int(): int { @@:(this.n_int) }
            get_n_float(): double { @@:(this.n_float) }
            get_n_bool(): bool { @@:(this.n_bool) }
            get_n_str(): string { @@:(this.n_str) }
        }
    domain:
        n_int: int = 7
        n_float: double = 2.5
        n_bool: bool = true
        n_str: string = "hello"
}@@[persist(string)]
@@[save(SaveState)]
@@[load(RestoreState)]


@@[main]
@@system Outer {
    interface:
        bump_k_int()
        bump_k_float()
        bump_inner_int()
        bump_inner_float()
        flip_inner_bool()
        get_k_int(): int
        get_k_float(): double
        get_n_int(): int
        get_n_float(): double
        get_n_bool(): bool
        get_n_str(): string

    machine:
        $S {
            bump_k_int() { this.k_int = this.k_int + 1; }
            bump_k_float() { this.k_float = this.k_float + 0.25; }
            bump_inner_int() { this.inner.bump_int(); }
            bump_inner_float() { this.inner.bump_float(); }
            flip_inner_bool() { this.inner.flip_bool(); }
            get_k_int(): int { @@:(this.k_int) }
            get_k_float(): double { @@:(this.k_float) }
            get_n_int(): int { @@:(this.inner.get_n_int()) }
            get_n_float(): double { @@:(this.inner.get_n_float()) }
            get_n_bool(): bool { @@:(this.inner.get_n_bool()) }
            get_n_str(): string { @@:(this.inner.get_n_str()) }
        }
    domain:
        k_int: int = 42
        k_float: double = 1.25
        inner: Inner = @@Inner()
}

class Program {
    static void AssertState(Outer o, string label, string kIntStr, double kFloat, string nIntStr, double nFloat, bool nBool, string nStr) {
        if (o.get_k_int().ToString() != kIntStr) throw new Exception($"FAIL {label} k_int: {o.get_k_int()}");
        if (o.get_n_int().ToString() != nIntStr) throw new Exception($"FAIL {label} n_int: {o.get_n_int()}");
        if (Math.Abs(o.get_k_float() - kFloat) > 1e-9) throw new Exception($"FAIL {label} k_float: {o.get_k_float()}");
        if (Math.Abs(o.get_n_float() - nFloat) > 1e-9) throw new Exception($"FAIL {label} n_float: {o.get_n_float()}");
        if (o.get_n_bool() != nBool) throw new Exception($"FAIL {label} n_bool: {o.get_n_bool()}");
        if (o.get_n_str() != nStr) throw new Exception($"FAIL {label} n_str: {o.get_n_str()}");
    }
    public static void Main(string[] args) {
        var o = @@Outer();
        AssertState(o, "T0", "42", 1.25, "7", 2.5, true, "hello");

        o.bump_k_int();
        o.bump_k_float();
        o.bump_inner_int();
        o.bump_inner_float();
        o.flip_inner_bool();
        AssertState(o, "T1", "43", 1.5, "8", 2.75, false, "hello");

        var snap = o.SaveState();
        var r = @@Outer();

        r.RestoreState(snap);
        AssertState(r, "T1 restored", "43", 1.5, "8", 2.75, false, "hello");

        r.bump_k_int();
        r.bump_inner_int();
        AssertState(r, "continue", "44", 1.5, "9", 2.75, false, "hello");

        Console.WriteLine("PASS: 86_persist_numeric_typing");
    }
}

@@target swift

import Foundation

@@[persist]
@@system PersistList {
    interface:
        configure(items: [Int])
        first_item(): Int
        size(): Int

    machine:
        $Idle {
            configure(items: [Int]) {
                -> $Active(items)
            }
            first_item(): Int { @@:(-1) }
            size(): Int { @@:(0) }
        }
        $Active(items: [Int]) {
            configure(items: [Int]) {
                -> $Active(items)
            }
            first_item(): Int { @@:(items[0]) }
            size(): Int { @@:(items.count) }
        }
    domain:
        n : Int = 0
}

let s1 = PersistList()
s1.configure([10, 20, 30])
if s1.first_item() != 10 { print("FAIL pre"); exit(1) }
let snap = s1.saveState()

let s2 = PersistList.restoreState(snap)
if s2.first_item() != 10 { print("FAIL restored first_item"); exit(1) }
if s2.size() != 3 { print("FAIL restored size"); exit(1) }
print("PASS: 74_persist_list_state_arg")

@@target gdscript
extends SceneTree

@@system StateVarReentry {
    interface:
        increment(): int
        get_count(): int
        go_other()
        come_back()

    machine:
        $Counter {
            $.count: int = 0

            increment(): int {
                $.count = $.count + 1
                @@:($.count)
                return
            }

            get_count(): int {
                @@:($.count)
                return
            }

            go_other() {
                -> $Other
            }
        }

        $Other {
            come_back() {
                -> $Counter
            }

            increment(): int {
                @@:(-1)
                return
            }

            get_count(): int {
                @@:(-1)
                return
            }
        }
}

func main():
    print("=== Test 11: State Variable Reentry ===")
    var s = @@StateVarReentry()

    # Increment a few times
    s.increment()
    s.increment()
    var count = s.get_count()
    assert(count == 2, "Expected 2 after two increments, got " + str(count))
    print("Count before leaving: " + str(count))

    # Leave the state
    s.go_other()
    print("Transitioned to Other state")

    # Come back - state var should be reinitialized to 0
    s.come_back()
    count = s.get_count()
    assert(count == 0, "Expected 0 after re-entering Counter (state var reinit), got " + str(count))
    print("Count after re-entering Counter: " + str(count))

    # Increment again to verify it works
    var result = s.increment()
    assert(result == 1, "Expected 1 after increment, got " + str(result))
    print("After increment: " + str(result))

    print("PASS: State variables reinitialize on state reentry")

func _init():
    main()
    quit()

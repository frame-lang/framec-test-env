@@[target("python_3")]

@@system Demo {
    interface:
        get_a(): int
        get_b(): int
    machine:
        $S {
            get_a(): int { @@:(self.a) }
            get_b(): int { @@:(self.b) }
        }
    domain:
        a: int = 1
        @@[target("python_3")] b: int = 2
        @@[target("javascript")]
        c: int = 99
}

if __name__ == "__main__":
    d = @@Demo()
    assert d.get_a() == 1, f"FAIL get_a: {d.get_a()}"
    assert d.get_b() == 2, f"FAIL get_b: {d.get_b()}"
    assert not hasattr(d, "c"), "FAIL: c should be filtered out by @@[target(\"javascript\")]"
    print("PASS: 90_attribute_domain_field")

@@target dart

// Test 41: HSM Single Parent Relationship
//
// Tests basic child-parent HSM relationship:
// - Child declares parent with "=> $Parent" syntax
// - Child can forward events to parent
// - Child remains current state after forward
// - Parent handler executes and returns control

@@system HSMSingleParent {
    interface:
        child_only()
        forward_to_parent()
        get_log(): String[]
        get_state(): str

    machine:
        $Child => $Parent {
            child_only() {
                this.log.add("Child:child_only")
            }

            forward_to_parent() {
                this.log.add("Child:before_forward")
                => $^
                this.log.add("Child:after_forward")
            }

            get_log(): list {
                @@:(this.log)
                return;
            }

            get_state(): str {
                @@:("Child")
                return;
            }
        }

        $Parent {
            forward_to_parent() {
                this.log.add("Parent:forward_to_parent")
            }

            get_log(): list {
                @@:(this.log)
                return;
            }

            get_state(): str {
                @@:("Parent")
                return;
            }
        }
    domain:
        log: String[] = []
}

void main() {
    print("== Test 41: HSM Single Parent ==");
    final s = @@HSMSingleParent();

    // TC1.1.1: Child declares parent with "=> $Parent" syntax (verified by compilation)
    print("TC1.1.1: Child-Parent relationship compiles - PASS");

    // TC1.1.2: Child can forward events to parent
    s.forward_to_parent();
    var log = s.get_log();
    if (!log.includes("Child:before_forward")) throw Exception("Expected Child:before_forward in log, got ${jsonEncode(log)}");
    if (!log.includes("Parent:forward_to_parent")) throw Exception("Expected Parent:forward_to_parent in log, got ${jsonEncode(log)}");
    print("TC1.1.2: Child forwards to parent - PASS (log: ${jsonEncode(log)})");

    // TC1.1.3: Child remains the current state (no transition occurs on forward)
    final state = s.get_state();
    if (state != "Child") throw Exception("Expected state 'Child', got '${state}'");
    print("TC1.1.3: Child remains current state after forward - PASS");

    // TC1.1.4: Parent handler executes and returns control
    // Verified by "Child:after_forward" appearing after parent execution
    if (!log.includes("Child:after_forward")) throw Exception("Expected Child:after_forward in log (after parent), got ${jsonEncode(log)}");
    final idx_parent = log.indexOf("Parent:forward_to_parent");
    final idx_after = log.indexOf("Child:after_forward");
    if (idx_after <= idx_parent) throw Exception("Expected Child:after_forward after Parent handler");
    print("TC1.1.4: Parent executes and returns control - PASS");

    // TC1.1.5: Child-only event not forwarded
    s.child_only();
    log = s.get_log();
    final count = log.filter((x: String) => x == "Child:child_only").length;
    if (count != 1) throw Exception("Expected exactly 1 Child:child_only, got ${jsonEncode(log)}");
    print("TC1.1.5: Child-only event handled locally - PASS");

    print("PASS: HSM single parent relationship works correctly");
}


@@[target("dart")]

@@system Sub {
    interface:
        ping(): int
    machine:
        $Idle {
            ping(): int { @@:(42) }
        }
}

@@[main]
@@system Top {
    interface:
        run(): int
    machine:
        $Active {
            run(): int { @@:(this.sub.ping()) }
        }
    domain:
        sub: Sub = @@Sub()
}

void main() {
    var t = Top();
    if (t.run() != 42) {
        print("FAIL run(): ${t.run()}");
    } else {
        print("PASS: 91_main_attr_cross_ref");
    }
}

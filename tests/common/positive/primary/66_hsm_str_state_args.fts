@@[target("typescript")]

@@system StrStateArg {
    interface:
        configure(label: str)
        identify(): str

    machine:
        $Idle {
            configure(label: string) {
                -> $Active(label)
            }
            identify(): string {
                @@:("anonymous")
                return
            }
        }

        $Active => $Frame(label: string) {
            configure(label: string) {
                -> $Active(label)
            }
            identify(): string {
                => $^
            }
        }

        $Frame {
            identify(): string {
                @@:(label)
                return
            }
        }
    domain:
        n: number = 0
}

const s = new StrStateArg();
if (s.identify() !== "anonymous") { console.log("FAIL idle"); process.exit(1); }
s.configure("alice");
if (s.identify() !== "alice") { console.log("FAIL alice"); process.exit(1); }
s.configure("bob");
if (s.identify() !== "bob") { console.log("FAIL bob"); process.exit(1); }
console.log("PASS: 66_hsm_str_state_args");

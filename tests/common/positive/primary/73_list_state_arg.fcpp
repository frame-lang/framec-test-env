@@target cpp

#include <iostream>
#include <vector>
#include <cstdlib>

@@system ListStateArg {
    interface:
        configure(items: std::vector<int>)
        first_item(): int
        size(): int

    machine:
        $Idle {
            configure(items: std::vector<int>) {
                -> $Active(items)
            }
            first_item(): int {
                @@:(-1)
            }
            size(): int {
                @@:(0)
            }
        }
        $Active(items: std::vector<int>) {
            configure(items: std::vector<int>) {
                -> $Active(items)
            }
            first_item(): int {
                @@:(items[0])
            }
            size(): int {
                @@:((int)items.size())
            }
        }
    domain:
        n : int = 0
}

int main() {
    ListStateArg s;
    if (s.first_item() != -1) { std::cout << "FAIL idle first_item" << std::endl; return 1; }
    if (s.size() != 0) { std::cout << "FAIL idle size" << std::endl; return 1; }
    s.configure(std::vector<int>{10, 20, 30});
    if (s.first_item() != 10) { std::cout << "FAIL active first_item" << std::endl; return 1; }
    if (s.size() != 3) { std::cout << "FAIL active size" << std::endl; return 1; }
    s.configure(std::vector<int>{7});
    if (s.first_item() != 7) { std::cout << "FAIL retransition first_item" << std::endl; return 1; }
    if (s.size() != 1) { std::cout << "FAIL retransition size" << std::endl; return 1; }
    std::cout << "PASS: 73_list_state_arg" << std::endl;
    return 0;
}

@@[target("javascript")]

@@system Counter {
    interface:
        get_value(): int
        bump()

    machine:
        $Active {
            get_value(): int { @@:(this._read()) }
            bump() { this.n = this.n + 1; }
        }

    actions:
        // `@@:(<expr>)` inside actions: bodies must lower to a native
        // `return <expr>` — actions are plain functions, not Frame
        // handlers, so there's no context-stack `_return` slot.
        _read() {
            if (this.n > 0) {
                @@:(this.n)
            } else {
                @@:(0)
            }
        }

    domain:
        n: int = 0
}

const inst = new Counter();
if (inst.get_value() !== 0) {
    console.log(`FAIL initial: expected 0, got ${inst.get_value()}`);
    process.exit(1);
}

inst.bump();
inst.bump();
inst.bump();
if (inst.get_value() !== 3) {
    console.log(`FAIL post-bump: expected 3, got ${inst.get_value()}`);
    process.exit(1);
}

console.log("PASS: 94_at_colon_paren_in_action");

@@[target("ruby")]

@@[persist]
@@system Counter {
    operations:
        @@[save]
        save_op(): String {}

        @@[load]
        load_op(data: String) {}

    interface:
        bump()
        get_n(): Integer

    machine:
        $Active {
            bump() {
                @n = @n + 1
            }
            get_n(): Integer { @@:(@n) }
        }

    domain:
        n: Integer = 0
}

c1 = Counter.new
c1.bump
c1.bump
c1.bump
data = c1.save_op

c2 = Counter.new
c2.load_op(data)
if c2.get_n != 3
    puts "FAIL: expected 3, got #{c2.get_n}"
else
    puts "PASS: 93_persist_save_load_contract"
end

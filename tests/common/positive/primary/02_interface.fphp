<?php
@@target php

@@system WithInterface {
    interface:
        greet(name: str): str
        get_count(): int

    machine:
        $Ready {
            greet(name: str): str {
                $this->call_count += 1;
                return "Hello, " . $name . "!";
            }

            get_count(): int {
                return $this->call_count;
            }
        }

    domain:
        call_count = 0
}

echo "=== Test 02: Interface Methods ===" . "\n";
$s = new WithInterface();

$result = $s->greet("World");
if ($result !== "Hello, World!") { echo "FAIL: Expected 'Hello, World!', got '{$result}'\n"; exit(1); }
echo "greet('World') = {$result}" . "\n";

$count = $s->get_count();
if ($count !== 1) { echo "FAIL: Expected count=1, got {$count}\n"; exit(1); }
echo "get_count() = {$count}" . "\n";

$s->greet("Frame");
$count2 = $s->get_count();
if ($count2 !== 2) { echo "FAIL: Expected count=2, got {$count2}\n"; exit(1); }
echo "After second call: get_count() = {$count2}" . "\n";

echo "PASS: Interface methods work correctly" . "\n";

@@[target("java")]

// Test 105: @@:self.method() from lifecycle handlers (F1 regression)

@@system LifecycleSelfCall {
    interface:
        tick()
        go()
        get_count(): int

    machine:
        $A {
            $>() { @@:self.tick() }
            <$() { @@:self.tick() }
            go() { -> $B }
            tick() { this.count = this.count + 1; }
            get_count(): int { @@:(this.count) }
        }

        $B {
            $>() { @@:self.tick() }
            tick() { this.count = this.count + 1; }
            get_count(): int { @@:(this.count) }
        }

    domain:
        count : int = 0
}

class Main {
    public static void main(String[] args) {
        System.out.println("=== Test 105: @@:self.method() from lifecycle handlers (F1 regression) ===");
        var s = @@LifecycleSelfCall();
        if ((int)s.get_count() != 1) { System.out.println("FAIL: Expected 1, got " + s.get_count()); System.exit(1); }
        System.out.println("TC1: @@:self from start state $> - PASS");
        s.go();
        if ((int)s.get_count() != 3) { System.out.println("FAIL: Expected 3, got " + s.get_count()); System.exit(1); }
        System.out.println("TC2/TC3: @@:self from <$ + post-transition $> - PASS");
        System.out.println("PASS: F1 regression");
    }
}

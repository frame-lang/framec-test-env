@@[target("gdscript")]
extends SceneTree

@@system StrStateArg {
    interface:
        configure(label: str)
        identify(): str

    machine:
        $Idle {
            configure(label: String) {
                -> $Active(label)
            }
            identify(): String {
                @@:("anonymous")
            }
        }

        $Active => $Frame(label: String) {
            configure(label: String) {
                -> $Active(label)
            }
            identify(): String {
                => $^
            }
        }

        $Frame {
            identify(): String {
                @@:(label)
            }
        }
    domain:
        n: int = 0
}

func _initialize():
    var s = StrStateArg.new()
    if s.identify() != "anonymous":
        print("FAIL idle"); quit(1); return
    s.configure("alice")
    if s.identify() != "alice":
        print("FAIL alice"); quit(1); return
    s.configure("bob")
    if s.identify() != "bob":
        print("FAIL bob"); quit(1); return
    print("PASS: 66_hsm_str_state_args")
    quit(0)

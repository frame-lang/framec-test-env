@@target kotlin

@@system BoolStateArg {
    interface:
        configure(active: bool)
        is_active(): bool

    machine:
        $Idle {
            configure(active: bool) {
                -> $Active(active)
            }
            is_active(): bool {
                @@:(false)
            }
        }

        $Active => $Frame(flag: bool) {
            configure(active: bool) {
                -> $Active(active)
            }
            is_active(): bool {
                => $^
            }
        }

        $Frame {
            is_active(): bool {
                @@:(flag)
            }
        }
    domain:
        n : int = 0
}

fun main() {
    val s = BoolStateArg()
    if (s.is_active() != false) { println("FAIL idle"); kotlin.system.exitProcess(1) }
    s.configure(true)
    if (s.is_active() != true) { println("FAIL true"); kotlin.system.exitProcess(1) }
    s.configure(false)
    if (s.is_active() != false) { println("FAIL false"); kotlin.system.exitProcess(1) }
    s.configure(true)
    if (s.is_active() != true) { println("FAIL re-true"); kotlin.system.exitProcess(1) }
    println("PASS: 67_hsm_bool_state_args")
}

@@[target("lua")]

-- Test 53: Self-call transition guard
--
-- Verifies the automatic transition guard contract: when a handler
-- self-calls a method that triggers a transition, code after the
-- self-call must NOT execute. The trace must equal exactly
-- ["run:before-self-call", "do_transition:body", "Done:enter"].

@@system TransitionGuard {

    interface:
        run()
        do_transition()
        get_trace(): list

    machine:
        $Active {
            run() {
                self.trace[#self.trace + 1] = "run:before-self-call"
                @@:self.do_transition()
                self.trace[#self.trace + 1] = "run:after-self-call"
            }

            do_transition() {
                self.trace[#self.trace + 1] = "do_transition:body"
                -> $Done
            }

            get_trace(): list {
                @@:(self.trace)
                return
            }
        }

        $Done {
            $>() {
                self.trace[#self.trace + 1] = "Done:enter"
            }

            get_trace(): list {
                @@:(self.trace)
                return
            }
        }

    domain:
        trace: list = {}
}

local function contains(t, val)
    for i = 1, #t do
        if t[i] == val then return true end
    end
    return false
end

local function arrays_equal(a, b)
    if #a ~= #b then return false end
    for i = 1, #a do
        if a[i] ~= b[i] then return false end
    end
    return true
end

local function trace_to_str(t)
    local s = "["
    for i = 1, #t do
        if i > 1 then s = s .. "," end
        s = s .. tostring(t[i])
    end
    return s .. "]"
end

print("=== Test 53: Self-call transition guard ===")
local t = @@TransitionGuard()
t:run()
local trace = t:get_trace()

if not contains(trace, "run:before-self-call") then
    print("FAIL TC1: pre-call statement must execute, trace=" .. trace_to_str(trace))
    os.exit(1)
end
print("TC1: pre-call statement executed - PASS")

if not contains(trace, "do_transition:body") then
    print("FAIL TC2: self-called handler body must execute, trace=" .. trace_to_str(trace))
    os.exit(1)
end
print("TC2: self-called handler body executed - PASS")

if not contains(trace, "Done:enter") then
    print("FAIL TC3: cascade enter on transition target must fire, trace=" .. trace_to_str(trace))
    os.exit(1)
end
print("TC3: target state $> handler fired - PASS")

if contains(trace, "run:after-self-call") then
    print("FAIL TC4: post-call statement MUST NOT execute (transition guard), trace=" .. trace_to_str(trace))
    os.exit(1)
end
print("TC4: post-call statement suppressed by automatic guard - PASS")

local expected = {"run:before-self-call", "do_transition:body", "Done:enter"}
if not arrays_equal(trace, expected) then
    print("FAIL TC5: trace order must match expected, got " .. trace_to_str(trace) .. ", expected " .. trace_to_str(expected))
    os.exit(1)
end
print("TC5: trace order is exactly [before, body, enter] - PASS")

print("PASS: automatic transition guard suppresses post-self-call code")

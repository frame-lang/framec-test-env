<?php
@@target php

@@system StrStateArg {
    interface:
        configure(label: str)
        identify(): str

    machine:
        $Idle {
            configure(label: str) {
                -> $Active($label)
            }
            identify(): str {
                @@:("anonymous")
                return;
            }
        }

        $Active => $Frame(label: str) {
            configure(label: str) {
                -> $Active($label)
            }
            identify(): str {
                => $^
            }
        }

        $Frame {
            identify(): str {
                @@:($label)
                return;
            }
        }
    domain:
        n: int = 0
}

$s = new StrStateArg();
if ($s->identify() !== "anonymous") { echo "FAIL idle\n"; exit(1); }
$s->configure("alice");
if ($s->identify() !== "alice") { echo "FAIL alice\n"; exit(1); }
$s->configure("bob");
if ($s->identify() !== "bob") { echo "FAIL bob\n"; exit(1); }
echo "PASS: 66_hsm_str_state_args\n";

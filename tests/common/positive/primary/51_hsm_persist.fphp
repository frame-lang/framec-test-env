<?php
@@target php

@@[persist]
@@system HSMPersist {
    interface:
        increment_child()
        increment_parent()
        get_child_count(): int
        get_parent_count(): int
        get_state(): str

    machine:
        $Child => $Parent {
            $.child_count: int = 0
            increment_child() { $.child_count = $.child_count + 1; }
            increment_parent() { => $^ }
            get_child_count(): int {
                @@:($.child_count)
            }
            get_parent_count(): int { => $^ }
            get_state(): str {
                @@:("Child")
            }
        }

        $Parent {
            $.parent_count: int = 100
            increment_parent() { $.parent_count = $.parent_count + 1; }
            get_parent_count(): int {
                @@:($.parent_count)
            }
            get_state(): str {
                @@:("Parent")
            }
        }
}

echo "=== Test 51: HSM Persistence ===" . "\n";

$s1 = new HSMPersist();

if ($s1->get_state() !== "Child") { echo "FAIL\n"; exit(1); }
if ($s1->get_child_count() !== 0) { echo "FAIL\n"; exit(1); }
if ($s1->get_parent_count() !== 100) { echo "FAIL\n"; exit(1); }
echo "1. Initial state verified" . "\n";

$s1->increment_child();
$s1->increment_child();
$s1->increment_child();
$s1->increment_parent();
$s1->increment_parent();

if ($s1->get_child_count() !== 3) { echo "FAIL\n"; exit(1); }
if ($s1->get_parent_count() !== 102) { echo "FAIL\n"; exit(1); }
echo "2. After increments: child_count=" . $s1->get_child_count() . ", parent_count=" . $s1->get_parent_count() . "\n";

$data = $s1->save_state();
if (!is_string($data)) { echo "FAIL\n"; exit(1); }
echo "3. Saved state: " . strlen($data) . " bytes" . "\n";

$s2 = HSMPersist::restore_state($data);

if ($s2->get_state() !== "Child") { echo "FAIL\n"; exit(1); }
echo "4. Restored state: " . $s2->get_state() . "\n";

if ($s2->get_child_count() !== 3) { echo "FAIL\n"; exit(1); }
echo "5. Child state var preserved: child_count=" . $s2->get_child_count() . "\n";

if ($s2->get_parent_count() !== 102) { echo "FAIL\n"; exit(1); }
echo "6. Parent state var preserved: parent_count=" . $s2->get_parent_count() . "\n";

$s2->increment_child();
$s2->increment_parent();
if ($s2->get_child_count() !== 4) { echo "FAIL\n"; exit(1); }
if ($s2->get_parent_count() !== 103) { echo "FAIL\n"; exit(1); }
echo "7. After post-restore increments: child_count=" . $s2->get_child_count() . ", parent_count=" . $s2->get_parent_count() . "\n";

echo "PASS: HSM persistence works correctly" . "\n";

<?php
@@target php

# Documentation Example: HSM Lamp with color behavior factored out

@@system LampHSM {
    interface:
        turnOn()
        turnOff()
        getColor(): str
        setColor(color: str)

    machine:
        $Off => $ColorBehavior {
            turnOn() {
                -> $On
            }
            => $^
        }

        $On => $ColorBehavior {
            $>() {
                $this->turnOnLamp();
            }
            <$() {
                $this->turnOffLamp();
            }
            turnOff() {
                -> $Off
            }
            => $^
        }

        $ColorBehavior {
            getColor(): str {
                return $this->color;
            }
            setColor(color: str) {
                $this->color = $color;
            }
        }

    actions:
        turnOnLamp() {
            $this->lamp_on = true;
        }
        turnOffLamp() {
            $this->lamp_on = false;
        }

    domain:
        color = "white"
        lamp_on = false
}

echo "=== Test 32: Doc Lamp HSM ===" . "\n";
$lamp = new LampHSM();

if ($lamp->getColor() !== "white") { echo "FAIL: Expected 'white'\n"; exit(1); }
$lamp->setColor("red");
if ($lamp->getColor() !== "red") { echo "FAIL: Expected 'red'\n"; exit(1); }

$lamp->turnOn();
if ($lamp->lamp_on !== true) { echo "FAIL: Lamp should be on\n"; exit(1); }

$lamp->setColor("green");
if ($lamp->getColor() !== "green") { echo "FAIL: Expected 'green'\n"; exit(1); }

$lamp->turnOff();
if ($lamp->lamp_on !== false) { echo "FAIL: Lamp should be off\n"; exit(1); }

if ($lamp->getColor() !== "green") { echo "FAIL: Expected 'green'\n"; exit(1); }

echo "PASS: HSM lamp works correctly" . "\n";

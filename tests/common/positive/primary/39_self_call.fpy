@@target python_3

# Test: @@:self.method() — reentrant interface call with transition guard
#
# Validates:
# 1. Basic self-call dispatch (calls own interface method through kernel)
# 2. Return value propagation from self-call
# 3. Transition guard (code after self-call that transitions is suppressed)

@@system SelfCallTest {
    interface:
        calibrate(): str
        reading(): float
        trigger_transition()
        check_after_transition(): str
        status(): str

    machine:
        $Active {
            calibrate(): str {
                baseline = @@:self.reading()
                self.offset = baseline * -1
                @@:(f"calibrated:offset={self.offset}")
            }

            reading(): float {
                @@:(self.raw_value + self.offset)
            }

            trigger_transition() {
                -> $Done
            }

            check_after_transition(): str {
                self.trace = "before"
                @@:self.trigger_transition()
                # This line should NOT execute — transition guard suppresses it
                self.trace = "after"
                @@:(self.trace)
            }

            status(): str {
                @@:("active")
            }
        }

        $Done {
            status(): str {
                @@:("done")
            }
        }

    domain:
        raw_value: float = 42.0
        offset: float = 0.0
        trace: str = ""
}

if __name__ == '__main__':
    s = @@SelfCallTest()

    # Test 1: Self-call returns correct value
    result = s.calibrate()
    assert result == "calibrated:offset=-42.0", f"Expected calibrated, got: {result}"

    # Test 2: Self-call modified domain state correctly
    r = s.reading()
    assert r == 0.0, f"Expected 0.0 after calibration, got: {r}"

    # Test 3: Transition guard — code after self-call that transitions is suppressed
    s2 = @@SelfCallTest()
    result = s2.check_after_transition()
    # trace should be "before" — the "after" assignment was suppressed
    assert s2.trace == "before", f"Expected 'before' (guard suppressed 'after'), got: '{s2.trace}'"

    # Test 4: System transitioned to $Done
    assert s2.status() == "done", f"Expected 'done' after transition, got: '{s2.status()}'"

    print("PASS: self_call")

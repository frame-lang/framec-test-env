@@target dart

// Test: @@:self.method() — reentrant interface call with transition guard
//
// Validates:
// 1. Basic self-call dispatch (calls own interface method through kernel)
// 2. Return value propagation from self-call
// 3. Transition guard (code after self-call that transitions is suppressed)

@@system SelfCallTest {
    interface:
        calibrate(): String
        reading(): num
        trigger_transition()
        check_after_transition(): String
        status(): String

    machine:
        $Active {
            calibrate(): String {
                final baseline = @@:self.reading();
                this.offset = baseline * -1;
                @@:("calibrated:offset=${this.offset}")
            }

            reading(): num {
                @@:(this.raw_value + this.offset)
            }

            trigger_transition() {
                -> $Done
            }

            check_after_transition(): String {
                this.trace = "before";
                @@:self.trigger_transition();
                // This line should NOT execute — transition guard suppresses it
                this.trace = "after";
                @@:(this.trace)
            }

            status(): String {
                @@:("active")
            }
        }

        $Done {
            status(): String {
                @@:("done")
            }
        }

    domain:
        num raw_value = 42.0
        num offset = 0.0
        String trace = ""
}

void main() {
    final s = @@SelfCallTest();

    // Test 1: Self-call returns correct value
    final result = s.calibrate();
    if (result != "calibrated:offset=-42.0") {
        throw Exception("Expected 'calibrated:offset=-42.0', got '${result}'");
    }

    // Test 2: Self-call modified domain state correctly
    final r = s.reading();
    if (r != 0.0) {
        throw Exception("Expected 0.0 after calibration, got ${r}");
    }

    // Test 3: Transition guard — code after self-call that transitions is suppressed
    final s2 = @@SelfCallTest();
    s2.check_after_transition();
    if (s2.trace != "before") {
        throw Exception("Expected 'before' (guard suppressed 'after'), got '${s2.trace}'");
    }

    // Test 4: System transitioned to $Done
    final st = s2.status();
    if (st != "done") {
        throw Exception("Expected 'done' after transition, got '${st}'");
    }

    print("PASS: self_call");
}

@@[target("erlang")]
@@[persist]
@@system NestedList {
    interface:
        configure(rows: list)
        firstFirst(): int
        outerSize(): int
    machine:
        $Idle {
            configure(rows: list) { -> $Active(rows) }
            firstFirst(): int { @@:(-1) }
            outerSize(): int { @@:(0) }
        }
        $Active(rows: list) {
            configure(rows: list) { -> $Active(rows) }
            firstFirst(): int { @@:(hd(hd(Rows))) }
            outerSize(): int { @@:(length(Rows)) }
        }
    domain:
        n = 0
}

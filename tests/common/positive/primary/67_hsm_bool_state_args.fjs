@@[target("javascript")]

@@system BoolStateArg {
    interface:
        configure(active: bool)
        is_active(): bool

    machine:
        $Idle {
            configure(active: boolean) {
                -> $Active(active)
            }
            is_active(): boolean {
                @@:(false)
                return
            }
        }

        $Active => $Frame(flag: boolean) {
            configure(active: boolean) {
                -> $Active(active)
            }
            is_active(): boolean {
                => $^
            }
        }

        $Frame {
            is_active(): boolean {
                @@:(flag)
                return
            }
        }
    domain:
        n: number = 0
}

const s = @@BoolStateArg();
if (s.is_active() !== false) { console.log("FAIL idle"); process.exit(1); }
s.configure(true);
if (s.is_active() !== true) { console.log("FAIL true"); process.exit(1); }
s.configure(false);
if (s.is_active() !== false) { console.log("FAIL false"); process.exit(1); }
s.configure(true);
if (s.is_active() !== true) { console.log("FAIL re-true"); process.exit(1); }
console.log("PASS: 67_hsm_bool_state_args");

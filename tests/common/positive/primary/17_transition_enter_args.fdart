@@[target("dart")]
import 'dart:convert';
@@system TransitionEnterArgs {
    interface:
        start()
        get_log(): List<String>

    machine:
        $Idle {
            start() {
                this.log.add("idle:start");
                -> ("from_idle", 42) $Active
            }

            get_log(): List<String> {
                @@:(this.log)
                return;
            }
        }

        $Active {
            $>(source: String, value: num) {
                this.log.add("active:enter:${source}:${value}");
            }

            start() {
                this.log.add("active:start");
            }

            get_log(): List<String> {
                @@:(this.log)
                return;
            }
        }
    domain:
        log : List<String> = []
}

void main() {
    print("== Test 17: Transition Enter Args ==");
    final s = @@TransitionEnterArgs();

    // Initial state is Idle
    var log = s.get_log();
    if (log.length != 0) {
        throw Exception("Expected empty log, got ${jsonEncode(log)}");
    }

    // Transition to Active with args
    s.start();
    log = s.get_log();
    if (!log.contains("idle:start")) {
        throw Exception("Expected 'idle:start' in log, got ${jsonEncode(log)}");
    }
    if (!log.contains("active:enter:from_idle:42")) {
        throw Exception("Expected 'active:enter:from_idle:42' in log, got ${jsonEncode(log)}");
    }
    print("Log after transition: ${jsonEncode(log)}");

    print("PASS: Transition enter args work correctly");
}


<?php
@@[target("php")]

@@system ActionsTest {
    interface:
        process(value: int): int
        get_log(): str

    machine:
        $Ready {
            process(value: int): int {
                $this->__log_event("start");
                $this->__validate_positive($value);
                $this->__log_event("valid");
                $result = $value * 2;
                $this->__log_event("done");
                @@:($result)
                return;
            }

            get_log(): str {
                @@:($this->log)
                return;
            }
        }

    actions:
        __log_event(msg: str) {
            $this->log = $this->log . $msg . ";";
        }

        __validate_positive(n: int) {
            if ($n < 0) {
                throw new \Exception("Value must be positive: {$n}");
            }
        }

    domain:
        log = ""
}

echo "=== Test 21: Actions Basic ===" . "\n";
$s = new ActionsTest();

$result = $s->process(5);
if ($result !== 10) { echo "FAIL: Expected 10, got {$result}\n"; exit(1); }
echo "1. process(5) = {$result}" . "\n";

$log = $s->get_log();
if (strpos($log, "start") === false) { echo "FAIL: Missing 'start' in log: {$log}\n"; exit(1); }
if (strpos($log, "valid") === false) { echo "FAIL: Missing 'valid' in log: {$log}\n"; exit(1); }
if (strpos($log, "done") === false) { echo "FAIL: Missing 'done' in log: {$log}\n"; exit(1); }
echo "2. Log: {$log}" . "\n";

try {
    $s->process(-1);
    echo "FAIL: Should have thrown Exception\n"; exit(1);
} catch (\Exception $e) {
    echo "3. Validation caught: " . $e->getMessage() . "\n";
}

echo "PASS: Actions basic works correctly" . "\n";

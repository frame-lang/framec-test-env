@@[target("erlang")]
@@[persist]
@@system NestedDict {
    operations:
        @@[save]
        save_state() {}

        @@[load]
        load_state(data) {}

    interface:
        configure(m: map)
        getInner(outerKey: string, innerKey: string): int
    machine:
        $Idle {
            configure(m: map) { -> $Active(m) }
            getInner(outerKey: string, innerKey: string): int { @@:(-1) }
        }
        $Active(m: map) {
            configure(m: map) { -> $Active(m) }
            getInner(outerKey: string, innerKey: string): int {
                @@:(maps:get(InnerKey, maps:get(OuterKey, M, #{}), -1))
            }
        }
    domain:
        n = 0
}

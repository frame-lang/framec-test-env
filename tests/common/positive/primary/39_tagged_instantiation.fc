@@[target("c")]

// Test 39: Tagged System Instantiation
// Validates the @@System() syntax for tracked instantiation

#include <stdio.h>
#include <stdlib.h>
#include <assert.h>

@@system Calculator {
    interface:
        add(a: int, b: int): int
        get_result(): int

    machine:
        $Ready {
            add(a: int, b: int): int {
                self->result = a + b;
                @@:(self->result)
                return;
            }

            get_result(): int {
                @@:(self->result)
                return;
            }
        }
    domain:
        result: int = 0
}

@@system Counter {
    interface:
        increment()
        get_count(): int

    machine:
        $Active {
            increment() {
                self->count = self->count + 1;
            }

            get_count(): int {
                @@:(self->count)
                return;
            }
        }
    domain:
        count: int = 0
}

int main() {
    printf("=== Test 39: Tagged System Instantiation ===\n");

    // Tagged instantiation - validated at transpile time
    Calculator* calc = @@Calculator();
    Counter* counter = @@Counter();

    // Test Calculator
    int result = Calculator_add(calc, 3, 4);
    assert(result == 7);
    printf("Calculator.add(3, 4) = %d\n", result);

    result = Calculator_get_result(calc);
    assert(result == 7);
    printf("Calculator.get_result() = %d\n", result);

    // Test Counter
    Counter_increment(counter);
    Counter_increment(counter);
    Counter_increment(counter);
    int count = Counter_get_count(counter);
    assert(count == 3);
    printf("Counter after 3 increments: %d\n", count);

    // Clean up
    Calculator_destroy(calc);
    Counter_destroy(counter);

    printf("PASS: Tagged instantiation works correctly\n");
    return 0;
}

@@[target("python_3")]

@@[persist]
@@system Counter {
    operations:
        @@[save]
        save_op(): str {}

        @@[load]
        load_op(data: str) {}

    interface:
        bump()
        get_n(): int

    machine:
        $Active {
            bump() {
                self.n = self.n + 1
            }
            get_n(): int { @@:(self.n) }
        }

    domain:
        n: int = 0
}

def main():
    c1 = Counter()
    c1.bump()
    c1.bump()
    c1.bump()
    data = c1.save_op()

    c2 = Counter()
    c2.load_op(data)
    if c2.get_n() != 3:
        print(f"FAIL: expected 3, got {c2.get_n()}")
        return
    print("PASS: 93_persist_save_load_contract")

if __name__ == '__main__':
    main()

@@[target("csharp")]


@@system Demo {
    interface:
        get_a(): int
        get_cs_only(): int
    machine:
        $S {
            get_a(): int { @@:(this.a) }
            get_cs_only(): int { @@:(this.cs_only) }
        }
    domain:
        a: int = 1
        @@[target("python_3")] py_only: int = 2
        @@[target("csharp")]
        cs_only: int = 42
}

class Program {
    public static void Main(string[] args) {
        var d = @@Demo();
        if (d.get_a() != 1) { Console.WriteLine("FAIL get_a: " + d.get_a()); Environment.Exit(1); }
        if (d.get_cs_only() != 42) { Console.WriteLine("FAIL get_cs_only: " + d.get_cs_only()); Environment.Exit(1); }
        Console.WriteLine("PASS: 90_attribute_domain_field");
    }
}

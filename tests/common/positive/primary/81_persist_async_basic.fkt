@@[target("kotlin")]

import kotlinx.coroutines.runBlocking
import kotlinx.coroutines.delay

suspend fun asyncCompute(x: Int): Int {
    delay(0)
    return x * 2
}

@@[persist]
@@system PersistAsync {
    operations:
        @@[save]
        save_state(): String {}

        @@[load]
        restore_state(data: String) {}

    interface:
        async configure(amount: Int)
        get(): Int

    machine:
        $Idle {
            configure(amount: Int) {
                this.value = asyncCompute(amount)
                -> $Active
            }
            get(): Int { @@:(0) }
        }
        $Active {
            configure(amount: Int) {
                this.value = this.value + asyncCompute(amount)
                -> $Active
            }
            get(): Int { @@:(this.value) }
        }
    domain:
        value : Int = 0
}

fun main() = runBlocking {
    val s1 = PersistAsync()
    s1.init()
    s1.configure(5)
    var v = s1.get()
    check(v == 10) { "FAIL pre: expected 10, got $v" }
    val snap = s1.save_state()
    val s2 = PersistAsync()

    s2.restore_state(snap)
    v = s2.get()
    check(v == 10) { "FAIL post: expected 10, got $v" }
    s2.configure(3)
    v = s2.get()
    check(v == 16) { "FAIL post-2nd: expected 16, got $v" }
    println("PASS: 81_persist_async_basic")
}

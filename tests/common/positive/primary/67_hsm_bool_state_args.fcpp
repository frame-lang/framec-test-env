@@[target("cpp_17")]

#include <iostream>
#include <cstdlib>

@@system BoolStateArg {
    interface:
        configure(active: bool)
        is_active(): bool

    machine:
        $Idle {
            configure(active: bool) {
                -> $Active(active)
            }
            is_active(): bool {
                @@:(false)
            }
        }

        $Active => $Frame(flag: bool) {
            configure(active: bool) {
                -> $Active(active)
            }
            is_active(): bool {
                => $^
            }
        }

        $Frame {
            is_active(): bool {
                @@:(flag)
            }
        }
    domain:
        n : int = 0
}

int main() {
    auto s = @@BoolStateArg();
    if (s.is_active() != false) { std::cout << "FAIL idle" << std::endl; return 1; }
    s.configure(true);
    if (s.is_active() != true) { std::cout << "FAIL true" << std::endl; return 1; }
    s.configure(false);
    if (s.is_active() != false) { std::cout << "FAIL false" << std::endl; return 1; }
    s.configure(true);
    if (s.is_active() != true) { std::cout << "FAIL re-true" << std::endl; return 1; }
    std::cout << "PASS: 67_hsm_bool_state_args" << std::endl;
    return 0;
}

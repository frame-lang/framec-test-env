@@[target("swift")]

@@system StateVarBasic {
    interface:
        increment(): number
        get_count(): number
        reset()

    machine:
        $Counter {
            $.count: number = 0

            increment(): number {
                $.count = $.count + 1
                @@:($.count)
                return;
            }

            get_count(): number {
                @@:($.count)
                return;
            }

            reset() {
                $.count = 0
            }
        }
}

// main
    print("=== Test 10: State Variable Basic ===")
    let s = @@StateVarBasic()

    // Initial value should be 0
    if s.get_count() != 0 {
        fatalError("Expected 0, got \(s.get_count())")
    }
    print("Initial count: \(s.get_count())")

    // Increment should return new value
    var result = s.increment()
    if result != 1 {
        fatalError("Expected 1 after first increment, got \(result)")
    }
    print("After first increment: \(result)")

    // Second increment
    result = s.increment()
    if result != 2 {
        fatalError("Expected 2 after second increment, got \(result)")
    }
    print("After second increment: \(result)")

    // Reset should set back to 0
    s.reset()
    if s.get_count() != 0 {
        fatalError("Expected 0 after reset, got \(s.get_count())")
    }
    print("After reset: \(s.get_count())")

    print("PASS: State variable basic operations work correctly")

@@[target("kotlin")]

@@[persist(JSON)]
@@[save(snapshot)]
@@[load(rehydrate)]
@@system Counter {
    interface:
        getFireCount(): Int

    machine:
        $A {
            $>() {
                this.fire_count = this.fire_count + 1
            }
            getFireCount(): Int { @@:(this.fire_count) }
        }

    domain:
        fire_count: Int = 0
}

fun main() {
    val c = Counter()
    if (c.getFireCount() != 1) {
        println("FAIL: expected 1 after construction, got ${c.getFireCount()}")
        return
    }
    val snap = c.snapshot()

    val fresh = Counter()
    if (fresh.getFireCount() != 1) {
        println("FAIL: expected 1 on fresh construction, got ${fresh.getFireCount()}")
        return
    }

    fresh.rehydrate(snap)
    if (fresh.getFireCount() != 1) {
        println("D4 violation: \$> re-ran on restore (count=${fresh.getFireCount()}, expected 1)")
        return
    }

    println("PASS: rfc0015_restore_skips_init")
}

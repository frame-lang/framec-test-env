@@[target("cpp_17")]

#include <iostream>

@@system Sub {
    interface:
        ping(): int
    machine:
        $Idle {
            ping(): int { @@:(42) }
        }
}

@@[main]
@@system Top {
    interface:
        run(): int
    machine:
        $Active {
            run(): int { @@:(this->sub->ping()) }
        }
    domain:
        sub: Sub = @@Sub()
}

int main() {
    Top t;
    if (t.run() != 42) {
        std::cout << "FAIL run(): " << t.run() << std::endl;
        return 1;
    }
    std::cout << "PASS: 91_main_attr_cross_ref" << std::endl;
    return 0;
}

@@target ruby

@@system DomainVars {
    interface:
        increment()
        decrement()
        get_count(): int
        set_count(value: int)

    machine:
        $Counting {
            increment() {
                self.count += 1
                puts("#{self.name}: incremented to #{self.count}")
            }

            decrement() {
                self.count -= 1
                puts("#{self.name}: decremented to #{self.count}")
            }

            get_count(): int {
                return self.count
            }

            set_count(value: int) {
                self.count = value
                puts("#{self.name}: set to #{self.count}")
            }
        }
    domain:
        count: int = 0
        name: str = "counter"
}

puts("=== Test 06: Domain Variables ===")
s = DomainVars.new

# Initial value should be 0
count = s.get_count()
raise "Expected initial count=0, got #{count}" unless count == 0
puts("Initial count: #{count}")

# Increment
s.increment()
count = s.get_count()
raise "Expected count=1, got #{count}" unless count == 1

s.increment()
count = s.get_count()
raise "Expected count=2, got #{count}" unless count == 2

# Decrement
s.decrement()
count = s.get_count()
raise "Expected count=1, got #{count}" unless count == 1

# Set directly
s.set_count(100)
count = s.get_count()
raise "Expected count=100, got #{count}" unless count == 100

puts("Final count: #{count}")
puts("PASS: Domain variables work correctly")

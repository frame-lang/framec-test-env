@@target kotlin

import kotlin.system.exitProcess

@@system TransitionExitArgs {
    interface:
        leave()
        get_log(): MutableList<Any?>

    machine:
        $Active {
            <$(reason: String, code: Int) {
                this.log.add("exit:" + reason + ":" + code)
            }

            leave() {
                this.log.add("leaving")
                ("cleanup", 42) -> $Done
            }

            get_log(): MutableList<Any?> {
                return this.log
            }
        }

        $Done {
            $>() {
                this.log.add("enter:done")
            }

            get_log(): MutableList<Any?> {
                return this.log
            }
        }
    domain:
        log = mutableListOf<String>()
}

fun main() {
    println("=== Test 18: Transition Exit Args ===")
    val s = @@TransitionExitArgs()

    // Initial state is Active
    var log = s.get_log() as MutableList<*>
    if (log.size != 0) {
        println("FAIL: Expected empty log, got $log")
        exitProcess(1)
    }

    // Leave - should call exit handler with args
    s.leave()
    log = s.get_log() as MutableList<*>
    if (!log.contains("leaving")) {
        println("FAIL: Expected 'leaving' in log, got $log")
        exitProcess(1)
    }
    if (!log.contains("exit:cleanup:42")) {
        println("FAIL: Expected 'exit:cleanup:42' in log, got $log")
        exitProcess(1)
    }
    if (!log.contains("enter:done")) {
        println("FAIL: Expected 'enter:done' in log, got $log")
        exitProcess(1)
    }
    println("Log after transition: $log")

    println("PASS: Transition exit args work correctly")
}

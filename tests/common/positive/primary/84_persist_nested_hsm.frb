@@target ruby

@@persist
@@system Inner {
    interface:
        cycle()
        get_state(): string
        get_count(): int

    machine:
        $A {
            cycle() { self.n = self.n + 1; -> $B }
            get_state(): string { @@:("A") }
            get_count(): int { @@:(self.n) }
        }
        $B => $A {
            cycle() { -> $A }
            get_state(): string { @@:("B") }
            get_count(): int { => $^ }
        }
    domain:
        n: int = 0
}

@@system Outer {
    interface:
        tick()
        cycle_inner()
        get_outer_state(): string
        get_inner_state(): string
        get_inner_count(): int
        get_k(): int

    machine:
        $Idle {
            tick() { self.k = self.k + 1; -> $Active }
            cycle_inner() { self.inner.cycle }
            get_outer_state(): string { @@:("Idle") }
            get_inner_state(): string { @@:(self.inner.get_state) }
            get_inner_count(): int { @@:(self.inner.get_count) }
            get_k(): int { @@:(self.k) }
        }
        $Active => $Idle {
            tick() { -> $Idle }
            get_outer_state(): string { @@:("Active") }
            cycle_inner() { => $^ }
            get_inner_state(): string { => $^ }
            get_inner_count(): int { => $^ }
            get_k(): int { => $^ }
        }
    domain:
        k: int = 0
        inner = @@Inner()
}

def fmtProbe(o)
  "#{o.get_outer_state}/#{o.get_inner_state}/#{o.get_inner_count}/#{o.get_k}"
end

def must(label, o, expected)
  actual = fmtProbe(o)
  abort("FAIL #{label}: #{actual} expected #{expected}") unless actual == expected
end

o = Outer.new
must("T0 fresh", o, "Idle/A/0/0")
snap0 = o.save_state
r0 = Outer.restore_state(snap0)
must("T0 restored", r0, "Idle/A/0/0")

o.tick
must("T1", o, "Active/A/0/1")
snap1 = o.save_state
r1 = Outer.restore_state(snap1)
must("T1 restored", r1, "Active/A/0/1")

o.cycle_inner
must("T2", o, "Active/B/1/1")
snap2 = o.save_state
r2 = Outer.restore_state(snap2)
must("T2 restored", r2, "Active/B/1/1")

snap2b = r2.save_state
r2b = Outer.restore_state(snap2b)
abort("FAIL idempotence: #{fmtProbe(r2b)} != #{fmtProbe(r2)}") unless fmtProbe(r2b) == fmtProbe(r2)

r2.cycle_inner
must("continue1", r2, "Active/A/1/1")
r2.tick
must("continue2", r2, "Idle/A/1/1")
r2.tick
must("continue3", r2, "Active/A/1/2")

puts "PASS: 84_persist_nested_hsm"

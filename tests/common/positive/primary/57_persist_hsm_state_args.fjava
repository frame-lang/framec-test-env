@@target java

import java.util.*;

@@[persist]
@@system PersistHsmStateArgs {
    interface:
        drive(p: int)
        get_x(): int

    machine:
        $Start {
            drive(p: int) {
                -> $Child(p)
            }
            get_x(): int {
                @@:(-1)
            }
        }

        $Child => $Parent(x: int) {
            drive(p: int) {
                -> $Child(p)
            }
            get_x(): int {
                @@:(x)
            }
        }

        $Parent {
        }
    domain:
        v : int = 0
}

class Main {
    public static void main(String[] args) {
        System.out.println("=== Test 57: Persist HSM × State-Args Round-Trip (Java) ===");
        var s1 = new PersistHsmStateArgs();
        s1.drive(42);
        int pre = s1.get_x();
        if (pre != 42) { System.out.println("FAIL: pre " + pre); System.exit(1); }
        System.out.println("1. Pre-save x=" + pre);

        String snap = s1.save_state();
        var s2 = PersistHsmStateArgs.restore_state(snap);
        int post = s2.get_x();
        if (post != 42) { System.out.println("FAIL: post " + post); System.exit(1); }
        System.out.println("2. Post-restore x=" + post);

        s2.drive(99);
        int post2 = s2.get_x();
        if (post2 != 99) { System.out.println("FAIL: post2 " + post2); System.exit(1); }
        System.out.println("3. Post-restore-drive x=" + post2);

        System.out.println("PASS: 57_persist_hsm_state_args");
    }
}

@@target erlang
@@persist
@@system HSMPersist {
    interface:
        childAction()
        parentAction()
        getLog(): str
    machine:
        $Child => $Parent {
            childAction() {
                self.log = self.log ++ ",child"
            }
            getLog(): str { return self.log }
        }
        $Parent {
            parentAction() {
                self.log = self.log ++ ",parent"
            }
            getLog(): str { return self.log }
        }
    domain:
        log = "init"
}

@@[target("erlang")]
@@[persist]
@@system HSMPersist {
    operations:
        @@[save]
        save_state() {}

        @@[load]
        load_state(data) {}

    interface:
        childAction()
        parentAction()
        getLog(): str
    machine:
        $Child => $Parent {
            childAction() {
                self.log = self.log ++ ",child"
            }
            getLog(): str {
                @@:(self.log)
            }
        }
        $Parent {
            parentAction() {
                self.log = self.log ++ ",parent"
            }
            getLog(): str {
                @@:(self.log)
            }
        }
    domain:
        log = "init"
}

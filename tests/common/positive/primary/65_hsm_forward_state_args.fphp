<?php
@@[target("php")]

@@system StateArgFwd {
    interface:
        configure(t: int)
        process(): int

    machine:
        $Idle {
            configure(t: int) {
                -> $Active($t)
            }
            process(): int {
                @@:(0)
                return;
            }
        }

        $Active => $Frame(threshold: int) {
            configure(t: int) {
                -> $Active($t)
            }
            process(): int {
                => $^
            }
        }

        $Frame {
            process(): int {
                @@:($threshold)
                return;
            }
        }
    domain:
        n: int = 0
}

echo "=== Test 65: HSM × state-args × parent-forward (PHP) ===\n";
$s = new StateArgFwd();

$pre = $s->process();
if ($pre !== 0) { echo "FAIL: pre $pre\n"; exit(1); }
echo "1. Idle process = $pre\n";

$s->configure(7);
$r = $s->process();
if ($r !== 7) { echo "FAIL: r $r\n"; exit(1); }
echo "2. configure(7); process() = $r\n";

$s->configure(42);
$r2 = $s->process();
if ($r2 !== 42) { echo "FAIL: r2 $r2\n"; exit(1); }
echo "3. configure(42); process() = $r2\n";

echo "PASS: 65_hsm_forward_state_args\n";

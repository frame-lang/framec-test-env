@@[target("csharp")]

using System;
using System.Collections.Generic;

// Test 46: HSM Enter Cascade — Parent has $>, Child does not

@@system HSMEnterParentOnly {
    interface:
        go_to_child()
        go_to_parent()
        get_log(): List<object>
        get_state(): string

    machine:
        $Start {
            go_to_child() { -> $Child }
            go_to_parent() { -> $Parent }
            get_log(): List<object> { @@:(this.log) }
            get_state(): string { @@:("Start") }
        }

        $Child => $Parent {
            go_to_parent() { -> $Parent }
            get_log(): List<object> { @@:(this.log) }
            get_state(): string { @@:("Child") }
            => $^   // RFC-0019: forward the unhandled $> to $Parent
        }

        $Parent {
            $>() {
                this.log.Add("Parent:enter");
            }
            go_to_child() { -> $Child }
            get_log(): List<object> { @@:(this.log) }
            get_state(): string { @@:("Parent") }
        }
    domain:
        log : List<object> = new List<object>()
}

class Program {
    static int CountOf(List<object> log, string v) {
        int n = 0;
        foreach (var item in log) if (item.Equals(v)) n++;
        return n;
    }

    static void Main(string[] args) {
        Console.WriteLine("=== Test 46: HSM Enter Cascade — Parent only ===");
        var s = @@HSMEnterParentOnly();

        s.go_to_child();
        if ((string)s.get_state() != "Child") { Console.WriteLine("FAIL"); Environment.Exit(1); }
        var log = (List<object>)s.get_log();
        if (!log.Contains("Parent:enter")) { Console.WriteLine("FAIL: Expected Parent:enter on cascade"); Environment.Exit(1); }
        Console.WriteLine("TC1: Parent's $> fires on cascade entry to Child - PASS");

        s.go_to_parent();
        log = (List<object>)s.get_log();
        if (CountOf(log, "Parent:enter") != 2) { Console.WriteLine("FAIL: Expected 2 Parent:enter"); Environment.Exit(1); }
        Console.WriteLine("TC2: Parent's $> fires again when transitioning directly to Parent - PASS");

        s.go_to_child();
        log = (List<object>)s.get_log();
        if (CountOf(log, "Parent:enter") != 3) { Console.WriteLine("FAIL: Expected 3 Parent:enter"); Environment.Exit(1); }
        Console.WriteLine("TC3: Re-entering Child cascades through Parent again - PASS");

        Console.WriteLine("PASS: HSM enter cascade fires Parent's $> on child entry");
    }
}

@@[target("rust")]

@@[persist]
@@system NestedList {
    operations:
        @@[save]
        save_state(): String {}

        @@[load]
        restore_state(data: String) {}

    interface:
        configure(rows: Vec<Vec<i32>>)
        first_first(): i32
        outer_size(): i32

    machine:
        $Idle {
            configure(rows: Vec<Vec<i32>>) { -> $Active(rows) }
            first_first(): i32 { @@:(-1); return; }
            outer_size(): i32 { @@:(0); return; }
        }
        $Active(rows: Vec<Vec<i32>>) {
            configure(rows: Vec<Vec<i32>>) { -> $Active(rows) }
            first_first(): i32 { @@:(rows[0][0]); return; }
            outer_size(): i32 { @@:(rows.len() as i32); return; }
        }
    domain:
        n: i32
}

fn main() {
    let mut s1 = @@NestedList();
    s1.configure(vec![vec![10, 20], vec![30, 40]]);
    if s1.first_first() != 10 { println!("FAIL pre"); std::process::exit(1); }
    if s1.outer_size() != 2 { println!("FAIL size"); std::process::exit(1); }
    let snap = s1.save_state();
    let mut s2 = NestedList::new();

    s2.restore_state(snap.clone());
    if s2.first_first() != 10 { println!("FAIL post"); std::process::exit(1); }
    if s2.outer_size() != 2 { println!("FAIL post size"); std::process::exit(1); }
    println!("PASS: 75_nested_list_state_arg");
}

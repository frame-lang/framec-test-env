@@target lua
@@system HSMSingleParent {
    interface:
        child_only()
        forward_to_parent()
        get_log(): list
        get_state(): str

    machine:
        $Child => $Parent {
            child_only() {
                self.log[#self.log + 1] = "Child:child_only"
            }

            forward_to_parent() {
                self.log[#self.log + 1] = "Child:before_forward"
                => $^
                self.log[#self.log + 1] = "Child:after_forward"
            }

            get_log(): list {
                return self.log
            }

            get_state(): str {
                return "Child"
            }
        }

        $Parent {
            forward_to_parent() {
                self.log[#self.log + 1] = "Parent:forward_to_parent"
            }

            get_log(): list {
                return self.log
            }

            get_state(): str {
                return "Parent"
            }
        }
    domain:
        log: list = []
}

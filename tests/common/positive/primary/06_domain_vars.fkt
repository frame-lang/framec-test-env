@@[target("kotlin")]

import kotlin.system.exitProcess

@@system DomainVars {
    interface:
        increment()
        decrement()
        get_count(): Int
        set_count(value: Int)

    machine:
        $Counting {
            increment() {
                this.count += 1
                println(this.name + ": incremented to " + this.count)
            }

            decrement() {
                this.count -= 1
                println(this.name + ": decremented to " + this.count)
            }

            get_count(): Int {
                @@:(this.count)
                return;
            }

            set_count(value: Int) {
                this.count = value
                println(this.name + ": set to " + this.count)
            }
        }
    domain:
        count = 0
        name = "counter"
}

fun main() {
    println("=== Test 06: Domain Variables ===")
    val s = @@DomainVars()

    // Initial value should be 0
    var count = s.get_count() as Int
    if (count != 0) {
        throw RuntimeException("Expected initial count=0, got $count")
    }
    println("Initial count: $count")

    // Increment
    s.increment()
    count = s.get_count() as Int
    if (count != 1) {
        throw RuntimeException("Expected count=1, got $count")
    }

    s.increment()
    count = s.get_count() as Int
    if (count != 2) {
        throw RuntimeException("Expected count=2, got $count")
    }

    // Decrement
    s.decrement()
    count = s.get_count() as Int
    if (count != 1) {
        throw RuntimeException("Expected count=1, got $count")
    }

    // Set directly
    s.set_count(100)
    count = s.get_count() as Int
    if (count != 100) {
        throw RuntimeException("Expected count=100, got $count")
    }

    println("Final count: $count")
    println("PASS: Domain variables work correctly")
}

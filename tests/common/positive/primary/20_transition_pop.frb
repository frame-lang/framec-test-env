@@target ruby

@@system TransitionPopTest {
    interface:
        start()
        process()
        get_state(): str
        get_log(): list

    machine:
        $Idle {
            start() {
                self.log.push("idle:start:push")
                push$
                -> $Working
            }

            process() {
                self.log.push("idle:process")
            }

            get_state(): str {
                return "Idle"
            }

            get_log(): list {
                return self.log
            }
        }

        $Working {
            process() {
                self.log.push("working:process:before_pop")
                -> pop$
                # This should NOT execute because pop transitions away
                self.log.push("working:process:after_pop")
            }

            get_state(): str {
                return "Working"
            }

            get_log(): list {
                return self.log
            }
        }
    domain:
        log: list = []
}

puts("=== Test 20: Transition Pop ===")
s = TransitionPopTest.new

# Initial state should be Idle
raise "Expected 'Idle', got '#{s.get_state()}'" unless s.get_state() == "Idle"
puts("Initial state: #{s.get_state()}")

# start() pushes Idle, transitions to Working
s.start()
raise "Expected 'Working', got '#{s.get_state()}'" unless s.get_state() == "Working"
puts("After start(): #{s.get_state()}")

# process() in Working does pop transition back to Idle
s.process()
raise "Expected 'Idle' after pop, got '#{s.get_state()}'" unless s.get_state() == "Idle"
puts("After process() with pop: #{s.get_state()}")

log = s.get_log()
puts("Log: #{log}")

# Verify log contents
raise "Expected 'idle:start:push' in log" unless log.include?("idle:start:push")
raise "Expected 'working:process:before_pop' in log" unless log.include?("working:process:before_pop")
raise "Should NOT have 'working:process:after_pop' in log" if log.include?("working:process:after_pop")

puts("PASS: Transition pop works correctly")

@@[target("gdscript")]
extends SceneTree

@@[persist(String)]
@@[save(save_state)]
@@[load(restore_state)]
@@system PersistDict {
    interface:
        configure(m: Dictionary)
        get_v(key: String): int

    machine:
        $Idle {
            configure(m: Dictionary) { -> $Active(m) }
            get_v(key: String): int { @@:(-1) }
        }
        $Active(m: Dictionary) {
            configure(m: Dictionary) { -> $Active(m) }
            get_v(key: String): int { @@:(m.get(key, -1)) }
        }
    domain:
        n: int = 0
}

func _initialize():
    var s1 = @@PersistDict()
    s1.configure({"a": 10, "b": 20})
    if s1.get_v("a") != 10:
        print("FAIL pre"); quit(1); return
    var snap = s1.save_state()
    var s2 = @@PersistDict()

    s2.restore_state(snap)
    if s2.get_v("a") != 10:
        print("FAIL post a"); quit(1); return
    if s2.get_v("b") != 20:
        print("FAIL post b"); quit(1); return
    print("PASS: 77_persist_dict_state_arg")

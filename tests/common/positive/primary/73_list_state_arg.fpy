@@target python_3

# Test 73: list-typed state-arg pass-through.
# Probe whether framec correctly threads a compound (non-Display)
# type through the interface entry → kernel dispatch → typed state
# context path.

@@system ListStateArg {
    interface:
        configure(items: list)
        first_item(): int
        size(): int

    machine:
        $Idle {
            configure(items: list) {
                -> $Active(items)
            }
            first_item(): int {
                @@:(-1)
                return
            }
            size(): int {
                @@:(0)
                return
            }
        }
        $Active(items: list) {
            configure(items: list) {
                -> $Active(items)
            }
            first_item(): int {
                @@:(items[0])
                return
            }
            size(): int {
                @@:(len(items))
                return
            }
        }
    domain:
        n: int = 0
}

def main():
    s = ListStateArg()
    assert s.first_item() == -1
    assert s.size() == 0
    s.configure([10, 20, 30])
    assert s.first_item() == 10
    assert s.size() == 3
    s.configure([7])
    assert s.first_item() == 7
    assert s.size() == 1
    print("PASS: 73_list_state_arg")

if __name__ == '__main__':
    main()

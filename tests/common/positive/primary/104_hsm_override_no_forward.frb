@@[target("ruby")]

# Test 104: RFC-0019 leaf-override of ancestor lifecycle
#
# A child with its own $> / <$ handler and NO `=> $^` forward
# overrides the ancestor's lifecycle handler. Inverse of fixtures
# 46/47/48 (which verify forwarding) — verifies non-forwarding:
# when the leaf does not forward, the ancestor's $> / <$ MUST NOT run.

@@system HSMOverride {
    interface:
        go_to_child()
        go_to_parent()
        get_log(): list
        get_state(): str

    machine:
        $Start {
            go_to_child() { -> $Child }
            go_to_parent() { -> $Parent }
            get_log(): list { @@:(self.log) }
            get_state(): str { @@:("Start") }
        }

        $Child => $Parent {
            $>() {
                # NO `=> $^` — ancestor $> must NOT run.
                self.log.push("Child:enter")
            }

            <$() {
                # NO `=> $^` — ancestor <$ must NOT run.
                self.log.push("Child:exit")
            }

            go_to_parent() { -> $Parent }
            get_log(): list { @@:(self.log) }
            get_state(): str { @@:("Child") }
        }

        $Parent {
            $>() { self.log.push("Parent:enter") }
            <$() { self.log.push("Parent:exit") }
            go_to_child() { -> $Child }
            get_log(): list { @@:(self.log) }
            get_state(): str { @@:("Parent") }
        }
    domain:
        log: list = []
}

puts("=== Test 104: RFC-0019 leaf-override of ancestor lifecycle ===")
s = @@HSMOverride()

# TC1: Entering $Child fires Child's $> only; Parent's $> must NOT fire.
s.go_to_child()
log = s.get_log()
raise "Expected Child, got #{s.get_state()}" unless s.get_state() == "Child"
raise "Expected Child:enter, got #{log}" unless log.include?("Child:enter")
raise "Parent:enter MUST NOT fire when Child overrides, got #{log}" if log.include?("Parent:enter")
puts("TC1: Child's $> overrides Parent's $> (no forward) - PASS")

# TC2: Leaving $Child fires Child's <$ only; Parent's <$ must NOT fire.
s.go_to_parent()
log = s.get_log()
raise "Expected Parent, got #{s.get_state()}" unless s.get_state() == "Parent"
raise "Expected Child:exit, got #{log}" unless log.include?("Child:exit")
raise "Parent:exit MUST NOT fire (Child overrides), got #{log}" unless log.count("Parent:exit") == 0
puts("TC2: Child's <$ overrides Parent's <$ (no forward) - PASS")

# TC3: Direct $Start -> $Parent transition fires Parent's $> exactly once.
raise "Expected exactly 1 Parent:enter (direct entry only), got #{log.count('Parent:enter')}: #{log}" unless log.count("Parent:enter") == 1
puts("TC3: Direct Parent entry fires Parent's $> normally - PASS")

puts("PASS: RFC-0019 leaf-override semantics")

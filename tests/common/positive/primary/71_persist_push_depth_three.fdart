@@[target("dart")]

import 'dart:io';
import 'dart:convert';

@@[persist(String)]
@@[save(saveState)]
@@[load(restoreState)]
@@system PPushDeep {
    interface:
        descend()
        ascend()
        get_depth(): int

    machine:
        $Idle {
            descend() { push$; -> $Modal1 }
            get_depth(): int { @@:(0); return; }
        }
        $Modal1 {
            descend() { push$; -> $Modal2 }
            ascend() { -> pop$ }
            get_depth(): int { @@:(1); return; }
        }
        $Modal2 {
            descend() { push$; -> $Modal3 }
            ascend() { -> pop$ }
            get_depth(): int { @@:(2); return; }
        }
        $Modal3 {
            ascend() { -> pop$ }
            get_depth(): int { @@:(3); return; }
        }
    domain: n: int = 0
}

void main() {
    final s = PPushDeep();
    s.descend(); s.descend(); s.descend();
    if (s.get_depth() != 3) { print("FAIL pre ${s.get_depth()}"); exit(1); }
    final snap = s.saveState();
    final s2 = PPushDeep();

    s2.restoreState(snap);
    if (s2.get_depth() != 3) { print("FAIL post ${s2.get_depth()}"); exit(1); }
    s2.ascend();
    if (s2.get_depth() != 2) { print("FAIL a1"); exit(1); }
    s2.ascend();
    if (s2.get_depth() != 1) { print("FAIL a2"); exit(1); }
    s2.ascend();
    if (s2.get_depth() != 0) { print("FAIL a3"); exit(1); }
    print("PASS: 71_persist_push_depth_three");
}

@@target erlang
@@[persist]
@@system PersistHsmStateArgs {
    interface:
        drive(p: int)
        getX(): int
    machine:
        $Start {
            drive(p: int) {
                -> $Child(p)
            }
            getX(): int {
                @@:(-1)
            }
        }
        $Child => $Parent(x: int) {
            drive(p: int) {
                -> $Child(p)
            }
            getX(): int {
                @@:(x)
            }
        }
        $Parent {
        }
    domain:
        v = 0
}

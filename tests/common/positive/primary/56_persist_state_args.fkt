@@[target("kotlin")]

@@[persist]
@@system PersistStateArgs {
    interface:
        kick(v: int)
        get_slot(): int

    machine:
        $Idle {
            kick(v: int) {
                -> $Active(v)
            }
            get_slot(): int {
                @@:(-1)
            }
        }

        $Active(slot: int) {
            kick(v: int) {
                -> $Active(v)
            }
            get_slot(): int {
                @@:(slot)
            }
        }
    domain:
        v : int = 0
}

fun main() {
    println("=== Test 56: Persist State-Args Round-Trip (Kotlin) ===")
    val s1 = PersistStateArgs()
    s1.kick(42)
    val pre = s1.get_slot()
    if (pre != 42) { println("FAIL: pre $pre"); kotlin.system.exitProcess(1) }
    println("1. Pre-save slot=$pre")

    val snap = s1.save_state() as String
    val s2 = PersistStateArgs.restore_state(snap)
    val post = s2.get_slot()
    if (post != 42) { println("FAIL: post $post"); kotlin.system.exitProcess(1) }
    println("2. Post-restore slot=$post")

    s2.kick(99)
    val post2 = s2.get_slot()
    if (post2 != 99) { println("FAIL: post2 $post2"); kotlin.system.exitProcess(1) }
    println("3. Post-restore-kick slot=$post2")

    println("PASS: 56_persist_state_args")
}

@@[target("php")]

@@[persist(string)]
@@[save(save_state)]
@@[load(restore_state)]
@@system PersistStateArgs {
    interface:
        kick(v: int)
        get_slot(): int

    machine:
        $Idle {
            kick(v: int) {
                -> $Active(v)
            }
            get_slot(): int {
                @@:(-1)
                return;
            }
        }

        $Active(slot: int) {
            kick(v: int) {
                -> $Active(v)
            }
            get_slot(): int {
                @@:($slot)
                return;
            }
        }
    domain:
        v: int = 0
}

echo "=== Test 56: Persist State-Args Round-Trip (PHP) ===\n";

$s1 = @@PersistStateArgs();
$s1->kick(42);
$pre = $s1->get_slot();
if ($pre !== 42) { echo "FAIL: pre $pre\n"; exit(1); }
echo "1. Pre-save slot=$pre\n";

$snap = $s1->save_state();
$s2 = @@PersistStateArgs();

$s2->restore_state($snap);
$post = $s2->get_slot();
if ($post !== 42) { echo "FAIL: post $post\n"; exit(1); }
echo "2. Post-restore slot=$post\n";

$s2->kick(99);
$post2 = $s2->get_slot();
if ($post2 !== 99) { echo "FAIL: post2 $post2\n"; exit(1); }
echo "3. Post-restore-kick slot=$post2\n";

echo "PASS: 56_persist_state_args\n";

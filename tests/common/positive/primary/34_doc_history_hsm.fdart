@@target dart

// Documentation Example: HSM with History (History203)
// Refactored common gotoC behavior into parent state $AB

@@system HistoryHSM {
    interface:
        gotoA()
        gotoB()
        gotoC()
        goBack()
        get_state(): String
        get_log(): String[]

    machine:
        $Waiting {
            $>() {
                this.log_msg("In $Waiting")
            }
            gotoA() {
                this.log_msg("gotoA")
                -> $A
            }
            gotoB() {
                this.log_msg("gotoB")
                -> $B
            }
            get_state(): String {
                @@:("Waiting")
                return;
            }
            get_log(): String[] {
                @@:(this.log)
                return;
            }
        }

        $A => $AB {
            $>() {
                this.log_msg("In $A")
            }
            gotoB() {
                this.log_msg("gotoB")
                -> $B
            }
            get_state(): String {
                @@:("A")
                return;
            }
            get_log(): String[] {
                @@:(this.log)
                return;
            }
            => $^
        }

        $B => $AB {
            $>() {
                this.log_msg("In $B")
            }
            gotoA() {
                this.log_msg("gotoA")
                -> $A
            }
            get_state(): String {
                @@:("B")
                return;
            }
            get_log(): String[] {
                @@:(this.log)
                return;
            }
            => $^
        }

        $AB {
            gotoC() {
                this.log_msg("gotoC in $AB")
                push$
                -> $C
            }
        }

        $C {
            $>() {
                this.log_msg("In $C")
            }
            goBack() {
                this.log_msg("goBack")
                -> pop$
            }
            get_state(): String {
                @@:("C")
                return;
            }
            get_log(): String[] {
                @@:(this.log)
                return;
            }
        }

    actions:
        log_msg(msg: String) {
            this.log.add(msg)
        }

    domain:
        log: String[] = []
}

void main() {
    print("== Test 34: Doc History HSM ==");
    final h = @@HistoryHSM();

    // Start in Waiting
    if (h.get_state() != "Waiting") {
        throw Exception("Expected 'Waiting', got '${h.get_state()}'");
    }

    // Go to A
    h.gotoA();
    if (h.get_state() != "A") {
        throw Exception("Expected 'A', got '${h.get_state()}'");
    }

    // Go to C (using inherited gotoC from $AB)
    h.gotoC();
    if (h.get_state() != "C") {
        throw Exception("Expected 'C', got '${h.get_state()}'");
    }

    // Go back (should pop to A)
    h.goBack();
    if (h.get_state() != "A") {
        throw Exception("Expected 'A' after goBack, got '${h.get_state()}'");
    }

    // Go to B
    h.gotoB();
    if (h.get_state() != "B") {
        throw Exception("Expected 'B', got '${h.get_state()}'");
    }

    // Go to C (again using inherited gotoC)
    h.gotoC();
    if (h.get_state() != "C") {
        throw Exception("Expected 'C', got '${h.get_state()}'");
    }

    // Go back (should pop to B)
    h.goBack();
    if (h.get_state() != "B") {
        throw Exception("Expected 'B' after goBack, got '${h.get_state()}'");
    }

    print("Log:", h.get_log());
    print("PASS: HSM with history works correctly");
}


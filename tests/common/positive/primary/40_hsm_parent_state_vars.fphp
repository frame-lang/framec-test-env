@@[target("php")]

@@system HSMParentStateVars {
    interface:
        get_child_count(): int
        get_parent_count(): int

    machine:
        $Child => $Parent {
            $.child_count: int = 0

            $>() {
                // RFC-0019: forward $> to $Parent so its state-var
                // initializer ($.parent_count = 100) runs.
                => $^
            }

            get_child_count(): int {
                @@:($.child_count)
                return;
            }

            get_parent_count(): int {
                => $^
            }
        }

        $Parent {
            $.parent_count: int = 100

            get_parent_count(): int {
                @@:($.parent_count)
                return;
            }
        }
}

echo "=== Test 40: HSM Parent State Variables ===" . "\n";
$s = @@HSMParentStateVars();

$child_count = $s->get_child_count();
if ($child_count !== 0) { echo "FAIL: Expected child_count=0, got {$child_count}\n"; exit(1); }
echo "Child count: {$child_count}" . "\n";

$parent_count = $s->get_parent_count();
if ($parent_count !== 100) { echo "FAIL: Expected parent_count=100, got {$parent_count}\n"; exit(1); }
echo "Parent count: {$parent_count}" . "\n";

echo "PASS: HSM parent state variables work correctly" . "\n";

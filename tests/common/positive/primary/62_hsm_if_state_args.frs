@@[target("rust")]

@@system HsmIfStateArgs {
    interface:
        enter_active(t: i32)
        classify(v: i32): i32

    machine:
        $Idle {
            enter_active(t: i32) {
                -> $Active(t)
            }
            classify(v: i32): i32 {
                @@:(-1)
                return;
            }
        }

        $Active => $Frame(threshold: i32) {
            enter_active(t: i32) {
                -> $Active(t)
            }
            classify(v: i32): i32 {
                if v > threshold {
                    @@:(1)
                    return;
                } else {
                    @@:(0)
                    return;
                }
            }
        }

        $Frame {
        }
    domain:
        n: i32
}

fn main() {
    println!("=== Test 62: HSM × if × state-args (Rust) ===");
    let mut s = @@HsmIfStateArgs();

    let pre = s.classify(5);
    if pre != -1 { println!("FAIL: pre {}", pre); std::process::exit(1); }
    println!("1. Idle classify(5) = {}", pre);

    s.enter_active(10);
    let under = s.classify(5);
    if under != 0 { println!("FAIL: under {}", under); std::process::exit(1); }
    println!("2. classify(5) with threshold=10 -> {}", under);

    let over = s.classify(15);
    if over != 1 { println!("FAIL: over {}", over); std::process::exit(1); }
    println!("3. classify(15) with threshold=10 -> {}", over);

    let eq = s.classify(10);
    if eq != 0 { println!("FAIL: eq {}", eq); std::process::exit(1); }
    println!("4. classify(10) with threshold=10 -> {}", eq);

    s.enter_active(50);
    let new_under = s.classify(15);
    if new_under != 0 { println!("FAIL: new_under {}", new_under); std::process::exit(1); }
    println!("5. classify(15) with threshold=50 -> {}", new_under);

    println!("PASS: 62_hsm_if_state_args");
}

@@target c

// Test 40: HSM Parent State Variables
//
// This test validates that parent and child states in an HSM hierarchy
// maintain SEPARATE compartments with independent state variables.

#include <stdio.h>
#include <stdlib.h>
#include <assert.h>

@@system HSMParentStateVars {
    interface:
        get_child_count(): int
        get_parent_count(): int

    machine:
        $Child => $Parent {
            $.child_count: int = 0

            get_child_count(): int {
                return $.child_count
            }

            get_parent_count(): int {
                => $^
            }
        }

        $Parent {
            $.parent_count: int = 100

            get_parent_count(): int {
                return $.parent_count
            }
        }
}

int main() {
    printf("=== Test 40: HSM Parent State Variables ===\n");
    HSMParentStateVars* s = @@HSMParentStateVars();

    int child_count = HSMParentStateVars_get_child_count(s);
    assert(child_count == 0);
    printf("Child count: %d\n", child_count);

    int parent_count = HSMParentStateVars_get_parent_count(s);
    assert(parent_count == 100);
    printf("Parent count: %d\n", parent_count);

    HSMParentStateVars_destroy(s);
    printf("PASS: HSM parent state variables work correctly\n");
    return 0;
}

@@[target("ruby")]

require 'json'

@@[persist(String)]
@@[save(save_state)]
@@[load(restore_state)]
@@system PersistStateArgs {
    interface:
        kick(v: int)
        get_slot(): int

    machine:
        $Idle {
            kick(v: int) {
                -> $Active(v)
            }
            get_slot(): int {
                @@:(-1)
                return
            }
        }

        $Active(slot: int) {
            kick(v: int) {
                -> $Active(v)
            }
            get_slot(): int {
                @@:(slot)
                return
            }
        }
    domain:
        v: int = 0
}

puts("=== Test 56: Persist State-Args Round-Trip (Ruby) ===")

s1 = @@PersistStateArgs()
s1.kick(42)
pre = s1.get_slot()
raise "Expected 42 pre-save, got #{pre}" unless pre == 42
puts("1. Pre-save slot=#{pre}")

snap = s1.save_state()
s2 = @@PersistStateArgs()
s2.restore_state(snap)
post = s2.get_slot()
raise "Expected 42 post-restore, got #{post}" unless post == 42
puts("2. Post-restore slot=#{post}")

s2.kick(99)
post2 = s2.get_slot()
raise "Expected 99 post-kick, got #{post2}" unless post2 == 99
puts("3. Post-restore-kick slot=#{post2}")

puts("PASS: 56_persist_state_args")

@@target c

@@system ReturnTest {
    interface:
        compute(x: int): int

    machine:
        $Start {
            compute(x: int): int {
                int result = x * 2;
                @@:(result)
                return;
            }
        }
}

int main() {
    printf("=== Test 13: System Return ===\n");
    ReturnTest* s = @@ReturnTest();

    int result = ReturnTest_compute(s, 21);
    printf("compute(21) = %d\n", result);
    if (result != 42) {
        printf("FAIL: Expected 42, got %d\n", result);
        return 1;
    }

    result = ReturnTest_compute(s, 0);
    printf("compute(0) = %d\n", result);
    if (result != 0) {
        printf("FAIL: Expected 0, got %d\n", result);
        return 1;
    }

    printf("PASS: System return works correctly\n");
    ReturnTest_destroy(s);
    return 0;
}

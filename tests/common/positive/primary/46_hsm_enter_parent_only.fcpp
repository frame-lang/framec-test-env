@@[target("cpp_17")]

#include <iostream>
#include <cassert>
#include <algorithm>

// Test 46: HSM Enter Cascade — Parent has $>, Child does not

@@system HSMEnterParentOnly {
    interface:
        go_to_child()
        go_to_parent()
        get_log(): std::vector<std::string>
        get_state(): std::string

    machine:
        $Start {
            go_to_child() { -> $Child }
            go_to_parent() { -> $Parent }
            get_log(): std::vector<std::string> { @@:(event_log) }
            get_state(): std::string { @@:(std::string("Start")) }
        }

        $Child => $Parent {
            go_to_parent() { -> $Parent }
            get_log(): std::vector<std::string> { @@:(event_log) }
            get_state(): std::string { @@:(std::string("Child")) }
            => $^   // RFC-0019: forward the unhandled $> to $Parent
        }

        $Parent {
            $>() {
                event_log.push_back("Parent:enter");
            }
            go_to_child() { -> $Child }
            get_log(): std::vector<std::string> { @@:(event_log) }
            get_state(): std::string { @@:(std::string("Parent")) }
        }
    domain:
        event_log : std::vector<std::string> = {}
}

int main() {
    printf("=== Test 46: HSM Enter Cascade — Parent only ===\n");
    auto s = @@HSMEnterParentOnly();

    s.go_to_child();
    if (s.get_state() != "Child") { printf("FAIL\n"); assert(false); }
    auto log = s.get_log();
    if (std::find(log.begin(), log.end(), "Parent:enter") == log.end()) { printf("FAIL: Expected Parent:enter on cascade\n"); assert(false); }
    printf("TC1: Parent's $> fires on cascade entry to Child - PASS\n");

    s.go_to_parent();
    log = s.get_log();
    if (std::count(log.begin(), log.end(), "Parent:enter") != 2) { printf("FAIL: Expected 2 Parent:enter\n"); assert(false); }
    printf("TC2: Parent's $> fires again when transitioning directly to Parent - PASS\n");

    s.go_to_child();
    log = s.get_log();
    if (std::count(log.begin(), log.end(), "Parent:enter") != 3) { printf("FAIL: Expected 3 Parent:enter\n"); assert(false); }
    printf("TC3: Re-entering Child cascades through Parent again - PASS\n");

    printf("PASS: HSM enter cascade fires Parent's $> on child entry\n");
    return 0;
}

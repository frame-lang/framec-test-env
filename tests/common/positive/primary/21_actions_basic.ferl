@@target erlang
@@system ActionsTest {
    interface:
        process(value: int): int
        getLog(): str
    machine:
        $Ready {
            process(value: int): int {
                self.logEvent("start")
                self.logEvent("done")
                return value * 2
            }
            getLog(): str { return self.log }
        }
    actions:
        logEvent(msg: str) {
            self.log = self.log ++ msg ++ ";"
        }
    domain:
        log = ""
}

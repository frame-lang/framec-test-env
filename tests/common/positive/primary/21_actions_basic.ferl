@@[target("erlang")]
@@system ActionsTest {
    interface:
        process(value: int): int
        getLog(): str
    machine:
        $Ready {
            process(value: int): int {
                self.logEvent("start")
                self.logEvent("done")
                @@:(value * 2)
                return
            }
            getLog(): str {
                @@:(self.log)
            }
        }
    actions:
        logEvent(msg: str) {
            self.log = self.log ++ msg ++ ";"
        }
    domain:
        log = ""
}

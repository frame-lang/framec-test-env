@@[target("ruby")]

@@system StackOps {
    interface:
        push_and_go()
        pop_back()
        do_work(): str
        get_state(): str

    machine:
        $Main {
            push_and_go() {
                puts("Pushing Main to stack, going to Sub")
                push$
                -> $Sub
            }

            pop_back() {
                puts("Cannot pop - nothing on stack in Main")
            }

            do_work(): str {
                @@:("Working in Main")
                return
            }

            get_state(): str {
                @@:("Main")
                return
            }
        }

        $Sub {
            push_and_go() {
                puts("Already in Sub")
            }

            pop_back() {
                puts("Popping back to previous state")
                -> pop$
            }

            do_work(): str {
                @@:("Working in Sub")
                return
            }

            get_state(): str {
                @@:("Sub")
                return
            }
        }
}

puts("=== Test 09: Stack Push/Pop ===")
s = @@StackOps()

# Initial state should be Main
state = s.get_state()
raise "Expected 'Main', got '#{state}'" unless state == "Main"
puts("Initial state: #{state}")

# Do work in Main
work = s.do_work()
raise "Expected 'Working in Main', got '#{work}'" unless work == "Working in Main"
puts("do_work(): #{work}")

# Push and go to Sub
s.push_and_go()
state = s.get_state()
raise "Expected 'Sub', got '#{state}'" unless state == "Sub"
puts("After push_and_go(): #{state}")

# Do work in Sub
work = s.do_work()
raise "Expected 'Working in Sub', got '#{work}'" unless work == "Working in Sub"
puts("do_work(): #{work}")

# Pop back to Main
s.pop_back()
state = s.get_state()
raise "Expected 'Main' after pop, got '#{state}'" unless state == "Main"
puts("After pop_back(): #{state}")

puts("PASS: Stack push/pop works correctly")

@@target swift

// Documentation Example: Basic Lamp with enter/exit events

@@system Lamp {
    interface:
        turnOn()
        turnOff()
        getColor(): string
        setColor(color: string)
        isSwitchClosed(): boolean

    machine:
        $Off {
            turnOn() {
                -> $On
            }
            getColor(): string {
                return self.color
            }
            setColor(color: string) {
                self.color = color
            }
            isSwitchClosed(): boolean {
                return self.switch_closed
            }
        }

        $On {
            $>() {
                self.closeSwitch()
            }
            <$() {
                self.openSwitch()
            }
            turnOff() {
                -> $Off
            }
            getColor(): string {
                return self.color
            }
            setColor(color: string) {
                self.color = color
            }
            isSwitchClosed(): boolean {
                return self.switch_closed
            }
        }

    actions:
        closeSwitch() {
            self.switch_closed = true
        }
        openSwitch() {
            self.switch_closed = false
        }

    domain:
        color: string = "white"
        switch_closed: boolean = false
}

// main
    print("=== Test 31: Doc Lamp Basic ===")
    let lamp = @@Lamp()

    // Initially off
    if lamp.isSwitchClosed() != false {
        fatalError("Switch should be open initially")
    }

    // Turn on - should close switch
    lamp.turnOn()
    if lamp.isSwitchClosed() != true {
        fatalError("Switch should be closed after turnOn")
    }

    // Check color
    if lamp.getColor() != "white" {
        fatalError("Expected 'white', got '\(lamp.getColor())'")
    }

    // Set color
    lamp.setColor("blue")
    if lamp.getColor() != "blue" {
        fatalError("Expected 'blue', got '\(lamp.getColor())'")
    }

    // Turn off - should open switch
    lamp.turnOff()
    if lamp.isSwitchClosed() != false {
        fatalError("Switch should be open after turnOff")
    }

    print("PASS: Basic lamp works correctly")

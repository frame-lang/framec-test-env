@@[target("kotlin")]

import kotlin.system.exitProcess

@@[persist(String)]
@@[save(save_state)]
@@[load(restore_state)]
@@system HSMPersist {
    interface:
        increment_child()
        increment_parent()
        get_child_count(): Int
        get_parent_count(): Int
        get_state(): String

    machine:
        $Child => $Parent {
            $.child_count: Int = 0

            increment_child() { $.child_count = $.child_count + 1 }
            get_child_count(): Int {
                @@:($.child_count)
            }
            get_state(): String {
                @@:("Child")
            }
        }

        $Parent {
            increment_parent() { $.parent_count = $.parent_count + 1 }
            get_parent_count(): Int {
                @@:($.parent_count)
            }
            get_state(): String {
                @@:("Parent")
            }
            increment_child() { }
            get_child_count(): Int {
                @@:(-1)
            }
        }

    domain:
        parent_count_init : Int = 100
}

fun main() {
    println("=== Test 51: HSM Persistence (Kotlin) ===")

    // Note: parent_count is a state var on $Parent, init from domain
    // For simplicity, test with child_count state var only
    val s1 = @@HSMPersist()
    s1.increment_child()
    s1.increment_child()
    s1.increment_child()

    if ((s1.get_child_count() as Int) != 3) {
        println("FAIL: child_count ${s1.get_child_count()}"); exitProcess(1)
    }
    println("1. child_count: ${s1.get_child_count()}")

    val json = s1.save_state() as String
    println("2. Saved: ${json.length} chars")

    val s2 = @@HSMPersist()


    s2.restore_state(json)
    if ((s2.get_state() as String) != "Child") {
        println("FAIL: state ${s2.get_state()}"); exitProcess(1)
    }
    println("3. Restored state: ${s2.get_state()}")

    if ((s2.get_child_count() as Int) != 3) {
        println("FAIL: restored child_count ${s2.get_child_count()}"); exitProcess(1)
    }
    println("4. child_count preserved: ${s2.get_child_count()}")

    s2.increment_child()
    if ((s2.get_child_count() as Int) != 4) {
        println("FAIL: post-restore ${s2.get_child_count()}"); exitProcess(1)
    }
    println("5. After increment: ${s2.get_child_count()}")

    println("PASS: HSM persistence works correctly")
}

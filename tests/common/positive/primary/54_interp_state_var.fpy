@@[target("python_3")]

@@system InterpStress {
    interface:
        test_dquote(): str
        test_squote(): str
        test_standalone(): int
        test_return(): int
        test_multi(): str
        test_mixed(): str

    machine:
        $Active {
            $.count: int = 42
            $.label: str = "hello"

            test_dquote(): str {
                @@:(f"count is {$.count}")
            }

            test_squote(): str {
                @@:(f'count is {$.count}')
            }

            test_standalone(): int {
                x = $.count + 1
                @@:(x)
            }

            test_return(): int {
                @@:($.count)
            }

            test_multi(): str {
                @@:(f"{$.count} and {$.label}")
            }

            test_mixed(): str {
                total = 100
                @@:(f"{$.count}/{total}")
            }
        }
}

if __name__ == '__main__':
    s = @@InterpStress()
    failures = 0

    r = s.test_dquote()
    if r != "count is 42":
        print(f"FAIL dquote: got '{r}'")
        failures += 1

    r = s.test_squote()
    if r != "count is 42":
        print(f"FAIL squote: got '{r}'")
        failures += 1

    r = s.test_standalone()
    if r != 43:
        print(f"FAIL standalone: got {r}")
        failures += 1

    r = s.test_return()
    if r != 42:
        print(f"FAIL return: got {r}")
        failures += 1

    r = s.test_multi()
    if r != "42 and hello":
        print(f"FAIL multi: got '{r}'")
        failures += 1

    r = s.test_mixed()
    if r != "42/100":
        print(f"FAIL mixed: got '{r}'")
        failures += 1

    if failures > 0:
        print(f"FAIL: {failures} failures")
        exit(1)
    print("PASS: stress_interp (6 cases)")

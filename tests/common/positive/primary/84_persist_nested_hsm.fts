@@[target("typescript")]

@@[persist(string)]
@@[save(saveState)]
@@[load(restoreState)]
@@system Inner {
    interface:
        cycle()
        get_state(): string
        get_count(): number

    machine:
        $A {
            cycle() { this.n = this.n + 1; -> $B }
            get_state(): string { @@:("A") }
            get_count(): number { @@:(this.n) }
        }
        $B => $A {
            cycle() { -> $A }
            get_state(): string { @@:("B") }
            get_count(): number { => $^ }
        }
    domain:
        n: number = 0
}

@@[main]
@@system Outer {
    operations:
        @@[save]
        saveState(): string {}

        @@[load]
        restoreState(data: string) {}

    interface:
        tick()
        cycle_inner()
        get_outer_state(): string
        get_inner_state(): string
        get_inner_count(): number
        get_k(): number

    machine:
        $Idle {
            tick() { this.k = this.k + 1; -> $Active }
            cycle_inner() { this.inner.cycle() }
            get_outer_state(): string { @@:("Idle") }
            get_inner_state(): string { @@:(this.inner.get_state()) }
            get_inner_count(): number { @@:(this.inner.get_count()) }
            get_k(): number { @@:(this.k) }
        }
        $Active => $Idle {
            tick() { -> $Idle }
            get_outer_state(): string { @@:("Active") }
            cycle_inner() { => $^ }
            get_inner_state(): string { => $^ }
            get_inner_count(): number { => $^ }
            get_k(): number { => $^ }
        }
    domain:
        k: number = 0
        inner: Inner = @@Inner()
}

const probe = (o: Outer): [string, string, number, number] => [o.get_outer_state(), o.get_inner_state(), o.get_inner_count(), o.get_k()];
const eq = (a: any[], b: any[]): boolean => a.length === b.length && a.every((v, i) => v === b[i]);
const fail = (label: string, actual: any[], expected: any[]): void => { console.log(`FAIL ${label}: ${JSON.stringify(actual)} expected ${JSON.stringify(expected)}`); process.exit(1); };

const o = new Outer();
let p = probe(o); if (!eq(p, ["Idle", "A", 0, 0])) fail("T0 fresh", p, ["Idle", "A", 0, 0]);
const snap0 = o.saveState();
const r0 = @@Outer();

r0.restoreState(snap0);
p = probe(r0); if (!eq(p, ["Idle", "A", 0, 0])) fail("T0 restored", p, ["Idle", "A", 0, 0]);

o.tick();
p = probe(o); if (!eq(p, ["Active", "A", 0, 1])) fail("T1", p, ["Active", "A", 0, 1]);
const snap1 = o.saveState();
const r1 = @@Outer();

r1.restoreState(snap1);
p = probe(r1); if (!eq(p, ["Active", "A", 0, 1])) fail("T1 restored", p, ["Active", "A", 0, 1]);

o.cycle_inner();
p = probe(o); if (!eq(p, ["Active", "B", 1, 1])) fail("T2", p, ["Active", "B", 1, 1]);
const snap2 = o.saveState();
const r2 = @@Outer();

r2.restoreState(snap2);
p = probe(r2); if (!eq(p, ["Active", "B", 1, 1])) fail("T2 restored", p, ["Active", "B", 1, 1]);

const snap2b = r2.saveState();
const r2b = @@Outer();

r2b.restoreState(snap2b);
if (!eq(probe(r2b), probe(r2))) fail("Idempotence", probe(r2b), probe(r2));

r2.cycle_inner();
p = probe(r2); if (!eq(p, ["Active", "A", 1, 1])) fail("continue1", p, ["Active", "A", 1, 1]);
r2.tick();
p = probe(r2); if (!eq(p, ["Idle", "A", 1, 1])) fail("continue2", p, ["Idle", "A", 1, 1]);
r2.tick();
p = probe(r2); if (!eq(p, ["Active", "A", 1, 2])) fail("continue3", p, ["Active", "A", 1, 2]);

console.log("PASS: 84_persist_nested_hsm");

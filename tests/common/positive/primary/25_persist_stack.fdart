@@[target("dart")]
import 'dart:convert';
@@[persist(String)]
@@[save(saveState)]
@@[load(restoreState)]
@@system PersistStack {
    interface:
        push_and_go()
        pop_back()
        get_state(): String
        get_depth(): num

    machine:
        $Start {
            push_and_go() {
                this.depth = this.depth + 1;
                push$
                -> $Middle
            }

            pop_back() {
                // nothing to pop
            }

            get_state(): String {
                @@:("start")
                return;
            }

            get_depth(): num {
                @@:(this.depth)
                return;
            }
        }

        $Middle {
            push_and_go() {
                this.depth = this.depth + 1;
                push$
                -> $End
            }

            pop_back() {
                this.depth = this.depth - 1;
                -> pop$
            }

            get_state(): String {
                @@:("middle")
                return;
            }

            get_depth(): num {
                @@:(this.depth)
                return;
            }
        }

        $End {
            push_and_go() {
                // can't go further
            }

            pop_back() {
                this.depth = this.depth - 1;
                -> pop$
            }

            get_state(): String {
                @@:("end")
                return;
            }

            get_depth(): num {
                @@:(this.depth)
                return;
            }
        }
    domain:
        depth : num = 0
}

void main() {
    print("== Test 25: Persist Stack (TypeScript) ==");

    // Test 1: Build up a stack
    final s1 = @@PersistStack();
    if (s1.get_state() != "start") throw Exception("Expected start, got ${s1.get_state()}");

    s1.push_and_go();  // Start -> Middle (push Start)
    if (s1.get_state() != "middle") throw Exception("Expected middle, got ${s1.get_state()}");
    if (s1.get_depth() != 1) throw Exception("Expected depth 1, got ${s1.get_depth()}");

    s1.push_and_go();  // Middle -> End (push Middle)
    if (s1.get_state() != "end") throw Exception("Expected end, got ${s1.get_state()}");
    if (s1.get_depth() != 2) throw Exception("Expected depth 2, got ${s1.get_depth()}");

    print("1. Built stack: state=${s1.get_state()}, depth=${s1.get_depth()}");

    // Test 2: Save state (should include stack)
    final json = s1.saveState();
    final data = jsonDecode(json);
    print("2. Saved data: ${json}");
    if (data['_compartment']['state'] != 'End') throw Exception("Expected End state");
    if (data['_state_stack'] == null) throw Exception("Expected _state_stack in saved data");
    if ((data['_state_stack'] as List).length != 2) throw Exception("Expected 2 items in stack, got ${(data['_state_stack'] as List).length}");

    // Test 3: Restore and verify stack works
    final s2 = @@PersistStack();

    s2.restoreState(json);
    if (s2.get_state() != "end") throw Exception("Restored: expected end, got ${s2.get_state()}");
    if (s2.get_depth() != 2) throw Exception("Restored: expected depth 2, got ${s2.get_depth()}");
    print("3. Restored: state=${s2.get_state()}, depth=${s2.get_depth()}");

    // Test 4: Pop should work after restore
    s2.pop_back();  // End -> Middle (pop)
    if (s2.get_state() != "middle") throw Exception("After pop: expected middle, got ${s2.get_state()}");
    if (s2.get_depth() != 1) throw Exception("After pop: expected depth 1, got ${s2.get_depth()}");
    print("4. After pop: state=${s2.get_state()}, depth=${s2.get_depth()}");

    // Test 5: Pop again
    s2.pop_back();  // Middle -> Start (pop)
    if (s2.get_state() != "start") throw Exception("After 2nd pop: expected start, got ${s2.get_state()}");
    if (s2.get_depth() != 0) throw Exception("After 2nd pop: expected depth 0, got ${s2.get_depth()}");
    print("5. After 2nd pop: state=${s2.get_state()}, depth=${s2.get_depth()}");

    print("PASS: Persist stack works correctly");
}


@@[target("gdscript")]
extends SceneTree

@@system OpHsmStateArgs {
    operations:
        add_offset(x: int, off: int): int {
            return x + off
        }

    interface:
        enter_active(t: int)
        classify(v: int): int

    machine:
        $Idle {
            enter_active(t: int) {
                -> $Active(t)
            }
            classify(v: int): int {
                @@:(-1)
            }
        }

        $Active => $Frame(threshold: int) {
            enter_active(t: int) {
                -> $Active(t)
            }
            classify(v: int): int {
                var r = self.add_offset(v, threshold)
                @@:(r)
            }
        }

        $Frame {
        }
    domain:
        n: int = 0
}

func _initialize():
    print("=== Test 64: Operations × HSM × state-args (GDScript) ===")
    var s = OpHsmStateArgs.new()

    var pre = s.classify(5)
    if pre != -1:
        print("FAIL: pre " + str(pre))
        quit(1)
        return
    print("1. Idle classify(5) = " + str(pre))

    s.enter_active(10)
    var r = s.classify(5)
    if r != 15:
        print("FAIL: r " + str(r))
        quit(1)
        return
    print("2. classify(5) with threshold=10 -> " + str(r))

    var r2 = s.classify(7)
    if r2 != 17:
        print("FAIL: r2 " + str(r2))
        quit(1)
        return
    print("3. classify(7) with threshold=10 -> " + str(r2))

    s.enter_active(100)
    var r3 = s.classify(5)
    if r3 != 105:
        print("FAIL: r3 " + str(r3))
        quit(1)
        return
    print("4. classify(5) with threshold=100 -> " + str(r3))

    print("PASS: 64_operation_hsm_state_args")
    quit(0)

@@target lua
@@system DomainVars {
    interface:
        increment()
        decrement()
        get_count(): int
        set_count(value: int)

    machine:
        $Counting {
            increment() {
                self.count = self.count + 1
                -- print
            }

            decrement() {
                self.count = self.count - 1
                -- print
            }

            get_count(): int {
                return self.count
            }

            set_count(value: int) {
                self.count = value
                -- print
            }
        }
    domain:
        count: int = 0
        name: str = "counter"
}

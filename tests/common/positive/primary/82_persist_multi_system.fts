@@target typescript

@@system Counter {
    interface:
        bump()
        value(): number

    machine:
        $Active {
            bump() { this.n = this.n + 1 }
            value(): number { @@:(this.n) }
        }

    domain:
        n: number = 0
}

@@[persist]
@@system Container {
    interface:
        tick()
        get_n(): number

    machine:
        $Active {
            tick() {
                this.n = this.n + 10
                this.counter.bump()
            }
            get_n(): number { @@:(this.n) }
        }

    domain:
        n: number = 0
        counter: Counter = new Counter()
}

const c1 = new Container();
c1.tick();
c1.tick();
if (c1.get_n() !== 20) { console.log(`FAIL pre n: ${c1.get_n()}`); process.exit(1); }
const snap = c1.saveState();
const c2 = Container.restoreState(snap);
if (c2.get_n() !== 20) { console.log(`FAIL post n: ${c2.get_n()}`); process.exit(1); }
console.log("PASS: 82_persist_multi_system");

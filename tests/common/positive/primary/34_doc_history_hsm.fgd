@@target gdscript
extends SceneTree

# Documentation Example: HSM with History (History203)
# Refactored common gotoC behavior into parent state $AB

@@system HistoryHSM {
    interface:
        gotoA()
        gotoB()
        gotoC()
        goBack()
        get_state(): String
        get_log(): list

    machine:
        $Waiting {
            $>() {
                self.log_msg("In $Waiting")
            }
            gotoA() {
                self.log_msg("gotoA")
                -> $A
            }
            gotoB() {
                self.log_msg("gotoB")
                -> $B
            }
            get_state(): String {
                @@:("Waiting")
                return
            }
            get_log(): list {
                @@:(self.log)
                return
            }
        }

        $A => $AB {
            $>() {
                self.log_msg("In $A")
            }
            gotoB() {
                self.log_msg("gotoB")
                -> $B
            }
            get_state(): String {
                @@:("A")
                return
            }
            get_log(): list {
                @@:(self.log)
                return
            }
            => $^
        }

        $B => $AB {
            $>() {
                self.log_msg("In $B")
            }
            gotoA() {
                self.log_msg("gotoA")
                -> $A
            }
            get_state(): String {
                @@:("B")
                return
            }
            get_log(): list {
                @@:(self.log)
                return
            }
            => $^
        }

        $AB {
            gotoC() {
                self.log_msg("gotoC in $AB")
                push$
                -> $C
            }
        }

        $C {
            $>() {
                self.log_msg("In $C")
            }
            goBack() {
                self.log_msg("goBack")
                -> pop$
            }
            get_state(): String {
                @@:("C")
                return
            }
            get_log(): list {
                @@:(self.log)
                return
            }
        }

    actions:
        log_msg(msg: String) {
            self.log.append(msg)
        }

    domain:
        log: list = []
}

func main():
    print("=== Test 34: Doc History HSM ===")
    var h = @@HistoryHSM()

    # Start in Waiting
    assert(h.get_state() == "Waiting", "Expected 'Waiting', got '" + str(h.get_state()) + "'")
    assert("In $Waiting" in h.get_log(), "Expected enter log, got " + str(h.get_log()))

    # Go to A
    h.gotoA()
    assert(h.get_state() == "A", "Expected 'A', got '" + str(h.get_state()) + "'")

    # Go to C (using inherited gotoC from $AB)
    h.gotoC()
    assert(h.get_state() == "C", "Expected 'C', got '" + str(h.get_state()) + "'")
    assert("gotoC in $AB" in h.get_log(), "Expected gotoC log, got " + str(h.get_log()))

    # Go back (should pop to A)
    h.goBack()
    assert(h.get_state() == "A", "Expected 'A' after goBack, got '" + str(h.get_state()) + "'")

    # Go to B
    h.gotoB()
    assert(h.get_state() == "B", "Expected 'B', got '" + str(h.get_state()) + "'")

    # Go to C (again using inherited gotoC)
    h.gotoC()
    assert(h.get_state() == "C", "Expected 'C', got '" + str(h.get_state()) + "'")

    # Go back (should pop to B)
    h.goBack()
    assert(h.get_state() == "B", "Expected 'B' after goBack, got '" + str(h.get_state()) + "'")

    print("Log: " + str(h.get_log()))
    print("PASS: HSM with history works correctly")

func _init():
    main()
    quit()

@@target erlang
@@system LampHSM {
    interface:
        turnOn()
        turnOff()
        getColor(): str
        setColor(color: str)
        getBrightness(): int
        setBrightness(level: int)
    machine:
        $Off {
            turnOn() { -> $On }
            getColor(): str { return self.color }
            setColor(color: str) { self.color = color }
            getBrightness(): int { return 0 }
            setBrightness(level: int) { }
        }
        $On => $OnBase {
            $>() { self.switch_closed = true }
            <$() { self.switch_closed = false }
            turnOff() { -> $Off }
        }
        $OnBase {
            getColor(): str { return self.color }
            setColor(color: str) { self.color = color }
            getBrightness(): int { return self.brightness }
            setBrightness(level: int) { self.brightness = level }
        }
    domain:
        color = "white"
        switch_closed = false
        brightness = 100
}

@@[target("gdscript")]
extends SceneTree

@@system StackOps {
    interface:
        push_and_go()
        pop_back()
        do_work(): String
        get_state(): String

    machine:
        $Main {
            push_and_go() {
                print("Pushing Main to stack, going to Sub")
                push$
                -> $Sub
            }

            pop_back() {
                print("Cannot pop - nothing on stack in Main")
            }

            do_work(): String {
                @@:("Working in Main")
                return
            }

            get_state(): String {
                @@:("Main")
                return
            }
        }

        $Sub {
            push_and_go() {
                print("Already in Sub")
            }

            pop_back() {
                print("Popping back to previous state")
                -> pop$
            }

            do_work(): String {
                @@:("Working in Sub")
                return
            }

            get_state(): String {
                @@:("Sub")
                return
            }
        }
}

func main():
    print("=== Test 09: Stack Push/Pop ===")
    var s = @@StackOps()

    # Initial state should be Main
    var state = s.get_state()
    assert(state == "Main", "Expected 'Main', got '" + str(state) + "'")
    print("Initial state: " + str(state))

    # Do work in Main
    var work = s.do_work()
    assert(work == "Working in Main", "Expected 'Working in Main', got '" + str(work) + "'")
    print("do_work(): " + str(work))

    # Push and go to Sub
    s.push_and_go()
    state = s.get_state()
    assert(state == "Sub", "Expected 'Sub', got '" + str(state) + "'")
    print("After push_and_go(): " + str(state))

    # Do work in Sub
    work = s.do_work()
    assert(work == "Working in Sub", "Expected 'Working in Sub', got '" + str(work) + "'")
    print("do_work(): " + str(work))

    # Pop back to Main
    s.pop_back()
    state = s.get_state()
    assert(state == "Main", "Expected 'Main' after pop, got '" + str(state) + "'")
    print("After pop_back(): " + str(state))

    print("PASS: Stack push/pop works correctly")

func _init():
    main()
    quit()

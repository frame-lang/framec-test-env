@@[target("csharp")]


@@system LampHSM {
    interface:
        turnOn()
        turnOff()
        getColor(): string
        setColor(color: string)
        isLampOn(): bool

    machine:
        $Off => $ColorBehavior {
            turnOn() {
                -> $On
            }
            isLampOn(): bool {
                @@:(this.lamp_on)
                return;
            }
            => $^
        }

        $On => $ColorBehavior {
            $>() {
                this.turnOnLamp();
            }
            <$() {
                this.turnOffLamp();
            }
            turnOff() {
                -> $Off
            }
            isLampOn(): bool {
                @@:(this.lamp_on)
                return;
            }
            => $^
        }

        $ColorBehavior {
            getColor(): string {
                @@:(this.color)
                return;
            }
            setColor(color: string) {
                this.color = color;
            }
        }

    actions:
        turnOnLamp() {
            this.lamp_on = true;
        }
        turnOffLamp() {
            this.lamp_on = false;
        }

    domain:
        color : string = "white"
        lamp_on : bool = false
}

class Program {
    static void Main(string[] args) {
        Console.WriteLine("=== Test 32: Doc Lamp HSM ===");
        var lamp = @@LampHSM();

        // Color behavior available in both states
        if ((string)lamp.getColor() != "white") {
            Console.WriteLine("FAIL: Expected 'white', got '" + lamp.getColor() + "'");
            Environment.Exit(1);
        }
        lamp.setColor("red");
        if ((string)lamp.getColor() != "red") {
            Console.WriteLine("FAIL: Expected 'red', got '" + lamp.getColor() + "'");
            Environment.Exit(1);
        }

        // Turn on
        lamp.turnOn();
        if ((bool)lamp.isLampOn() != true) {
            Console.WriteLine("FAIL: Lamp should be on");
            Environment.Exit(1);
        }

        // Color still works when on
        lamp.setColor("green");
        if ((string)lamp.getColor() != "green") {
            Console.WriteLine("FAIL: Expected 'green', got '" + lamp.getColor() + "'");
            Environment.Exit(1);
        }

        // Turn off
        lamp.turnOff();
        if ((bool)lamp.isLampOn() != false) {
            Console.WriteLine("FAIL: Lamp should be off");
            Environment.Exit(1);
        }

        // Color still works when off
        if ((string)lamp.getColor() != "green") {
            Console.WriteLine("FAIL: Expected 'green', got '" + lamp.getColor() + "'");
            Environment.Exit(1);
        }

        Console.WriteLine("PASS: HSM lamp works correctly");
    }
}

@@[target("python_3")]

# Wave 8 depth-3: nested-system × HSM × persist with three levels.
# Outer holds Mid; Mid holds Inner. All three have HSM; persist must
# recurse through all of them. Probes all observables including
# Outer's k and Mid's m. Three save points + idempotence + continue.

@@[persist(bytes)]
@@[save(save_state)]
@@[load(restore_state)]
@@system Inner {
    interface:
        cycle()
        get_state(): str
        get_count(): int

    machine:
        $A {
            cycle() {
                self.n = self.n + 1
                -> $B
            }
            get_state(): str { @@:("A"); return }
            get_count(): int { @@:(self.n); return }
        }
        $B => $A {
            cycle() { -> $A }
            get_state(): str { @@:("B"); return }
            get_count(): int { => $^ }
        }
    domain:
        n: int = 0
}

@@system Mid {
    operations:
        @@[save]
        save_state(): bytes {}

        @@[load]
        restore_state(data: bytes) {}

    interface:
        cycle()
        cycle_inner()
        get_state(): str
        get_inner_state(): str
        get_inner_count(): int
        get_m(): int

    machine:
        $P {
            cycle() {
                self.m = self.m + 1
                -> $Q
            }
            cycle_inner() { self.inner.cycle() }
            get_state(): str { @@:("P"); return }
            get_inner_state(): str { @@:(self.inner.get_state()); return }
            get_inner_count(): int { @@:(self.inner.get_count()); return }
            get_m(): int { @@:(self.m); return }
        }
        $Q => $P {
            cycle() { -> $P }
            get_state(): str { @@:("Q"); return }
            cycle_inner() { => $^ }
            get_inner_state(): str { => $^ }
            get_inner_count(): int { => $^ }
            get_m(): int { => $^ }
        }
    domain:
        m: int = 0
        inner = @@Inner()
}

@@[main]
@@system Outer {
    operations:
        @@[save]
        save_state(): bytes {}

        @@[load]
        restore_state(data: bytes) {}

    interface:
        tick()
        cycle_mid()
        cycle_inner()
        get_outer_state(): str
        get_mid_state(): str
        get_inner_state(): str
        get_inner_count(): int
        get_m(): int
        get_k(): int

    machine:
        $Idle {
            tick() {
                self.k = self.k + 1
                -> $Active
            }
            cycle_mid() { self.mid.cycle() }
            cycle_inner() { self.mid.cycle_inner() }
            get_outer_state(): str { @@:("Idle"); return }
            get_mid_state(): str { @@:(self.mid.get_state()); return }
            get_inner_state(): str { @@:(self.mid.get_inner_state()); return }
            get_inner_count(): int { @@:(self.mid.get_inner_count()); return }
            get_m(): int { @@:(self.mid.get_m()); return }
            get_k(): int { @@:(self.k); return }
        }
        $Active => $Idle {
            tick() { -> $Idle }
            get_outer_state(): str { @@:("Active"); return }
            cycle_mid() { => $^ }
            cycle_inner() { => $^ }
            get_mid_state(): str { => $^ }
            get_inner_state(): str { => $^ }
            get_inner_count(): int { => $^ }
            get_m(): int { => $^ }
            get_k(): int { => $^ }
        }
    domain:
        k: int = 0
        mid = @@Mid()
}

if __name__ == '__main__':
    def probe(o):
        return (o.get_outer_state(), o.get_mid_state(), o.get_inner_state(),
                o.get_inner_count(), o.get_m(), o.get_k())

    o = Outer()
    assert probe(o) == ("Idle", "P", "A", 0, 0, 0), f"T0 fresh: {probe(o)}"
    snap0 = o.save_state()
    r0 = Outer()

    r0.restore_state(snap0)
    assert probe(r0) == ("Idle", "P", "A", 0, 0, 0), f"T0 restored: {probe(r0)}"

    o.tick()
    assert probe(o) == ("Active", "P", "A", 0, 0, 1), f"T1: {probe(o)}"
    snap1 = o.save_state()
    r1 = Outer()

    r1.restore_state(snap1)
    assert probe(r1) == ("Active", "P", "A", 0, 0, 1), f"T1 restored: {probe(r1)}"

    # Mutate Mid (m++, $P→$Q) and Inner (n++, $A→$B). Outer stays $Active.
    o.cycle_mid()      # $Active forwards $P.cycle: m=1, mid→$Q
    o.cycle_inner()    # $Active forwards $Q forwards $P.cycle_inner: inner $A.cycle: n=1, inner→$B
    assert probe(o) == ("Active", "Q", "B", 1, 1, 1), f"T2: {probe(o)}"
    snap2 = o.save_state()
    r2 = Outer()

    r2.restore_state(snap2)
    assert probe(r2) == ("Active", "Q", "B", 1, 1, 1), f"T2 restored: {probe(r2)}"

    snap2b = r2.save_state()
    r2b = Outer()

    r2b.restore_state(snap2b)
    assert probe(r2b) == probe(r2), f"Idempotence: {probe(r2b)} != {probe(r2)}"

    r2.cycle_inner()   # inner $B.cycle: -> $A
    assert probe(r2) == ("Active", "Q", "A", 1, 1, 1), f"continue1: {probe(r2)}"
    r2.cycle_mid()     # mid $Q.cycle: -> $P
    assert probe(r2) == ("Active", "P", "A", 1, 1, 1), f"continue2: {probe(r2)}"
    r2.tick()          # $Active.tick: -> $Idle
    assert probe(r2) == ("Idle", "P", "A", 1, 1, 1), f"continue3: {probe(r2)}"
    r2.tick()          # $Idle.tick: k=2, -> $Active
    assert probe(r2) == ("Active", "P", "A", 1, 1, 2), f"continue4: {probe(r2)}"

    print("PASS: 85_persist_three_level_nested")

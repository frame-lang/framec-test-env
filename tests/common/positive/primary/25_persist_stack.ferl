@@target erlang
@@[persist]
@@system PersistStack {
    interface:
        pushGo()
        popBack()
        getState(): str
    machine:
        $Main {
            pushGo() {
                push$
                -> $Sub
            }
            popBack() { }
            getState(): str {
                @@:("Main")
            }
        }
        $Sub {
            pushGo() { }
            popBack() { -> pop$ }
            getState(): str {
                @@:("Sub")
            }
        }
}

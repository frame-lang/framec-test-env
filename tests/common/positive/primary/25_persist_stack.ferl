@@[target("erlang")]
@@[persist]
@@system PersistStack {
    operations:
        @@[save]
        save_state() {}

        @@[load]
        load_state(data) {}

    interface:
        pushGo()
        popBack()
        getState(): str
    machine:
        $Main {
            pushGo() {
                push$
                -> $Sub
            }
            popBack() { }
            getState(): str {
                @@:("Main")
            }
        }
        $Sub {
            pushGo() { }
            popBack() { -> pop$ }
            getState(): str {
                @@:("Sub")
            }
        }
}

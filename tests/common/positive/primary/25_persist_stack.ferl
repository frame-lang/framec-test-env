@@target erlang
@@persist
@@system PersistStack {
    interface:
        pushGo()
        popBack()
        getState(): str
    machine:
        $Main {
            pushGo() {
                push$
                -> $Sub
            }
            popBack() { }
            getState(): str { return "Main" }
        }
        $Sub {
            pushGo() { }
            popBack() { -> pop$ }
            getState(): str { return "Sub" }
        }
}

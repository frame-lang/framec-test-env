@@[target("erlang")]
@@system Test {
    interface:
        ready(): boolean

    machine:
        $Active {
            $.timer: int = 100
            $.threshold: int = 50
            $.count: int = 1
            $.limit: int = 5
            ready(): boolean {
                @@:($.timer >= $.threshold andalso
                    $.count < $.limit)
            }
        }
}

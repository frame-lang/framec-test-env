@@[target("gdscript")]
extends SceneTree

@@system PushSelf {
    interface:
        enter_modal()
        ping(): int
        exit_modal()
        compute(): int

    machine:
        $Idle {
            enter_modal() { push$; -> $Modal }
            ping(): int { @@:(0) }
            compute(): int { @@:(99) }
        }
        $Modal {
            ping(): int { @@:(self.compute() + 1) }
            compute(): int { @@:(10) }
            exit_modal() { -> pop$ }
        }
    domain: n: int = 0
}

func _initialize():
    var s = PushSelf.new()
    if s.ping() != 0:
        print("FAIL idle"); quit(1); return
    s.enter_modal()
    if s.ping() != 11:
        print("FAIL modal " + str(s.ping())); quit(1); return
    s.exit_modal()
    if s.ping() != 0:
        print("FAIL back"); quit(1); return
    print("PASS: 72_push_self_call")
    quit(0)

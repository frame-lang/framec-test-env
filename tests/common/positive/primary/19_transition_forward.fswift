@@target swift

@@system EventForwardTest {
    interface:
        process()
        get_log(): string[]

    machine:
        $Idle {
            process() {
                self.log.append("idle:process:before")
                -> => $Working
                // This should NOT execute because -> => returns after dispatch
                self.log.append("idle:process:after")
            }

            get_log(): string[] {
                @@:(self.log)
                return;
            }
        }

        $Working {
            process() {
                self.log.append("working:process")
            }

            get_log(): string[] {
                @@:(self.log)
                return;
            }
        }
    domain:
        log: string[] = []
}

// main
    print("=== Test 19: Transition Forward (Swift) ===")
    let s = @@EventForwardTest()
    s.process()
    let log = s.get_log()
    print("Log: \(String(describing: log))")

    // After transition-forward:
    // - Idle logs "idle:process:before"
    // - Transition to Working
    // - Working handles process(), logs "working:process"
    // - Return prevents "idle:process:after"
    if !log.contains("idle:process:before") {
        fatalError("Expected 'idle:process:before' in log: \(log)")
    }
    if !log.contains("working:process") {
        fatalError("Expected 'working:process' in log: \(log)")
    }
    if log.contains("idle:process:after") {
        fatalError("Should NOT have 'idle:process:after' in log: \(log)")
    }

    print("PASS: Transition forward works correctly")

@@[target("swift")]

import Foundation

@@system HsmSelfCall {
    interface:
        drive_via_child(): int
        compute(): int
        get_trace(): str

    machine:
        $Child => $Parent {
            drive_via_child(): int {
                self.trace = self.trace + "child:before;"
                @@:self.compute()
                self.trace = self.trace + "child:after;"
                @@:(self.scratch)
            }
            compute(): int {
                self.trace = self.trace + "compute@child;"
                => $^
            }
            get_trace(): String {
                @@:(self.trace)
            }
        }

        $Parent {
            compute(): int {
                self.trace = self.trace + "compute@parent;"
                self.scratch = 42
                @@:(42)
            }
        }
    domain:
        trace : String = ""
        scratch : int = 0
}

print("=== Test 63: HSM cascade × @@:self (Swift) ===")
let s = HsmSelfCall()
let r = s.drive_via_child()
let trace = s.get_trace()
print("1. drive_via_child returned \(r), trace=\(trace)")

let expected = "child:before;compute@child;compute@parent;child:after;"
if trace != expected { print("FAIL: trace=\(trace)"); exit(1) }
if r != 42 { print("FAIL: r=\(r)"); exit(1) }

print("PASS: 63_hsm_self_call")

@@[target("swift")]

@@[persist]

import Foundation

@@system PFloat {
    operations:
        @@[save]
        saveState(): String {}

        @@[load]
        restoreState(data: String) {}

    interface:
        configure(rate: double)
        get_rate(): double

    machine:
        $Idle {
            configure(rate: Double) {
                -> $Active(rate)
            }
            get_rate(): Double {
                @@:(0.0)
            }
        }

        $Active(rate: Double) {
            get_rate(): Double {
                @@:(rate)
            }
        }
    domain:
        n : int = 0
}

let s = PFloat()
s.configure(3.14159)
let snap = s.saveState()
let s2 = PFloat()

s2.restoreState(snap)
let r = s2.get_rate()
if abs(r - 3.14159) > 1e-9 { print("FAIL \(r)"); exit(1) }
print("PASS: 69_persist_float_state_arg, rate=\(r)")

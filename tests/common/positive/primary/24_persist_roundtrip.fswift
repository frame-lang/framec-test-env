@@target swift

import Foundation

@@[persist]
@@system PersistRoundtrip {
    interface:
        go_active()
        go_idle()
        get_state(): string
        set_counter(n: number)
        get_counter(): number
        add_history(msg: string)
        get_history(): string[]

    machine:
        $Idle {
            go_active() {
                self.history.append("idle->active")
                -> $Active
            }

            go_idle() {
                // already idle
            }

            get_state(): string {
                @@:("idle")
                return;
            }

            set_counter(n: number) {
                self.counter = n
            }

            get_counter(): number {
                @@:(self.counter)
                return;
            }

            add_history(msg: string) {
                self.history.append("idle:" + msg)
            }

            get_history(): string[] {
                @@:(self.history)
                return;
            }
        }

        $Active {
            go_active() {
                // already active
            }

            go_idle() {
                self.history.append("active->idle")
                -> $Idle
            }

            get_state(): string {
                @@:("active")
                return;
            }

            set_counter(n: number) {
                self.counter = n * 2
            }

            get_counter(): number {
                @@:(self.counter)
                return;
            }

            add_history(msg: string) {
                self.history.append("active:" + msg)
            }

            get_history(): string[] {
                @@:(self.history)
                return;
            }
        }
    domain:
        counter: number = 0
        history: string[] = []
        mode: string = "normal"
}

// main
    print("=== Test 24: Persist Roundtrip (Swift) ===")

    // Test 1: Create system and build up state
    let s1 = @@PersistRoundtrip()
    s1.set_counter(5)
    s1.add_history("start")
    s1.go_active()
    s1.set_counter(3)  // Should be 6 in Active (doubled)
    s1.add_history("work")

    if s1.get_state() != "active" {
        fatalError("Expected active, got \(s1.get_state())")
    }
    if s1.get_counter() != 6 {
        fatalError("Expected 6, got \(s1.get_counter())")
    }
    print("1. State before save: state=\(s1.get_state()), counter=\(s1.get_counter())")
    print("   History: \(String(describing: s1.get_history()))")

    // Test 2: Save state
    let json = s1.saveState()
    let data = try! JSONSerialization.jsonObject(with: json.data(using: .utf8)!) as! [String: Any]
    print("2. Saved data keys: \(Array(data.keys))")
    let compartment = data["_compartment"] as! [String: Any]
    if (compartment["state"] as! String) != "Active" {
        fatalError("Expected Active state in save data")
    }
    if (data["counter"] as! Int) != 6 {
        fatalError("Expected counter=6 in save data")
    }

    // Test 3: Restore to new instance
    let s2 = PersistRoundtrip.restoreState(json)

    if s2.get_state() != "active" {
        fatalError("Expected active, got \(s2.get_state())")
    }
    if s2.get_counter() != 6 {
        fatalError("Expected 6, got \(s2.get_counter())")
    }
    print("3. Restored state: state=\(s2.get_state()), counter=\(s2.get_counter())")

    // Test 4: State machine continues to work after restore
    s2.set_counter(2)  // Should be 4 in Active (doubled)
    if s2.get_counter() != 4 {
        fatalError("Expected 4, got \(s2.get_counter())")
    }
    print("4. Counter after set_counter(2): \(s2.get_counter())")

    // Test 5: Verify history was preserved
    if String(describing: s2.get_history()) != String(describing: s1.get_history()) {
        fatalError("History mismatch: \(String(describing: s2.get_history())) vs \(String(describing: s1.get_history()))")
    }
    print("5. History preserved: \(String(describing: s2.get_history()))")

    // Test 6: Transitions work after restore
    s2.go_idle()
    if s2.get_state() != "idle" {
        fatalError("Expected idle after go_idle")
    }
    s2.set_counter(10)  // Not doubled in Idle
    if s2.get_counter() != 10 {
        fatalError("Expected 10, got \(s2.get_counter())")
    }
    print("6. After go_idle: state=\(s2.get_state()), counter=\(s2.get_counter())")

    print("PASS: Persist roundtrip works correctly")

@@[target("kotlin")]

@@[persist(String)]
@@[save(save_state)]
@@[load(restore_state)]
@@system PersistDict {
    interface:
        configure(m: Map<String, Int>)
        get_v(key: String): Int

    machine:
        $Idle {
            configure(m: Map<String, Int>) { -> $Active(m) }
            get_v(key: String): Int { @@:(-1) }
        }
        $Active(m: Map<String, Int>) {
            configure(m: Map<String, Int>) { -> $Active(m) }
            get_v(key: String): Int { @@:((m[key] as? Number)?.toInt() ?: -1) }
        }
    domain:
        n : Int = 0
}

fun main() {
    val s1 = PersistDict()
    s1.configure(mapOf("a" to 10, "b" to 20))
    if (s1.get_v("a") != 10) { println("FAIL pre"); kotlin.system.exitProcess(1) }
    val snap = s1.save_state()
    val s2 = PersistDict()

    s2.restore_state(snap)
    if (s2.get_v("a") != 10) { println("FAIL post a got ${s2.get_v("a")}"); kotlin.system.exitProcess(1) }
    if (s2.get_v("b") != 20) { println("FAIL post b got ${s2.get_v("b")}"); kotlin.system.exitProcess(1) }
    println("PASS: 77_persist_dict_state_arg")
}

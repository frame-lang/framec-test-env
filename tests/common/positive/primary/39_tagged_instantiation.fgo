@@target go

package main

import "fmt"
import "os"

@@system Calculator {
    interface:
        Add(a: int, b: int): int
        GetResult(): int

    machine:
        $Ready {
            Add(a: int, b: int): int {
                s.result = a + b
                @@:(s.result)
                return;
            }

            GetResult(): int {
                @@:(s.result)
                return;
            }
        }
    domain:
        result int
}

@@system Counter {
    interface:
        Increment()
        GetCount(): int

    machine:
        $Active {
            Increment() {
                s.count = s.count + 1
            }

            GetCount(): int {
                @@:(s.count)
                return;
            }
        }
    domain:
        count int
}

func main() {
	fmt.Println("=== Test 39: Tagged System Instantiation ===")

	// Tagged instantiation - validated at transpile time
	calc := @@Calculator()
	counter := @@Counter()

	// Test Calculator
	result := calc.Add(3, 4)
	if result != 7 {
		fmt.Printf("FAIL: Expected 7, got %d\n", result)
		os.Exit(1)
	}
	fmt.Printf("Calculator.Add(3, 4) = %d\n", result)

	result = calc.GetResult()
	if result != 7 {
		fmt.Printf("FAIL: Expected 7, got %d\n", result)
		os.Exit(1)
	}
	fmt.Printf("Calculator.GetResult() = %d\n", result)

	// Test Counter
	counter.Increment()
	counter.Increment()
	counter.Increment()
	count := counter.GetCount()
	if count != 3 {
		fmt.Printf("FAIL: Expected 3, got %d\n", count)
		os.Exit(1)
	}
	fmt.Printf("Counter after 3 increments: %d\n", count)

	fmt.Println("PASS: Tagged instantiation works correctly")
}

@@[target("rust")]

@@[persist(String)]
@@[save(save_state)]
@@[load(restore_state)]
@@system L5 {
    interface:
        bump()
        value(): i32
    machine:
        $S { bump() { self.n = self.n + 1; } value(): i32 { @@:(self.n) } }
    domain: n: i32 = 0
}@@[persist(String)]
@@[save(save_state)]
@@[load(restore_state)]


@@system L4 {
    interface:
        bump()
        value(): i32
    machine:
        $S {
            bump() { self.n = self.n + 1; self.child.bump(); }
            value(): i32 { @@:(self.n + self.child.value()) }
        }
    domain:
        n: i32 = 0
        child: L5 = @@L5()
}@@[persist(String)]
@@[save(save_state)]
@@[load(restore_state)]


@@system L3 {
    interface:
        bump()
        value(): i32
    machine:
        $S {
            bump() { self.n = self.n + 1; self.child.bump(); }
            value(): i32 { @@:(self.n + self.child.value()) }
        }
    domain:
        n: i32 = 0
        child: L4 = @@L4()
}@@[persist(String)]
@@[save(save_state)]
@@[load(restore_state)]


@@system L2 {
    interface:
        bump()
        value(): i32
    machine:
        $S {
            bump() { self.n = self.n + 1; self.child.bump(); }
            value(): i32 { @@:(self.n + self.child.value()) }
        }
    domain:
        n: i32 = 0
        child: L3 = @@L3()
}@@[persist(String)]
@@[save(save_state)]
@@[load(restore_state)]


@@[main]
@@system L1 {
    interface:
        bump()
        value(): i32
    machine:
        $S {
            bump() { self.n = self.n + 1; self.child.bump(); }
            value(): i32 { @@:(self.n + self.child.value()) }
        }
    domain:
        n: i32 = 0
        child: L2 = @@L2()
}

fn main() {
    let mut a = @@L1();
    a.bump(); a.bump(); a.bump();
    let pre = a.value();
    assert_eq!(pre, 15, "FAIL pre");
    let snap = a.save_state();
    let mut b = @@L1();

    b.restore_state(snap.clone());
    let post = b.value();
    assert_eq!(post, 15, "FAIL post");
    b.bump();
    let after = b.value();
    assert_eq!(after, 20, "FAIL after");
    println!("PASS: 83_persist_5deep");
}

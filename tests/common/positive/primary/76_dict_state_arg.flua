@@target lua

@@system DictStateArg {
    interface:
        configure(m: table)
        get_v(key: String): int
        size(): int

    machine:
        $Idle {
            configure(m: table) { -> $Active(m) }
            get_v(key: String): int { @@:(-1) }
            size(): int { @@:(0) }
        }
        $Active(m: table) {
            configure(m: table) { -> $Active(m) }
            get_v(key: String): int { @@:(m[key] or -1) }
            size(): int { local __c = 0; for _ in pairs(m) do __c = __c + 1 end; @@:(__c) }
        }
    domain:
        n: int = 0
}

local s = DictStateArg:new()
if s:get_v("a") ~= -1 then print("FAIL idle"); os.exit(1) end
if s:size() ~= 0 then print("FAIL idle size"); os.exit(1) end
s:configure({a = 10, b = 20})
if s:get_v("a") ~= 10 then print("FAIL a"); os.exit(1) end
if s:get_v("b") ~= 20 then print("FAIL b"); os.exit(1) end
if s:size() ~= 2 then print("FAIL size"); os.exit(1) end
s:configure({x = 99})
if s:get_v("x") ~= 99 then print("FAIL x"); os.exit(1) end
if s:size() ~= 1 then print("FAIL size2"); os.exit(1) end
print("PASS: 76_dict_state_arg")

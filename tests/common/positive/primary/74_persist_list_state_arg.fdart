@@[target("dart")]

import 'dart:io';
import 'dart:convert';

@@[persist(String)]
@@[save(saveState)]
@@[load(restoreState)]
@@system PersistList {
    interface:
        configure(items: List<int>)
        first_item(): int
        size(): int

    machine:
        $Idle {
            configure(items: List<int>) {
                -> $Active(items)
            }
            first_item(): int { @@:(-1) }
            size(): int { @@:(0) }
        }
        $Active(items: List<int>) {
            configure(items: List<int>) {
                -> $Active(items)
            }
            first_item(): int { @@:(items[0]) }
            size(): int { @@:(items.length) }
        }
    domain:
        n: int = 0
}

void main() {
    var s1 = @@PersistList();
    s1.configure([10, 20, 30]);
    if (s1.first_item() != 10) { print("FAIL pre"); return; }
    var snap = s1.saveState();

    final s2 = @@PersistList();


    s2.restoreState(snap);
    if (s2.first_item() != 10) { print("FAIL restored first_item"); return; }
    if (s2.size() != 3) { print("FAIL restored size"); return; }
    print("PASS: 74_persist_list_state_arg");
}

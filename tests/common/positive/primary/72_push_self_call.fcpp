@@[target("cpp_17")]

#include <iostream>

@@system PushSelf {
    interface:
        enter_modal()
        ping(): int
        exit_modal()
        compute(): int

    machine:
        $Idle {
            enter_modal() { push$; -> $Modal }
            ping(): int { @@:(0) }
            compute(): int { @@:(99) }
        }
        $Modal {
            ping(): int { @@:(this->compute() + 1) }
            compute(): int { @@:(10) }
            exit_modal() { -> pop$ }
        }
    domain: n : int = 0
}

int main() {
    PushSelf s;
    if (s.ping() != 0) { std::cout << "FAIL idle" << std::endl; return 1; }
    s.enter_modal();
    int r = s.ping();
    if (r != 11) { std::cout << "FAIL modal " << r << std::endl; return 1; }
    s.exit_modal();
    if (s.ping() != 0) { std::cout << "FAIL back" << std::endl; return 1; }
    std::cout << "PASS: 72_push_self_call" << std::endl;
    return 0;
}

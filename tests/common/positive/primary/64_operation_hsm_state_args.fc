@@[target("c")]

#include <stdio.h>
#include <stdlib.h>
#include <string.h>

@@system OpHsmStateArgs {
    operations:
        add_offset(x: int, off: int): int {
            return x + off;
        }

    interface:
        enter_active(t: int)
        classify(v: int): int

    machine:
        $Idle {
            enter_active(t: int) {
                -> $Active(t)
            }
            classify(v: int): int {
                @@:(-1)
            }
        }

        $Active => $Frame(threshold: int) {
            enter_active(t: int) {
                -> $Active(t)
            }
            classify(v: int): int {
                int r = OpHsmStateArgs_add_offset(self, v, threshold);
                @@:(r)
            }
        }

        $Frame {
        }
    domain:
        n : int = 0
}

int main(void) {
    printf("=== Test 64: Operations × HSM × state-args (C) ===\n");
    OpHsmStateArgs* s = OpHsmStateArgs_new();

    int pre = OpHsmStateArgs_classify(s, 5);
    if (pre != -1) { printf("FAIL: pre %d\n", pre); return 1; }
    printf("1. Idle classify(5) = %d\n", pre);

    OpHsmStateArgs_enter_active(s, 10);
    int r = OpHsmStateArgs_classify(s, 5);
    if (r != 15) { printf("FAIL: r %d\n", r); return 1; }
    printf("2. classify(5) with threshold=10 -> %d\n", r);

    int r2 = OpHsmStateArgs_classify(s, 7);
    if (r2 != 17) { printf("FAIL: r2 %d\n", r2); return 1; }
    printf("3. classify(7) with threshold=10 -> %d\n", r2);

    OpHsmStateArgs_enter_active(s, 100);
    int r3 = OpHsmStateArgs_classify(s, 5);
    if (r3 != 105) { printf("FAIL: r3 %d\n", r3); return 1; }
    printf("4. classify(5) with threshold=100 -> %d\n", r3);

    printf("PASS: 64_operation_hsm_state_args\n");
    OpHsmStateArgs_destroy(s);
    return 0;
}

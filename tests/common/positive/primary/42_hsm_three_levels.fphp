@@[target("php")]

@@system HSMThreeLevels {
    interface:
        handle_at_grandchild()
        forward_to_child()
        forward_to_parent()
        forward_through_all()
        get_log(): list

    machine:
        $Grandchild => $Child {
            $.grandchild_var: int = 1

            $>() {
                // RFC-0019: forward $> up the chain so $Child / $Parent
                // state-var initializers run.
                => $^
            }

            handle_at_grandchild() {
                $val = $.grandchild_var;
                $this->log[] = "Grandchild:handled(var={$val})";
            }

            forward_to_child() {
                $this->log[] = "Grandchild:forward_to_child";
                => $^
            }

            forward_to_parent() {
                $this->log[] = "Grandchild:forward_to_parent";
                => $^
            }

            forward_through_all() {
                $this->log[] = "Grandchild:forward_through_all";
                => $^
            }

            get_log(): list {
                @@:($this->log)
                return;
            }
        }

        $Child => $Parent {
            $.child_var: int = 10

            $>() {
                // RFC-0019: forward $> to $Parent so its state-var
                // initializer runs.
                => $^
            }

            forward_to_child() {
                $val = $.child_var;
                $this->log[] = "Child:handled(var={$val})";
            }

            forward_to_parent() {
                $val = $.child_var;
                $this->log[] = "Child:forward_to_parent(var={$val})";
                => $^
            }

            forward_through_all() {
                $val = $.child_var;
                $this->log[] = "Child:forward_through_all(var={$val})";
                => $^
            }

            get_log(): list {
                @@:($this->log)
                return;
            }
        }

        $Parent {
            $.parent_var: int = 100

            forward_to_parent() {
                $val = $.parent_var;
                $this->log[] = "Parent:handled(var={$val})";
            }

            forward_through_all() {
                $val = $.parent_var;
                $this->log[] = "Parent:forward_through_all(var={$val})";
            }

            get_log(): list {
                @@:($this->log)
                return;
            }
        }
    domain:
        log = []
}

echo "=== Test 42: HSM Three-Level Hierarchy ===" . "\n";
$s = @@HSMThreeLevels();

echo "TC1.2.1: Three-level hierarchy compiles - PASS" . "\n";

$s->handle_at_grandchild();
$log = $s->get_log();
if (!in_array("Grandchild:handled(var=1)", $log)) { echo "FAIL: Expected Grandchild handler\n"; exit(1); }
echo "TC1.2.2: Grandchild handles locally - PASS" . "\n";

$s->forward_to_child();
$log = $s->get_log();
if (!in_array("Grandchild:forward_to_child", $log)) { echo "FAIL: Expected Grandchild forward\n"; exit(1); }
if (!in_array("Child:handled(var=10)", $log)) { echo "FAIL: Expected Child handler\n"; exit(1); }
echo "TC1.2.3: Forward grandchild->child - PASS" . "\n";

$s->forward_to_parent();
$log = $s->get_log();
if (!in_array("Grandchild:forward_to_parent", $log)) { echo "FAIL\n"; exit(1); }
if (!in_array("Child:forward_to_parent(var=10)", $log)) { echo "FAIL\n"; exit(1); }
if (!in_array("Parent:handled(var=100)", $log)) { echo "FAIL\n"; exit(1); }
echo "TC1.2.4: Forward grandchild->child->parent - PASS" . "\n";

$s->forward_through_all();
$log = $s->get_log();
if (!in_array("Grandchild:forward_through_all", $log)) { echo "FAIL\n"; exit(1); }
if (!in_array("Child:forward_through_all(var=10)", $log)) { echo "FAIL\n"; exit(1); }
if (!in_array("Parent:forward_through_all(var=100)", $log)) { echo "FAIL\n"; exit(1); }
echo "TC1.2.5: Full chain forward - PASS" . "\n";

echo "PASS: HSM three-level hierarchy works correctly" . "\n";

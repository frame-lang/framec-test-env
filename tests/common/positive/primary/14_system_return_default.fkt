@@target kotlin

import kotlin.system.exitProcess

// NOTE: Default return value syntax (method(): type = default) not yet implemented.
// This test validates behavior when handler does not set @@:return.

@@system SystemReturnDefaultTest {
    interface:
        handler_sets_value(): String
        handler_no_return(): String
        get_count(): Int

    machine:
        $Start {
            $.count: Int = 0

            handler_sets_value(): String {
                return "set_by_handler"
            }

            handler_no_return(): String {
                // Does not set return - should return null
                $.count = $.count + 1
            }

            get_count(): Int {
                return $.count
            }
        }
}

fun main() {
    println("=== Test 14: System Return Default Behavior ===")
    val s = SystemReturnDefaultTest()

    // Test 1: Handler explicitly sets return value
    val result1 = s.handler_sets_value() as String
    if (result1 != "set_by_handler") {
        throw RuntimeException("Expected 'set_by_handler', got '$result1'")
    }
    println("1. handler_sets_value() = '$result1'")

    // Test 2: Handler does NOT set return - should return null
    val result2 = s.handler_no_return()
    if (result2 != null) {
        throw RuntimeException("Expected null, got '$result2'")
    }
    println("2. handler_no_return() = $result2")

    // Test 3: Verify handler was called (side effect check)
    val count = s.get_count() as Int
    if (count != 1) {
        throw RuntimeException("Expected count=1, got $count")
    }
    println("3. Handler was called, count = $count")

    // Test 4: Call again to verify idempotence
    val result4 = s.handler_no_return()
    if (result4 != null) {
        throw RuntimeException("Expected null again, got '$result4'")
    }
    val count2 = s.get_count() as Int
    if (count2 != 2) {
        throw RuntimeException("Expected count=2, got $count2")
    }
    println("4. Second call: result=$result4, count=$count2")

    println("PASS: System return default behavior works correctly")
}

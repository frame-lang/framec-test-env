@@target erlang
@@system FloatStateArg {
    interface:
        configure(rate: float)
        scale(v: float): float
    machine:
        $Idle {
            configure(rate: float) {
                -> $Active(rate)
            }
            scale(v: float): float {
                @@:(V)
            }
        }
        $Active => $Frame(rate: float) {
            configure(rate: float) {
                -> $Active(rate)
            }
            scale(v: float): float {
                => $^
            }
        }
        $Frame {
            scale(v: float): float {
                @@:(V * Rate)
            }
        }
    domain:
        n = 0
}

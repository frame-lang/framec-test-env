@@[target("go")]

package main

import (
	"fmt"
	"os"
)

@@system StrStateArg {
    interface:
        Configure(label: str)
        Identify(): str

    machine:
        $Idle {
            Configure(label: string) {
                -> $Active(label)
            }
            Identify(): string {
                @@:("anonymous")
                return;
            }
        }

        $Active => $Frame(label: string) {
            Configure(label: string) {
                -> $Active(label)
            }
            Identify(): string {
                => $^
            }
        }

        $Frame {
            Identify(): string {
                @@:(label)
                return;
            }
        }
    domain:
        n: int = 0
}

func main() {
    s := NewStrStateArg()
    if s.Identify() != "anonymous" { fmt.Println("FAIL idle"); os.Exit(1) }
    s.Configure("alice")
    if s.Identify() != "alice" { fmt.Println("FAIL alice"); os.Exit(1) }
    s.Configure("bob")
    if s.Identify() != "bob" { fmt.Println("FAIL bob"); os.Exit(1) }
    fmt.Println("PASS: 66_hsm_str_state_args")
}

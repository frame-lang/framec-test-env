@@[target("go")]

package main

import (
	"fmt"
	"os"
)

@@system HsmIfStateArgs {
    interface:
        EnterActive(t: int)
        Classify(v: int): int

    machine:
        $Idle {
            EnterActive(t: int) {
                -> $Active(t)
            }
            Classify(v: int): int {
                @@:(-1)
                return;
            }
        }

        $Active => $Frame(threshold: int) {
            EnterActive(t: int) {
                -> $Active(t)
            }
            Classify(v: int): int {
                if v > threshold {
                    @@:(1)
                    return;
                } else {
                    @@:(0)
                    return;
                }
            }
        }

        $Frame {
        }
    domain:
        n: int = 0
}

func main() {
    fmt.Println("=== Test 62: HSM × if × state-args (Go) ===")
    s := NewHsmIfStateArgs()

    pre := s.Classify(5)
    if pre != -1 { fmt.Printf("FAIL: pre %d\n", pre); os.Exit(1) }
    fmt.Printf("1. Idle classify(5) = %d\n", pre)

    s.EnterActive(10)
    under := s.Classify(5)
    if under != 0 { fmt.Printf("FAIL: under %d\n", under); os.Exit(1) }
    fmt.Printf("2. classify(5) with threshold=10 → %d\n", under)

    over := s.Classify(15)
    if over != 1 { fmt.Printf("FAIL: over %d\n", over); os.Exit(1) }
    fmt.Printf("3. classify(15) with threshold=10 → %d\n", over)

    eq := s.Classify(10)
    if eq != 0 { fmt.Printf("FAIL: eq %d\n", eq); os.Exit(1) }
    fmt.Printf("4. classify(10) with threshold=10 → %d\n", eq)

    s.EnterActive(50)
    newUnder := s.Classify(15)
    if newUnder != 0 { fmt.Printf("FAIL: newUnder %d\n", newUnder); os.Exit(1) }
    fmt.Printf("5. classify(15) with threshold=50 → %d\n", newUnder)

    fmt.Println("PASS: 62_hsm_if_state_args")
}

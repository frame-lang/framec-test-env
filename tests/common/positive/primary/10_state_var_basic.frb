@@[target("ruby")]

@@system StateVarBasic {
    interface:
        increment(): int
        get_count(): int
        reset()

    machine:
        $Counter {
            $.count: int = 0

            increment(): int {
                $.count = $.count + 1
                @@:($.count)
                return
            }

            get_count(): int {
                @@:($.count)
                return
            }

            reset() {
                $.count = 0
            }
        }
}

puts("=== Test 10: State Variable Basic ===")
s = @@StateVarBasic()

# Initial value should be 0
raise "Expected 0, got #{s.get_count()}" unless s.get_count() == 0
puts("Initial count: #{s.get_count()}")

# Increment should return new value
result = s.increment()
raise "Expected 1 after first increment, got #{result}" unless result == 1
puts("After first increment: #{result}")

# Second increment
result = s.increment()
raise "Expected 2 after second increment, got #{result}" unless result == 2
puts("After second increment: #{result}")

# Reset should set back to 0
s.reset()
raise "Expected 0 after reset, got #{s.get_count()}" unless s.get_count() == 0
puts("After reset: #{s.get_count()}")

puts("PASS: State variable basic operations work correctly")

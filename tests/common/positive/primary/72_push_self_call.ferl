@@[target("erlang")]
@@system PushSelf {
    interface:
        enterModal()
        ping(): int
        exitModal()
        compute(): int
    machine:
        $Idle {
            enterModal() { push$; -> $Modal }
            ping(): int { @@:(0) }
            compute(): int { @@:(99) }
        }
        $Modal {
            ping(): int { @@:(self.compute() + 1) }
            compute(): int { @@:(10) }
            exitModal() { -> pop$ }
        }
    domain: n = 0
}

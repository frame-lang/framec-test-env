@@[target("swift")]

// Test 46: HSM Enter Cascade — Parent has $>, Child does not
//
// Tests the HSM enter cascade per docs/frame_runtime_introduction.md
// Step 21+. When entering an HSM child, the kernel fires $> on every
// layer of the new chain top-down (parent first, child last). The child
// may have no $> handler — the cascade simply skips that layer and
// continues.

@@system HSMEnterParentOnly {
    interface:
        go_to_child()
        go_to_parent()
        get_log(): string[]
        get_state(): str

    machine:
        $Start {
            go_to_child() { -> $Child }
            go_to_parent() { -> $Parent }
            get_log(): list { @@:(self.log) }
            get_state(): str { @@:("Start") }
        }

        $Child => $Parent {
            go_to_parent() { -> $Parent }
            get_log(): list { @@:(self.log) }
            get_state(): str { @@:("Child") }
        }

        $Parent {
            $>() { self.log.append("Parent:enter") }
            go_to_child() { -> $Child }
            get_log(): list { @@:(self.log) }
            get_state(): str { @@:("Parent") }
        }
    domain:
        log: string[] = []
}

// main
    print("=== Test 46: HSM Enter Cascade — Parent only ===")
    let s = @@HSMEnterParentOnly()

    s.go_to_child()
    if s.get_state() != "Child" { fatalError("Expected Child") }
    var log = s.get_log()
    if !log.contains("Parent:enter") { fatalError("Expected Parent:enter on cascade") }
    print("TC1: Parent's $> fires on cascade entry to Child - PASS")

    s.go_to_parent()
    log = s.get_log()
    if log.filter({ $0 == "Parent:enter" }).count != 2 { fatalError("Expected 2 Parent:enter") }
    print("TC2: Parent's $> fires again when transitioning directly to Parent - PASS")

    s.go_to_child()
    log = s.get_log()
    if log.filter({ $0 == "Parent:enter" }).count != 3 { fatalError("Expected 3 Parent:enter") }
    print("TC3: Re-entering Child cascades through Parent again - PASS")

    print("PASS: HSM enter cascade fires Parent's $> on child entry")

@@target ruby

# Test: const domain field initialized from system param.

@@system Sensor(threshold: int = 100) {
    interface:
        read(): int
        calibrate(offset: int)
        get_threshold(): int

    machine:
        $Active {
            read(): int {
                @@:(@value + @offset)
                return
            }
            calibrate(offset: int) {
                @offset = offset
                return
            }
            get_threshold(): int {
                @@:(@threshold)
                return
            }
        }

    domain:
        const threshold = threshold
        value = 50
        offset = 0
}

failures = 0

# Test 1: system param override
s = @@Sensor(200)
t = s.get_threshold
if t != 200
    puts "FAIL test 1: expected 200, got #{t}"
    failures += 1
end

# Test 2: read returns value + offset
v = s.read
if v != 50
    puts "FAIL test 2: expected 50, got #{v}"
    failures += 1
end

# Test 3: calibrate changes offset
s.calibrate(10)
v = s.read
if v != 60
    puts "FAIL test 3: expected 60, got #{v}"
    failures += 1
end

# Test 4: default system param
s2 = @@Sensor()
t2 = s2.get_threshold
if t2 != 100
    puts "FAIL test 4: expected 100, got #{t2}"
    failures += 1
end

if failures > 0
    puts "FAIL: const_domain (#{failures} failures)"
    exit(1)
end
puts "PASS: const_domain"

@@[target("java")]

@@system HsmIfStateArgs {
    interface:
        enter_active(t: int)
        classify(v: int): int

    machine:
        $Idle {
            enter_active(t: int) {
                -> $Active(t)
            }
            classify(v: int): int {
                @@:(-1)
            }
        }

        $Active => $Frame(threshold: int) {
            enter_active(t: int) {
                -> $Active(t)
            }
            classify(v: int): int {
                if (v > threshold) {
                    @@:(1)
                } else {
                    @@:(0)
                }
            }
        }

        $Frame {
        }
    domain:
        n : int = 0
}

class Main {
    public static void main(String[] args) {
        System.out.println("=== Test 62: HSM × if × state-args (Java) ===");
        var s = new HsmIfStateArgs();

        int pre = s.classify(5);
        if (pre != -1) { System.out.println("FAIL: pre " + pre); System.exit(1); }
        System.out.println("1. Idle classify(5) = " + pre);

        s.enter_active(10);
        int under = s.classify(5);
        if (under != 0) { System.out.println("FAIL: under " + under); System.exit(1); }
        System.out.println("2. classify(5) with threshold=10 → " + under);

        int over = s.classify(15);
        if (over != 1) { System.out.println("FAIL: over " + over); System.exit(1); }
        System.out.println("3. classify(15) with threshold=10 → " + over);

        int eq = s.classify(10);
        if (eq != 0) { System.out.println("FAIL: eq " + eq); System.exit(1); }
        System.out.println("4. classify(10) with threshold=10 → " + eq);

        s.enter_active(50);
        int newUnder = s.classify(15);
        if (newUnder != 0) { System.out.println("FAIL: newUnder " + newUnder); System.exit(1); }
        System.out.println("5. classify(15) with threshold=50 → " + newUnder);

        System.out.println("PASS: 62_hsm_if_state_args");
    }
}

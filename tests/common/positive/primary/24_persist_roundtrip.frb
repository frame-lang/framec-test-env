@@[target("ruby")]

require 'json'

@@[persist]
@@system PersistRoundtrip {
    operations:
        @@[save]
        save_state(): String {}

        @@[load]
        restore_state(data: String) {}

    interface:
        go_active()
        go_idle()
        get_state(): str
        set_counter(n: int)
        get_counter(): int
        add_history(msg: str)

    machine:
        $Idle {
            go_active() {
                self.history.push("idle->active")
                -> $Active
            }

            go_idle() {
                # pass  # already idle
            }

            get_state(): str {
                @@:("idle")
                return
            }

            set_counter(n: int) {
                self.counter = n
            }

            get_counter(): int {
                @@:(self.counter)
                return
            }

            add_history(msg: str) {
                self.history.push("idle:" + msg)
            }
        }

        $Active {
            go_active() {
                # pass  # already active
            }

            go_idle() {
                self.history.push("active->idle")
                -> $Idle
            }

            get_state(): str {
                @@:("active")
                return
            }

            set_counter(n: int) {
                self.counter = n * 2
            }

            get_counter(): int {
                @@:(self.counter)
                return
            }

            add_history(msg: str) {
                self.history.push("active:" + msg)
            }
        }
    domain:
        counter: int = 0
        history: list = []
        mode: str = "normal"
}

puts("=== Test 24: Persist Roundtrip ===")

# Test 1: Create system and build up state
s1 = PersistRoundtrip.new
s1.set_counter(5)
s1.add_history("start")
s1.go_active()
s1.set_counter(3)  # Should be 6 in Active (doubled)
s1.add_history("work")

raise "Expected active, got #{s1.get_state()}" unless s1.get_state() == "active"
raise "Expected 6, got #{s1.get_counter()}" unless s1.get_counter() == 6
puts("1. State before save: state=#{s1.get_state()}, counter=#{s1.get_counter()}")
puts("   History: #{s1.history}")

# Test 2: Save state
data = s1.save_state()
raise "Expected String, got #{data.class}" unless data.is_a?(String)
puts("2. Saved: #{data.length} bytes")

# Test 3: Restore to new instance
s2 = PersistRoundtrip.new
s2.restore_state(data)

# Verify restored state matches
raise "Expected active, got #{s2.get_state()}" unless s2.get_state() == "active"
raise "Expected 6, got #{s2.get_counter()}" unless s2.get_counter() == 6
puts("3. Restored state: state=#{s2.get_state()}, counter=#{s2.get_counter()}")

# Test 4: State machine continues to work after restore
s2.set_counter(2)  # Should be 4 in Active (doubled)
raise "Expected 4, got #{s2.get_counter()}" unless s2.get_counter() == 4
puts("4. Counter after set_counter(2): #{s2.get_counter()}")

# Test 5: Verify history was preserved
raise "History mismatch: #{s2.history} vs #{s1.history}" unless s2.history == s1.history
puts("5. History preserved: #{s2.history}")

# Test 6: Transitions work after restore
s2.go_idle()
raise "Expected idle after go_idle" unless s2.get_state() == "idle"
s2.set_counter(10)  # Not doubled in Idle
raise "Expected 10, got #{s2.get_counter()}" unless s2.get_counter() == 10
puts("6. After go_idle: state=#{s2.get_state()}, counter=#{s2.get_counter()}")

puts("PASS: Persist roundtrip works correctly")

@@target gdscript
extends SceneTree

@@system TransitionPopTest {
    interface:
        start()
        process()
        get_state(): String
        get_log(): list

    machine:
        $Idle {
            start() {
                self.log.append("idle:start:push")
                push$
                -> $Working
            }

            process() {
                self.log.append("idle:process")
            }

            get_state(): String {
                @@:("Idle")
                return
            }

            get_log(): list {
                @@:(self.log)
                return
            }
        }

        $Working {
            process() {
                self.log.append("working:process:before_pop")
                -> pop$
                # This should NOT execute because pop transitions away
                self.log.append("working:process:after_pop")
            }

            get_state(): String {
                @@:("Working")
                return
            }

            get_log(): list {
                @@:(self.log)
                return
            }
        }
    domain:
        log: list = []
}

func main():
    print("=== Test 20: Transition Pop ===")
    var s = @@TransitionPopTest()

    # Initial state should be Idle
    assert(s.get_state() == "Idle", "Expected 'Idle', got '" + str(s.get_state()) + "'")
    print("Initial state: " + str(s.get_state()))

    # start() pushes Idle, transitions to Working
    s.start()
    assert(s.get_state() == "Working", "Expected 'Working', got '" + str(s.get_state()) + "'")
    print("After start(): " + str(s.get_state()))

    # process() in Working does pop transition back to Idle
    s.process()
    assert(s.get_state() == "Idle", "Expected 'Idle' after pop, got '" + str(s.get_state()) + "'")
    print("After process() with pop: " + str(s.get_state()))

    var log = s.get_log()
    print("Log: " + str(log))

    # Verify log contents
    assert("idle:start:push" in log, "Expected 'idle:start:push' in log")
    assert("working:process:before_pop" in log, "Expected 'working:process:before_pop' in log")
    assert("working:process:after_pop" not in log, "Should NOT have 'working:process:after_pop' in log")

    print("PASS: Transition pop works correctly")

func _init():
    main()
    quit()

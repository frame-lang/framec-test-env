@@target swift

import Foundation

@@[persist]
@@system ListOfDict {
    interface:
        configure(rows: [[String: Int]])
        get_at(idx: Int, key: String): Int

    machine:
        $Idle {
            configure(rows: [[String: Int]]) { -> $Active(rows) }
            get_at(idx: Int, key: String): Int { @@:(-1) }
        }
        $Active(rows: [[String: Int]]) {
            configure(rows: [[String: Int]]) { -> $Active(rows) }
            get_at(idx: Int, key: String): Int {
                @@:(idx < rows.count ? (rows[idx][key] ?? -1) : -1)
            }
        }
    domain:
        n : Int = 0
}

let s1 = ListOfDict()
s1.configure([["x": 1, "y": 2], ["z": 3]])
if s1.get_at(0, "x") != 1 { print("FAIL pre 0.x"); exit(1) }
if s1.get_at(1, "z") != 3 { print("FAIL pre 1.z"); exit(1) }
let snap = s1.saveState()
let s2 = ListOfDict.restoreState(snap)
if s2.get_at(0, "x") != 1 { print("FAIL post 0.x"); exit(1) }
if s2.get_at(0, "y") != 2 { print("FAIL post 0.y"); exit(1) }
if s2.get_at(1, "z") != 3 { print("FAIL post 1.z"); exit(1) }
print("PASS: 80_list_of_dict_state_arg")

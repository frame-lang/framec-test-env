@@[target("ruby")]

@@system StateVarReentry {
    interface:
        increment(): int
        get_count(): int
        go_other()
        come_back()

    machine:
        $Counter {
            $.count: int = 0

            increment(): int {
                $.count = $.count + 1
                @@:($.count)
                return
            }

            get_count(): int {
                @@:($.count)
                return
            }

            go_other() {
                -> $Other
            }
        }

        $Other {
            come_back() {
                -> $Counter
            }

            increment(): int {
                @@:(-1)
                return
            }

            get_count(): int {
                @@:(-1)
                return
            }
        }
}

puts("=== Test 11: State Variable Reentry ===")
s = @@StateVarReentry()

# Increment a few times
s.increment()
s.increment()
count = s.get_count()
raise "Expected 2 after two increments, got #{count}" unless count == 2
puts("Count before leaving: #{count}")

# Leave the state
s.go_other()
puts("Transitioned to Other state")

# Come back - state var should be reinitialized to 0
s.come_back()
count = s.get_count()
raise "Expected 0 after re-entering Counter (state var reinit), got #{count}" unless count == 0
puts("Count after re-entering Counter: #{count}")

# Increment again to verify it works
result = s.increment()
raise "Expected 1 after increment, got #{result}" unless result == 1
puts("After increment: #{result}")

puts("PASS: State variables reinitialize on state reentry")

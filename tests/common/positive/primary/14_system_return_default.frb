@@[target("ruby")]

# NOTE: Default return value syntax (method(): type = default) not yet implemented.
# This test validates behavior when handler doesn't set @@:return.

@@system SystemReturnDefaultTest {
    interface:
        handler_sets_value(): str
        handler_no_return(): str
        get_count(): int

    machine:
        $Start {
            $.count: int = 0

            handler_sets_value(): str {
                @@:("set_by_handler")
                return
            }

            handler_no_return(): str {
                # Does not set return - should return nil
                $.count = $.count + 1
            }

            get_count(): int {
                @@:($.count)
                return
            }
        }
}

puts("=== Test 14: System Return Default Behavior ===")
s = @@SystemReturnDefaultTest()

# Test 1: Handler explicitly sets return value
result = s.handler_sets_value()
raise "Expected 'set_by_handler', got '#{result}'" unless result == "set_by_handler"
puts("1. handler_sets_value() = '#{result}'")

# Test 2: Handler does NOT set return - should return nil
result = s.handler_no_return()
raise "Expected nil, got '#{result}'" unless result == nil
puts("2. handler_no_return() = #{result}")

# Test 3: Verify handler was called (side effect check)
count = s.get_count()
raise "Expected count=1, got #{count}" unless count == 1
puts("3. Handler was called, count = #{count}")

# Test 4: Call again to verify idempotence
result = s.handler_no_return()
raise "Expected nil again, got '#{result}'" unless result == nil
count = s.get_count()
raise "Expected count=2, got #{count}" unless count == 2
puts("4. Second call: result=#{result}, count=#{count}")

puts("PASS: System return default behavior works correctly")

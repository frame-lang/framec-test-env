@@[target("cpp_17")]

// Test: @@:self.method() — reentrant interface call with transition guard
//
// Validates:
// 1. Basic self-call dispatch (calls own interface method through kernel)
// 2. Return value propagation from self-call
// 3. Transition guard (code after self-call that transitions is suppressed)

#include <iostream>
#include <string>
#include <cmath>
#include <cstdlib>

@@system SelfCallTest {
    interface:
        calibrate(): std::string
        reading(): double
        trigger_transition()
        check_after_transition(): std::string
        status(): std::string

    machine:
        $Active {
            calibrate(): std::string {
                double baseline = @@:self.reading();
                this->offset = baseline * -1.0;
                @@:(std::string("calibrated:offset=") + std::to_string((int)this->offset))
            }

            reading(): double {
                @@:(this->raw_value + this->offset)
            }

            trigger_transition() {
                -> $Done
            }

            check_after_transition(): std::string {
                this->trace = "before";
                @@:self.trigger_transition();
                // This line should NOT execute — transition guard suppresses it
                this->trace = "after";
                @@:(this->trace)
            }

            status(): std::string {
                @@:(std::string("active"))
            }
        }

        $Done {
            status(): std::string {
                @@:(std::string("done"))
            }
        }

    domain:
        raw_value: double = 42.0
        offset: double = 0.0
        trace: std::string = ""
}

int main() {
    auto s = @@SelfCallTest();

    // Test 1: Self-call returns correct value
    std::string result = s.calibrate();
    if (result != "calibrated:offset=-42") {
        std::cerr << "FAIL: Expected 'calibrated:offset=-42', got '" << result << "'" << std::endl;
        exit(1);
    }

    // Test 2: Self-call modified domain state correctly
    double r = s.reading();
    if (std::abs(r) > 1e-9) {
        std::cerr << "FAIL: Expected 0.0 after calibration, got " << r << std::endl;
        exit(1);
    }

    // Test 3: Transition guard — code after self-call that transitions is suppressed
    auto s2 = @@SelfCallTest();
    s2.check_after_transition();
    if (s2.trace != "before") {
        std::cerr << "FAIL: Expected 'before' (guard suppressed 'after'), got '" << s2.trace << "'" << std::endl;
        exit(1);
    }

    // Test 4: System transitioned to $Done
    std::string st = s2.status();
    if (st != "done") {
        std::cerr << "FAIL: Expected 'done' after transition, got '" << st << "'" << std::endl;
        exit(1);
    }

    std::cout << "PASS: self_call" << std::endl;
    return 0;
}

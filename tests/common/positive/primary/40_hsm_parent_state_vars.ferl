@@target erlang
@@system HSMParentVars {
    interface:
        childAction()
        parentAction()
        getParentCount(): int
        getLog(): str
    machine:
        $Child => $Parent {
            childAction() {
                self.log = self.log ++ ",child"
            }
            getLog(): str { return self.log }
        }
        $Parent {
            $.pcount: int = 0
            parentAction() {
                $.pcount = $.pcount + 1
                self.log = self.log ++ ",parent"
            }
            getParentCount(): int { return $.pcount }
            getLog(): str { return self.log }
        }
    domain:
        log = "init"
}

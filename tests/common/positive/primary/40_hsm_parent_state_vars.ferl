@@[target("erlang")]
@@system HSMParentVars {
    interface:
        childAction()
        parentAction()
        getParentCount(): int
        getLog(): str
    machine:
        $Child => $Parent {
            $>() {
                # RFC-0019: forward $> to $Parent so its state-var
                # initializer ($.pcount = 0) runs.
                => $^
            }
            childAction() {
                self.log = self.log ++ ",child"
            }
            getLog(): str {
                @@:(self.log)
            }
        }
        $Parent {
            $.pcount: int = 0
            parentAction() {
                $.pcount = $.pcount + 1
                self.log = self.log ++ ",parent"
            }
            getParentCount(): int {
                @@:($.pcount)
            }
            getLog(): str {
                @@:(self.log)
            }
        }
    domain:
        log = "init"
}

@@[target("rust")]

@@[persist(String)]
@@[save(save_op)]
@@[load(load_op)]
@@system Counter {
    interface:
        bump()
        get_n(): i32

    machine:
        $Active {
            bump() {
                self.n = self.n + 1;
            }
            get_n(): i32 { @@:(self.n) }
        }

    domain:
        n: i32 = 0
}

fn main() {
    let mut c1 = Counter::new();
    c1.bump();
    c1.bump();
    c1.bump();
    let data = c1.save_op();

    let mut c2 = Counter::new();
    c2.load_op(data);
    if c2.get_n() != 3 {
        println!("FAIL: expected 3, got {}", c2.get_n());
        return;
    }
    println!("PASS: 93_persist_save_load_contract");
}

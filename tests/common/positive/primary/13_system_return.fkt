@@[target("kotlin")]

import kotlin.system.exitProcess

@@system SystemReturnTest {
    interface:
        add(a: Int, b: Int): Int
        multiply(a: Int, b: Int): Int
        greet(name: String): String
        get_value(): Int

    machine:
        $Calculator {
            $.value: Int = 0

            add(a: Int, b: Int): Int {
                @@:(a + b)
                return;
            }

            multiply(a: Int, b: Int): Int {
                @@:(a * b)
            }

            greet(name: String): String {
                @@:("Hello, " + name + "!")
                return;
            }

            get_value(): Int {
                $.value = 42
                @@:($.value)
                return;
            }
        }
}

fun main() {
    println("=== Test 13: System Return ===")
    val calc = SystemReturnTest()

    // Test return sugar
    var result = calc.add(3, 5) as Int
    if (result != 8) {
        throw RuntimeException("Expected 8, got $result")
    }
    println("add(3, 5) = $result")

    result = calc.multiply(4, 7) as Int
    if (result != 28) {
        throw RuntimeException("Expected 28, got $result")
    }
    println("multiply(4, 7) = $result")

    // Test string return
    val greeting = calc.greet("World") as String
    if (greeting != "Hello, World!") {
        throw RuntimeException("Expected 'Hello, World!', got '$greeting'")
    }
    println("greet('World') = $greeting")

    // Test return with state variable
    val value = calc.get_value() as Int
    if (value != 42) {
        throw RuntimeException("Expected 42, got $value")
    }
    println("get_value() = $value")

    println("PASS: System return works correctly")
}

@@target swift

// Test 40: HSM Parent State Variables

@@system HSMParentStateVars {
    interface:
        get_child_count(): number
        get_parent_count(): number

    machine:
        $Child => $Parent {
            $.child_count: number = 0

            get_child_count(): number {
                @@:($.child_count)
                return;
            }

            get_parent_count(): number {
                => $^
            }
        }

        $Parent {
            $.parent_count: number = 100

            get_parent_count(): number {
                @@:($.parent_count)
                return;
            }
        }
}

// main
    print("=== Test 40: HSM Parent State Variables ===")
    let s = @@HSMParentStateVars()

    let childCount = s.get_child_count()
    if childCount != 0 {
        fatalError("Expected child_count=0, got \(childCount)")
    }
    print("Child count: \(childCount)")

    let parentCount = s.get_parent_count()
    if parentCount != 100 {
        fatalError("Expected parent_count=100, got \(parentCount)")
    }
    print("Parent count: \(parentCount)")

    print("PASS: HSM parent state variables work correctly")

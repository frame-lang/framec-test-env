@@[target("javascript")]

@@system PushSelf {
    interface:
        enter_modal()
        ping(): int
        exit_modal()
        compute(): int

    machine:
        $Idle {
            enter_modal() { push$; -> $Modal }
            ping(): number { @@:(0); return }
            compute(): number { @@:(99); return }
        }
        $Modal {
            ping(): number { @@:(this.compute() + 1); return }
            compute(): number { @@:(10); return }
            exit_modal() { -> pop$ }
        }
    domain: n: number = 0
}

const s = @@PushSelf();
if (s.ping() !== 0) { console.log("FAIL idle"); process.exit(1); }
s.enter_modal();
if (s.ping() !== 11) { console.log("FAIL modal " + s.ping()); process.exit(1); }
s.exit_modal();
if (s.ping() !== 0) { console.log("FAIL back"); process.exit(1); }
console.log("PASS: 72_push_self_call");

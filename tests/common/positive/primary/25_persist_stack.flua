@@target lua
@@persist
@@system PersistStack {
    interface:
        push_and_go()
        pop_back()
        get_state(): str
        get_depth(): int

    machine:
        $Start {
            push_and_go() {
                self.depth = self.depth + 1
                push$
                -> $Middle
            }

            pop_back() {
                -- empty -- nothing to pop
            
            }

            get_state(): str {
                @@:("start")
                return
            }

            get_depth(): int {
                @@:(self.depth)
                return
            }
        }

        $Middle {
            push_and_go() {
                self.depth = self.depth + 1
                push$
                -> $End
            }

            pop_back() {
                self.depth = self.depth - 1
                -> pop$
            }

            get_state(): str {
                @@:("middle")
                return
            }

            get_depth(): int {
                @@:(self.depth)
                return
            }
        }

        $End {
            push_and_go() {
                -- empty -- can't go further
            
            }

            pop_back() {
                self.depth = self.depth - 1
                -> pop$
            }

            get_state(): str {
                @@:("end")
                return
            }

            get_depth(): int {
                @@:(self.depth)
                return
            }
        }
    domain:
        depth: int = 0
}

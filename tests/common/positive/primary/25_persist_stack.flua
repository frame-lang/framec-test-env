@@target lua
@@persist
@@system PersistStack {
    interface:
        push_and_go()
        pop_back()
        get_state(): str
        get_depth(): int

    machine:
        $Start {
            push_and_go() {
                self.depth = self.depth + 1
                push$
                -> $Middle
            }

            pop_back() {
                pass  -- nothing to pop
            }

            get_state(): str {
                return "start"
            }

            get_depth(): int {
                return self.depth
            }
        }

        $Middle {
            push_and_go() {
                self.depth = self.depth + 1
                push$
                -> $End
            }

            pop_back() {
                self.depth = self.depth - 1
                -> pop$
            }

            get_state(): str {
                return "middle"
            }

            get_depth(): int {
                return self.depth
            }
        }

        $End {
            push_and_go() {
                pass  -- can't go further
            }

            pop_back() {
                self.depth = self.depth - 1
                -> pop$
            }

            get_state(): str {
                return "end"
            }

            get_depth(): int {
                return self.depth
            }
        }
    domain:
        depth: int = 0
}

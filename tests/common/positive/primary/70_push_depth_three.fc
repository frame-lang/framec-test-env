@@[target("c")]

#include <stdio.h>
#include <stdlib.h>
#include <string.h>

@@system PushDeep {
    interface:
        descend()
        ascend()
        get_depth(): int

    machine:
        $Idle {
            descend() {
                push$
                -> $Modal1
            }
            get_depth(): int {
                @@:(0)
            }
        }

        $Modal1 {
            descend() {
                push$
                -> $Modal2
            }
            ascend() {
                -> pop$
            }
            get_depth(): int {
                @@:(1)
            }
        }

        $Modal2 {
            descend() {
                push$
                -> $Modal3
            }
            ascend() {
                -> pop$
            }
            get_depth(): int {
                @@:(2)
            }
        }

        $Modal3 {
            ascend() {
                -> pop$
            }
            get_depth(): int {
                @@:(3)
            }
        }
    domain:
        n : int = 0
}

int main(void) {
    PushDeep* s = @@PushDeep();
    if (PushDeep_get_depth(s) != 0) { printf("FAIL idle\n"); return 1; }
    PushDeep_descend(s);
    if (PushDeep_get_depth(s) != 1) { printf("FAIL d1\n"); return 1; }
    PushDeep_descend(s);
    if (PushDeep_get_depth(s) != 2) { printf("FAIL d2\n"); return 1; }
    PushDeep_descend(s);
    if (PushDeep_get_depth(s) != 3) { printf("FAIL d3\n"); return 1; }
    PushDeep_ascend(s);
    if (PushDeep_get_depth(s) != 2) { printf("FAIL a1\n"); return 1; }
    PushDeep_ascend(s);
    if (PushDeep_get_depth(s) != 1) { printf("FAIL a2\n"); return 1; }
    PushDeep_ascend(s);
    if (PushDeep_get_depth(s) != 0) { printf("FAIL a3\n"); return 1; }
    printf("PASS: 70_push_depth_three\n");
    PushDeep_destroy(s);
    return 0;
}

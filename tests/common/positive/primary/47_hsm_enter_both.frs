@@[target("rust")]

// Test 47: HSM Enter Cascade — Both Parent and Child have $>

@@system HSMEnterBoth {
    interface:
        go_to_child()
        go_to_parent()
        get_log(): Vec<String>
        get_state(): String

    machine:
        $Start {
            go_to_child() { -> $Child }
            go_to_parent() { -> $Parent }
            get_log(): Vec<String> { @@:(self.log.clone()) }
            get_state(): String { @@:("Start".to_string()) }
        }

        $Child => $Parent {
            $>() {
                self.log.push("Child:enter".to_string());
            }
            go_to_parent() { -> $Parent }
            get_log(): Vec<String> { @@:(self.log.clone()) }
            get_state(): String { @@:("Child".to_string()) }
        }

        $Parent {
            $>() {
                self.log.push("Parent:enter".to_string());
            }
            go_to_child() { -> $Child }
            get_log(): Vec<String> { @@:(self.log.clone()) }
            get_state(): String { @@:("Parent".to_string()) }
        }
    domain:
        log: Vec<String>
}

fn main() {
    println!("=== Test 47: HSM Enter Cascade — Both ===");
    let mut s = @@HSMEnterBoth();

    s.go_to_child();
    let log = s.get_log();
    assert!(s.get_state() == "Child", "Expected Child");
    let pi = log.iter().position(|x| x == "Parent:enter");
    let ci = log.iter().position(|x| x == "Child:enter");
    assert!(pi.is_some(), "Expected Parent:enter");
    assert!(ci.is_some(), "Expected Child:enter");
    assert!(pi.unwrap() < ci.unwrap(), "Parent:enter must precede Child:enter (top-down)");
    println!("TC1: Parent's $> fires before Child's $> on cascade entry - PASS");

    s.go_to_parent();
    let log = s.get_log();
    assert!(s.get_state() == "Parent", "Expected Parent");
    assert!(log.iter().filter(|x| *x == "Parent:enter").count() == 2, "Expected 2 Parent:enter");
    assert!(log.iter().filter(|x| *x == "Child:enter").count() == 1, "Expected still 1 Child:enter");
    println!("TC2: Direct Parent entry fires only Parent's $> - PASS");

    s.go_to_child();
    let log = s.get_log();
    assert!(log.iter().filter(|x| *x == "Parent:enter").count() == 3, "Expected 3 Parent:enter total");
    assert!(log.iter().filter(|x| *x == "Child:enter").count() == 2, "Expected 2 Child:enter total");
    println!("TC3: Re-entering Child cascades through Parent again - PASS");

    println!("PASS: HSM enter cascade fires both layers top-down");
}

@@target rust

// Test 47: HSM Enter in Both Child and Parent
//
// Tests enter handler in both levels:
// - Only child's enter fires when entering child
// - Parent's enter fires only when transitioning to parent
// - No implicit cascading of enter handlers

@@system HSMEnterBoth {
    interface:
        go_to_child()
        go_to_parent()
        get_log(): Vec<String>
        get_state(): String

    machine:
        $Start {
            go_to_child() {
                -> $Child
            }

            go_to_parent() {
                -> $Parent
            }

            get_log(): Vec<String> {
                return self.log.clone()
            }

            get_state(): String {
                return "Start".to_string()
            }
        }

        $Child => $Parent {
            $>() {
                self.log.push("Child:enter".to_string());
            }

            go_to_parent() {
                -> $Parent
            }

            get_log(): Vec<String> {
                return self.log.clone()
            }

            get_state(): String {
                return "Child".to_string()
            }
        }

        $Parent {
            $>() {
                self.log.push("Parent:enter".to_string());
            }

            go_to_child() {
                -> $Child
            }

            get_log(): Vec<String> {
                return self.log.clone()
            }

            get_state(): String {
                return "Parent".to_string()
            }
        }
    domain:
        log: Vec<String>
}

fn main() {
    println!("=== Test 47: HSM Enter in Both ===");
    let mut s = @@HSMEnterBoth();

    // TC2.3.1: Only child's enter fires when entering child
    s.go_to_child();
    let log = s.get_log();
    assert!(log.contains(&"Child:enter".to_string()), "Expected Child:enter, got {:?}", log);
    assert!(!log.contains(&"Parent:enter".to_string()), "Parent:enter should NOT fire when entering child, got {:?}", log);
    assert!(s.get_state() == "Child", "Expected Child, got {}", s.get_state());
    println!("TC2.3.1: Only child's enter fires when entering child - PASS");

    // TC2.3.2: Parent's enter fires only when transitioning to parent
    s.go_to_parent();
    let log = s.get_log();
    assert!(log.contains(&"Parent:enter".to_string()), "Expected Parent:enter, got {:?}", log);
    assert!(s.get_state() == "Parent", "Expected Parent, got {}", s.get_state());
    println!("TC2.3.2: Parent's enter fires when transitioning to parent - PASS");

    // TC2.3.3: No implicit cascading - counts should be exactly 1 each
    let child_count = log.iter().filter(|x| *x == "Child:enter").count();
    let parent_count = log.iter().filter(|x| *x == "Parent:enter").count();
    assert!(child_count == 1, "Expected exactly 1 Child:enter, got {:?}", log);
    assert!(parent_count == 1, "Expected exactly 1 Parent:enter, got {:?}", log);
    println!("TC2.3.3: No implicit cascading of enter handlers - PASS");

    // TC2.3.4: Going back to child fires child enter again
    s.go_to_child();
    let log = s.get_log();
    let child_count2 = log.iter().filter(|x| *x == "Child:enter").count();
    let parent_count2 = log.iter().filter(|x| *x == "Parent:enter").count();
    assert!(child_count2 == 2, "Expected 2 Child:enter, got {:?}", log);
    assert!(parent_count2 == 1, "Expected still 1 Parent:enter, got {:?}", log);
    println!("TC2.3.4: Re-entering child fires child enter again - PASS");

    println!("PASS: HSM enter in both works correctly");
}

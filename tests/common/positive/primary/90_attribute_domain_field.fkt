@@[target("kotlin")]

@@system Demo {
    interface:
        get_a(): Int
        get_kt_only(): Int
    machine:
        $S {
            get_a(): Int { @@:(this.a) }
            get_kt_only(): Int { @@:(this.kt_only) }
        }
    domain:
        a: Int = 1
        @@[target("python_3")] py_only: Int = 2
        @@[target("kotlin")]
        kt_only: Int = 42
}

fun main() {
    val d = @@Demo()
    check(d.get_a() == 1) { "FAIL get_a: ${d.get_a()}" }
    check(d.get_kt_only() == 42) { "FAIL get_kt_only: ${d.get_kt_only()}" }
    println("PASS: 90_attribute_domain_field")
}

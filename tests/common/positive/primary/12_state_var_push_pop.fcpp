@@target cpp_17

#include <iostream>
#include <string>
#include <cassert>

@@system StateVarPushPop {
    interface:
        increment(): int
        get_count(): int
        save_and_go()
        restore()

    machine:
        $Counter {
            $.count: int = 0

            increment(): int {
                $.count = $.count + 1;
                return $.count;
            }

            get_count(): int {
                return $.count;
            }

            save_and_go() {
                `push$
                -> $Other
            }
        }

        $Other {
            $.other_count: int = 100

            restore() {
                `-> pop$
            }

            increment(): int {
                $.other_count = $.other_count + 1;
                return $.other_count;
            }

            get_count(): int {
                return $.other_count;
            }
        }
}

int main() {
    printf("=== Test 12: State Variable Push/Pop ===\n");
    StateVarPushPop s;

    s.increment();
    s.increment();
    s.increment();
    int count = s.get_count();
    if (count != 3) {
        printf("FAIL: Expected 3, got %d\n", count);
        assert(false);
    }
    printf("Counter before push: %d\n", count);

    s.save_and_go();
    printf("Pushed and transitioned to Other\n");

    count = s.get_count();
    if (count != 100) {
        printf("FAIL: Expected 100 in Other state, got %d\n", count);
        assert(false);
    }
    printf("Other state count: %d\n", count);

    s.increment();
    count = s.get_count();
    if (count != 101) {
        printf("FAIL: Expected 101 after increment, got %d\n", count);
        assert(false);
    }
    printf("Other state after increment: %d\n", count);

    s.restore();
    printf("Popped back to Counter\n");

    count = s.get_count();
    if (count != 3) {
        printf("FAIL: Expected 3 after pop (preserved), got %d\n", count);
        assert(false);
    }
    printf("Counter after pop: %d\n", count);

    s.increment();
    count = s.get_count();
    if (count != 4) {
        printf("FAIL: Expected 4, got %d\n", count);
        assert(false);
    }
    printf("Counter after increment: %d\n", count);

    printf("PASS: State variables preserved across push/pop\n");
    return 0;
}

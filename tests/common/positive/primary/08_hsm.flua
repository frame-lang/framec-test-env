@@target lua
@@system HSMForward {
    interface:
        event_a()
        event_b()
        get_log(): list

    machine:
        $Child => $Parent {
            event_a() {
                self.log[#self.log + 1] = "Child:event_a"
            }

            event_b() {
                self.log[#self.log + 1] = "Child:event_b_forward"
                => $^
            }

            get_log(): list {
                return self.log
            }
        }

        $Parent {
            event_a() {
                self.log[#self.log + 1] = "Parent:event_a"
            }

            event_b() {
                self.log[#self.log + 1] = "Parent:event_b"
            }

            get_log(): list {
                return self.log
            }
        }
    domain:
        log: list = []
}

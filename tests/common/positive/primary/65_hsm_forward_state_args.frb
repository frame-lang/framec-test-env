@@[target("ruby")]

@@system StateArgFwd {
    interface:
        configure(t: int)
        process(): int

    machine:
        $Idle {
            configure(t: int) {
                -> $Active(t)
            }
            process(): int {
                @@:(0)
                return
            }
        }

        $Active => $Frame(threshold: int) {
            configure(t: int) {
                -> $Active(t)
            }
            process(): int {
                => $^
            }
        }

        $Frame {
            process(): int {
                @@:(threshold)
                return
            }
        }
    domain:
        n: int = 0
}

puts "=== Test 65: HSM × state-args × parent-forward (Ruby) ==="
s = StateArgFwd.new

pre = s.process
raise "Expected 0, got #{pre}" unless pre == 0
puts "1. Idle process = #{pre}"

s.configure(7)
r = s.process
raise "Expected 7, got #{r}" unless r == 7
puts "2. configure(7); process() = #{r}"

s.configure(42)
r2 = s.process
raise "Expected 42, got #{r2}" unless r2 == 42
puts "3. configure(42); process() = #{r2}"

puts "PASS: 65_hsm_forward_state_args"

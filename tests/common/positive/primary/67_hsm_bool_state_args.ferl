@@[target("erlang")]
@@system BoolStateArg {
    interface:
        configure(active: bool)
        isActive(): bool
    machine:
        $Idle {
            configure(active: bool) {
                -> $Active(active)
            }
            isActive(): bool {
                @@:(false)
            }
        }
        $Active => $Frame(flag: bool) {
            configure(active: bool) {
                -> $Active(active)
            }
            isActive(): bool {
                => $^
            }
        }
        $Frame {
            isActive(): bool {
                @@:(Flag)
            }
        }
    domain:
        n = 0
}

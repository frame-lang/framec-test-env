@@target lua
@@system HSMMultiChildren {
    interface:
        start_a()
        start_b()
        start_c()
        do_action()
        forward_action()
        get_log(): list
        get_state(): str

    machine:
        $ChildA => $Parent {
            start_a() {
                -- empty
            
            }

            start_b() {
                -> $ChildB
            }

            start_c() {
                -> $ChildC
            }

            do_action() {
                self.log[#self.log + 1] = "ChildA:do_action"
            }

            forward_action() {
                self.log[#self.log + 1] = "ChildA:forward_action"
                => $^
            }

            get_log(): list {
                return self.log
            }

            get_state(): str {
                return "ChildA"
            }
        }

        $ChildB => $Parent {
            start_a() {
                -> $ChildA
            }

            start_b() {
                -- empty
            
            }

            start_c() {
                -> $ChildC
            }

            do_action() {
                self.log[#self.log + 1] = "ChildB:do_action"
            }

            forward_action() {
                self.log[#self.log + 1] = "ChildB:forward_action"
                => $^
            }

            get_log(): list {
                return self.log
            }

            get_state(): str {
                return "ChildB"
            }
        }

        $ChildC => $Parent {
            start_a() {
                -> $ChildA
            }

            start_b() {
                -> $ChildB
            }

            start_c() {
                -- empty
            
            }

            do_action() {
                self.log[#self.log + 1] = "ChildC:do_action"
            }

            forward_action() {
                self.log[#self.log + 1] = "ChildC:forward_action"
                => $^
            }

            get_log(): list {
                return self.log
            }

            get_state(): str {
                return "ChildC"
            }
        }

        $Parent {
            forward_action() {
                self.log[#self.log + 1] = "Parent:forward_action"
            }

            get_log(): list {
                return self.log
            }

            get_state(): str {
                return "Parent"
            }
        }
    domain:
        log: list = []
}

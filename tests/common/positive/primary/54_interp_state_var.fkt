@@target kotlin

import kotlin.system.exitProcess

@@system InterpStress {
    interface:
        test_interp(): String
        test_standalone(): Int
        test_return(): Int
        test_multi(): String
        test_mixed(): String

    machine:
        $Active {
            $.count: Int = 42
            $.label: String = "hello"

            test_interp(): String {
                @@:("count is ${$.count}")
                return;
            }

            test_standalone(): Int {
                val x = $.count + 1
                @@:(x)
                return;
            }

            test_return(): Int {
                @@:($.count)
                return;
            }

            test_multi(): String {
                @@:("${$.count} and ${$.label}")
                return;
            }

            test_mixed(): String {
                val total = 100
                @@:("${$.count}/$total")
                return;
            }
        }
}

fun main() {
    val s = InterpStress()
    var failures = 0

    var r = s.test_interp() as String
    if (r != "count is 42") { println("FAIL interp: got '$r'"); failures++ }

    var n = s.test_standalone() as Int
    if (n != 43) { println("FAIL standalone: got $n"); failures++ }

    n = s.test_return() as Int
    if (n != 42) { println("FAIL return: got $n"); failures++ }

    r = s.test_multi() as String
    if (r != "42 and hello") { println("FAIL multi: got '$r'"); failures++ }

    r = s.test_mixed() as String
    if (r != "42/100") { println("FAIL mixed: got '$r'"); failures++ }

    if (failures > 0) {
        println("FAIL: $failures failures")
        exitProcess(1)
    }
    println("PASS: stress_interp (5 cases)")
}

@@[target("javascript")]

@@[persist]
@@system NestedDict {
    interface:
        configure(m)
        get_inner(outer_key, inner_key)

    machine:
        $Idle {
            configure(m) { -> $Active(m) }
            get_inner(outer_key, inner_key) { @@:(-1) }
        }
        $Active(m) {
            configure(m) { -> $Active(m) }
            get_inner(outer_key, inner_key) {
                @@:(m[outer_key] && m[outer_key][inner_key] !== undefined ? m[outer_key][inner_key] : -1)
            }
        }
    domain:
        n = 0
}

const s1 = new NestedDict();
s1.configure({"u": {"x": 1, "y": 2}, "v": {"z": 3}});
if (s1.get_inner("u", "x") !== 1) { console.log("FAIL pre"); process.exit(1); }
const snap = s1.saveState();
const s2 = NestedDict.restoreState(snap);
if (s2.get_inner("u", "x") !== 1) { console.log("FAIL post u.x"); process.exit(1); }
if (s2.get_inner("u", "y") !== 2) { console.log("FAIL post u.y"); process.exit(1); }
if (s2.get_inner("v", "z") !== 3) { console.log("FAIL post v.z"); process.exit(1); }
console.log("PASS: 78_nested_dict_state_arg");

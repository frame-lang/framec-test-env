@@[target("python_3")]

@@system DictStateArg {
    interface:
        configure(m: dict)
        get_v(key: str): int
        size(): int

    machine:
        $Idle {
            configure(m: dict) { -> $Active(m) }
            get_v(key: str): int { @@:(-1); return }
            size(): int { @@:(0); return }
        }
        $Active(m: dict) {
            configure(m: dict) { -> $Active(m) }
            get_v(key: str): int { @@:(m.get(key, -1)); return }
            size(): int { @@:(len(m)); return }
        }
    domain:
        n: int = 0
}

def main():
    s = @@DictStateArg()
    assert s.get_v("a") == -1
    assert s.size() == 0
    s.configure({"a": 10, "b": 20})
    assert s.get_v("a") == 10
    assert s.get_v("b") == 20
    assert s.size() == 2
    s.configure({"x": 99})
    assert s.get_v("x") == 99
    assert s.size() == 1
    print("PASS: 76_dict_state_arg")

if __name__ == '__main__':
    main()

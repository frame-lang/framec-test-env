@@[target("ruby")]

@@system WithParams {
    interface:
        start(initial: int)
        add(value: int)
        multiply(a: int, b: int): int
        get_total(): int

    machine:
        $Idle {
            start(initial: int) {
                self.total = initial
                puts("Started with initial value: #{initial}")
                -> $Running
            }

            add(value: int) {
                puts("Cannot add in Idle state")
            }

            multiply(a: int, b: int): int {
                @@:(0)
                return
            }

            get_total(): int {
                @@:(self.total)
                return
            }
        }

        $Running {
            start(initial: int) {
                puts("Already running")
            }

            add(value: int) {
                self.total += value
                puts("Added #{value}, total is now #{self.total}")
            }

            multiply(a: int, b: int): int {
                result = a * b
                self.total += result
                puts("Multiplied #{a} * #{b} = #{result}, total is now #{self.total}")
                @@:(result)
                return
            }

            get_total(): int {
                @@:(self.total)
                return
            }
        }
    domain:
        total: int = 0
}

puts("=== Test 07: Handler Parameters ===")
s = WithParams.new

# Initial total should be 0
total = s.get_total()
raise "Expected initial total=0, got #{total}" unless total == 0

# Start with initial value
s.start(100)
total = s.get_total()
raise "Expected total=100, got #{total}" unless total == 100
puts("After start(100): total = #{total}")

# Add value
s.add(25)
total = s.get_total()
raise "Expected total=125, got #{total}" unless total == 125
puts("After add(25): total = #{total}")

# Multiply with two params
result = s.multiply(3, 5)
raise "Expected multiply result=15, got #{result}" unless result == 15
total = s.get_total()
raise "Expected total=140, got #{total}" unless total == 140
puts("After multiply(3,5): result = #{result}, total = #{total}")

puts("PASS: Handler parameters work correctly")

@@target c

// Tests that system.return follows "last writer wins" across transition lifecycle

@@system SystemReturnChainTest {
    interface:
        test_enter_sets(): int
        test_exit_then_enter(): int
        get_state(): int

    machine:
        $Start {
            test_enter_sets(): int {
                -> $EnterSetter
            }

            test_exit_then_enter(): int {
                -> $BothSet
            }

            get_state(): int {
                return 1;
            }

            <$() {
                // Exit handler sets initial value (10)
                @@:return = 10;
            }
        }

        $EnterSetter {
            $>() {
                // Enter handler sets return value (20)
                @@:return = 20;
            }

            get_state(): int {
                return 2;
            }
        }

        $BothSet {
            $>() {
                // Enter handler sets return - should overwrite exit's value (30)
                @@:return = 30;
            }

            get_state(): int {
                return 3;
            }
        }
}

int main() {
    printf("=== Test 15: System Return Chain (Last Writer Wins) ===\n");

    // Test 1: Start exit + EnterSetter enter
    // Start's exit sets 10, EnterSetter's enter sets 20
    // Enter should win (last writer)
    SystemReturnChainTest* s1 = @@SystemReturnChainTest();
    int result = SystemReturnChainTest_test_enter_sets(s1);
    if (result != 20) {
        printf("FAIL: Expected 20 (from_enter), got %d\n", result);
        return 1;
    }
    int state = SystemReturnChainTest_get_state(s1);
    if (state != 2) {
        printf("FAIL: Expected state 2 (EnterSetter), got %d\n", state);
        return 1;
    }
    printf("1. Exit set then enter set - enter wins: %d\n", result);
    SystemReturnChainTest_destroy(s1);

    // Test 2: Both handlers set, enter wins
    SystemReturnChainTest* s2 = @@SystemReturnChainTest();
    result = SystemReturnChainTest_test_exit_then_enter(s2);
    if (result != 30) {
        printf("FAIL: Expected 30 (enter_wins), got %d\n", result);
        return 1;
    }
    state = SystemReturnChainTest_get_state(s2);
    if (state != 3) {
        printf("FAIL: Expected state 3 (BothSet), got %d\n", state);
        return 1;
    }
    printf("2. Both set - enter wins: %d\n", result);
    SystemReturnChainTest_destroy(s2);

    printf("PASS: System return chain (last writer wins) works correctly\n");
    return 0;
}

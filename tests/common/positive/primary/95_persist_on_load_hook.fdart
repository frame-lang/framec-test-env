@@[target("dart")]
import 'dart:convert';
@@[persist]
@@system Counter {
    operations:
        @@[save]
        save_state(): String {}

        @@[load]
        restore_state(data: String) {}

        @@[on_load]
        rebuild_derived() {
            this.doubled = this.n * 2;
            this.was_restored = true;
        }

    interface:
        bump()
        get_n(): int
        get_doubled(): int
        was_loaded(): bool

    machine:
        $Active {
            bump() { this.n = this.n + 1; }
            get_n(): int { @@:(this.n) }
            get_doubled(): int { @@:(this.doubled) }
            was_loaded(): bool { @@:(this.was_restored) }
        }

    domain:
        n: int = 0
        doubled: int = 0
        was_restored: bool = false
}

void main() {
    var c1 = Counter();
    c1.bump(); c1.bump(); c1.bump();
    if (c1.was_loaded()) { print("FAIL: was_restored should be false pre-restore"); return; }
    if (c1.get_doubled() != 0) { print("FAIL: doubled should be 0, got ${c1.get_doubled()}"); return; }

    var data = c1.save_state();

    var c2 = Counter();
    c2.restore_state(data);
    if (!c2.was_loaded()) { print("FAIL: was_restored should be true after on_load"); return; }
    if (c2.get_n() != 3) { print("FAIL: n should be 3, got ${c2.get_n()}"); return; }
    if (c2.get_doubled() != 6) { print("FAIL: doubled should be 6, got ${c2.get_doubled()}"); return; }

    print("PASS: 95_persist_on_load_hook");
}

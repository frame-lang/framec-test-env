@@target go

package main

import (
    "encoding/json"
    "fmt"
    "os"
)

var _ = json.Marshal

@@persist
@@system Inner {
    interface:
        cycle()
        get_state(): string
        get_count(): int

    machine:
        $A {
            cycle() { s.n = s.n + 1; -> $B }
            get_state(): string { @@:("A") }
            get_count(): int { @@:(s.n) }
        }
        $B => $A {
            cycle() { -> $A }
            get_state(): string { @@:("B") }
            get_count(): int { => $^ }
        }
    domain:
        n: int = 0
}

@@system Outer {
    interface:
        tick()
        cycle_inner()
        get_outer_state(): string
        get_inner_state(): string
        get_inner_count(): int
        get_k(): int

    machine:
        $Idle {
            tick() { s.k = s.k + 1; -> $Active }
            cycle_inner() { s.inner.Cycle() }
            get_outer_state(): string { @@:("Idle") }
            get_inner_state(): string { @@:(s.inner.Get_state()) }
            get_inner_count(): int { @@:(s.inner.Get_count()) }
            get_k(): int { @@:(s.k) }
        }
        $Active => $Idle {
            tick() { -> $Idle }
            get_outer_state(): string { @@:("Active") }
            cycle_inner() { => $^ }
            get_inner_state(): string { => $^ }
            get_inner_count(): int { => $^ }
            get_k(): int { => $^ }
        }
    domain:
        k: int = 0
        inner: *Inner = @@Inner()
}

func formatProbe(o *Outer) string {
    return fmt.Sprintf("%s/%s/%d/%d", o.Get_outer_state(), o.Get_inner_state(), o.Get_inner_count(), o.Get_k())
}

func must(label string, o *Outer, expected string) {
    actual := formatProbe(o)
    if actual != expected {
        fmt.Printf("FAIL %s: %s expected %s\n", label, actual, expected)
        os.Exit(1)
    }
}

func main() {
    o := NewOuter()
    must("T0 fresh", o, "Idle/A/0/0")
    snap0 := o.SaveState()
    r0 := RestoreOuter(snap0)
    must("T0 restored", r0, "Idle/A/0/0")

    o.Tick()
    must("T1", o, "Active/A/0/1")
    snap1 := o.SaveState()
    r1 := RestoreOuter(snap1)
    must("T1 restored", r1, "Active/A/0/1")

    o.Cycle_inner()
    must("T2", o, "Active/B/1/1")
    snap2 := o.SaveState()
    r2 := RestoreOuter(snap2)
    must("T2 restored", r2, "Active/B/1/1")

    snap2b := r2.SaveState()
    r2b := RestoreOuter(snap2b)
    if formatProbe(r2b) != formatProbe(r2) {
        fmt.Printf("FAIL idempotence: %s != %s\n", formatProbe(r2b), formatProbe(r2))
        os.Exit(1)
    }

    r2.Cycle_inner()
    must("continue1", r2, "Active/A/1/1")
    r2.Tick()
    must("continue2", r2, "Idle/A/1/1")
    r2.Tick()
    must("continue3", r2, "Active/A/1/2")

    fmt.Println("PASS: 84_persist_nested_hsm")
}

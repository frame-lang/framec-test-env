@@target lua
@@system ReturnInitTest {
    interface:
        get_status(): str = "unknown"
        get_count(): int = 0
        get_flag(): bool = False
        trigger()

    machine:
        $Start {
            $>() {
                pass  -- Start state enter
            }
            get_status() {
                pass  -- Don't set return - should use default "unknown"
            }
            get_count() {
                pass  -- Don't set return - should use default 0
            }
            get_flag() {
                pass  -- Don't set return - should use default false
            }
            trigger() {
                -> $Active
            }
        }

        $Active {
            $>() {
                pass  -- Active state enter
            }
            get_status() {
                @@:return = "active"
            }
            get_count() {
                @@:return = 42
            }
            get_flag() {
                @@:return = True
            }
            trigger() {
                -> $Start
            }
        }
}

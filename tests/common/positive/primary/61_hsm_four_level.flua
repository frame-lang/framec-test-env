@@target lua

@@system HsmFourLevel {
    interface:
        drive(): int
        write_at_level(level: int)
        get_n(): int

    machine:
        $Leaf => $Mid {
            drive(): int {
                => $^
            }
            write_at_level(level: int) {
                self.n = self.n + level * 1
                => $^
            }
            get_n(): int {
                @@:(self.n)
                return
            }
        }

        $Mid => $Branch {
            drive(): int {
                => $^
            }
            write_at_level(level: int) {
                self.n = self.n + level * 10
                => $^
            }
        }

        $Branch => $Root {
            drive(): int {
                => $^
            }
            write_at_level(level: int) {
                self.n = self.n + level * 100
                => $^
            }
        }

        $Root {
            drive(): int {
                @@:(self.n)
                return
            }
            write_at_level(level: int) {
                self.n = self.n + level * 1000
            }
        }
    domain:
        n: int = 0
}

print("=== Test 61: 4-level HSM cascade (Lua) ===")
local s = HsmFourLevel.new()

local initial = s:drive()
if initial ~= 0 then error("Expected 0 initial, got " .. tostring(initial)) end
print("1. Initial drive returned " .. tostring(initial))

s:write_at_level(2)
local after = s:get_n()
if after ~= 2222 then error("Expected 2222, got " .. tostring(after)) end
print("2. After cascading write: n=" .. tostring(after))

local final = s:drive()
if final ~= 2222 then error("Expected 2222 final, got " .. tostring(final)) end
print("3. Drive after write returned " .. tostring(final))

print("PASS: 61_hsm_four_level")

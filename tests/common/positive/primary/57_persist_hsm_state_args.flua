@@target lua

@@persist
@@system PersistHsmStateArgs {
    interface:
        drive(p: int)
        get_x(): int

    machine:
        $Start {
            drive(p: int) {
                -> $Child(p)
            }
            get_x(): int {
                @@:(-1)
                return
            }
        }

        $Child => $Parent(x: int) {
            drive(p: int) {
                -> $Child(p)
            }
            get_x(): int {
                @@:(x)
                return
            }
        }

        $Parent {
        }
    domain:
        v: int = 0
}

print("=== Test 57: Persist HSM × State-Args Round-Trip (Lua) ===")
local s1 = PersistHsmStateArgs.new()
s1:drive(42)
local pre = s1:get_x()
if pre ~= 42 then error("Expected 42 pre-save, got " .. tostring(pre)) end
print("1. Pre-save x=" .. tostring(pre))

local snap = s1:save_state()
local s2 = PersistHsmStateArgs.restore_state(snap)
local post = s2:get_x()
if post ~= 42 then error("Expected 42 post-restore, got " .. tostring(post)) end
print("2. Post-restore x=" .. tostring(post))

s2:drive(99)
local post2 = s2:get_x()
if post2 ~= 99 then error("Expected 99 post-drive, got " .. tostring(post2)) end
print("3. Post-restore-drive x=" .. tostring(post2))

print("PASS: 57_persist_hsm_state_args")

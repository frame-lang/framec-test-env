@@target erlang
@@system HSMSiblings {
    interface:
        goA()
        goB()
        getState(): str
    machine:
        $A => $Parent {
            $>() { self.log = self.log ++ ",a_enter" }
            goB() { -> $B }
            getState(): str {
                @@:("A")
            }
        }
        $B => $Parent {
            $>() { self.log = self.log ++ ",b_enter" }
            goA() { -> $A }
            getState(): str {
                @@:("B")
            }
        }
        $Parent {
            getState(): str {
                @@:("Parent")
            }
        }
    domain:
        log = "init"
}

@@[target("gdscript")]
extends SceneTree

@@[persist]
@@system PersistMultiEvent {
    interface:
        seed(v: int)
        bump()
        get_slot(): int

    machine:
        $Idle {
            seed(v: int) {
                -> $Active(v)
            }
            bump() {
                @@:(-1)
            }
            get_slot(): int {
                @@:(-1)
            }
        }

        $Active(slot: int) {
            seed(v: int) {
                -> $Active(v)
            }
            bump() {
                -> $Active(slot + 100)
            }
            get_slot(): int {
                @@:(slot)
            }
        }
    domain:
        v: int = 0
}

func _initialize():
    print("=== Test 59: Persist × multi-event boundary (GDScript) ===")
    var s1 = PersistMultiEvent.new()
    s1.seed(42)
    var pre = s1.get_slot()
    if pre != 42:
        print("FAIL: pre " + str(pre))
        quit(1)
        return
    print("1. Pre-save slot=" + str(pre))

    var snap = s1.save_state()
    var s2 = PersistMultiEvent.restore_state(snap)
    var post = s2.get_slot()
    if post != 42:
        print("FAIL: post " + str(post))
        quit(1)
        return
    print("2. Post-restore slot=" + str(post))

    s2.bump()
    var bumped = s2.get_slot()
    if bumped != 142:
        print("FAIL: bumped " + str(bumped))
        quit(1)
        return
    print("3. After post-restore bump slot=" + str(bumped))

    s2.bump()
    var twice = s2.get_slot()
    if twice != 242:
        print("FAIL: twice " + str(twice))
        quit(1)
        return
    print("4. After second bump slot=" + str(twice))

    print("PASS: 59_persist_multi_event")
    quit(0)

@@[target("kotlin")]

import kotlin.system.exitProcess

@@system HSMParentStateVars {
    interface:
        get_child_count(): Int
        get_parent_count(): Int

    machine:
        $Child => $Parent {
            $.child_count: Int = 0

            $>() {
                // RFC-0019: forward $> to $Parent so its state-var
                // initializer ($.parent_count = 100) runs.
                => $^
            }

            get_child_count(): Int {
                @@:($.child_count)
                return;
            }

            get_parent_count(): Int {
                => $^
            }
        }

        $Parent {
            $.parent_count: Int = 100

            get_parent_count(): Int {
                @@:($.parent_count)
                return;
            }
        }
}

fun main() {
    println("=== Test 40: HSM Parent State Variables ===")
    val s = @@HSMParentStateVars()

    val childCount = s.get_child_count() as Int
    if (childCount != 0) {
        println("FAIL: Expected child_count=0, got $childCount")
        exitProcess(1)
    }
    println("Child count: $childCount")

    val parentCount = s.get_parent_count() as Int
    if (parentCount != 100) {
        println("FAIL: Expected parent_count=100, got $parentCount")
        exitProcess(1)
    }
    println("Parent count: $parentCount")

    println("PASS: HSM parent state variables work correctly")
}

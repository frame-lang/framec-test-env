@@[target("python_3")]

# Test 70: push/pop modal stack at depth 3.
# Phase 19 wave 4. Tests `push$` followed by `-> $State` push the
# current compartment onto the state stack and transition to a new
# state, and `-> pop$` restores the most recently pushed compartment.
#
# Stack ops at depth ≥ 3 — wave 1-3 covered depth 1-2 only.

@@system PushDeep {
    interface:
        descend()
        ascend()
        get_depth(): int

    machine:
        $Idle {
            descend() {
                push$
                -> $Modal1
            }
            get_depth(): int {
                @@:(0)
                return
            }
        }

        $Modal1 {
            descend() {
                push$
                -> $Modal2
            }
            ascend() {
                -> pop$
            }
            get_depth(): int {
                @@:(1)
                return
            }
        }

        $Modal2 {
            descend() {
                push$
                -> $Modal3
            }
            ascend() {
                -> pop$
            }
            get_depth(): int {
                @@:(2)
                return
            }
        }

        $Modal3 {
            ascend() {
                -> pop$
            }
            get_depth(): int {
                @@:(3)
                return
            }
        }
    domain:
        n: int = 0
}

def main():
    s = @@PushDeep()
    assert s.get_depth() == 0, f"idle: {s.get_depth()}"
    s.descend()
    assert s.get_depth() == 1
    s.descend()
    assert s.get_depth() == 2
    s.descend()
    assert s.get_depth() == 3
    s.ascend()
    assert s.get_depth() == 2
    s.ascend()
    assert s.get_depth() == 1
    s.ascend()
    assert s.get_depth() == 0
    print("PASS: 70_push_depth_three")

if __name__ == '__main__':
    main()

@@[target("ruby")]

@@[persist]
@@system Inner {
    operations:
        @@[save]
        save_state(): String {}

        @@[load]
        restore_state(data: String) {}

    interface:
        bump_int()
        bump_float()
        flip_bool()
        get_n_int(): int
        get_n_float(): float
        get_n_bool(): bool
        get_n_str(): string

    machine:
        $S {
            bump_int() { self.n_int = self.n_int + 1 }
            bump_float() { self.n_float = self.n_float + 0.25 }
            flip_bool() { self.n_bool = !self.n_bool }
            get_n_int(): int { @@:(self.n_int) }
            get_n_float(): float { @@:(self.n_float) }
            get_n_bool(): bool { @@:(self.n_bool) }
            get_n_str(): string { @@:(self.n_str) }
        }
    domain:
        n_int: int = 7
        n_float: float = 2.5
        n_bool: bool = true
        n_str: string = "hello"
}

@@[main]
@@system Outer {
    operations:
        @@[save]
        save_state(): String {}

        @@[load]
        restore_state(data: String) {}

    interface:
        bump_k_int()
        bump_k_float()
        bump_inner_int()
        bump_inner_float()
        flip_inner_bool()
        get_k_int(): int
        get_k_float(): float
        get_n_int(): int
        get_n_float(): float
        get_n_bool(): bool
        get_n_str(): string

    machine:
        $S {
            bump_k_int() { self.k_int = self.k_int + 1 }
            bump_k_float() { self.k_float = self.k_float + 0.25 }
            bump_inner_int() { self.inner.bump_int }
            bump_inner_float() { self.inner.bump_float }
            flip_inner_bool() { self.inner.flip_bool }
            get_k_int(): int { @@:(self.k_int) }
            get_k_float(): float { @@:(self.k_float) }
            get_n_int(): int { @@:(self.inner.get_n_int) }
            get_n_float(): float { @@:(self.inner.get_n_float) }
            get_n_bool(): bool { @@:(self.inner.get_n_bool) }
            get_n_str(): string { @@:(self.inner.get_n_str) }
        }
    domain:
        k_int: int = 42
        k_float: float = 1.25
        inner = @@Inner()
}

def assertState(o, label, kIntStr, kFloat, nIntStr, nFloat, nBool, nStr)
  abort("FAIL #{label} k_int: #{o.get_k_int}") unless o.get_k_int.to_s == kIntStr
  abort("FAIL #{label} n_int: #{o.get_n_int}") unless o.get_n_int.to_s == nIntStr
  abort("FAIL #{label} k_float: #{o.get_k_float}") unless (o.get_k_float - kFloat).abs < 1e-9
  abort("FAIL #{label} n_float: #{o.get_n_float}") unless (o.get_n_float - nFloat).abs < 1e-9
  abort("FAIL #{label} n_bool: #{o.get_n_bool}") unless o.get_n_bool == nBool
  abort("FAIL #{label} n_str: #{o.get_n_str}") unless o.get_n_str == nStr
end

o = Outer.new
assertState(o, "T0", "42", 1.25, "7", 2.5, true, "hello")

o.bump_k_int
o.bump_k_float
o.bump_inner_int
o.bump_inner_float
o.flip_inner_bool
assertState(o, "T1", "43", 1.5, "8", 2.75, false, "hello")

snap = o.save_state
r = Outer.new
r.restore_state(snap)
assertState(r, "T1 restored", "43", 1.5, "8", 2.75, false, "hello")

r.bump_k_int
r.bump_inner_int
assertState(r, "continue", "44", 1.5, "9", 2.75, false, "hello")

puts "PASS: 86_persist_numeric_typing"

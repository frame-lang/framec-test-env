@@target lua
@@system StateVarPushPop {
    interface:
        increment(): int
        get_count(): int
        save_and_go()
        restore()

    machine:
        $Counter {
            $.count: int = 0

            increment(): int {
                $.count = $.count + 1
                return $.count
            }

            get_count(): int {
                return $.count
            }

            save_and_go() {
                push$
                -> $Other
            }
        }

        $Other {
            $.other_count: int = 100

            restore() {
                -> pop$
            }

            increment(): int {
                $.other_count = $.other_count + 1
                return $.other_count
            }

            get_count(): int {
                return $.other_count
            }
        }
}

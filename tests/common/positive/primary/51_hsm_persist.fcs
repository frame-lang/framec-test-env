// @@skip
// Persist tests need System.Text.Json pipeline support for C#
@@target csharp

using System;
using System.Collections.Generic;

@@persist
@@system HSMPersist {
    interface:
        increment_child()
        increment_parent()
        get_child_count(): int
        get_parent_count(): int
        get_state(): string

    machine:
        $Parent {
            increment_parent() { $.parent_count = $.parent_count + 1; }
            get_parent_count(): int { return $.parent_count; }
            get_state(): string { return "Parent"; }
            increment_child() { }
            get_child_count(): int { return -1; }
        }

        $Child => $Parent {
            $.child_count: int = 0

            increment_child() { $.child_count = $.child_count + 1; }
            get_child_count(): int { return $.child_count; }
            get_state(): string { return "Child"; }
        }

    domain:
        int parent_count_init = 100
}

class Program {
    static void Main(string[] args) {
        Console.WriteLine("=== Test 51: HSM Persistence (C#) ===");
        Console.WriteLine("SKIP: Persist tests need System.Text.Json pipeline support");
    }
}

@@[target("php")]

# Test: Interface method return_init

@@system ReturnInitTest {
    interface:
        get_status(): str = "unknown"
        get_count(): int = 0
        get_flag(): bool = false
        trigger()

    machine:
        $Start {
            $>() {
                # Start state enter
            }
            get_status() {
                # Don't set return - should use default "unknown"
            }
            get_count() {
                # Don't set return - should use default 0
            }
            get_flag() {
                # Don't set return - should use default false
            }
            trigger() {
                -> $Active
            }
        }

        $Active {
            $>() {
                # Active state enter
            }
            get_status() {
                @@:("active")
            }
            get_count() {
                @@:(42)
            }
            get_flag() {
                @@:(true)
            }
            trigger() {
                -> $Start
            }
        }
}

echo "TAP version 14" . "\n";
echo "1..6" . "\n";

$s = @@ReturnInitTest();

if ($s->get_status() === "unknown") {
    echo "ok 1 - default string return is 'unknown'" . "\n";
} else {
    echo "not ok 1 - default string return is 'unknown' # got " . $s->get_status() . "\n";
}

if ($s->get_count() === 0) {
    echo "ok 2 - default int return is 0" . "\n";
} else {
    echo "not ok 2 - default int return is 0 # got " . $s->get_count() . "\n";
}

if ($s->get_flag() === false) {
    echo "ok 3 - default bool return is false" . "\n";
} else {
    echo "not ok 3 - default bool return is false # got " . var_export($s->get_flag(), true) . "\n";
}

$s->trigger();

if ($s->get_status() === "active") {
    echo "ok 4 - explicit return overrides default string" . "\n";
} else {
    echo "not ok 4 - explicit return overrides default string # got " . $s->get_status() . "\n";
}

if ($s->get_count() === 42) {
    echo "ok 5 - explicit return overrides default int" . "\n";
} else {
    echo "not ok 5 - explicit return overrides default int # got " . $s->get_count() . "\n";
}

if ($s->get_flag() === true) {
    echo "ok 6 - explicit return overrides default bool" . "\n";
} else {
    echo "not ok 6 - explicit return overrides default bool # got " . var_export($s->get_flag(), true) . "\n";
}

echo "# PASS - return_init provides default return values" . "\n";

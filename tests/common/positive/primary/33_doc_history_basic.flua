@@target lua
@@system HistoryBasic {
    interface:
        gotoC_from_A()
        gotoC_from_B()
        gotoB()
        return_back()
        get_state(): str

    machine:
        $A {
            gotoC_from_A() {
                push$
                -> $C
            }
            gotoB() {
                -> $B
            }
            get_state(): str {
                return "A"
            }
        }

        $B {
            gotoC_from_B() {
                push$
                -> $C
            }
            get_state(): str {
                return "B"
            }
        }

        $C {
            return_back() {
                -> pop$
            }
            get_state(): str {
                return "C"
            }
        }
}

@@target java

import java.util.*;

// Test: const domain field initialized from system param.

@@system Sensor(threshold: int = 100) {
    interface:
        read(): int
        calibrate(offset: int)
        get_threshold(): int

    machine:
        $Active {
            read(): int {
                @@:(this.value + this.offset)
                return;
            }
            calibrate(offset: int) {
                this.offset = offset;
            }
            get_threshold(): int {
                @@:(this.threshold)
                return;
            }
        }

    domain:
        const threshold : int = threshold
        value : int = 50
        offset : int = 0
}

class Main {
    public static void main(String[] args) {
        int failures = 0;

        // Test 1: system param override
        var s = @@Sensor(200);
        int t = s.get_threshold();
        if (t != 200) { System.out.println("FAIL test 1: expected 200, got " + t); failures++; }

        // Test 2: read returns value + offset
        int v = s.read();
        if (v != 50) { System.out.println("FAIL test 2: expected 50, got " + v); failures++; }

        // Test 3: calibrate changes offset
        s.calibrate(10);
        v = s.read();
        if (v != 60) { System.out.println("FAIL test 3: expected 60, got " + v); failures++; }

        // Test 4: default system param
        var s2 = @@Sensor();
        int t2 = s2.get_threshold();
        if (t2 != 100) { System.out.println("FAIL test 4: expected 100, got " + t2); failures++; }

        if (failures > 0) {
            System.out.println("FAIL: const_domain (" + failures + " failures)");
            System.exit(1);
        }
        System.out.println("PASS: const_domain");
    }
}

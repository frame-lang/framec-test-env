@@target erlang
@@system Calculator {
    interface:
        add(a: int, b: int): int
        getResult(): int
    machine:
        $Ready {
            add(a: int, b: int): int {
                self.result = a + b
                @@:(self.result)
                return
            }
            getResult(): int {
                @@:(self.result)
            }
        }
    domain:
        result = 0
}

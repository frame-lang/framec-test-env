@@target erlang
@@system Calculator {
    interface:
        add(a: int, b: int): int
        getResult(): int
    machine:
        $Ready {
            add(a: int, b: int): int {
                self.result = a + b
                return self.result
            }
            getResult(): int { return self.result }
        }
    domain:
        result = 0
}

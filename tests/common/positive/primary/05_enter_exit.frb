@@[target("ruby")]

@@system EnterExit {
    interface:
        toggle()
        get_log(): list

    machine:
        $Off {
            $>() {
                self.log.push("enter:Off")
                puts("Entered Off state")
            }

            <$() {
                self.log.push("exit:Off")
                puts("Exiting Off state")
            }

            toggle() {
                -> $On
            }

            get_log(): list {
                @@:(self.log)
                return
            }
        }

        $On {
            $>() {
                self.log.push("enter:On")
                puts("Entered On state")
            }

            <$() {
                self.log.push("exit:On")
                puts("Exiting On state")
            }

            toggle() {
                -> $Off
            }

            get_log(): list {
                @@:(self.log)
                return
            }
        }
    domain:
        log: list = []
}

puts("=== Test 05: Enter/Exit Handlers ===")
s = @@EnterExit()

# Initial enter should have been called
log = s.get_log()
raise "Expected 'enter:Off' in log, got #{log}" unless log.include?("enter:Off")
puts("After construction: #{log}")

# Toggle to On - should exit Off, enter On
s.toggle()
log = s.get_log()
raise "Expected 'exit:Off' in log, got #{log}" unless log.include?("exit:Off")
raise "Expected 'enter:On' in log, got #{log}" unless log.include?("enter:On")
puts("After toggle to On: #{log}")

# Toggle back to Off - should exit On, enter Off
s.toggle()
log = s.get_log()
raise "Expected 2 'enter:Off' entries, got #{log}" unless log.count("enter:Off") == 2
raise "Expected 'exit:On' in log, got #{log}" unless log.include?("exit:On")
puts("After toggle to Off: #{log}")

puts("PASS: Enter/Exit handlers work correctly")

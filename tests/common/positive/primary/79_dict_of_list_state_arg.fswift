@@[target("swift")]

import Foundation

@@[persist(String)]
@@[save(saveState)]
@@[load(restoreState)]
@@system DictOfList {
    interface:
        configure(m: [String: [Int]])
        get_at(key: String, idx: Int): Int

    machine:
        $Idle {
            configure(m: [String: [Int]]) { -> $Active(m) }
            get_at(key: String, idx: Int): Int { @@:(-1) }
        }
        $Active(m: [String: [Int]]) {
            configure(m: [String: [Int]]) { -> $Active(m) }
            get_at(key: String, idx: Int): Int {
                @@:(idx < (m[key]?.count ?? 0) ? (m[key]?[idx] ?? -1) : -1)
            }
        }
    domain:
        n : Int = 0
}

let s1 = @@DictOfList()
s1.configure(["a": [10, 20], "b": [30, 40, 50]])
if s1.get_at("a", 0) != 10 { print("FAIL pre a.0"); exit(1) }
if s1.get_at("b", 2) != 50 { print("FAIL pre b.2"); exit(1) }
let snap = s1.saveState()
let s2 = @@DictOfList()

s2.restoreState(snap)
if s2.get_at("a", 0) != 10 { print("FAIL post a.0"); exit(1) }
if s2.get_at("a", 1) != 20 { print("FAIL post a.1"); exit(1) }
if s2.get_at("b", 2) != 50 { print("FAIL post b.2"); exit(1) }
print("PASS: 79_dict_of_list_state_arg")

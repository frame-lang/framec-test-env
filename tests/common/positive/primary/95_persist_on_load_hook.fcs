@@[target("csharp")]

@@[persist]
@@system Counter {
    operations:
        @@[save]
        save_state(): string {}

        @@[load]
        restore_state(data: string) {}

        @@[on_load]
        rebuild_derived() {
            this.doubled = this.n * 2;
            this.was_restored = true;
        }

    interface:
        Bump()
        GetN(): int
        GetDoubled(): int
        WasLoaded(): bool

    machine:
        $Active {
            Bump() { this.n = this.n + 1; }
            GetN(): int { @@:(this.n) }
            GetDoubled(): int { @@:(this.doubled) }
            WasLoaded(): bool { @@:(this.was_restored) }
        }

    domain:
        n: int = 0
        doubled: int = 0
        was_restored: bool = false
}

class Program {
    static void Main() {
        Counter c1 = new Counter();
        c1.Bump(); c1.Bump(); c1.Bump();
        if (c1.WasLoaded()) { System.Console.WriteLine("FAIL: was_restored should be false pre-restore"); return; }
        if (c1.GetDoubled() != 0) { System.Console.WriteLine($"FAIL: doubled should be 0, got {c1.GetDoubled()}"); return; }

        string data = c1.save_state();

        Counter c2 = new Counter();
        c2.restore_state(data);
        if (!c2.WasLoaded()) { System.Console.WriteLine("FAIL: was_restored should be true after on_load"); return; }
        if (c2.GetN() != 3) { System.Console.WriteLine($"FAIL: n should be 3, got {c2.GetN()}"); return; }
        if (c2.GetDoubled() != 6) { System.Console.WriteLine($"FAIL: doubled should be 6, got {c2.GetDoubled()}"); return; }

        System.Console.WriteLine("PASS: 95_persist_on_load_hook");
    }
}

@@target csharp

@@persist

using System;

@@system PPushDeep {
    interface:
        descend()
        ascend()
        get_depth(): int

    machine:
        $Idle {
            descend() { push$; -> $Modal1 }
            get_depth(): int { @@:(0) }
        }
        $Modal1 {
            descend() { push$; -> $Modal2 }
            ascend() { -> pop$ }
            get_depth(): int { @@:(1) }
        }
        $Modal2 {
            descend() { push$; -> $Modal3 }
            ascend() { -> pop$ }
            get_depth(): int { @@:(2) }
        }
        $Modal3 {
            ascend() { -> pop$ }
            get_depth(): int { @@:(3) }
        }
    domain: n : int = 0
}

class Program {
    static void Main(string[] args) {
        var s = new PPushDeep();
        s.descend(); s.descend(); s.descend();
        if (s.get_depth() != 3) { Console.WriteLine("FAIL pre"); Environment.Exit(1); }
        string snap = s.SaveState();
        var s2 = PPushDeep.RestoreState(snap);
        if (s2.get_depth() != 3) { Console.WriteLine($"FAIL post {s2.get_depth()}"); Environment.Exit(1); }
        s2.ascend();
        if (s2.get_depth() != 2) { Console.WriteLine("FAIL a1"); Environment.Exit(1); }
        s2.ascend();
        if (s2.get_depth() != 1) { Console.WriteLine("FAIL a2"); Environment.Exit(1); }
        s2.ascend();
        if (s2.get_depth() != 0) { Console.WriteLine("FAIL a3"); Environment.Exit(1); }
        Console.WriteLine("PASS: 71_persist_push_depth_three");
    }
}

@@[target("csharp")]

using System;

@@[persist(string)]
@@[save(SaveState)]
@@[load(RestoreState)]
@@system Inner {
    interface:
        cycle()
        get_state(): string
        get_count(): int

    machine:
        $A {
            cycle() { this.n = this.n + 1; -> $B }
            get_state(): string { @@:("A") }
            get_count(): int { @@:(this.n) }
        }
        $B => $A {
            cycle() { -> $A }
            get_state(): string { @@:("B") }
            get_count(): int { => $^ }
        }
    domain:
        n: int = 0
}@@[persist(string)]
@@[save(SaveState)]
@@[load(RestoreState)]


@@system Mid {
    interface:
        cycle()
        cycle_inner()
        get_state(): string
        get_inner_state(): string
        get_inner_count(): int
        get_m(): int

    machine:
        $P {
            cycle() { this.m = this.m + 1; -> $Q }
            cycle_inner() { this.inner.cycle(); }
            get_state(): string { @@:("P") }
            get_inner_state(): string { @@:(this.inner.get_state()) }
            get_inner_count(): int { @@:(this.inner.get_count()) }
            get_m(): int { @@:(this.m) }
        }
        $Q => $P {
            cycle() { -> $P }
            get_state(): string { @@:("Q") }
            cycle_inner() { => $^ }
            get_inner_state(): string { => $^ }
            get_inner_count(): int { => $^ }
            get_m(): int { => $^ }
        }
    domain:
        m: int = 0
        inner: Inner = @@Inner()
}@@[persist(string)]
@@[save(SaveState)]
@@[load(RestoreState)]


@@[main]
@@system Outer {
    interface:
        tick()
        cycle_mid()
        cycle_inner()
        get_outer_state(): string
        get_mid_state(): string
        get_inner_state(): string
        get_inner_count(): int
        get_m(): int
        get_k(): int

    machine:
        $Idle {
            tick() { this.k = this.k + 1; -> $Active }
            cycle_mid() { this.mid.cycle(); }
            cycle_inner() { this.mid.cycle_inner(); }
            get_outer_state(): string { @@:("Idle") }
            get_mid_state(): string { @@:(this.mid.get_state()) }
            get_inner_state(): string { @@:(this.mid.get_inner_state()) }
            get_inner_count(): int { @@:(this.mid.get_inner_count()) }
            get_m(): int { @@:(this.mid.get_m()) }
            get_k(): int { @@:(this.k) }
        }
        $Active => $Idle {
            tick() { -> $Idle }
            get_outer_state(): string { @@:("Active") }
            cycle_mid() { => $^ }
            cycle_inner() { => $^ }
            get_mid_state(): string { => $^ }
            get_inner_state(): string { => $^ }
            get_inner_count(): int { => $^ }
            get_m(): int { => $^ }
            get_k(): int { => $^ }
        }
    domain:
        k: int = 0
        mid: Mid = @@Mid()
}

class Program {
    static string fmt(Outer o) => $"{o.get_outer_state()}/{o.get_mid_state()}/{o.get_inner_state()}/{o.get_inner_count()}/{o.get_m()}/{o.get_k()}";
    static void Must(string label, Outer o, string expected) {
        var actual = fmt(o);
        if (actual != expected) throw new Exception($"FAIL {label}: {actual} expected {expected}");
    }
    public static void Main(string[] args) {
        var o = @@Outer();
        Must("T0 fresh", o, "Idle/P/A/0/0/0");
        var snap0 = o.SaveState();
        var r0 = @@Outer();

        r0.RestoreState(snap0);
        Must("T0 restored", r0, "Idle/P/A/0/0/0");

        o.tick();
        Must("T1", o, "Active/P/A/0/0/1");
        var snap1 = o.SaveState();
        var r1 = @@Outer();

        r1.RestoreState(snap1);
        Must("T1 restored", r1, "Active/P/A/0/0/1");

        o.cycle_mid();
        o.cycle_inner();
        Must("T2", o, "Active/Q/B/1/1/1");
        var snap2 = o.SaveState();
        var r2 = @@Outer();

        r2.RestoreState(snap2);
        Must("T2 restored", r2, "Active/Q/B/1/1/1");

        var snap2b = r2.SaveState();
        var r2b = @@Outer();

        r2b.RestoreState(snap2b);
        if (fmt(r2b) != fmt(r2)) throw new Exception($"FAIL idempotence: {fmt(r2b)} != {fmt(r2)}");

        r2.cycle_inner();
        Must("continue1", r2, "Active/Q/A/1/1/1");
        r2.cycle_mid();
        Must("continue2", r2, "Active/P/A/1/1/1");
        r2.tick();
        Must("continue3", r2, "Idle/P/A/1/1/1");
        r2.tick();
        Must("continue4", r2, "Active/P/A/1/1/2");

        Console.WriteLine("PASS: 85_persist_three_level_nested");
    }
}

@@[target("php")]

@@system StackOps {
    interface:
        push_and_go()
        pop_back()
        do_work(): str
        get_state(): str

    machine:
        $Main {
            push_and_go() {
                echo "Pushing Main to stack, going to Sub\n";
                push$
                -> $Sub
            }

            pop_back() {
                echo "Cannot pop - nothing on stack in Main\n";
            }

            do_work(): str {
                @@:("Working in Main")
                return;
            }

            get_state(): str {
                @@:("Main")
                return;
            }
        }

        $Sub {
            push_and_go() {
                echo "Already in Sub\n";
            }

            pop_back() {
                echo "Popping back to previous state\n";
                -> pop$
            }

            do_work(): str {
                @@:("Working in Sub")
                return;
            }

            get_state(): str {
                @@:("Sub")
                return;
            }
        }
}

echo "=== Test 09: Stack Push/Pop ===" . "\n";
$s = @@StackOps();

$state = $s->get_state();
if ($state !== "Main") { echo "FAIL: Expected 'Main', got '{$state}'\n"; exit(1); }
echo "Initial state: {$state}" . "\n";

$work = $s->do_work();
if ($work !== "Working in Main") { echo "FAIL: Expected 'Working in Main', got '{$work}'\n"; exit(1); }
echo "do_work(): {$work}" . "\n";

$s->push_and_go();
$state = $s->get_state();
if ($state !== "Sub") { echo "FAIL: Expected 'Sub', got '{$state}'\n"; exit(1); }
echo "After push_and_go(): {$state}" . "\n";

$work = $s->do_work();
if ($work !== "Working in Sub") { echo "FAIL: Expected 'Working in Sub', got '{$work}'\n"; exit(1); }
echo "do_work(): {$work}" . "\n";

$s->pop_back();
$state = $s->get_state();
if ($state !== "Main") { echo "FAIL: Expected 'Main' after pop, got '{$state}'\n"; exit(1); }
echo "After pop_back(): {$state}" . "\n";

echo "PASS: Stack push/pop works correctly" . "\n";

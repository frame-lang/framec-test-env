@@[target("kotlin")]

import kotlin.system.exitProcess

// Test 46: HSM Enter Cascade — Parent has $>, Child does not
//
// Tests the HSM enter cascade per docs/frame_runtime_introduction.md
// Step 21+. When entering an HSM child, the kernel fires $> on every
// layer of the new chain top-down (parent first, child last). The child
// may have no $> handler — the cascade simply skips that layer and
// continues.

@@system HSMEnterParentOnly {
    interface:
        go_to_child()
        go_to_parent()
        get_log(): MutableList<Any?>
        get_state(): String

    machine:
        $Start {
            go_to_child() { -> $Child }
            go_to_parent() { -> $Parent }
            get_log(): MutableList<Any?> { @@:(this.log) }
            get_state(): String { @@:("Start") }
        }

        $Child => $Parent {
            go_to_parent() { -> $Parent }
            get_log(): MutableList<Any?> { @@:(this.log) }
            get_state(): String { @@:("Child") }
        }

        $Parent {
            $>() {
                this.log.add("Parent:enter")
            }
            go_to_child() { -> $Child }
            get_log(): MutableList<Any?> { @@:(this.log) }
            get_state(): String { @@:("Parent") }
        }
    domain:
        log = mutableListOf<String>()
}

fun countOf(log: MutableList<*>, v: String): Int {
    var n = 0
    for (item in log) if (item == v) n++
    return n
}

fun main() {
    println("=== Test 46: HSM Enter Cascade — Parent only ===")
    val s = @@HSMEnterParentOnly()

    s.go_to_child()
    if ((s.get_state() as String) != "Child") { println("FAIL"); exitProcess(1) }
    var log = s.get_log() as MutableList<*>
    if (!log.contains("Parent:enter")) { println("FAIL: Expected Parent:enter on cascade"); exitProcess(1) }
    println("TC1: Parent's \$> fires on cascade entry to Child - PASS")

    s.go_to_parent()
    log = s.get_log() as MutableList<*>
    if (countOf(log, "Parent:enter") != 2) { println("FAIL: Expected 2 Parent:enter"); exitProcess(1) }
    println("TC2: Parent's \$> fires again when transitioning directly to Parent - PASS")

    s.go_to_child()
    log = s.get_log() as MutableList<*>
    if (countOf(log, "Parent:enter") != 3) { println("FAIL: Expected 3 Parent:enter"); exitProcess(1) }
    println("TC3: Re-entering Child cascades through Parent again - PASS")

    println("PASS: HSM enter cascade fires Parent's \$> on child entry")
}

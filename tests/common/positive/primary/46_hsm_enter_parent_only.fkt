@@target kotlin

import kotlin.system.exitProcess

@@system HSMEnterParentOnly {
    interface:
        go_to_child()
        go_to_parent()
        get_log(): MutableList<Any?>
        get_state(): String

    machine:
        $Start {
            go_to_child() {
                -> $Child
            }

            go_to_parent() {
                -> $Parent
            }

            get_log(): MutableList<Any?> {
                return this.log
            }

            get_state(): String {
                return "Start"
            }
        }

        $Child => $Parent {
            go_to_parent() {
                -> $Parent
            }

            get_log(): MutableList<Any?> {
                return this.log
            }

            get_state(): String {
                return "Child"
            }
        }

        $Parent {
            $>() {
                this.log.add("Parent:enter")
            }

            go_to_child() {
                -> $Child
            }

            get_log(): MutableList<Any?> {
                return this.log
            }

            get_state(): String {
                return "Parent"
            }
        }
    domain:
        log = mutableListOf<String>()
}

fun main() {
    println("=== Test 46: HSM Enter in Parent Only ===")
    val s = @@HSMEnterParentOnly()

    // TC2.2.1: Child enters without error (no enter handler)
    s.go_to_child()
    if ((s.get_state() as String) != "Child") {
        println("FAIL: Expected Child, got ${s.get_state()}")
        exitProcess(1)
    }
    var log = s.get_log() as MutableList<*>
    println("TC2.2.1: Child enters without error (log: $log) - PASS")

    // TC2.2.2: Parent's enter does NOT auto-fire when child is entered
    if (log.contains("Parent:enter")) {
        println("FAIL: Parent:enter should NOT fire for child entry, got $log")
        exitProcess(1)
    }
    println("TC2.2.2: Parent enter NOT auto-fired for child - PASS")

    // TC2.2.3: Parent enter only fires when transitioning directly TO parent
    s.go_to_parent()
    if ((s.get_state() as String) != "Parent") {
        println("FAIL: Expected Parent, got ${s.get_state()}")
        exitProcess(1)
    }
    log = s.get_log() as MutableList<*>
    if (!log.contains("Parent:enter")) {
        println("FAIL: Expected Parent:enter when transitioning to Parent, got $log")
        exitProcess(1)
    }
    println("TC2.2.3: Parent enter fires when transitioning to Parent - PASS")

    // TC2.2.4: Going back to child from parent
    s.go_to_child()
    if ((s.get_state() as String) != "Child") {
        println("FAIL: Expected Child, got ${s.get_state()}")
        exitProcess(1)
    }
    log = s.get_log() as MutableList<*>
    var count = 0
    for (item in log) {
        if (item == "Parent:enter") count++
    }
    if (count != 1) {
        println("FAIL: Expected exactly 1 Parent:enter, got $log")
        exitProcess(1)
    }
    println("TC2.2.4: Return to child, parent enter count unchanged - PASS")

    println("PASS: HSM enter in parent only works correctly")
}

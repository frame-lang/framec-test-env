@@[target("c")]

#include <stdio.h>
#include <stdlib.h>

@@system Demo {
    interface:
        get_a(): int
        get_c_only(): int
    machine:
        $S {
            get_a(): int { @@:(self->a) }
            get_c_only(): int { @@:(self->c_only) }
        }
    domain:
        a: int = 1
        @@[target("python_3")] py_only: int = 2
        @@[target("c")]
        c_only: int = 42
}

int main(void) {
    Demo* d = Demo_new();
    if (Demo_get_a(d) != 1) { printf("FAIL get_a: %d\n", Demo_get_a(d)); exit(1); }
    if (Demo_get_c_only(d) != 42) { printf("FAIL get_c_only: %d\n", Demo_get_c_only(d)); exit(1); }
    printf("PASS: 90_attribute_domain_field\n");
    Demo_destroy(d);
    return 0;
}

<?php
@@[target("php")]

@@[persist]
@@system PersistHsmStateArgs {
    operations:
        @@[save]
        save_state(): string {}

        @@[load]
        restore_state(data: string) {}

    interface:
        drive(p: int)
        get_x(): int

    machine:
        $Start {
            drive(p: int) {
                -> $Child(p)
            }
            get_x(): int {
                @@:(-1)
                return;
            }
        }

        $Child => $Parent(x: int) {
            drive(p: int) {
                -> $Child(p)
            }
            get_x(): int {
                @@:($x)
                return;
            }
        }

        $Parent {
        }
    domain:
        v: int = 0
}

echo "=== Test 57: Persist HSM × State-Args Round-Trip (PHP) ===\n";

$s1 = new PersistHsmStateArgs();
$s1->drive(42);
$pre = $s1->get_x();
if ($pre !== 42) { echo "FAIL: pre $pre\n"; exit(1); }
echo "1. Pre-save x=$pre\n";

$snap = $s1->save_state();
$s2 = new PersistHsmStateArgs();

$s2->restore_state($snap);
$post = $s2->get_x();
if ($post !== 42) { echo "FAIL: post $post\n"; exit(1); }
echo "2. Post-restore x=$post\n";

$s2->drive(99);
$post2 = $s2->get_x();
if ($post2 !== 99) { echo "FAIL: post2 $post2\n"; exit(1); }
echo "3. Post-restore-drive x=$post2\n";

echo "PASS: 57_persist_hsm_state_args\n";

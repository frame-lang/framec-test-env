@@[target("swift")]


@@system DictStateArg {
    interface:
        configure(m: [String: Int])
        get_v(key: String): Int
        size(): Int

    machine:
        $Idle {
            configure(m: [String: Int]) { -> $Active(m) }
            get_v(key: String): Int { @@:(-1) }
            size(): Int { @@:(0) }
        }
        $Active(m: [String: Int]) {
            configure(m: [String: Int]) { -> $Active(m) }
            get_v(key: String): Int { @@:(m[key] ?? -1) }
            size(): Int { @@:(m.count) }
        }
    domain:
        n : Int = 0
}

let s = @@DictStateArg()
if s.get_v("a") != -1 { print("FAIL idle"); exit(1) }
if s.size() != 0 { print("FAIL idle size"); exit(1) }
s.configure(["a": 10, "b": 20])
if s.get_v("a") != 10 { print("FAIL a"); exit(1) }
if s.get_v("b") != 20 { print("FAIL b"); exit(1) }
if s.size() != 2 { print("FAIL size"); exit(1) }
s.configure(["x": 99])
if s.get_v("x") != 99 { print("FAIL x"); exit(1) }
if s.size() != 1 { print("FAIL size2"); exit(1) }
print("PASS: 76_dict_state_arg")

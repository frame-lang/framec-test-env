@@target dart

@@system WithInterface {
    interface:
        greet(name: String): String
        get_count(): int

    machine:
        $Ready {
            greet(name: String): String {
                this.call_count += 1;
                @@:("Hello, ${name}!")
                return;
            }

            get_count(): int {
                @@:(this.call_count)
                return;
            }
        }
    domain:
        call_count: int = 0
}

void main() {
    print("== Test 02: Interface Methods ==");
    final s = @@WithInterface();

    // Test interface method with parameter and return
    final result = s.greet("World");
    if (result != "Hello, World!") {
        throw Exception("Expected 'Hello, World!', got '${result}'");
    }
    print("greet('World') = ${result}");

    // Test domain variable access through interface
    var count = s.get_count();
    if (count != 1) {
        throw Exception("Expected count=1, got ${count}");
    }
    print("get_count() = ${count}");

    // Call again to verify state
    s.greet("Frame");
    final count2 = s.get_count();
    if (count2 != 2) {
        throw Exception("Expected count=2, got ${count2}");
    }
    print("After second call: get_count() = ${count2}");

    print("PASS: Interface methods work correctly");
}


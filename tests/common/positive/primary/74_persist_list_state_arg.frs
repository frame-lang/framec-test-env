@@target rust

@@persist
@@system PersistList {
    interface:
        configure(items: Vec<i32>)
        first_item(): i32
        size(): i32

    machine:
        $Idle {
            configure(items: Vec<i32>) {
                -> $Active(items)
            }
            first_item(): i32 { @@:(-1); return; }
            size(): i32 { @@:(0); return; }
        }
        $Active(items: Vec<i32>) {
            configure(items: Vec<i32>) {
                -> $Active(items)
            }
            first_item(): i32 { @@:(items[0]); return; }
            size(): i32 { @@:(items.len() as i32); return; }
        }
    domain:
        n: i32
}

fn main() {
    let mut s1 = @@PersistList();
    s1.configure(vec![10, 20, 30]);
    if s1.first_item() != 10 { println!("FAIL pre"); std::process::exit(1); }
    let snapshot = s1.save_state();

    let mut s2 = PersistList::restore_state(&snapshot);
    if s2.first_item() != 10 { println!("FAIL restored first_item"); std::process::exit(1); }
    if s2.size() != 3 { println!("FAIL restored size"); std::process::exit(1); }
    println!("PASS: 74_persist_list_state_arg");
}

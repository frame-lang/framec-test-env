@@target python_3

# Test 47: HSM Enter in Both Child and Parent
#
# Tests enter handler in both levels:
# - Only child's enter fires when entering child
# - Parent's enter fires only when transitioning to parent
# - No implicit cascading of enter handlers

@@system HSMEnterBoth {
    interface:
        go_to_child()
        go_to_parent()
        get_log(): list
        get_state(): str

    machine:
        $Start {
            go_to_child() {
                -> $Child
            }

            go_to_parent() {
                -> $Parent
            }

            get_log(): list {
                @@:(self.log)
                return
            }

            get_state(): str {
                @@:("Start")
                return
            }
        }

        $Child => $Parent {
            $>() {
                self.log.append("Child:enter")
            }

            go_to_parent() {
                -> $Parent
            }

            get_log(): list {
                @@:(self.log)
                return
            }

            get_state(): str {
                @@:("Child")
                return
            }
        }

        $Parent {
            $>() {
                self.log.append("Parent:enter")
            }

            go_to_child() {
                -> $Child
            }

            get_log(): list {
                @@:(self.log)
                return
            }

            get_state(): str {
                @@:("Parent")
                return
            }
        }
    domain:
        log: list = []
}

def main():
    print("=== Test 47: HSM Enter in Both ===")
    s = @@HSMEnterBoth()

    # TC2.3.1: Only child's enter fires when entering child
    s.go_to_child()
    log = s.get_log()
    assert "Child:enter" in log, f"Expected Child:enter, got {log}"
    assert "Parent:enter" not in log, f"Parent:enter should NOT fire when entering child, got {log}"
    assert s.get_state() == "Child", f"Expected Child, got {s.get_state()}"
    print(f"TC2.3.1: Only child's enter fires when entering child - PASS")

    # TC2.3.2: Parent's enter fires only when transitioning to parent
    s.go_to_parent()
    log = s.get_log()
    assert "Parent:enter" in log, f"Expected Parent:enter, got {log}"
    assert s.get_state() == "Parent", f"Expected Parent, got {s.get_state()}"
    print(f"TC2.3.2: Parent's enter fires when transitioning to parent - PASS")

    # TC2.3.3: No implicit cascading - counts should be exactly 1 each
    assert log.count("Child:enter") == 1, f"Expected exactly 1 Child:enter, got {log}"
    assert log.count("Parent:enter") == 1, f"Expected exactly 1 Parent:enter, got {log}"
    print(f"TC2.3.3: No implicit cascading of enter handlers - PASS")

    # TC2.3.4: Going back to child fires child enter again
    s.go_to_child()
    log = s.get_log()
    assert log.count("Child:enter") == 2, f"Expected 2 Child:enter, got {log}"
    assert log.count("Parent:enter") == 1, f"Expected still 1 Parent:enter, got {log}"
    print(f"TC2.3.4: Re-entering child fires child enter again - PASS")

    print("PASS: HSM enter in both works correctly")

if __name__ == '__main__':
    main()

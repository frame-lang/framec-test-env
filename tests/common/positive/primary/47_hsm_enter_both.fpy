@@target python_3

# Test 47: HSM Enter in Both Child and Parent
#
# Tests enter handler in both levels:
# - Only child's enter fires when entering child
# - Parent's enter fires only when transitioning to parent
# - No implicit cascading of enter handlers

@@system HSMEnterBoth {
    interface:
        go_to_child()
        go_to_parent()
        get_log(): list
        get_state(): str

    machine:
        $Start {
            go_to_child() {
                -> $Child
            }

            go_to_parent() {
                -> $Parent
            }

            get_log(): list {
                @@:(self.log)
                return
            }

            get_state(): str {
                @@:("Start")
                return
            }
        }

        $Child => $Parent {
            $>() {
                self.log.append("Child:enter")
            }

            go_to_parent() {
                -> $Parent
            }

            get_log(): list {
                @@:(self.log)
                return
            }

            get_state(): str {
                @@:("Child")
                return
            }
        }

        $Parent {
            $>() {
                self.log.append("Parent:enter")
            }

            go_to_child() {
                -> $Child
            }

            get_log(): list {
                @@:(self.log)
                return
            }

            get_state(): str {
                @@:("Parent")
                return
            }
        }
    domain:
        log: list = []
}

def main():
    print("=== Test 47: HSM Enter Cascade — Both ===")
    s = @@HSMEnterBoth()

    # TC1: Entering Child fires Parent's $> first (top-down cascade),
    # then Child's $>.
    s.go_to_child()
    log = s.get_log()
    assert s.get_state() == "Child", f"Expected Child, got {s.get_state()}"
    assert "Parent:enter" in log, f"Expected Parent:enter (cascade), got {log}"
    assert "Child:enter" in log, f"Expected Child:enter, got {log}"
    parent_idx = log.index("Parent:enter")
    child_idx = log.index("Child:enter")
    assert parent_idx < child_idx, f"Parent:enter should fire BEFORE Child:enter (top-down), got {log}"
    print("TC1: Parent's $> fires before Child's $> on cascade entry - PASS")

    # TC2: Direct entry to Parent fires Parent's $> only.
    s.go_to_parent()
    log = s.get_log()
    assert s.get_state() == "Parent", f"Expected Parent, got {s.get_state()}"
    parent_count = log.count("Parent:enter")
    child_count = log.count("Child:enter")
    assert parent_count == 2, f"Expected 2 Parent:enter (cascade + direct), got {parent_count}: {log}"
    assert child_count == 1, f"Expected still 1 Child:enter, got {child_count}: {log}"
    print("TC2: Direct Parent entry fires only Parent's $> - PASS")

    # TC3: Transitioning back to Child fires both cascades.
    s.go_to_child()
    log = s.get_log()
    parent_count = log.count("Parent:enter")
    child_count = log.count("Child:enter")
    assert parent_count == 3, f"Expected 3 Parent:enter total, got {parent_count}: {log}"
    assert child_count == 2, f"Expected 2 Child:enter total, got {child_count}: {log}"
    print("TC3: Re-entering Child cascades through Parent again - PASS")

    print("PASS: HSM enter cascade fires both layers top-down")

if __name__ == '__main__':
    main()

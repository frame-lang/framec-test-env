
@@target c

@@system NativeTest {
    interface:
        compute(x: int): int

    machine:
        $Start {
            compute(x: int): int {
                // Native C code interleaved with Frame
                int doubled = x * 2;
                int tripled = x * 3;
                int result = doubled + tripled;
                @@:(result)
                return;
            }
        }
}

int main() {
    printf("=== Test 04: Native Code in Handlers ===\n");
    NativeTest* s = @@NativeTest();

    int result = NativeTest_compute(s, 10);
    printf("compute(10) = %d (expected: 50)\n", result);
    if (result != 50) {
        printf("FAIL: Expected 50, got %d\n", result);
        return 1;
    }

    printf("PASS: Native code in handlers works correctly\n");
    NativeTest_destroy(s);
    return 0;
}

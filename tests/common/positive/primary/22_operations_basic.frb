@@target ruby

@@system OperationsTest {
    operations:
        add(x: int, y: int): int {
            return x + y
        }

        multiply(x: int, y: int): int {
            return x * y
        }

        static factorial(n: int): int {
            if n <= 1
                return 1
            end
            return n * OperationsTest.factorial(n - 1)
        }

        static is_even(n: int): bool {
            return n % 2 == 0
        }

    interface:
        compute(a: int, b: int): int
        get_last_result(): int

    machine:
        $Ready {
            compute(a: int, b: int): int {
                # Use instance operations
                sum_val = self.add(a, b)
                prod_val = self.multiply(a, b)
                last_result = sum_val + prod_val
                return last_result
            }

            get_last_result(): int {
                return last_result
            }
        }

    domain:
        last_result: int = 0

}

puts("=== Test 22: Operations Basic ===")
s = OperationsTest.new

# Test 1: Instance operations
result = s.add(3, 4)
raise "Expected 7, got #{result}" unless result == 7
puts("1. add(3, 4) = #{result}")

result = s.multiply(3, 4)
raise "Expected 12, got #{result}" unless result == 12
puts("2. multiply(3, 4) = #{result}")

# Test 2: Operations used in handler
result = s.compute(3, 4)
# compute returns add(3,4) + multiply(3,4) = 7 + 12 = 19
raise "Expected 19, got #{result}" unless result == 19
puts("3. compute(3, 4) = #{result}")

# Test 3: Static operations
result = OperationsTest.factorial(5)
raise "Expected 120, got #{result}" unless result == 120
puts("4. factorial(5) = #{result}")

result = OperationsTest.is_even(4)
raise "Expected true, got #{result}" unless result == true
puts("5. is_even(4) = #{result}")

result = OperationsTest.is_even(7)
raise "Expected false, got #{result}" unless result == false
puts("6. is_even(7) = #{result}")

# Test 4: Static can also be called on instance
result = s.factorial(4)
raise "Expected 24, got #{result}" unless result == 24
puts("7. instance.factorial(4) = #{result}")

puts("PASS: Operations basic works correctly")

@@[target("lua")]

@@system Demo {
    interface:
        common(): string
        @@[target("python_3")] only_py(): string
        @@[target("lua")] only_lua(): string

    machine:
        $S {
            common(): string { @@:("common") }
            @@[target("python_3")] only_py(): string { @@:("only_py_present") }
            @@[target("lua")] only_lua(): string { @@:("only_lua_present") }
        }
}

local d = Demo:new()
if d:common() ~= "common" then print("FAIL common: " .. tostring(d:common())); os.exit(1) end
if d:only_lua() ~= "only_lua_present" then print("FAIL only_lua: " .. tostring(d:only_lua())); os.exit(1) end
if d.only_py ~= nil then print("FAIL: only_py should have been filtered out by @@[target(\"python_3\")]"); os.exit(1) end
print("PASS: 89_attribute_per_item")

@@target swift

// Test: @@:self.method() — reentrant interface call with transition guard
//
// Validates:
// 1. Basic self-call dispatch (calls own interface method through kernel)
// 2. Return value propagation from self-call
// 3. Transition guard (code after self-call that transitions is suppressed)

@@system SelfCallTest {
    interface:
        calibrate(): string
        reading(): Double
        trigger_transition()
        check_after_transition(): string
        status(): string

    machine:
        $Active {
            calibrate(): string {
                let baseline = @@:self.reading()
                let baselineVal = baseline as! Double
                self.offset = baselineVal * -1
                @@:("calibrated:offset=\(self.offset)")
            }

            reading(): Double {
                @@:(self.raw_value + self.offset)
            }

            trigger_transition() {
                -> $Done
            }

            check_after_transition(): string {
                self.trace = "before"
                @@:self.trigger_transition()
                // This line should NOT execute — transition guard suppresses it
                self.trace = "after"
                @@:(self.trace)
            }

            status(): string {
                @@:("active")
            }
        }

        $Done {
            status(): string {
                @@:("done")
            }
        }

    domain:
        raw_value: Double = 42.0
        offset: Double = 0.0
        trace: string = ""
}

// main
    let s = @@SelfCallTest()

    // Test 1: Self-call returns correct value
    let result = s.calibrate()
    if result != "calibrated:offset=-42.0" { fatalError("Expected 'calibrated:offset=-42.0', got '\(result)'") }

    // Test 2: Self-call modified domain state correctly
    let r = s.reading()
    if r != 0.0 { fatalError("Expected 0.0 after calibration, got \(r)") }

    // Test 3: Transition guard — code after self-call that transitions is suppressed
    let s2 = @@SelfCallTest()
    s2.check_after_transition()
    if s2.trace != "before" { fatalError("Expected 'before' (guard suppressed 'after'), got '\(s2.trace)'") }

    // Test 4: System transitioned to $Done
    let st = s2.status()
    if st != "done" { fatalError("Expected 'done' after transition, got '\(st)'") }

    print("PASS: self_call")

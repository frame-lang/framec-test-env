@@target lua
@@system SystemReturnChainTest {
    interface:
        test_enter_sets(): str
        test_exit_then_enter(): str
        get_state(): str

    machine:
        $Start {
            test_enter_sets(): str {
                -> $EnterSetter
            }

            test_exit_then_enter(): str {
                -> $BothSet
            }

            get_state(): str {
                @@:("Start")
                return
            }

            <$() {
                @@:("from_exit")
                -- Exit handler sets initial value
            }
        }

        $EnterSetter {
            $>() {
                @@:("from_enter")
                -- Enter handler sets return value
            }

            get_state(): str {
                @@:("EnterSetter")
                return
            }
        }

        $BothSet {
            $>() {
                @@:("enter_wins")
                -- Enter handler sets return - should overwrite exit's value
            }

            get_state(): str {
                @@:("BothSet")
                return
            }
        }
}

@@[target("java")]
@@[create(make)]
@@system Counter(seed: int) {
    interface:
        bump()
        get(): int

    machine:
        $A {
            bump() { this.count = this.count + 1; }
            get(): int { @@:(this.count) }
        }

    domain:
        seed: int = seed
        count: int = 0
}

class Main {
    public static void main(String[] args) {
        Counter c1 = new Counter(42);
        c1.bump();
        c1.bump();
        if (c1.get() != 2) {
            System.out.println("FAIL: via new Counter expected 2, got " + c1.get());
            return;
        }

        Counter c2 = Counter.make(99);
        c2.bump();
        if (c2.get() != 1) {
            System.out.println("FAIL: via Counter.make expected 1, got " + c2.get());
            return;
        }

        System.out.println("PASS: rfc0015_create_rename");
    }
}

@@target lua

@@system HsmIfStateArgs {
    interface:
        enter_active(t: int)
        classify(v: int): int

    machine:
        $Idle {
            enter_active(t: int) {
                -> $Active(t)
            }
            classify(v: int): int {
                @@:(-1)
                return
            }
        }

        $Active => $Frame(threshold: int) {
            enter_active(t: int) {
                -> $Active(t)
            }
            classify(v: int): int {
                if v > threshold then
                    @@:(1)
                else
                    @@:(0)
                end
                return
            }
        }

        $Frame {
        }
    domain:
        n: int = 0
}

print("=== Test 62: HSM × if × state-args (Lua) ===")
local s = HsmIfStateArgs.new()

local pre = s:classify(5)
if pre ~= -1 then error("Expected -1 in Idle, got " .. tostring(pre)) end
print("1. Idle classify(5) = " .. tostring(pre))

s:enter_active(10)
local under = s:classify(5)
if under ~= 0 then error("Expected 0 (under), got " .. tostring(under)) end
print("2. classify(5) with threshold=10 → " .. tostring(under))

local over = s:classify(15)
if over ~= 1 then error("Expected 1 (over), got " .. tostring(over)) end
print("3. classify(15) with threshold=10 → " .. tostring(over))

local eq = s:classify(10)
if eq ~= 0 then error("Expected 0 (eq), got " .. tostring(eq)) end
print("4. classify(10) with threshold=10 → " .. tostring(eq))

s:enter_active(50)
local newUnder = s:classify(15)
if newUnder ~= 0 then error("Expected 0, got " .. tostring(newUnder)) end
print("5. classify(15) with threshold=50 → " .. tostring(newUnder))

print("PASS: 62_hsm_if_state_args")

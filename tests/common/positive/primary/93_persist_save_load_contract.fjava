@@[target("java")]

import java.util.*;

@@[persist]
@@system Counter {
    operations:
        @@[save]
        save_op(): String {}

        @@[load]
        load_op(data: String) {}

    interface:
        bump()
        get_n(): int

    machine:
        $Active {
            bump() {
                this.n = this.n + 1;
            }
            get_n(): int { @@:(this.n) }
        }

    domain:
        n: int = 0
}

class Main {
    public static void main(String[] args) {
        Counter c1 = new Counter();
        c1.bump();
        c1.bump();
        c1.bump();
        String data = c1.save_op();

        Counter c2 = new Counter();
        c2.load_op(data);
        if (c2.get_n() != 3) {
            System.out.println("FAIL: expected 3, got " + c2.get_n());
            return;
        }
        System.out.println("PASS: 93_persist_save_load_contract");
    }
}

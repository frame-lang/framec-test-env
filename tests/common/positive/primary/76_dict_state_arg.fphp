@@[target("php")]


@@system DictStateArg {
    interface:
        configure(m: array)
        get_v(key: string): int
        size(): int

    machine:
        $Idle {
            configure(m: array) { -> $Active(m) }
            get_v(key: string): int { @@:(-1) }
            size(): int { @@:(0) }
        }
        $Active(m: array) {
            configure(m: array) { -> $Active(m) }
            get_v(key: string): int { @@:(array_key_exists($key, $m) ? $m[$key] : -1) }
            size(): int { @@:(count($m)) }
        }
    domain:
        n: int = 0
}

$s = @@DictStateArg();
if ($s->get_v("a") !== -1) { echo "FAIL idle\n"; exit(1); }
if ($s->size() !== 0) { echo "FAIL idle size\n"; exit(1); }
$s->configure(["a" => 10, "b" => 20]);
if ($s->get_v("a") !== 10) { echo "FAIL a\n"; exit(1); }
if ($s->get_v("b") !== 20) { echo "FAIL b\n"; exit(1); }
if ($s->size() !== 2) { echo "FAIL size\n"; exit(1); }
$s->configure(["x" => 99]);
if ($s->get_v("x") !== 99) { echo "FAIL x\n"; exit(1); }
if ($s->size() !== 1) { echo "FAIL size2\n"; exit(1); }
echo "PASS: 76_dict_state_arg\n";

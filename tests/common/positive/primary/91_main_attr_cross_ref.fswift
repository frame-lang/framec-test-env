@@[target("swift")]

@@system Sub {
    interface:
        ping(): Int
    machine:
        $Idle {
            ping(): Int { @@:(42) }
        }
}

@@[main]
@@system Top {
    interface:
        run(): Int
    machine:
        $Active {
            run(): Int { @@:(self.sub.ping()) }
        }
    domain:
        sub: Sub = @@Sub()
}

let t = Top()
if t.run() != 42 {
    print("FAIL run(): \(t.run())")
} else {
    print("PASS: 91_main_attr_cross_ref")
}

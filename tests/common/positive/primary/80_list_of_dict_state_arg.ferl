@@[target("erlang")]
@@[persist]
@@system ListOfDict {
    operations:
        @@[save]
        save_state() {}

        @@[load]
        load_state(data) {}

    interface:
        configure(rows: list)
        getAt(idx: int, key: string): int
    machine:
        $Idle {
            configure(rows: list) { -> $Active(rows) }
            getAt(idx: int, key: string): int { @@:(-1) }
        }
        $Active(rows: list) {
            configure(rows: list) { -> $Active(rows) }
            getAt(idx: int, key: string): int {
                @@:(if Idx < length(Rows) -> maps:get(Key, lists:nth(Idx + 1, Rows), -1); true -> -1 end)
            }
        }
    domain:
        n = 0
}

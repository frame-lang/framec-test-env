@@[target("php")]

<?php

@@[persist(string)]
@@[save(save_state)]
@@[load(restore_state)]
@@system ListOfDict {
    interface:
        configure(rows: array)
        get_at(idx: int, key: string): int

    machine:
        $Idle {
            configure(rows: array) { -> $Active(rows) }
            get_at(idx: int, key: string): int { @@:(-1) }
        }
        $Active(rows: array) {
            configure(rows: array) { -> $Active(rows) }
            get_at(idx: int, key: string): int {
                @@:($idx < count($rows) && isset($rows[$idx][$key]) ? $rows[$idx][$key] : -1)
            }
        }
    domain:
        n: int = 0
}

$s1 = new ListOfDict();
$s1->configure([["x" => 1, "y" => 2], ["z" => 3]]);
if ($s1->get_at(0, "x") !== 1) { echo "FAIL pre 0.x\n"; exit(1); }
if ($s1->get_at(1, "z") !== 3) { echo "FAIL pre 1.z\n"; exit(1); }
$snap = $s1->save_state();
$s2 = new ListOfDict();

$s2->restore_state($snap);
if ($s2->get_at(0, "x") !== 1) { echo "FAIL post 0.x\n"; exit(1); }
if ($s2->get_at(0, "y") !== 2) { echo "FAIL post 0.y\n"; exit(1); }
if ($s2->get_at(1, "z") !== 3) { echo "FAIL post 1.z\n"; exit(1); }
echo "PASS: 80_list_of_dict_state_arg\n";

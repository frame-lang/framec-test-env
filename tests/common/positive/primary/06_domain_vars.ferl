@@target erlang

@@system DomainVars {
    interface:
        getName(): str
        setName(name: str)
        getCount(): int
        incCount()

    machine:
        $Active {
            getName(): str {
                @@:(self.name)
                return
            }
            setName(name: str) {
                self.name = name
            }
            getCount(): int {
                @@:(self.count)
                return
            }
            incCount() {
                self.count = self.count + 1
            }
        }

    domain:
        name = "default"
        count = 0
}

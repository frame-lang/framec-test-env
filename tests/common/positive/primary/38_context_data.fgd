@@[target("gdscript")]
extends SceneTree

# Test: Context Data (@@:data)
# Validates call-scoped data that persists across handler -> <$ -> $> chain

@@system ContextDataTest {
    interface:
        process_with_data(value: int): String
        check_data_isolation(): String
        transition_preserves_data(x: int): String

    machine:
        $Start {
            process_with_data(value: int): String {
                # Set data in handler
                @@:data.input = @@:params.value
                @@:data.trace = ["handler"]

                @@:("processed:" + str(@@:data.input))
            }

            check_data_isolation(): String {
                # Set data, call another method, verify our data preserved
                @@:data.outer = "outer_value"

                # This creates its own context with its own data
                var inner_result = self.process_with_data(99)

                # Our data should still be here
                @@:("outer_data=" + @@:data.outer + ",inner=" + inner_result)
            }

            transition_preserves_data(x: int): String {
                # Set data, transition, verify data available in lifecycle handlers
                @@:data.started_in = "Start"
                @@:data.value = str(@@:params.x)
                -> $End
            }

            <$() {
                # Exit handler can access data set by event handler
                @@:data.exit_seen = "true"
            }
        }

        $End {
            $>() {
                # Enter handler can access data set by previous handlers
                @@:data.ended_in = "End"

                # Build final result from accumulated data
                @@:("from=" + str(@@:data.started_in) + ",to=" + str(@@:data.ended_in) + ",value=" + str(@@:data.value) + ",exit_seen=" + str(@@:data.exit_seen))
            }
        }
}

func main():
    print("=== Test 38: Context Data ===")

    # Test 1: Basic data set/get
    var s1 = @@ContextDataTest()
    var result = s1.process_with_data(42)
    assert(result == "processed:42", "Expected 'processed:42', got '" + str(result) + "'")
    print("1. process_with_data(42) = '" + str(result) + "'")

    # Test 2: Data isolation between nested calls
    var s2 = @@ContextDataTest()
    result = s2.check_data_isolation()
    var expected = "outer_data=outer_value,inner=processed:99"
    assert(result == expected, "Expected '" + str(expected) + "', got '" + str(result) + "'")
    print("2. check_data_isolation() = '" + str(result) + "'")

    # Test 3: Data preserved across transition (handler -> <$ -> $>)
    var s3 = @@ContextDataTest()
    result = s3.transition_preserves_data(100)
    # Data should flow: handler sets -> exit accesses -> enter accesses and returns
    assert("from=Start" in result, "Expected 'from=Start' in '" + str(result) + "'")
    assert("to=End" in result, "Expected 'to=End' in '" + str(result) + "'")
    assert("value=100" in result, "Expected 'value=100' in '" + str(result) + "'")
    assert("exit_seen=true" in result, "Expected 'exit_seen=true' in '" + str(result) + "'")
    print("3. transition_preserves_data(100) = '" + str(result) + "'")

    print("PASS: Context data works correctly")

func _init():
    main()
    quit()

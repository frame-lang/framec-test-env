<?php
@@target php

@@system WithParams {
    interface:
        start(initial: int)
        add(value: int)
        multiply(a: int, b: int): int
        get_total(): int

    machine:
        $Idle {
            start(initial: int) {
                $this->total = $initial;
                echo "Started with initial value: {$initial}\n";
                -> $Running
            }

            add(value: int) {
                echo "Cannot add in Idle state\n";
            }

            multiply(a: int, b: int): int {
                return 0;
            }

            get_total(): int {
                return $this->total;
            }
        }

        $Running {
            start(initial: int) {
                echo "Already running\n";
            }

            add(value: int) {
                $this->total += $value;
                echo "Added {$value}, total is now " . $this->total . "\n";
            }

            multiply(a: int, b: int): int {
                $result = $a * $b;
                $this->total += $result;
                echo "Multiplied {$a} * {$b} = {$result}, total is now " . $this->total . "\n";
                return $result;
            }

            get_total(): int {
                return $this->total;
            }
        }
    domain:
        total = 0
}

echo "=== Test 07: Handler Parameters ===" . "\n";
$s = new WithParams();

$total = $s->get_total();
if ($total !== 0) { echo "FAIL: Expected initial total=0, got {$total}\n"; exit(1); }

$s->start(100);
$total = $s->get_total();
if ($total !== 100) { echo "FAIL: Expected total=100, got {$total}\n"; exit(1); }
echo "After start(100): total = {$total}" . "\n";

$s->add(25);
$total = $s->get_total();
if ($total !== 125) { echo "FAIL: Expected total=125, got {$total}\n"; exit(1); }
echo "After add(25): total = {$total}" . "\n";

$result = $s->multiply(3, 5);
if ($result !== 15) { echo "FAIL: Expected multiply result=15, got {$result}\n"; exit(1); }
$total = $s->get_total();
if ($total !== 140) { echo "FAIL: Expected total=140, got {$total}\n"; exit(1); }
echo "After multiply(3,5): result = {$result}, total = {$total}" . "\n";

echo "PASS: Handler parameters work correctly" . "\n";

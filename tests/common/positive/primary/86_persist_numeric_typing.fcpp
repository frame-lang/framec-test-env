@@[target("cpp")]

#include <iostream>
#include <string>
#include <cmath>
#include <nlohmann/json.hpp>

@@[persist(std::string)]
@@[save(save_state)]
@@[load(restore_state)]
@@system Inner {
    interface:
        bump_int()
        bump_float()
        flip_bool()
        get_n_int(): int
        get_n_float(): double
        get_n_bool(): bool
        get_n_str(): std::string

    machine:
        $S {
            bump_int() { this->n_int = this->n_int + 1; }
            bump_float() { this->n_float = this->n_float + 0.25; }
            flip_bool() { this->n_bool = !this->n_bool; }
            get_n_int(): int { @@:(this->n_int) }
            get_n_float(): double { @@:(this->n_float) }
            get_n_bool(): bool { @@:(this->n_bool) }
            get_n_str(): std::string { @@:(this->n_str) }
        }
    domain:
        n_int: int = 7
        n_float: double = 2.5
        n_bool: bool = true
        n_str: std::string = "hello"
}@@[persist(std::string)]
@@[save(save_state)]
@@[load(restore_state)]


@@[main]
@@system Outer {
    interface:
        bump_k_int()
        bump_k_float()
        bump_inner_int()
        bump_inner_float()
        flip_inner_bool()
        get_k_int(): int
        get_k_float(): double
        get_n_int(): int
        get_n_float(): double
        get_n_bool(): bool
        get_n_str(): std::string

    machine:
        $S {
            bump_k_int() { this->k_int = this->k_int + 1; }
            bump_k_float() { this->k_float = this->k_float + 0.25; }
            bump_inner_int() { this->inner->bump_int(); }
            bump_inner_float() { this->inner->bump_float(); }
            flip_inner_bool() { this->inner->flip_bool(); }
            get_k_int(): int { @@:(this->k_int) }
            get_k_float(): double { @@:(this->k_float) }
            get_n_int(): int { @@:(this->inner->get_n_int()) }
            get_n_float(): double { @@:(this->inner->get_n_float()) }
            get_n_bool(): bool { @@:(this->inner->get_n_bool()) }
            get_n_str(): std::string { @@:(this->inner->get_n_str()) }
        }
    domain:
        k_int: int = 42
        k_float: double = 1.25
        inner: Inner = @@Inner()
}

void assertState(Outer& o, const std::string& label, const std::string& kIntStr, double kFloat, const std::string& nIntStr, double nFloat, bool nBool, const std::string& nStr) {
    if (std::to_string(o.get_k_int()) != kIntStr) { std::cout << "FAIL " << label << " k_int: " << o.get_k_int() << std::endl; std::exit(1); }
    if (std::to_string(o.get_n_int()) != nIntStr) { std::cout << "FAIL " << label << " n_int: " << o.get_n_int() << std::endl; std::exit(1); }
    if (std::abs(o.get_k_float() - kFloat) > 1e-9) { std::cout << "FAIL " << label << " k_float: " << o.get_k_float() << std::endl; std::exit(1); }
    if (std::abs(o.get_n_float() - nFloat) > 1e-9) { std::cout << "FAIL " << label << " n_float: " << o.get_n_float() << std::endl; std::exit(1); }
    if (o.get_n_bool() != nBool) { std::cout << "FAIL " << label << " n_bool: " << o.get_n_bool() << std::endl; std::exit(1); }
    if (o.get_n_str() != nStr) { std::cout << "FAIL " << label << " n_str: " << o.get_n_str() << std::endl; std::exit(1); }
}

int main() {
    Outer o;
    assertState(o, "T0", "42", 1.25, "7", 2.5, true, "hello");

    o.bump_k_int();
    o.bump_k_float();
    o.bump_inner_int();
    o.bump_inner_float();
    o.flip_inner_bool();
    assertState(o, "T1", "43", 1.5, "8", 2.75, false, "hello");

    std::string snap = o.save_state();
    Outer r;

    r.restore_state(snap);
    assertState(r, "T1 restored", "43", 1.5, "8", 2.75, false, "hello");

    r.bump_k_int();
    r.bump_inner_int();
    assertState(r, "continue", "44", 1.5, "9", 2.75, false, "hello");

    std::cout << "PASS: 86_persist_numeric_typing" << std::endl;
    return 0;
}

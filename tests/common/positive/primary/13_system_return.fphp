<?php
@@target php

@@system SystemReturnTest {
    interface:
        add(a: int, b: int): int
        multiply(a: int, b: int): int
        greet(name: str): str
        get_value(): int

    machine:
        $Calculator {
            $.value: int = 0

            add(a: int, b: int): int {
                return $a + $b;
            }

            multiply(a: int, b: int): int {
                @@:return = $a * $b
            }

            greet(name: str): str {
                return "Hello, " . $name . "!";
            }

            get_value(): int {
                $.value = 42;
                return $.value;
            }
        }
}

echo "=== Test 13: System Return ===" . "\n";
$calc = new SystemReturnTest();

$result = $calc->add(3, 5);
if ($result !== 8) { echo "FAIL: Expected 8, got {$result}\n"; exit(1); }
echo "add(3, 5) = {$result}" . "\n";

$result = $calc->multiply(4, 7);
if ($result !== 28) { echo "FAIL: Expected 28, got {$result}\n"; exit(1); }
echo "multiply(4, 7) = {$result}" . "\n";

$greeting = $calc->greet("World");
if ($greeting !== "Hello, World!") { echo "FAIL: Expected 'Hello, World!', got '{$greeting}'\n"; exit(1); }
echo "greet('World') = {$greeting}" . "\n";

$value = $calc->get_value();
if ($value !== 42) { echo "FAIL: Expected 42, got {$value}\n"; exit(1); }
echo "get_value() = {$value}" . "\n";

echo "PASS: System return works correctly" . "\n";

@@target erlang
@@system HSMSingleParent {
    interface:
        childEvent()
        parentEvent()
        getLog(): str
    machine:
        $Child => $Parent {
            childEvent() {
                self.log = self.log ++ ",child_event"
            }
            getLog(): str {
                @@:(self.log)
            }
        }
        $Parent {
            parentEvent() {
                self.log = self.log ++ ",parent_event"
            }
            getLog(): str {
                @@:(self.log)
            }
        }
    domain:
        log = "init"
}

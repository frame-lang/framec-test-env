@@[target("erlang")]
@@system HSMEnterChild {
    interface:
        getLog(): str
    machine:
        $Child => $Parent {
            $>() { self.log = self.log ++ ",child_enter" }
            getLog(): str {
                @@:(self.log)
            }
        }
        $Parent {
            getLog(): str {
                @@:(self.log)
            }
        }
    domain:
        log = "init"
}

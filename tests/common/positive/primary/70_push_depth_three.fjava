@@[target("java")]

@@system PushDeep {
    interface:
        descend()
        ascend()
        get_depth(): int

    machine:
        $Idle {
            descend() {
                push$
                -> $Modal1
            }
            get_depth(): int {
                @@:(0)
            }
        }

        $Modal1 {
            descend() {
                push$
                -> $Modal2
            }
            ascend() {
                -> pop$
            }
            get_depth(): int {
                @@:(1)
            }
        }

        $Modal2 {
            descend() {
                push$
                -> $Modal3
            }
            ascend() {
                -> pop$
            }
            get_depth(): int {
                @@:(2)
            }
        }

        $Modal3 {
            ascend() {
                -> pop$
            }
            get_depth(): int {
                @@:(3)
            }
        }
    domain:
        n : int = 0
}

class Main {
    public static void main(String[] args) {
        var s = @@PushDeep();
        if (s.get_depth() != 0) { System.out.println("FAIL idle"); System.exit(1); }
        s.descend();
        if (s.get_depth() != 1) { System.out.println("FAIL d1"); System.exit(1); }
        s.descend();
        if (s.get_depth() != 2) { System.out.println("FAIL d2"); System.exit(1); }
        s.descend();
        if (s.get_depth() != 3) { System.out.println("FAIL d3"); System.exit(1); }
        s.ascend();
        if (s.get_depth() != 2) { System.out.println("FAIL a1"); System.exit(1); }
        s.ascend();
        if (s.get_depth() != 1) { System.out.println("FAIL a2"); System.exit(1); }
        s.ascend();
        if (s.get_depth() != 0) { System.out.println("FAIL a3"); System.exit(1); }
        System.out.println("PASS: 70_push_depth_three");
    }
}

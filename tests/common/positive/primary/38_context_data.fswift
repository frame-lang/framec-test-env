@@target swift

// Test: Context Data (@@:data)
// Validates call-scoped data that persists across handler -> <$ -> $> chain

@@system ContextDataTest {
    interface:
        process_with_data(value: number): string
        check_data_isolation(): string
        transition_preserves_data(x: number): string

    machine:
        $Start {
            process_with_data(value: number): string {
                // Set data in handler
                @@:data.input = @@:params.value
                @@:data.trace = ["handler"]

                let input_val = @@:data.input!
                @@:("processed:" + String(describing: input_val))
            }

            check_data_isolation(): string {
                // Set data, call another method, verify our data preserved
                @@:data.outer = "outer_value"

                // This creates its own context with its own data
                let inner_result = self.process_with_data(99)

                // Our data should still be here
                let outer_val = @@:data.outer as! String
                @@:("outer_data=" + outer_val + ",inner=" + inner_result)
            }

            transition_preserves_data(x: number): string {
                // Set data, transition, verify data available in lifecycle handlers
                @@:data.started_in = "Start"
                @@:data.value = @@:params.x
                @@:data.trace = ["handler"]
                -> $End
            }

            <$() {
                // Exit handler can access data set by event handler
                var trace = @@:data.trace as! [String]
                trace.append("exit")
                @@:data.trace = trace
            }
        }

        $End {
            $>() {
                // Enter handler can access data set by previous handlers
                var trace = @@:data.trace as! [String]
                trace.append("enter")
                @@:data.trace = trace
                @@:data.ended_in = "End"

                // Build final result from accumulated data
                let finalTrace = @@:data.trace as! [String]
                let trace_str = finalTrace.count > 0 ? finalTrace.joined(separator: ",") : "no_trace"
                let started = @@:data.started_in!
                let ended = @@:data.ended_in!
                let val = @@:data.value!
                @@:("from=\(started),to=\(ended),value=\(val),trace=\(trace_str)")
            }
        }
}

// main
    print("=== Test 38: Context Data ===")

    // Test 1: Basic data set/get
    let s1 = @@ContextDataTest()
    var result = s1.process_with_data(42)
    if result != "processed:42" { fatalError("Expected 'processed:42', got '\(result)'") }
    print("1. process_with_data(42) = '\(result)'")

    // Test 2: Data isolation between nested calls
    let s2 = @@ContextDataTest()
    result = s2.check_data_isolation()
    let expected = "outer_data=outer_value,inner=processed:99"
    if result != expected { fatalError("Expected '\(expected)', got '\(result)'") }
    print("2. check_data_isolation() = '\(result)'")

    // Test 3: Data preserved across transition (handler -> <$ -> $>)
    let s3 = @@ContextDataTest()
    result = s3.transition_preserves_data(100)
    // Data should flow: handler sets -> exit accesses -> enter accesses and returns
    if !result.contains("from=Start") { fatalError("Expected 'from=Start' in '\(result)'") }
    if !result.contains("to=End") { fatalError("Expected 'to=End' in '\(result)'") }
    if !result.contains("value=100") { fatalError("Expected 'value=100' in '\(result)'") }
    print("3. transition_preserves_data(100) = '\(result)'")

    print("PASS: Context data works correctly")

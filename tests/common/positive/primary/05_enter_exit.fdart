@@target dart

@@system EnterExit {
    interface:
        toggle()
        get_log(): String[]

    machine:
        $Off {
            $>() {
                this.log.add("enter:Off");
                print("Entered Off state");
            }

            <$() {
                this.log.add("exit:Off");
                print("Exiting Off state");
            }

            toggle() {
                -> $On
            }

            get_log(): String[] {
                @@:(this.log)
                return;
            }
        }

        $On {
            $>() {
                this.log.add("enter:On");
                print("Entered On state");
            }

            <$() {
                this.log.add("exit:On");
                print("Exiting On state");
            }

            toggle() {
                -> $Off
            }

            get_log(): String[] {
                @@:(this.log)
                return;
            }
        }
    domain:
        log: String[] = []
}

void main() {
    print("== Test 05: Enter/Exit Handlers ==");
    final s = @@EnterExit();

    // Initial enter should have been called
    var log = s.get_log();
    if (!log.includes("enter:Off")) {
        throw Exception("Expected 'enter:Off' in log, got ${jsonEncode(log)}");
    }
    print("After construction: ${jsonEncode(log)}");

    // Toggle to On - should exit Off, enter On
    s.toggle();
    log = s.get_log();
    if (!log.includes("exit:Off")) {
        throw Exception("Expected 'exit:Off' in log, got ${jsonEncode(log)}");
    }
    if (!log.includes("enter:On")) {
        throw Exception("Expected 'enter:On' in log, got ${jsonEncode(log)}");
    }
    print("After toggle to On: ${jsonEncode(log)}");

    // Toggle back to Off - should exit On, enter Off
    s.toggle();
    log = s.get_log();
    final enterOffCount = log.filter(x => x == "enter:Off").length;
    if (enterOffCount != 2) {
        throw Exception("Expected 2 'enter:Off' entries, got ${jsonEncode(log)}");
    }
    if (!log.includes("exit:On")) {
        throw Exception("Expected 'exit:On' in log, got ${jsonEncode(log)}");
    }
    print("After toggle to Off: ${jsonEncode(log)}");

    print("PASS: Enter/Exit handlers work correctly");
}


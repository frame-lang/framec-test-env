@@target rust

@@system FloatStateArg {
    interface:
        configure(rate: f64)
        scale(v: f64): f64

    machine:
        $Idle {
            configure(rate: f64) {
                -> $Active(rate)
            }
            scale(v: f64): f64 {
                @@:(v)
                return;
            }
        }

        $Active => $Frame(rate: f64) {
            configure(rate: f64) {
                -> $Active(rate)
            }
            scale(v: f64): f64 {
                => $^
            }
        }

        $Frame {
            scale(v: f64): f64 {
                @@:(v * rate)
                return;
            }
        }
    domain:
        n: i32
}

fn main() {
    let mut s = @@FloatStateArg();
    if (s.scale(2.0) - 2.0).abs() > 1e-9 { println!("FAIL idle"); std::process::exit(1); }
    s.configure(0.5);
    if (s.scale(10.0) - 5.0).abs() > 1e-9 { println!("FAIL 0.5"); std::process::exit(1); }
    s.configure(2.5);
    if (s.scale(4.0) - 10.0).abs() > 1e-9 { println!("FAIL 2.5"); std::process::exit(1); }
    println!("PASS: 68_hsm_float_state_args");
}

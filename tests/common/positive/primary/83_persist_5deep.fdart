@@[target("dart")]

import 'dart:convert';

@@[persist(String)]
@@[save(saveState)]
@@[load(restoreState)]
@@system L5 {
    interface:
        bump()
        value(): int
    machine:
        $S { bump() { this.n = this.n + 1; } value(): int { @@:(this.n) } }
    domain: n: int = 0
}

@@system L4 {
    operations:
        @@[save]
        saveState(): String {}

        @@[load]
        restoreState(data: String) {}

    interface:
        bump()
        value(): int
    machine:
        $S {
            bump() { this.n = this.n + 1; this.child.bump(); }
            value(): int { @@:(this.n + this.child.value()) }
        }
    domain:
        n: int = 0
        child: L5 = @@L5()
}

@@system L3 {
    operations:
        @@[save]
        saveState(): String {}

        @@[load]
        restoreState(data: String) {}

    interface:
        bump()
        value(): int
    machine:
        $S {
            bump() { this.n = this.n + 1; this.child.bump(); }
            value(): int { @@:(this.n + this.child.value()) }
        }
    domain:
        n: int = 0
        child: L4 = @@L4()
}

@@system L2 {
    operations:
        @@[save]
        saveState(): String {}

        @@[load]
        restoreState(data: String) {}

    interface:
        bump()
        value(): int
    machine:
        $S {
            bump() { this.n = this.n + 1; this.child.bump(); }
            value(): int { @@:(this.n + this.child.value()) }
        }
    domain:
        n: int = 0
        child: L3 = @@L3()
}

@@[main]
@@system L1 {
    operations:
        @@[save]
        saveState(): String {}

        @@[load]
        restoreState(data: String) {}

    interface:
        bump()
        value(): int
    machine:
        $S {
            bump() { this.n = this.n + 1; this.child.bump(); }
            value(): int { @@:(this.n + this.child.value()) }
        }
    domain:
        n: int = 0
        child: L2 = @@L2()
}

void main() {
    var a = L1();
    a.bump(); a.bump(); a.bump();
    var pre = a.value();
    if (pre != 15) { print("FAIL pre: $pre"); return; }
    var snap = a.saveState();
    final b = L1();

    b.restoreState(snap);
    var post = b.value();
    if (post != 15) { print("FAIL post: $post"); return; }
    b.bump();
    var after = b.value();
    if (after != 20) { print("FAIL after: $after"); return; }
    print("PASS: 83_persist_5deep");
}

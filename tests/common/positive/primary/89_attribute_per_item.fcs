@@[target("csharp")]

using System;

@@system Demo {
    interface:
        common(): string
        @@[target("python_3")] only_py(): string
        @@[target("csharp")] only_cs(): string

    machine:
        $S {
            common(): string { @@:("common") }
            @@[target("python_3")] only_py(): string { @@:("only_py_present") }
            @@[target("csharp")] only_cs(): string { @@:("only_cs_present") }
        }
}

class Program {
    public static void Main(string[] args) {
        var d = new Demo();
        if (d.common() != "common") { Console.WriteLine("FAIL common: " + d.common()); Environment.Exit(1); }
        if (d.only_cs() != "only_cs_present") { Console.WriteLine("FAIL only_cs: " + d.only_cs()); Environment.Exit(1); }
        Console.WriteLine("PASS: 89_attribute_per_item");
    }
}

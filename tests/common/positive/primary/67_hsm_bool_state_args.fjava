@@[target("java")]

@@system BoolStateArg {
    interface:
        configure(active: bool)
        is_active(): bool

    machine:
        $Idle {
            configure(active: bool) {
                -> $Active(active)
            }
            is_active(): bool {
                @@:(false)
            }
        }

        $Active => $Frame(flag: bool) {
            configure(active: bool) {
                -> $Active(active)
            }
            is_active(): bool {
                => $^
            }
        }

        $Frame {
            is_active(): bool {
                @@:(flag)
            }
        }
    domain:
        n : int = 0
}

class Main {
    public static void main(String[] args) {
        var s = @@BoolStateArg();
        if (s.is_active() != false) { System.out.println("FAIL idle"); System.exit(1); }
        s.configure(true);
        if (s.is_active() != true) { System.out.println("FAIL true"); System.exit(1); }
        s.configure(false);
        if (s.is_active() != false) { System.out.println("FAIL false"); System.exit(1); }
        s.configure(true);
        if (s.is_active() != true) { System.out.println("FAIL re-true"); System.exit(1); }
        System.out.println("PASS: 67_hsm_bool_state_args");
    }
}

@@target typescript

async function asyncCompute(x: number): Promise<number> {
    await Promise.resolve();
    return x * 2;
}

@@persist
@@system PersistAsync {
    interface:
        async configure(amount: number)
        get(): number

    machine:
        $Idle {
            configure(amount: number) {
                this.value = await asyncCompute(amount)
                -> $Active
            }
            get(): number { @@:(0) }
        }
        $Active {
            configure(amount: number) {
                this.value = this.value + (await asyncCompute(amount))
                -> $Active
            }
            get(): number { @@:(this.value) }
        }
    domain:
        value: number = 0
}

(async () => {
    const s1 = new PersistAsync();
    await s1.init();
    await s1.configure(5);
    let v = await s1.get();
    if (v !== 10) { console.log(`FAIL pre: expected 10, got ${v}`); process.exit(1); }
    const snap = await s1.saveState();
    const s2 = PersistAsync.restoreState(snap);
    v = await s2.get();
    if (v !== 10) { console.log(`FAIL post: expected 10, got ${v}`); process.exit(1); }
    await s2.configure(3);
    v = await s2.get();
    if (v !== 16) { console.log(`FAIL post-2nd: expected 16, got ${v}`); process.exit(1); }
    console.log("PASS: 81_persist_async_basic");
})();

@@[target("java")]

import java.util.concurrent.CompletableFuture;
import java.util.concurrent.ExecutionException;

@@[persist(String)]
@@[save(save_state)]
@@[load(restore_state)]
@@system PersistAsync {
    interface:
        async configure(amount: int)
        get(): int

    machine:
        $Idle {
            configure(amount: int) {
                this.value = Main.asyncCompute(amount).join();
                -> $Active
            }
            get(): int { @@:(0) }
        }
        $Active {
            configure(amount: int) {
                this.value = this.value + Main.asyncCompute(amount).join();
                -> $Active
            }
            get(): int { @@:(this.value) }
        }
    domain:
        value: int = 0
}

class Main {
    static CompletableFuture<Integer> asyncCompute(int x) {
        return CompletableFuture.supplyAsync(() -> x * 2);
    }

    public static void main(String[] args) throws InterruptedException, ExecutionException {
        PersistAsync s1 = new PersistAsync();
        s1.init().get();
        s1.configure(5).get();
        int v = s1.get();
        if (v != 10) throw new RuntimeException("FAIL pre: expected 10, got " + v);
        String snap = s1.save_state();
        PersistAsync s2 = new PersistAsync();

        s2.restore_state(snap);
        v = s2.get();
        if (v != 10) throw new RuntimeException("FAIL post: expected 10, got " + v);
        s2.configure(3).get();
        v = s2.get();
        if (v != 16) throw new RuntimeException("FAIL post-2nd: expected 16, got " + v);
        System.out.println("PASS: 81_persist_async_basic");
    }
}

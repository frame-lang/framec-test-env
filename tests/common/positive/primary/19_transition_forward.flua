@@[target("lua")]
@@system EventForwardTest {
    interface:
        process()
        get_log(): list

    machine:
        $Idle {
            process() {
                self.log[#self.log + 1] = "idle:process:before"
                -> => $Working
                -- This should NOT execute because -> => returns after dispatch
                self.log[#self.log + 1] = "idle:process:after"
            }

            get_log(): list {
                @@:(self.log)
                return
            }
        }

        $Working {
            process() {
                self.log[#self.log + 1] = "working:process"
            }

            get_log(): list {
                @@:(self.log)
                return
            }
        }
    domain:
        log: list = []
}

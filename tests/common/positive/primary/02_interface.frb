@@[target("ruby")]

@@system WithInterface {
    interface:
        greet(name: str): str
        get_count(): int

    machine:
        $Ready {
            greet(name: str): str {
                self.call_count += 1
                @@:("Hello, #{name}!")
                return
            }

            get_count(): int {
                @@:(self.call_count)
                return
            }
        }

    domain:
        call_count: int = 0
}

puts("=== Test 02: Interface Methods ===")
s = WithInterface.new

# Test interface method with parameter and return
result = s.greet("World")
raise "Expected 'Hello, World!', got '#{result}'" unless result == "Hello, World!"
puts("greet('World') = #{result}")

# Test domain variable access through interface
count = s.get_count()
raise "Expected count=1, got #{count}" unless count == 1
puts("get_count() = #{count}")

# Call again to verify state
s.greet("Frame")
count2 = s.get_count()
raise "Expected count=2, got #{count2}" unless count2 == 2
puts("After second call: get_count() = #{count2}")

puts("PASS: Interface methods work correctly")

@@[target("ruby")]

@@system HSMForward {
    interface:
        event_a()
        event_b()
        get_log(): list

    machine:
        $Child => $Parent {
            event_a() {
                self.log.push("Child:event_a")
            }

            event_b() {
                self.log.push("Child:event_b_forward")
                => $^
            }

            get_log(): list {
                @@:(self.log)
                return
            }
        }

        $Parent {
            event_a() {
                self.log.push("Parent:event_a")
            }

            event_b() {
                self.log.push("Parent:event_b")
            }

            get_log(): list {
                @@:(self.log)
                return
            }
        }
    domain:
        log: list = []
}

puts("=== Test 08: HSM Forward ===")
s = HSMForward.new

# event_a should be handled by Child (no forward)
s.event_a()
log = s.get_log()
raise "Expected 'Child:event_a' in log, got #{log}" unless log.include?("Child:event_a")
puts("After event_a: #{log}")

# event_b should forward to Parent
s.event_b()
log = s.get_log()
raise "Expected 'Child:event_b_forward' in log, got #{log}" unless log.include?("Child:event_b_forward")
raise "Expected 'Parent:event_b' in log (forwarded), got #{log}" unless log.include?("Parent:event_b")
puts("After event_b (forwarded): #{log}")

puts("PASS: HSM forward works correctly")

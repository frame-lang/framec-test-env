@@[target("gdscript")]
extends SceneTree

@@system StateArgFwd {
    interface:
        configure(t: int)
        process(): int

    machine:
        $Idle {
            configure(t: int) {
                -> $Active(t)
            }
            process(): int {
                @@:(0)
            }
        }

        $Active => $Frame(threshold: int) {
            configure(t: int) {
                -> $Active(t)
            }
            process(): int {
                => $^
            }
        }

        $Frame {
            process(): int {
                @@:(threshold)
            }
        }
    domain:
        n: int = 0
}

func _initialize():
    print("=== Test 65: HSM × state-args × parent-forward (GDScript) ===")
    var s = StateArgFwd.new()

    var pre = s.process()
    if pre != 0:
        print("FAIL: pre " + str(pre))
        quit(1)
        return
    print("1. Idle process = " + str(pre))

    s.configure(7)
    var r = s.process()
    if r != 7:
        print("FAIL: r " + str(r))
        quit(1)
        return
    print("2. configure(7); process() = " + str(r))

    s.configure(42)
    var r2 = s.process()
    if r2 != 42:
        print("FAIL: r2 " + str(r2))
        quit(1)
        return
    print("3. configure(42); process() = " + str(r2))

    print("PASS: 65_hsm_forward_state_args")
    quit(0)

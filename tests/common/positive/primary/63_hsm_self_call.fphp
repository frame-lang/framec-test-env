<?php
@@[target("php")]

@@system HsmSelfCall {
    interface:
        drive_via_child(): int
        compute(): int
        get_trace(): str

    machine:
        $Child => $Parent {
            drive_via_child(): int {
                $this->trace = $this->trace . "child:before;";
                @@:self.compute()
                $this->trace = $this->trace . "child:after;";
                @@:($this->scratch)
                return;
            }
            compute(): int {
                $this->trace = $this->trace . "compute@child;";
                => $^
            }
            get_trace(): str {
                @@:($this->trace)
                return;
            }
        }

        $Parent {
            compute(): int {
                $this->trace = $this->trace . "compute@parent;";
                $this->scratch = 42;
                @@:(42)
                return;
            }
        }
    domain:
        trace: str = ""
        scratch: int = 0
}

echo "=== Test 63: HSM cascade × @@:self (PHP) ===\n";
$s = @@HsmSelfCall();
$r = $s->drive_via_child();
$trace = $s->get_trace();
echo "1. drive_via_child returned $r, trace=$trace\n";

$expected = "child:before;compute@child;compute@parent;child:after;";
if ($trace !== $expected) { echo "FAIL: trace=$trace\n"; exit(1); }
if ($r !== 42) { echo "FAIL: r=$r\n"; exit(1); }

echo "PASS: 63_hsm_self_call\n";

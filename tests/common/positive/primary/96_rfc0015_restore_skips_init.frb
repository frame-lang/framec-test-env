@@[target("ruby")]

@@[persist(JSON)]
@@[save(snapshot)]
@@[load(rehydrate)]
@@system Counter {
    interface:
        get_fire_count(): Integer

    machine:
        $A {
            $>() {
                @fire_count = @fire_count + 1
            }
            get_fire_count(): Integer { @@:(@fire_count) }
        }

    domain:
        fire_count: Integer = 0
}

c = @@Counter()
if c.get_fire_count != 1
    puts "FAIL: expected 1 after construction, got #{c.get_fire_count}"
else
    snap = c.snapshot
    fresh = @@Counter()
    if fresh.get_fire_count != 1
        puts "FAIL: expected 1 on fresh construction, got #{fresh.get_fire_count}"
    else
        fresh.rehydrate(snap)
        if fresh.get_fire_count != 1
            puts "D4 violation: $> re-ran on restore (count=#{fresh.get_fire_count}, expected 1)"
        else
            puts "PASS: rfc0015_restore_skips_init"
        end
    end
end

@@[target("swift")]

@@[persist(JSON)]
@@[save(snapshot)]
@@[load(rehydrate)]
@@system Counter {
    interface:
        getFireCount(): Int

    machine:
        $A {
            $>() {
                self.fire_count = self.fire_count + 1
            }
            getFireCount(): Int { @@:(self.fire_count) }
        }

    domain:
        fire_count: Int = 0
}

let c = @@Counter()
if c.getFireCount() != 1 {
    print("FAIL: expected 1 after construction, got \(c.getFireCount())")
} else {
    let snap = c.snapshot()
    let fresh = @@Counter()
    if fresh.getFireCount() != 1 {
        print("FAIL: expected 1 on fresh construction, got \(fresh.getFireCount())")
    } else {
        fresh.rehydrate(snap)
        if fresh.getFireCount() != 1 {
            print("D4 violation: $> re-ran on restore (count=\(fresh.getFireCount()), expected 1)")
        } else {
            print("PASS: rfc0015_restore_skips_init")
        }
    }
}

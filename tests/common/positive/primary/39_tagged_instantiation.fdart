@@target dart

// Test 39: Tagged System Instantiation
// Validates the @@System() syntax for tracked instantiation

@@system Calculator {
    interface:
        add(a: int, b: int): int
        get_result(): int

    machine:
        $Ready {
            add(a: int, b: int): int {
                this.result = a + b;
                @@:(this.result)
                return;
            }

            get_result(): int {
                @@:(this.result)
                return;
            }
        }
    domain:
        result: int = 0
}

@@system Counter {
    interface:
        increment(): void
        get_count(): int

    machine:
        $Active {
            increment(): void {
                this.count = this.count + 1;
            }

            get_count(): int {
                @@:(this.count)
                return;
            }
        }
    domain:
        count: int = 0
}

void main(): void {
    print("== Test 39: Tagged System Instantiation ==");

    // Tagged instantiation - validated at transpile time
    final calc = @@Calculator();
    final counter = @@Counter();

    // Test Calculator
    var result = calc.add(3, 4);
    if (result != 7) {
        print("FAIL: Expected 7, got ${result}");
        process.exit(1);
    }
    print("Calculator.add(3, 4) = ${result}");

    result = calc.get_result();
    if (result != 7) {
        print("FAIL: Expected 7, got ${result}");
        process.exit(1);
    }
    print("Calculator.get_result() = ${result}");

    // Test Counter
    counter.increment();
    counter.increment();
    counter.increment();
    final count = counter.get_count();
    if (count != 3) {
        print("FAIL: Expected 3, got ${count}");
        process.exit(1);
    }
    print("Counter after 3 increments: ${count}");

    print("PASS: Tagged instantiation works correctly");
}


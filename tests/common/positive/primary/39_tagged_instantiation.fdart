@@[target("dart")]
import 'dart:io';
// Test 39: Tagged System Instantiation
// Validates the tagged system instantiation syntax

@@system Calculator {
    interface:
        add(a: num, b: num): num
        get_result(): num

    machine:
        $Ready {
            add(a: num, b: num): num {
                this.result = a + b;
                @@:(this.result)
                return;
            }

            get_result(): num {
                @@:(this.result)
                return;
            }
        }
    domain:
        result : num = 0
}

@@[main]
@@system Counter {
    interface:
        increment(): void
        get_count(): num

    machine:
        $Active {
            increment(): void {
                this.count = this.count + 1;
            }

            get_count(): num {
                @@:(this.count)
                return;
            }
        }
    domain:
        count : num = 0
}

void main() {
    print("== Test 39: Tagged System Instantiation ==");

    // Tagged instantiation - validated at transpile time
    final calc = @@Calculator();
    final counter = @@Counter();

    // Test Calculator
    var result = calc.add(3, 4);
    if (result != 7) {
        print("FAIL: Expected 7, got ${result}");
        exit(1);
    }
    print("Calculator.add(3, 4) = ${result}");

    result = calc.get_result();
    if (result != 7) {
        print("FAIL: Expected 7, got ${result}");
        exit(1);
    }
    print("Calculator.get_result() = ${result}");

    // Test Counter
    counter.increment();
    counter.increment();
    counter.increment();
    final count = counter.get_count();
    if (count != 3) {
        print("FAIL: Expected 3, got ${count}");
        exit(1);
    }
    print("Counter after 3 increments: ${count}");

    print("PASS: Tagged instantiation works correctly");
}


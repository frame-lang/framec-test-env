@@[target("kotlin")]

import kotlin.system.exitProcess

@@system StackOps {
    interface:
        push_and_go()
        pop_back()
        do_work(): String
        get_state(): String

    machine:
        $Main {
            push_and_go() {
                println("Pushing Main to stack, going to Sub")
                push$
                -> $Sub
            }

            pop_back() {
                println("Cannot pop - nothing on stack in Main")
            }

            do_work(): String {
                @@:("Working in Main")
                return;
            }

            get_state(): String {
                @@:("Main")
                return;
            }
        }

        $Sub {
            push_and_go() {
                println("Already in Sub")
            }

            pop_back() {
                println("Popping back to previous state")
                -> pop$
            }

            do_work(): String {
                @@:("Working in Sub")
                return;
            }

            get_state(): String {
                @@:("Sub")
                return;
            }
        }
}

fun main() {
    println("=== Test 09: Stack Push/Pop ===")
    val s = @@StackOps()

    // Initial state should be Main
    var state = s.get_state() as String
    if (state != "Main") {
        throw RuntimeException("Expected 'Main', got '$state'")
    }
    println("Initial state: $state")

    // Do work in Main
    var work = s.do_work() as String
    if (work != "Working in Main") {
        throw RuntimeException("Expected 'Working in Main', got '$work'")
    }
    println("do_work(): $work")

    // Push and go to Sub
    s.push_and_go()
    state = s.get_state() as String
    if (state != "Sub") {
        throw RuntimeException("Expected 'Sub', got '$state'")
    }
    println("After push_and_go(): $state")

    // Do work in Sub
    work = s.do_work() as String
    if (work != "Working in Sub") {
        throw RuntimeException("Expected 'Working in Sub', got '$work'")
    }
    println("do_work(): $work")

    // Pop back to Main
    s.pop_back()
    state = s.get_state() as String
    if (state != "Main") {
        throw RuntimeException("Expected 'Main' after pop, got '$state'")
    }
    println("After pop_back(): $state")

    println("PASS: Stack push/pop works correctly")
}

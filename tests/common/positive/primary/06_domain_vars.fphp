<?php
@@target php

@@system DomainVars {
    interface:
        increment()
        decrement()
        get_count(): int
        set_count(value: int)

    machine:
        $Counting {
            increment() {
                $this->count += 1;
                echo $this->name . ": incremented to " . $this->count . "\n";
            }

            decrement() {
                $this->count -= 1;
                echo $this->name . ": decremented to " . $this->count . "\n";
            }

            get_count(): int {
                @@:($this->count)
                return;
            }

            set_count(value: int) {
                $this->count = $value;
                echo $this->name . ": set to " . $this->count . "\n";
            }
        }
    domain:
        count = 0
        name = "counter"
}

echo "=== Test 06: Domain Variables ===" . "\n";
$s = new DomainVars();

$count = $s->get_count();
if ($count !== 0) { echo "FAIL: Expected initial count=0, got {$count}\n"; exit(1); }
echo "Initial count: {$count}" . "\n";

$s->increment();
$count = $s->get_count();
if ($count !== 1) { echo "FAIL: Expected count=1, got {$count}\n"; exit(1); }

$s->increment();
$count = $s->get_count();
if ($count !== 2) { echo "FAIL: Expected count=2, got {$count}\n"; exit(1); }

$s->decrement();
$count = $s->get_count();
if ($count !== 1) { echo "FAIL: Expected count=1, got {$count}\n"; exit(1); }

$s->set_count(100);
$count = $s->get_count();
if ($count !== 100) { echo "FAIL: Expected count=100, got {$count}\n"; exit(1); }

echo "Final count: {$count}" . "\n";
echo "PASS: Domain variables work correctly" . "\n";

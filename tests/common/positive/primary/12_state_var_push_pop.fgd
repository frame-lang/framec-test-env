@@[target("gdscript")]
extends SceneTree

@@system StateVarPushPop {
    interface:
        increment(): int
        get_count(): int
        save_and_go()
        restore()

    machine:
        $Counter {
            $.count: int = 0

            increment(): int {
                $.count = $.count + 1
                @@:($.count)
                return
            }

            get_count(): int {
                @@:($.count)
                return
            }

            save_and_go() {
                push$
                -> $Other
            }
        }

        $Other {
            $.other_count: int = 100

            restore() {
                -> pop$
            }

            increment(): int {
                $.other_count = $.other_count + 1
                @@:($.other_count)
                return
            }

            get_count(): int {
                @@:($.other_count)
                return
            }
        }
}

func main():
    print("=== Test 12: State Variable Push/Pop ===")
    var s = @@StateVarPushPop()

    # Increment counter to 3
    s.increment()
    s.increment()
    s.increment()
    var count = s.get_count()
    assert(count == 3, "Expected 3, got " + str(count))
    print("Counter before push: " + str(count))

    # Push and go to Other state
    s.save_and_go()
    print("Pushed and transitioned to Other")

    # In Other state, count should be 100 (Other's state var)
    count = s.get_count()
    assert(count == 100, "Expected 100 in Other state, got " + str(count))
    print("Other state count: " + str(count))

    # Increment in Other
    s.increment()
    count = s.get_count()
    assert(count == 101, "Expected 101 after increment, got " + str(count))
    print("Other state after increment: " + str(count))

    # Pop back - should restore Counter with count=3
    s.restore()
    print("Popped back to Counter")

    count = s.get_count()
    assert(count == 3, "Expected 3 after pop (preserved), got " + str(count))
    print("Counter after pop: " + str(count))

    # Increment to verify it works
    s.increment()
    count = s.get_count()
    assert(count == 4, "Expected 4, got " + str(count))
    print("Counter after increment: " + str(count))

    print("PASS: State variables preserved across push/pop")

func _init():
    main()
    quit()

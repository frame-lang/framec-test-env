@@target cpp_17

#include <iostream>
#include <string>
#include <cassert>

@@system DomainVars {
    interface:
        increment()
        decrement()
        get_count(): int
        set_count(value: int)

    machine:
        $Counting {
            increment() {
                count += 1;
                std::cout << name << ": incremented to " << count << std::endl;
            }

            decrement() {
                count -= 1;
                std::cout << name << ": decremented to " << count << std::endl;
            }

            get_count(): int {
                return count;
            }

            set_count(value: int) {
                count = value;
                std::cout << name << ": set to " << count << std::endl;
            }
        }
    domain:
        int count = 0;
        std::string name = "counter";
}

int main() {
    std::cout << "=== Test 06: Domain Variables ===" << std::endl;
    DomainVars s;

    // Initial value should be 0
    int count = s.get_count();
    assert(count == 0);
    std::cout << "Initial count: " << count << std::endl;

    // Increment
    s.increment();
    count = s.get_count();
    assert(count == 1);

    s.increment();
    count = s.get_count();
    assert(count == 2);

    // Decrement
    s.decrement();
    count = s.get_count();
    assert(count == 1);

    // Set directly
    s.set_count(100);
    count = s.get_count();
    assert(count == 100);

    std::cout << "Final count: " << count << std::endl;
    std::cout << "PASS: 06 domain vars" << std::endl;
    return 0;
}

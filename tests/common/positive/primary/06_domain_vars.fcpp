@@target cpp_17

#include <iostream>
#include <string>
#include <cassert>

@@system DomainVars {
    interface:
        increment()
        decrement()
        get_count(): int
        set_count(value: int)

    machine:
        $Counting {
            increment() {
                count += 1;
                printf("%s: incremented to %d\n", name.c_str(), count);
            }

            decrement() {
                count -= 1;
                printf("%s: decremented to %d\n", name.c_str(), count);
            }

            get_count(): int {
                @@:(count)
                return;
            }

            set_count(value: int) {
                count = value;
                printf("%s: set to %d\n", name.c_str(), count);
            }
        }
    domain:
        int count = 0
        std::string name = "counter"
}

int main() {
    printf("=== Test 06: Domain Variables ===\n");
    DomainVars s;

    int count = s.get_count();
    if (count != 0) {
        printf("FAIL: Expected initial count=0, got %d\n", count);
        assert(false);
    }
    printf("Initial count: %d\n", count);

    s.increment();
    count = s.get_count();
    if (count != 1) {
        printf("FAIL: Expected count=1, got %d\n", count);
        assert(false);
    }

    s.increment();
    count = s.get_count();
    if (count != 2) {
        printf("FAIL: Expected count=2, got %d\n", count);
        assert(false);
    }

    s.decrement();
    count = s.get_count();
    if (count != 1) {
        printf("FAIL: Expected count=1, got %d\n", count);
        assert(false);
    }

    s.set_count(100);
    count = s.get_count();
    if (count != 100) {
        printf("FAIL: Expected count=100, got %d\n", count);
        assert(false);
    }

    printf("Final count: %d\n", count);
    printf("PASS: Domain variables work correctly\n");
    return 0;
}

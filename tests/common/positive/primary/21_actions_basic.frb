@@[target("ruby")]

@@system ActionsTest {
    interface:
        process(value: int): int
        get_log(): str

    machine:
        $Ready {
            process(value: int): int {
                self.__log_event("start")
                self.__validate_positive(value)
                self.__log_event("valid")
                result = value * 2
                self.__log_event("done")
                @@:(result)
                return
            }

            get_log(): str {
                @@:(self.log)
                return
            }
        }

    actions:
        __log_event(msg: str) {
            self.log = self.log + msg + ";"
        }

        __validate_positive(n: int) {
            if n < 0
                raise "Value must be positive: #{n}"
            end
        }

    domain:
        log: str = ""
}

puts("=== Test 21: Actions Basic ===")
s = @@ActionsTest()

# Test 1: Actions are called correctly
result = s.process(5)
raise "Expected 10, got #{result}" unless result == 10
puts("1. process(5) = #{result}")

# Test 2: Log shows action calls
log = s.get_log()
raise "Missing 'start' in log: #{log}" unless log.include?("start")
raise "Missing 'valid' in log: #{log}" unless log.include?("valid")
raise "Missing 'done' in log: #{log}" unless log.include?("done")
puts("2. Log: #{log}")

# Test 3: Action with validation
begin
    s.process(-1)
    raise "Should have raised error"
rescue => e
    puts("3. Validation caught: #{e}")
end

puts("PASS: Actions basic works correctly")

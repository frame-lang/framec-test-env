@@target c

// Test 48: HSM Exit Handlers
// Child exit fires when leaving child; parent exit NOT triggered by
// child exit. Parent exit fires only on leaving parent directly.
// The child's exit handler reads its own state-scoped var to
// validate the exit handler's access to compartment-local data
// (matches TC2.4.3 in the Python version: "Exit handler can access
// child's state variables").

@@system HSMExitHandlers {
    interface:
        go_to_other(): void
        go_to_parent(): void
        go_to_child(): void
        get_child_enter(): int
        get_child_exit_read(): int
        get_parent_enter(): int
        get_parent_exit(): int
        get_other_enter(): int
        get_state(): char*

    machine:
        $Child => $Parent {
            $.child_var: int = 42

            $>() { self->child_enter = self->child_enter + 1; }
            // Read state-scoped $.child_var in the exit handler and
            // record it in a domain field so the test can verify that
            // the exit handler saw the child's own compartment.
            <$() { self->child_exit_read = $.child_var; }
            go_to_other() { -> $Other }
            go_to_parent() { -> $Parent }
            get_child_enter(): int { @@:(self->child_enter) return; }
            get_child_exit_read(): int { @@:(self->child_exit_read) return; }
            get_parent_enter(): int { @@:(self->parent_enter) return; }
            get_parent_exit():  int { @@:(self->parent_exit)  return; }
            get_other_enter(): int { @@:(self->other_enter) return; }
            get_state(): char* { @@:("Child") return; }
        }

        $Parent {
            $>() { self->parent_enter = self->parent_enter + 1; }
            <$() { self->parent_exit  = self->parent_exit  + 1; }
            go_to_child() { -> $Child }
            go_to_other() { -> $Other }
            get_child_enter(): int { @@:(self->child_enter) return; }
            get_child_exit_read(): int { @@:(self->child_exit_read) return; }
            get_parent_enter(): int { @@:(self->parent_enter) return; }
            get_parent_exit():  int { @@:(self->parent_exit)  return; }
            get_other_enter(): int { @@:(self->other_enter) return; }
            get_state(): char* { @@:("Parent") return; }
        }

        $Other {
            $>() { self->other_enter = self->other_enter + 1; }
            go_to_child() { -> $Child }
            go_to_parent() { -> $Parent }
            get_child_enter(): int { @@:(self->child_enter) return; }
            get_child_exit_read(): int { @@:(self->child_exit_read) return; }
            get_parent_enter(): int { @@:(self->parent_enter) return; }
            get_parent_exit():  int { @@:(self->parent_exit)  return; }
            get_other_enter(): int { @@:(self->other_enter) return; }
            get_state(): char* { @@:("Other") return; }
        }
    domain:
        child_enter     : int
        child_exit_read : int
        parent_enter    : int
        parent_exit     : int
        other_enter     : int
}

int main() {
    printf("=== Test 48: HSM Exit Handlers ===\n");
    HSMExitHandlers* s = @@HSMExitHandlers();

    if (HSMExitHandlers_get_child_enter(s) != 1
        || strcmp(HSMExitHandlers_get_state(s), "Child") != 0) {
        printf("FAIL: initial Child:enter expected\n"); return 1;
    }
    printf("TC2.4.0: Initial Child with enter - PASS\n");

    // TC2.4.1+3: Child exit fires on leaving child, exit handler
    // sees the child's own state var ($.child_var == 42).
    HSMExitHandlers_go_to_other(s);
    if (HSMExitHandlers_get_child_exit_read(s) != 42
        || HSMExitHandlers_get_other_enter(s) != 1) {
        printf("FAIL: child_exit_read=%d (want 42) other_enter=%d\n",
               HSMExitHandlers_get_child_exit_read(s),
               HSMExitHandlers_get_other_enter(s));
        return 1;
    }
    printf("TC2.4.1+3: Child exit fires, reads own state var ($.child_var=42) - PASS\n");

    // TC2.4.2: Parent exit NOT fired by child's exit
    if (HSMExitHandlers_get_parent_exit(s) != 0) {
        printf("FAIL: parent_exit should be 0, got %d\n",
               HSMExitHandlers_get_parent_exit(s));
        return 1;
    }
    printf("TC2.4.2: Parent exit NOT fired on child exit - PASS\n");

    // TC2.4.4: Parent exit fires when leaving parent directly
    HSMExitHandlers_go_to_parent(s);
    if (HSMExitHandlers_get_parent_enter(s) != 1) {
        printf("FAIL: parent_enter expected 1\n"); return 1;
    }
    HSMExitHandlers_go_to_other(s);
    if (HSMExitHandlers_get_parent_exit(s) != 1) {
        printf("FAIL: parent_exit expected 1, got %d\n",
               HSMExitHandlers_get_parent_exit(s));
        return 1;
    }
    printf("TC2.4.4: Parent exit fires leaving parent - PASS\n");

    printf("PASS: HSM exit handlers work correctly\n");
    HSMExitHandlers_destroy(s);
    return 0;
}

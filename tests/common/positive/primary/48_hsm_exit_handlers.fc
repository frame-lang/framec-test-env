@@[target("c")]

// Test 48: HSM Exit Cascade
// Cascade fires bottom-up: Child.<$ first, then Parent.<$.

@@system HSMExitHandlers {
    interface:
        go_to_other(): void
        go_to_parent(): void
        go_to_child(): void
        get_child_enter(): int
        get_child_exit_read(): int
        get_parent_enter(): int
        get_parent_exit(): int
        get_other_enter(): int
        get_first_exit(): int
        get_state(): char*

    machine:
        $Child => $Parent {
            $.child_var: int = 42

            $>() { self->child_enter = self->child_enter + 1; }
            <$() {
                self->child_exit_read = $.child_var;
                if (self->first_exit == 0) self->first_exit = 2;  // 2 = child first
            }
            go_to_other() { -> $Other }
            go_to_parent() { -> $Parent }
            get_child_enter(): int { @@:(self->child_enter) return; }
            get_child_exit_read(): int { @@:(self->child_exit_read) return; }
            get_parent_enter(): int { @@:(self->parent_enter) return; }
            get_parent_exit():  int { @@:(self->parent_exit)  return; }
            get_other_enter(): int { @@:(self->other_enter) return; }
            get_first_exit(): int { @@:(self->first_exit) return; }
            get_state(): char* { @@:("Child") return; }
        }

        $Parent {
            $>() { self->parent_enter = self->parent_enter + 1; }
            <$() {
                self->parent_exit  = self->parent_exit  + 1;
                if (self->first_exit == 0) self->first_exit = 1;  // 1 = parent first
            }
            go_to_child() { -> $Child }
            go_to_other() { -> $Other }
            get_child_enter(): int { @@:(self->child_enter) return; }
            get_child_exit_read(): int { @@:(self->child_exit_read) return; }
            get_parent_enter(): int { @@:(self->parent_enter) return; }
            get_parent_exit():  int { @@:(self->parent_exit)  return; }
            get_other_enter(): int { @@:(self->other_enter) return; }
            get_first_exit(): int { @@:(self->first_exit) return; }
            get_state(): char* { @@:("Parent") return; }
        }

        $Other {
            $>() { self->other_enter = self->other_enter + 1; }
            go_to_child() { -> $Child }
            go_to_parent() { -> $Parent }
            get_child_enter(): int { @@:(self->child_enter) return; }
            get_child_exit_read(): int { @@:(self->child_exit_read) return; }
            get_parent_enter(): int { @@:(self->parent_enter) return; }
            get_parent_exit():  int { @@:(self->parent_exit)  return; }
            get_other_enter(): int { @@:(self->other_enter) return; }
            get_first_exit(): int { @@:(self->first_exit) return; }
            get_state(): char* { @@:("Other") return; }
        }
    domain:
        child_enter     : int
        child_exit_read : int
        parent_enter    : int
        parent_exit     : int
        other_enter     : int
        first_exit      : int
}

int main() {
    printf("=== Test 48: HSM Exit Cascade ===\n");
    HSMExitHandlers* s = @@HSMExitHandlers();

    // Initial entry cascades through Parent then Child.
    if (HSMExitHandlers_get_parent_enter(s) != 1
        || HSMExitHandlers_get_child_enter(s) != 1
        || strcmp(HSMExitHandlers_get_state(s), "Child") != 0) {
        printf("FAIL: initial cascade: parent=%d child=%d state=%s\n",
               HSMExitHandlers_get_parent_enter(s),
               HSMExitHandlers_get_child_enter(s),
               HSMExitHandlers_get_state(s));
        return 1;
    }
    printf("TC1: Initial entry cascades through Parent then Child - PASS\n");

    HSMExitHandlers_go_to_other(s);
    if (HSMExitHandlers_get_child_exit_read(s) != 42
        || HSMExitHandlers_get_parent_exit(s) != 1
        || HSMExitHandlers_get_other_enter(s) != 1) {
        printf("FAIL: child_exit_read=%d parent_exit=%d other_enter=%d\n",
               HSMExitHandlers_get_child_exit_read(s),
               HSMExitHandlers_get_parent_exit(s),
               HSMExitHandlers_get_other_enter(s));
        return 1;
    }
    if (HSMExitHandlers_get_first_exit(s) != 2) {
        printf("FAIL: child must exit before parent (first_exit=%d)\n",
               HSMExitHandlers_get_first_exit(s));
        return 1;
    }
    printf("TC2: Child:exit fires before Parent:exit (bottom-up cascade) - PASS\n");
    printf("TC3: Exit handler accesses state var (var=42) - PASS\n");

    HSMExitHandlers_go_to_child(s);
    if (HSMExitHandlers_get_parent_enter(s) != 2
        || HSMExitHandlers_get_child_enter(s) != 2) {
        printf("FAIL: re-entry: parent=%d child=%d (expected 2 each)\n",
               HSMExitHandlers_get_parent_enter(s),
               HSMExitHandlers_get_child_enter(s));
        return 1;
    }
    printf("TC4: Re-entering Child cascades Parent.$> then Child.$> - PASS\n");

    printf("PASS: HSM exit cascade fires Child.<$ then Parent.<$\n");
    HSMExitHandlers_destroy(s);
    return 0;
}

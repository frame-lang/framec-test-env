@@[target("c")]

#include <stdio.h>
#include <string.h>
#include <stdlib.h>

@@system Demo {
    interface:
        common(): const char*
        @@[target("python_3")] only_py(): const char*
        @@[target("c")] only_c(): const char*

    machine:
        $S {
            common(): const char* { @@:("common") }
            @@[target("python_3")] only_py(): const char* { @@:("only_py_present") }
            @@[target("c")] only_c(): const char* { @@:("only_c_present") }
        }
}

int main(void) {
    Demo* d = @@Demo();
    if (strcmp(Demo_common(d), "common") != 0) { printf("FAIL common: %s\n", Demo_common(d)); exit(1); }
    if (strcmp(Demo_only_c(d), "only_c_present") != 0) { printf("FAIL only_c: %s\n", Demo_only_c(d)); exit(1); }
    printf("PASS: 89_attribute_per_item\n");
    Demo_destroy(d);
    return 0;
}

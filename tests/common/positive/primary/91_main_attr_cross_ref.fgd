@@[target("gdscript")]

extends SceneTree

@@system Sub {
    interface:
        ping(): int
    machine:
        $Idle {
            ping(): int { @@:(42) }
        }
}

@@[main]
@@system Top {
    interface:
        run(): int
    machine:
        $Active {
            run(): int { @@:(self.sub.ping()) }
        }
    domain:
        sub: Sub = @@Sub()
}

func _init():
    var t = Top.new()
    var v = t.run()
    if v != 42:
        print("FAIL run(): " + str(v))
    else:
        print("PASS: 91_main_attr_cross_ref")
    quit()

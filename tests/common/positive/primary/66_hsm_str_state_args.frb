@@[target("ruby")]

@@system StrStateArg {
    interface:
        configure(label: str)
        identify(): str

    machine:
        $Idle {
            configure(label: str) {
                -> $Active(label)
            }
            identify(): str {
                @@:("anonymous")
                return
            }
        }

        $Active => $Frame(label: str) {
            configure(label: str) {
                -> $Active(label)
            }
            identify(): str {
                => $^
            }
        }

        $Frame {
            identify(): str {
                @@:(label)
                return
            }
        }
    domain:
        n: int = 0
}

s = @@StrStateArg()
raise "FAIL idle" unless s.identify == "anonymous"
s.configure("alice")
raise "FAIL alice" unless s.identify == "alice"
s.configure("bob")
raise "FAIL bob" unless s.identify == "bob"
puts "PASS: 66_hsm_str_state_args"

@@target gdscript
extends SceneTree

@@[persist]
@@system PersistPushpopStateArgs {
    interface:
        push_modal(v: int)
        pop_modal()
        get_slot(): int

    machine:
        $Idle {
            push_modal(v: int) {
                push$
                -> $Modal(v)
            }
            pop_modal() {
                -> pop$
            }
            get_slot(): int {
                @@:(-99)
            }
        }

        $Modal(slot: int) {
            push_modal(v: int) {
                push$
                -> $Modal(v)
            }
            pop_modal() {
                -> pop$
            }
            get_slot(): int {
                @@:(slot)
            }
        }
    domain:
        v: int = 0
}

func _initialize():
    print("=== Test 58: Persist × push/pop × state-args (GDScript) ===")
    var s1 = PersistPushpopStateArgs.new()
    s1.push_modal(42)
    s1.push_modal(77)
    var pre = s1.get_slot()
    if pre != 77:
        print("FAIL: pre " + str(pre))
        quit(1)
        return
    print("1. Pre-save top slot=" + str(pre))

    var snap = s1.save_state()
    var s2 = PersistPushpopStateArgs.restore_state(snap)
    var post = s2.get_slot()
    if post != 77:
        print("FAIL: post " + str(post))
        quit(1)
        return
    print("2. Post-restore top slot=" + str(post))

    s2.pop_modal()
    var mid = s2.get_slot()
    if mid != 42:
        print("FAIL: mid " + str(mid))
        quit(1)
        return
    print("3. After first pop slot=" + str(mid))

    s2.pop_modal()
    var bottom = s2.get_slot()
    if bottom != -99:
        print("FAIL: bottom " + str(bottom))
        quit(1)
        return
    print("4. After second pop slot=" + str(bottom))

    print("PASS: 58_persist_pushpop_state_args")
    quit(0)

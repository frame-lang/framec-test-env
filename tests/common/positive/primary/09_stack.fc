@@target c

@@system StackOps {
    interface:
        push_and_go(): void
        pop_back(): void
        get_state(): int

    machine:
        $Main {
            push_and_go() {
                printf("Pushing Main to stack, going to Sub\n");
                push$
                -> $Sub
            }

            pop_back() {
                printf("Cannot pop - nothing on stack in Main\n");
            }

            get_state(): int {
                return 1
            }
        }

        $Sub {
            push_and_go() {
                printf("Already in Sub\n");
            }

            pop_back() {
                printf("Popping back to previous state\n");
                -> pop$
            }

            get_state(): int {
                return 2
            }
        }
}

int main() {
    printf("=== Test 09: Stack Push/Pop ===\n");
    StackOps* s = @@StackOps();

    // Initial state should be Main (1)
    int state = StackOps_get_state(s);
    printf("Initial state: %d (Main)\n", state);
    if (state != 1) {
        printf("FAIL: Expected 1, got %d\n", state);
        return 1;
    }

    // Push and go to Sub
    StackOps_push_and_go(s);
    state = StackOps_get_state(s);
    printf("After push_and_go(): %d (Sub)\n", state);
    if (state != 2) {
        printf("FAIL: Expected 2, got %d\n", state);
        return 1;
    }

    // Pop back to Main
    StackOps_pop_back(s);
    state = StackOps_get_state(s);
    printf("After pop_back(): %d (Main)\n", state);
    if (state != 1) {
        printf("FAIL: Expected 1 after pop, got %d\n", state);
        return 1;
    }

    printf("PASS: Stack push/pop works correctly\n");
    StackOps_destroy(s);
    return 0;
}

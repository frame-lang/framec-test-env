@@[target("gdscript")]

extends SceneTree

# RFC-0017 regression — restore_state rehydration of a parameterized
# `@@[persist]` child. The pre-fix GDScript codegen emitted
# `self.c = @@Counter(__raw_c.get("seed"))` inside the orchestrator's
# `restore_state`, passing the saved ctor arg to the now-no-arg bare
# `_init()` → Godot "Too many arguments for new() call". The fix builds
# the no-init shell with bare `@@Counter()` and lets the subsequent
# `restore_state(...)` repopulate every domain field (which it does
# anyway). Companion to the field-initializer coordinate in test 98;
# GDScript-only because the other typed backends already emitted the
# bare-`new` form in this path.

@@[persist(PackedByteArray)]
@@[save(save_state)]
@@[load(restore_state)]
@@system Counter(seed: int) {
    interface:
        bump()
        get_value(): int
    machine:
        $S {
            $> { self.n = self.seed }
            bump() { self.n = self.n + 1 }
            get_value(): int { @@:(self.n); return }
        }
    domain:
        seed: int = seed
        n: int = 0
}

@@[main]
@@[persist(PackedByteArray)]
@@[save(save_state)]
@@[load(restore_state)]
@@system World {
    interface:
        bump_c()
        get_c(): int
    machine:
        $S {
            bump_c() { self.c.bump() }
            get_c(): int { @@:(self.c.get_value()); return }
        }
    domain:
        c = @@Counter(7)
}

func _init():
    var w = World._create()
    if w.get_c() != 7:
        print("FAIL initial c: " + str(w.get_c()))
        quit()
    w.bump_c()
    if w.get_c() != 8:
        print("FAIL post-bump c: " + str(w.get_c()))
        quit()
    var snap = w.save_state()
    var r = World._create()
    r.restore_state(snap)
    if r.get_c() != 8:
        print("FAIL restored c: " + str(r.get_c()))
        quit()
    r.bump_c()
    if r.get_c() != 9:
        print("FAIL continued c: " + str(r.get_c()))
        quit()
    print("PASS: 99_persist_param_child")
    quit()

@@target swift

@@system OperationsTest {
    operations:
        add(x: number, y: number): number {
            return x + y
        }

        multiply(x: number, y: number): number {
            return x * y
        }

        static factorial(n: number): number {
            if (n <= 1) {
                return 1
            }
            return n * OperationsTest.factorial(n - 1)
        }

        static is_even(n: number): boolean {
            return n % 2 == 0
        }
    interface:
        compute(a: number, b: number): number
        get_last_result(): number

    machine:
        $Ready {
            compute(a: number, b: number): number {
                // Use instance operations
                let sum_val = self.add(a, b)
                let prod_val = self.multiply(a, b)
                let last_result = sum_val + prod_val
                return last_result
            }

            get_last_result(): number {
                return self.last_result
            }
        }
    domain:
        last_result: number = 0

}

// main
    print("=== Test 22: Operations Basic (Swift) ===")
    let s = @@OperationsTest()

    // Test 1: Instance operations
    var result = s.add(3, 4)
    if result != 7 {
        fatalError("Expected 7, got \(result)")
    }
    print("1. add(3, 4) = \(result)")

    result = s.multiply(3, 4)
    if result != 12 {
        fatalError("Expected 12, got \(result)")
    }
    print("2. multiply(3, 4) = \(result)")

    // Test 2: Operations used in handler
    result = s.compute(3, 4)
    // compute returns add(3,4) + multiply(3,4) = 7 + 12 = 19
    if result != 19 {
        fatalError("Expected 19, got \(result)")
    }
    print("3. compute(3, 4) = \(result)")

    // Test 3: Static operations
    result = OperationsTest.factorial(5)
    if result != 120 {
        fatalError("Expected 120, got \(result)")
    }
    print("4. factorial(5) = \(result)")

    var is_even = OperationsTest.is_even(4)
    if is_even != true {
        fatalError("Expected true, got \(is_even)")
    }
    print("5. is_even(4) = \(is_even)")

    is_even = OperationsTest.is_even(7)
    if is_even != false {
        fatalError("Expected false, got \(is_even)")
    }
    print("6. is_even(7) = \(is_even)")

    // Test 4: Static via class
    result = OperationsTest.factorial(4)
    if result != 24 {
        fatalError("Expected 24, got \(result)")
    }
    print("7. OperationsTest.factorial(4) = \(result)")

    print("PASS: Operations basic works correctly")

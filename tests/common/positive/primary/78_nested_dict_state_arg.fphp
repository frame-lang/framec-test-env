@@[target("php")]

<?php

@@[persist]
@@system NestedDict {
    operations:
        @@[save]
        save_state(): string {}

        @@[load]
        restore_state(data: string) {}

    interface:
        configure(m: array)
        get_inner(outer_key: string, inner_key: string): int

    machine:
        $Idle {
            configure(m: array) { -> $Active(m) }
            get_inner(outer_key: string, inner_key: string): int { @@:(-1) }
        }
        $Active(m: array) {
            configure(m: array) { -> $Active(m) }
            get_inner(outer_key: string, inner_key: string): int {
                @@:(isset($m[$outer_key]) && isset($m[$outer_key][$inner_key]) ? $m[$outer_key][$inner_key] : -1)
            }
        }
    domain:
        n: int = 0
}

$s1 = new NestedDict();
$s1->configure(["u" => ["x" => 1, "y" => 2], "v" => ["z" => 3]]);
if ($s1->get_inner("u", "x") !== 1) { echo "FAIL pre\n"; exit(1); }
$snap = $s1->save_state();
$s2 = new NestedDict();

$s2->restore_state($snap);
if ($s2->get_inner("u", "x") !== 1) { echo "FAIL post u.x\n"; exit(1); }
if ($s2->get_inner("u", "y") !== 2) { echo "FAIL post u.y\n"; exit(1); }
if ($s2->get_inner("v", "z") !== 3) { echo "FAIL post v.z\n"; exit(1); }
echo "PASS: 78_nested_dict_state_arg\n";

@@[target("kotlin")]

@@system Sub {
    interface:
        ping(): Int
    machine:
        $Idle {
            ping(): Int { @@:(42) }
        }
}

@@[main]
@@system Top {
    interface:
        run(): Int
    machine:
        $Active {
            run(): Int { @@:(this.sub.ping()) }
        }
    domain:
        sub: Sub = @@Sub()
}

fun main() {
    val t = @@Top()
    if (t.run() != 42) {
        println("FAIL run(): ${t.run()}")
    } else {
        println("PASS: 91_main_attr_cross_ref")
    }
}

@@target kotlin

import kotlin.system.exitProcess

@@system Lamp {
    interface:
        turnOn()
        turnOff()
        getColor(): String
        setColor(color: String)
        isSwitchClosed(): Boolean

    machine:
        $Off {
            turnOn() {
                -> $On
            }
            getColor(): String {
                return this.color
            }
            setColor(color: String) {
                this.color = color
            }
            isSwitchClosed(): Boolean {
                return this.switch_closed
            }
        }

        $On {
            $>() {
                this.closeSwitch()
            }
            <$() {
                this.openSwitch()
            }
            turnOff() {
                -> $Off
            }
            getColor(): String {
                return this.color
            }
            setColor(color: String) {
                this.color = color
            }
            isSwitchClosed(): Boolean {
                return this.switch_closed
            }
        }

    actions:
        closeSwitch() {
            this.switch_closed = true
        }
        openSwitch() {
            this.switch_closed = false
        }

    domain:
        color = "white"
        switch_closed = false
}

fun main() {
    println("=== Test 31: Doc Lamp Basic ===")
    val lamp = @@Lamp()

    // Initially off
    if (lamp.isSwitchClosed() != false) {
        println("FAIL: Switch should be open initially")
        exitProcess(1)
    }

    // Turn on - should close switch
    lamp.turnOn()
    if (lamp.isSwitchClosed() != true) {
        println("FAIL: Switch should be closed after turnOn")
        exitProcess(1)
    }

    // Check color
    if ((lamp.getColor() as String) != "white") {
        println("FAIL: Expected 'white', got '${lamp.getColor()}'")
        exitProcess(1)
    }

    // Set color
    lamp.setColor("blue")
    if ((lamp.getColor() as String) != "blue") {
        println("FAIL: Expected 'blue', got '${lamp.getColor()}'")
        exitProcess(1)
    }

    // Turn off - should open switch
    lamp.turnOff()
    if (lamp.isSwitchClosed() != false) {
        println("FAIL: Switch should be open after turnOff")
        exitProcess(1)
    }

    println("PASS: Basic lamp works correctly")
}

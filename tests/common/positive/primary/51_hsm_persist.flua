@@[target("lua")]
@@[persist]
@@system HSMPersist {
    operations:
        @@[save]
        save_state(): string {}

        @@[load]
        restore_state(data: string) {}

    interface:
        increment_child()
        increment_parent()
        get_child_count(): int
        get_parent_count(): int
        get_state(): str

    machine:
        $Child => $Parent {
            $.child_count: int = 0

            increment_child() {
                $.child_count = $.child_count + 1
            }

            increment_parent() {
                -- Forward to parent
                => $^
            
            }

            get_child_count(): int {
                @@:($.child_count)
                return
            }

            get_parent_count(): int {
                -- Forward to parent
                => $^
            
            }

            get_state(): str {
                @@:("Child")
                return
            }
        }

        $Parent {
            $.parent_count: int = 100

            increment_parent() {
                $.parent_count = $.parent_count + 1
            }

            get_parent_count(): int {
                @@:($.parent_count)
                return
            }

            get_state(): str {
                @@:("Parent")
                return
            }
        }
}

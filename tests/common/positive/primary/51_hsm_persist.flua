@@target lua
@@persist
@@system HSMPersist {
    interface:
        increment_child()
        increment_parent()
        get_child_count(): int
        get_parent_count(): int
        get_state(): str

    machine:
        $Child => $Parent {
            $.child_count: int = 0

            increment_child() {
                $.child_count = $.child_count + 1
            }

            increment_parent() {
                -- Forward to parent
                => $^
            
            }

            get_child_count(): int {
                return $.child_count
            }

            get_parent_count(): int {
                -- Forward to parent
                => $^
            
            }

            get_state(): str {
                return "Child"
            }
        }

        $Parent {
            $.parent_count: int = 100

            increment_parent() {
                $.parent_count = $.parent_count + 1
            }

            get_parent_count(): int {
                return $.parent_count
            }

            get_state(): str {
                return "Parent"
            }
        }
}

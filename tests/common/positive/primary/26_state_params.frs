@@[target("rust")]

@@system StateParams {
    interface:
        start(val: i32)
        get_value(): i32

    machine:
        $Idle {
            start(val: i32) {
                -> $Counter(val)
            }

            get_value(): i32 {
                @@:(0)
                return;
            }
        }

        $Counter(initial: i32) {
            $>() {
                println!("Counter entered with initial={}", initial);
            }

            get_value(): i32 {
                @@:(initial)
                return;
            }
        }
}

fn main() {
    println!("=== Test 26: State Parameters ===");
    let mut s = @@StateParams();

    let val = s.get_value();
    assert_eq!(val, 0, "Expected 0 in Idle");
    println!("Initial value: {}", val);

    s.start(42);
    let val = s.get_value();
    assert_eq!(val, 42, "Expected 42 in Counter from state param");
    println!("Value after transition: {}", val);

    println!("PASS: State parameters work correctly");
}

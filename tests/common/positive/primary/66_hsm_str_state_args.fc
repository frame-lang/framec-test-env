@@[target("c")]

#include <stdio.h>
#include <stdlib.h>
#include <string.h>

@@system StrStateArg {
    interface:
        configure(label: str)
        identify(): str

    machine:
        $Idle {
            configure(label: str) {
                -> $Active(label)
            }
            identify(): str {
                @@:("anonymous")
            }
        }

        $Active => $Frame(label: str) {
            configure(label: str) {
                -> $Active(label)
            }
            identify(): str {
                => $^
            }
        }

        $Frame {
            identify(): str {
                @@:(label)
            }
        }
    domain:
        n : int = 0
}

int main(void) {
    StrStateArg* s = @@StrStateArg();
    const char* r = StrStateArg_identify(s);
    if (strcmp(r, "anonymous") != 0) { printf("FAIL idle: %s\n", r); return 1; }
    StrStateArg_configure(s, "alice");
    r = StrStateArg_identify(s);
    if (strcmp(r, "alice") != 0) { printf("FAIL alice: %s\n", r); return 1; }
    StrStateArg_configure(s, "bob");
    r = StrStateArg_identify(s);
    if (strcmp(r, "bob") != 0) { printf("FAIL bob: %s\n", r); return 1; }
    printf("PASS: 66_hsm_str_state_args\n");
    StrStateArg_destroy(s);
    return 0;
}

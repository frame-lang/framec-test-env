@@[target("ruby")]

# Test 105: @@:self.method() from lifecycle handlers (F1 regression)

@@system LifecycleSelfCall {
    interface:
        tick()
        go()
        get_count(): int

    machine:
        $A {
            $>() { @@:self.tick() }
            <$() { @@:self.tick() }
            go() { -> $B }
            tick() { self.count = self.count + 1 }
            get_count(): int { @@:(self.count) }
        }

        $B {
            $>() { @@:self.tick() }
            tick() { self.count = self.count + 1 }
            get_count(): int { @@:(self.count) }
        }

    domain:
        count: int = 0
}

puts("=== Test 105: @@:self.method() from lifecycle handlers (F1 regression) ===")
s = @@LifecycleSelfCall()
raise "Expected 1, got #{s.get_count()}" unless s.get_count() == 1
puts("TC1: @@:self from start state $> - PASS")
s.go()
raise "Expected 3, got #{s.get_count()}" unless s.get_count() == 3
puts("TC2/TC3: @@:self from <$ + post-transition $> - PASS")
puts("PASS: F1 regression")

@@[target("kotlin")]

import kotlin.system.exitProcess

// Test 53: Self-call transition guard
//
// Verifies the automatic transition guard contract: when a handler
// self-calls a method that triggers a transition, code after the
// self-call must NOT execute. The trace must equal exactly
// ["run:before-self-call", "do_transition:body", "Done:enter"].

@@system TransitionGuard {

    interface:
        run()
        do_transition()
        get_trace(): MutableList<Any?>

    machine:
        $Active {
            run() {
                this.trace.add("run:before-self-call")
                @@:self.do_transition()
                this.trace.add("run:after-self-call")
            }

            do_transition() {
                this.trace.add("do_transition:body")
                -> $Done
            }

            get_trace(): MutableList<Any?> {
                @@:(this.trace)
                return;
            }
        }

        $Done {
            $>() {
                this.trace.add("Done:enter")
            }

            get_trace(): MutableList<Any?> {
                @@:(this.trace)
                return;
            }
        }

    domain:
        trace = mutableListOf<String>()
}

fun main() {
    println("=== Test 53: Self-call transition guard ===")
    val t = @@TransitionGuard()
    t.run()
    val trace = t.get_trace() as MutableList<*>

    if (!trace.contains("run:before-self-call")) {
        println("FAIL TC1: pre-call statement must execute, trace=$trace")
        exitProcess(1)
    }
    println("TC1: pre-call statement executed - PASS")

    if (!trace.contains("do_transition:body")) {
        println("FAIL TC2: self-called handler body must execute, trace=$trace")
        exitProcess(1)
    }
    println("TC2: self-called handler body executed - PASS")

    if (!trace.contains("Done:enter")) {
        println("FAIL TC3: cascade enter on transition target must fire, trace=$trace")
        exitProcess(1)
    }
    println("TC3: target state \$> handler fired - PASS")

    if (trace.contains("run:after-self-call")) {
        println("FAIL TC4: post-call statement MUST NOT execute (transition guard), trace=$trace")
        exitProcess(1)
    }
    println("TC4: post-call statement suppressed by automatic guard - PASS")

    val expected = listOf("run:before-self-call", "do_transition:body", "Done:enter")
    if (trace.size != expected.size) {
        println("FAIL TC5: trace size mismatch, got ${trace.size}, expected ${expected.size}")
        exitProcess(1)
    }
    for (i in expected.indices) {
        if (trace[i] != expected[i]) {
            println("FAIL TC5: trace[$i] mismatch, got ${trace[i]}, expected ${expected[i]}")
            exitProcess(1)
        }
    }
    println("TC5: trace order is exactly [before, body, enter] - PASS")

    println("PASS: automatic transition guard suppresses post-self-call code")
}

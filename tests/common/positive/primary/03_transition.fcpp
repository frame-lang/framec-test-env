@@target cpp_17

#include <iostream>
#include <string>
#include <cassert>

@@system TransitionTest {
    interface:
        next()
        get_state(): str

    machine:
        $A {
            next() {
                -> $B
            }
            get_state(): str {
                return std::string("A")
            }
        }

        $B {
            next() {
                -> $C
            }
            get_state(): str {
                return std::string("B")
            }
        }

        $C {
            get_state(): str {
                return std::string("C")
            }
        }
}

int main() {
    TransitionTest s;
    assert(s.get_state() == "A");
    s.next();
    assert(s.get_state() == "B");
    s.next();
    assert(s.get_state() == "C");
    std::cout << "PASS: 03 transition" << std::endl;
    return 0;
}

@@target ruby

@@system HSMEnterBoth {
    interface:
        go_to_child()
        go_to_parent()
        get_log(): list
        get_state(): str

    machine:
        $Start {
            go_to_child() { -> $Child }
            go_to_parent() { -> $Parent }
            get_log(): list {
                @@:(self.log)
            }
            get_state(): str {
                @@:("Start")
            }
        }

        $Child => $Parent {
            $>() { self.log.push("Child:enter") }
            go_to_parent() { -> $Parent }
            get_log(): list {
                @@:(self.log)
            }
            get_state(): str {
                @@:("Child")
            }
        }

        $Parent {
            $>() { self.log.push("Parent:enter") }
            go_to_child() { -> $Child }
            get_log(): list {
                @@:(self.log)
            }
            get_state(): str {
                @@:("Parent")
            }
        }
    domain:
        log: list = []
}

puts("=== Test 47: HSM Enter in Both ===")
s = HSMEnterBoth.new

s.go_to_child()
log = s.get_log()
raise "Expected Child:enter, got #{log}" unless log.include?("Child:enter")
raise "Parent:enter should NOT fire when entering child, got #{log}" if log.include?("Parent:enter")
raise "Expected Child, got #{s.get_state()}" unless s.get_state() == "Child"
puts("TC2.3.1: Only child's enter fires when entering child - PASS")

s.go_to_parent()
log = s.get_log()
raise "Expected Parent:enter, got #{log}" unless log.include?("Parent:enter")
raise "Expected Parent, got #{s.get_state()}" unless s.get_state() == "Parent"
puts("TC2.3.2: Parent's enter fires when transitioning to parent - PASS")

raise "Expected exactly 1 Child:enter, got #{log}" unless log.count("Child:enter") == 1
raise "Expected exactly 1 Parent:enter, got #{log}" unless log.count("Parent:enter") == 1
puts("TC2.3.3: No implicit cascading of enter handlers - PASS")

s.go_to_child()
log = s.get_log()
raise "Expected 2 Child:enter, got #{log}" unless log.count("Child:enter") == 2
raise "Expected still 1 Parent:enter, got #{log}" unless log.count("Parent:enter") == 1
puts("TC2.3.4: Re-entering child fires child enter again - PASS")

puts("PASS: HSM enter in both works correctly")

@@[target("ruby")]

# Test 47: HSM Enter Cascade — Both Parent and Child have $>
#
# Tests the HSM enter cascade per docs/frame_runtime_introduction.md
# Step 21+. When entering an HSM child, the kernel fires $> on every
# layer of the new chain top-down (parent first, child last).

@@system HSMEnterBoth {
    interface:
        go_to_child()
        go_to_parent()
        get_log(): list
        get_state(): str

    machine:
        $Start {
            go_to_child() { -> $Child }
            go_to_parent() { -> $Parent }
            get_log(): list { @@:(self.log) }
            get_state(): str { @@:("Start") }
        }

        $Child => $Parent {
            $>() { self.log.push("Child:enter") }
            go_to_parent() { -> $Parent }
            get_log(): list { @@:(self.log) }
            get_state(): str { @@:("Child") }
        }

        $Parent {
            $>() { self.log.push("Parent:enter") }
            go_to_child() { -> $Child }
            get_log(): list { @@:(self.log) }
            get_state(): str { @@:("Parent") }
        }
    domain:
        log: list = []
}

puts("=== Test 47: HSM Enter Cascade — Both ===")
s = HSMEnterBoth.new

# TC1: Entering Child fires Parent's $> first (top-down cascade), then Child's $>.
s.go_to_child()
log = s.get_log()
raise "Expected Child, got #{s.get_state()}" unless s.get_state() == "Child"
raise "Expected Parent:enter (cascade), got #{log}" unless log.include?("Parent:enter")
raise "Expected Child:enter, got #{log}" unless log.include?("Child:enter")
parent_idx = log.index("Parent:enter")
child_idx = log.index("Child:enter")
raise "Parent:enter must precede Child:enter (top-down), got #{log}" unless parent_idx < child_idx
puts("TC1: Parent's $> fires before Child's $> on cascade entry - PASS")

# TC2: Direct entry to Parent fires Parent's $> only.
s.go_to_parent()
log = s.get_log()
raise "Expected Parent, got #{s.get_state()}" unless s.get_state() == "Parent"
raise "Expected 2 Parent:enter, got #{log.count('Parent:enter')}" unless log.count("Parent:enter") == 2
raise "Expected still 1 Child:enter, got #{log.count('Child:enter')}" unless log.count("Child:enter") == 1
puts("TC2: Direct Parent entry fires only Parent's $> - PASS")

# TC3: Transitioning back to Child fires both cascades.
s.go_to_child()
log = s.get_log()
raise "Expected 3 Parent:enter total, got #{log.count('Parent:enter')}" unless log.count("Parent:enter") == 3
raise "Expected 2 Child:enter total, got #{log.count('Child:enter')}" unless log.count("Child:enter") == 2
puts("TC3: Re-entering Child cascades through Parent again - PASS")

puts("PASS: HSM enter cascade fires both layers top-down")

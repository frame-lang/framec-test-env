@@target swift

// Test: Interface method return_init
// Validates that interface methods can have default return values
// Syntax: method(): type = "default_value"

@@system ReturnInitTest {
    interface:
        get_status(): string = "unknown"
        get_count(): number = 0
        get_flag(): boolean = false
        trigger()

    machine:
        $Start {
            $>() {
                // Start state enter (no-op)
            }
            get_status() {
                // Do not set return - should use default "unknown"
            }
            get_count() {
                // Do not set return - should use default 0
            }
            get_flag() {
                // Do not set return - should use default false
            }
            trigger() {
                -> $Active
            }
        }

        $Active {
            $>() {
                // Active state enter (no-op)
            }
            get_status() {
                @@:return = "active"
            }
            get_count() {
                @@:return = 42
            }
            get_flag() {
                @@:return = true
            }
            trigger() {
                -> $Start
            }
        }
}

// main
    print("TAP version 14")
    print("1..6")

    let s = @@ReturnInitTest()

    // Test 1: Default string return
    if s.get_status() == "unknown" {
        print("ok 1 - default string return is 'unknown'")
    } else {
        print("not ok 1 - default string return is 'unknown' # got \(s.get_status())")
    }

    // Test 2: Default int return
    if s.get_count() == 0 {
        print("ok 2 - default int return is 0")
    } else {
        print("not ok 2 - default int return is 0 # got \(s.get_count())")
    }

    // Test 3: Default bool return
    if s.get_flag() == false {
        print("ok 3 - default bool return is false")
    } else {
        print("not ok 3 - default bool return is false # got \(s.get_flag())")
    }

    // Transition to Active state
    s.trigger()

    // Test 4: Explicit string return overrides default
    if s.get_status() == "active" {
        print("ok 4 - explicit return overrides default string")
    } else {
        print("not ok 4 - explicit return overrides default string # got \(s.get_status())")
    }

    // Test 5: Explicit int return overrides default
    if s.get_count() == 42 {
        print("ok 5 - explicit return overrides default int")
    } else {
        print("not ok 5 - explicit return overrides default int # got \(s.get_count())")
    }

    // Test 6: Explicit bool return overrides default
    if s.get_flag() == true {
        print("ok 6 - explicit return overrides default bool")
    } else {
        print("not ok 6 - explicit return overrides default bool # got \(s.get_flag())")
    }

    print("# PASS - return_init provides default return values")

@@[target("gdscript")]
extends SceneTree

# Test 40: HSM Parent State Variables
#
# This test validates that parent and child states in an HSM hierarchy
# maintain SEPARATE compartments with independent state variables.
#
# EXPECTED ARCHITECTURE:
# - Child has its own compartment: {state: "Child", state_vars: {child_count: 0}}
# - Parent has its own compartment: {state: "Parent", state_vars: {parent_count: 100}}
# - Child's compartment.parent_compartment -> Parent's compartment
# - When child forwards to parent, parent accesses ITS OWN compartment
#
# CURRENT BUG:
# - Only one compartment exists (the current state's)
# - Parent's state vars are never initialized because we never transition TO parent
# - When child forwards to parent, parent tries to access child's compartment
# - Result: KeyError because parent_count doesn't exist in child's state_vars

@@system HSMParentStateVars {
    interface:
        get_child_count(): int
        get_parent_count(): int

    machine:
        $Child => $Parent {
            $.child_count: int = 0

            $>() {
                # RFC-0019: forward $> to $Parent so its state-var
                # initializer ($.parent_count = 100) runs.
                => $^
            }

            get_child_count(): int {
                @@:($.child_count)
                return
            }

            get_parent_count(): int {
                # Forward to parent - parent should use ITS compartment
                => $^
            }
        }

        $Parent {
            $.parent_count: int = 100

            get_parent_count(): int {
                # This should return 100 from parent's compartment
                @@:($.parent_count)
                return
            }
        }
}

func main():
    print("=== Test 40: HSM Parent State Variables ===")
    var s = @@HSMParentStateVars()

    # Child's state var should be 0 (from child's compartment)
    var child_count = s.get_child_count()
    assert(child_count == 0, "Expected child_count=0, got " + str(child_count))
    print("Child count: " + str(child_count))

    # Parent's state var should be 100 (from parent's compartment)
    # This FAILS with current implementation because:
    # 1. Parent's compartment doesn't exist
    # 2. Parent's $> handler was never called
    # 3. Parent tries to access "parent_count" in child's state_vars
    var parent_count = s.get_parent_count()
    assert(parent_count == 100, "Expected parent_count=100, got " + str(parent_count))
    print("Parent count: " + str(parent_count))

    print("PASS: HSM parent state variables work correctly")

func _init():
    main()
    quit()

@@[target("swift")]

import Foundation

@@system FloatStateArg {
    interface:
        configure(rate: float)
        scale(v: float): float

    machine:
        $Idle {
            configure(rate: Double) {
                -> $Active(rate)
            }
            scale(v: Double): Double {
                @@:(v)
            }
        }

        $Active => $Frame(rate: Double) {
            configure(rate: Double) {
                -> $Active(rate)
            }
            scale(v: Double): Double {
                => $^
            }
        }

        $Frame {
            scale(v: Double): Double {
                @@:(v * rate)
            }
        }
    domain:
        n : int = 0
}

let s = @@FloatStateArg()
if abs(s.scale(2.0) - 2.0) > 1e-9 { print("FAIL idle"); exit(1) }
s.configure(0.5)
if abs(s.scale(10.0) - 5.0) > 1e-9 { print("FAIL 0.5"); exit(1) }
s.configure(2.5)
if abs(s.scale(4.0) - 10.0) > 1e-9 { print("FAIL 2.5"); exit(1) }
print("PASS: 68_hsm_float_state_args")

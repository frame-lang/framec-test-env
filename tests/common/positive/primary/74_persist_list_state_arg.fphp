@@[target("php")]


@@[persist(string)]
@@[save(save_state)]
@@[load(restore_state)]
@@system PersistList {
    interface:
        configure(items: array)
        first_item(): int
        size(): int

    machine:
        $Idle {
            configure(items: array) {
                -> $Active(items)
            }
            first_item(): int { @@:(-1) }
            size(): int { @@:(0) }
        }
        $Active(items: array) {
            configure(items: array) {
                -> $Active(items)
            }
            first_item(): int { @@:($items[0]) }
            size(): int { @@:(count($items)) }
        }
    domain:
        n: int = 0
}

$s1 = @@PersistList();
$s1->configure([10, 20, 30]);
if ($s1->first_item() !== 10) { echo "FAIL pre\n"; exit(1); }
$snap = $s1->save_state();

$s2 = @@PersistList();


$s2->restore_state($snap);
if ($s2->first_item() !== 10) { echo "FAIL restored first_item\n"; exit(1); }
if ($s2->size() !== 3) { echo "FAIL restored size\n"; exit(1); }
echo "PASS: 74_persist_list_state_arg\n";

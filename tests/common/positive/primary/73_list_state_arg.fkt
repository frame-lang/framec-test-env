@@[target("kotlin")]

@@system ListStateArg {
    interface:
        configure(items: List<Int>)
        first_item(): Int
        size(): Int

    machine:
        $Idle {
            configure(items: List<Int>) {
                -> $Active(items)
            }
            first_item(): Int {
                @@:(-1)
            }
            size(): Int {
                @@:(0)
            }
        }
        $Active(items: List<Int>) {
            configure(items: List<Int>) {
                -> $Active(items)
            }
            first_item(): Int {
                @@:(items[0])
            }
            size(): Int {
                @@:(items.size)
            }
        }
    domain:
        n : Int = 0
}

fun main() {
    val s = @@ListStateArg()
    if (s.first_item() != -1) { println("FAIL idle first_item"); kotlin.system.exitProcess(1) }
    if (s.size() != 0) { println("FAIL idle size"); kotlin.system.exitProcess(1) }
    s.configure(listOf(10, 20, 30))
    if (s.first_item() != 10) { println("FAIL active first_item"); kotlin.system.exitProcess(1) }
    if (s.size() != 3) { println("FAIL active size"); kotlin.system.exitProcess(1) }
    s.configure(listOf(7))
    if (s.first_item() != 7) { println("FAIL retransition first_item"); kotlin.system.exitProcess(1) }
    if (s.size() != 1) { println("FAIL retransition size"); kotlin.system.exitProcess(1) }
    println("PASS: 73_list_state_arg")
}

<?php
@@[target("php")]

@@system FloatStateArg {
    interface:
        configure(rate: float)
        scale(v: float): float

    machine:
        $Idle {
            configure(rate: float) {
                -> $Active($rate)
            }
            scale(v: float): float {
                @@:($v)
                return;
            }
        }

        $Active => $Frame(rate: float) {
            configure(rate: float) {
                -> $Active($rate)
            }
            scale(v: float): float {
                => $^
            }
        }

        $Frame {
            scale(v: float): float {
                @@:($v * $rate)
                return;
            }
        }
    domain:
        n: int = 0
}

$s = @@FloatStateArg();
if ($s->scale(2.0) !== 2.0) { echo "FAIL idle\n"; exit(1); }
$s->configure(0.5);
if (abs($s->scale(10.0) - 5.0) > 1e-9) { echo "FAIL 0.5\n"; exit(1); }
$s->configure(2.5);
if (abs($s->scale(4.0) - 10.0) > 1e-9) { echo "FAIL 2.5\n"; exit(1); }
echo "PASS: 68_hsm_float_state_args\n";

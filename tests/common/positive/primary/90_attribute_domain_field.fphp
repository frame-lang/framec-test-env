@@[target("php")]


@@system Demo {
    interface:
        get_a(): int
        get_php_only(): int
    machine:
        $S {
            get_a(): int { @@:($this->a) }
            get_php_only(): int { @@:($this->php_only) }
        }
    domain:
        a: int = 1
        @@[target("python_3")] py_only: int = 2
        @@[target("php")]
        php_only: int = 42
}

$d = @@Demo();
if ($d->get_a() !== 1) { echo "FAIL get_a: " . $d->get_a() . "\n"; exit(1); }
if ($d->get_php_only() !== 42) { echo "FAIL get_php_only: " . $d->get_php_only() . "\n"; exit(1); }
if (property_exists($d, "py_only")) { echo "FAIL: py_only should have been filtered out by @@[target(\"python_3\")]\n"; exit(1); }
echo "PASS: 90_attribute_domain_field\n";

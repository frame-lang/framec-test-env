@@[target("dart")]
import 'dart:convert';
@@[persist(JSON)]
@@[save(snapshot)]
@@[load(rehydrate)]
@@system Counter {
    interface:
        get_fire_count(): int

    machine:
        $A {
            $>() {
                this.fire_count = this.fire_count + 1;
            }
            get_fire_count(): int { @@:(this.fire_count) }
        }

    domain:
        fire_count: int = 0
}

void main() {
    var c = Counter();
    if (c.get_fire_count() != 1) {
        print("FAIL: expected 1 after construction, got ${c.get_fire_count()}");
        return;
    }
    var snap = c.snapshot();

    var fresh = Counter();
    if (fresh.get_fire_count() != 1) {
        print("FAIL: expected 1 on fresh construction, got ${fresh.get_fire_count()}");
        return;
    }

    fresh.rehydrate(snap);
    if (fresh.get_fire_count() != 1) {
        print("D4 violation: \$> re-ran on restore (count=${fresh.get_fire_count()}, expected 1)");
        return;
    }

    print("PASS: rfc0015_restore_skips_init");
}

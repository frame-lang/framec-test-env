<?php
@@target php

@@system Calculator {
    interface:
        add(a: int, b: int): int
        get_result(): int

    machine:
        $Ready {
            add(a: int, b: int): int {
                $this->result = $a + $b;
                return $this->result;
            }

            get_result(): int {
                return $this->result;
            }
        }
    domain:
        result = 0
}

@@system Counter {
    interface:
        increment()
        get_count(): int

    machine:
        $Active {
            increment() {
                $this->count = $this->count + 1;
            }

            get_count(): int {
                return $this->count;
            }
        }
    domain:
        count = 0
}

echo "=== Test 39: Tagged System Instantiation ===" . "\n";

$calc = new Calculator();
$counter = new Counter();

$result = $calc->add(3, 4);
if ($result !== 7) { echo "FAIL: Expected 7, got {$result}\n"; exit(1); }
echo "Calculator->add(3, 4) = {$result}" . "\n";

$result = $calc->get_result();
if ($result !== 7) { echo "FAIL: Expected 7, got {$result}\n"; exit(1); }
echo "Calculator->get_result() = {$result}" . "\n";

$counter->increment();
$counter->increment();
$counter->increment();
$count = $counter->get_count();
if ($count !== 3) { echo "FAIL: Expected 3, got {$count}\n"; exit(1); }
echo "Counter after 3 increments: {$count}" . "\n";

echo "PASS: Tagged instantiation works correctly" . "\n";

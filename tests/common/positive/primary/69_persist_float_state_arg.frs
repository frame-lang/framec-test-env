@@[target("rust")]
@@[persist]

@@system PFloat {
    interface:
        configure(rate: f64)
        get_rate(): f64

    machine:
        $Idle {
            configure(rate: f64) {
                -> $Active(rate)
            }
            get_rate(): f64 {
                @@:(0.0)
                return;
            }
        }

        $Active(rate: f64) {
            get_rate(): f64 {
                @@:(rate)
                return;
            }
        }
    domain:
        n: i32
}

fn main() {
    let mut s = @@PFloat();
    s.configure(3.14159);
    let snap = s.save_state();
    let mut s2 = PFloat::restore_state(&snap);
    let r = s2.get_rate();
    if (r - 3.14159).abs() > 1e-9 { println!("FAIL {}", r); std::process::exit(1); }
    println!("PASS: 69_persist_float_state_arg, rate={}", r);
}

@@target kotlin

import kotlin.system.exitProcess

@@system HSMThreeLevels {
    interface:
        handle_at_grandchild()
        forward_to_child()
        forward_to_parent()
        forward_through_all()
        get_log(): MutableList<Any?>

    machine:
        $Grandchild => $Child {
            $.grandchild_var: Int = 1

            handle_at_grandchild() {
                val v = $.grandchild_var
                this.log.add("Grandchild:handled(var=" + v + ")")
            }

            forward_to_child() {
                this.log.add("Grandchild:forward_to_child")
                => $^
            }

            forward_to_parent() {
                this.log.add("Grandchild:forward_to_parent")
                => $^
            }

            forward_through_all() {
                this.log.add("Grandchild:forward_through_all")
                => $^
            }

            get_log(): MutableList<Any?> {
                @@:(this.log)
                return;
            }
        }

        $Child => $Parent {
            $.child_var: Int = 10

            forward_to_child() {
                val v = $.child_var
                this.log.add("Child:handled(var=" + v + ")")
            }

            forward_to_parent() {
                val v = $.child_var
                this.log.add("Child:forward_to_parent(var=" + v + ")")
                => $^
            }

            forward_through_all() {
                val v = $.child_var
                this.log.add("Child:forward_through_all(var=" + v + ")")
                => $^
            }

            get_log(): MutableList<Any?> {
                @@:(this.log)
                return;
            }
        }

        $Parent {
            $.parent_var: Int = 100

            forward_to_parent() {
                val v = $.parent_var
                this.log.add("Parent:handled(var=" + v + ")")
            }

            forward_through_all() {
                val v = $.parent_var
                this.log.add("Parent:forward_through_all(var=" + v + ")")
            }

            get_log(): MutableList<Any?> {
                @@:(this.log)
                return;
            }
        }
    domain:
        log = mutableListOf<String>()
}

fun main() {
    println("=== Test 42: HSM Three-Level Hierarchy ===")
    val s = @@HSMThreeLevels()

    // TC1.2.1: Three-level hierarchy compiles
    println("TC1.2.1: Three-level hierarchy compiles - PASS")

    // TC1.2.2: Handle at grandchild (no forward)
    s.handle_at_grandchild()
    var log = s.get_log() as MutableList<*>
    if (!log.contains("Grandchild:handled(var=1)")) {
        println("FAIL: Expected Grandchild handler, got $log")
        exitProcess(1)
    }
    println("TC1.2.2: Grandchild handles locally - PASS")

    // TC1.2.3: Forward from grandchild to child
    s.forward_to_child()
    log = s.get_log() as MutableList<*>
    if (!log.contains("Grandchild:forward_to_child")) {
        println("FAIL: Expected Grandchild forward, got $log")
        exitProcess(1)
    }
    if (!log.contains("Child:handled(var=10)")) {
        println("FAIL: Expected Child handler, got $log")
        exitProcess(1)
    }
    println("TC1.2.3: Forward grandchild->child - PASS")

    // TC1.2.4: Forward from grandchild through child to parent
    s.forward_to_parent()
    log = s.get_log() as MutableList<*>
    if (!log.contains("Grandchild:forward_to_parent")) {
        println("FAIL: Expected Grandchild forward, got $log")
        exitProcess(1)
    }
    if (!log.contains("Child:forward_to_parent(var=10)")) {
        println("FAIL: Expected Child forward, got $log")
        exitProcess(1)
    }
    if (!log.contains("Parent:handled(var=100)")) {
        println("FAIL: Expected Parent handler, got $log")
        exitProcess(1)
    }
    println("TC1.2.4: Forward grandchild->child->parent - PASS")

    // TC1.2.5: Forward through entire chain
    s.forward_through_all()
    log = s.get_log() as MutableList<*>
    if (!log.contains("Grandchild:forward_through_all")) {
        println("FAIL: Expected Grandchild, got $log")
        exitProcess(1)
    }
    if (!log.contains("Child:forward_through_all(var=10)")) {
        println("FAIL: Expected Child, got $log")
        exitProcess(1)
    }
    if (!log.contains("Parent:forward_through_all(var=100)")) {
        println("FAIL: Expected Parent, got $log")
        exitProcess(1)
    }
    println("TC1.2.5: Full chain forward - PASS")

    // Verify state variable isolation
    println("TC1.2.6: State vars isolated (grandchild=1, child=10, parent=100) - PASS")

    println("PASS: HSM three-level hierarchy works correctly")
}

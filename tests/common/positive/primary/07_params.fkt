@@target kotlin

import kotlin.system.exitProcess

@@system WithParams {
    interface:
        start(initial: Int)
        add(value: Int)
        multiply(a: Int, b: Int): Int
        get_total(): Int

    machine:
        $Idle {
            start(initial: Int) {
                this.total = initial
                println("Started with initial value: " + initial)
                -> $Running
            }

            add(value: Int) {
                println("Cannot add in Idle state")
            }

            multiply(a: Int, b: Int): Int {
                return 0
            }

            get_total(): Int {
                return this.total
            }
        }

        $Running {
            start(initial: Int) {
                println("Already running")
            }

            add(value: Int) {
                this.total += value
                println("Added " + value + ", total is now " + this.total)
            }

            multiply(a: Int, b: Int): Int {
                val result = a * b
                this.total += result
                println("Multiplied " + a + " * " + b + " = " + result + ", total is now " + this.total)
                return result
            }

            get_total(): Int {
                return this.total
            }
        }
    domain:
        total = 0
}

fun main() {
    println("=== Test 07: Handler Parameters ===")
    val s = WithParams()

    // Initial total should be 0
    var total = s.get_total() as Int
    if (total != 0) {
        throw RuntimeException("Expected initial total=0, got $total")
    }

    // Start with initial value
    s.start(100)
    total = s.get_total() as Int
    if (total != 100) {
        throw RuntimeException("Expected total=100, got $total")
    }
    println("After start(100): total = $total")

    // Add value
    s.add(25)
    total = s.get_total() as Int
    if (total != 125) {
        throw RuntimeException("Expected total=125, got $total")
    }
    println("After add(25): total = $total")

    // Multiply with two params
    val result = s.multiply(3, 5) as Int
    if (result != 15) {
        throw RuntimeException("Expected multiply result=15, got $result")
    }
    total = s.get_total() as Int
    if (total != 140) {
        throw RuntimeException("Expected total=140, got $total")
    }
    println("After multiply(3,5): result = $result, total = $total")

    println("PASS: Handler parameters work correctly")
}

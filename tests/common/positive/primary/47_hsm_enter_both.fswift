@@[target("swift")]

// Test 47: HSM Enter Cascade — Both Parent and Child have $>

@@system HSMEnterBoth {
    interface:
        go_to_child()
        go_to_parent()
        get_log(): string[]
        get_state(): str

    machine:
        $Start {
            go_to_child() { -> $Child }
            go_to_parent() { -> $Parent }
            get_log(): list { @@:(self.log) }
            get_state(): str { @@:("Start") }
        }

        $Child => $Parent {
            $>() { self.log.append("Child:enter") }
            go_to_parent() { -> $Parent }
            get_log(): list { @@:(self.log) }
            get_state(): str { @@:("Child") }
        }

        $Parent {
            $>() { self.log.append("Parent:enter") }
            go_to_child() { -> $Child }
            get_log(): list { @@:(self.log) }
            get_state(): str { @@:("Parent") }
        }
    domain:
        log: string[] = []
}

// main
    print("=== Test 47: HSM Enter Cascade — Both ===")
    let s = @@HSMEnterBoth()

    s.go_to_child()
    var log = s.get_log()
    if s.get_state() != "Child" { fatalError("Expected Child") }
    let pi = log.firstIndex(of: "Parent:enter") ?? -1
    let ci = log.firstIndex(of: "Child:enter") ?? -1
    if pi == -1 { fatalError("Expected Parent:enter") }
    if ci == -1 { fatalError("Expected Child:enter") }
    if pi >= ci { fatalError("Parent:enter must precede Child:enter") }
    print("TC1: Parent's $> fires before Child's $> on cascade entry - PASS")

    s.go_to_parent()
    log = s.get_log()
    if s.get_state() != "Parent" { fatalError("Expected Parent") }
    if log.filter({ $0 == "Parent:enter" }).count != 2 { fatalError("Expected 2 Parent:enter") }
    if log.filter({ $0 == "Child:enter" }).count != 1 { fatalError("Expected still 1 Child:enter") }
    print("TC2: Direct Parent entry fires only Parent's $> - PASS")

    s.go_to_child()
    log = s.get_log()
    if log.filter({ $0 == "Parent:enter" }).count != 3 { fatalError("Expected 3 Parent:enter") }
    if log.filter({ $0 == "Child:enter" }).count != 2 { fatalError("Expected 2 Child:enter") }
    print("TC3: Re-entering Child cascades through Parent again - PASS")

    print("PASS: HSM enter cascade fires both layers top-down")

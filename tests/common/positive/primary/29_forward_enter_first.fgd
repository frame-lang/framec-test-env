@@target gdscript
extends SceneTree

@@system ForwardEnterFirst {
    interface:
        process()
        get_counter(): int
        get_log(): list

    machine:
        $Idle {
            process() {
                -> => $Working
            }

            get_counter(): int {
                @@:(-1)
                return
            }

            get_log(): list {
                @@:(self.log)
                return
            }
        }

        $Working {
            $.counter: int = 100

            $>() {
                self.log.append("Working:enter")
            }

            process() {
                self.log.append("Working:process:counter=" + str($.counter))
                $.counter = $.counter + 1
            }

            get_counter(): int {
                @@:($.counter)
                return
            }

            get_log(): list {
                @@:(self.log)
                return
            }
        }
    domain:
        log: list = []
}

func main():
    print("=== Test 29: Forward Enter First ===")
    var s = @@ForwardEnterFirst()

    # Initial state is Idle
    assert(s.get_counter() == -1, "Expected -1 in Idle")

    # Call process - should forward to Working
    # Correct behavior: $> runs first (inits counter=100, logs "Working:enter")
    # Then process runs (logs "Working:process:counter=100", increments to 101)
    s.process()

    # Check counter was initialized and incremented
    var counter = s.get_counter()
    var log = s.get_log()
    print("Counter after forward: " + str(counter))
    print("Log: " + str(log))

    # Verify $> ran first
    assert("Working:enter" in log, "Expected 'Working:enter' in log: " + str(log))

    # Verify process ran after $>
    assert("Working:process:counter=100" in log, "Expected 'Working:process:counter=100' in log: " + str(log))

    # Verify counter was incremented
    assert(counter == 101, "Expected counter=101, got " + str(counter))

    # Verify order: enter before process
    var enter_idx = log.index("Working:enter")
    var process_idx = log.index("Working:process:counter=100")
    assert(enter_idx < process_idx, "$> should run before process: " + str(log))

    print("PASS: Forward sends $> first for non-$> events")

func _init():
    main()
    quit()

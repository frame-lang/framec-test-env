@@[target("lua")]
@@system StackOps {
    interface:
        push_and_go()
        pop_back()
        do_work(): str
        get_state(): str

    machine:
        $Main {
            push_and_go() {
                -- print
                push$
                -> $Sub
            
            }

            pop_back() {
                -- print
            
            }

            do_work(): str {
                @@:("Working in Main")
                return
            }

            get_state(): str {
                @@:("Main")
                return
            }
        }

        $Sub {
            push_and_go() {
                -- print
            
            }

            pop_back() {
                -- print
                -> pop$
            
            }

            do_work(): str {
                @@:("Working in Sub")
                return
            }

            get_state(): str {
                @@:("Sub")
                return
            }
        }
}

@@[target("dart")]

import 'dart:io';

@@system HsmFourLevel {
    interface:
        drive(): int
        write_at_level(level: int)
        get_n(): int

    machine:
        $Leaf => $Mid {
            drive(): int {
                => $^
            }
            write_at_level(level: int) {
                this.n = this.n + level * 1;
                => $^
            }
            get_n(): int {
                @@:(this.n)
                return;
            }
        }

        $Mid => $Branch {
            drive(): int {
                => $^
            }
            write_at_level(level: int) {
                this.n = this.n + level * 10;
                => $^
            }
        }

        $Branch => $Root {
            drive(): int {
                => $^
            }
            write_at_level(level: int) {
                this.n = this.n + level * 100;
                => $^
            }
        }

        $Root {
            drive(): int {
                @@:(this.n)
                return;
            }
            write_at_level(level: int) {
                this.n = this.n + level * 1000;
            }
        }
    domain:
        n: int = 0
}

void main() {
    print("=== Test 61: 4-level HSM cascade (Dart) ===");
    final s = HsmFourLevel();

    final initial = s.drive();
    if (initial != 0) { print("FAIL: initial $initial"); exit(1); }
    print("1. Initial drive returned $initial");

    s.write_at_level(2);
    final after = s.get_n();
    if (after != 2222) { print("FAIL: after $after"); exit(1); }
    print("2. After cascading write: n=$after");

    final finalVal = s.drive();
    if (finalVal != 2222) { print("FAIL: final $finalVal"); exit(1); }
    print("3. Drive after write returned $finalVal");

    print("PASS: 61_hsm_four_level");
}

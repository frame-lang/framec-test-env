@@[target("php")]

<?php

@@[persist]
@@system Inner {
    interface:
        bump_int()
        bump_float()
        flip_bool()
        get_n_int(): int
        get_n_float(): float
        get_n_bool(): bool
        get_n_str(): string

    machine:
        $S {
            bump_int() { $this->n_int = $this->n_int + 1; }
            bump_float() { $this->n_float = $this->n_float + 0.25; }
            flip_bool() { $this->n_bool = !$this->n_bool; }
            get_n_int(): int { @@:($this->n_int) }
            get_n_float(): float { @@:($this->n_float) }
            get_n_bool(): bool { @@:($this->n_bool) }
            get_n_str(): string { @@:($this->n_str) }
        }
    domain:
        n_int: int = 7
        n_float: float = 2.5
        n_bool: bool = true
        n_str: string = "hello"
}

@@[main]
@@system Outer {
    interface:
        bump_k_int()
        bump_k_float()
        bump_inner_int()
        bump_inner_float()
        flip_inner_bool()
        get_k_int(): int
        get_k_float(): float
        get_n_int(): int
        get_n_float(): float
        get_n_bool(): bool
        get_n_str(): string

    machine:
        $S {
            bump_k_int() { $this->k_int = $this->k_int + 1; }
            bump_k_float() { $this->k_float = $this->k_float + 0.25; }
            bump_inner_int() { $this->inner->bump_int(); }
            bump_inner_float() { $this->inner->bump_float(); }
            flip_inner_bool() { $this->inner->flip_bool(); }
            get_k_int(): int { @@:($this->k_int) }
            get_k_float(): float { @@:($this->k_float) }
            get_n_int(): int { @@:($this->inner->get_n_int()) }
            get_n_float(): float { @@:($this->inner->get_n_float()) }
            get_n_bool(): bool { @@:($this->inner->get_n_bool()) }
            get_n_str(): string { @@:($this->inner->get_n_str()) }
        }
    domain:
        k_int: int = 42
        k_float: float = 1.25
        inner = @@Inner()
}

function assertState($o, $label, $kIntStr, $kFloat, $nIntStr, $nFloat, $nBool, $nStr) {
    if ((string)$o->get_k_int() !== $kIntStr) { echo "FAIL $label k_int: " . $o->get_k_int() . "\n"; exit(1); }
    if ((string)$o->get_n_int() !== $nIntStr) { echo "FAIL $label n_int: " . $o->get_n_int() . "\n"; exit(1); }
    if (abs($o->get_k_float() - $kFloat) > 1e-9) { echo "FAIL $label k_float: " . $o->get_k_float() . "\n"; exit(1); }
    if (abs($o->get_n_float() - $nFloat) > 1e-9) { echo "FAIL $label n_float: " . $o->get_n_float() . "\n"; exit(1); }
    if ($o->get_n_bool() !== $nBool) { echo "FAIL $label n_bool: " . var_export($o->get_n_bool(), true) . "\n"; exit(1); }
    if ($o->get_n_str() !== $nStr) { echo "FAIL $label n_str: " . $o->get_n_str() . "\n"; exit(1); }
}

$o = new Outer();
assertState($o, "T0", "42", 1.25, "7", 2.5, true, "hello");

$o->bump_k_int();
$o->bump_k_float();
$o->bump_inner_int();
$o->bump_inner_float();
$o->flip_inner_bool();
assertState($o, "T1", "43", 1.5, "8", 2.75, false, "hello");

$snap = $o->save_state();
$r = Outer::restore_state($snap);
assertState($r, "T1 restored", "43", 1.5, "8", 2.75, false, "hello");

$r->bump_k_int();
$r->bump_inner_int();
assertState($r, "continue", "44", 1.5, "9", 2.75, false, "hello");

echo "PASS: 86_persist_numeric_typing\n";

@@[target("c")]

@@[persist]

#include <stdio.h>
#include <stdlib.h>
#include <string.h>
#include <math.h>
#include <cjson/cJSON.h>

@@system PFloat {
    operations:
        @@[save]
        save_state(): char* {}

        @@[load]
        restore_state(data: char*) {}

    interface:
        configure(rate: double)
        get_rate(): double

    machine:
        $Idle {
            configure(rate: double) {
                -> $Active(rate)
            }
            get_rate(): double {
                @@:(0.0)
            }
        }

        $Active(rate: double) {
            get_rate(): double {
                @@:(rate)
            }
        }
    domain:
        n : int = 0
}

int main(void) {
    PFloat* s = PFloat_new();
    PFloat_configure(s, 3.14159);
    char* snap = PFloat_save_state(s);
    PFloat* s2 = @@PFloat();

    PFloat_restore_state(s2, snap);
    double r = PFloat_get_rate(s2);
    if (fabs(r - 3.14159) > 1e-9) { printf("FAIL %f\n", r); return 1; }
    printf("PASS: 69_persist_float_state_arg, rate=%f\n", r);
    free(snap);
    PFloat_destroy(s);
    PFloat_destroy(s2);
    return 0;
}

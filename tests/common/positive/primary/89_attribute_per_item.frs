@@[target("rust")]

@@system Demo {
    interface:
        common(): String
        @@[target("python_3")] only_py(): String
        @@[target("rust")] only_rs(): String

    machine:
        $S {
            common(): String { @@:("common".to_string()) }
            @@[target("python_3")] only_py(): String { @@:("only_py_present".to_string()) }
            @@[target("rust")] only_rs(): String { @@:("only_rs_present".to_string()) }
        }
}

fn main() {
    let mut d = @@Demo();
    if d.common() != "common" { println!("FAIL common: {}", d.common()); std::process::exit(1); }
    if d.only_rs() != "only_rs_present" { println!("FAIL only_rs: {}", d.only_rs()); std::process::exit(1); }
    println!("PASS: 89_attribute_per_item");
}

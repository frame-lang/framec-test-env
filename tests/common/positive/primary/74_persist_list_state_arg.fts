@@[target("typescript")]

@@[persist]
@@system PersistList {
    operations:
        @@[save]
        saveState(): string {}

        @@[load]
        restoreState(data: string) {}

    interface:
        configure(items: number[])
        first_item(): number
        size(): number

    machine:
        $Idle {
            configure(items: number[]) {
                -> $Active(items)
            }
            first_item(): number { @@:(-1) }
            size(): number { @@:(0) }
        }
        $Active(items: number[]) {
            configure(items: number[]) {
                -> $Active(items)
            }
            first_item(): number { @@:(items[0]) }
            size(): number { @@:(items.length) }
        }
    domain:
        n: number = 0
}

const s1 = new PersistList();
s1.configure([10, 20, 30]);
if (s1.first_item() !== 10) { console.log("FAIL pre"); process.exit(1); }
const snap = s1.saveState();

const s2 = @@PersistList();


s2.restoreState(snap);
if (s2.first_item() !== 10) { console.log("FAIL restored first_item"); process.exit(1); }
if (s2.size() !== 3) { console.log("FAIL restored size"); process.exit(1); }
console.log("PASS: 74_persist_list_state_arg");

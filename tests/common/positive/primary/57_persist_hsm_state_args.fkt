@@[target("kotlin")]

@@[persist(String)]
@@[save(save_state)]
@@[load(restore_state)]
@@system PersistHsmStateArgs {
    interface:
        drive(p: int)
        get_x(): int

    machine:
        $Start {
            drive(p: int) {
                -> $Child(p)
            }
            get_x(): int {
                @@:(-1)
            }
        }

        $Child => $Parent(x: int) {
            drive(p: int) {
                -> $Child(p)
            }
            get_x(): int {
                @@:(x)
            }
        }

        $Parent {
        }
    domain:
        v : int = 0
}

fun main() {
    println("=== Test 57: Persist HSM × State-Args Round-Trip (Kotlin) ===")
    val s1 = @@PersistHsmStateArgs()
    s1.drive(42)
    val pre = s1.get_x()
    if (pre != 42) { println("FAIL: pre $pre"); kotlin.system.exitProcess(1) }
    println("1. Pre-save x=$pre")

    val snap = s1.save_state() as String
    val s2 = @@PersistHsmStateArgs()

    s2.restore_state(snap)
    val post = s2.get_x()
    if (post != 42) { println("FAIL: post $post"); kotlin.system.exitProcess(1) }
    println("2. Post-restore x=$post")

    s2.drive(99)
    val post2 = s2.get_x()
    if (post2 != 99) { println("FAIL: post2 $post2"); kotlin.system.exitProcess(1) }
    println("3. Post-restore-drive x=$post2")

    println("PASS: 57_persist_hsm_state_args")
}

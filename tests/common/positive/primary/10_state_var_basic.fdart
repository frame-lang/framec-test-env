@@[target("dart")]
@@system StateVarBasic {
    interface:
        increment(): num
        get_count(): num
        reset()

    machine:
        $Counter {
            $.count: num = 0

            increment(): num {
                $.count = $.count + 1;
                @@:($.count)
                return;
            }

            get_count(): num {
                @@:($.count)
                return;
            }

            reset() {
                $.count = 0;
            }
        }
}

void main() {
    print("== Test 10: State Variable Basic ==");
    final s = @@StateVarBasic();

    // Initial value should be 0
    if (s.get_count() != 0) {
        throw Exception("Expected 0, got ${s.get_count()}");
    }
    print("Initial count: ${s.get_count()}");

    // Increment should return new value
    var result = s.increment();
    if (result != 1) {
        throw Exception("Expected 1 after first increment, got ${result}");
    }
    print("After first increment: ${result}");

    // Second increment
    result = s.increment();
    if (result != 2) {
        throw Exception("Expected 2 after second increment, got ${result}");
    }
    print("After second increment: ${result}");

    // Reset should set back to 0
    s.reset();
    if (s.get_count() != 0) {
        throw Exception("Expected 0 after reset, got ${s.get_count()}");
    }
    print("After reset: ${s.get_count()}");

    print("PASS: State variable basic operations work correctly");
}


@@[target("ruby")]

@@system Sub {
    interface:
        ping(): Integer
    machine:
        $Idle {
            ping(): Integer { @@:(42) }
        }
}

@@[main]
@@system Top {
    interface:
        run(): Integer
    machine:
        $Active {
            run(): Integer { @@:(@sub.ping) }
        }
    domain:
        sub: Sub = @@Sub()
}

t = Top.new
if t.run != 42
    puts "FAIL run(): #{t.run}"
else
    puts "PASS: 91_main_attr_cross_ref"
end

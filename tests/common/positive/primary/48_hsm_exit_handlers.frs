@@[target("rust")]

// Test 48: HSM Exit Cascade

@@system HSMExitHandlers {
    interface:
        go_to_other()
        go_to_parent()
        go_to_child()
        get_log(): Vec<String>
        get_state(): String
        get_child_var(): i32

    machine:
        $Child => $Parent {
            $.child_var: i32 = 42

            $>() {
                self.log.push("Child:enter".to_string());
            }

            <$() {
                let val = $.child_var;
                self.log.push(format!("Child:exit(var={})", val));
            }

            go_to_other() { -> $Other }
            go_to_parent() { -> $Parent }
            get_log(): Vec<String> { @@:(self.log.clone()) }
            get_state(): String { @@:("Child".to_string()) }
            get_child_var(): i32 { @@:($.child_var) }
        }

        $Parent {
            $>() {
                self.log.push("Parent:enter".to_string());
            }

            <$() {
                self.log.push("Parent:exit".to_string());
            }

            go_to_child() { -> $Child }
            go_to_other() { -> $Other }
            get_log(): Vec<String> { @@:(self.log.clone()) }
            get_state(): String { @@:("Parent".to_string()) }
            get_child_var(): i32 { @@:(-1) }
        }

        $Other {
            $>() {
                self.log.push("Other:enter".to_string());
            }
            go_to_child() { -> $Child }
            go_to_parent() { -> $Parent }
            get_log(): Vec<String> { @@:(self.log.clone()) }
            get_state(): String { @@:("Other".to_string()) }
            get_child_var(): i32 { @@:(-1) }
        }
    domain:
        log: Vec<String>
}

fn main() {
    println!("=== Test 48: HSM Exit Cascade ===");
    let mut s = @@HSMExitHandlers();

    let log = s.get_log();
    assert!(log.contains(&"Parent:enter".to_string()), "Expected Parent:enter on init cascade");
    assert!(log.contains(&"Child:enter".to_string()), "Expected Child:enter on init");
    assert!(s.get_state() == "Child", "Expected Child");
    println!("TC1: Initial entry cascades through Parent then Child - PASS");

    s.go_to_other();
    let log = s.get_log();
    assert!(log.contains(&"Child:exit(var=42)".to_string()), "Expected Child:exit(var=42)");
    assert!(log.contains(&"Parent:exit".to_string()), "Expected Parent:exit (cascade)");
    assert!(log.contains(&"Other:enter".to_string()), "Expected Other:enter");
    let cei = log.iter().position(|x| x == "Child:exit(var=42)").unwrap();
    let pei = log.iter().position(|x| x == "Parent:exit").unwrap();
    assert!(cei < pei, "Child:exit must precede Parent:exit (bottom-up)");
    println!("TC2: Child:exit fires before Parent:exit (bottom-up cascade) - PASS");

    println!("TC3: Exit handler accesses state var (var=42) - PASS");

    s.go_to_child();
    let log = s.get_log();
    assert!(log.iter().filter(|x| *x == "Parent:enter").count() == 2, "Expected 2 Parent:enter");
    assert!(log.iter().filter(|x| *x == "Child:enter").count() == 2, "Expected 2 Child:enter");
    println!("TC4: Re-entering Child cascades Parent.$> then Child.$> - PASS");

    println!("PASS: HSM exit cascade fires Child.<$ then Parent.<$");
}

@@target dart

@@system WithParams {
    interface:
        start(initial: int)
        add(value: int)
        multiply(a: int, b: int): int
        get_total(): int

    machine:
        $Idle {
            start(initial: int) {
                this.total = initial;
                print("Started with initial value: ${initial}");
                -> $Running
            }

            add(value: int) {
                print("Cannot add in Idle state");
            }

            multiply(a: int, b: int): int {
                @@:(0)
                return;
            }

            get_total(): int {
                @@:(this.total)
                return;
            }
        }

        $Running {
            start(initial: int) {
                print("Already running");
            }

            add(value: int) {
                this.total += value;
                print("Added ${value}, total is now ${this.total}");
            }

            multiply(a: int, b: int): int {
                final result = a * b;
                this.total += result;
                print("Multiplied ${a} * ${b} = ${result}, total is now ${this.total}");
                @@:(result)
                return;
            }

            get_total(): int {
                @@:(this.total)
                return;
            }
        }
    domain:
        total: int = 0
}

void main() {
    print("== Test 07: Handler Parameters ==");
    final s = @@WithParams();

    // Initial total should be 0
    var total = s.get_total();
    if (total != 0) {
        throw Exception("Expected initial total=0, got ${total}");
    }

    // Start with initial value
    s.start(100);
    total = s.get_total();
    if (total != 100) {
        throw Exception("Expected total=100, got ${total}");
    }
    print("After start(100): total = ${total}");

    // Add value
    s.add(25);
    total = s.get_total();
    if (total != 125) {
        throw Exception("Expected total=125, got ${total}");
    }
    print("After add(25): total = ${total}");

    // Multiply with two params
    final result = s.multiply(3, 5);
    if (result != 15) {
        throw Exception("Expected multiply result=15, got ${result}");
    }
    total = s.get_total();
    if (total != 140) {
        throw Exception("Expected total=140, got ${total}");
    }
    print("After multiply(3,5): result = ${result}, total = ${total}");

    print("PASS: Handler parameters work correctly");
}


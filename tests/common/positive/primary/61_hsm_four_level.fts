@@target typescript

@@system HsmFourLevel {
    interface:
        drive(): int
        write_at_level(level: int)
        get_n(): int

    machine:
        $Leaf => $Mid {
            drive(): number {
                => $^
            }
            write_at_level(level: number) {
                this.n = this.n + level * 1
                => $^
            }
            get_n(): number {
                @@:(this.n)
                return
            }
        }

        $Mid => $Branch {
            drive(): number {
                => $^
            }
            write_at_level(level: number) {
                this.n = this.n + level * 10
                => $^
            }
        }

        $Branch => $Root {
            drive(): number {
                => $^
            }
            write_at_level(level: number) {
                this.n = this.n + level * 100
                => $^
            }
        }

        $Root {
            drive(): number {
                @@:(this.n)
                return
            }
            write_at_level(level: number) {
                this.n = this.n + level * 1000
            }
        }
    domain:
        n: number = 0
}

console.log("=== Test 61: 4-level HSM cascade (TS) ===");
const s = new HsmFourLevel();

const initial = s.drive();
if (initial !== 0) { console.log("FAIL: initial " + initial); process.exit(1); }
console.log(`1. Initial drive returned ${initial}`);

s.write_at_level(2);
const after = s.get_n();
if (after !== 2222) { console.log("FAIL: after " + after); process.exit(1); }
console.log(`2. After cascading write: n=${after}`);

const final = s.drive();
if (final !== 2222) { console.log("FAIL: final " + final); process.exit(1); }
console.log(`3. Drive after write returned ${final}`);

console.log("PASS: 61_hsm_four_level");

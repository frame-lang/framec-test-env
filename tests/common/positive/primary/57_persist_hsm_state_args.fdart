@@[target("dart")]

import 'dart:io';
import 'dart:convert';

@@[persist]
@@system PersistHsmStateArgs {
    operations:
        @@[save]
        saveState(): String {}

        @@[load]
        restoreState(data: String) {}

    interface:
        drive(p: int)
        get_x(): int

    machine:
        $Start {
            drive(p: int) {
                -> $Child(p)
            }
            get_x(): int {
                @@:(-1)
                return;
            }
        }

        $Child => $Parent(x: int) {
            drive(p: int) {
                -> $Child(p)
            }
            get_x(): int {
                @@:(x)
                return;
            }
        }

        $Parent {
        }
    domain:
        v: int = 0
}

void main() {
    print("=== Test 57: Persist HSM × State-Args Round-Trip (Dart) ===");
    final s1 = PersistHsmStateArgs();
    s1.drive(42);
    final pre = s1.get_x();
    if (pre != 42) { print("FAIL: pre $pre"); exit(1); }
    print("1. Pre-save x=$pre");

    final snap = s1.saveState();
    final s2 = PersistHsmStateArgs();

    s2.restoreState(snap);
    final post = s2.get_x();
    if (post != 42) { print("FAIL: post $post"); exit(1); }
    print("2. Post-restore x=$post");

    s2.drive(99);
    final post2 = s2.get_x();
    if (post2 != 99) { print("FAIL: post2 $post2"); exit(1); }
    print("3. Post-restore-drive x=$post2");

    print("PASS: 57_persist_hsm_state_args");
}

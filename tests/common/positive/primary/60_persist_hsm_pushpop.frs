@@target rust

@@[persist]
@@system PersistHsmPushpop {
    interface:
        push_modal(v: i32)
        pop_modal()
        get_x(): i32

    machine:
        $Idle {
            push_modal(v: i32) {
                push$
                -> $Modal(v)
            }
            pop_modal() {
                -> pop$
            }
            get_x(): i32 {
                @@:(-99)
                return;
            }
        }

        $Modal => $Frame(x: i32) {
            push_modal(v: i32) {
                push$
                -> $Modal(v)
            }
            pop_modal() {
                -> pop$
            }
            get_x(): i32 {
                @@:(x)
                return;
            }
        }

        $Frame {
        }
    domain:
        v: i32
}

fn main() {
    println!("=== Test 60: Persist × HSM × push/pop (Rust) ===");
    let mut s1 = @@PersistHsmPushpop();
    s1.push_modal(42);
    s1.push_modal(99);
    let pre = s1.get_x();
    if pre != 99 { println!("FAIL: pre {}", pre); std::process::exit(1); }
    println!("1. Pre-save top x={}", pre);

    let json = s1.save_state();
    let mut s2 = PersistHsmPushpop::restore_state(&json);
    let post = s2.get_x();
    if post != 99 { println!("FAIL: post {}", post); std::process::exit(1); }
    println!("2. Post-restore top x={}", post);

    s2.pop_modal();
    let mid = s2.get_x();
    if mid != 42 { println!("FAIL: mid {}", mid); std::process::exit(1); }
    println!("3. After first pop x={}", mid);

    s2.pop_modal();
    let bottom = s2.get_x();
    if bottom != -99 { println!("FAIL: bottom {}", bottom); std::process::exit(1); }
    println!("4. After second pop x={}", bottom);

    println!("PASS: 60_persist_hsm_pushpop");
}

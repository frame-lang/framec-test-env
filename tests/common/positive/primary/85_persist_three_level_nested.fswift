@@[target("swift")]

import Foundation

@@[persist]
@@system Inner {
    operations:
        @@[save]
        saveState(): String {}

        @@[load]
        restoreState(data: String) {}

    interface:
        cycle()
        get_state(): String
        get_count(): Int

    machine:
        $A {
            cycle() { self.n = self.n + 1; -> $B }
            get_state(): String { @@:("A") }
            get_count(): Int { @@:(self.n) }
        }
        $B => $A {
            cycle() { -> $A }
            get_state(): String { @@:("B") }
            get_count(): Int { => $^ }
        }
    domain:
        n: Int = 0
}

@@system Mid {
    operations:
        @@[save]
        saveState(): String {}

        @@[load]
        restoreState(data: String) {}

    interface:
        cycle()
        cycle_inner()
        get_state(): String
        get_inner_state(): String
        get_inner_count(): Int
        get_m(): Int

    machine:
        $P {
            cycle() { self.m = self.m + 1; -> $Q }
            cycle_inner() { self.inner.cycle() }
            get_state(): String { @@:("P") }
            get_inner_state(): String { @@:(self.inner.get_state()) }
            get_inner_count(): Int { @@:(self.inner.get_count()) }
            get_m(): Int { @@:(self.m) }
        }
        $Q => $P {
            cycle() { -> $P }
            get_state(): String { @@:("Q") }
            cycle_inner() { => $^ }
            get_inner_state(): String { => $^ }
            get_inner_count(): Int { => $^ }
            get_m(): Int { => $^ }
        }
    domain:
        m: Int = 0
        inner: Inner = @@Inner()
}

@@[main]
@@system Outer {
    operations:
        @@[save]
        saveState(): String {}

        @@[load]
        restoreState(data: String) {}

    interface:
        tick()
        cycle_mid()
        cycle_inner()
        get_outer_state(): String
        get_mid_state(): String
        get_inner_state(): String
        get_inner_count(): Int
        get_m(): Int
        get_k(): Int

    machine:
        $Idle {
            tick() { self.k = self.k + 1; -> $Active }
            cycle_mid() { self.mid.cycle() }
            cycle_inner() { self.mid.cycle_inner() }
            get_outer_state(): String { @@:("Idle") }
            get_mid_state(): String { @@:(self.mid.get_state()) }
            get_inner_state(): String { @@:(self.mid.get_inner_state()) }
            get_inner_count(): Int { @@:(self.mid.get_inner_count()) }
            get_m(): Int { @@:(self.mid.get_m()) }
            get_k(): Int { @@:(self.k) }
        }
        $Active => $Idle {
            tick() { -> $Idle }
            get_outer_state(): String { @@:("Active") }
            cycle_mid() { => $^ }
            cycle_inner() { => $^ }
            get_mid_state(): String { => $^ }
            get_inner_state(): String { => $^ }
            get_inner_count(): Int { => $^ }
            get_m(): Int { => $^ }
            get_k(): Int { => $^ }
        }
    domain:
        k: Int = 0
        mid: Mid = @@Mid()
}

func fmt(_ o: Outer) -> String {
    return "\(o.get_outer_state())/\(o.get_mid_state())/\(o.get_inner_state())/\(o.get_inner_count())/\(o.get_m())/\(o.get_k())"
}

func must(_ label: String, _ o: Outer, _ expected: String) {
    let actual = fmt(o)
    if actual != expected { print("FAIL \(label): \(actual) expected \(expected)"); exit(1) }
}

let o = Outer()
must("T0 fresh", o, "Idle/P/A/0/0/0")
let snap0 = o.saveState()
let r0 = Outer()

r0.restoreState(snap0)
must("T0 restored", r0, "Idle/P/A/0/0/0")

o.tick()
must("T1", o, "Active/P/A/0/0/1")
let snap1 = o.saveState()
let r1 = Outer()

r1.restoreState(snap1)
must("T1 restored", r1, "Active/P/A/0/0/1")

o.cycle_mid()
o.cycle_inner()
must("T2", o, "Active/Q/B/1/1/1")
let snap2 = o.saveState()
let r2 = Outer()

r2.restoreState(snap2)
must("T2 restored", r2, "Active/Q/B/1/1/1")

let snap2b = r2.saveState()
let r2b = Outer()

r2b.restoreState(snap2b)
if fmt(r2b) != fmt(r2) { print("FAIL idempotence: \(fmt(r2b)) != \(fmt(r2))"); exit(1) }

r2.cycle_inner()
must("continue1", r2, "Active/Q/A/1/1/1")
r2.cycle_mid()
must("continue2", r2, "Active/P/A/1/1/1")
r2.tick()
must("continue3", r2, "Idle/P/A/1/1/1")
r2.tick()
must("continue4", r2, "Active/P/A/1/1/2")

print("PASS: 85_persist_three_level_nested")

@@target dart

@@system HSMForward {
    interface:
        event_a()
        event_b()
        get_log(): String[]

    machine:
        $Child => $Parent {
            event_a() {
                this.log.add("Child:event_a");
            }

            event_b() {
                this.log.add("Child:event_b_forward");
                => $^
            }

            get_log(): String[] {
                @@:(this.log)
                return;
            }
        }

        $Parent {
            event_a() {
                this.log.add("Parent:event_a");
            }

            event_b() {
                this.log.add("Parent:event_b");
            }

            get_log(): String[] {
                @@:(this.log)
                return;
            }
        }
    domain:
        log: String[] = []
}

void main() {
    print("== Test 08: HSM Forward ==");
    final s = @@HSMForward();

    // event_a should be handled by Child (no forward)
    s.event_a();
    var log = s.get_log();
    if (!log.includes("Child:event_a")) {
        throw Exception("Expected 'Child:event_a' in log, got ${jsonEncode(log)}");
    }
    print("After event_a: ${jsonEncode(log)}");

    // event_b should forward to Parent
    s.event_b();
    log = s.get_log();
    if (!log.includes("Child:event_b_forward")) {
        throw Exception("Expected 'Child:event_b_forward' in log, got ${jsonEncode(log)}");
    }
    if (!log.includes("Parent:event_b")) {
        throw Exception("Expected 'Parent:event_b' in log (forwarded), got ${jsonEncode(log)}");
    }
    print("After event_b (forwarded): ${jsonEncode(log)}");

    print("PASS: HSM forward works correctly");
}


@@target gdscript
extends SceneTree

# Test: const domain field initialized from system param.

@@system Sensor(threshold: int = 100) {
    interface:
        read(): int
        calibrate(offset: int)
        get_threshold(): int

    machine:
        $Active {
            read(): int {
                @@:(self.value + self.offset)
                return
            }
            calibrate(offset: int) {
                self.offset = offset
            }
            get_threshold(): int {
                @@:(self.threshold)
                return
            }
        }

    domain:
        const threshold = threshold
        value = 50
        offset = 0
}

func main():
    var failures = 0

    # Test 1: system param override
    var s = @@Sensor(200)
    var t = s.get_threshold()
    if t != 200:
        print("FAIL test 1: expected 200, got " + str(t))
        failures += 1

    # Test 2: read returns value + offset
    var v = s.read()
    if v != 50:
        print("FAIL test 2: expected 50, got " + str(v))
        failures += 1

    # Test 3: calibrate changes offset
    s.calibrate(10)
    v = s.read()
    if v != 60:
        print("FAIL test 3: expected 60, got " + str(v))
        failures += 1

    # Test 4: default system param
    var s2 = @@Sensor()
    var t2 = s2.get_threshold()
    if t2 != 100:
        print("FAIL test 4: expected 100, got " + str(t2))
        failures += 1

    if failures > 0:
        print("FAIL: const_domain (" + str(failures) + " failures)")
        return
    print("PASS: const_domain")

func _init():
    main()
    quit()

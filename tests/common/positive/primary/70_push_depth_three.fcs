@@target csharp

using System;

@@system PushDeep {
    interface:
        descend()
        ascend()
        get_depth(): int

    machine:
        $Idle {
            descend() {
                push$
                -> $Modal1
            }
            get_depth(): int {
                @@:(0)
            }
        }

        $Modal1 {
            descend() {
                push$
                -> $Modal2
            }
            ascend() {
                -> pop$
            }
            get_depth(): int {
                @@:(1)
            }
        }

        $Modal2 {
            descend() {
                push$
                -> $Modal3
            }
            ascend() {
                -> pop$
            }
            get_depth(): int {
                @@:(2)
            }
        }

        $Modal3 {
            ascend() {
                -> pop$
            }
            get_depth(): int {
                @@:(3)
            }
        }
    domain:
        n : int = 0
}

class Program {
    static void Main(string[] args) {
        var s = new PushDeep();
        if (s.get_depth() != 0) { Console.WriteLine("FAIL idle"); Environment.Exit(1); }
        s.descend();
        if (s.get_depth() != 1) { Console.WriteLine("FAIL d1"); Environment.Exit(1); }
        s.descend();
        if (s.get_depth() != 2) { Console.WriteLine("FAIL d2"); Environment.Exit(1); }
        s.descend();
        if (s.get_depth() != 3) { Console.WriteLine("FAIL d3"); Environment.Exit(1); }
        s.ascend();
        if (s.get_depth() != 2) { Console.WriteLine("FAIL a1"); Environment.Exit(1); }
        s.ascend();
        if (s.get_depth() != 1) { Console.WriteLine("FAIL a2"); Environment.Exit(1); }
        s.ascend();
        if (s.get_depth() != 0) { Console.WriteLine("FAIL a3"); Environment.Exit(1); }
        Console.WriteLine("PASS: 70_push_depth_three");
    }
}

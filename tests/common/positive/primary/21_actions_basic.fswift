@@target swift

@@system ActionsTest {
    interface:
        process(value: number): number
        get_log(): string

    machine:
        $Ready {
            process(value: number): number {
                self.__log_event("start")
                self.__validate_positive(value)
                self.__log_event("valid")
                let result = value * 2
                self.__log_event("done")
                return result
            }

            get_log(): string {
                return self.log
            }
        }
    actions:
        __log_event(msg: string) {
            self.log = self.log + msg + ";"
        }

        __validate_positive(n: number) {
            if (n < 0) {
                fatalError("Value must be positive: \(n)")
            }
        }
    domain:
        log: string = ""

}

// main
    print("=== Test 21: Actions Basic (Swift) ===")
    let s = @@ActionsTest()

    // Test 1: Actions are called correctly
    let result = s.process(5)
    if result != 10 {
        fatalError("Expected 10, got \(result)")
    }
    print("1. process(5) = \(result)")

    // Test 2: Log shows action calls
    let log = s.get_log()
    if !log.contains("start") {
        fatalError("Missing 'start' in log: \(log)")
    }
    if !log.contains("valid") {
        fatalError("Missing 'valid' in log: \(log)")
    }
    if !log.contains("done") {
        fatalError("Missing 'done' in log: \(log)")
    }
    print("2. Log: \(log)")

    // Test 3: Action with validation (negative value should crash)
    // Note: In Swift, fatalError is not catchable, so we skip the negative test
    print("3. Validation action verified (negative would fatalError)")

    print("PASS: Actions basic works correctly")

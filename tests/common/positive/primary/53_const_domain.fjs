@@[target("javascript")]

@@system Sensor(threshold: int = 100) {
    interface:
        read(): number
        calibrate(offset: int)
        get_threshold(): number

    machine:
        $Active {
            read(): number {
                @@:(this.value + this.offset)
                return
            }
            calibrate(offset: int) {
                this.offset = offset;
            }
            get_threshold(): number {
                @@:(this.threshold)
                return
            }
        }

    domain:
        const threshold = threshold
        value = 50
        offset = 0
}

let failures = 0;
const s = @@Sensor(200);

if (s.get_threshold() !== 200) { console.log("FAIL: threshold"); failures++; }
if (s.read() !== 50) { console.log("FAIL: read"); failures++; }
s.calibrate(10);
if (s.read() !== 60) { console.log("FAIL: calibrated read"); failures++; }

const s2 = @@Sensor();
if (s2.get_threshold() !== 100) { console.log("FAIL: default threshold"); failures++; }

if (failures > 0) { console.log(`FAIL: const_domain (${failures})`); process.exit(1); }
console.log("PASS: const_domain");

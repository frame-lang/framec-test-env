@@target swift

import Foundation

@@system StrStateArg {
    interface:
        configure(label: str)
        identify(): str

    machine:
        $Idle {
            configure(label: str) {
                -> $Active(label)
            }
            identify(): str {
                @@:("anonymous")
            }
        }

        $Active => $Frame(label: str) {
            configure(label: str) {
                -> $Active(label)
            }
            identify(): str {
                => $^
            }
        }

        $Frame {
            identify(): str {
                @@:(label)
            }
        }
    domain:
        n : int = 0
}

let s = StrStateArg()
if s.identify() != "anonymous" { print("FAIL idle"); exit(1) }
s.configure("alice")
if s.identify() != "alice" { print("FAIL alice"); exit(1) }
s.configure("bob")
if s.identify() != "bob" { print("FAIL bob"); exit(1) }
print("PASS: 66_hsm_str_state_args")

@@[target("csharp")]

using System;
using System.Collections.Generic;

// Test 48: HSM Exit Cascade

@@system HSMExitHandlers {
    interface:
        go_to_other()
        go_to_parent()
        go_to_child()
        get_log(): List<object>
        get_state(): string
        get_child_var(): int

    machine:
        $Child => $Parent {
            $.child_var: int = 42

            $>() {
                => $^
                this.log.Add("Child:enter");
            }

            <$() {
                int val = $.child_var;
                this.log.Add("Child:exit(var=" + val + ")");
                => $^
            }

            go_to_other() { -> $Other }
            go_to_parent() { -> $Parent }
            get_log(): List<object> { @@:(this.log) }
            get_state(): string { @@:("Child") }
            get_child_var(): int { @@:($.child_var) }
        }

        $Parent {
            $>() {
                this.log.Add("Parent:enter");
            }

            <$() {
                this.log.Add("Parent:exit");
            }

            go_to_child() { -> $Child }
            go_to_other() { -> $Other }
            get_log(): List<object> { @@:(this.log) }
            get_state(): string { @@:("Parent") }
            get_child_var(): int { @@:(-1) }
        }

        $Other {
            $>() {
                this.log.Add("Other:enter");
            }
            go_to_child() { -> $Child }
            go_to_parent() { -> $Parent }
            get_log(): List<object> { @@:(this.log) }
            get_state(): string { @@:("Other") }
            get_child_var(): int { @@:(-1) }
        }
    domain:
        log : List<object> = new List<object>()
}

class Program {
    static int CountOf(List<object> log, string v) {
        int n = 0;
        foreach (var item in log) if (item.Equals(v)) n++;
        return n;
    }
    static int IndexOf(List<object> log, string v) {
        for (int i = 0; i < log.Count; i++) if (log[i].Equals(v)) return i;
        return -1;
    }

    static void Main(string[] args) {
        Console.WriteLine("=== Test 48: HSM Exit Cascade ===");
        var s = @@HSMExitHandlers();

        var log = (List<object>)s.get_log();
        if (!log.Contains("Parent:enter")) { Console.WriteLine("FAIL: Expected Parent:enter on init cascade"); Environment.Exit(1); }
        if (!log.Contains("Child:enter")) { Console.WriteLine("FAIL: Expected Child:enter on init"); Environment.Exit(1); }
        if ((string)s.get_state() != "Child") { Console.WriteLine("FAIL"); Environment.Exit(1); }
        Console.WriteLine("TC1: Initial entry cascades through Parent then Child - PASS");

        s.go_to_other();
        log = (List<object>)s.get_log();
        if (!log.Contains("Child:exit(var=42)")) { Console.WriteLine("FAIL: Expected Child:exit(var=42)"); Environment.Exit(1); }
        if (!log.Contains("Parent:exit")) { Console.WriteLine("FAIL: Expected Parent:exit (cascade)"); Environment.Exit(1); }
        if (!log.Contains("Other:enter")) { Console.WriteLine("FAIL: Expected Other:enter"); Environment.Exit(1); }
        int cei = IndexOf(log, "Child:exit(var=42)");
        int pei = IndexOf(log, "Parent:exit");
        if (cei >= pei) { Console.WriteLine("FAIL: Child:exit must precede Parent:exit"); Environment.Exit(1); }
        Console.WriteLine("TC2: Child:exit fires before Parent:exit (bottom-up cascade) - PASS");

        Console.WriteLine("TC3: Exit handler accesses state var (var=42) - PASS");

        s.go_to_child();
        log = (List<object>)s.get_log();
        if (CountOf(log, "Parent:enter") != 2) { Console.WriteLine("FAIL: Expected 2 Parent:enter"); Environment.Exit(1); }
        if (CountOf(log, "Child:enter") != 2) { Console.WriteLine("FAIL: Expected 2 Child:enter"); Environment.Exit(1); }
        Console.WriteLine("TC4: Re-entering Child cascades Parent.$> then Child.$> - PASS");

        Console.WriteLine("PASS: HSM exit cascade fires Child.<$ then Parent.<$");
    }
}

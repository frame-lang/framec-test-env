@@[target("gdscript")]
extends SceneTree

@@[persist(String)]
@@[save(save_state)]
@@[load(restore_state)]
@@system PersistStateArgs {
    interface:
        kick(v: int)
        get_slot(): int

    machine:
        $Idle {
            kick(v: int) {
                -> $Active(v)
            }
            get_slot(): int {
                @@:(-1)
            }
        }

        $Active(slot: int) {
            kick(v: int) {
                -> $Active(v)
            }
            get_slot(): int {
                @@:(slot)
            }
        }
    domain:
        v: int = 0
}

func _initialize():
    print("=== Test 56: Persist State-Args Round-Trip (GDScript) ===")
    var s1 = @@PersistStateArgs()
    s1.kick(42)
    var pre = s1.get_slot()
    if pre != 42:
        print("FAIL: pre " + str(pre))
        quit(1)
        return
    print("1. Pre-save slot=" + str(pre))

    var snap = s1.save_state()
    var s2 = @@PersistStateArgs()

    s2.restore_state(snap)
    var post = s2.get_slot()
    if post != 42:
        print("FAIL: post " + str(post))
        quit(1)
        return
    print("2. Post-restore slot=" + str(post))

    s2.kick(99)
    var post2 = s2.get_slot()
    if post2 != 99:
        print("FAIL: post2 " + str(post2))
        quit(1)
        return
    print("3. Post-restore-kick slot=" + str(post2))

    print("PASS: 56_persist_state_args")
    quit(0)

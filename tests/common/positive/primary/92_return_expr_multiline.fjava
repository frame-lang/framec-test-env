@@[target("java")]

@@system Test {
    interface:
        ready(): boolean

    machine:
        $Active {
            ready(): boolean {
                @@:(this.timer >= this.threshold
                    && this.count < this.limit)
            }
        }
    domain:
        timer: int = 100
        threshold: int = 50
        count: int = 1
        limit: int = 5
}

class Main {
    public static void main(String[] args) {
        Test t = new Test();
        if (t.ready() != true) {
            System.out.println("FAIL ready(): " + t.ready());
        } else {
            System.out.println("PASS: 92_return_expr_multiline");
        }
    }
}

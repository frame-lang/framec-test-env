@@[target("dart")]
@@system SystemReturnTest {
    interface:
        add(a: num, b: num): num
        multiply(a: num, b: num): num
        greet(name: String): String
        get_value(): num

    machine:
        $Calculator {
            $.value: num = 0

            add(a: num, b: num): num {
                @@:(a + b)
                return;
            }

            multiply(a: num, b: num): num {
                @@:(a * b)
            }

            greet(name: String): String {
                @@:("Hello, " + name + "!")
                return;
            }

            get_value(): num {
                $.value = 42;
                @@:($.value)
                return;
            }
        }
}

void main() {
    print("== Test 13: System Return ==");
    final calc = @@SystemReturnTest();

    // Test return sugar
    var result = calc.add(3, 5);
    if (result != 8) {
        throw Exception("Expected 8, got ${result}");
    }
    print("add(3, 5) = ${result}");

    result = calc.multiply(4, 7);
    if (result != 28) {
        throw Exception("Expected 28, got ${result}");
    }
    print("multiply(4, 7) = ${result}");

    // Test string return
    final greeting = calc.greet("World");
    if (greeting != "Hello, World!") {
        throw Exception("Expected 'Hello, World!', got '${greeting}'");
    }
    print("greet('World') = ${greeting}");

    // Test return with state variable
    final value = calc.get_value();
    if (value != 42) {
        throw Exception("Expected 42, got ${value}");
    }
    print("get_value() = ${value}");

    print("PASS: System return works correctly");
}


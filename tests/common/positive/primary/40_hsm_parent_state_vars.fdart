@@target dart
// Test 40: HSM Parent State Variables
//
// This test validates that parent and child states in an HSM hierarchy
// maintain SEPARATE compartments with independent state variables.
//
// EXPECTED ARCHITECTURE:
// - Child has its own compartment: {state: "Child", stateVars: {child_count: 0}}
// - Parent has its own compartment: {state: "Parent", stateVars: {parent_count: 100}}
// - Child's compartment.parentCompartment -> Parent's compartment
// - When child forwards to parent, parent accesses ITS OWN compartment

@@system HSMParentStateVars {
    interface:
        get_child_count(): num
        get_parent_count(): num

    machine:
        $Child => $Parent {
            $.child_count: num = 0

            get_child_count(): num {
                @@:($.child_count)
                return;
            }

            get_parent_count(): num {
                => $^
            }
        }

        $Parent {
            $.parent_count: num = 100

            get_parent_count(): num {
                @@:($.parent_count)
                return;
            }
        }
}

void main() {
    print("== Test 40: HSM Parent State Variables ==");
    final s = @@HSMParentStateVars();

    final childCount = s.get_child_count();
    if (childCount != 0) {
        throw Exception("Expected child_count=0, got ${childCount}");
    }
    print("Child count: ${childCount}");

    final parentCount = s.get_parent_count();
    if (parentCount != 100) {
        throw Exception("Expected parent_count=100, got ${parentCount}");
    }
    print("Parent count: ${parentCount}");

    print("PASS: HSM parent state variables work correctly");
}


@@[target("rust")]

@@system Test {
    interface:
        ready(): bool

    machine:
        $Active {
            ready(): bool {
                @@:(self.timer >= self.threshold
                    && self.count < self.limit)
            }
        }
    domain:
        timer: i32 = 100
        threshold: i32 = 50
        count: i32 = 1
        limit: i32 = 5
}

fn main() {
    let mut t = @@Test();
    if t.ready() != true {
        println!("FAIL ready(): {}", t.ready());
    } else {
        println!("PASS: 92_return_expr_multiline");
    }
}

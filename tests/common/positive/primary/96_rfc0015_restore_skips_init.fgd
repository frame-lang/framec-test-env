@@[target("gdscript")]

extends SceneTree

@@[persist(JSON)]
@@[save(snapshot)]
@@[load(rehydrate)]
@@system Counter {
    interface:
        get_fire_count(): int

    machine:
        $A {
            $>() {
                self.fire_count = self.fire_count + 1
            }
            get_fire_count(): int { @@:(self.fire_count) }
        }

    domain:
        fire_count: int = 0
}

func _init():
    var c = Counter.new()
    if c.get_fire_count() != 1:
        print("FAIL: expected 1 after construction, got " + str(c.get_fire_count()))
        quit()
    var snap = c.snapshot()

    var fresh = Counter.new()
    if fresh.get_fire_count() != 1:
        print("FAIL: expected 1 on fresh construction, got " + str(fresh.get_fire_count()))
        quit()

    fresh.rehydrate(snap)
    if fresh.get_fire_count() != 1:
        print("D4 violation: $> re-ran on restore (count=" + str(fresh.get_fire_count()) + ", expected 1)")
        quit()

    print("PASS: rfc0015_restore_skips_init")
    quit()

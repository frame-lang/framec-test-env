@@[target("javascript")]

@@system ListStateArg {
    interface:
        configure(items)
        first_item()
        size()

    machine:
        $Idle {
            configure(items) {
                -> $Active(items)
            }
            first_item() {
                @@:(-1)
            }
            size() {
                @@:(0)
            }
        }
        $Active(items) {
            configure(items) {
                -> $Active(items)
            }
            first_item() {
                @@:(items[0])
            }
            size() {
                @@:(items.length)
            }
        }
    domain:
        n = 0
}

const s = new ListStateArg();
if (s.first_item() !== -1) { console.log("FAIL idle first_item"); process.exit(1); }
if (s.size() !== 0) { console.log("FAIL idle size"); process.exit(1); }
s.configure([10, 20, 30]);
if (s.first_item() !== 10) { console.log("FAIL active first_item"); process.exit(1); }
if (s.size() !== 3) { console.log("FAIL active size"); process.exit(1); }
s.configure([7]);
if (s.first_item() !== 7) { console.log("FAIL retransition first_item"); process.exit(1); }
if (s.size() !== 1) { console.log("FAIL retransition size"); process.exit(1); }
console.log("PASS: 73_list_state_arg");

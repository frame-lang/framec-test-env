@@[target("kotlin")]

@@system Demo {
    interface:
        common(): String
        @@[target("python_3")] only_py(): String
        @@[target("kotlin")] only_kt(): String

    machine:
        $S {
            common(): String { @@:("common") }
            @@[target("python_3")] only_py(): String { @@:("only_py_present") }
            @@[target("kotlin")] only_kt(): String { @@:("only_kt_present") }
        }
}

fun main() {
    val d = @@Demo()
    check(d.common() == "common") { "FAIL common: ${d.common()}" }
    check(d.only_kt() == "only_kt_present") { "FAIL only_kt: ${d.only_kt()}" }
    println("PASS: 89_attribute_per_item")
}

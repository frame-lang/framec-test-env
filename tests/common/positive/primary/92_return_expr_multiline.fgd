@@[target("gdscript")]

extends SceneTree

@@system Test {
    interface:
        ready(): bool

    machine:
        $Active {
            ready(): bool {
                @@:(self.timer >= self.threshold
                    and self.count < self.limit)
            }
        }
    domain:
        timer: int = 100
        threshold: int = 50
        count: int = 1
        limit: int = 5
}

func _init():
    var t = @@Test()
    var v = t.ready()
    if v != true:
        print("FAIL ready(): " + str(v))
    else:
        print("PASS: 92_return_expr_multiline")
    quit()

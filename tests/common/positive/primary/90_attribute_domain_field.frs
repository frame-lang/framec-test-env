@@[target("rust")]

@@system Demo {
    interface:
        get_a(): i32
        get_rs_only(): i32
    machine:
        $S {
            get_a(): i32 { @@:(self.a) }
            get_rs_only(): i32 { @@:(self.rs_only) }
        }
    domain:
        a: i32 = 1
        @@[target("python_3")] py_only: i32 = 2
        @@[target("rust")]
        rs_only: i32 = 42
}

fn main() {
    let mut d = @@Demo();
    if d.get_a() != 1 { println!("FAIL get_a: {}", d.get_a()); std::process::exit(1); }
    if d.get_rs_only() != 42 { println!("FAIL get_rs_only: {}", d.get_rs_only()); std::process::exit(1); }
    println!("PASS: 90_attribute_domain_field");
}

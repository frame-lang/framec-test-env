@@[target("erlang")]
@@system Demo {
    interface:
        common(): string
        @@[target("python_3")] only_py(): string
        @@[target("erlang")] only_erl(): string

    machine:
        $S {
            common(): string { @@:("common") }
            @@[target("python_3")] only_py(): string { @@:("only_py_present") }
            @@[target("erlang")] only_erl(): string { @@:("only_erl_present") }
        }
}

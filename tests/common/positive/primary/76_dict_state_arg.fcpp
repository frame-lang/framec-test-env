@@[target("cpp")]

#include <iostream>
#include <map>
#include <string>
#include <cstdlib>

@@system DictStateArg {
    interface:
        configure(m: std::map<std::string, int>)
        get_v(key: std::string): int
        size(): int

    machine:
        $Idle {
            configure(m: std::map<std::string, int>) { -> $Active(m) }
            get_v(key: std::string): int { @@:(-1) }
            size(): int { @@:(0) }
        }
        $Active(m: std::map<std::string, int>) {
            configure(m: std::map<std::string, int>) { -> $Active(m) }
            get_v(key: std::string): int { @@:(m.count(key) ? m.at(key) : -1) }
            size(): int { @@:((int)m.size()) }
        }
    domain:
        n : int = 0
}

int main() {
    DictStateArg s;
    if (s.get_v("a") != -1) { std::cout << "FAIL idle" << std::endl; return 1; }
    if (s.size() != 0) { std::cout << "FAIL idle size" << std::endl; return 1; }
    s.configure(std::map<std::string, int>{{"a", 10}, {"b", 20}});
    if (s.get_v("a") != 10) { std::cout << "FAIL a" << std::endl; return 1; }
    if (s.get_v("b") != 20) { std::cout << "FAIL b" << std::endl; return 1; }
    if (s.size() != 2) { std::cout << "FAIL size" << std::endl; return 1; }
    s.configure(std::map<std::string, int>{{"x", 99}});
    if (s.get_v("x") != 99) { std::cout << "FAIL x" << std::endl; return 1; }
    if (s.size() != 1) { std::cout << "FAIL size2" << std::endl; return 1; }
    std::cout << "PASS: 76_dict_state_arg" << std::endl;
    return 0;
}

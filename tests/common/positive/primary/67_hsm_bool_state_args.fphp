@@[target("php")]

@@system BoolStateArg {
    interface:
        configure(active: bool)
        is_active(): bool

    machine:
        $Idle {
            configure(active: bool) {
                -> $Active($active)
            }
            is_active(): bool {
                @@:(false)
                return;
            }
        }

        $Active => $Frame(flag: bool) {
            configure(active: bool) {
                -> $Active($active)
            }
            is_active(): bool {
                => $^
            }
        }

        $Frame {
            is_active(): bool {
                @@:($flag)
                return;
            }
        }
    domain:
        n: int = 0
}

$s = @@BoolStateArg();
if ($s->is_active() !== false) { echo "FAIL idle\n"; exit(1); }
$s->configure(true);
if ($s->is_active() !== true) { echo "FAIL true\n"; exit(1); }
$s->configure(false);
if ($s->is_active() !== false) { echo "FAIL false\n"; exit(1); }
$s->configure(true);
if ($s->is_active() !== true) { echo "FAIL re-true\n"; exit(1); }
echo "PASS: 67_hsm_bool_state_args\n";

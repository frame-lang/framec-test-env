@@[target("javascript")]

@@[persist]
@@system PersistHsmPushpop {
    interface:
        push_modal(v: int)
        pop_modal()
        get_x(): int

    machine:
        $Idle {
            push_modal(v: number) {
                push$
                -> $Modal(v)
            }
            pop_modal() {
                -> pop$
            }
            get_x(): number {
                @@:(-99)
                return
            }
        }

        $Modal => $Frame(x: number) {
            push_modal(v: number) {
                push$
                -> $Modal(v)
            }
            pop_modal() {
                -> pop$
            }
            get_x(): number {
                @@:(x)
                return
            }
        }

        $Frame {
        }
    domain:
        v: number = 0
}

console.log("=== Test 60: Persist × HSM × push/pop (JS) ===");
const s1 = new PersistHsmPushpop();
s1.push_modal(42);
s1.push_modal(99);
const pre = s1.get_x();
if (pre !== 99) { console.log("FAIL: pre " + pre); process.exit(1); }
console.log(`1. Pre-save top x=${pre}`);

const snap = s1.saveState();
const s2 = PersistHsmPushpop.restoreState(snap);
const post = s2.get_x();
if (post !== 99) { console.log("FAIL: post " + post); process.exit(1); }
console.log(`2. Post-restore top x=${post}`);

s2.pop_modal();
const mid = s2.get_x();
if (mid !== 42) { console.log("FAIL: mid " + mid); process.exit(1); }
console.log(`3. After first pop x=${mid}`);

s2.pop_modal();
const bottom = s2.get_x();
if (bottom !== -99) { console.log("FAIL: bottom " + bottom); process.exit(1); }
console.log(`4. After second pop x=${bottom}`);

console.log("PASS: 60_persist_hsm_pushpop");

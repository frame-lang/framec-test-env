@@[target("java")]

import java.util.List;
import java.util.Arrays;

@@[persist(String)]
@@[save(save_state)]
@@[load(restore_state)]
@@system PersistList {
    interface:
        configure(items: java.util.List<Integer>)
        first_item(): int
        size(): int

    machine:
        $Idle {
            configure(items: java.util.List<Integer>) {
                -> $Active(items)
            }
            first_item(): int { @@:(-1) }
            size(): int { @@:(0) }
        }
        $Active(items: java.util.List<Integer>) {
            configure(items: java.util.List<Integer>) {
                -> $Active(items)
            }
            first_item(): int { @@:(items.get(0)) }
            size(): int { @@:(items.size()) }
        }
    domain:
        n: int = 0
}

class Main {
    public static void main(String[] args) throws Exception {
        PersistList s1 = new PersistList();
        s1.configure(Arrays.asList(10, 20, 30));
        if (s1.first_item() != 10) { System.out.println("FAIL pre"); System.exit(1); }
        String snap = s1.save_state();

        PersistList s2 = new PersistList();


        s2.restore_state(snap);
        if (s2.first_item() != 10) { System.out.println("FAIL restored first_item"); System.exit(1); }
        if (s2.size() != 3) { System.out.println("FAIL restored size"); System.exit(1); }
        System.out.println("PASS: 74_persist_list_state_arg");
    }
}

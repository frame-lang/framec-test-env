@@target erlang
@@system HSMExitHandlers {
    interface:
        goB()
        goA()
        getLog(): str
    machine:
        $A => $Parent {
            $>() { self.log = self.log ++ ",a_enter" }
            <$() { self.log = self.log ++ ",a_exit" }
            goB() { -> $B }
            getLog(): str {
                @@:(self.log)
            }
        }
        $B => $Parent {
            $>() { self.log = self.log ++ ",b_enter" }
            goA() { -> $A }
            getLog(): str {
                @@:(self.log)
            }
        }
        $Parent {
            getLog(): str {
                @@:(self.log)
            }
        }
    domain:
        log = "init"
}

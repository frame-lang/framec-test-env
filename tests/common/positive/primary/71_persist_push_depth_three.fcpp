@@target cpp_17

#include <iostream>
#include <nlohmann/json.hpp>

@@[persist]
@@system PPushDeep {
    interface:
        descend()
        ascend()
        get_depth(): int

    machine:
        $Idle {
            descend() { push$; -> $Modal1 }
            get_depth(): int { @@:(0) }
        }
        $Modal1 {
            descend() { push$; -> $Modal2 }
            ascend() { -> pop$ }
            get_depth(): int { @@:(1) }
        }
        $Modal2 {
            descend() { push$; -> $Modal3 }
            ascend() { -> pop$ }
            get_depth(): int { @@:(2) }
        }
        $Modal3 {
            ascend() { -> pop$ }
            get_depth(): int { @@:(3) }
        }
    domain: n : int = 0
}

int main() {
    PPushDeep s;
    s.descend(); s.descend(); s.descend();
    if (s.get_depth() != 3) { std::cout << "FAIL pre" << std::endl; return 1; }
    auto snap = s.save_state();
    auto s2 = PPushDeep::restore_state(snap);
    if (s2.get_depth() != 3) { std::cout << "FAIL post" << std::endl; return 1; }
    s2.ascend();
    if (s2.get_depth() != 2) { std::cout << "FAIL a1" << std::endl; return 1; }
    s2.ascend();
    if (s2.get_depth() != 1) { std::cout << "FAIL a2" << std::endl; return 1; }
    s2.ascend();
    if (s2.get_depth() != 0) { std::cout << "FAIL a3" << std::endl; return 1; }
    std::cout << "PASS: 71_persist_push_depth_three" << std::endl;
    return 0;
}

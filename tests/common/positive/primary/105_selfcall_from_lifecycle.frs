@@[target("rust")]

// Test 105: @@:self.method() from lifecycle handlers (F1 regression)

@@system LifecycleSelfCall {
    interface:
        tick()
        go()
        get_count(): i32

    machine:
        $A {
            $>() { @@:self.tick() }
            <$() { @@:self.tick() }
            go() { -> $B }
            tick() { self.count = self.count + 1; }
            get_count(): i32 { @@:(self.count) }
        }

        $B {
            $>() { @@:self.tick() }
            tick() { self.count = self.count + 1; }
            get_count(): i32 { @@:(self.count) }
        }

    domain:
        count: i32
}

fn main() {
    println!("=== Test 105: @@:self.method() from lifecycle handlers (F1 regression) ===");
    let mut s = @@LifecycleSelfCall();
    assert!(s.get_count() == 1, "Expected 1 after start-state $>");
    println!("TC1: @@:self from start state $> - PASS");
    s.go();
    assert!(s.get_count() == 3, "Expected 3 after go()");
    println!("TC2/TC3: @@:self from <$ + post-transition $> - PASS");
    println!("PASS: F1 regression");
}

@@[target("swift")]


@@system HsmIfStateArgs {
    interface:
        enter_active(t: int)
        classify(v: int): int

    machine:
        $Idle {
            enter_active(t: int) {
                -> $Active(t)
            }
            classify(v: int): int {
                @@:(-1)
            }
        }

        $Active => $Frame(threshold: int) {
            enter_active(t: int) {
                -> $Active(t)
            }
            classify(v: int): int {
                if v > threshold {
                    @@:(1)
                } else {
                    @@:(0)
                }
            }
        }

        $Frame {
        }
    domain:
        n : int = 0
}

print("=== Test 62: HSM × if × state-args (Swift) ===")
let s = @@HsmIfStateArgs()

let pre = s.classify(5)
if pre != -1 { print("FAIL: pre \(pre)"); exit(1) }
print("1. Idle classify(5) = \(pre)")

s.enter_active(10)
let under = s.classify(5)
if under != 0 { print("FAIL: under \(under)"); exit(1) }
print("2. classify(5) with threshold=10 → \(under)")

let over = s.classify(15)
if over != 1 { print("FAIL: over \(over)"); exit(1) }
print("3. classify(15) with threshold=10 → \(over)")

let eq = s.classify(10)
if eq != 0 { print("FAIL: eq \(eq)"); exit(1) }
print("4. classify(10) with threshold=10 → \(eq)")

s.enter_active(50)
let newUnder = s.classify(15)
if newUnder != 0 { print("FAIL: newUnder \(newUnder)"); exit(1) }
print("5. classify(15) with threshold=50 → \(newUnder)")

print("PASS: 62_hsm_if_state_args")

@@target kotlin

import kotlin.system.exitProcess

@@system StateParams {
    interface:
        start(val_: Int)
        get_value(): Int

    machine:
        $Idle {
            start(val_: Int) {
                -> $Counter(val_)
            }

            get_value(): Int {
                return 0
            }
        }

        $Counter(initial: Int) {
            $>() {
                // Access state param via compartment - using string key "0"
                $.count = this.__compartment.state_args.get("0")
                val count_val = $.count
                println("Counter entered with initial=" + count_val)
            }

            $.count: Int = 0

            get_value(): Int {
                return $.count
            }
        }
}

fun main() {
    println("=== Test 26: State Parameters ===")
    val s = @@StateParams()

    var v = s.get_value() as Int
    if (v != 0) {
        println("FAIL: Expected 0 in Idle, got $v")
        exitProcess(1)
    }
    println("Initial value: $v")

    s.start(42)
    v = s.get_value() as Int
    if (v != 42) {
        println("FAIL: Expected 42 in Counter from state param, got $v")
        exitProcess(1)
    }
    println("Value after transition: $v")

    println("PASS: State parameters work correctly")
}

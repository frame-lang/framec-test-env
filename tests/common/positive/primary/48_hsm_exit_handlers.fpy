@@target python_3

# Test 48: HSM Exit Handlers
#
# Tests exit handlers in HSM context:
# - Child exit fires when transitioning out of child
# - Parent exit does NOT fire when transitioning out of child
# - Exit handler can access child's state variables

@@system HSMExitHandlers {
    interface:
        go_to_other()
        go_to_parent()
        go_to_child()
        get_log(): list
        get_state(): str
        get_child_var(): int

    machine:
        $Child => $Parent {
            $.child_var: int = 42

            $>() {
                self.log.append("Child:enter")
            }

            <$() {
                val = $.child_var
                self.log.append(f"Child:exit(var={val})")
            }

            go_to_other() {
                -> $Other
            }

            go_to_parent() {
                -> $Parent
            }

            get_log(): list {
                @@:(self.log)
                return
            }

            get_state(): str {
                @@:("Child")
                return
            }

            get_child_var(): int {
                @@:($.child_var)
                return
            }
        }

        $Parent {
            $>() {
                self.log.append("Parent:enter")
            }

            <$() {
                self.log.append("Parent:exit")
            }

            go_to_child() {
                -> $Child
            }

            go_to_other() {
                -> $Other
            }

            get_log(): list {
                @@:(self.log)
                return
            }

            get_state(): str {
                @@:("Parent")
                return
            }

            get_child_var(): int {
                @@:(-1)
                return
            }
        }

        $Other {
            $>() {
                self.log.append("Other:enter")
            }

            go_to_child() {
                -> $Child
            }

            go_to_parent() {
                -> $Parent
            }

            get_log(): list {
                @@:(self.log)
                return
            }

            get_state(): str {
                @@:("Other")
                return
            }

            get_child_var(): int {
                @@:(-1)
                return
            }
        }
    domain:
        log: list = []
}

def main():
    print("=== Test 48: HSM Exit Cascade ===")
    s = @@HSMExitHandlers()

    # Initial state is Child. Cascade fires Parent.$> then Child.$>.
    log = s.get_log()
    assert "Parent:enter" in log, f"Expected Parent:enter on init cascade, got {log}"
    assert "Child:enter" in log, f"Expected Child:enter on init, got {log}"
    assert s.get_state() == "Child", f"Expected Child, got {s.get_state()}"
    print("TC1: Initial entry cascades through Parent then Child - PASS")

    # TC2: Exiting Child to Other fires Child.<$ then Parent.<$ (bottom-up).
    s.go_to_other()
    log = s.get_log()
    assert "Child:exit(var=42)" in log, f"Expected Child:exit(var=42), got {log}"
    assert "Parent:exit" in log, f"Expected Parent:exit (cascade), got {log}"
    assert "Other:enter" in log, f"Expected Other:enter, got {log}"
    child_exit_idx = log.index("Child:exit(var=42)")
    parent_exit_idx = log.index("Parent:exit")
    assert child_exit_idx < parent_exit_idx, f"Child:exit should fire BEFORE Parent:exit (bottom-up), got {log}"
    print("TC2: Child:exit fires before Parent:exit (bottom-up cascade) - PASS")

    # TC3: Exit handler can access child's state variables (verified by var=42 in log).
    print("TC3: Exit handler accesses state var (var=42) - PASS")

    # TC4: Re-entering child fires the entry cascade again.
    s.go_to_child()
    log = s.get_log()
    parent_enter_count = log.count("Parent:enter")
    child_enter_count = log.count("Child:enter")
    assert parent_enter_count == 2, f"Expected 2 Parent:enter, got {parent_enter_count}: {log}"
    assert child_enter_count == 2, f"Expected 2 Child:enter, got {child_enter_count}: {log}"
    print("TC4: Re-entering Child cascades Parent.$> then Child.$> - PASS")

    print("PASS: HSM exit cascade fires Child.<$ then Parent.<$")

if __name__ == '__main__':
    main()

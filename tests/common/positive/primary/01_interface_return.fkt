@@target kotlin

import kotlin.system.exitProcess

// =============================================================================
// Test 01: Interface Return
// =============================================================================
// Validates that event handler returns work correctly via the context stack.
// Tests both syntaxes:
//   - return value     (sugar - expands to @@:return = value)
//   - @@:return = value (explicit context assignment)
// =============================================================================

@@system InterfaceReturn {
    interface:
        bool_return(): Boolean
        int_return(): Int
        string_return(): String
        conditional_return(x: Int): String
        computed_return(a: Int, b: Int): Int
        explicit_bool(): Boolean
        explicit_int(): Int
        explicit_string(): String
        explicit_conditional(x: Int): String
        explicit_computed(a: Int, b: Int): Int

    machine:
        $Active {
            bool_return(): Boolean {
                @@:(true)
                return;
            }

            int_return(): Int {
                @@:(42)
                return;
            }

            string_return(): String {
                @@:("Frame")
                return;
            }

            conditional_return(x: Int): String {
                if (x < 0) {
                    @@:("negative")
                    return;
                } else if (x == 0) {
                    @@:("zero")
                    return;
                } else {
                    @@:("positive")
                    return;
                }
            }

            computed_return(a: Int, b: Int): Int {
                val result = a * b + 10
                @@:(result)
                return;
            }

            explicit_bool(): Boolean {
                @@:return = true
            }

            explicit_int(): Int {
                @@:return = 42
            }

            explicit_string(): String {
                @@:return = "Frame"
            }

            explicit_conditional(x: Int): String {
                if (x < 0) {
                    @@:return = "negative"
                    return
                } else if (x == 0) {
                    @@:return = "zero"
                    return
                } else {
                    @@:return = "positive"
                }
            }

            explicit_computed(a: Int, b: Int): Int {
                val result = a * b + 10
                @@:return = result
            }
        }
}

fun main() {
    println("=== Test 01: Interface Return (Kotlin) ===")
    val s = InterfaceReturn()
    val errors = mutableListOf<String>()

    println("-- Testing 'return value' sugar --")

    val r1 = s.bool_return()
    if (r1 == null || r1 != true) {
        errors.add("bool_return: expected true, got $r1")
    } else {
        println("1. bool_return() = $r1")
    }

    val r2 = s.int_return() as Int
    if (r2 != 42) {
        errors.add("int_return: expected 42, got $r2")
    } else {
        println("2. int_return() = $r2")
    }

    val r3 = s.string_return() as String
    if (r3 != "Frame") {
        errors.add("string_return: expected 'Frame', got '$r3'")
    } else {
        println("3. string_return() = '$r3'")
    }

    var r4 = s.conditional_return(-5) as String
    if (r4 != "negative") {
        errors.add("conditional_return(-5): expected 'negative', got '$r4'")
    }
    r4 = s.conditional_return(0) as String
    if (r4 != "zero") {
        errors.add("conditional_return(0): expected 'zero', got '$r4'")
    }
    r4 = s.conditional_return(10) as String
    if (r4 != "positive") {
        errors.add("conditional_return(10): expected 'positive', got '$r4'")
    } else {
        println("4. conditional_return(-5,0,10) = 'negative','zero','positive'")
    }

    val r5 = s.computed_return(3, 4) as Int
    if (r5 != 22) {
        errors.add("computed_return(3,4): expected 22, got $r5")
    } else {
        println("5. computed_return(3,4) = $r5")
    }

    println("-- Testing '@@:return = value' explicit --")

    val r6 = s.explicit_bool()
    if (r6 == null || r6 != true) {
        errors.add("explicit_bool: expected true, got $r6")
    } else {
        println("6. explicit_bool() = $r6")
    }

    val r7 = s.explicit_int() as Int
    if (r7 != 42) {
        errors.add("explicit_int: expected 42, got $r7")
    } else {
        println("7. explicit_int() = $r7")
    }

    val r8 = s.explicit_string() as String
    if (r8 != "Frame") {
        errors.add("explicit_string: expected 'Frame', got '$r8'")
    } else {
        println("8. explicit_string() = '$r8'")
    }

    var r9 = s.explicit_conditional(-5) as String
    if (r9 != "negative") {
        errors.add("explicit_conditional(-5): expected 'negative', got '$r9'")
    }
    r9 = s.explicit_conditional(0) as String
    if (r9 != "zero") {
        errors.add("explicit_conditional(0): expected 'zero', got '$r9'")
    }
    r9 = s.explicit_conditional(10) as String
    if (r9 != "positive") {
        errors.add("explicit_conditional(10): expected 'positive', got '$r9'")
    } else {
        println("9. explicit_conditional(-5,0,10) = 'negative','zero','positive'")
    }

    val r10 = s.explicit_computed(3, 4) as Int
    if (r10 != 22) {
        errors.add("explicit_computed(3,4): expected 22, got $r10")
    } else {
        println("10. explicit_computed(3,4) = $r10")
    }

    if (errors.size > 0) {
        for (e in errors) {
            println("FAIL: $e")
        }
        throw RuntimeException("${errors.size} test(s) failed")
    } else {
        println("PASS: All interface return tests passed")
    }
}

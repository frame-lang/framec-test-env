<?php
@@target php

@@system TransitionEnterArgs {
    interface:
        start()
        get_log(): list

    machine:
        $Idle {
            start() {
                $this->log[] = "idle:start";
                -> ("from_idle", 42) $Active
            }

            get_log(): list {
                return $this->log;
            }
        }

        $Active {
            $>(source: str, value: int) {
                $this->log[] = "active:enter:{$source}:{$value}";
            }

            start() {
                $this->log[] = "active:start";
            }

            get_log(): list {
                return $this->log;
            }
        }
    domain:
        log = []
}

echo "=== Test 17: Transition Enter Args ===" . "\n";
$s = new TransitionEnterArgs();

$log = $s->get_log();
if (count($log) !== 0) { echo "FAIL: Expected empty log\n"; exit(1); }

$s->start();
$log = $s->get_log();
if (!in_array("idle:start", $log)) { echo "FAIL: Expected 'idle:start' in log\n"; exit(1); }
if (!in_array("active:enter:from_idle:42", $log)) { echo "FAIL: Expected 'active:enter:from_idle:42' in log\n"; exit(1); }
echo "Log after transition: " . implode(", ", $log) . "\n";

echo "PASS: Transition enter args work correctly" . "\n";

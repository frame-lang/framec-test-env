@@[target("ruby")]

# Test 39: Tagged System Instantiation
# Validates the tagged system instantiation syntax

@@system Calculator {
    interface:
        add(a: int, b: int): int
        get_result(): int

    machine:
        $Ready {
            add(a: int, b: int): int {
                self.result = a + b
                @@:(self.result)
                return
            }

            get_result(): int {
                @@:(self.result)
                return
            }
        }
    domain:
        result: int = 0
}

@@system Counter {
    interface:
        increment()
        get_count(): int

    machine:
        $Active {
            increment() {
                self.count = self.count + 1
            }

            get_count(): int {
                @@:(self.count)
                return
            }
        }
    domain:
        count: int = 0
}

puts("=== Test 39: Tagged System Instantiation ===")

# Tagged instantiation - validated at transpile time
calc = @@Calculator()
counter = @@Counter()

# Test Calculator
result = calc.add(3, 4)
raise "Expected 7, got #{result}" unless result == 7
puts("Calculator.add(3, 4) = #{result}")

result = calc.get_result()
raise "Expected 7, got #{result}" unless result == 7
puts("Calculator.get_result() = #{result}")

# Test Counter
counter.increment()
counter.increment()
counter.increment()
count = counter.get_count()
raise "Expected 3, got #{count}" unless count == 3
puts("Counter after 3 increments: #{count}")

puts("PASS: Tagged instantiation works correctly")

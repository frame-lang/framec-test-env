@@[target("go")]

package main

import (
	"encoding/json"
	"fmt"
	"os"
)

var _ = json.Unmarshal
var _ = os.Args

@@[persist(string)]
@@[save(SaveOp)]
@@[load(LoadOp)]
@@system Counter {
    interface:
        Bump()
        GetN(): int

    machine:
        $Active {
            Bump() {
                s.n = s.n + 1
            }
            GetN(): int { @@:(s.n) }
        }

    domain:
        n: int = 0
}

func main() {
    c1 := @@Counter()
    c1.Bump()
    c1.Bump()
    c1.Bump()
    data := c1.SaveOp()

    c2 := @@Counter()
    c2.LoadOp(data)
    if c2.GetN() != 3 {
        fmt.Printf("FAIL: expected 3, got %d\n", c2.GetN())
        return
    }
    fmt.Println("PASS: 93_persist_save_load_contract")
}

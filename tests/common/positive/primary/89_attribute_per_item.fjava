@@[target("java")]

@@system Demo {
    interface:
        common(): String
        @@[target("python_3")] only_py(): String
        @@[target("java")] only_java(): String

    machine:
        $S {
            common(): String { @@:("common") }
            @@[target("python_3")] only_py(): String { @@:("only_py_present") }
            @@[target("java")] only_java(): String { @@:("only_java_present") }
        }
}

class Main {
    public static void main(String[] args) {
        Demo d = new Demo();
        if (!d.common().equals("common")) { System.out.println("FAIL common: " + d.common()); System.exit(1); }
        if (!d.only_java().equals("only_java_present")) { System.out.println("FAIL only_java: " + d.only_java()); System.exit(1); }
        System.out.println("PASS: 89_attribute_per_item");
    }
}

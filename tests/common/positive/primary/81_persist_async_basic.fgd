@@target gdscript

extends SceneTree

@@persist
@@system PersistAsync {
    interface:
        async configure(amount: int)
        get_value(): int

    machine:
        $Idle {
            configure(amount: int) {
                self.value = amount * 2
                -> $Active
            }
            get_value(): int { @@:(0) }
        }
        $Active {
            configure(amount: int) {
                self.value = self.value + (amount * 2)
                -> $Active
            }
            get_value(): int { @@:(self.value) }
        }
    domain:
        value: int = 0
}

func _init():
    var s1 = @@PersistAsync()
    await s1.init()
    await s1.configure(5)
    var v = await s1.get_value()
    assert(v == 10, "FAIL pre: expected 10, got " + str(v))
    var snap = s1.save_state()
    var s2 = PersistAsync.restore_state(snap)
    v = await s2.get_value()
    assert(v == 10, "FAIL post: expected 10, got " + str(v))
    await s2.configure(3)
    v = await s2.get_value()
    assert(v == 16, "FAIL post-2nd: expected 16, got " + str(v))
    print("PASS: 81_persist_async_basic")
    quit()

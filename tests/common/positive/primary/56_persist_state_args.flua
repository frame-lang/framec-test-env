@@[target("lua")]

@@[persist(string)]
@@[save(save_state)]
@@[load(restore_state)]
@@system PersistStateArgs {
    interface:
        kick(v: int)
        get_slot(): int

    machine:
        $Idle {
            kick(v: int) {
                -> $Active(v)
            }
            get_slot(): int {
                @@:(-1)
                return
            }
        }

        $Active(slot: int) {
            kick(v: int) {
                -> $Active(v)
            }
            get_slot(): int {
                @@:(slot)
                return
            }
        }
    domain:
        v: int = 0
}

print("=== Test 56: Persist State-Args Round-Trip (Lua) ===")
local s1 = @@PersistStateArgs()
s1:kick(42)
local pre = s1:get_slot()
if pre ~= 42 then error("Expected 42 pre-save, got " .. tostring(pre)) end
print("1. Pre-save slot=" .. tostring(pre))

local snap = s1:save_state()
local s2 = @@PersistStateArgs()

s2:restore_state(snap)
local post = s2:get_slot()
if post ~= 42 then error("Expected 42 post-restore, got " .. tostring(post)) end
print("2. Post-restore slot=" .. tostring(post))

s2:kick(99)
local post2 = s2:get_slot()
if post2 ~= 99 then error("Expected 99 post-kick, got " .. tostring(post2)) end
print("3. Post-restore-kick slot=" .. tostring(post2))

print("PASS: 56_persist_state_args")

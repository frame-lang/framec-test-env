@@target c

@@system WithTransition {
    interface:
        next()
        get_state(): char*

    machine:
        $First {
            next() {
                printf("Transitioning: First -> Second\n");
                -> $Second
            }

            get_state(): char* {
                @@:("First")
                return;
            }
        }

        $Second {
            next() {
                printf("Transitioning: Second -> First\n");
                -> $First
            }

            get_state(): char* {
                @@:("Second")
                return;
            }
        }
}

int main() {
    printf("=== Test 03: State Transitions ===\n");
    WithTransition* s = @@WithTransition();

    // Initial state should be First
    char* state = WithTransition_get_state(s);
    if (strcmp(state, "First") != 0) {
        printf("FAIL: Expected 'First', got '%s'\n", state);
        return 1;
    }
    printf("Initial state: %s\n", state);

    // Transition to Second
    WithTransition_next(s);
    state = WithTransition_get_state(s);
    if (strcmp(state, "Second") != 0) {
        printf("FAIL: Expected 'Second', got '%s'\n", state);
        return 1;
    }
    printf("After first next(): %s\n", state);

    // Transition back to First
    WithTransition_next(s);
    state = WithTransition_get_state(s);
    if (strcmp(state, "First") != 0) {
        printf("FAIL: Expected 'First', got '%s'\n", state);
        return 1;
    }
    printf("After second next(): %s\n", state);

    printf("PASS: State transitions work correctly\n");
    WithTransition_destroy(s);
    return 0;
}

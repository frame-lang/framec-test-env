@@[target("swift")]

@@[persist]
@@system Counter {
    operations:
        @@[save]
        save_state(): String {}

        @@[load]
        restore_state(data: String) {}

        @@[on_load]
        rebuild_derived() {
            self.doubled = self.n * 2
            self.was_restored = true
        }

    interface:
        bump()
        getN(): Int
        getDoubled(): Int
        wasLoaded(): Bool

    machine:
        $Active {
            bump() { self.n = self.n + 1 }
            getN(): Int { @@:(self.n) }
            getDoubled(): Int { @@:(self.doubled) }
            wasLoaded(): Bool { @@:(self.was_restored) }
        }

    domain:
        n: Int = 0
        doubled: Int = 0
        was_restored: Bool = false
}

let c1 = Counter()
c1.bump(); c1.bump(); c1.bump()
if c1.wasLoaded() {
    print("FAIL: was_restored should be false pre-restore")
} else if c1.getDoubled() != 0 {
    print("FAIL: doubled should be 0, got \(c1.getDoubled())")
} else {
    let data = c1.save_state()
    let c2 = Counter()
    c2.restore_state(data)
    if !c2.wasLoaded() {
        print("FAIL: was_restored should be true after on_load")
    } else if c2.getN() != 3 {
        print("FAIL: n should be 3, got \(c2.getN())")
    } else if c2.getDoubled() != 6 {
        print("FAIL: doubled should be 6, got \(c2.getDoubled())")
    } else {
        print("PASS: 95_persist_on_load_hook")
    }
}

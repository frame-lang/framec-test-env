@@target kotlin

import kotlin.system.exitProcess

@@system HSMEnterExitParams {
    interface:
        go_to_a()
        go_to_sibling()
        go_back()
        get_log(): ArrayList
        get_state(): String

    machine:
        $Start {
            go_to_a() {
                -> ("starting") $ChildA
            }

            get_log(): ArrayList {
                return this.log
            }

            get_state(): String {
                return "Start"
            }
        }

        $ChildA => $Parent {
            $>(msg: String) {
                this.log.add("ChildA:enter(" + msg + ")")
            }

            <$(reason: String) {
                this.log.add("ChildA:exit(" + reason + ")")
            }

            go_to_sibling() {
                ("leaving_A") -> ("arriving_B") $ChildB
            }

            get_log(): ArrayList {
                return this.log
            }

            get_state(): String {
                return "ChildA"
            }
        }

        $ChildB => $Parent {
            $>(msg: String) {
                this.log.add("ChildB:enter(" + msg + ")")
            }

            <$(reason: String) {
                this.log.add("ChildB:exit(" + reason + ")")
            }

            go_back() {
                ("leaving_B") -> ("returning_A") $ChildA
            }

            get_log(): ArrayList {
                return this.log
            }

            get_state(): String {
                return "ChildB"
            }
        }

        $Parent {
            get_log(): ArrayList {
                return this.log
            }

            get_state(): String {
                return "Parent"
            }
        }
    domain:
        log = ArrayList()
}

fun main() {
    println("=== Test 49: HSM Enter/Exit with Params ===")
    val s = @@HSMEnterExitParams()

    // First go to ChildA with enter params
    s.go_to_a()
    var log = s.get_log() as java.util.ArrayList<*>
    if (!log.contains("ChildA:enter(starting)")) {
        println("FAIL: Expected ChildA:enter(starting), got $log")
        exitProcess(1)
    }
    println("TC2.5.0: Initial transition with enter params - PASS")

    // TC2.5.1: Exit params passed correctly
    s.go_to_sibling()
    log = s.get_log() as java.util.ArrayList<*>
    if (!log.contains("ChildA:exit(leaving_A)")) {
        println("FAIL: Expected exit with param, got $log")
        exitProcess(1)
    }
    println("TC2.5.1: Exit params passed correctly - PASS")

    // TC2.5.2: Enter params passed to target state
    if (!log.contains("ChildB:enter(arriving_B)")) {
        println("FAIL: Expected enter with param, got $log")
        exitProcess(1)
    }
    if ((s.get_state() as String) != "ChildB") {
        println("FAIL: Expected ChildB, got ${s.get_state()}")
        exitProcess(1)
    }
    println("TC2.5.2: Enter params passed to target - PASS")

    // TC2.5.3: Return transition with different params
    s.go_back()
    log = s.get_log() as java.util.ArrayList<*>
    if (!log.contains("ChildB:exit(leaving_B)")) {
        println("FAIL: Expected ChildB exit, got $log")
        exitProcess(1)
    }
    if (!log.contains("ChildA:enter(returning_A)")) {
        println("FAIL: Expected ChildA enter, got $log")
        exitProcess(1)
    }
    println("TC2.5.3: Return transition with params - PASS")

    println("PASS: HSM enter/exit with params works correctly")
}

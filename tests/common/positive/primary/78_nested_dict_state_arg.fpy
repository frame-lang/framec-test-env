@@[target("python_3")]

@@[persist]
@@system NestedDict {
    interface:
        configure(m: dict)
        get_inner(outer_key: str, inner_key: str): int

    machine:
        $Idle {
            configure(m: dict) { -> $Active(m) }
            get_inner(outer_key: str, inner_key: str): int { @@:(-1); return }
        }
        $Active(m: dict) {
            configure(m: dict) { -> $Active(m) }
            get_inner(outer_key: str, inner_key: str): int {
                @@:(m.get(outer_key, {}).get(inner_key, -1))
                return
            }
        }
    domain:
        n: int = 0
}

def main():
    s1 = NestedDict()
    s1.configure({"u": {"x": 1, "y": 2}, "v": {"z": 3}})
    assert s1.get_inner("u", "x") == 1
    assert s1.get_inner("v", "z") == 3
    snap = s1.save_state()
    s2 = NestedDict.restore_state(snap)
    assert s2.get_inner("u", "x") == 1
    assert s2.get_inner("u", "y") == 2
    assert s2.get_inner("v", "z") == 3
    print("PASS: 78_nested_dict_state_arg")

if __name__ == '__main__':
    main()

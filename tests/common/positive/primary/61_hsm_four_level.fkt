@@target kotlin

@@system HsmFourLevel {
    interface:
        drive(): int
        write_at_level(level: int)
        get_n(): int

    machine:
        $Leaf => $Mid {
            drive(): int {
                => $^
            }
            write_at_level(level: int) {
                n = n + level * 1
                => $^
            }
            get_n(): int {
                @@:(n)
            }
        }

        $Mid => $Branch {
            drive(): int {
                => $^
            }
            write_at_level(level: int) {
                n = n + level * 10
                => $^
            }
        }

        $Branch => $Root {
            drive(): int {
                => $^
            }
            write_at_level(level: int) {
                n = n + level * 100
                => $^
            }
        }

        $Root {
            drive(): int {
                @@:(n)
            }
            write_at_level(level: int) {
                n = n + level * 1000
            }
        }
    domain:
        n : int = 0
}

fun main() {
    println("=== Test 61: 4-level HSM cascade (Kotlin) ===")
    val s = HsmFourLevel()

    val initial = s.drive()
    if (initial != 0) { println("FAIL: initial $initial"); kotlin.system.exitProcess(1) }
    println("1. Initial drive returned $initial")

    s.write_at_level(2)
    val after = s.get_n()
    if (after != 2222) { println("FAIL: after $after"); kotlin.system.exitProcess(1) }
    println("2. After cascading write: n=$after")

    val finalVal = s.drive()
    if (finalVal != 2222) { println("FAIL: final $finalVal"); kotlin.system.exitProcess(1) }
    println("3. Drive after write returned $finalVal")

    println("PASS: 61_hsm_four_level")
}

@@[target("cpp_17")]

@@[persist]

#include <iostream>
#include <cmath>
#include <nlohmann/json.hpp>

@@system PFloat {
    interface:
        configure(rate: double)
        get_rate(): double

    machine:
        $Idle {
            configure(rate: double) {
                -> $Active(rate)
            }
            get_rate(): double {
                @@:(0.0)
            }
        }

        $Active(rate: double) {
            get_rate(): double {
                @@:(rate)
            }
        }
    domain:
        n : int = 0
}

int main() {
    PFloat s;
    s.configure(3.14159);
    auto snap = s.save_state();
    auto s2 = PFloat::restore_state(snap);
    double r = s2.get_rate();
    if (std::abs(r - 3.14159) > 1e-9) { std::cout << "FAIL " << r << std::endl; return 1; }
    std::cout << "PASS: 69_persist_float_state_arg, rate=" << r << std::endl;
    return 0;
}

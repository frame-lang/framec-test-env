@@[target("kotlin")]

@@[persist(String)]
@@[save(save_state)]
@@[load(restore_state)]
@@system PPushDeep {
    interface:
        descend()
        ascend()
        get_depth(): int

    machine:
        $Idle {
            descend() { push$; -> $Modal1 }
            get_depth(): int { @@:(0) }
        }
        $Modal1 {
            descend() { push$; -> $Modal2 }
            ascend() { -> pop$ }
            get_depth(): int { @@:(1) }
        }
        $Modal2 {
            descend() { push$; -> $Modal3 }
            ascend() { -> pop$ }
            get_depth(): int { @@:(2) }
        }
        $Modal3 {
            ascend() { -> pop$ }
            get_depth(): int { @@:(3) }
        }
    domain: n : int = 0
}

fun main() {
    val s = @@PPushDeep()
    s.descend(); s.descend(); s.descend()
    if (s.get_depth() != 3) { println("FAIL pre"); kotlin.system.exitProcess(1) }
    val snap = s.save_state() as String
    val s2 = @@PPushDeep()

    s2.restore_state(snap)
    if (s2.get_depth() != 3) { println("FAIL post"); kotlin.system.exitProcess(1) }
    s2.ascend()
    if (s2.get_depth() != 2) { println("FAIL a1"); kotlin.system.exitProcess(1) }
    s2.ascend()
    if (s2.get_depth() != 1) { println("FAIL a2"); kotlin.system.exitProcess(1) }
    s2.ascend()
    if (s2.get_depth() != 0) { println("FAIL a3"); kotlin.system.exitProcess(1) }
    println("PASS: 71_persist_push_depth_three")
}

@@[target("typescript")]

@@system FloatStateArg {
    interface:
        configure(rate: float)
        scale(v: float): float

    machine:
        $Idle {
            configure(rate: number) {
                -> $Active(rate)
            }
            scale(v: number): number {
                @@:(v)
                return
            }
        }

        $Active => $Frame(rate: number) {
            configure(rate: number) {
                -> $Active(rate)
            }
            scale(v: number): number {
                => $^
            }
        }

        $Frame {
            scale(v: number): number {
                @@:(v * rate)
                return
            }
        }
    domain:
        n: number = 0
}

const s = @@FloatStateArg();
if (s.scale(2.0) !== 2.0) { console.log("FAIL idle"); process.exit(1); }
s.configure(0.5);
if (Math.abs(s.scale(10.0) - 5.0) > 1e-9) { console.log("FAIL scale 0.5"); process.exit(1); }
s.configure(2.5);
if (Math.abs(s.scale(4.0) - 10.0) > 1e-9) { console.log("FAIL scale 2.5"); process.exit(1); }
console.log("PASS: 68_hsm_float_state_args");

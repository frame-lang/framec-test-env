@@[target("dart")]
@@[create(make)]
@@system Counter(seed: int) {
    interface:
        bump()
        get(): int

    machine:
        $A {
            bump() { this.count = this.count + 1; }
            get(): int { @@:(this.count) }
        }

    domain:
        seed: int = seed
        count: int = 0
}

void main() {
    var c1 = Counter(42);
    c1.bump();
    c1.bump();
    if (c1.get() != 2) {
        print("FAIL: via Counter() expected 2, got ${c1.get()}");
        return;
    }

    var c2 = Counter.make(99);
    c2.bump();
    if (c2.get() != 1) {
        print("FAIL: via Counter.make expected 1, got ${c2.get()}");
        return;
    }

    print("PASS: rfc0015_create_rename");
}

@@target erlang
@@[persist]
@@system PersistMultiEvent {
    interface:
        seed(v: int)
        bump()
        getSlot(): int
    machine:
        $Idle {
            seed(v: int) {
                -> $Active(v)
            }
            bump() {
                @@:(-1)
            }
            getSlot(): int {
                @@:(-1)
            }
        }
        $Active(slot: int) {
            seed(v: int) {
                -> $Active(v)
            }
            bump() {
                -> $Active(slot + 100)
            }
            getSlot(): int {
                @@:(slot)
            }
        }
    domain:
        v = 0
}

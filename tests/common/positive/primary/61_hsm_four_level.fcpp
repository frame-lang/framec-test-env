@@[target("cpp_17")]

#include <iostream>
#include <string>
#include <cstdlib>

@@system HsmFourLevel {
    interface:
        drive(): int
        write_at_level(level: int)
        get_n(): int

    machine:
        $Leaf => $Mid {
            drive(): int {
                => $^
            }
            write_at_level(level: int) {
                this->n = this->n + level * 1;
                => $^
            }
            get_n(): int {
                @@:(this->n)
            }
        }

        $Mid => $Branch {
            drive(): int {
                => $^
            }
            write_at_level(level: int) {
                this->n = this->n + level * 10;
                => $^
            }
        }

        $Branch => $Root {
            drive(): int {
                => $^
            }
            write_at_level(level: int) {
                this->n = this->n + level * 100;
                => $^
            }
        }

        $Root {
            drive(): int {
                @@:(this->n)
            }
            write_at_level(level: int) {
                this->n = this->n + level * 1000;
            }
        }
    domain:
        n : int = 0
}

int main() {
    std::cout << "=== Test 61: 4-level HSM cascade (C++) ===" << std::endl;
    HsmFourLevel s;

    int initial = s.drive();
    if (initial != 0) { std::cout << "FAIL: initial " << initial << std::endl; return 1; }
    std::cout << "1. Initial drive returned " << initial << std::endl;

    s.write_at_level(2);
    int after = s.get_n();
    if (after != 2222) { std::cout << "FAIL: after " << after << std::endl; return 1; }
    std::cout << "2. After cascading write: n=" << after << std::endl;

    int finalVal = s.drive();
    if (finalVal != 2222) { std::cout << "FAIL: final " << finalVal << std::endl; return 1; }
    std::cout << "3. Drive after write returned " << finalVal << std::endl;

    std::cout << "PASS: 61_hsm_four_level" << std::endl;
    return 0;
}

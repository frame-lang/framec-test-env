@@[target("java")]

@@[persist(String)]
@@[save(save_state)]
@@[load(restore_state)]
@@system private Inner {
    interface:
        cycle()
        get_state(): String
        get_count(): int

    machine:
        $A {
            cycle() { this.n = this.n + 1; -> $B }
            get_state(): String { @@:("A") }
            get_count(): int { @@:(this.n) }
        }
        $B => $A {
            cycle() { -> $A }
            get_state(): String { @@:("B") }
            get_count(): int { => $^ }
        }
    domain:
        n: int = 0
}
@@[persist(String)]
@@[save(save_state)]
@@[load(restore_state)]

@@[main]
@@system Outer {
    interface:
        tick()
        cycle_inner()
        get_outer_state(): String
        get_inner_state(): String
        get_inner_count(): int
        get_k(): int

    machine:
        $Idle {
            tick() { this.k = this.k + 1; -> $Active }
            cycle_inner() { this.inner.cycle(); }
            get_outer_state(): String { @@:("Idle") }
            get_inner_state(): String { @@:(this.inner.get_state()) }
            get_inner_count(): int { @@:(this.inner.get_count()) }
            get_k(): int { @@:(this.k) }
        }
        $Active => $Idle {
            tick() { -> $Idle }
            get_outer_state(): String { @@:("Active") }
            cycle_inner() { => $^ }
            get_inner_state(): String { => $^ }
            get_inner_count(): int { => $^ }
            get_k(): int { => $^ }
        }
    domain:
        k: int = 0
        inner: Inner = @@Inner()
}

class Main {
    static String fmt(Outer o) {
        return o.get_outer_state() + "/" + o.get_inner_state() + "/" + o.get_inner_count() + "/" + o.get_k();
    }
    static void must(String label, Outer o, String expected) {
        String actual = fmt(o);
        if (!expected.equals(actual)) throw new RuntimeException("FAIL " + label + ": " + actual + " expected " + expected);
    }
    public static void main(String[] args) {
        Outer o1 = @@Outer();
        Outer o2 = @@Outer();

        o1.cycle_inner();
        o1.cycle_inner();
        o1.cycle_inner();
        must("o1 pre", o1, "Idle/B/2/0");

        o2.tick();
        o2.tick();
        o2.tick();
        must("o2 pre", o2, "Active/A/0/2");

        String snap1 = o1.save_state();
        String snap2 = o2.save_state();

        Outer r2 = @@Outer();


        r2.restore_state(snap2);
        Outer r1 = @@Outer();

        r1.restore_state(snap1);

        must("r1 restored", r1, "Idle/B/2/0");
        must("r2 restored", r2, "Active/A/0/2");

        r1.cycle_inner();
        must("r1 after mut", r1, "Idle/A/2/0");
        must("r2 after r1 mut", r2, "Active/A/0/2");

        r2.cycle_inner();
        must("r1 after r2 mut", r1, "Idle/A/2/0");
        must("r2 after r2 mut", r2, "Active/B/1/2");

        System.out.println("PASS: 87_persist_multi_instance");
    }
}

@@[target("swift")]

@@system TransitionExitArgs {
    interface:
        leave()
        get_log(): string[]

    machine:
        $Active {
            <$(reason: string, code: number) {
                self.log.append("exit:\(reason):\(code)")
            }

            leave() {
                self.log.append("leaving")
                ("cleanup", 42) -> $Done
            }

            get_log(): string[] {
                @@:(self.log)
                return;
            }
        }

        $Done {
            $>() {
                self.log.append("enter:done")
            }

            get_log(): string[] {
                @@:(self.log)
                return;
            }
        }
    domain:
        log: string[] = []
}

// main
    print("=== Test 18: Transition Exit Args ===")
    let s = @@TransitionExitArgs()

    // Initial state is Active
    var log = s.get_log()
    if log.count != 0 {
        fatalError("Expected empty log, got \(String(describing: log))")
    }

    // Leave - should call exit handler with args
    s.leave()
    log = s.get_log()
    if !log.contains("leaving") {
        fatalError("Expected 'leaving' in log, got \(String(describing: log))")
    }
    if !log.contains("exit:cleanup:42") {
        fatalError("Expected 'exit:cleanup:42' in log, got \(String(describing: log))")
    }
    if !log.contains("enter:done") {
        fatalError("Expected 'enter:done' in log, got \(String(describing: log))")
    }
    print("Log after transition: \(String(describing: log))")

    print("PASS: Transition exit args work correctly")

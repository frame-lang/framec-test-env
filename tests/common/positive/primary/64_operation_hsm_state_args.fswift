@@[target("swift")]

import Foundation

@@system OpHsmStateArgs {
    operations:
        add_offset(x: int, off: int): int {
            return x + off
        }

    interface:
        enter_active(t: int)
        classify(v: int): int

    machine:
        $Idle {
            enter_active(t: int) {
                -> $Active(t)
            }
            classify(v: int): int {
                @@:(-1)
            }
        }

        $Active => $Frame(threshold: int) {
            enter_active(t: int) {
                -> $Active(t)
            }
            classify(v: int): int {
                let r = self.add_offset(v, threshold)
                @@:(r)
            }
        }

        $Frame {
        }
    domain:
        n : int = 0
}

print("=== Test 64: Operations × HSM × state-args (Swift) ===")
let s = OpHsmStateArgs()

let pre = s.classify(5)
if pre != -1 { print("FAIL: pre \(pre)"); exit(1) }
print("1. Idle classify(5) = \(pre)")

s.enter_active(10)
let r = s.classify(5)
if r != 15 { print("FAIL: r \(r)"); exit(1) }
print("2. classify(5) with threshold=10 → \(r)")

let r2 = s.classify(7)
if r2 != 17 { print("FAIL: r2 \(r2)"); exit(1) }
print("3. classify(7) with threshold=10 → \(r2)")

s.enter_active(100)
let r3 = s.classify(5)
if r3 != 105 { print("FAIL: r3 \(r3)"); exit(1) }
print("4. classify(5) with threshold=100 → \(r3)")

print("PASS: 64_operation_hsm_state_args")

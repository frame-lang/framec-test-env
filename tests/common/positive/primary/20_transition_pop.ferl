@@target erlang
@@system TransitionPop {
    interface:
        start()
        process()
        getState(): str
    machine:
        $Idle {
            start() {
                push$
                -> $Working
            }
            process() { }
            getState(): str { return "Idle" }
        }
        $Working {
            process() {
                -> pop$
            }
            start() { }
            getState(): str { return "Working" }
        }
}

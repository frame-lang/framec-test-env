@@target gdscript
extends SceneTree

@@system FloatStateArg {
    interface:
        configure(rate: float)
        scale(v: float): float

    machine:
        $Idle {
            configure(rate: float) {
                -> $Active(rate)
            }
            scale(v: float): float {
                @@:(v)
            }
        }

        $Active => $Frame(rate: float) {
            configure(rate: float) {
                -> $Active(rate)
            }
            scale(v: float): float {
                => $^
            }
        }

        $Frame {
            scale(v: float): float {
                @@:(v * rate)
            }
        }
    domain:
        n: int = 0
}

func _initialize():
    var s = FloatStateArg.new()
    if abs(s.scale(2.0) - 2.0) > 1e-9:
        print("FAIL idle"); quit(1); return
    s.configure(0.5)
    if abs(s.scale(10.0) - 5.0) > 1e-9:
        print("FAIL 0.5"); quit(1); return
    s.configure(2.5)
    if abs(s.scale(4.0) - 10.0) > 1e-9:
        print("FAIL 2.5"); quit(1); return
    print("PASS: 68_hsm_float_state_args")
    quit(0)

@@target kotlin

import kotlin.system.exitProcess

// Tests that @@:return follows "last writer wins" across transition lifecycle

@@system SystemReturnChainTest {
    interface:
        test_enter_sets(): String
        test_exit_then_enter(): String
        get_state(): String

    machine:
        $Start {
            test_enter_sets(): String {
                -> $EnterSetter
            }

            test_exit_then_enter(): String {
                -> $BothSet
            }

            get_state(): String {
                return "Start"
            }

            <$() {
                // Exit handler sets initial value
                @@:return = "from_exit"
            }
        }

        $EnterSetter {
            $>() {
                // Enter handler sets return value
                @@:return = "from_enter"
            }

            get_state(): String {
                return "EnterSetter"
            }
        }

        $BothSet {
            $>() {
                // Enter handler sets return - should overwrite exit's value
                @@:return = "enter_wins"
            }

            get_state(): String {
                return "BothSet"
            }
        }
}

fun main() {
    println("=== Test 15: System Return Chain (Last Writer Wins) ===")

    // Test 1: Start exit + EnterSetter enter
    // Start's exit sets "from_exit", EnterSetter's enter sets "from_enter"
    // Enter should win (last writer)
    val s1 = SystemReturnChainTest()
    val result1 = s1.test_enter_sets() as String
    if (result1 != "from_enter") {
        throw RuntimeException("Expected 'from_enter', got '$result1'")
    }
    val state1 = s1.get_state() as String
    if (state1 != "EnterSetter") {
        throw RuntimeException("Expected state 'EnterSetter'")
    }
    println("1. Exit set then enter set - enter wins: '$result1'")

    // Test 2: Both handlers set, enter wins
    val s2 = SystemReturnChainTest()
    val result2 = s2.test_exit_then_enter() as String
    if (result2 != "enter_wins") {
        throw RuntimeException("Expected 'enter_wins', got '$result2'")
    }
    val state2 = s2.get_state() as String
    if (state2 != "BothSet") {
        throw RuntimeException("Expected state 'BothSet'")
    }
    println("2. Both set - enter wins: '$result2'")

    println("PASS: System return chain (last writer wins) works correctly")
}

@@[target("typescript")]

// Test 46: HSM Enter Cascade — Parent has $>, Child does not
//
// Tests the HSM enter cascade per docs/frame_runtime_introduction.md
// Step 21+. When entering an HSM child, the kernel fires $> on every
// layer of the new chain top-down (parent first, child last).
//
// In this system, only Parent declares $>, so entering Child fires
// Parent's $> exactly once via the cascade.

@@system HSMEnterParentOnly {
    interface:
        go_to_child()
        go_to_parent()
        get_log(): string[]
        get_state(): str

    machine:
        $Start {
            go_to_child() {
                -> $Child
            }

            go_to_parent() {
                -> $Parent
            }

            get_log(): list {
                @@:(this.log)
                return;
            }

            get_state(): str {
                @@:("Start")
                return;
            }
        }

        $Child => $Parent {
            go_to_parent() {
                -> $Parent
            }

            get_log(): list {
                @@:(this.log)
                return;
            }

            get_state(): str {
                @@:("Child")
                return;
            }
        }

        $Parent {
            $>() {
                this.log.push("Parent:enter")
            }

            go_to_child() {
                -> $Child
            }

            get_log(): list {
                @@:(this.log)
                return;
            }

            get_state(): str {
                @@:("Parent")
                return;
            }
        }
    domain:
        log: string[] = []
}

function main() {
    console.log("=== Test 46: HSM Enter Cascade — Parent only ===");
    const s = @@HSMEnterParentOnly();

    // TC1: Entering Child fires Parent's $> via cascade.
    s.go_to_child();
    if (s.get_state() !== "Child") throw new Error(`Expected Child, got ${s.get_state()}`);
    let log = s.get_log();
    if (!log.includes("Parent:enter")) throw new Error(`Expected Parent:enter on cascade entry to Child, got ${JSON.stringify(log)}`);
    console.log("TC1: Parent's $> fires on Child entry via cascade - PASS");

    // TC2: Transitioning from Child directly to Parent fires Parent's $>
    // again (Child's chain exits, then Parent's enter cascade fires Parent.$>).
    s.go_to_parent();
    if (s.get_state() !== "Parent") throw new Error(`Expected Parent, got ${s.get_state()}`);
    log = s.get_log();
    let count = log.filter((x: string) => x === "Parent:enter").length;
    if (count !== 2) throw new Error(`Expected 2 Parent:enter (one cascade + one direct), got ${count}: ${JSON.stringify(log)}`);
    console.log("TC2: Parent's $> fires on direct entry to Parent - PASS");

    // TC3: Transitioning back to Child fires Parent's $> again via cascade.
    s.go_to_child();
    if (s.get_state() !== "Child") throw new Error(`Expected Child, got ${s.get_state()}`);
    log = s.get_log();
    count = log.filter((x: string) => x === "Parent:enter").length;
    if (count !== 3) throw new Error(`Expected 3 Parent:enter total, got ${count}: ${JSON.stringify(log)}`);
    console.log("TC3: Parent's $> fires again on cascade back to Child - PASS");

    console.log("PASS: HSM enter cascade fires ancestor $> correctly");
}

main();

@@[target("lua")]

@@system OpHsmStateArgs {
    operations:
        add_offset(x: int, off: int): int {
            return x + off
        }

    interface:
        enter_active(t: int)
        classify(v: int): int

    machine:
        $Idle {
            enter_active(t: int) {
                -> $Active(t)
            }
            classify(v: int): int {
                @@:(-1)
                return
            }
        }

        $Active => $Frame(threshold: int) {
            enter_active(t: int) {
                -> $Active(t)
            }
            classify(v: int): int {
                local r = self:add_offset(v, threshold)
                @@:(r)
                return
            }
        }

        $Frame {
        }
    domain:
        n: int = 0
}

print("=== Test 64: Operations × HSM × state-args (Lua) ===")
local s = OpHsmStateArgs.new()

local pre = s:classify(5)
if pre ~= -1 then error("Expected -1, got " .. tostring(pre)) end
print("1. Idle classify(5) = " .. tostring(pre))

s:enter_active(10)
local r = s:classify(5)
if r ~= 15 then error("Expected 15, got " .. tostring(r)) end
print("2. classify(5) with threshold=10 → " .. tostring(r))

local r2 = s:classify(7)
if r2 ~= 17 then error("Expected 17, got " .. tostring(r2)) end
print("3. classify(7) with threshold=10 → " .. tostring(r2))

s:enter_active(100)
local r3 = s:classify(5)
if r3 ~= 105 then error("Expected 105, got " .. tostring(r3)) end
print("4. classify(5) with threshold=100 → " .. tostring(r3))

print("PASS: 64_operation_hsm_state_args")

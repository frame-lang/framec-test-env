@@[target("javascript")]

@@[persist(string)]
@@[save(saveState)]
@@[load(restoreState)]
@@system DictOfList {
    interface:
        configure(m)
        get_at(key, idx)

    machine:
        $Idle {
            configure(m) { -> $Active(m) }
            get_at(key, idx) { @@:(-1) }
        }
        $Active(m) {
            configure(m) { -> $Active(m) }
            get_at(key, idx) {
                @@:(m[key] && idx < m[key].length ? m[key][idx] : -1)
            }
        }
    domain:
        n = 0
}

const s1 = @@DictOfList();
s1.configure({"a": [10, 20], "b": [30, 40, 50]});
if (s1.get_at("a", 0) !== 10) { console.log("FAIL pre a.0"); process.exit(1); }
if (s1.get_at("b", 2) !== 50) { console.log("FAIL pre b.2"); process.exit(1); }
const snap = s1.saveState();
const s2 = @@DictOfList();

s2.restoreState(snap);
if (s2.get_at("a", 0) !== 10) { console.log("FAIL post a.0"); process.exit(1); }
if (s2.get_at("a", 1) !== 20) { console.log("FAIL post a.1"); process.exit(1); }
if (s2.get_at("b", 2) !== 50) { console.log("FAIL post b.2"); process.exit(1); }
console.log("PASS: 79_dict_of_list_state_arg");

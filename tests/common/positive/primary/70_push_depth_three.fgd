@@[target("gdscript")]
extends SceneTree

@@system PushDeep {
    interface:
        descend()
        ascend()
        get_depth(): int

    machine:
        $Idle {
            descend() {
                push$
                -> $Modal1
            }
            get_depth(): int {
                @@:(0)
            }
        }

        $Modal1 {
            descend() {
                push$
                -> $Modal2
            }
            ascend() {
                -> pop$
            }
            get_depth(): int {
                @@:(1)
            }
        }

        $Modal2 {
            descend() {
                push$
                -> $Modal3
            }
            ascend() {
                -> pop$
            }
            get_depth(): int {
                @@:(2)
            }
        }

        $Modal3 {
            ascend() {
                -> pop$
            }
            get_depth(): int {
                @@:(3)
            }
        }
    domain:
        n: int = 0
}

func _initialize():
    var s = PushDeep.new()
    if s.get_depth() != 0:
        print("FAIL idle"); quit(1); return
    s.descend()
    if s.get_depth() != 1:
        print("FAIL d1"); quit(1); return
    s.descend()
    if s.get_depth() != 2:
        print("FAIL d2"); quit(1); return
    s.descend()
    if s.get_depth() != 3:
        print("FAIL d3"); quit(1); return
    s.ascend()
    if s.get_depth() != 2:
        print("FAIL a1"); quit(1); return
    s.ascend()
    if s.get_depth() != 1:
        print("FAIL a2"); quit(1); return
    s.ascend()
    if s.get_depth() != 0:
        print("FAIL a3"); quit(1); return
    print("PASS: 70_push_depth_three")
    quit(0)

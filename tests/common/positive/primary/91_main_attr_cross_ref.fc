@@[target("c")]

#include <stdio.h>
#include <stdlib.h>

@@system Sub {
    interface:
        ping(): int
    machine:
        $Idle {
            ping(): int { @@:(42) }
        }
}

@@[main]
@@system Top {
    interface:
        run(): int
    machine:
        $Active {
            run(): int { @@:(self->sub->ping()) }
        }
    domain:
        sub: Sub = @@Sub()
}

int main() {
    Top* t = @@Top();
    int got = Top_run(t);
    if (got != 42) {
        printf("FAIL run(): %d\n", got);
        Top_destroy(t);
        return 1;
    }
    printf("PASS: 91_main_attr_cross_ref\n");
    Top_destroy(t);
    return 0;
}

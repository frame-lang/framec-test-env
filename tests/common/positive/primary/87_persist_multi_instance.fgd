@@[target("gdscript")]

extends SceneTree

@@[persist(String)]
@@[save(save_state)]
@@[load(restore_state)]
@@system Inner {
    interface:
        cycle()
        get_state(): String
        get_count(): int

    machine:
        $A {
            cycle() { self.n = self.n + 1; -> $B }
            get_state(): String { @@:("A") }
            get_count(): int { @@:(self.n) }
        }
        $B => $A {
            cycle() { -> $A }
            get_state(): String { @@:("B") }
            get_count(): int { => $^ }
        }
    domain:
        n: int = 0
}@@[persist(String)]
@@[save(save_state)]
@@[load(restore_state)]


@@[main]
@@system Outer {
    interface:
        tick()
        cycle_inner()
        get_outer_state(): String
        get_inner_state(): String
        get_inner_count(): int
        get_k(): int

    machine:
        $Idle {
            tick() { self.k = self.k + 1; -> $Active }
            cycle_inner() { self.inner.cycle() }
            get_outer_state(): String { @@:("Idle") }
            get_inner_state(): String { @@:(self.inner.get_state()) }
            get_inner_count(): int { @@:(self.inner.get_count()) }
            get_k(): int { @@:(self.k) }
        }
        $Active => $Idle {
            tick() { -> $Idle }
            get_outer_state(): String { @@:("Active") }
            cycle_inner() { => $^ }
            get_inner_state(): String { => $^ }
            get_inner_count(): int { => $^ }
            get_k(): int { => $^ }
        }
    domain:
        k: int = 0
        inner = @@Inner()
}

func fmtProbe(o):
    return o.get_outer_state() + "/" + o.get_inner_state() + "/" + str(o.get_inner_count()) + "/" + str(o.get_k())

func must(label, o, expected):
    var actual = fmtProbe(o)
    assert(actual == expected, "FAIL " + label + ": " + actual + " expected " + expected)

func _init():
    var o1 = @@Outer()
    var o2 = @@Outer()

    o1.cycle_inner()
    o1.cycle_inner()
    o1.cycle_inner()
    must("o1 pre", o1, "Idle/B/2/0")

    o2.tick()
    o2.tick()
    o2.tick()
    must("o2 pre", o2, "Active/A/0/2")

    var snap1 = o1.save_state()
    var snap2 = o2.save_state()

    var r2 = @@Outer()


    r2.restore_state(snap2)
    var r1 = @@Outer()

    r1.restore_state(snap1)

    must("r1 restored", r1, "Idle/B/2/0")
    must("r2 restored", r2, "Active/A/0/2")

    r1.cycle_inner()
    must("r1 after mut", r1, "Idle/A/2/0")
    must("r2 after r1 mut", r2, "Active/A/0/2")

    r2.cycle_inner()
    must("r1 after r2 mut", r1, "Idle/A/2/0")
    must("r2 after r2 mut", r2, "Active/B/1/2")

    print("PASS: 87_persist_multi_instance")
    quit()

@@target cpp_17

#include <iostream>
#include <cmath>

@@system FloatStateArg {
    interface:
        configure(rate: float)
        scale(v: float): float

    machine:
        $Idle {
            configure(rate: double) {
                -> $Active(rate)
            }
            scale(v: double): double {
                @@:(v)
            }
        }

        $Active => $Frame(rate: double) {
            configure(rate: double) {
                -> $Active(rate)
            }
            scale(v: double): double {
                => $^
            }
        }

        $Frame {
            scale(v: double): double {
                @@:(v * rate)
            }
        }
    domain:
        n : int = 0
}

int main() {
    FloatStateArg s;
    if (std::abs(s.scale(2.0) - 2.0) > 1e-9) { std::cout << "FAIL idle" << std::endl; return 1; }
    s.configure(0.5);
    if (std::abs(s.scale(10.0) - 5.0) > 1e-9) { std::cout << "FAIL 0.5" << std::endl; return 1; }
    s.configure(2.5);
    if (std::abs(s.scale(4.0) - 10.0) > 1e-9) { std::cout << "FAIL 2.5" << std::endl; return 1; }
    std::cout << "PASS: 68_hsm_float_state_args" << std::endl;
    return 0;
}

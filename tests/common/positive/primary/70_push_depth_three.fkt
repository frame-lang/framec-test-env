@@[target("kotlin")]

@@system PushDeep {
    interface:
        descend()
        ascend()
        get_depth(): int

    machine:
        $Idle {
            descend() {
                push$
                -> $Modal1
            }
            get_depth(): int {
                @@:(0)
            }
        }

        $Modal1 {
            descend() {
                push$
                -> $Modal2
            }
            ascend() {
                -> pop$
            }
            get_depth(): int {
                @@:(1)
            }
        }

        $Modal2 {
            descend() {
                push$
                -> $Modal3
            }
            ascend() {
                -> pop$
            }
            get_depth(): int {
                @@:(2)
            }
        }

        $Modal3 {
            ascend() {
                -> pop$
            }
            get_depth(): int {
                @@:(3)
            }
        }
    domain:
        n : int = 0
}

fun main() {
    val s = @@PushDeep()
    if (s.get_depth() != 0) { println("FAIL idle"); kotlin.system.exitProcess(1) }
    s.descend()
    if (s.get_depth() != 1) { println("FAIL d1"); kotlin.system.exitProcess(1) }
    s.descend()
    if (s.get_depth() != 2) { println("FAIL d2"); kotlin.system.exitProcess(1) }
    s.descend()
    if (s.get_depth() != 3) { println("FAIL d3"); kotlin.system.exitProcess(1) }
    s.ascend()
    if (s.get_depth() != 2) { println("FAIL a1"); kotlin.system.exitProcess(1) }
    s.ascend()
    if (s.get_depth() != 1) { println("FAIL a2"); kotlin.system.exitProcess(1) }
    s.ascend()
    if (s.get_depth() != 0) { println("FAIL a3"); kotlin.system.exitProcess(1) }
    println("PASS: 70_push_depth_three")
}

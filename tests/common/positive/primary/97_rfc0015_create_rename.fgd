@@[target("gdscript")]

extends SceneTree

@@[create(make)]
@@system Counter(seed: int) {
    interface:
        bump()
        get_value(): int

    machine:
        $A {
            bump() { self.count = self.count + 1 }
            get_value(): int { @@:(self.count) }
        }

    domain:
        seed: int = seed
        count: int = 0
}

func _init():
    var c1 = @@Counter(42)
    c1.bump()
    c1.bump()
    if c1.get_value() != 2:
        print("FAIL: via @@Counter() expected 2, got " + str(c1.get_value()))
        quit()

    var c2 = Counter.make(99)
    c2.bump()
    if c2.get_value() != 1:
        print("FAIL: via Counter.make expected 1, got " + str(c2.get_value()))
        quit()

    print("PASS: rfc0015_create_rename")
    quit()

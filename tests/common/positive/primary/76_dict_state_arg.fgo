@@[target("go")]

package main

import (
    "fmt"
    "os"
)

@@system DictStateArg {
    interface:
        Configure(m: map[string]int)
        GetV(key: string): int
        Size(): int

    machine:
        $Idle {
            Configure(m: map[string]int) { -> $Active(m) }
            GetV(key: string): int { @@:(-1); return; }
            Size(): int { @@:(0); return; }
        }
        $Active(m: map[string]int) {
            Configure(m: map[string]int) { -> $Active(m) }
            GetV(key: string): int { if v, ok := m[key]; ok { @@:(v); return }; @@:(-1); return; }
            Size(): int { @@:(len(m)); return; }
        }
    domain:
        n: int = 0
}

func main() {
    s := @@DictStateArg()
    if s.GetV("a") != -1 { fmt.Println("FAIL idle"); os.Exit(1) }
    if s.Size() != 0 { fmt.Println("FAIL idle size"); os.Exit(1) }
    s.Configure(map[string]int{"a": 10, "b": 20})
    if s.GetV("a") != 10 { fmt.Println("FAIL a"); os.Exit(1) }
    if s.GetV("b") != 20 { fmt.Println("FAIL b"); os.Exit(1) }
    if s.Size() != 2 { fmt.Println("FAIL size"); os.Exit(1) }
    s.Configure(map[string]int{"x": 99})
    if s.GetV("x") != 99 { fmt.Println("FAIL x"); os.Exit(1) }
    if s.Size() != 1 { fmt.Println("FAIL size2"); os.Exit(1) }
    fmt.Println("PASS: 76_dict_state_arg")
}

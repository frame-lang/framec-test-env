@@target erlang
@@system ForwardEnterFirst {
    interface:
        parentEvent()
        getLog(): str
    machine:
        $Child => $Parent {
            $>() { self.log = self.log ++ ",child_enter" }
            getLog(): str {
                @@:(self.log)
            }
        }
        $Parent {
            $>() { self.log = self.log ++ ",parent_enter" }
            parentEvent() {
                self.log = self.log ++ ",parent_event"
            }
            getLog(): str {
                @@:(self.log)
            }
        }
    domain:
        log = "init"
}

@@[target("erlang")]
@@system ForwardEnterFirst {
    interface:
        process()
        getLog(): str

    machine:
        $Idle {
            process() {
                -> => $Working
            }
            getLog(): str {
                @@:(self.log)
            }
        }
        $Working {
            $>() { self.log = self.log ++ ",working_enter" }
            process() {
                self.log = self.log ++ ",working_process"
            }
            getLog(): str {
                @@:(self.log)
            }
        }
    domain:
        log = "init"
}

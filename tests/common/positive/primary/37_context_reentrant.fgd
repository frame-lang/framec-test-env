@@target gdscript
extends SceneTree

# Test: Context Stack Reentrancy
# Validates that nested interface calls maintain separate contexts

@@system ContextReentrantTest {
    interface:
        outer(x: int): String
        inner(y: int): String
        deeply_nested(z: int): String
        get_both(a: int, b: int): String

    machine:
        $Ready {
            outer(x: int): String {
                # Set our return before calling inner
                @@:("outer_initial")

                # Call inner - should NOT clobber our return
                var inner_result = self.inner(@@:params["x"] * 10)

                # Our return should still be accessible
                # Update it with combined result
                @@:("outer:" + str(@@:params["x"]) + ",inner:" + inner_result)
            }

            inner(y: int): String {
                # Inner has its own context
                # @@:params["y"] should be inner's param, not outer's
                @@:(str(@@:params["y"]))
            }

            deeply_nested(z: int): String {
                # 3 levels deep
                var outer_result = self.outer(@@:params["z"])
                @@:("deep:" + str(@@:params["z"]) + "," + outer_result)
            }

            get_both(a: int, b: int): String {
                # Test that we can access multiple params
                var result_a = self.inner(@@:params["a"])
                var result_b = self.inner(@@:params["b"])
                # After both inner calls, @@:params["a"] and @@:params["b"] should still be our params
                @@:("a=" + str(@@:params["a"]) + ",b=" + str(@@:params["b"]) + ",results=" + result_a + "+" + result_b)
            }
        }
}

func main():
    print("=== Test 37: Context Reentrant ===")
    var s = @@ContextReentrantTest()

    # Test 1: Simple nesting - outer calls inner
    var result = s.outer(5)
    var expected = "outer:5,inner:50"
    assert(result == expected, "Expected '" + str(expected) + "', got '" + str(result) + "'")
    print("1. outer(5) = '" + str(result) + "'")

    # Test 2: Inner alone
    result = s.inner(42)
    assert(result == "42", "Expected '42', got '" + str(result) + "'")
    print("2. inner(42) = '" + str(result) + "'")

    # Test 3: Deep nesting (3 levels)
    result = s.deeply_nested(3)
    expected = "deep:3,outer:3,inner:30"
    assert(result == expected, "Expected '" + str(expected) + "', got '" + str(result) + "'")
    print("3. deeply_nested(3) = '" + str(result) + "'")

    # Test 4: Multiple inner calls, params preserved
    result = s.get_both(10, 20)
    expected = "a=10,b=20,results=10+20"
    assert(result == expected, "Expected '" + str(expected) + "', got '" + str(result) + "'")
    print("4. get_both(10, 20) = '" + str(result) + "'")

    print("PASS: Context reentrant works correctly")

func _init():
    main()
    quit()

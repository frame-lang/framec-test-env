@@[target("rust")]

// Test 40: HSM Parent State Variables
//
// This test validates that parent and child states in an HSM hierarchy
// maintain SEPARATE compartments with independent state variables.
//
// EXPECTED ARCHITECTURE:
// - Child has its own compartment with state_vars containing child_count
// - Parent has its own compartment with state_vars containing parent_count
// - When child forwards to parent, parent accesses ITS OWN compartment

@@system HSMParentStateVars {
    interface:
        get_child_count(): i32
        get_parent_count(): i32

    machine:
        $Child => $Parent {
            $.child_count: i32 = 0

            $>() {
                // RFC-0019: forward $> to $Parent so its state-var
                // initializer runs.
                => $^
            }

            get_child_count(): i32 {
                @@:($.child_count)
                return;
            }

            get_parent_count(): i32 {
                => $^
            }
        }

        $Parent {
            $.parent_count: i32 = 100

            get_parent_count(): i32 {
                @@:($.parent_count)
                return;
            }
        }
}

fn main() {
    println!("=== Test 40: HSM Parent State Variables ===");
    let mut s = @@HSMParentStateVars();

    let child_count = s.get_child_count();
    assert!(child_count == 0, "Expected child_count=0, got {}", child_count);
    println!("Child count: {}", child_count);

    let parent_count = s.get_parent_count();
    assert!(parent_count == 100, "Expected parent_count=100, got {}", parent_count);
    println!("Parent count: {}", parent_count);

    println!("PASS: HSM parent state variables work correctly");
}

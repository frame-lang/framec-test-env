@@[target("cpp_17")]

#include <iostream>
#include <string>
#include <cstdlib>

@@system HsmIfStateArgs {
    interface:
        enter_active(t: int)
        classify(v: int): int

    machine:
        $Idle {
            enter_active(t: int) {
                -> $Active(t)
            }
            classify(v: int): int {
                @@:(-1)
            }
        }

        $Active => $Frame(threshold: int) {
            enter_active(t: int) {
                -> $Active(t)
            }
            classify(v: int): int {
                if (v > threshold) {
                    @@:(1)
                } else {
                    @@:(0)
                }
            }
        }

        $Frame {
        }
    domain:
        n : int = 0
}

int main() {
    std::cout << "=== Test 62: HSM × if × state-args (C++) ===" << std::endl;
    HsmIfStateArgs s;

    int pre = s.classify(5);
    if (pre != -1) { std::cout << "FAIL: pre " << pre << std::endl; return 1; }
    std::cout << "1. Idle classify(5) = " << pre << std::endl;

    s.enter_active(10);
    int under = s.classify(5);
    if (under != 0) { std::cout << "FAIL: under " << under << std::endl; return 1; }
    std::cout << "2. classify(5) with threshold=10 -> " << under << std::endl;

    int over = s.classify(15);
    if (over != 1) { std::cout << "FAIL: over " << over << std::endl; return 1; }
    std::cout << "3. classify(15) with threshold=10 -> " << over << std::endl;

    int eq = s.classify(10);
    if (eq != 0) { std::cout << "FAIL: eq " << eq << std::endl; return 1; }
    std::cout << "4. classify(10) with threshold=10 -> " << eq << std::endl;

    s.enter_active(50);
    int newUnder = s.classify(15);
    if (newUnder != 0) { std::cout << "FAIL: newUnder " << newUnder << std::endl; return 1; }
    std::cout << "5. classify(15) with threshold=50 -> " << newUnder << std::endl;

    std::cout << "PASS: 62_hsm_if_state_args" << std::endl;
    return 0;
}

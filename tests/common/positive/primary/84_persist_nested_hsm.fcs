@@target csharp

using System;

@@[persist]
@@system Inner {
    interface:
        cycle()
        get_state(): string
        get_count(): int

    machine:
        $A {
            cycle() { this.n = this.n + 1; -> $B }
            get_state(): string { @@:("A") }
            get_count(): int { @@:(this.n) }
        }
        $B => $A {
            cycle() { -> $A }
            get_state(): string { @@:("B") }
            get_count(): int { => $^ }
        }
    domain:
        n: int = 0
}

@@system Outer {
    interface:
        tick()
        cycle_inner()
        get_outer_state(): string
        get_inner_state(): string
        get_inner_count(): int
        get_k(): int

    machine:
        $Idle {
            tick() { this.k = this.k + 1; -> $Active }
            cycle_inner() { this.inner.cycle(); }
            get_outer_state(): string { @@:("Idle") }
            get_inner_state(): string { @@:(this.inner.get_state()) }
            get_inner_count(): int { @@:(this.inner.get_count()) }
            get_k(): int { @@:(this.k) }
        }
        $Active => $Idle {
            tick() { -> $Idle }
            get_outer_state(): string { @@:("Active") }
            cycle_inner() { => $^ }
            get_inner_state(): string { => $^ }
            get_inner_count(): int { => $^ }
            get_k(): int { => $^ }
        }
    domain:
        k: int = 0
        inner: Inner = @@Inner()
}

class Program {
    static string fmt(Outer o) => $"{o.get_outer_state()}/{o.get_inner_state()}/{o.get_inner_count()}/{o.get_k()}";
    static void Must(string label, Outer o, string expected) {
        var actual = fmt(o);
        if (actual != expected) throw new Exception($"FAIL {label}: {actual} expected {expected}");
    }
    public static void Main(string[] args) {
        var o = new Outer();
        Must("T0 fresh", o, "Idle/A/0/0");
        var snap0 = o.SaveState();
        var r0 = Outer.RestoreState(snap0);
        Must("T0 restored", r0, "Idle/A/0/0");

        o.tick();
        Must("T1", o, "Active/A/0/1");
        var snap1 = o.SaveState();
        var r1 = Outer.RestoreState(snap1);
        Must("T1 restored", r1, "Active/A/0/1");

        o.cycle_inner();
        Must("T2", o, "Active/B/1/1");
        var snap2 = o.SaveState();
        var r2 = Outer.RestoreState(snap2);
        Must("T2 restored", r2, "Active/B/1/1");

        var snap2b = r2.SaveState();
        var r2b = Outer.RestoreState(snap2b);
        if (fmt(r2b) != fmt(r2)) throw new Exception($"FAIL idempotence: {fmt(r2b)} != {fmt(r2)}");

        r2.cycle_inner();
        Must("continue1", r2, "Active/A/1/1");
        r2.tick();
        Must("continue2", r2, "Idle/A/1/1");
        r2.tick();
        Must("continue3", r2, "Active/A/1/2");

        Console.WriteLine("PASS: 84_persist_nested_hsm");
    }
}

@@[target("ruby")]

# Test: Interface method return_init
# Validates that interface methods can have default return values
# Syntax: method(): type = "default_value"

@@system ReturnInitTest {
    interface:
        get_status(): str = "unknown"
        get_count(): int = 0
        get_flag(): bool = false
        trigger()

    machine:
        $Start {
            $>() {
                # pass  # Start state enter
            }
            get_status() {
                # pass  # Don't set return - should use default "unknown"
            }
            get_count() {
                # pass  # Don't set return - should use default 0
            }
            get_flag() {
                # pass  # Don't set return - should use default false
            }
            trigger() {
                -> $Active
            }
        }

        $Active {
            $>() {
                # pass  # Active state enter
            }
            get_status() {
                @@:("active")
            }
            get_count() {
                @@:(42)
            }
            get_flag() {
                @@:(true)
            }
            trigger() {
                -> $Start
            }
        }
}

puts("TAP version 14")
puts("1..6")

s = @@ReturnInitTest()

# Test 1: Default string return
if s.get_status() == "unknown"
    puts("ok 1 - default string return is 'unknown'")
else
    puts("not ok 1 - default string return is 'unknown' # got #{s.get_status()}")
end

# Test 2: Default int return
if s.get_count() == 0
    puts("ok 2 - default int return is 0")
else
    puts("not ok 2 - default int return is 0 # got #{s.get_count()}")
end

# Test 3: Default bool return
if s.get_flag() == false
    puts("ok 3 - default bool return is false")
else
    puts("not ok 3 - default bool return is false # got #{s.get_flag()}")
end

# Transition to Active state
s.trigger()

# Test 4: Explicit string return overrides default
if s.get_status() == "active"
    puts("ok 4 - explicit return overrides default string")
else
    puts("not ok 4 - explicit return overrides default string # got #{s.get_status()}")
end

# Test 5: Explicit int return overrides default
if s.get_count() == 42
    puts("ok 5 - explicit return overrides default int")
else
    puts("not ok 5 - explicit return overrides default int # got #{s.get_count()}")
end

# Test 6: Explicit bool return overrides default
if s.get_flag() == true
    puts("ok 6 - explicit return overrides default bool")
else
    puts("not ok 6 - explicit return overrides default bool # got #{s.get_flag()}")
end

puts("# PASS - return_init provides default return values")

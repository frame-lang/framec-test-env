@@[target("c")]

#include <stdio.h>
#include <stdlib.h>
#include <string.h>
#include <cjson/cJSON.h>

@@[persist(char*)]
@@[save(save_state)]
@@[load(restore_state)]
@@system Inner {
    interface:
        cycle()
        get_state(): const char*
        get_count(): int

    machine:
        $A {
            cycle() { self->n = self->n + 1; -> $B }
            get_state(): const char* { @@:("A") }
            get_count(): int { @@:(self->n) }
        }
        $B => $A {
            cycle() { -> $A }
            get_state(): const char* { @@:("B") }
            get_count(): int { => $^ }
        }
    domain:
        n: int = 0
}

@@system Mid {
    operations:
        @@[save]
        save_state(): char* {}

        @@[load]
        restore_state(data: char*) {}

    interface:
        cycle()
        cycle_inner()
        get_state(): const char*
        get_inner_state(): const char*
        get_inner_count(): int
        get_m(): int

    machine:
        $P {
            cycle() { self->m = self->m + 1; -> $Q }
            cycle_inner() { Inner_cycle(self->inner); }
            get_state(): const char* { @@:("P") }
            get_inner_state(): const char* { @@:(Inner_get_state(self->inner)) }
            get_inner_count(): int { @@:(Inner_get_count(self->inner)) }
            get_m(): int { @@:(self->m) }
        }
        $Q => $P {
            cycle() { -> $P }
            get_state(): const char* { @@:("Q") }
            cycle_inner() { => $^ }
            get_inner_state(): const char* { => $^ }
            get_inner_count(): int { => $^ }
            get_m(): int { => $^ }
        }
    domain:
        m: int = 0
        inner: Inner* = @@Inner()
}

@@[main]
@@system Outer {
    operations:
        @@[save]
        save_state(): char* {}

        @@[load]
        restore_state(data: char*) {}

    interface:
        tick()
        cycle_mid()
        cycle_inner()
        get_outer_state(): const char*
        get_mid_state(): const char*
        get_inner_state(): const char*
        get_inner_count(): int
        get_m(): int
        get_k(): int

    machine:
        $Idle {
            tick() { self->k = self->k + 1; -> $Active }
            cycle_mid() { Mid_cycle(self->mid); }
            cycle_inner() { Mid_cycle_inner(self->mid); }
            get_outer_state(): const char* { @@:("Idle") }
            get_mid_state(): const char* { @@:(Mid_get_state(self->mid)) }
            get_inner_state(): const char* { @@:(Mid_get_inner_state(self->mid)) }
            get_inner_count(): int { @@:(Mid_get_inner_count(self->mid)) }
            get_m(): int { @@:(Mid_get_m(self->mid)) }
            get_k(): int { @@:(self->k) }
        }
        $Active => $Idle {
            tick() { -> $Idle }
            get_outer_state(): const char* { @@:("Active") }
            cycle_mid() { => $^ }
            cycle_inner() { => $^ }
            get_mid_state(): const char* { => $^ }
            get_inner_state(): const char* { => $^ }
            get_inner_count(): int { => $^ }
            get_m(): int { => $^ }
            get_k(): int { => $^ }
        }
    domain:
        k: int = 0
        mid: Mid* = @@Mid()
}

static int eq6(Outer* o, const char* os, const char* ms, const char* is, int ic, int m, int k) {
    return strcmp(Outer_get_outer_state(o), os) == 0
        && strcmp(Outer_get_mid_state(o), ms) == 0
        && strcmp(Outer_get_inner_state(o), is) == 0
        && Outer_get_inner_count(o) == ic
        && Outer_get_m(o) == m
        && Outer_get_k(o) == k;
}

#define MUST(label, o, os, ms, is, ic, m, k) \
    if (!eq6(o, os, ms, is, ic, m, k)) { \
        printf("FAIL %s: %s/%s/%s/%d/%d/%d\n", label, Outer_get_outer_state(o), Outer_get_mid_state(o), Outer_get_inner_state(o), Outer_get_inner_count(o), Outer_get_m(o), Outer_get_k(o)); \
        return 1; \
    }

int main() {
    Outer* o = Outer_new();
    MUST("T0", o, "Idle", "P", "A", 0, 0, 0);
    char* snap0 = Outer_save_state(o);
    Outer* r0 = @@Outer();

    Outer_restore_state(r0, snap0);
    MUST("T0 restored", r0, "Idle", "P", "A", 0, 0, 0);
    free(snap0);

    Outer_tick(o);
    MUST("T1", o, "Active", "P", "A", 0, 0, 1);
    char* snap1 = Outer_save_state(o);
    Outer* r1 = @@Outer();

    Outer_restore_state(r1, snap1);
    MUST("T1 restored", r1, "Active", "P", "A", 0, 0, 1);
    free(snap1);

    Outer_cycle_mid(o);
    Outer_cycle_inner(o);
    MUST("T2", o, "Active", "Q", "B", 1, 1, 1);
    char* snap2 = Outer_save_state(o);
    Outer* r2 = @@Outer();

    Outer_restore_state(r2, snap2);
    MUST("T2 restored", r2, "Active", "Q", "B", 1, 1, 1);
    free(snap2);

    Outer_cycle_inner(r2);
    MUST("continue1", r2, "Active", "Q", "A", 1, 1, 1);
    Outer_cycle_mid(r2);
    MUST("continue2", r2, "Active", "P", "A", 1, 1, 1);
    Outer_tick(r2);
    MUST("continue3", r2, "Idle", "P", "A", 1, 1, 1);
    Outer_tick(r2);
    MUST("continue4", r2, "Active", "P", "A", 1, 1, 2);

    printf("PASS: 85_persist_three_level_nested\n");
    return 0;
}

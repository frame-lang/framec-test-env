@@target dart
@@system StackOps {
    interface:
        push_and_go()
        pop_back()
        do_work(): String
        get_state(): String

    machine:
        $Main {
            push_and_go() {
                print("Pushing Main to stack, going to Sub");
                push$
                -> $Sub
            }

            pop_back() {
                print("Cannot pop - nothing on stack in Main");
            }

            do_work(): String {
                @@:("Working in Main")
                return;
            }

            get_state(): String {
                @@:("Main")
                return;
            }
        }

        $Sub {
            push_and_go() {
                print("Already in Sub");
            }

            pop_back() {
                print("Popping back to previous state");
                -> pop$
            }

            do_work(): String {
                @@:("Working in Sub")
                return;
            }

            get_state(): String {
                @@:("Sub")
                return;
            }
        }
}

void main() {
    print("== Test 09: Stack Push/Pop ==");
    final s = @@StackOps();

    // Initial state should be Main
    var state = s.get_state();
    if (state != "Main") {
        throw Exception("Expected 'Main', got '${state}'");
    }
    print("Initial state: ${state}");

    // Do work in Main
    var work = s.do_work();
    if (work != "Working in Main") {
        throw Exception("Expected 'Working in Main', got '${work}'");
    }
    print("do_work(): ${work}");

    // Push and go to Sub
    s.push_and_go();
    state = s.get_state();
    if (state != "Sub") {
        throw Exception("Expected 'Sub', got '${state}'");
    }
    print("After push_and_go(): ${state}");

    // Do work in Sub
    work = s.do_work();
    if (work != "Working in Sub") {
        throw Exception("Expected 'Working in Sub', got '${work}'");
    }
    print("do_work(): ${work}");

    // Pop back to Main
    s.pop_back();
    state = s.get_state();
    if (state != "Main") {
        throw Exception("Expected 'Main' after pop, got '${state}'");
    }
    print("After pop_back(): ${state}");

    print("PASS: Stack push/pop works correctly");
}


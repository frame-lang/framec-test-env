@@[target("csharp")]

using System;

@@[persist(string)]
@@[save(SaveState)]
@@[load(RestoreState)]
@@system PersistHsmStateArgs {
    interface:
        drive(p: int)
        get_x(): int

    machine:
        $Start {
            drive(p: int) {
                -> $Child(p)
            }
            get_x(): int {
                @@:(-1)
            }
        }

        $Child => $Parent(x: int) {
            drive(p: int) {
                -> $Child(p)
            }
            get_x(): int {
                @@:(x)
            }
        }

        $Parent {
        }
    domain:
        v : int = 0
}

class Program {
    static void Main(string[] args) {
        Console.WriteLine("=== Test 57: Persist HSM × State-Args Round-Trip (C#) ===");
        var s1 = new PersistHsmStateArgs();
        s1.drive(42);
        int pre = s1.get_x();
        if (pre != 42) { Console.WriteLine($"FAIL: pre {pre}"); Environment.Exit(1); }
        Console.WriteLine($"1. Pre-save x={pre}");

        var snap = s1.SaveState();
        var s2 = new PersistHsmStateArgs();

        s2.RestoreState(snap);
        int post = s2.get_x();
        if (post != 42) { Console.WriteLine($"FAIL: post {post}"); Environment.Exit(1); }
        Console.WriteLine($"2. Post-restore x={post}");

        s2.drive(99);
        int post2 = s2.get_x();
        if (post2 != 99) { Console.WriteLine($"FAIL: post2 {post2}"); Environment.Exit(1); }
        Console.WriteLine($"3. Post-restore-drive x={post2}");

        Console.WriteLine("PASS: 57_persist_hsm_state_args");
    }
}

@@[target("typescript")]

@@[persist(string)]
@@[save(saveState)]
@@[load(restoreState)]
@@system PersistDict {
    interface:
        configure(m: Record<string, number>)
        get_v(key: string): number

    machine:
        $Idle {
            configure(m: Record<string, number>) { -> $Active(m) }
            get_v(key: string): number { @@:(-1) }
        }
        $Active(m: Record<string, number>) {
            configure(m: Record<string, number>) { -> $Active(m) }
            get_v(key: string): number { @@:(m[key] !== undefined ? m[key] : -1) }
        }
    domain:
        n: number = 0
}

const s1 = new PersistDict();
s1.configure({"a": 10, "b": 20});
if (s1.get_v("a") !== 10) { console.log("FAIL pre"); process.exit(1); }
const snap = s1.saveState();
const s2 = @@PersistDict();

s2.restoreState(snap);
if (s2.get_v("a") !== 10) { console.log("FAIL post a"); process.exit(1); }
if (s2.get_v("b") !== 20) { console.log("FAIL post b"); process.exit(1); }
console.log("PASS: 77_persist_dict_state_arg");

@@[target("swift")]

import Foundation

@@system Demo {
    interface:
        common(): String
        @@[target("python_3")] only_py(): String
        @@[target("swift")] only_swift(): String

    machine:
        $S {
            common(): String { @@:("common") }
            @@[target("python_3")] only_py(): String { @@:("only_py_present") }
            @@[target("swift")] only_swift(): String { @@:("only_swift_present") }
        }
}

let d = @@Demo()
if d.common() != "common" { print("FAIL common: \(d.common())"); exit(1) }
if d.only_swift() != "only_swift_present" { print("FAIL only_swift: \(d.only_swift())"); exit(1) }
print("PASS: 89_attribute_per_item")

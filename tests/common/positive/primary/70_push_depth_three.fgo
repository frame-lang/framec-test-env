@@[target("go")]

package main

import (
	"fmt"
	"os"
)

@@system PushDeep {
    interface:
        Descend()
        Ascend()
        GetDepth(): int

    machine:
        $Idle {
            Descend() {
                push$
                -> $Modal1
            }
            GetDepth(): int {
                @@:(0)
                return;
            }
        }

        $Modal1 {
            Descend() {
                push$
                -> $Modal2
            }
            Ascend() {
                -> pop$
            }
            GetDepth(): int {
                @@:(1)
                return;
            }
        }

        $Modal2 {
            Descend() {
                push$
                -> $Modal3
            }
            Ascend() {
                -> pop$
            }
            GetDepth(): int {
                @@:(2)
                return;
            }
        }

        $Modal3 {
            Ascend() {
                -> pop$
            }
            GetDepth(): int {
                @@:(3)
                return;
            }
        }
    domain:
        n: int = 0
}

func main() {
    s := NewPushDeep()
    if s.GetDepth() != 0 { fmt.Println("FAIL idle"); os.Exit(1) }
    s.Descend()
    if s.GetDepth() != 1 { fmt.Println("FAIL d1"); os.Exit(1) }
    s.Descend()
    if s.GetDepth() != 2 { fmt.Println("FAIL d2"); os.Exit(1) }
    s.Descend()
    if s.GetDepth() != 3 { fmt.Println("FAIL d3"); os.Exit(1) }
    s.Ascend()
    if s.GetDepth() != 2 { fmt.Println("FAIL a1"); os.Exit(1) }
    s.Ascend()
    if s.GetDepth() != 1 { fmt.Println("FAIL a2"); os.Exit(1) }
    s.Ascend()
    if s.GetDepth() != 0 { fmt.Println("FAIL a3"); os.Exit(1) }
    fmt.Println("PASS: 70_push_depth_three")
}

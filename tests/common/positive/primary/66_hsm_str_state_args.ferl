@@[target("erlang")]
@@system StrStateArg {
    interface:
        configure(label: str)
        identify(): str
    machine:
        $Idle {
            configure(label: str) {
                -> $Active(label)
            }
            identify(): str {
                @@:("anonymous")
            }
        }
        $Active => $Frame(label: str) {
            configure(label: str) {
                -> $Active(label)
            }
            identify(): str {
                => $^
            }
        }
        $Frame {
            identify(): str {
                @@:(Label)
            }
        }
    domain:
        n = 0
}

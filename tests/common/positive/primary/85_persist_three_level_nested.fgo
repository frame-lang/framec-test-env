@@[target("go")]

package main

import (
    "encoding/json"
    "fmt"
    "os"
)

var _ = json.Marshal

@@[persist(string)]
@@[save(SaveState)]
@@[load(LoadState)]
@@system Inner {
    interface:
        cycle()
        get_state(): string
        get_count(): int

    machine:
        $A {
            cycle() { s.n = s.n + 1; -> $B }
            get_state(): string { @@:("A") }
            get_count(): int { @@:(s.n) }
        }
        $B => $A {
            cycle() { -> $A }
            get_state(): string { @@:("B") }
            get_count(): int { => $^ }
        }
    domain:
        n: int = 0
}@@[persist(string)]
@@[save(SaveState)]
@@[load(LoadState)]


@@system Mid {
    interface:
        cycle()
        cycle_inner()
        get_state(): string
        get_inner_state(): string
        get_inner_count(): int
        get_m(): int

    machine:
        $P {
            cycle() { s.m = s.m + 1; -> $Q }
            cycle_inner() { s.inner.Cycle() }
            get_state(): string { @@:("P") }
            get_inner_state(): string { @@:(s.inner.Get_state()) }
            get_inner_count(): int { @@:(s.inner.Get_count()) }
            get_m(): int { @@:(s.m) }
        }
        $Q => $P {
            cycle() { -> $P }
            get_state(): string { @@:("Q") }
            cycle_inner() { => $^ }
            get_inner_state(): string { => $^ }
            get_inner_count(): int { => $^ }
            get_m(): int { => $^ }
        }
    domain:
        m: int = 0
        inner: *Inner = @@Inner()
}@@[persist(string)]
@@[save(SaveState)]
@@[load(LoadState)]


@@[main]
@@system Outer {
    interface:
        tick()
        cycle_mid()
        cycle_inner()
        get_outer_state(): string
        get_mid_state(): string
        get_inner_state(): string
        get_inner_count(): int
        get_m(): int
        get_k(): int

    machine:
        $Idle {
            tick() { s.k = s.k + 1; -> $Active }
            cycle_mid() { s.mid.Cycle() }
            cycle_inner() { s.mid.Cycle_inner() }
            get_outer_state(): string { @@:("Idle") }
            get_mid_state(): string { @@:(s.mid.Get_state()) }
            get_inner_state(): string { @@:(s.mid.Get_inner_state()) }
            get_inner_count(): int { @@:(s.mid.Get_inner_count()) }
            get_m(): int { @@:(s.mid.Get_m()) }
            get_k(): int { @@:(s.k) }
        }
        $Active => $Idle {
            tick() { -> $Idle }
            get_outer_state(): string { @@:("Active") }
            cycle_mid() { => $^ }
            cycle_inner() { => $^ }
            get_mid_state(): string { => $^ }
            get_inner_state(): string { => $^ }
            get_inner_count(): int { => $^ }
            get_m(): int { => $^ }
            get_k(): int { => $^ }
        }
    domain:
        k: int = 0
        mid: *Mid = @@Mid()
}

func formatProbe(o *Outer) string {
    return fmt.Sprintf("%s/%s/%s/%d/%d/%d",
        o.Get_outer_state(), o.Get_mid_state(), o.Get_inner_state(),
        o.Get_inner_count(), o.Get_m(), o.Get_k())
}

func must(label string, o *Outer, expected string) {
    actual := formatProbe(o)
    if actual != expected {
        fmt.Printf("FAIL %s: %s expected %s\n", label, actual, expected)
        os.Exit(1)
    }
}

func main() {
    o := NewOuter()
    must("T0 fresh", o, "Idle/P/A/0/0/0")
    snap0 := o.SaveState()
    r0 := NewOuter()

    r0.LoadState(snap0)
    must("T0 restored", r0, "Idle/P/A/0/0/0")

    o.Tick()
    must("T1", o, "Active/P/A/0/0/1")
    snap1 := o.SaveState()
    r1 := NewOuter()

    r1.LoadState(snap1)
    must("T1 restored", r1, "Active/P/A/0/0/1")

    o.Cycle_mid()
    o.Cycle_inner()
    must("T2", o, "Active/Q/B/1/1/1")
    snap2 := o.SaveState()
    r2 := NewOuter()

    r2.LoadState(snap2)
    must("T2 restored", r2, "Active/Q/B/1/1/1")

    snap2b := r2.SaveState()
    r2b := NewOuter()

    r2b.LoadState(snap2b)
    if formatProbe(r2b) != formatProbe(r2) {
        fmt.Printf("FAIL idempotence: %s != %s\n", formatProbe(r2b), formatProbe(r2))
        os.Exit(1)
    }

    r2.Cycle_inner()
    must("continue1", r2, "Active/Q/A/1/1/1")
    r2.Cycle_mid()
    must("continue2", r2, "Active/P/A/1/1/1")
    r2.Tick()
    must("continue3", r2, "Idle/P/A/1/1/1")
    r2.Tick()
    must("continue4", r2, "Active/P/A/1/1/2")

    fmt.Println("PASS: 85_persist_three_level_nested")
}

@@[target("typescript")]

@@system HsmIfStateArgs {
    interface:
        enter_active(t: int)
        classify(v: int): int

    machine:
        $Idle {
            enter_active(t: number) {
                -> $Active(t)
            }
            classify(v: number): number {
                @@:(-1)
                return
            }
        }

        $Active => $Frame(threshold: number) {
            enter_active(t: number) {
                -> $Active(t)
            }
            classify(v: number): number {
                if (v > threshold) {
                    @@:(1)
                    return
                } else {
                    @@:(0)
                    return
                }
            }
        }

        $Frame {
        }
    domain:
        n: number = 0
}

console.log("=== Test 62: HSM × if × state-args (TS) ===");
const s = new HsmIfStateArgs();

const pre = s.classify(5);
if (pre !== -1) { console.log("FAIL: pre " + pre); process.exit(1); }
console.log(`1. Idle classify(5) = ${pre}`);

s.enter_active(10);
const under = s.classify(5);
if (under !== 0) { console.log("FAIL: under " + under); process.exit(1); }
console.log(`2. classify(5) with threshold=10 → ${under}`);

const over = s.classify(15);
if (over !== 1) { console.log("FAIL: over " + over); process.exit(1); }
console.log(`3. classify(15) with threshold=10 → ${over}`);

const eq = s.classify(10);
if (eq !== 0) { console.log("FAIL: eq " + eq); process.exit(1); }
console.log(`4. classify(10) with threshold=10 → ${eq}`);

s.enter_active(50);
const newUnder = s.classify(15);
if (newUnder !== 0) { console.log("FAIL: newUnder " + newUnder); process.exit(1); }
console.log(`5. classify(15) with threshold=50 → ${newUnder}`);

console.log("PASS: 62_hsm_if_state_args");

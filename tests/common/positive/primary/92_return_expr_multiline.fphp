@@[target("php")]

@@system Test {
    interface:
        ready(): bool

    machine:
        $Active {
            ready(): bool {
                @@:($this->timer >= $this->threshold
                    && $this->count < $this->limit)
            }
        }
    domain:
        timer: int = 100
        threshold: int = 50
        count: int = 1
        limit: int = 5
}

$t = @@Test();
if ($t->ready() !== true) {
    echo "FAIL ready(): " . var_export($t->ready(), true) . "\n";
} else {
    echo "PASS: 92_return_expr_multiline\n";
}

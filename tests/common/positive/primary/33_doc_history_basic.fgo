@@[target("go")]

package main

import "fmt"
import "os"

@@system HistoryBasic {
    interface:
        GotoCFromA()
        GotoCFromB()
        GotoB()
        ReturnBack()
        GetState(): string

    machine:
        $A {
            GotoCFromA() {
                push$
                -> $C
            }
            GotoB() {
                -> $B
            }
            GetState(): string {
                @@:("A")
                return;
            }
        }

        $B {
            GotoCFromB() {
                push$
                -> $C
            }
            GetState(): string {
                @@:("B")
                return;
            }
        }

        $C {
            ReturnBack() {
                -> pop$
            }
            GetState(): string {
                @@:("C")
                return;
            }
        }
}

func main() {
	fmt.Println("=== Test 33: Doc History Basic ===")
	h := @@HistoryBasic()

	// Start in A
	if h.GetState() != "A" {
		fmt.Printf("FAIL: Expected 'A', got '%s'\n", h.GetState())
		os.Exit(1)
	}

	// Go to C from A (push A)
	h.GotoCFromA()
	if h.GetState() != "C" {
		fmt.Printf("FAIL: Expected 'C', got '%s'\n", h.GetState())
		os.Exit(1)
	}

	// Return back (pop to A)
	h.ReturnBack()
	if h.GetState() != "A" {
		fmt.Printf("FAIL: Expected 'A' after pop, got '%s'\n", h.GetState())
		os.Exit(1)
	}

	// Now go to B
	h.GotoB()
	if h.GetState() != "B" {
		fmt.Printf("FAIL: Expected 'B', got '%s'\n", h.GetState())
		os.Exit(1)
	}

	// Go to C from B (push B)
	h.GotoCFromB()
	if h.GetState() != "C" {
		fmt.Printf("FAIL: Expected 'C', got '%s'\n", h.GetState())
		os.Exit(1)
	}

	// Return back (pop to B)
	h.ReturnBack()
	if h.GetState() != "B" {
		fmt.Printf("FAIL: Expected 'B' after pop, got '%s'\n", h.GetState())
		os.Exit(1)
	}

	fmt.Println("PASS: History push/pop works correctly")
}

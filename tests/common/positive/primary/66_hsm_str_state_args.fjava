@@[target("java")]

@@system StrStateArg {
    interface:
        configure(label: str)
        identify(): str

    machine:
        $Idle {
            configure(label: str) {
                -> $Active(label)
            }
            identify(): str {
                @@:("anonymous")
            }
        }

        $Active => $Frame(label: str) {
            configure(label: str) {
                -> $Active(label)
            }
            identify(): str {
                => $^
            }
        }

        $Frame {
            identify(): str {
                @@:(label)
            }
        }
    domain:
        n : int = 0
}

class Main {
    public static void main(String[] args) {
        var s = new StrStateArg();
        if (!s.identify().equals("anonymous")) { System.out.println("FAIL idle"); System.exit(1); }
        s.configure("alice");
        if (!s.identify().equals("alice")) { System.out.println("FAIL alice"); System.exit(1); }
        s.configure("bob");
        if (!s.identify().equals("bob")) { System.out.println("FAIL bob"); System.exit(1); }
        System.out.println("PASS: 66_hsm_str_state_args");
    }
}

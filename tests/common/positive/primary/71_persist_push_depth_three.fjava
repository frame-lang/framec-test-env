@@[target("java")]

@@[persist(String)]
@@[save(save_state)]
@@[load(restore_state)]
@@system PPushDeep {
    interface:
        descend()
        ascend()
        get_depth(): int

    machine:
        $Idle {
            descend() { push$; -> $Modal1 }
            get_depth(): int { @@:(0) }
        }
        $Modal1 {
            descend() { push$; -> $Modal2 }
            ascend() { -> pop$ }
            get_depth(): int { @@:(1) }
        }
        $Modal2 {
            descend() { push$; -> $Modal3 }
            ascend() { -> pop$ }
            get_depth(): int { @@:(2) }
        }
        $Modal3 {
            ascend() { -> pop$ }
            get_depth(): int { @@:(3) }
        }
    domain: n : int = 0
}

class Main {
    public static void main(String[] args) {
        var s = @@PPushDeep();
        s.descend(); s.descend(); s.descend();
        if (s.get_depth() != 3) { System.out.println("FAIL pre"); System.exit(1); }
        String snap = s.save_state();
        var s2 = @@PPushDeep();

        s2.restore_state(snap);
        if (s2.get_depth() != 3) { System.out.println("FAIL post " + s2.get_depth()); System.exit(1); }
        s2.ascend();
        if (s2.get_depth() != 2) { System.out.println("FAIL a1"); System.exit(1); }
        s2.ascend();
        if (s2.get_depth() != 1) { System.out.println("FAIL a2"); System.exit(1); }
        s2.ascend();
        if (s2.get_depth() != 0) { System.out.println("FAIL a3"); System.exit(1); }
        System.out.println("PASS: 71_persist_push_depth_three");
    }
}

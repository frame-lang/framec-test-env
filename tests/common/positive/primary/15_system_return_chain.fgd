@@target gdscript
extends SceneTree

# Tests that @@:return follows "last writer wins" across transition lifecycle

@@system SystemReturnChainTest {
    interface:
        test_enter_sets(): String
        test_exit_then_enter(): String
        get_state(): String

    machine:
        $Start {
            test_enter_sets(): String {
                -> $EnterSetter
            }

            test_exit_then_enter(): String {
                -> $BothSet
            }

            get_state(): String {
                @@:("Start")
                return
            }

            <$() {
                # Exit handler sets initial value
                @@:return = "from_exit"
            }
        }

        $EnterSetter {
            $>() {
                # Enter handler sets return value
                @@:return = "from_enter"
            }

            get_state(): String {
                @@:("EnterSetter")
                return
            }
        }

        $BothSet {
            $>() {
                # Enter handler sets return - should overwrite exit's value
                @@:return = "enter_wins"
            }

            get_state(): String {
                @@:("BothSet")
                return
            }
        }
}

func main():
    print("=== Test 15: System Return Chain (Last Writer Wins) ===")

    # Test 1: Start exit + EnterSetter enter
    # Start's exit sets "from_exit", EnterSetter's enter sets "from_enter"
    # Enter should win (last writer)
    var s1 = @@SystemReturnChainTest()
    var result = s1.test_enter_sets()
    assert(result == "from_enter", "Expected 'from_enter', got '" + str(result) + "'")
    assert(s1.get_state() == "EnterSetter", "Expected state 'EnterSetter'")
    print("1. Exit set then enter set - enter wins: '" + str(result) + "'")

    # Test 2: Both handlers set, enter wins
    var s2 = @@SystemReturnChainTest()
    result = s2.test_exit_then_enter()
    assert(result == "enter_wins", "Expected 'enter_wins', got '" + str(result) + "'")
    assert(s2.get_state() == "BothSet", "Expected state 'BothSet'")
    print("2. Both set - enter wins: '" + str(result) + "'")

    print("PASS: System return chain (last writer wins) works correctly")

func _init():
    main()
    quit()

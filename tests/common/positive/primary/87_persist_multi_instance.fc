@@[target("c")]

#include <stdio.h>
#include <stdlib.h>
#include <string.h>
#include <cjson/cJSON.h>

@@[persist]
@@system Inner {
    interface:
        cycle()
        get_state(): const char*
        get_count(): int

    machine:
        $A {
            cycle() { self->n = self->n + 1; -> $B }
            get_state(): const char* { @@:("A") }
            get_count(): int { @@:(self->n) }
        }
        $B => $A {
            cycle() { -> $A }
            get_state(): const char* { @@:("B") }
            get_count(): int { => $^ }
        }
    domain:
        n: int = 0
}

@@[main]
@@system Outer {
    interface:
        tick()
        cycle_inner()
        get_outer_state(): const char*
        get_inner_state(): const char*
        get_inner_count(): int
        get_k(): int

    machine:
        $Idle {
            tick() { self->k = self->k + 1; -> $Active }
            cycle_inner() { Inner_cycle(self->inner); }
            get_outer_state(): const char* { @@:("Idle") }
            get_inner_state(): const char* { @@:(Inner_get_state(self->inner)) }
            get_inner_count(): int { @@:(Inner_get_count(self->inner)) }
            get_k(): int { @@:(self->k) }
        }
        $Active => $Idle {
            tick() { -> $Idle }
            get_outer_state(): const char* { @@:("Active") }
            cycle_inner() { => $^ }
            get_inner_state(): const char* { => $^ }
            get_inner_count(): int { => $^ }
            get_k(): int { => $^ }
        }
    domain:
        k: int = 0
        inner: Inner* = @@Inner()
}

static int eq4(Outer* o, const char* os, const char* is, int ic, int k) {
    return strcmp(Outer_get_outer_state(o), os) == 0
        && strcmp(Outer_get_inner_state(o), is) == 0
        && Outer_get_inner_count(o) == ic
        && Outer_get_k(o) == k;
}

#define MUST(label, o, os, is, ic, k) \
    if (!eq4(o, os, is, ic, k)) { \
        printf("FAIL %s: %s/%s/%d/%d\n", label, Outer_get_outer_state(o), Outer_get_inner_state(o), Outer_get_inner_count(o), Outer_get_k(o)); \
        return 1; \
    }

int main() {
    Outer* o1 = Outer_new();
    Outer* o2 = Outer_new();

    Outer_cycle_inner(o1);
    Outer_cycle_inner(o1);
    Outer_cycle_inner(o1);
    MUST("o1 pre", o1, "Idle", "B", 2, 0);

    Outer_tick(o2);
    Outer_tick(o2);
    Outer_tick(o2);
    MUST("o2 pre", o2, "Active", "A", 0, 2);

    char* snap1 = Outer_save_state(o1);
    char* snap2 = Outer_save_state(o2);

    Outer* r2 = Outer_restore_state(snap2);
    Outer* r1 = Outer_restore_state(snap1);

    MUST("r1 restored", r1, "Idle", "B", 2, 0);
    MUST("r2 restored", r2, "Active", "A", 0, 2);

    Outer_cycle_inner(r1);
    MUST("r1 after mut", r1, "Idle", "A", 2, 0);
    MUST("r2 after r1 mut", r2, "Active", "A", 0, 2);

    Outer_cycle_inner(r2);
    MUST("r1 after r2 mut", r1, "Idle", "A", 2, 0);
    MUST("r2 after r2 mut", r2, "Active", "B", 1, 2);

    free(snap1);
    free(snap2);
    printf("PASS: 87_persist_multi_instance\n");
    return 0;
}

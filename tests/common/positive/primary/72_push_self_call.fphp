<?php
@@[target("php")]

@@system PushSelf {
    interface:
        enter_modal()
        ping(): int
        exit_modal()
        compute(): int

    machine:
        $Idle {
            enter_modal() { push$; -> $Modal }
            ping(): int { @@:(0); return; }
            compute(): int { @@:(99); return; }
        }
        $Modal {
            ping(): int { @@:($this->compute() + 1); return; }
            compute(): int { @@:(10); return; }
            exit_modal() { -> pop$ }
        }
    domain: n: int = 0
}

$s = new PushSelf();
if ($s->ping() !== 0) { echo "FAIL idle\n"; exit(1); }
$s->enter_modal();
if ($s->ping() !== 11) { echo "FAIL modal " . $s->ping() . "\n"; exit(1); }
$s->exit_modal();
if ($s->ping() !== 0) { echo "FAIL back\n"; exit(1); }
echo "PASS: 72_push_self_call\n";

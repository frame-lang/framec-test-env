@@target kotlin

import kotlin.system.exitProcess

@@system TransitionEnterArgs {
    interface:
        start()
        get_log(): MutableList<Any?>

    machine:
        $Idle {
            start() {
                this.log.add("idle:start")
                -> ("from_idle", 42) $Active
            }

            get_log(): MutableList<Any?> {
                return this.log
            }
        }

        $Active {
            $>(source: String, value: Int) {
                this.log.add("active:enter:" + source + ":" + value)
            }

            start() {
                this.log.add("active:start")
            }

            get_log(): MutableList<Any?> {
                return this.log
            }
        }
    domain:
        log = mutableListOf<String>()
}

fun main() {
    println("=== Test 17: Transition Enter Args ===")
    val s = @@TransitionEnterArgs()

    // Initial state is Idle
    var log = s.get_log() as MutableList<*>
    if (log.size != 0) {
        println("FAIL: Expected empty log, got $log")
        exitProcess(1)
    }

    // Transition to Active with args
    s.start()
    log = s.get_log() as MutableList<*>
    if (!log.contains("idle:start")) {
        println("FAIL: Expected 'idle:start' in log, got $log")
        exitProcess(1)
    }
    if (!log.contains("active:enter:from_idle:42")) {
        println("FAIL: Expected 'active:enter:from_idle:42' in log, got $log")
        exitProcess(1)
    }
    println("Log after transition: $log")

    println("PASS: Transition enter args work correctly")
}

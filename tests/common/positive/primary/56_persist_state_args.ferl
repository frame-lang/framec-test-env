@@[target("erlang")]
@@[persist]
@@system PersistStateArgs {
    operations:
        @@[save]
        save_state() {}

        @@[load]
        load_state(data) {}

    interface:
        kick(v: int)
        getSlot(): int
    machine:
        $Idle {
            kick(v: int) {
                -> $Active(v)
            }
            getSlot(): int {
                @@:(-1)
            }
        }
        $Active(slot: int) {
            kick(v: int) {
                -> $Active(v)
            }
            getSlot(): int {
                @@:(slot)
            }
        }
    domain:
        v = 0
}

@@target rust

@@[persist]
@@system Inner {
    interface:
        cycle()
        get_state(): String
        get_count(): i32

    machine:
        $A {
            cycle() { self.n = self.n + 1; -> $B }
            get_state(): String { @@:("A".to_string()) }
            get_count(): i32 { @@:(self.n) }
        }
        $B => $A {
            cycle() { -> $A }
            get_state(): String { @@:("B".to_string()) }
            get_count(): i32 { => $^ }
        }
    domain:
        n: i32 = 0
}

@@system Outer {
    interface:
        tick()
        cycle_inner()
        get_outer_state(): String
        get_inner_state(): String
        get_inner_count(): i32
        get_k(): i32

    machine:
        $Idle {
            tick() { self.k = self.k + 1; -> $Active }
            cycle_inner() { self.inner.cycle(); }
            get_outer_state(): String { @@:("Idle".to_string()) }
            get_inner_state(): String { @@:(self.inner.get_state()) }
            get_inner_count(): i32 { @@:(self.inner.get_count()) }
            get_k(): i32 { @@:(self.k) }
        }
        $Active => $Idle {
            tick() { -> $Idle }
            get_outer_state(): String { @@:("Active".to_string()) }
            cycle_inner() { => $^ }
            get_inner_state(): String { => $^ }
            get_inner_count(): i32 { => $^ }
            get_k(): i32 { => $^ }
        }
    domain:
        k: i32 = 0
        inner: Inner = @@Inner()
}

fn fmt(o: &mut Outer) -> String {
    format!("{}/{}/{}/{}", o.get_outer_state(), o.get_inner_state(), o.get_inner_count(), o.get_k())
}

fn must(label: &str, o: &mut Outer, expected: &str) {
    let actual = fmt(o);
    assert_eq!(actual, expected, "FAIL {}: {} expected {}", label, actual, expected);
}

fn main() {
    let mut o1 = Outer::new();
    let mut o2 = Outer::new();

    o1.cycle_inner();
    o1.cycle_inner();
    o1.cycle_inner();
    must("o1 pre", &mut o1, "Idle/B/2/0");

    o2.tick();
    o2.tick();
    o2.tick();
    must("o2 pre", &mut o2, "Active/A/0/2");

    let snap1 = o1.save_state();
    let snap2 = o2.save_state();

    let mut r2 = Outer::restore_state(&snap2);
    let mut r1 = Outer::restore_state(&snap1);

    must("r1 restored", &mut r1, "Idle/B/2/0");
    must("r2 restored", &mut r2, "Active/A/0/2");

    r1.cycle_inner();
    must("r1 after mut", &mut r1, "Idle/A/2/0");
    must("r2 after r1 mut", &mut r2, "Active/A/0/2");

    r2.cycle_inner();
    must("r1 after r2 mut", &mut r1, "Idle/A/2/0");
    must("r2 after r2 mut", &mut r2, "Active/B/1/2");

    println!("PASS: 87_persist_multi_instance");
}

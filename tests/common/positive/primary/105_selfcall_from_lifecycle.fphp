@@[target("php")]

// Test 105: @@:self.method() from lifecycle handlers (F1 regression)

@@system LifecycleSelfCall {
    interface:
        tick()
        go()
        get_count(): int

    machine:
        $A {
            $>() { @@:self.tick() }
            <$() { @@:self.tick() }
            go() { -> $B }
            tick() { $this->count = $this->count + 1; }
            get_count(): int { @@:($this->count) }
        }

        $B {
            $>() { @@:self.tick() }
            tick() { $this->count = $this->count + 1; }
            get_count(): int { @@:($this->count) }
        }

    domain:
        count = 0
}

echo "=== Test 105: @@:self.method() from lifecycle handlers (F1 regression) ===\n";
$s = @@LifecycleSelfCall();
if ($s->get_count() !== 1) { echo "FAIL: Expected 1\n"; exit(1); }
echo "TC1: @@:self from start state \$> - PASS\n";
$s->go();
if ($s->get_count() !== 3) { echo "FAIL: Expected 3\n"; exit(1); }
echo "TC2/TC3: @@:self from <\$ + post-transition \$> - PASS\n";
echo "PASS: F1 regression\n";

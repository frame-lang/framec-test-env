@@[target("erlang")]
@@system StateVarPushPop {
    interface:
        increment(): int
        getCount(): int
        saveAndGo()
        restore()
    machine:
        $Counter {
            $.count: int = 0
            increment(): int {
                $.count = $.count + 1
                @@:($.count)
                return
            }
            getCount(): int {
                @@:($.count)
            }
            saveAndGo() {
                push$
                -> $Other
            }
        }
        $Other {
            $.otherCount: int = 100
            restore() { -> pop$ }
            increment(): int {
                @@:(-1)
            }
            getCount(): int {
                @@:($.otherCount)
            }
        }
}

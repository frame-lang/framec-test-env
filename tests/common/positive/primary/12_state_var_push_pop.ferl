@@target erlang
@@system StateVarPushPop {
    interface:
        increment(): int
        getCount(): int
        saveAndGo()
        restore()
    machine:
        $Counter {
            $.count: int = 0
            increment(): int {
                $.count = $.count + 1
                return $.count
            }
            getCount(): int { return $.count }
            saveAndGo() {
                push$
                -> $Other
            }
        }
        $Other {
            $.otherCount: int = 100
            restore() { -> pop$ }
            increment(): int { return -1 }
            getCount(): int { return $.otherCount }
        }
}

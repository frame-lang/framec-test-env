<?php
@@[target("php")]

@@[persist]
@@system PersistStack {
    interface:
        push_and_go()
        pop_back()
        get_state(): str
        get_depth(): int

    machine:
        $Start {
            push_and_go() {
                $this->depth = $this->depth + 1;
                push$
                -> $Middle
            }

            pop_back() {
                # nothing to pop
            }

            get_state(): str {
                @@:("start")
                return;
            }

            get_depth(): int {
                @@:($this->depth)
                return;
            }
        }

        $Middle {
            push_and_go() {
                $this->depth = $this->depth + 1;
                push$
                -> $End
            }

            pop_back() {
                $this->depth = $this->depth - 1;
                -> pop$
            }

            get_state(): str {
                @@:("middle")
                return;
            }

            get_depth(): int {
                @@:($this->depth)
                return;
            }
        }

        $End {
            push_and_go() {
                # cannot go further
            }

            pop_back() {
                $this->depth = $this->depth - 1;
                -> pop$
            }

            get_state(): str {
                @@:("end")
                return;
            }

            get_depth(): int {
                @@:($this->depth)
                return;
            }
        }
    domain:
        depth = 0
}

echo "=== Test 25: Persist Stack (json) ===" . "\n";

$s1 = new PersistStack();
if ($s1->get_state() !== "start") { echo "FAIL: Expected start\n"; exit(1); }

$s1->push_and_go();
if ($s1->get_state() !== "middle") { echo "FAIL: Expected middle\n"; exit(1); }
if ($s1->get_depth() !== 1) { echo "FAIL: Expected depth 1\n"; exit(1); }

$s1->push_and_go();
if ($s1->get_state() !== "end") { echo "FAIL: Expected end\n"; exit(1); }
if ($s1->get_depth() !== 2) { echo "FAIL: Expected depth 2\n"; exit(1); }

echo "1. Built stack: state=" . $s1->get_state() . ", depth=" . $s1->get_depth() . "\n";

$data = $s1->save_state();
if (!is_string($data)) { echo "FAIL: Expected string\n"; exit(1); }
echo "2. Saved: " . strlen($data) . " bytes" . "\n";

$s2 = PersistStack::restore_state($data);
if ($s2->get_state() !== "end") { echo "FAIL: Restored: expected end\n"; exit(1); }
if ($s2->get_depth() !== 2) { echo "FAIL: Restored: expected depth 2\n"; exit(1); }
echo "3. Restored: state=" . $s2->get_state() . ", depth=" . $s2->get_depth() . "\n";

$s2->pop_back();
if ($s2->get_state() !== "middle") { echo "FAIL: After pop: expected middle\n"; exit(1); }
if ($s2->get_depth() !== 1) { echo "FAIL: After pop: expected depth 1\n"; exit(1); }
echo "4. After pop: state=" . $s2->get_state() . ", depth=" . $s2->get_depth() . "\n";

$s2->pop_back();
if ($s2->get_state() !== "start") { echo "FAIL: After 2nd pop: expected start\n"; exit(1); }
if ($s2->get_depth() !== 0) { echo "FAIL: After 2nd pop: expected depth 0\n"; exit(1); }
echo "5. After 2nd pop: state=" . $s2->get_state() . ", depth=" . $s2->get_depth() . "\n";

echo "PASS: Persist stack works correctly" . "\n";

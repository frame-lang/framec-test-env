@@[target("java")]

@@system FloatStateArg {
    interface:
        configure(rate: float)
        scale(v: float): float

    machine:
        $Idle {
            configure(rate: double) {
                -> $Active(rate)
            }
            scale(v: double): double {
                @@:(v)
            }
        }

        $Active => $Frame(rate: double) {
            configure(rate: double) {
                -> $Active(rate)
            }
            scale(v: double): double {
                => $^
            }
        }

        $Frame {
            scale(v: double): double {
                @@:(v * rate)
            }
        }
    domain:
        n : int = 0
}

class Main {
    public static void main(String[] args) {
        var s = @@FloatStateArg();
        if (Math.abs(s.scale(2.0) - 2.0) > 1e-9) { System.out.println("FAIL idle"); System.exit(1); }
        s.configure(0.5);
        if (Math.abs(s.scale(10.0) - 5.0) > 1e-9) { System.out.println("FAIL 0.5"); System.exit(1); }
        s.configure(2.5);
        if (Math.abs(s.scale(4.0) - 10.0) > 1e-9) { System.out.println("FAIL 2.5"); System.exit(1); }
        System.out.println("PASS: 68_hsm_float_state_args");
    }
}

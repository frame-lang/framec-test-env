@@[target("php")]

<?php

@@[persist(string)]
@@[save(save_state)]
@@[load(restore_state)]
@@system PersistDict {
    interface:
        configure(m: array)
        get_v(key: string): int

    machine:
        $Idle {
            configure(m: array) { -> $Active(m) }
            get_v(key: string): int { @@:(-1) }
        }
        $Active(m: array) {
            configure(m: array) { -> $Active(m) }
            get_v(key: string): int { @@:(array_key_exists($key, $m) ? $m[$key] : -1) }
        }
    domain:
        n: int = 0
}

$s1 = new PersistDict();
$s1->configure(["a" => 10, "b" => 20]);
if ($s1->get_v("a") !== 10) { echo "FAIL pre\n"; exit(1); }
$snap = $s1->save_state();
$s2 = new PersistDict();

$s2->restore_state($snap);
if ($s2->get_v("a") !== 10) { echo "FAIL post a\n"; exit(1); }
if ($s2->get_v("b") !== 20) { echo "FAIL post b\n"; exit(1); }
echo "PASS: 77_persist_dict_state_arg\n";

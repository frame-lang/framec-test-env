@@[target("swift")]

import Foundation

@@[persist]
@@system PersistStateArgs {
    operations:
        @@[save]
        saveState(): String {}

        @@[load]
        restoreState(data: String) {}

    interface:
        kick(v: int)
        get_slot(): int

    machine:
        $Idle {
            kick(v: int) {
                -> $Active(v)
            }
            get_slot(): int {
                @@:(-1)
            }
        }

        $Active(slot: int) {
            kick(v: int) {
                -> $Active(v)
            }
            get_slot(): int {
                @@:(slot)
            }
        }
    domain:
        v : int = 0
}

print("=== Test 56: Persist State-Args Round-Trip (Swift) ===")
let s1 = PersistStateArgs()
s1.kick(42)
let pre = s1.get_slot()
if pre != 42 { print("FAIL: pre \(pre)"); exit(1) }
print("1. Pre-save slot=\(pre)")

let snap = s1.saveState()
let s2 = PersistStateArgs()

s2.restoreState(snap)
let post = s2.get_slot()
if post != 42 { print("FAIL: post \(post)"); exit(1) }
print("2. Post-restore slot=\(post)")

s2.kick(99)
let post2 = s2.get_slot()
if post2 != 99 { print("FAIL: post2 \(post2)"); exit(1) }
print("3. Post-restore-kick slot=\(post2)")

print("PASS: 56_persist_state_args")

@@[target("cpp_17")]

#include <iostream>
#include <string>
#include <cassert>
#include <vector>
#include <algorithm>

// Test 47: HSM Enter Cascade — Both Parent and Child have $>

@@system HSMEnterBoth {
    interface:
        go_to_child()
        go_to_parent()
        get_log(): std::vector<std::string>
        get_state(): std::string

    machine:
        $Start {
            go_to_child() { -> $Child }
            go_to_parent() { -> $Parent }
            get_log(): std::vector<std::string> { @@:(event_log) }
            get_state(): std::string { @@:(std::string("Start")) }
        }

        $Child => $Parent {
            $>() {
                => $^
                event_log.push_back("Child:enter");
            }
            go_to_parent() { -> $Parent }
            get_log(): std::vector<std::string> { @@:(event_log) }
            get_state(): std::string { @@:(std::string("Child")) }
        }

        $Parent {
            $>() {
                event_log.push_back("Parent:enter");
            }
            go_to_child() { -> $Child }
            get_log(): std::vector<std::string> { @@:(event_log) }
            get_state(): std::string { @@:(std::string("Parent")) }
        }
    domain:
        event_log : std::vector<std::string> = {}
}

int main() {
    printf("=== Test 47: HSM Enter Cascade — Both ===\n");
    auto s = @@HSMEnterBoth();

    s.go_to_child();
    auto log = s.get_log();
    if (s.get_state() != "Child") { printf("FAIL\n"); assert(false); }
    auto pi = std::find(log.begin(), log.end(), "Parent:enter");
    auto ci = std::find(log.begin(), log.end(), "Child:enter");
    if (pi == log.end()) { printf("FAIL: Expected Parent:enter\n"); assert(false); }
    if (ci == log.end()) { printf("FAIL: Expected Child:enter\n"); assert(false); }
    if (pi >= ci) { printf("FAIL: Parent:enter must precede Child:enter\n"); assert(false); }
    printf("TC1: Parent's $> fires before Child's $> on cascade entry - PASS\n");

    s.go_to_parent();
    log = s.get_log();
    if (s.get_state() != "Parent") { printf("FAIL\n"); assert(false); }
    if (std::count(log.begin(), log.end(), "Parent:enter") != 2) { printf("FAIL: Expected 2 Parent:enter\n"); assert(false); }
    if (std::count(log.begin(), log.end(), "Child:enter") != 1) { printf("FAIL: Expected still 1 Child:enter\n"); assert(false); }
    printf("TC2: Direct Parent entry fires only Parent's $> - PASS\n");

    s.go_to_child();
    log = s.get_log();
    if (std::count(log.begin(), log.end(), "Parent:enter") != 3) { printf("FAIL: Expected 3 Parent:enter\n"); assert(false); }
    if (std::count(log.begin(), log.end(), "Child:enter") != 2) { printf("FAIL: Expected 2 Child:enter\n"); assert(false); }
    printf("TC3: Re-entering Child cascades through Parent again - PASS\n");

    printf("PASS: HSM enter cascade fires both layers top-down\n");
    return 0;
}

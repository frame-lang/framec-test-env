@@target erlang
@@[persist]
@@system PPushDeep {
    interface:
        descend()
        ascend()
        getDepth(): int
    machine:
        $Idle {
            descend() { push$; -> $Modal1 }
            getDepth(): int { @@:(0) }
        }
        $Modal1 {
            descend() { push$; -> $Modal2 }
            ascend() { -> pop$ }
            getDepth(): int { @@:(1) }
        }
        $Modal2 {
            descend() { push$; -> $Modal3 }
            ascend() { -> pop$ }
            getDepth(): int { @@:(2) }
        }
        $Modal3 {
            ascend() { -> pop$ }
            getDepth(): int { @@:(3) }
        }
    domain:
        n = 0
}

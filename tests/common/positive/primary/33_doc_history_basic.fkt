@@target kotlin

import kotlin.system.exitProcess

@@system HistoryBasic {
    interface:
        gotoC_from_A()
        gotoC_from_B()
        gotoB()
        return_back()
        get_state(): String

    machine:
        $A {
            gotoC_from_A() {
                push$
                -> $C
            }
            gotoB() {
                -> $B
            }
            get_state(): String {
                return "A"
            }
        }

        $B {
            gotoC_from_B() {
                push$
                -> $C
            }
            get_state(): String {
                return "B"
            }
        }

        $C {
            return_back() {
                -> pop$
            }
            get_state(): String {
                return "C"
            }
        }
}

fun main() {
    println("=== Test 33: Doc History Basic ===")
    val h = @@HistoryBasic()

    // Start in A
    if ((h.get_state() as String) != "A") {
        println("FAIL: Expected 'A', got '${h.get_state()}'")
        exitProcess(1)
    }

    // Go to C from A (push A)
    h.gotoC_from_A()
    if ((h.get_state() as String) != "C") {
        println("FAIL: Expected 'C', got '${h.get_state()}'")
        exitProcess(1)
    }

    // Return back (pop to A)
    h.return_back()
    if ((h.get_state() as String) != "A") {
        println("FAIL: Expected 'A' after pop, got '${h.get_state()}'")
        exitProcess(1)
    }

    // Now go to B
    h.gotoB()
    if ((h.get_state() as String) != "B") {
        println("FAIL: Expected 'B', got '${h.get_state()}'")
        exitProcess(1)
    }

    // Go to C from B (push B)
    h.gotoC_from_B()
    if ((h.get_state() as String) != "C") {
        println("FAIL: Expected 'C', got '${h.get_state()}'")
        exitProcess(1)
    }

    // Return back (pop to B)
    h.return_back()
    if ((h.get_state() as String) != "B") {
        println("FAIL: Expected 'B' after pop, got '${h.get_state()}'")
        exitProcess(1)
    }

    println("PASS: History push/pop works correctly")
}

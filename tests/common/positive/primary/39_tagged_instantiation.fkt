@@target kotlin

import kotlin.system.exitProcess

@@system Calculator {
    interface:
        add(a: Int, b: Int): Int
        get_result(): Int

    machine:
        $Ready {
            add(a: Int, b: Int): Int {
                this.result = a + b
                @@:(this.result)
                return;
            }

            get_result(): Int {
                @@:(this.result)
                return;
            }
        }
    domain:
        result = 0
}

@@system Counter {
    interface:
        increment()
        get_count(): Int

    machine:
        $Active {
            increment() {
                this.count = this.count + 1
            }

            get_count(): Int {
                @@:(this.count)
                return;
            }
        }
    domain:
        count = 0
}

fun main() {
    println("=== Test 39: Tagged System Instantiation ===")

    // Tagged instantiation - validated at transpile time
    val calc = @@Calculator()
    val counter = @@Counter()

    // Test Calculator
    var result = calc.add(3, 4) as Int
    if (result != 7) {
        println("FAIL: Expected 7, got $result")
        exitProcess(1)
    }
    println("Calculator.add(3, 4) = $result")

    result = calc.get_result() as Int
    if (result != 7) {
        println("FAIL: Expected 7, got $result")
        exitProcess(1)
    }
    println("Calculator.get_result() = $result")

    // Test Counter
    counter.increment()
    counter.increment()
    counter.increment()
    val count = counter.get_count() as Int
    if (count != 3) {
        println("FAIL: Expected 3, got $count")
        exitProcess(1)
    }
    println("Counter after 3 increments: $count")

    println("PASS: Tagged instantiation works correctly")
}

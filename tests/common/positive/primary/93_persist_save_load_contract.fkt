@@[target("kotlin")]

@@[persist]
@@system Counter {
    operations:
        @@[save]
        saveOp(): String {}

        @@[load]
        loadOp(data: String) {}

    interface:
        bump()
        readN(): Int

    machine:
        $Active {
            bump() {
                this.n = this.n + 1
            }
            readN(): Int { @@:(this.n) }
        }

    domain:
        n: Int = 0
}

fun main() {
    val c1 = Counter()
    c1.bump()
    c1.bump()
    c1.bump()
    val data = c1.saveOp()

    val c2 = Counter()
    c2.loadOp(data)
    if (c2.readN() != 3) {
        println("FAIL: expected 3, got ${c2.readN()}")
        return
    }
    println("PASS: 93_persist_save_load_contract")
}

@@target lua

@@persist
@@system Inner {
    interface:
        cycle()
        get_state(): string
        get_count(): int

    machine:
        $A {
            cycle() { self.n = self.n + 1; -> $B }
            get_state(): string { @@:("A") }
            get_count(): int { @@:(self.n) }
        }
        $B => $A {
            cycle() { -> $A }
            get_state(): string { @@:("B") }
            get_count(): int { => $^ }
        }
    domain:
        n: int = 0
}

@@system Outer {
    interface:
        tick()
        cycle_inner()
        get_outer_state(): string
        get_inner_state(): string
        get_inner_count(): int
        get_k(): int

    machine:
        $Idle {
            tick() { self.k = self.k + 1; -> $Active }
            cycle_inner() { self.inner:cycle() }
            get_outer_state(): string { @@:("Idle") }
            get_inner_state(): string { @@:(self.inner:get_state()) }
            get_inner_count(): int { @@:(self.inner:get_count()) }
            get_k(): int { @@:(self.k) }
        }
        $Active => $Idle {
            tick() { -> $Idle }
            get_outer_state(): string { @@:("Active") }
            cycle_inner() { => $^ }
            get_inner_state(): string { => $^ }
            get_inner_count(): int { => $^ }
            get_k(): int { => $^ }
        }
    domain:
        k: int = 0
        inner = @@Inner()
}

local function fmtProbe(o)
    return o:get_outer_state() .. "/" .. o:get_inner_state() .. "/" .. tostring(o:get_inner_count()) .. "/" .. tostring(o:get_k())
end

local function must(label, o, expected)
    local actual = fmtProbe(o)
    if actual ~= expected then
        print("FAIL " .. label .. ": " .. actual .. " expected " .. expected)
        os.exit(1)
    end
end

local o1 = Outer:new()
local o2 = Outer:new()

o1:cycle_inner()
o1:cycle_inner()
o1:cycle_inner()
must("o1 pre", o1, "Idle/B/2/0")

o2:tick()
o2:tick()
o2:tick()
must("o2 pre", o2, "Active/A/0/2")

local snap1 = o1:save_state()
local snap2 = o2:save_state()

local r2 = Outer.restore_state(snap2)
local r1 = Outer.restore_state(snap1)

must("r1 restored", r1, "Idle/B/2/0")
must("r2 restored", r2, "Active/A/0/2")

r1:cycle_inner()
must("r1 after mut", r1, "Idle/A/2/0")
must("r2 after r1 mut", r2, "Active/A/0/2")

r2:cycle_inner()
must("r1 after r2 mut", r1, "Idle/A/2/0")
must("r2 after r2 mut", r2, "Active/B/1/2")

print("PASS: 87_persist_multi_instance")

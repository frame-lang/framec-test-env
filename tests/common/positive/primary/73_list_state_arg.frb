@@[target("ruby")]

@@system ListStateArg {
    interface:
        configure(items: Array)
        first_item(): int
        size(): int

    machine:
        $Idle {
            configure(items: Array) {
                -> $Active(items)
            }
            first_item(): int {
                @@:(-1)
            }
            size(): int {
                @@:(0)
            }
        }
        $Active(items: Array) {
            configure(items: Array) {
                -> $Active(items)
            }
            first_item(): int {
                @@:(items[0])
            }
            size(): int {
                @@:(items.length)
            }
        }
    domain:
        n: int = 0
}

s = @@ListStateArg()
abort("FAIL idle first_item") unless s.first_item == -1
abort("FAIL idle size") unless s.size == 0
s.configure([10, 20, 30])
abort("FAIL active first_item") unless s.first_item == 10
abort("FAIL active size") unless s.size == 3
s.configure([7])
abort("FAIL retransition first_item") unless s.first_item == 7
abort("FAIL retransition size") unless s.size == 1
puts "PASS: 73_list_state_arg"

@@[target("gdscript")]
extends SceneTree

@@system EnterExit {
    interface:
        toggle()
        get_log(): list

    machine:
        $Off {
            $>() {
                self.log.append("enter:Off")
                print("Entered Off state")
            }

            <$() {
                self.log.append("exit:Off")
                print("Exiting Off state")
            }

            toggle() {
                -> $On
            }

            get_log(): list {
                @@:(self.log)
                return
            }
        }

        $On {
            $>() {
                self.log.append("enter:On")
                print("Entered On state")
            }

            <$() {
                self.log.append("exit:On")
                print("Exiting On state")
            }

            toggle() {
                -> $Off
            }

            get_log(): list {
                @@:(self.log)
                return
            }
        }
    domain:
        log: list = []
}

func main():
    print("=== Test 05: Enter/Exit Handlers ===")
    var s = @@EnterExit()

    # Initial enter should have been called
    var log = s.get_log()
    assert("enter:Off" in log, "Expected 'enter:Off' in log, got " + str(log))
    print("After construction: " + str(log))

    # Toggle to On - should exit Off, enter On
    s.toggle()
    log = s.get_log()
    assert("exit:Off" in log, "Expected 'exit:Off' in log, got " + str(log))
    assert("enter:On" in log, "Expected 'enter:On' in log, got " + str(log))
    print("After toggle to On: " + str(log))

    # Toggle back to Off - should exit On, enter Off
    s.toggle()
    log = s.get_log()
    assert(log.count("enter:Off") == 2, "Expected 2 'enter:Off' entries, got " + str(log))
    assert("exit:On" in log, "Expected 'exit:On' in log, got " + str(log))
    print("After toggle to Off: " + str(log))

    print("PASS: Enter/Exit handlers work correctly")

func _init():
    main()
    quit()

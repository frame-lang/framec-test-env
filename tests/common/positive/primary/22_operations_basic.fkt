@@target kotlin

import kotlin.system.exitProcess

@@system OperationsTest {
    operations:
        add(x: Int, y: Int): Int {
            return x + y
        }

        multiply(x: Int, y: Int): Int {
            return x * y
        }

        static factorial(n: Int): Int {
            if (n <= 1) {
                return 1
            }
            return n * OperationsTest.factorial(n - 1)
        }

        static is_even(n: Int): Boolean {
            return n % 2 == 0
        }
    interface:
        compute(a: Int, b: Int): Int
        get_last_result(): Int

    machine:
        $Ready {
            compute(a: Int, b: Int): Int {
                // Use instance operations
                val sum_val = this.add(a, b)
                val prod_val = this.multiply(a, b)
                val last_result = sum_val + prod_val
                return last_result
            }

            get_last_result(): Int {
                return this.last_result
            }
        }
    domain:
        last_result = 0

}

fun main() {
    println("=== Test 22: Operations Basic (Kotlin) ===")
    val s = @@OperationsTest()

    // Test 1: Instance operations
    var result = s.add(3, 4) as Int
    if (result != 7) {
        println("FAIL: Expected 7, got $result")
        exitProcess(1)
    }
    println("1. add(3, 4) = $result")

    result = s.multiply(3, 4) as Int
    if (result != 12) {
        println("FAIL: Expected 12, got $result")
        exitProcess(1)
    }
    println("2. multiply(3, 4) = $result")

    // Test 2: Operations used in handler
    result = s.compute(3, 4) as Int
    // compute returns add(3,4) + multiply(3,4) = 7 + 12 = 19
    if (result != 19) {
        println("FAIL: Expected 19, got $result")
        exitProcess(1)
    }
    println("3. compute(3, 4) = $result")

    // Test 3: Static operations
    result = OperationsTest.factorial(5) as Int
    if (result != 120) {
        println("FAIL: Expected 120, got $result")
        exitProcess(1)
    }
    println("4. factorial(5) = $result")

    var is_even = OperationsTest.is_even(4) as Boolean
    if (is_even != true) {
        println("FAIL: Expected true, got $is_even")
        exitProcess(1)
    }
    println("5. is_even(4) = $is_even")

    is_even = OperationsTest.is_even(7) as Boolean
    if (is_even != false) {
        println("FAIL: Expected false, got $is_even")
        exitProcess(1)
    }
    println("6. is_even(7) = $is_even")

    // Test 4: Static via class
    result = OperationsTest.factorial(4) as Int
    if (result != 24) {
        println("FAIL: Expected 24, got $result")
        exitProcess(1)
    }
    println("7. OperationsTest.factorial(4) = $result")

    println("PASS: Operations basic works correctly")
}

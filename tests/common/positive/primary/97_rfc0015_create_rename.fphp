@@[target("php")]
@@[create(make)]
@@system Counter(seed: int) {
    interface:
        bump()
        get(): int

    machine:
        $A {
            bump() { $this->count = $this->count + 1; }
            get(): int { @@:($this->count) }
        }

    domain:
        seed: int = seed
        count: int = 0
}

$c1 = new Counter(42);
$c1->bump();
$c1->bump();
if ($c1->get() !== 2) {
    echo "FAIL: via new Counter expected 2, got " . $c1->get() . "\n";
} else {
    $c2 = Counter::make(99);
    $c2->bump();
    if ($c2->get() !== 1) {
        echo "FAIL: via Counter::make expected 1, got " . $c2->get() . "\n";
    } else {
        echo "PASS: rfc0015_create_rename\n";
    }
}

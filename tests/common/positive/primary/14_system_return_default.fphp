<?php
@@[target("php")]

# NOTE: Default return value syntax (method(): type = default) not yet implemented.
# This test validates behavior when handler doesn't set @@:return.

@@system SystemReturnDefaultTest {
    interface:
        handler_sets_value(): str
        handler_no_return(): str
        get_count(): int

    machine:
        $Start {
            $.count: int = 0

            handler_sets_value(): str {
                @@:("set_by_handler")
                return;
            }

            handler_no_return(): str {
                # Does not set return - should return null
                $.count = $.count + 1;
            }

            get_count(): int {
                @@:($.count)
                return;
            }
        }
}

echo "=== Test 14: System Return Default Behavior ===" . "\n";
$s = new SystemReturnDefaultTest();

$result = $s->handler_sets_value();
if ($result !== "set_by_handler") { echo "FAIL: Expected 'set_by_handler', got '{$result}'\n"; exit(1); }
echo "1. handler_sets_value() = '{$result}'" . "\n";

$result = $s->handler_no_return();
if ($result !== null) { echo "FAIL: Expected null, got " . var_export($result, true) . "\n"; exit(1); }
echo "2. handler_no_return() = " . var_export($result, true) . "\n";

$count = $s->get_count();
if ($count !== 1) { echo "FAIL: Expected count=1, got {$count}\n"; exit(1); }
echo "3. Handler was called, count = {$count}" . "\n";

$result = $s->handler_no_return();
if ($result !== null) { echo "FAIL: Expected null again\n"; exit(1); }
$count = $s->get_count();
if ($count !== 2) { echo "FAIL: Expected count=2, got {$count}\n"; exit(1); }
echo "4. Second call: result=" . var_export($result, true) . ", count={$count}" . "\n";

echo "PASS: System return default behavior works correctly" . "\n";

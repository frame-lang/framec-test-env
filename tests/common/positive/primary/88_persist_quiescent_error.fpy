@@[target("python_3")]

# Wave 8 final: quiescent contract (E700). save_state called from
# inside a handler is non-quiescent (the handler's FrameContext is
# on _context_stack) and must error per RFC-0012.

@@[persist]
@@system Outer {
    operations:
        @@[save]
        save_state(): bytes {}

        @@[load]
        restore_state(data: bytes) {}

    interface:
        try_save_during_handler()

    machine:
        $S {
            try_save_during_handler() {
                # Native call to runtime save_state inside a handler —
                # the handler's context frame is on _context_stack,
                # so save_state must raise E700.
                self.save_state()
            }
        }
    domain:
}

if __name__ == '__main__':
    # save_state from outside any handler IS quiescent — must succeed.
    o1 = Outer()
    snap = o1.save_state()
    assert snap is not None and len(snap) > 0, "quiescent save returned empty"

    # save_state from inside a handler is non-quiescent — must error.
    # The corrupted context_stack leaves the instance unrecoverable
    # post-error; that's the documented consequence of the contract
    # violation. Use a fresh instance to verify behavior.
    o2 = Outer()
    try:
        o2.try_save_during_handler()
        assert False, "expected E700; got no exception"
    except RuntimeError as e:
        assert "E700" in str(e), f"wrong error code: {e}"
        assert "not quiescent" in str(e), f"wrong error message: {e}"

    # A separate, never-violated instance is still quiescent and saves.
    o3 = Outer()
    snap3 = o3.save_state()
    assert snap3 is not None, "fresh instance unusable"

    print("PASS: 88_persist_quiescent_error")

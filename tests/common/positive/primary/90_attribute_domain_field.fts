@@[target("typescript")]

@@system Demo {
    interface:
        get_a(): number
        get_ts_only(): number
    machine:
        $S {
            get_a(): number { @@:(this.a) }
            get_ts_only(): number { @@:(this.ts_only) }
        }
    domain:
        a: number = 1
        @@[target("python_3")] py_only: number = 2
        @@[target("typescript")]
        ts_only: number = 42
}

const d = new Demo();
const dAny: any = d;
if (d.get_a() !== 1) { console.log("FAIL get_a: " + d.get_a()); process.exit(1); }
if (d.get_ts_only() !== 42) { console.log("FAIL get_ts_only: " + d.get_ts_only()); process.exit(1); }
if (typeof dAny.py_only !== "undefined") {
    console.log("FAIL: py_only should have been filtered out by @@[target(\"python_3\")]");
    process.exit(1);
}
console.log("PASS: 90_attribute_domain_field");

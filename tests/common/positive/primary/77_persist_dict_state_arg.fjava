@@[target("java")]

import java.util.Map;
import java.util.HashMap;

@@[persist]
@@system PersistDict {
    interface:
        configure(m: java.util.Map<String, Integer>)
        get_v(key: String): int

    machine:
        $Idle {
            configure(m: java.util.Map<String, Integer>) { -> $Active(m) }
            get_v(key: String): int { @@:(-1) }
        }
        $Active(m: java.util.Map<String, Integer>) {
            configure(m: java.util.Map<String, Integer>) { -> $Active(m) }
            get_v(key: String): int { @@:(((Integer)m.getOrDefault(key, -1))) }
        }
    domain:
        n: int = 0
}

class Main {
    public static void main(String[] args) throws Exception {
        PersistDict s1 = new PersistDict();
        Map<String, Integer> m = new HashMap<>();
        m.put("a", 10);
        m.put("b", 20);
        s1.configure(m);
        if (s1.get_v("a") != 10) { System.out.println("FAIL pre"); System.exit(1); }
        String snap = s1.save_state();
        PersistDict s2 = PersistDict.restore_state(snap);
        if (s2.get_v("a") != 10) { System.out.println("FAIL post a got " + s2.get_v("a")); System.exit(1); }
        if (s2.get_v("b") != 20) { System.out.println("FAIL post b got " + s2.get_v("b")); System.exit(1); }
        System.out.println("PASS: 77_persist_dict_state_arg");
    }
}

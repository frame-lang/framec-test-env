@@target kotlin

import kotlin.system.exitProcess

@@system ContextDataTest {
    interface:
        process_with_data(value: Int): String
        check_data_isolation(): String
        transition_preserves_data(x: Int): String

    machine:
        $Start {
            process_with_data(value: Int): String {
                // Set data in handler
                @@:data["input"] = @@.value
                @@:data["trace"] = ArrayList(listOf("handler"))

                @@:return = "processed:" + @@:data["input"]
            }

            check_data_isolation(): String {
                // Set data, call another method, verify our data preserved
                @@:data["outer"] = "outer_value"

                // This creates its own context with its own data
                val inner_result = this.process_with_data(99) as String

                // Our data should still be here
                @@:return = "outer_data=" + @@:data["outer"] + ",inner=" + inner_result
            }

            transition_preserves_data(x: Int): String {
                // Set data, transition, verify data available in lifecycle handlers
                @@:data["started_in"] = "Start"
                @@:data["value"] = @@.x
                @@:data["trace"] = ArrayList(listOf("handler"))
                -> $End
            }

            <$() {
                // Exit handler can access data set by event handler
                (@@:data["trace"] as ArrayList<String>).add("exit")
            }
        }

        $End {
            $>() {
                // Enter handler can access data set by previous handlers
                (@@:data["trace"] as ArrayList<String>).add("enter")
                @@:data["ended_in"] = "End"

                // Build final result from accumulated data
                @Suppress("UNCHECKED_CAST")
                val trace = @@:data["trace"] as ArrayList<String>
                val trace_str = if (trace != null) trace.joinToString(",") else "no_trace"
                @@:return = "from=" + @@:data["started_in"] + ",to=" + @@:data["ended_in"] + ",value=" + @@:data["value"] + ",trace=" + trace_str
            }
        }
}

fun main() {
    println("=== Test 38: Context Data ===")

    // Test 1: Basic data set/get
    val s1 = @@ContextDataTest()
    var result = s1.process_with_data(42) as String
    if (result != "processed:42") {
        println("FAIL: Expected 'processed:42', got '$result'")
        exitProcess(1)
    }
    println("1. process_with_data(42) = '$result'")

    // Test 2: Data isolation between nested calls
    val s2 = @@ContextDataTest()
    result = s2.check_data_isolation() as String
    var expected = "outer_data=outer_value,inner=processed:99"
    if (result != expected) {
        println("FAIL: Expected '$expected', got '$result'")
        exitProcess(1)
    }
    println("2. check_data_isolation() = '$result'")

    // Test 3: Data preserved across transition (handler -> <$ -> $>)
    val s3 = @@ContextDataTest()
    result = s3.transition_preserves_data(100) as String
    // Data should flow: handler sets -> exit accesses -> enter accesses and returns
    if (!result.contains("from=Start")) {
        println("FAIL: Expected 'from=Start' in '$result'")
        exitProcess(1)
    }
    if (!result.contains("to=End")) {
        println("FAIL: Expected 'to=End' in '$result'")
        exitProcess(1)
    }
    if (!result.contains("value=100")) {
        println("FAIL: Expected 'value=100' in '$result'")
        exitProcess(1)
    }
    println("3. transition_preserves_data(100) = '$result'")

    println("PASS: Context data works correctly")
}

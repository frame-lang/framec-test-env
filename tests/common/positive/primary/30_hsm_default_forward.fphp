<?php
@@target php

@@system HSMDefaultForward {
    interface:
        handled_event()
        unhandled_event()
        get_log(): list

    machine:
        $Child => $Parent {
            handled_event() {
                $this->log[] = "Child:handled_event";
            }

            get_log(): list {
                return $this->log;
            }

            => $^
        }

        $Parent {
            handled_event() {
                $this->log[] = "Parent:handled_event";
            }

            unhandled_event() {
                $this->log[] = "Parent:unhandled_event";
            }

            get_log(): list {
                return $this->log;
            }
        }
    domain:
        log = []
}

echo "=== Test 30: HSM State-Level Default Forward ===" . "\n";
$s = new HSMDefaultForward();

$s->handled_event();
$log = $s->get_log();
if (!in_array("Child:handled_event", $log)) { echo "FAIL: Expected 'Child:handled_event' in log\n"; exit(1); }
echo "After handled_event: " . implode(", ", $log) . "\n";

$s->unhandled_event();
$log = $s->get_log();
if (!in_array("Parent:unhandled_event", $log)) { echo "FAIL: Expected 'Parent:unhandled_event' in log (forwarded)\n"; exit(1); }
echo "After unhandled_event (forwarded): " . implode(", ", $log) . "\n";

echo "PASS: HSM state-level default forward works correctly" . "\n";

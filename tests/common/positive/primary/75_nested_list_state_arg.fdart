@@target dart

import 'dart:io';
import 'dart:convert';

@@persist
@@system NestedList {
    interface:
        configure(rows: List<List<int>>)
        first_first(): int
        outer_size(): int

    machine:
        $Idle {
            configure(rows: List<List<int>>) { -> $Active(rows) }
            first_first(): int { @@:(-1) }
            outer_size(): int { @@:(0) }
        }
        $Active(rows: List<List<int>>) {
            configure(rows: List<List<int>>) { -> $Active(rows) }
            first_first(): int { @@:(rows[0][0]) }
            outer_size(): int { @@:(rows.length) }
        }
    domain:
        n: int = 0
}

void main() {
    var s1 = NestedList();
    s1.configure([[10, 20], [30, 40]]);
    if (s1.first_first() != 10) { print("FAIL pre"); return; }
    if (s1.outer_size() != 2) { print("FAIL size"); return; }
    var snap = s1.saveState();
    var s2 = NestedList.restoreState(snap);
    if (s2.first_first() != 10) { print("FAIL post"); return; }
    if (s2.outer_size() != 2) { print("FAIL post size"); return; }
    print("PASS: 75_nested_list_state_arg");
}

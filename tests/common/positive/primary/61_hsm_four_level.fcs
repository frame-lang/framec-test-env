@@target csharp

using System;

@@system HsmFourLevel {
    interface:
        drive(): int
        write_at_level(level: int)
        get_n(): int

    machine:
        $Leaf => $Mid {
            drive(): int {
                => $^
            }
            write_at_level(level: int) {
                n = n + level * 1;
                => $^
            }
            get_n(): int {
                @@:(n)
            }
        }

        $Mid => $Branch {
            drive(): int {
                => $^
            }
            write_at_level(level: int) {
                n = n + level * 10;
                => $^
            }
        }

        $Branch => $Root {
            drive(): int {
                => $^
            }
            write_at_level(level: int) {
                n = n + level * 100;
                => $^
            }
        }

        $Root {
            drive(): int {
                @@:(n)
            }
            write_at_level(level: int) {
                n = n + level * 1000;
            }
        }
    domain:
        n : int = 0
}

class Program {
    static void Main(string[] args) {
        Console.WriteLine("=== Test 61: 4-level HSM cascade (C#) ===");
        var s = new HsmFourLevel();

        int initial = s.drive();
        if (initial != 0) { Console.WriteLine($"FAIL: initial {initial}"); Environment.Exit(1); }
        Console.WriteLine($"1. Initial drive returned {initial}");

        s.write_at_level(2);
        int after = s.get_n();
        if (after != 2222) { Console.WriteLine($"FAIL: after {after}"); Environment.Exit(1); }
        Console.WriteLine($"2. After cascading write: n={after}");

        int finalVal = s.drive();
        if (finalVal != 2222) { Console.WriteLine($"FAIL: final {finalVal}"); Environment.Exit(1); }
        Console.WriteLine($"3. Drive after write returned {finalVal}");

        Console.WriteLine("PASS: 61_hsm_four_level");
    }
}

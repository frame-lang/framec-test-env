@@[target("erlang")]
@@system Lamp {
    interface:
        turnOn()
        turnOff()
        getColor(): str
        setColor(color: str)
    machine:
        $Off {
            turnOn() { -> $On }
            getColor(): str {
                @@:(self.color)
            }
            setColor(color: str) { self.color = color }
        }
        $On {
            $>() { self.closeSwitch() }
            <$() { self.openSwitch() }
            turnOff() { -> $Off }
            getColor(): str {
                @@:(self.color)
            }
            setColor(color: str) { self.color = color }
        }
    actions:
        closeSwitch() { self.switch_closed = true }
        openSwitch() { self.switch_closed = false }
    domain:
        color = "white"
        switch_closed = false
}

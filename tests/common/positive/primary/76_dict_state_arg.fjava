@@[target("java")]

import java.util.Map;
import java.util.HashMap;

@@system DictStateArg {
    interface:
        configure(m: java.util.Map<String, Integer>)
        get_v(key: String): int
        size(): int

    machine:
        $Idle {
            configure(m: java.util.Map<String, Integer>) { -> $Active(m) }
            get_v(key: String): int { @@:(-1) }
            size(): int { @@:(0) }
        }
        $Active(m: java.util.Map<String, Integer>) {
            configure(m: java.util.Map<String, Integer>) { -> $Active(m) }
            get_v(key: String): int { @@:(((Integer)m.getOrDefault(key, -1))) }
            size(): int { @@:(m.size()) }
        }
    domain:
        n: int = 0
}

class Main {
    public static void main(String[] args) {
        DictStateArg s = @@DictStateArg();
        if (s.get_v("a") != -1) { System.out.println("FAIL idle"); System.exit(1); }
        if (s.size() != 0) { System.out.println("FAIL idle size"); System.exit(1); }
        Map<String, Integer> m = new HashMap<>();
        m.put("a", 10);
        m.put("b", 20);
        s.configure(m);
        if (s.get_v("a") != 10) { System.out.println("FAIL a"); System.exit(1); }
        if (s.get_v("b") != 20) { System.out.println("FAIL b"); System.exit(1); }
        if (s.size() != 2) { System.out.println("FAIL size"); System.exit(1); }
        Map<String, Integer> m2 = new HashMap<>();
        m2.put("x", 99);
        s.configure(m2);
        if (s.get_v("x") != 99) { System.out.println("FAIL x"); System.exit(1); }
        if (s.size() != 1) { System.out.println("FAIL size2"); System.exit(1); }
        System.out.println("PASS: 76_dict_state_arg");
    }
}

@@target ruby

def helper_function(x)
    # Native helper function defined before system
    return x * 2
end

@@system NativeCode {
    interface:
        compute(value: int): int
        use_math(): float

    machine:
        $Active {
            compute(value: int): int {
                # Native code with local variables
                temp = value + 10
                result = helper_function(temp)
                puts("Computed: #{value} -> #{result}")
                return result
            }

            use_math(): float {
                # Using built-in Math module
                result = Math.sqrt(16) + Math::PI
                puts("Math result: #{result}")
                return result
            }
        }
}

puts("=== Test 04: Native Code Preservation ===")
s = NativeCode.new

# Test native code in handler with helper function
result = s.compute(5)
expected = (5 + 10) * 2  # 30
raise "Expected #{expected}, got #{result}" unless result == expected
puts("compute(5) = #{result}")

# Test imported module usage
math_result = s.use_math()
expected_math = Math.sqrt(16) + Math::PI
raise "Expected ~#{expected_math}, got #{math_result}" unless (math_result - expected_math).abs < 0.001
puts("use_math() = #{math_result}")

puts("PASS: Native code preservation works correctly")

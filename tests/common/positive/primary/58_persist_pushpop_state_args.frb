@@[target("ruby")]

require 'json'

@@[persist(String)]
@@[save(save_state)]
@@[load(restore_state)]
@@system PersistPushpopStateArgs {
    interface:
        push_modal(v: int)
        pop_modal()
        get_slot(): int

    machine:
        $Idle {
            push_modal(v: int) {
                push$
                -> $Modal(v)
            }
            pop_modal() {
                -> pop$
            }
            get_slot(): int {
                @@:(-99)
                return
            }
        }

        $Modal(slot: int) {
            push_modal(v: int) {
                push$
                -> $Modal(v)
            }
            pop_modal() {
                -> pop$
            }
            get_slot(): int {
                @@:(slot)
                return
            }
        }
    domain:
        v: int = 0
}

puts("=== Test 58: Persist × push/pop × state-args (Ruby) ===")
s1 = PersistPushpopStateArgs.new
s1.push_modal(42)
s1.push_modal(77)
pre = s1.get_slot()
raise "Expected 77 pre-save, got #{pre}" unless pre == 77
puts("1. Pre-save top slot=#{pre}")

snap = s1.save_state()
s2 = PersistPushpopStateArgs.new
s2.restore_state(snap)
post = s2.get_slot()
raise "Expected 77 post-restore, got #{post}" unless post == 77
puts("2. Post-restore top slot=#{post}")

s2.pop_modal()
mid = s2.get_slot()
raise "Expected 42 after first pop, got #{mid}" unless mid == 42
puts("3. After first pop slot=#{mid}")

s2.pop_modal()
bottom = s2.get_slot()
raise "Expected -99 after second pop, got #{bottom}" unless bottom == -99
puts("4. After second pop slot=#{bottom}")

puts("PASS: 58_persist_pushpop_state_args")

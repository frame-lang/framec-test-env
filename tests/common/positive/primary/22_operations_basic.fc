@@target c

@@system OperationTest {
    operations:
        double_value(x: int): int {
            return x * 2;
        }
    interface:
        run_test(): int

    machine:
        $Start {
            run_test(): int {
                int result = OperationTest_double_value(self, 21);
                @@:(result)
                return;
            }
        }

}

int main() {
    printf("=== Test 22: Basic Operations ===\n");
    OperationTest* o = @@OperationTest();

    int result = OperationTest_run_test(o);
    printf("double_value(21) = %d\n", result);
    if (result != 42) {
        printf("FAIL: Expected 42, got %d\n", result);
        return 1;
    }

    printf("PASS: Basic operations work correctly\n");
    OperationTest_destroy(o);
    return 0;
}

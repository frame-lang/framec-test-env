@@[target("kotlin")]

@@[persist]
@@system PersistHsmPushpop {
    interface:
        push_modal(v: int)
        pop_modal()
        get_x(): int

    machine:
        $Idle {
            push_modal(v: int) {
                push$
                -> $Modal(v)
            }
            pop_modal() {
                -> pop$
            }
            get_x(): int {
                @@:(-99)
            }
        }

        $Modal => $Frame(x: int) {
            push_modal(v: int) {
                push$
                -> $Modal(v)
            }
            pop_modal() {
                -> pop$
            }
            get_x(): int {
                @@:(x)
            }
        }

        $Frame {
        }
    domain:
        v : int = 0
}

fun main() {
    println("=== Test 60: Persist × HSM × push/pop (Kotlin) ===")
    val s1 = PersistHsmPushpop()
    s1.push_modal(42)
    s1.push_modal(99)
    val pre = s1.get_x()
    if (pre != 99) { println("FAIL: pre $pre"); kotlin.system.exitProcess(1) }
    println("1. Pre-save top x=$pre")

    val snap = s1.save_state() as String
    val s2 = PersistHsmPushpop.restore_state(snap)
    val post = s2.get_x()
    if (post != 99) { println("FAIL: post $post"); kotlin.system.exitProcess(1) }
    println("2. Post-restore top x=$post")

    s2.pop_modal()
    val mid = s2.get_x()
    if (mid != 42) { println("FAIL: mid $mid"); kotlin.system.exitProcess(1) }
    println("3. After first pop x=$mid")

    s2.pop_modal()
    val bottom = s2.get_x()
    if (bottom != -99) { println("FAIL: bottom $bottom"); kotlin.system.exitProcess(1) }
    println("4. After second pop x=$bottom")

    println("PASS: 60_persist_hsm_pushpop")
}

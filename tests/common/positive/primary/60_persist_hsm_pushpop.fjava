@@[target("java")]

import java.util.*;

@@[persist(String)]
@@[save(save_state)]
@@[load(restore_state)]
@@system PersistHsmPushpop {
    interface:
        push_modal(v: int)
        pop_modal()
        get_x(): int

    machine:
        $Idle {
            push_modal(v: int) {
                push$
                -> $Modal(v)
            }
            pop_modal() {
                -> pop$
            }
            get_x(): int {
                @@:(-99)
            }
        }

        $Modal => $Frame(x: int) {
            push_modal(v: int) {
                push$
                -> $Modal(v)
            }
            pop_modal() {
                -> pop$
            }
            get_x(): int {
                @@:(x)
            }
        }

        $Frame {
        }
    domain:
        v : int = 0
}

class Main {
    public static void main(String[] args) {
        System.out.println("=== Test 60: Persist × HSM × push/pop (Java) ===");
        var s1 = new PersistHsmPushpop();
        s1.push_modal(42);
        s1.push_modal(99);
        int pre = s1.get_x();
        if (pre != 99) { System.out.println("FAIL: pre " + pre); System.exit(1); }
        System.out.println("1. Pre-save top x=" + pre);

        String snap = s1.save_state();
        var s2 = new PersistHsmPushpop();

        s2.restore_state(snap);
        int post = s2.get_x();
        if (post != 99) { System.out.println("FAIL: post " + post); System.exit(1); }
        System.out.println("2. Post-restore top x=" + post);

        s2.pop_modal();
        int mid = s2.get_x();
        if (mid != 42) { System.out.println("FAIL: mid " + mid); System.exit(1); }
        System.out.println("3. After first pop x=" + mid);

        s2.pop_modal();
        int bottom = s2.get_x();
        if (bottom != -99) { System.out.println("FAIL: bottom " + bottom); System.exit(1); }
        System.out.println("4. After second pop x=" + bottom);

        System.out.println("PASS: 60_persist_hsm_pushpop");
    }
}

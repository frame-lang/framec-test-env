@@target gdscript
extends SceneTree

# Test 42: HSM Three-Level Hierarchy
#
# Tests 3+ level deep hierarchies:
# - $Grandchild => $Child => $Parent
# - Forward through multiple levels
# - Each level's state variables remain isolated

@@system HSMThreeLevels {
    interface:
        handle_at_grandchild()
        forward_to_child()
        forward_to_parent()
        forward_through_all()
        get_log(): list

    machine:
        $Grandchild => $Child {
            $.grandchild_var: int = 1

            handle_at_grandchild() {
                var val = $.grandchild_var
                self.log.append("Grandchild:handled(var=" + str(val) + ")")
            }

            forward_to_child() {
                self.log.append("Grandchild:forward_to_child")
                => $^
            }

            forward_to_parent() {
                self.log.append("Grandchild:forward_to_parent")
                => $^
            }

            forward_through_all() {
                self.log.append("Grandchild:forward_through_all")
                => $^
            }

            get_log(): list {
                @@:(self.log)
                return
            }
        }

        $Child => $Parent {
            $.child_var: int = 10

            forward_to_child() {
                val = $.child_var
                self.log.append("Child:handled(var=" + str(val) + ")")
            }

            forward_to_parent() {
                val = $.child_var
                self.log.append("Child:forward_to_parent(var=" + str(val) + ")")
                => $^
            }

            forward_through_all() {
                val = $.child_var
                self.log.append("Child:forward_through_all(var=" + str(val) + ")")
                => $^
            }

            get_log(): list {
                @@:(self.log)
                return
            }
        }

        $Parent {
            $.parent_var: int = 100

            forward_to_parent() {
                val = $.parent_var
                self.log.append("Parent:handled(var=" + str(val) + ")")
            }

            forward_through_all() {
                val = $.parent_var
                self.log.append("Parent:forward_through_all(var=" + str(val) + ")")
            }

            get_log(): list {
                @@:(self.log)
                return
            }
        }
    domain:
        log: list = []
}

func main():
    print("=== Test 42: HSM Three-Level Hierarchy ===")
    var s = @@HSMThreeLevels()

    # TC1.2.1: Three-level hierarchy compiles
    print("TC1.2.1: Three-level hierarchy compiles - PASS")

    # TC1.2.2: Handle at grandchild (no forward)
    s.handle_at_grandchild()
    var log = s.get_log()
    assert("Grandchild:handled(var=1)" in log, "Expected Grandchild handler, got " + str(log))
    print("TC1.2.2: Grandchild handles locally - PASS")

    # TC1.2.3: Forward from grandchild to child
    s.forward_to_child()
    log = s.get_log()
    assert("Grandchild:forward_to_child" in log, "Expected Grandchild forward, got " + str(log))
    assert("Child:handled(var=10)" in log, "Expected Child handler, got " + str(log))
    print("TC1.2.3: Forward grandchild->child - PASS")

    # TC1.2.4: Forward from grandchild through child to parent
    s.forward_to_parent()
    log = s.get_log()
    assert("Grandchild:forward_to_parent" in log, "Expected Grandchild forward, got " + str(log))
    assert("Child:forward_to_parent(var=10)" in log, "Expected Child forward, got " + str(log))
    assert("Parent:handled(var=100)" in log, "Expected Parent handler, got " + str(log))
    print("TC1.2.4: Forward grandchild->child->parent - PASS")

    # TC1.2.5: Forward through entire chain
    s.forward_through_all()
    log = s.get_log()
    assert("Grandchild:forward_through_all" in log, "Expected Grandchild, got " + str(log))
    assert("Child:forward_through_all(var=10)" in log, "Expected Child, got " + str(log))
    assert("Parent:forward_through_all(var=100)" in log, "Expected Parent, got " + str(log))
    print("TC1.2.5: Full chain forward - PASS")

    # Verify state variable isolation
    print("TC1.2.6: State vars isolated (grandchild=1, child=10, parent=100) - PASS")

    print("PASS: HSM three-level hierarchy works correctly")

func _init():
    main()
    quit()

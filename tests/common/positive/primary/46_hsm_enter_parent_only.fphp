<?php
@@[target("php")]

// Test 46: HSM Enter Cascade — Parent has $>, Child does not
//
// Tests the HSM enter cascade per docs/frame_runtime_introduction.md
// Step 21+. When entering an HSM child, the kernel fires $> on every
// layer of the new chain top-down (parent first, child last). The child
// may have no $> handler — the cascade simply skips that layer and
// continues.

@@system HSMEnterParentOnly {
    interface:
        go_to_child()
        go_to_parent()
        get_log(): list
        get_state(): str

    machine:
        $Start {
            go_to_child() { -> $Child }
            go_to_parent() { -> $Parent }
            get_log(): list { @@:($this->log) }
            get_state(): str { @@:("Start") }
        }

        $Child => $Parent {
            go_to_parent() { -> $Parent }
            get_log(): list { @@:($this->log) }
            get_state(): str { @@:("Child") }
            => $^   // RFC-0019: forward the unhandled $> to $Parent
        }

        $Parent {
            $>() { $this->log[] = "Parent:enter"; }
            go_to_child() { -> $Child }
            get_log(): list { @@:($this->log) }
            get_state(): str { @@:("Parent") }
        }
    domain:
        log = []
}

echo "=== Test 46: HSM Enter Cascade — Parent only ===\n";
$s = @@HSMEnterParentOnly();

$s->go_to_child();
if ($s->get_state() !== "Child") { echo "FAIL\n"; exit(1); }
$log = $s->get_log();
if (!in_array("Parent:enter", $log)) { echo "FAIL: Expected Parent:enter on cascade\n"; exit(1); }
echo "TC1: Parent's \$> fires on cascade entry to Child - PASS\n";

$s->go_to_parent();
$log = $s->get_log();
$count = count(array_filter($log, function($v) { return $v === "Parent:enter"; }));
if ($count !== 2) { echo "FAIL: Expected 2 Parent:enter, got $count\n"; exit(1); }
echo "TC2: Parent's \$> fires again when transitioning directly to Parent - PASS\n";

$s->go_to_child();
$log = $s->get_log();
$count = count(array_filter($log, function($v) { return $v === "Parent:enter"; }));
if ($count !== 3) { echo "FAIL: Expected 3 Parent:enter, got $count\n"; exit(1); }
echo "TC3: Re-entering Child cascades through Parent again - PASS\n";

echo "PASS: HSM enter cascade fires Parent's \$> on child entry\n";

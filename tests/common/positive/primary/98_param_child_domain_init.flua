@@[target("lua")]

-- RFC-0017 regression: see .fpy header.

@@system Counter(seed: int) {
    interface:
        bump()
        get_value(): int
    machine:
        $S {
            $> { self.n = self.seed }
            bump() { self.n = self.n + 1 }
            get_value(): int { @@:(self.n) }
        }
    domain:
        seed = seed
        n = 0
}

@@[main]
@@system World {
    interface:
        bump_c()
        bump_d()
        get_c(): int
        get_d(): int
    machine:
        $S {
            bump_c() { self.c:bump() }
            bump_d() { self.d:bump() }
            get_c(): int { @@:(self.c:get_value()) }
            get_d(): int { @@:(self.d:get_value()) }
        }
    domain:
        c = @@Counter(7)
        d = @@Counter(11)
}

local w = @@World()
if w:get_c() ~= 7 then print("FAIL initial c: " .. w:get_c()); os.exit(1) end
if w:get_d() ~= 11 then print("FAIL initial d: " .. w:get_d()); os.exit(1) end
w:bump_c()
w:bump_d()
if w:get_c() ~= 8 then print("FAIL bump_c: " .. w:get_c()); os.exit(1) end
if w:get_d() ~= 12 then print("FAIL bump_d: " .. w:get_d()); os.exit(1) end
print("PASS: 98_param_child_domain_init")

@@[target("ruby")]

@@system HsmFourLevel {
    interface:
        drive(): int
        write_at_level(level: int)
        get_n(): int

    machine:
        $Leaf => $Mid {
            drive(): int {
                => $^
            }
            write_at_level(level: int) {
                self.n = self.n + level * 1
                => $^
            }
            get_n(): int {
                @@:(self.n)
                return
            }
        }

        $Mid => $Branch {
            drive(): int {
                => $^
            }
            write_at_level(level: int) {
                self.n = self.n + level * 10
                => $^
            }
        }

        $Branch => $Root {
            drive(): int {
                => $^
            }
            write_at_level(level: int) {
                self.n = self.n + level * 100
                => $^
            }
        }

        $Root {
            drive(): int {
                @@:(self.n)
                return
            }
            write_at_level(level: int) {
                self.n = self.n + level * 1000
            }
        }
    domain:
        n: int = 0
}

puts("=== Test 61: 4-level HSM cascade (Ruby) ===")
s = @@HsmFourLevel()

initial = s.drive()
raise "Expected 0 initial, got #{initial}" unless initial == 0
puts("1. Initial drive returned #{initial}")

s.write_at_level(2)
after = s.get_n()
raise "Expected 2222, got #{after}" unless after == 2222
puts("2. After cascading write: n=#{after}")

final = s.drive()
raise "Expected 2222 final, got #{final}" unless final == 2222
puts("3. Drive after write returned #{final}")

puts("PASS: 61_hsm_four_level")

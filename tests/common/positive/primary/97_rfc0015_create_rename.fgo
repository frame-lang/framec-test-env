@@[target("go")]

package main

import "fmt"

@@[create(make)]
@@system Counter(seed: int) {
    interface:
        Bump()
        GetValue(): int

    machine:
        $A {
            Bump() { s.count = s.count + 1 }
            GetValue(): int { @@:(s.count) }
        }

    domain:
        seed: int = seed
        count: int = 0
}

func main() {
    c1 := NewCounter(42)
    c1.Bump()
    c1.Bump()
    if c1.GetValue() != 2 {
        fmt.Printf("FAIL: via NewCounter expected 2, got %d\n", c1.GetValue())
        return
    }

    c2 := Make(99)
    c2.Bump()
    if c2.GetValue() != 1 {
        fmt.Printf("FAIL: via Make expected 1, got %d\n", c2.GetValue())
        return
    }

    fmt.Println("PASS: rfc0015_create_rename")
}

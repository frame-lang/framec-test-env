@@[target("java")]

import java.util.*;

@@[persist]
@@system PersistPushpopStateArgs {
    operations:
        @@[save]
        save_state(): String {}

        @@[load]
        restore_state(data: String) {}

    interface:
        push_modal(v: int)
        pop_modal()
        get_slot(): int

    machine:
        $Idle {
            push_modal(v: int) {
                push$
                -> $Modal(v)
            }
            pop_modal() {
                -> pop$
            }
            get_slot(): int {
                @@:(-99)
            }
        }

        $Modal(slot: int) {
            push_modal(v: int) {
                push$
                -> $Modal(v)
            }
            pop_modal() {
                -> pop$
            }
            get_slot(): int {
                @@:(slot)
            }
        }
    domain:
        v : int = 0
}

class Main {
    public static void main(String[] args) {
        System.out.println("=== Test 58: Persist × push/pop × state-args (Java) ===");
        var s1 = new PersistPushpopStateArgs();
        s1.push_modal(42);
        s1.push_modal(77);
        int pre = s1.get_slot();
        if (pre != 77) { System.out.println("FAIL: pre " + pre); System.exit(1); }
        System.out.println("1. Pre-save top slot=" + pre);

        String snap = s1.save_state();
        var s2 = new PersistPushpopStateArgs();

        s2.restore_state(snap);
        int post = s2.get_slot();
        if (post != 77) { System.out.println("FAIL: post " + post); System.exit(1); }
        System.out.println("2. Post-restore top slot=" + post);

        s2.pop_modal();
        int mid = s2.get_slot();
        if (mid != 42) { System.out.println("FAIL: mid " + mid); System.exit(1); }
        System.out.println("3. After first pop slot=" + mid);

        s2.pop_modal();
        int bottom = s2.get_slot();
        if (bottom != -99) { System.out.println("FAIL: bottom " + bottom); System.exit(1); }
        System.out.println("4. After second pop slot=" + bottom);

        System.out.println("PASS: 58_persist_pushpop_state_args");
    }
}

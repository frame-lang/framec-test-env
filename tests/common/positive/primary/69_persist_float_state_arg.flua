@@[target("lua")]
@@[persist(string)]
@@[save(save_state)]
@@[load(restore_state)]

@@system PFloat {
    interface:
        configure(rate: float)
        get_rate(): float

    machine:
        $Idle {
            configure(rate: float) {
                -> $Active(rate)
            }
            get_rate(): float {
                @@:(0.0)
                return
            }
        }

        $Active(rate: float) {
            get_rate(): float {
                @@:(rate)
                return
            }
        }
    domain:
        n: int = 0
}

local s = @@PFloat()
s:configure(3.14159)
local snap = s:save_state()
local s2 = @@PFloat()

s2:restore_state(snap)
local r = s2:get_rate()
if math.abs(r - 3.14159) > 1e-9 then error("FAIL " .. tostring(r)) end
print("PASS: 69_persist_float_state_arg, rate=" .. tostring(r))

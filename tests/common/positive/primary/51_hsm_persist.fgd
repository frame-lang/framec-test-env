@@[target("gdscript")]
extends SceneTree

# Test 51: HSM Persistence
#
# Tests that HSM parent compartment chain is properly saved and restored:
# - Child state vars preserved
# - Parent state vars preserved
# - Parent compartment chain intact after restore
# - Forwarding to parent still works after restore

@@[persist(String)]
@@[save(save_state)]
@@[load(restore_state)]
@@system HSMPersist {
    interface:
        increment_child()
        increment_parent()
        get_child_count(): int
        get_parent_count(): int
        get_state(): String

    machine:
        $Child => $Parent {
            $.child_count: int = 0

            increment_child() {
                $.child_count = $.child_count + 1
            }

            increment_parent() {
                # Forward to parent
                => $^
            }

            get_child_count(): int {
                @@:($.child_count)
                return
            }

            get_parent_count(): int {
                # Forward to parent
                => $^
            }

            get_state(): String {
                @@:("Child")
                return
            }
        }

        $Parent {
            $.parent_count: int = 100

            increment_parent() {
                $.parent_count = $.parent_count + 1
            }

            get_parent_count(): int {
                @@:($.parent_count)
                return
            }

            get_state(): String {
                @@:("Parent")
                return
            }
        }
}

func main():
    print("=== Test 51: HSM Persistence ===")

    # Create system and modify state vars at both levels
    var s1 = @@HSMPersist()

    # Verify initial state
    assert(s1.get_state() == "Child", "Expected Child, got " + str(s1.get_state()))
    assert(s1.get_child_count() == 0, "Expected 0, got " + str(s1.get_child_count()))
    assert(s1.get_parent_count() == 100, "Expected 100, got " + str(s1.get_parent_count()))
    print("1. Initial state verified: Child with child_count=0, parent_count=100")

    # Modify state vars at both levels
    s1.increment_child()
    s1.increment_child()
    s1.increment_child()  # child_count = 3
    s1.increment_parent()
    s1.increment_parent()  # parent_count = 102

    assert(s1.get_child_count() == 3, "Expected 3, got " + str(s1.get_child_count()))
    assert(s1.get_parent_count() == 102, "Expected 102, got " + str(s1.get_parent_count()))
    print("2. After increments: child_count=" + str(s1.get_child_count()) + ", parent_count=" + str(s1.get_parent_count()))

    # Save state
    var data = s1.save_state()
    assert(typeof(data) == TYPE_PACKED_BYTE_ARRAY, "Expected bytes, got " + str(typeof(data)))
    print("3. Saved state: " + str(data.size()) + " bytes")

    # Restore to new instance
    var s2 = HSMPersist.new()

    s2.restore_state(data)

    # Verify restored state
    assert(s2.get_state() == "Child", "Expected Child after restore, got " + str(s2.get_state()))
    print("4. Restored state: " + str(s2.get_state()))

    # Verify child state var preserved
    assert(s2.get_child_count() == 3, "Expected child_count=3, got " + str(s2.get_child_count()))
    print("5. Child state var preserved: child_count=" + str(s2.get_child_count()))

    # Verify parent state var preserved (requires parent compartment chain)
    assert(s2.get_parent_count() == 102, "Expected parent_count=102, got " + str(s2.get_parent_count()))
    print("6. Parent state var preserved: parent_count=" + str(s2.get_parent_count()))

    # Verify state machine still works after restore
    s2.increment_child()
    s2.increment_parent()
    assert(s2.get_child_count() == 4, "Expected 4, got " + str(s2.get_child_count()))
    assert(s2.get_parent_count() == 103, "Expected 103, got " + str(s2.get_parent_count()))
    print("7. After post-restore increments: child_count=" + str(s2.get_child_count()) + ", parent_count=" + str(s2.get_parent_count()))

    print("PASS: HSM persistence works correctly")

func _init():
    main()
    quit()

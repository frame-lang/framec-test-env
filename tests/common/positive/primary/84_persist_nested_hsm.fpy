@@[target("python_3")]

# Wave 8: nested-system × HSM × persist. Both Outer and Inner have HSM.
# Inner: $B is child of $A. Outer: $Active is child of $Idle.
# Three save points exercise: (T0) initial state, (T1) after tick
# transitions outer to $Active, (T2) after cycle_inner mutates inner.
# Restored instances must continue driving correctly. Idempotence:
# save→restore→save→restore must yield identical observables.

@@[persist(bytes)]
@@[save(save_state)]
@@[load(restore_state)]
@@system Inner {
    interface:
        cycle()
        get_state(): str
        get_count(): int

    machine:
        $A {
            cycle() {
                self.n = self.n + 1
                -> $B
            }
            get_state(): str { @@:("A"); return }
            get_count(): int { @@:(self.n); return }
        }
        $B => $A {
            cycle() { -> $A }
            get_state(): str { @@:("B"); return }
            get_count(): int { => $^ }
        }
    domain:
        n: int = 0
}

@@[main]
@@system Outer {
    operations:
        @@[save]
        save_state(): bytes {}

        @@[load]
        restore_state(data: bytes) {}

    interface:
        tick()
        cycle_inner()
        get_outer_state(): str
        get_inner_state(): str
        get_inner_count(): int
        get_k(): int

    machine:
        $Idle {
            tick() {
                self.k = self.k + 1
                -> $Active
            }
            cycle_inner() { self.inner.cycle() }
            get_outer_state(): str { @@:("Idle"); return }
            get_inner_state(): str { @@:(self.inner.get_state()); return }
            get_inner_count(): int { @@:(self.inner.get_count()); return }
            get_k(): int { @@:(self.k); return }
        }
        $Active => $Idle {
            tick() { -> $Idle }
            get_outer_state(): str { @@:("Active"); return }
            cycle_inner() { => $^ }
            get_inner_state(): str { => $^ }
            get_inner_count(): int { => $^ }
            get_k(): int { => $^ }
        }
    domain:
        k: int = 0
        inner = @@Inner()
}

if __name__ == '__main__':
    def probe(o):
        return (o.get_outer_state(), o.get_inner_state(), o.get_inner_count(), o.get_k())

    # T0: fresh
    o = Outer()
    assert probe(o) == ("Idle", "A", 0, 0), f"T0 fresh: {probe(o)}"
    snap0 = o.save_state()
    r0 = Outer()

    r0.restore_state(snap0)
    assert probe(r0) == ("Idle", "A", 0, 0), f"T0 restored: {probe(r0)}"

    # T1: after tick — outer transitions $Idle→$Active, k increments
    o.tick()
    assert probe(o) == ("Active", "A", 0, 1), f"T1: {probe(o)}"
    snap1 = o.save_state()
    r1 = Outer()

    r1.restore_state(snap1)
    assert probe(r1) == ("Active", "A", 0, 1), f"T1 restored: {probe(r1)}"

    # T2: after cycle_inner — $Active forwards to $Idle which calls
    # inner.cycle(); inner $A.cycle increments n then -> $B. Outer
    # stays in $Active because forward returns through parent body.
    o.cycle_inner()
    assert probe(o) == ("Active", "B", 1, 1), f"T2: {probe(o)}"
    snap2 = o.save_state()
    r2 = Outer()

    r2.restore_state(snap2)
    assert probe(r2) == ("Active", "B", 1, 1), f"T2 restored: {probe(r2)}"

    # Idempotence: save→restore→save→restore must yield identical
    # observables. (JSON-byte equality is not portable; observation
    # equality is the contract we care about.)
    snap2b = r2.save_state()
    r2b = Outer()

    r2b.restore_state(snap2b)
    assert probe(r2b) == probe(r2), f"Idempotence: {probe(r2b)} != {probe(r2)}"

    # Continuation: drive the restored instance — proves compartments,
    # state-stack, parent-chain are all live, not just deserialized.
    r2.cycle_inner()  # inner $B.cycle → -> $A; n unchanged
    assert probe(r2) == ("Active", "A", 1, 1), f"continue1: {probe(r2)}"
    r2.tick()         # $Active.tick → -> $Idle
    assert probe(r2) == ("Idle", "A", 1, 1), f"continue2: {probe(r2)}"
    r2.tick()         # $Idle.tick → k++, -> $Active
    assert probe(r2) == ("Active", "A", 1, 2), f"continue3: {probe(r2)}"

    print("PASS: 84_persist_nested_hsm")

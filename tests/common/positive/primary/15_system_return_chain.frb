@@target ruby

# Tests that @@:return follows "last writer wins" across transition lifecycle

@@system SystemReturnChainTest {
    interface:
        test_enter_sets(): str
        test_exit_then_enter(): str
        get_state(): str

    machine:
        $Start {
            test_enter_sets(): str {
                -> $EnterSetter
            }

            test_exit_then_enter(): str {
                -> $BothSet
            }

            get_state(): str {
                @@:("Start")
                return
            }

            <$() {
                # Exit handler sets initial value
                @@:("from_exit")
            }
        }

        $EnterSetter {
            $>() {
                # Enter handler sets return value
                @@:("from_enter")
            }

            get_state(): str {
                @@:("EnterSetter")
                return
            }
        }

        $BothSet {
            $>() {
                # Enter handler sets return - should overwrite exit's value
                @@:("enter_wins")
            }

            get_state(): str {
                @@:("BothSet")
                return
            }
        }
}

puts("=== Test 15: System Return Chain (Last Writer Wins) ===")

# Test 1: Start exit + EnterSetter enter
# Start's exit sets "from_exit", EnterSetter's enter sets "from_enter"
# Enter should win (last writer)
s1 = SystemReturnChainTest.new
result = s1.test_enter_sets()
raise "Expected 'from_enter', got '#{result}'" unless result == "from_enter"
raise "Expected state 'EnterSetter'" unless s1.get_state() == "EnterSetter"
puts("1. Exit set then enter set - enter wins: '#{result}'")

# Test 2: Both handlers set, enter wins
s2 = SystemReturnChainTest.new
result = s2.test_exit_then_enter()
raise "Expected 'enter_wins', got '#{result}'" unless result == "enter_wins"
raise "Expected state 'BothSet'" unless s2.get_state() == "BothSet"
puts("2. Both set - enter wins: '#{result}'")

puts("PASS: System return chain (last writer wins) works correctly")

@@target gdscript

@@system SystemReturnTest {
    interface:
        add(a: int, b: int): int
        multiply(a: int, b: int): int
        greet(name: str): str
        get_value(): int

    machine:
        $Calculator {
            $.value: int = 0

            add(a: int, b: int): int {
                @@:(a + b)
                return
            }

            multiply(a: int, b: int): int {
                @@:return = a * b
            }

            greet(name: str): str {
                @@:("Hello, " + name + "!")
                return
            }

            get_value(): int {
                $.value = 42
                @@:($.value)
                return
            }
        }
}

func main():
    print("=== Test 13: System Return ===")
    calc = @@SystemReturnTest()

    # Test return sugar
    result = calc.add(3, 5)
    assert(result == 8, "Expected 8, got " + str(result))
    print("add(3, 5) = " + str(result))

    # Test @@:return = expr
    result = calc.multiply(4, 7)
    assert(result == 28, "Expected 28, got " + str(result))
    print("multiply(4, 7) = " + str(result))

    # Test string return
    greeting = calc.greet("World")
    assert(greeting == "Hello, World!", "Expected 'Hello, World!', got '" + str(greeting) + "'")
    print("greet('World') = " + str(greeting))

    # Test return with state variable
    value = calc.get_value()
    assert(value == 42, "Expected 42, got " + str(value))
    print("get_value() = " + str(value))

    print("PASS: System return works correctly")

func _ready():
    main()

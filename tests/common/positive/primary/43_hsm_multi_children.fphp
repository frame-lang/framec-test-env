<?php
@@[target("php")]

@@system HSMMultiChildren {
    interface:
        start_a()
        start_b()
        start_c()
        do_action()
        forward_action()
        get_log(): list
        get_state(): str

    machine:
        $ChildA => $Parent {
            start_a() { }
            start_b() {
                -> $ChildB
            }
            start_c() {
                -> $ChildC
            }
            do_action() {
                $this->log[] = "ChildA:do_action";
            }
            forward_action() {
                $this->log[] = "ChildA:forward_action";
                => $^
            }
            get_log(): list {
                @@:($this->log)
                return;
            }
            get_state(): str {
                @@:("ChildA")
                return;
            }
        }

        $ChildB => $Parent {
            start_a() {
                -> $ChildA
            }
            start_b() { }
            start_c() {
                -> $ChildC
            }
            do_action() {
                $this->log[] = "ChildB:do_action";
            }
            forward_action() {
                $this->log[] = "ChildB:forward_action";
                => $^
            }
            get_log(): list {
                @@:($this->log)
                return;
            }
            get_state(): str {
                @@:("ChildB")
                return;
            }
        }

        $ChildC => $Parent {
            start_a() {
                -> $ChildA
            }
            start_b() {
                -> $ChildB
            }
            start_c() { }
            do_action() {
                $this->log[] = "ChildC:do_action";
            }
            forward_action() {
                $this->log[] = "ChildC:forward_action";
                => $^
            }
            get_log(): list {
                @@:($this->log)
                return;
            }
            get_state(): str {
                @@:("ChildC")
                return;
            }
        }

        $Parent {
            forward_action() {
                $this->log[] = "Parent:forward_action";
            }
            get_log(): list {
                @@:($this->log)
                return;
            }
            get_state(): str {
                @@:("Parent")
                return;
            }
        }
    domain:
        log = []
}

echo "=== Test 43: HSM Multiple Children ===" . "\n";
$s = @@HSMMultiChildren();

if ($s->get_state() !== "ChildA") { echo "FAIL\n"; exit(1); }

$s->forward_action();
$log = $s->get_log();
if (!in_array("ChildA:forward_action", $log)) { echo "FAIL\n"; exit(1); }
if (!in_array("Parent:forward_action", $log)) { echo "FAIL\n"; exit(1); }
echo "TC1.3.2: ChildA forwards to parent - PASS" . "\n";

$s->start_b();
if ($s->get_state() !== "ChildB") { echo "FAIL\n"; exit(1); }
echo "TC1.3.3: Transition A->B works - PASS" . "\n";

$s->forward_action();
$log = $s->get_log();
if (!in_array("ChildB:forward_action", $log)) { echo "FAIL\n"; exit(1); }
$parent_count = count(array_filter($log, function($v) { return $v === "Parent:forward_action"; }));
if ($parent_count !== 2) { echo "FAIL\n"; exit(1); }
echo "TC1.3.4: ChildB forwards to same parent - PASS" . "\n";

$s->start_c();
if ($s->get_state() !== "ChildC") { echo "FAIL\n"; exit(1); }
$s->forward_action();
$log = $s->get_log();
if (!in_array("ChildC:forward_action", $log)) { echo "FAIL\n"; exit(1); }
echo "TC1.3.5: ChildC forwards to same parent - PASS" . "\n";

$s->start_a();
$s->do_action();
$s->start_b();
$s->do_action();
$s->start_c();
$s->do_action();
$log = $s->get_log();
if (!in_array("ChildA:do_action", $log)) { echo "FAIL\n"; exit(1); }
if (!in_array("ChildB:do_action", $log)) { echo "FAIL\n"; exit(1); }
if (!in_array("ChildC:do_action", $log)) { echo "FAIL\n"; exit(1); }
echo "TC1.3.6: Each sibling has independent handlers - PASS" . "\n";

echo "PASS: HSM multiple children work correctly" . "\n";

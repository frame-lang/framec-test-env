@@target dart

@@system TransitionExitArgs {
    interface:
        leave()
        get_log(): String[]

    machine:
        $Active {
            <$(reason: String, code: int) {
                this.log.add("exit:${reason}:${code}");
            }

            leave() {
                this.log.add("leaving");
                ("cleanup", 42) -> $Done
            }

            get_log(): String[] {
                @@:(this.log)
                return;
            }
        }

        $Done {
            $>() {
                this.log.add("enter:done");
            }

            get_log(): String[] {
                @@:(this.log)
                return;
            }
        }
    domain:
        log: String[] = []
}

void main() {
    print("== Test 18: Transition Exit Args ==");
    final s = @@TransitionExitArgs();

    // Initial state is Active
    var log = s.get_log();
    if (log.length != 0) {
        throw Exception("Expected empty log, got ${jsonEncode(log)}");
    }

    // Leave - should call exit handler with args
    s.leave();
    log = s.get_log();
    if (!log.includes("leaving")) {
        throw Exception("Expected 'leaving' in log, got ${jsonEncode(log)}");
    }
    if (!log.includes("exit:cleanup:42")) {
        throw Exception("Expected 'exit:cleanup:42' in log, got ${jsonEncode(log)}");
    }
    if (!log.includes("enter:done")) {
        throw Exception("Expected 'enter:done' in log, got ${jsonEncode(log)}");
    }
    print("Log after transition: ${jsonEncode(log)}");

    print("PASS: Transition exit args work correctly");
}


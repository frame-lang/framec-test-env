@@target gdscript

@@system StateVarBasic {
    interface:
        increment(): int
        get_count(): int
        reset()

    machine:
        $Counter {
            $.count: int = 0

            increment(): int {
                $.count = $.count + 1
                @@:($.count)
                return
            }

            get_count(): int {
                @@:($.count)
                return
            }

            reset() {
                $.count = 0
            }
        }
}

func main():
    print("=== Test 10: State Variable Basic ===")
    s = @@StateVarBasic()

    # Initial value should be 0
    assert(s.get_count() == 0, "Expected 0, got " + str(s.get_count()))
    print("Initial count: " + str(s.get_count()))

    # Increment should return new value
    result = s.increment()
    assert(result == 1, "Expected 1 after first increment, got " + str(result))
    print("After first increment: " + str(result))

    # Second increment
    result = s.increment()
    assert(result == 2, "Expected 2 after second increment, got " + str(result))
    print("After second increment: " + str(result))

    # Reset should set back to 0
    s.reset()
    assert(s.get_count() == 0, "Expected 0 after reset, got " + str(s.get_count()))
    print("After reset: " + str(s.get_count()))

    print("PASS: State variable basic operations work correctly")

func _ready():
    main()

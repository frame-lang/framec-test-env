@@[target("csharp")]

using System;

@@system PushSelf {
    interface:
        enter_modal()
        ping(): int
        exit_modal()
        compute(): int

    machine:
        $Idle {
            enter_modal() { push$; -> $Modal }
            ping(): int { @@:(0) }
            compute(): int { @@:(99) }
        }
        $Modal {
            ping(): int { @@:(this.compute() + 1) }
            compute(): int { @@:(10) }
            exit_modal() { -> pop$ }
        }
    domain: n : int = 0
}

class Program {
    static void Main(string[] args) {
        var s = new PushSelf();
        if (s.ping() != 0) { Console.WriteLine("FAIL idle"); Environment.Exit(1); }
        s.enter_modal();
        int r = s.ping();
        if (r != 11) { Console.WriteLine($"FAIL modal {r}"); Environment.Exit(1); }
        s.exit_modal();
        if (s.ping() != 0) { Console.WriteLine("FAIL back"); Environment.Exit(1); }
        Console.WriteLine("PASS: 72_push_self_call");
    }
}

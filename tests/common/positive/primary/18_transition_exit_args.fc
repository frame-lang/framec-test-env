@@target c

@@system TransitionExitArgs {
    interface:
        leave(): void
        get_exit_code(): int

    machine:
        $Active {
            <$(reason: char*, code: int) {
                printf("exit:reason=%s,code=%d\n", reason, code);
                self->exit_code = code;
            }

            leave() {
                printf("leaving\n");
                ("cleanup", 42) -> $Done
            }

            get_exit_code(): int {
                return self->exit_code;
            }
        }

        $Done {
            $>() {
                printf("enter:done\n");
                self->enter_done = 1;
            }

            get_exit_code(): int {
                return self->exit_code;
            }
        }
    domain:
        int exit_code
        int enter_done
}

int main() {
    printf("=== Test 18: Transition Exit Args ===\n");
    TransitionExitArgs* s = @@TransitionExitArgs();

    // Initial state is Active
    int code = TransitionExitArgs_get_exit_code(s);
    if (code != 0) {
        printf("FAIL: Expected 0 initially, got %d\n", code);
        return 1;
    }

    // Leave - should call exit handler with args
    TransitionExitArgs_leave(s);
    code = TransitionExitArgs_get_exit_code(s);
    if (code != 42) {
        printf("FAIL: Expected exit_code=42, got %d\n", code);
        return 1;
    }
    printf("After transition: exit_code = %d\n", code);

    printf("PASS: Transition exit args work correctly\n");
    TransitionExitArgs_destroy(s);
    return 0;
}

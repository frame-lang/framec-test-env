@@[target("dart")]

import 'dart:io';

@@system Demo {
    interface:
        get_a(): int
        get_dart_only(): int
    machine:
        $S {
            get_a(): int { @@:(this.a) }
            get_dart_only(): int { @@:(this.dart_only) }
        }
    domain:
        a: int = 1
        @@[target("python_3")] py_only: int = 2
        @@[target("dart")]
        dart_only: int = 42
}

void main() {
    var d = @@Demo();
    if (d.get_a() != 1) { print("FAIL get_a: ${d.get_a()}"); exit(1); }
    if (d.get_dart_only() != 42) { print("FAIL get_dart_only: ${d.get_dart_only()}"); exit(1); }
    print("PASS: 90_attribute_domain_field");
}

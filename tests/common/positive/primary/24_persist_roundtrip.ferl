@@target erlang
@@persist
@@system PersistRoundtrip {
    interface:
        goActive()
        goIdle()
        getState(): str
        setCounter(n: int)
        getCounter(): int
    machine:
        $Idle {
            goActive() { -> $Active }
            goIdle() { }
            getState(): str {
                @@:("idle")
            }
            setCounter(n: int) { self.counter = n }
            getCounter(): int {
                @@:(self.counter)
            }
        }
        $Active {
            goIdle() { -> $Idle }
            goActive() { }
            getState(): str {
                @@:("active")
            }
            setCounter(n: int) { self.counter = n }
            getCounter(): int {
                @@:(self.counter)
            }
        }
    domain:
        counter = 0
}

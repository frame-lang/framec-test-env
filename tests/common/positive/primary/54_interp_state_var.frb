@@[target("ruby")]

@@system InterpStress {
    interface:
        test_interp(): String
        test_standalone(): Integer
        test_return(): Integer
        test_multi(): String
        test_mixed(): String

    machine:
        $Active {
            $.count: Integer = 42
            $.label: String = "hello"

            test_interp(): String {
                @@:("count is #{$.count}")
                return;
            }

            test_standalone(): Integer {
                x = $.count + 1
                @@:(x)
                return;
            }

            test_return(): Integer {
                @@:($.count)
                return;
            }

            test_multi(): String {
                @@:("#{$.count} and #{$.label}")
                return;
            }

            test_mixed(): String {
                total = 100
                @@:("#{$.count}/#{total}")
                return;
            }
        }
}

s = InterpStress.new
failures = 0

r = s.test_interp()
if r != "count is 42"
    puts "FAIL interp: got '#{r}'"
    failures += 1
end

r = s.test_standalone()
if r != 43
    puts "FAIL standalone: got #{r}"
    failures += 1
end

r = s.test_return()
if r != 42
    puts "FAIL return: got #{r}"
    failures += 1
end

r = s.test_multi()
if r != "42 and hello"
    puts "FAIL multi: got '#{r}'"
    failures += 1
end

r = s.test_mixed()
if r != "42/100"
    puts "FAIL mixed: got '#{r}'"
    failures += 1
end

if failures > 0
    puts "FAIL: #{failures} failures"
    exit 1
end
puts "PASS: stress_interp (5 cases)"

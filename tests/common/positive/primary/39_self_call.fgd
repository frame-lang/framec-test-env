@@target gdscript
extends SceneTree

# Test: @@:self.method() — reentrant interface call with transition guard
#
# Validates:
# 1. Basic self-call dispatch (calls own interface method through kernel)
# 2. Return value propagation from self-call
# 3. Transition guard (code after self-call that transitions is suppressed)

@@system SelfCallTest {
    interface:
        calibrate(): String
        reading(): float
        trigger_transition()
        check_after_transition(): String
        status(): String

    machine:
        $Active {
            calibrate(): String {
                var baseline = self.reading()
                self.offset = baseline * -1
                @@:("calibrated:offset=" + str(self.offset))
            }

            reading(): float {
                @@:(self.raw_value + self.offset)
            }

            trigger_transition() {
                -> $Done
            }

            check_after_transition(): String {
                self.trace = "before"
                self.trigger_transition()
                # This line should NOT execute — transition guard suppresses it
                self.trace = "after"
                @@:(self.trace)
            }

            status(): String {
                @@:("active")
            }
        }

        $Done {
            status(): String {
                @@:("done")
            }
        }

    domain:
        raw_value: float = 42.0
        offset: float = 0.0
        trace: String = ""
}

func main():
    # Test 1: Self-call returns correct value
    var s = @@SelfCallTest()
    var result = s.calibrate()
    assert(result == "calibrated:offset=-42.0", "Expected 'calibrated:offset=-42.0', got '" + str(result) + "'")

    # Test 2: Self-call modified domain state correctly
    var r = s.reading()
    assert(r == 0.0, "Expected 0.0 after calibration, got " + str(r))

    # Test 3: Transition guard — code after self-call that transitions is suppressed
    var s2 = @@SelfCallTest()
    s2.check_after_transition()
    assert(s2.trace == "before", "Expected 'before' (guard suppressed 'after'), got '" + str(s2.trace) + "'")

    # Test 4: System transitioned to $Done
    assert(s2.status() == "done", "Expected 'done' after transition, got '" + str(s2.status()) + "'")

    print("PASS: self_call")

func _init():
    main()
    quit()

@@target java

import java.util.*;

// Test 46: HSM Enter Cascade — Parent has $>, Child does not
//
// Tests the HSM enter cascade per docs/frame_runtime_introduction.md
// Step 21+. When entering an HSM child, the kernel fires $> on every
// layer of the new chain top-down (parent first, child last). The child
// may have no $> handler — the cascade simply skips that layer and
// continues.

@@system HSMEnterParentOnly {
    interface:
        go_to_child()
        go_to_parent()
        get_log(): ArrayList
        get_state(): String

    machine:
        $Start {
            go_to_child() { -> $Child }
            go_to_parent() { -> $Parent }
            get_log(): ArrayList { @@:(this.log) }
            get_state(): String { @@:("Start") }
        }

        $Child => $Parent {
            go_to_parent() { -> $Parent }
            get_log(): ArrayList { @@:(this.log) }
            get_state(): String { @@:("Child") }
        }

        $Parent {
            $>() {
                this.log.add("Parent:enter");
            }
            go_to_child() { -> $Child }
            get_log(): ArrayList { @@:(this.log) }
            get_state(): String { @@:("Parent") }
        }
    domain:
        log : ArrayList = new ArrayList()
}

class Main {
    static int countOf(ArrayList log, String v) {
        int n = 0;
        for (Object item : log) if (item.equals(v)) n++;
        return n;
    }

    public static void main(String[] args) {
        System.out.println("=== Test 46: HSM Enter Cascade — Parent only ===");
        var s = @@HSMEnterParentOnly();

        s.go_to_child();
        if (!s.get_state().equals("Child")) { System.out.println("FAIL"); System.exit(1); }
        ArrayList log = s.get_log();
        if (!log.contains("Parent:enter")) { System.out.println("FAIL: Expected Parent:enter on cascade"); System.exit(1); }
        System.out.println("TC1: Parent's $> fires on cascade entry to Child - PASS");

        s.go_to_parent();
        log = s.get_log();
        if (countOf(log, "Parent:enter") != 2) { System.out.println("FAIL: Expected 2 Parent:enter"); System.exit(1); }
        System.out.println("TC2: Parent's $> fires again when transitioning directly to Parent - PASS");

        s.go_to_child();
        log = s.get_log();
        if (countOf(log, "Parent:enter") != 3) { System.out.println("FAIL: Expected 3 Parent:enter"); System.exit(1); }
        System.out.println("TC3: Re-entering Child cascades through Parent again - PASS");

        System.out.println("PASS: HSM enter cascade fires Parent's $> on child entry");
    }
}

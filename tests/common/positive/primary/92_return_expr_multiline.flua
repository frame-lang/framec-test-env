@@[target("lua")]

@@system Test {
    interface:
        ready(): boolean

    machine:
        $Active {
            ready(): boolean {
                @@:(self.timer >= self.threshold
                    and self.count < self.limit)
            }
        }
    domain:
        timer: number = 100
        threshold: number = 50
        count: number = 1
        limit: number = 5
}

local t = Test:new()
if t:ready() ~= true then
    print("FAIL ready(): " .. tostring(t:ready()))
else
    print("PASS: 92_return_expr_multiline")
end

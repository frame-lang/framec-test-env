@@[target("dart")]

import 'dart:io';

@@system StrStateArg {
    interface:
        configure(label: str)
        identify(): str

    machine:
        $Idle {
            configure(label: String) {
                -> $Active(label)
            }
            identify(): String {
                @@:("anonymous")
                return;
            }
        }

        $Active => $Frame(label: String) {
            configure(label: String) {
                -> $Active(label)
            }
            identify(): String {
                => $^
            }
        }

        $Frame {
            identify(): String {
                @@:(label)
                return;
            }
        }
    domain:
        n: int = 0
}

void main() {
    final s = @@StrStateArg();
    if (s.identify() != "anonymous") { print("FAIL idle"); exit(1); }
    s.configure("alice");
    if (s.identify() != "alice") { print("FAIL alice"); exit(1); }
    s.configure("bob");
    if (s.identify() != "bob") { print("FAIL bob"); exit(1); }
    print("PASS: 66_hsm_str_state_args");
}

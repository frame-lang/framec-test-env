@@[target("typescript")]

@@system InterpStress {
    interface:
        test_template(): string
        test_standalone(): number
        test_return(): number
        test_multi(): string
        test_mixed(): string

    machine:
        $Active {
            $.count: number = 42
            $.label: string = "hello"

            test_template(): string {
                @@:(`count is ${$.count}`)
                return;
            }

            test_standalone(): number {
                const x = $.count + 1;
                @@:(x)
                return;
            }

            test_return(): number {
                @@:($.count)
                return;
            }

            test_multi(): string {
                @@:(`${$.count} and ${$.label}`)
                return;
            }

            test_mixed(): string {
                const total = 100;
                @@:(`${$.count}/${total}`)
                return;
            }
        }
}

function main() {
    const s = @@InterpStress();
    let failures = 0;

    let r: any = s.test_template();
    if (r !== "count is 42") { console.log(`FAIL template: got '${r}'`); failures++; }

    r = s.test_standalone();
    if (r !== 43) { console.log(`FAIL standalone: got ${r}`); failures++; }

    r = s.test_return();
    if (r !== 42) { console.log(`FAIL return: got ${r}`); failures++; }

    r = s.test_multi();
    if (r !== "42 and hello") { console.log(`FAIL multi: got '${r}'`); failures++; }

    r = s.test_mixed();
    if (r !== "42/100") { console.log(`FAIL mixed: got '${r}'`); failures++; }

    if (failures > 0) {
        console.log(`FAIL: ${failures} failures`);
        process.exit(1);
    }
    console.log("PASS: stress_interp (5 cases)");
}

main();

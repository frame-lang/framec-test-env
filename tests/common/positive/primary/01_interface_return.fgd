@@target gdscript

# =============================================================================
# Test 01: Interface Return
# =============================================================================
# Validates that event handler returns work correctly via the context stack.
# Tests both syntaxes:
#   - return value     (sugar - expands to @@:return = value)
#   - @@:return = value (explicit context assignment)
# =============================================================================

@@system InterfaceReturn {
    interface:
        bool_return(): bool
        int_return(): int
        string_return(): str
        conditional_return(x: int): str
        computed_return(a: int, b: int): int
        explicit_bool(): bool
        explicit_int(): int
        explicit_string(): str
        explicit_conditional(x: int): str
        explicit_computed(a: int, b: int): int

    machine:
        $Active {
            bool_return(): bool {
                @@:(true)
                return
            }

            int_return(): int {
                @@:(42)
                return
            }

            string_return(): str {
                @@:("Frame")
                return
            }

            conditional_return(x: int): str {
                if x < 0:
                    @@:("negative")
                    return
                elif x == 0:
                    @@:("zero")
                    return
                else:
                    @@:("positive")
                    return
            }

            computed_return(a: int, b: int): int {
                result = a * b + 10
                @@:(result)
                return
            }

            explicit_bool(): bool {
                @@:return = true
            }

            explicit_int(): int {
                @@:return = 42
            }

            explicit_string(): str {
                @@:return = "Frame"
            }

            explicit_conditional(x: int): str {
                if x < 0:
                    @@:return = "negative"
                    return
                elif x == 0:
                    @@:return = "zero"
                    return
                else:
                    @@:return = "positive"
            }

            explicit_computed(a: int, b: int): int {
                result = a * b + 10
                @@:return = result
            }
        }
}

func main():
    print("=== Test 01: Interface Return (Python) ===")
    s = @@InterfaceReturn()
    errors = []

    print("-- Testing 'return value' sugar --")

    r = s.bool_return()
    if r != true:
        errors.append("bool_return: expected True, got " + str(r))
    else:
        print("1. bool_return() = " + str(r))

    r = s.int_return()
    if r != 42:
        errors.append("int_return: expected 42, got " + str(r))
    else:
        print("2. int_return() = " + str(r))

    r = s.string_return()
    if r != "Frame":
        errors.append("string_return: expected 'Frame', got '" + str(r) + "'")
    else:
        print("3. string_return() = '" + str(r) + "'")

    r = s.conditional_return(-5)
    if r != "negative":
        errors.append("conditional_return(-5): expected 'negative', got '" + str(r) + "'")
    r = s.conditional_return(0)
    if r != "zero":
        errors.append("conditional_return(0): expected 'zero', got '" + str(r) + "'")
    r = s.conditional_return(10)
    if r != "positive":
        errors.append("conditional_return(10): expected 'positive', got '" + str(r) + "'")
    else:
        print("4. conditional_return(-5,0,10) = 'negative','zero','positive'")

    r = s.computed_return(3, 4)
    if r != 22:
        errors.append("computed_return(3,4): expected 22, got " + str(r))
    else:
        print("5. computed_return(3,4) = " + str(r))

    print("-- Testing '@@:return = value' explicit --")

    r = s.explicit_bool()
    if r != true:
        errors.append("explicit_bool: expected True, got " + str(r))
    else:
        print("6. explicit_bool() = " + str(r))

    r = s.explicit_int()
    if r != 42:
        errors.append("explicit_int: expected 42, got " + str(r))
    else:
        print("7. explicit_int() = " + str(r))

    r = s.explicit_string()
    if r != "Frame":
        errors.append("explicit_string: expected 'Frame', got '" + str(r) + "'")
    else:
        print("8. explicit_string() = '" + str(r) + "'")

    r = s.explicit_conditional(-5)
    if r != "negative":
        errors.append("explicit_conditional(-5): expected 'negative', got '" + str(r) + "'")
    r = s.explicit_conditional(0)
    if r != "zero":
        errors.append("explicit_conditional(0): expected 'zero', got '" + str(r) + "'")
    r = s.explicit_conditional(10)
    if r != "positive":
        errors.append("explicit_conditional(10): expected 'positive', got '" + str(r) + "'")
    else:
        print("9. explicit_conditional(-5,0,10) = 'negative','zero','positive'")

    r = s.explicit_computed(3, 4)
    if r != 22:
        errors.append("explicit_computed(3,4): expected 22, got " + str(r))
    else:
        print("10. explicit_computed(3,4) = " + str(r))

    if errors:
        for e in errors:
            print("FAIL: " + str(e))
        push_error(str(errors.size()) + " test(s) failed")
    else:
        print("PASS: All interface return tests passed")

func _ready():
    main()

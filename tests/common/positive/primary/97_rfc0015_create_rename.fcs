@@[target("csharp")]
@@[create(make)]
@@system Counter(seed: int) {
    interface:
        Bump()
        Get(): int

    machine:
        $A {
            Bump() { this.count = this.count + 1; }
            Get(): int { @@:(this.count) }
        }

    domain:
        seed: int = seed
        count: int = 0
}

class Program {
    static void Main() {
        Counter c1 = @@Counter(42);
        c1.Bump();
        c1.Bump();
        if (c1.Get() != 2) {
            System.Console.WriteLine($"FAIL: via new Counter expected 2, got {c1.Get()}");
            return;
        }

        Counter c2 = Counter.make(99);
        c2.Bump();
        if (c2.Get() != 1) {
            System.Console.WriteLine($"FAIL: via Counter.make expected 1, got {c2.Get()}");
            return;
        }

        System.Console.WriteLine("PASS: rfc0015_create_rename");
    }
}

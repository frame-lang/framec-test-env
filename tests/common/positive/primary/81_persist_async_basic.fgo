@@[target("go")]
@@skip -- Go does not have async/await (uses goroutines/channels)

package main

import "fmt"

@@system PersistAsync {
    interface:
        configure(amount: int)
        get(): int

    machine:
        $Idle {
            configure(amount: int) { -> $Active }
            get(): int { @@:(0) }
        }
        $Active {
            get(): int { @@:(0) }
        }
}

func main() {
	fmt.Println("SKIP: 81_persist_async_basic -- Go does not have async/await")
}

@@target dart

@@system HSMDefaultForward {
    interface:
        handled_event()
        unhandled_event()
        get_log(): String[]

    machine:
        $Child => $Parent {
            handled_event() {
                this.log.add("Child:handled_event")
            }

            get_log(): String[] {
                @@:(this.log)
                return;
            }

            => $^
        }

        $Parent {
            handled_event() {
                this.log.add("Parent:handled_event")
            }

            unhandled_event() {
                this.log.add("Parent:unhandled_event")
            }

            get_log(): String[] {
                @@:(this.log)
                return;
            }
        }
    domain:
        log: String[] = []
}

void main(): void {
    print("== Test 30: HSM State-Level Default Forward ==");
    final s = @@HSMDefaultForward();

    s.handled_event();
    var log = s.get_log();
    if (!log.includes("Child:handled_event")) {
        throw Exception("Expected 'Child:handled_event' in log, got ${log}");
    }
    print("After handled_event: ${jsonEncode(log)}");

    s.unhandled_event();
    log = s.get_log();
    if (!log.includes("Parent:unhandled_event")) {
        throw Exception("Expected 'Parent:unhandled_event' in log (forwarded), got ${log}");
    }
    print("After unhandled_event (forwarded): ${jsonEncode(log)}");

    print("PASS: HSM state-level default forward works correctly");
}


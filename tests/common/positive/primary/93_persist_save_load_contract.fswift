@@[target("swift")]

@@[persist(String)]
@@[save(saveOp)]
@@[load(loadOp)]
@@system Counter {
    interface:
        bump()
        getN(): Int

    machine:
        $Active {
            bump() {
                self.n = self.n + 1
            }
            getN(): Int { @@:(self.n) }
        }

    domain:
        n: Int = 0
}

let c1 = @@Counter()
c1.bump()
c1.bump()
c1.bump()
let data = c1.saveOp()

let c2 = @@Counter()
c2.loadOp(data)
if c2.getN() != 3 {
    print("FAIL: expected 3, got \(c2.getN())")
} else {
    print("PASS: 93_persist_save_load_contract")
}

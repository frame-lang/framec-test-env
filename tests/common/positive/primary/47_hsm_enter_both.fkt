@@target kotlin

import kotlin.system.exitProcess

@@system HSMEnterBoth {
    interface:
        go_to_child()
        go_to_parent()
        get_log(): MutableList<Any?>
        get_state(): String

    machine:
        $Start {
            go_to_child() {
                -> $Child
            }

            go_to_parent() {
                -> $Parent
            }

            get_log(): MutableList<Any?> {
                @@:(this.log)
                return;
            }

            get_state(): String {
                @@:("Start")
                return;
            }
        }

        $Child => $Parent {
            $>() {
                this.log.add("Child:enter")
            }

            go_to_parent() {
                -> $Parent
            }

            get_log(): MutableList<Any?> {
                @@:(this.log)
                return;
            }

            get_state(): String {
                @@:("Child")
                return;
            }
        }

        $Parent {
            $>() {
                this.log.add("Parent:enter")
            }

            go_to_child() {
                -> $Child
            }

            get_log(): MutableList<Any?> {
                @@:(this.log)
                return;
            }

            get_state(): String {
                @@:("Parent")
                return;
            }
        }
    domain:
        log = mutableListOf<String>()
}

fun main() {
    println("=== Test 47: HSM Enter in Both ===")
    val s = @@HSMEnterBoth()

    // TC2.3.1: Only child's enter fires when entering child
    s.go_to_child()
    var log = s.get_log() as MutableList<*>
    if (!log.contains("Child:enter")) {
        println("FAIL: Expected Child:enter, got $log")
        exitProcess(1)
    }
    if (log.contains("Parent:enter")) {
        println("FAIL: Parent:enter should NOT fire when entering child, got $log")
        exitProcess(1)
    }
    if ((s.get_state() as String) != "Child") {
        println("FAIL: Expected Child, got ${s.get_state()}")
        exitProcess(1)
    }
    println("TC2.3.1: Only child's enter fires when entering child - PASS")

    // TC2.3.2: Parent's enter fires only when transitioning to parent
    s.go_to_parent()
    log = s.get_log() as MutableList<*>
    if (!log.contains("Parent:enter")) {
        println("FAIL: Expected Parent:enter, got $log")
        exitProcess(1)
    }
    if ((s.get_state() as String) != "Parent") {
        println("FAIL: Expected Parent, got ${s.get_state()}")
        exitProcess(1)
    }
    println("TC2.3.2: Parent's enter fires when transitioning to parent - PASS")

    // TC2.3.3: No implicit cascading - counts should be exactly 1 each
    var childCount = 0
    var parentCount = 0
    for (item in log) {
        if (item == "Child:enter") childCount++
        if (item == "Parent:enter") parentCount++
    }
    if (childCount != 1) {
        println("FAIL: Expected exactly 1 Child:enter, got $log")
        exitProcess(1)
    }
    if (parentCount != 1) {
        println("FAIL: Expected exactly 1 Parent:enter, got $log")
        exitProcess(1)
    }
    println("TC2.3.3: No implicit cascading of enter handlers - PASS")

    // TC2.3.4: Going back to child fires child enter again
    s.go_to_child()
    log = s.get_log() as MutableList<*>
    var childCount2 = 0
    var parentCount2 = 0
    for (item in log) {
        if (item == "Child:enter") childCount2++
        if (item == "Parent:enter") parentCount2++
    }
    if (childCount2 != 2) {
        println("FAIL: Expected 2 Child:enter, got $log")
        exitProcess(1)
    }
    if (parentCount2 != 1) {
        println("FAIL: Expected still 1 Parent:enter, got $log")
        exitProcess(1)
    }
    println("TC2.3.4: Re-entering child fires child enter again - PASS")

    println("PASS: HSM enter in both works correctly")
}

@@[target("kotlin")]

import kotlin.system.exitProcess

// Test 47: HSM Enter Cascade — Both Parent and Child have $>
//
// Tests the HSM enter cascade per docs/frame_runtime_introduction.md
// Step 21+. When entering an HSM child, the kernel fires $> on every
// layer of the new chain top-down (parent first, child last).

@@system HSMEnterBoth {
    interface:
        go_to_child()
        go_to_parent()
        get_log(): MutableList<Any?>
        get_state(): String

    machine:
        $Start {
            go_to_child() { -> $Child }
            go_to_parent() { -> $Parent }
            get_log(): MutableList<Any?> { @@:(this.log) }
            get_state(): String { @@:("Start") }
        }

        $Child => $Parent {
            $>() {
                => $^
                this.log.add("Child:enter")
            }
            go_to_parent() { -> $Parent }
            get_log(): MutableList<Any?> { @@:(this.log) }
            get_state(): String { @@:("Child") }
        }

        $Parent {
            $>() {
                this.log.add("Parent:enter")
            }
            go_to_child() { -> $Child }
            get_log(): MutableList<Any?> { @@:(this.log) }
            get_state(): String { @@:("Parent") }
        }
    domain:
        log = mutableListOf<String>()
}

fun countOf(log: MutableList<*>, v: String): Int {
    var n = 0
    for (item in log) if (item == v) n++
    return n
}
fun indexOf(log: MutableList<*>, v: String): Int {
    for (i in log.indices) if (log[i] == v) return i
    return -1
}

fun main() {
    println("=== Test 47: HSM Enter Cascade — Both ===")
    val s = @@HSMEnterBoth()

    s.go_to_child()
    var log = s.get_log() as MutableList<*>
    if ((s.get_state() as String) != "Child") { println("FAIL"); exitProcess(1) }
    val pi = indexOf(log, "Parent:enter")
    val ci = indexOf(log, "Child:enter")
    if (pi == -1) { println("FAIL: Expected Parent:enter"); exitProcess(1) }
    if (ci == -1) { println("FAIL: Expected Child:enter"); exitProcess(1) }
    if (pi >= ci) { println("FAIL: Parent:enter must precede Child:enter"); exitProcess(1) }
    println("TC1: Parent's \$> fires before Child's \$> on cascade entry - PASS")

    s.go_to_parent()
    log = s.get_log() as MutableList<*>
    if ((s.get_state() as String) != "Parent") { println("FAIL"); exitProcess(1) }
    if (countOf(log, "Parent:enter") != 2) { println("FAIL: Expected 2 Parent:enter"); exitProcess(1) }
    if (countOf(log, "Child:enter") != 1) { println("FAIL: Expected still 1 Child:enter"); exitProcess(1) }
    println("TC2: Direct Parent entry fires only Parent's \$> - PASS")

    s.go_to_child()
    log = s.get_log() as MutableList<*>
    if (countOf(log, "Parent:enter") != 3) { println("FAIL: Expected 3 Parent:enter"); exitProcess(1) }
    if (countOf(log, "Child:enter") != 2) { println("FAIL: Expected 2 Child:enter"); exitProcess(1) }
    println("TC3: Re-entering Child cascades through Parent again - PASS")

    println("PASS: HSM enter cascade fires both layers top-down")
}

@@target gdscript
extends SceneTree

@@system HsmIfStateArgs {
    interface:
        enter_active(t: int)
        classify(v: int): int

    machine:
        $Idle {
            enter_active(t: int) {
                -> $Active(t)
            }
            classify(v: int): int {
                @@:(-1)
            }
        }

        $Active => $Frame(threshold: int) {
            enter_active(t: int) {
                -> $Active(t)
            }
            classify(v: int): int {
                if v > threshold:
                    @@:(1)
                else:
                    @@:(0)
            }
        }

        $Frame {
        }
    domain:
        n: int = 0
}

func _initialize():
    print("=== Test 62: HSM × if × state-args (GDScript) ===")
    var s = HsmIfStateArgs.new()

    var pre = s.classify(5)
    if pre != -1:
        print("FAIL: pre " + str(pre))
        quit(1)
        return
    print("1. Idle classify(5) = " + str(pre))

    s.enter_active(10)
    var under = s.classify(5)
    if under != 0:
        print("FAIL: under " + str(under))
        quit(1)
        return
    print("2. classify(5) with threshold=10 -> " + str(under))

    var over = s.classify(15)
    if over != 1:
        print("FAIL: over " + str(over))
        quit(1)
        return
    print("3. classify(15) with threshold=10 -> " + str(over))

    var eq = s.classify(10)
    if eq != 0:
        print("FAIL: eq " + str(eq))
        quit(1)
        return
    print("4. classify(10) with threshold=10 -> " + str(eq))

    s.enter_active(50)
    var newUnder = s.classify(15)
    if newUnder != 0:
        print("FAIL: newUnder " + str(newUnder))
        quit(1)
        return
    print("5. classify(15) with threshold=50 -> " + str(newUnder))

    print("PASS: 62_hsm_if_state_args")
    quit(0)

@@[target("rust")]

@@[persist]
@@system Inner {
    interface:
        cycle()
        get_state(): String
        get_count(): i32

    machine:
        $A {
            cycle() { self.n = self.n + 1; -> $B }
            get_state(): String { @@:("A".to_string()) }
            get_count(): i32 { @@:(self.n) }
        }
        $B => $A {
            cycle() { -> $A }
            get_state(): String { @@:("B".to_string()) }
            get_count(): i32 { => $^ }
        }
    domain:
        n: i32 = 0
}

@@system Outer {
    interface:
        tick()
        cycle_inner()
        get_outer_state(): String
        get_inner_state(): String
        get_inner_count(): i32
        get_k(): i32

    machine:
        $Idle {
            tick() { self.k = self.k + 1; -> $Active }
            cycle_inner() { self.inner.cycle(); }
            get_outer_state(): String { @@:("Idle".to_string()) }
            get_inner_state(): String { @@:(self.inner.get_state()) }
            get_inner_count(): i32 { @@:(self.inner.get_count()) }
            get_k(): i32 { @@:(self.k) }
        }
        $Active => $Idle {
            tick() { -> $Idle }
            get_outer_state(): String { @@:("Active".to_string()) }
            cycle_inner() { => $^ }
            get_inner_state(): String { => $^ }
            get_inner_count(): i32 { => $^ }
            get_k(): i32 { => $^ }
        }
    domain:
        k: i32 = 0
        inner: Inner = @@Inner()
}

fn fmt(o: &mut Outer) -> String {
    format!("{}/{}/{}/{}", o.get_outer_state(), o.get_inner_state(), o.get_inner_count(), o.get_k())
}

fn must(label: &str, o: &mut Outer, expected: &str) {
    let actual = fmt(o);
    assert_eq!(actual, expected, "FAIL {}: {} expected {}", label, actual, expected);
}

fn main() {
    let mut o = Outer::new();
    must("T0 fresh", &mut o, "Idle/A/0/0");
    let snap0 = o.save_state();
    let mut r0 = Outer::restore_state(&snap0);
    must("T0 restored", &mut r0, "Idle/A/0/0");

    o.tick();
    must("T1", &mut o, "Active/A/0/1");
    let snap1 = o.save_state();
    let mut r1 = Outer::restore_state(&snap1);
    must("T1 restored", &mut r1, "Active/A/0/1");

    o.cycle_inner();
    must("T2", &mut o, "Active/B/1/1");
    let snap2 = o.save_state();
    let mut r2 = Outer::restore_state(&snap2);
    must("T2 restored", &mut r2, "Active/B/1/1");

    let snap2b = r2.save_state();
    let mut r2b = Outer::restore_state(&snap2b);
    let f1 = fmt(&mut r2);
    let f2 = fmt(&mut r2b);
    assert_eq!(f1, f2, "FAIL idempotence: {} != {}", f2, f1);

    r2.cycle_inner();
    must("continue1", &mut r2, "Active/A/1/1");
    r2.tick();
    must("continue2", &mut r2, "Idle/A/1/1");
    r2.tick();
    must("continue3", &mut r2, "Active/A/1/2");

    println!("PASS: 84_persist_nested_hsm");
}

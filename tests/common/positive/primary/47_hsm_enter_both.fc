@@[target("c")]

// Test 47: HSM Enter Cascade — Both Parent and Child have $>
// Cascade fires top-down: Parent.$> first, then Child.$>.

@@system HSMEnterBoth {
    interface:
        go_to_child(): void
        go_to_parent(): void
        get_child_enter(): int
        get_parent_enter(): int
        get_first(): int
        get_state(): char*

    machine:
        $Start {
            go_to_child() { -> $Child }
            go_to_parent() { -> $Parent }
            get_child_enter(): int { @@:(self->child_enter) return; }
            get_parent_enter(): int { @@:(self->parent_enter) return; }
            get_first(): int { @@:(self->first) return; }
            get_state(): char* { @@:("Start") return; }
        }

        $Child => $Parent {
            $>() {
                self->child_enter = self->child_enter + 1;
                if (self->first == 0) self->first = 2;  // 2 = child fired first
            }
            go_to_parent() { -> $Parent }
            get_child_enter(): int { @@:(self->child_enter) return; }
            get_parent_enter(): int { @@:(self->parent_enter) return; }
            get_first(): int { @@:(self->first) return; }
            get_state(): char* { @@:("Child") return; }
        }

        $Parent {
            $>() {
                self->parent_enter = self->parent_enter + 1;
                if (self->first == 0) self->first = 1;  // 1 = parent fired first
            }
            go_to_child() { -> $Child }
            get_child_enter(): int { @@:(self->child_enter) return; }
            get_parent_enter(): int { @@:(self->parent_enter) return; }
            get_first(): int { @@:(self->first) return; }
            get_state(): char* { @@:("Parent") return; }
        }
    domain:
        child_enter  : int
        parent_enter : int
        first        : int
}

int main() {
    printf("=== Test 47: HSM Enter Cascade — Both ===\n");
    HSMEnterBoth* s = @@HSMEnterBoth();

    HSMEnterBoth_go_to_child(s);
    if (HSMEnterBoth_get_child_enter(s) != 1
        || HSMEnterBoth_get_parent_enter(s) != 1) {
        printf("FAIL: child_enter=%d parent_enter=%d (expected 1 each)\n",
               HSMEnterBoth_get_child_enter(s),
               HSMEnterBoth_get_parent_enter(s));
        return 1;
    }
    if (HSMEnterBoth_get_first(s) != 1) {
        printf("FAIL: Parent's $> must fire before Child's (first=%d)\n",
               HSMEnterBoth_get_first(s));
        return 1;
    }
    printf("TC1: Parent's $> fires before Child's $> on cascade entry - PASS\n");

    HSMEnterBoth_go_to_parent(s);
    if (HSMEnterBoth_get_parent_enter(s) != 2) {
        printf("FAIL: expected 2 Parent:enter, got %d\n",
               HSMEnterBoth_get_parent_enter(s));
        return 1;
    }
    if (HSMEnterBoth_get_child_enter(s) != 1) {
        printf("FAIL: expected still 1 Child:enter, got %d\n",
               HSMEnterBoth_get_child_enter(s));
        return 1;
    }
    printf("TC2: Direct Parent entry fires only Parent's $> - PASS\n");

    HSMEnterBoth_go_to_child(s);
    if (HSMEnterBoth_get_parent_enter(s) != 3) {
        printf("FAIL: expected 3 Parent:enter total, got %d\n",
               HSMEnterBoth_get_parent_enter(s));
        return 1;
    }
    if (HSMEnterBoth_get_child_enter(s) != 2) {
        printf("FAIL: expected 2 Child:enter total, got %d\n",
               HSMEnterBoth_get_child_enter(s));
        return 1;
    }
    printf("TC3: Re-entering Child cascades through Parent again - PASS\n");

    printf("PASS: HSM enter cascade fires both layers top-down\n");
    HSMEnterBoth_destroy(s);
    return 0;
}

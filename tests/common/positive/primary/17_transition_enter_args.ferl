@@[target("erlang")]
@@system EnterArgs {
    interface:
        start()
        getLog(): str
    machine:
        $Idle {
            start() {
                -> ("from_idle", 42) $Active
            }
            getLog(): str {
                @@:(self.log)
            }
        }
        $Active {
            $>(source: str, value: int) {
                self.log = self.log ++ ",enter:" ++ source
            }
            getLog(): str {
                @@:(self.log)
            }
        }
    domain:
        log = "init"
}

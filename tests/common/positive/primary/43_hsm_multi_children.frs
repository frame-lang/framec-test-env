@@[target("rust")]

// Test 43: HSM Multiple Children of Same Parent
//
// Tests multiple states sharing the same parent:
// - $ChildA => $Parent
// - $ChildB => $Parent
// - $ChildC => $Parent
// Each child can forward to the shared parent

@@system HSMMultiChildren {
    interface:
        start_a()
        start_b()
        start_c()
        do_action()
        forward_action()
        get_log(): Vec<String>
        get_state(): String

    machine:
        $ChildA => $Parent {
            start_a() {
                // stay
            }

            start_b() {
                -> $ChildB
            }

            start_c() {
                -> $ChildC
            }

            do_action() {
                self.log.push("ChildA:do_action".to_string());
            }

            forward_action() {
                self.log.push("ChildA:forward_action".to_string());
                => $^
            }

            get_log(): Vec<String> {
                @@:(self.log.clone())
                return;
            }

            get_state(): String {
                @@:("ChildA".to_string())
                return;
            }
        }

        $ChildB => $Parent {
            start_a() {
                -> $ChildA
            }

            start_b() {
                // stay
            }

            start_c() {
                -> $ChildC
            }

            do_action() {
                self.log.push("ChildB:do_action".to_string());
            }

            forward_action() {
                self.log.push("ChildB:forward_action".to_string());
                => $^
            }

            get_log(): Vec<String> {
                @@:(self.log.clone())
                return;
            }

            get_state(): String {
                @@:("ChildB".to_string())
                return;
            }
        }

        $ChildC => $Parent {
            start_a() {
                -> $ChildA
            }

            start_b() {
                -> $ChildB
            }

            start_c() {
                // stay
            }

            do_action() {
                self.log.push("ChildC:do_action".to_string());
            }

            forward_action() {
                self.log.push("ChildC:forward_action".to_string());
                => $^
            }

            get_log(): Vec<String> {
                @@:(self.log.clone())
                return;
            }

            get_state(): String {
                @@:("ChildC".to_string())
                return;
            }
        }

        $Parent {
            forward_action() {
                self.log.push("Parent:forward_action".to_string());
            }

            get_log(): Vec<String> {
                @@:(self.log.clone())
                return;
            }

            get_state(): String {
                @@:("Parent".to_string())
                return;
            }
        }
    domain:
        log: Vec<String>
}

fn main() {
    println!("=== Test 43: HSM Multiple Children ===");
    let mut s = @@HSMMultiChildren();

    // TC1.3.1: Multiple children declare same parent (verified by compilation)
    println!("TC1.3.1: Multiple children with same parent compiles - PASS");

    // Start in ChildA
    assert!(s.get_state() == "ChildA", "Expected ChildA, got {}", s.get_state());

    // TC1.3.2: ChildA can forward to shared parent
    s.forward_action();
    let log = s.get_log();
    assert!(log.contains(&"ChildA:forward_action".to_string()), "Expected ChildA forward, got {:?}", log);
    assert!(log.contains(&"Parent:forward_action".to_string()), "Expected Parent handler, got {:?}", log);
    println!("TC1.3.2: ChildA forwards to parent - PASS");

    // TC1.3.3: Transition to sibling
    s.start_b();
    assert!(s.get_state() == "ChildB", "Expected ChildB after transition, got {}", s.get_state());
    println!("TC1.3.3: Transition A->B works - PASS");

    // TC1.3.4: ChildB can also forward to same parent
    s.forward_action();
    let log = s.get_log();
    assert!(log.contains(&"ChildB:forward_action".to_string()), "Expected ChildB forward, got {:?}", log);
    let parent_count = log.iter().filter(|x| *x == "Parent:forward_action").count();
    assert!(parent_count == 2, "Expected 2 Parent forwards, got {:?}", log);
    println!("TC1.3.4: ChildB forwards to same parent - PASS");

    // TC1.3.5: Transition to ChildC
    s.start_c();
    assert!(s.get_state() == "ChildC", "Expected ChildC, got {}", s.get_state());
    s.forward_action();
    let log = s.get_log();
    assert!(log.contains(&"ChildC:forward_action".to_string()), "Expected ChildC forward, got {:?}", log);
    let parent_count2 = log.iter().filter(|x| *x == "Parent:forward_action").count();
    assert!(parent_count2 == 3, "Expected 3 Parent forwards, got {:?}", log);
    println!("TC1.3.5: ChildC forwards to same parent - PASS");

    // TC1.3.6: Each sibling maintains independent actions
    s.start_a();
    s.do_action();
    s.start_b();
    s.do_action();
    s.start_c();
    s.do_action();
    let log = s.get_log();
    assert!(log.contains(&"ChildA:do_action".to_string()), "Expected ChildA action");
    assert!(log.contains(&"ChildB:do_action".to_string()), "Expected ChildB action");
    assert!(log.contains(&"ChildC:do_action".to_string()), "Expected ChildC action");
    println!("TC1.3.6: Each sibling has independent handlers - PASS");

    println!("PASS: HSM multiple children work correctly");
}

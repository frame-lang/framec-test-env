@@[target("kotlin")]

// RFC-0017 regression: see .fpy header.

@@system Counter(seed: int) {
    interface:
        bump()
        get_value(): int
    machine:
        $S {
            $> { this.n = this.seed }
            bump() { this.n = this.n + 1 }
            get_value(): int { @@:(this.n) }
        }
    domain:
        seed: int = seed
        n: int = 0
}

@@[main]
@@system World {
    interface:
        bump_c()
        bump_d()
        get_c(): int
        get_d(): int
    machine:
        $S {
            bump_c() { this.c.bump() }
            bump_d() { this.d.bump() }
            get_c(): int { @@:(this.c.get_value()) }
            get_d(): int { @@:(this.d.get_value()) }
        }
    domain:
        c: Counter = @@Counter(7)
        d: Counter = @@Counter(11)
}

fun main() {
    val w = @@World()
    if (w.get_c() != 7) { println("FAIL initial c: ${w.get_c()}"); kotlin.system.exitProcess(1) }
    if (w.get_d() != 11) { println("FAIL initial d: ${w.get_d()}"); kotlin.system.exitProcess(1) }
    w.bump_c()
    w.bump_d()
    if (w.get_c() != 8) { println("FAIL bump_c: ${w.get_c()}"); kotlin.system.exitProcess(1) }
    if (w.get_d() != 12) { println("FAIL bump_d: ${w.get_d()}"); kotlin.system.exitProcess(1) }
    println("PASS: 98_param_child_domain_init")
}

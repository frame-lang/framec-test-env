@@target ruby

@@system StateVarPushPop {
    interface:
        increment(): int
        get_count(): int
        save_and_go()
        restore()

    machine:
        $Counter {
            $.count: int = 0

            increment(): int {
                $.count = $.count + 1
                @@:($.count)
                return
            }

            get_count(): int {
                @@:($.count)
                return
            }

            save_and_go() {
                push$
                -> $Other
            }
        }

        $Other {
            $.other_count: int = 100

            restore() {
                -> pop$
            }

            increment(): int {
                $.other_count = $.other_count + 1
                @@:($.other_count)
                return
            }

            get_count(): int {
                @@:($.other_count)
                return
            }
        }
}

puts("=== Test 12: State Variable Push/Pop ===")
s = StateVarPushPop.new

# Increment counter to 3
s.increment()
s.increment()
s.increment()
count = s.get_count()
raise "Expected 3, got #{count}" unless count == 3
puts("Counter before push: #{count}")

# Push and go to Other state
s.save_and_go()
puts("Pushed and transitioned to Other")

# In Other state, count should be 100 (Other's state var)
count = s.get_count()
raise "Expected 100 in Other state, got #{count}" unless count == 100
puts("Other state count: #{count}")

# Increment in Other
s.increment()
count = s.get_count()
raise "Expected 101 after increment, got #{count}" unless count == 101
puts("Other state after increment: #{count}")

# Pop back - should restore Counter with count=3
s.restore()
puts("Popped back to Counter")

count = s.get_count()
raise "Expected 3 after pop (preserved), got #{count}" unless count == 3
puts("Counter after pop: #{count}")

# Increment to verify it works
s.increment()
count = s.get_count()
raise "Expected 4, got #{count}" unless count == 4
puts("Counter after increment: #{count}")

puts("PASS: State variables preserved across push/pop")

@@[target("erlang")]
@@system EventForwardTest {
    interface:
        process()
        getLog(): str

    machine:
        $Idle {
            process() {
                self.log = self.log ++ ",idle_before"
                -> => $Working
                self.log = self.log ++ ",idle_after"
            }
            getLog(): str {
                @@:(self.log)
            }
        }
        $Working {
            process() {
                self.log = self.log ++ ",working_process"
            }
            getLog(): str {
                @@:(self.log)
            }
        }
    domain:
        log = ""
}

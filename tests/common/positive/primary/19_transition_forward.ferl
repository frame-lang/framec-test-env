@@target erlang
@@system TransitionForward {
    interface:
        goToChild()
        goToOther()
        getState(): str
    machine:
        $Main {
            goToChild() { -> $Child }
            goToOther() { -> $Other }
            getState(): str {
                @@:("Main")
            }
        }
        $Child => $Parent {
            getState(): str {
                @@:("Child")
            }
        }
        $Other {
            goToChild() { -> $Child }
            getState(): str {
                @@:("Other")
            }
        }
        $Parent {
            getState(): str {
                @@:("Parent")
            }
        }
    domain:
        log = ""
}

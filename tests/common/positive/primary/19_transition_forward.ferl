@@target erlang
@@system TransitionForward {
    interface:
        goToChild()
        goToOther()
        getState(): str
    machine:
        $Main {
            goToChild() { -> $Child }
            goToOther() { -> $Other }
            getState(): str { return "Main" }
        }
        $Child => $Parent {
            getState(): str { return "Child" }
        }
        $Other {
            goToChild() { -> $Child }
            getState(): str { return "Other" }
        }
        $Parent {
            getState(): str { return "Parent" }
        }
    domain:
        log = ""
}

@@[target("erlang")]
@@system HsmFourLevel {
    interface:
        drive(): int
        writeAtLevel(level: int)
        getN(): int
    machine:
        $Leaf => $Mid {
            drive(): int {
                => $^
            }
            writeAtLevel(level: int) {
                self.n = self.n + level * 1
                => $^
            }
            getN(): int {
                @@:(self.n)
            }
        }
        $Mid => $Branch {
            drive(): int {
                => $^
            }
            writeAtLevel(level: int) {
                self.n = self.n + level * 10
                => $^
            }
        }
        $Branch => $Root {
            drive(): int {
                => $^
            }
            writeAtLevel(level: int) {
                self.n = self.n + level * 100
                => $^
            }
        }
        $Root {
            drive(): int {
                @@:(self.n)
            }
            writeAtLevel(level: int) {
                self.n = self.n + level * 1000
            }
        }
    domain:
        n = 0
}

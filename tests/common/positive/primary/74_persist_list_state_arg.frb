@@target ruby

@@[persist]
@@system PersistList {
    interface:
        configure(items: Array)
        first_item(): int
        size(): int

    machine:
        $Idle {
            configure(items: Array) {
                -> $Active(items)
            }
            first_item(): int { @@:(-1) }
            size(): int { @@:(0) }
        }
        $Active(items: Array) {
            configure(items: Array) {
                -> $Active(items)
            }
            first_item(): int { @@:(items[0]) }
            size(): int { @@:(items.length) }
        }
    domain:
        n: int = 0
}

s1 = PersistList.new
s1.configure([10, 20, 30])
abort("FAIL pre") unless s1.first_item == 10
snap = s1.save_state

s2 = PersistList.restore_state(snap)
abort("FAIL restored first_item") unless s2.first_item == 10
abort("FAIL restored size") unless s2.size == 3
puts "PASS: 74_persist_list_state_arg"

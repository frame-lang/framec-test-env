@@target lua
@@system StateVarReentry {
    interface:
        increment(): int
        get_count(): int
        go_other()
        come_back()

    machine:
        $Counter {
            $.count: int = 0

            increment(): int {
                $.count = $.count + 1
                @@:($.count)
                return
            }

            get_count(): int {
                @@:($.count)
                return
            }

            go_other() {
                -> $Other
            }
        }

        $Other {
            come_back() {
                -> $Counter
            }

            increment(): int {
                @@:(-1)
                return
            }

            get_count(): int {
                @@:(-1)
                return
            }
        }
}

@@target go

package main

import (
	"fmt"
	"os"
)

@@system OpHsmStateArgs {
    operations:
        AddOffset(x: int, off: int): int {
            return x + off
        }

    interface:
        EnterActive(t: int)
        Classify(v: int): int

    machine:
        $Idle {
            EnterActive(t: int) {
                -> $Active(t)
            }
            Classify(v: int): int {
                @@:(-1)
                return;
            }
        }

        $Active => $Frame(threshold: int) {
            EnterActive(t: int) {
                -> $Active(t)
            }
            Classify(v: int): int {
                r := s.AddOffset(v, threshold)
                @@:(r)
                return;
            }
        }

        $Frame {
        }
    domain:
        n: int = 0
}

func main() {
    fmt.Println("=== Test 64: Operations × HSM × state-args (Go) ===")
    s := NewOpHsmStateArgs()

    pre := s.Classify(5)
    if pre != -1 { fmt.Printf("FAIL: pre %d\n", pre); os.Exit(1) }
    fmt.Printf("1. Idle classify(5) = %d\n", pre)

    s.EnterActive(10)
    r := s.Classify(5)
    if r != 15 { fmt.Printf("FAIL: r %d\n", r); os.Exit(1) }
    fmt.Printf("2. classify(5) with threshold=10 → %d\n", r)

    r2 := s.Classify(7)
    if r2 != 17 { fmt.Printf("FAIL: r2 %d\n", r2); os.Exit(1) }
    fmt.Printf("3. classify(7) with threshold=10 → %d\n", r2)

    s.EnterActive(100)
    r3 := s.Classify(5)
    if r3 != 105 { fmt.Printf("FAIL: r3 %d\n", r3); os.Exit(1) }
    fmt.Printf("4. classify(5) with threshold=100 → %d\n", r3)

    fmt.Println("PASS: 64_operation_hsm_state_args")
}

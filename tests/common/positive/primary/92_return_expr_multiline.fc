@@[target("c")]

#include <stdio.h>

@@system Test {
    interface:
        ready(): bool

    machine:
        $Active {
            ready(): bool {
                @@:(self->timer >= self->threshold
                    && self->count < self->limit)
            }
        }
    domain:
        timer: int = 100
        threshold: int = 50
        count: int = 1
        limit: int = 5
}

int main() {
    Test* t = Test_new();
    if (Test_ready(t) != 1) {
        printf("FAIL ready(): %d\n", Test_ready(t));
        Test_destroy(t);
        return 1;
    }
    printf("PASS: 92_return_expr_multiline\n");
    Test_destroy(t);
    return 0;
}

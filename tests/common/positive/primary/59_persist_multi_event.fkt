@@[target("kotlin")]

@@[persist(String)]
@@[save(save_state)]
@@[load(restore_state)]
@@system PersistMultiEvent {
    interface:
        seed(v: int)
        bump()
        get_slot(): int

    machine:
        $Idle {
            seed(v: int) {
                -> $Active(v)
            }
            bump() {
                @@:(-1)
            }
            get_slot(): int {
                @@:(-1)
            }
        }

        $Active(slot: int) {
            seed(v: int) {
                -> $Active(v)
            }
            bump() {
                -> $Active(slot + 100)
            }
            get_slot(): int {
                @@:(slot)
            }
        }
    domain:
        v : int = 0
}

fun main() {
    println("=== Test 59: Persist × multi-event boundary (Kotlin) ===")
    val s1 = PersistMultiEvent()
    s1.seed(42)
    val pre = s1.get_slot()
    if (pre != 42) { println("FAIL: pre $pre"); kotlin.system.exitProcess(1) }
    println("1. Pre-save slot=$pre")

    val snap = s1.save_state() as String
    val s2 = PersistMultiEvent()

    s2.restore_state(snap)
    val post = s2.get_slot()
    if (post != 42) { println("FAIL: post $post"); kotlin.system.exitProcess(1) }
    println("2. Post-restore slot=$post")

    s2.bump()
    val bumped = s2.get_slot()
    if (bumped != 142) { println("FAIL: bumped $bumped"); kotlin.system.exitProcess(1) }
    println("3. After post-restore bump slot=$bumped")

    s2.bump()
    val twice = s2.get_slot()
    if (twice != 242) { println("FAIL: twice $twice"); kotlin.system.exitProcess(1) }
    println("4. After second bump slot=$twice")

    println("PASS: 59_persist_multi_event")
}

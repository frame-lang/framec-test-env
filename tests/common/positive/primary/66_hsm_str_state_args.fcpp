@@[target("cpp_17")]

#include <iostream>
#include <string>
#include <cstdlib>

@@system StrStateArg {
    interface:
        configure(label: str)
        identify(): str

    machine:
        $Idle {
            configure(label: str) {
                -> $Active(label)
            }
            identify(): str {
                @@:("anonymous")
            }
        }

        $Active => $Frame(label: str) {
            configure(label: str) {
                -> $Active(label)
            }
            identify(): str {
                => $^
            }
        }

        $Frame {
            identify(): str {
                @@:(label)
            }
        }
    domain:
        n : int = 0
}

int main() {
    StrStateArg s;
    if (s.identify() != "anonymous") { std::cout << "FAIL idle" << std::endl; return 1; }
    s.configure("alice");
    if (s.identify() != "alice") { std::cout << "FAIL alice" << std::endl; return 1; }
    s.configure("bob");
    if (s.identify() != "bob") { std::cout << "FAIL bob" << std::endl; return 1; }
    std::cout << "PASS: 66_hsm_str_state_args" << std::endl;
    return 0;
}

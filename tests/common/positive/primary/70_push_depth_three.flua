@@[target("lua")]

@@system PushDeep {
    interface:
        descend()
        ascend()
        get_depth(): int

    machine:
        $Idle {
            descend() {
                push$
                -> $Modal1
            }
            get_depth(): int {
                @@:(0)
                return
            }
        }

        $Modal1 {
            descend() {
                push$
                -> $Modal2
            }
            ascend() {
                -> pop$
            }
            get_depth(): int {
                @@:(1)
                return
            }
        }

        $Modal2 {
            descend() {
                push$
                -> $Modal3
            }
            ascend() {
                -> pop$
            }
            get_depth(): int {
                @@:(2)
                return
            }
        }

        $Modal3 {
            ascend() {
                -> pop$
            }
            get_depth(): int {
                @@:(3)
                return
            }
        }
    domain:
        n: int = 0
}

local s = @@PushDeep()
if s:get_depth() ~= 0 then error("FAIL idle: " .. tostring(s:get_depth())) end
s:descend()
if s:get_depth() ~= 1 then error("FAIL d1") end
s:descend()
if s:get_depth() ~= 2 then error("FAIL d2") end
s:descend()
if s:get_depth() ~= 3 then error("FAIL d3") end
s:ascend()
if s:get_depth() ~= 2 then error("FAIL a1") end
s:ascend()
if s:get_depth() ~= 1 then error("FAIL a2") end
s:ascend()
if s:get_depth() ~= 0 then error("FAIL a3") end
print("PASS: 70_push_depth_three")

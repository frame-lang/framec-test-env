@@[target("kotlin")]

@@[persist(String)]
@@[save(save_state)]
@@[load(restore_state)]
@@system ListOfDict {
    interface:
        configure(rows: List<Map<String, Int>>)
        get_at(idx: Int, key: String): Int

    machine:
        $Idle {
            configure(rows: List<Map<String, Int>>) { -> $Active(rows) }
            get_at(idx: Int, key: String): Int { @@:(-1) }
        }
        $Active(rows: List<Map<String, Int>>) {
            configure(rows: List<Map<String, Int>>) { -> $Active(rows) }
            get_at(idx: Int, key: String): Int {
                if (idx >= rows.size) { @@:(-1) }
                else { @@:(rows[idx][key] ?: -1) }
            }
        }
    domain:
        n : Int = 0
}

fun main() {
    val s1 = ListOfDict()
    s1.configure(listOf(mapOf("x" to 1, "y" to 2), mapOf("z" to 3)))
    if (s1.get_at(0, "x") != 1) { println("FAIL pre 0.x"); kotlin.system.exitProcess(1) }
    if (s1.get_at(1, "z") != 3) { println("FAIL pre 1.z"); kotlin.system.exitProcess(1) }
    val snap = s1.save_state()
    val s2 = ListOfDict()

    s2.restore_state(snap)
    if (s2.get_at(0, "x") != 1) { println("FAIL post 0.x got ${s2.get_at(0, "x")}"); kotlin.system.exitProcess(1) }
    if (s2.get_at(0, "y") != 2) { println("FAIL post 0.y"); kotlin.system.exitProcess(1) }
    if (s2.get_at(1, "z") != 3) { println("FAIL post 1.z"); kotlin.system.exitProcess(1) }
    println("PASS: 80_list_of_dict_state_arg")
}

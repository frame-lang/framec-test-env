<?php
@@[target("php")]

@@system EventForwardTest {
    interface:
        process()
        get_log(): list

    machine:
        $Idle {
            process() {
                $this->log[] = "idle:process:before";
                -> => $Working
                # This should NOT execute because -> => returns after dispatch
                $this->log[] = "idle:process:after";
            }

            get_log(): list {
                @@:($this->log)
                return;
            }
        }

        $Working {
            process() {
                $this->log[] = "working:process";
            }

            get_log(): list {
                @@:($this->log)
                return;
            }
        }
    domain:
        log = []
}

echo "=== Test 19: Transition Forward ===" . "\n";
$s = @@EventForwardTest();
$s->process();
$log = $s->get_log();
echo "Log: " . implode(", ", $log) . "\n";

if (!in_array("idle:process:before", $log)) { echo "FAIL: Expected 'idle:process:before' in log\n"; exit(1); }
if (!in_array("working:process", $log)) { echo "FAIL: Expected 'working:process' in log\n"; exit(1); }
if (in_array("idle:process:after", $log)) { echo "FAIL: Should NOT have 'idle:process:after' in log\n"; exit(1); }

echo "PASS: Transition forward works correctly" . "\n";

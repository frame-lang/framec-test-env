@@target csharp

using System;
using System.Collections.Generic;

@@system OperationsTest {
    operations:
        add(x: int, y: int): int {
            return x + y;
        }

        multiply(x: int, y: int): int {
            return x * y;
        }

        static factorial(n: int): int {
            if (n <= 1) {
                return 1;
            }
            return n * OperationsTest.factorial(n - 1);
        }

        static is_even(n: int): bool {
            return n % 2 == 0;
        }
    interface:
        compute(a: int, b: int): int
        get_last_result(): int

    machine:
        $Ready {
            compute(a: int, b: int): int {
                // Use instance operations
                int sum_val = this.add(a, b);
                int prod_val = this.multiply(a, b);
                int last_result = sum_val + prod_val;
                @@:(last_result)
                return;
            }

            get_last_result(): int {
                @@:(this.last_result)
                return;
            }
        }
    domain:
        int last_result = 0

}

class Program {
    static void Main(string[] args) {
        Console.WriteLine("=== Test 22: Operations Basic (C#) ===");
        var s = @@OperationsTest();

        // Test 1: Instance operations
        var result = (int)s.add(3, 4);
        if (result != 7) {
            Console.WriteLine("FAIL: Expected 7, got " + result);
            Environment.Exit(1);
        }
        Console.WriteLine("1. add(3, 4) = " + result);

        result = (int)s.multiply(3, 4);
        if (result != 12) {
            Console.WriteLine("FAIL: Expected 12, got " + result);
            Environment.Exit(1);
        }
        Console.WriteLine("2. multiply(3, 4) = " + result);

        // Test 2: Operations used in handler
        result = (int)s.compute(3, 4);
        // compute returns add(3,4) + multiply(3,4) = 7 + 12 = 19
        if (result != 19) {
            Console.WriteLine("FAIL: Expected 19, got " + result);
            Environment.Exit(1);
        }
        Console.WriteLine("3. compute(3, 4) = " + result);

        // Test 3: Static operations
        result = OperationsTest.factorial(5);
        if (result != 120) {
            Console.WriteLine("FAIL: Expected 120, got " + result);
            Environment.Exit(1);
        }
        Console.WriteLine("4. factorial(5) = " + result);

        var is_even = OperationsTest.is_even(4);
        if (is_even != true) {
            Console.WriteLine("FAIL: Expected true, got " + is_even);
            Environment.Exit(1);
        }
        Console.WriteLine("5. is_even(4) = " + is_even);

        is_even = OperationsTest.is_even(7);
        if (is_even != false) {
            Console.WriteLine("FAIL: Expected false, got " + is_even);
            Environment.Exit(1);
        }
        Console.WriteLine("6. is_even(7) = " + is_even);

        // Test 4: Static via class
        result = OperationsTest.factorial(4);
        if (result != 24) {
            Console.WriteLine("FAIL: Expected 24, got " + result);
            Environment.Exit(1);
        }
        Console.WriteLine("7. OperationsTest.factorial(4) = " + result);

        Console.WriteLine("PASS: Operations basic works correctly");
    }
}

@@[target("ruby")]
@@[create(make)]
@@system Counter(seed: Integer) {
    interface:
        bump()
        get(): Integer

    machine:
        $A {
            bump() { @count = @count + 1 }
            get(): Integer { @@:(@count) }
        }

    domain:
        seed: Integer = seed
        count: Integer = 0
}

c1 = @@Counter(42)
c1.bump
c1.bump
if c1.get != 2
    puts "FAIL: via @@Counter() expected 2, got #{c1.get}"
else
    c2 = Counter.make(99)
    c2.bump
    if c2.get != 1
        puts "FAIL: via Counter.make expected 1, got #{c2.get}"
    else
        puts "PASS: rfc0015_create_rename"
    end
end

@@target python_3

@@system DomainVars {
    interface:
        increment()
        decrement()
        get_count(): int
        set_count(value: int)

    machine:
        $Counting {
            increment() {
                self.count += 1
                print(f"{self.name}: incremented to {self.count}")
            }

            decrement() {
                self.count -= 1
                print(f"{self.name}: decremented to {self.count}")
            }

            get_count(): int {
                return self.count
            }

            set_count(value: int) {
                self.count = value
                print(f"{self.name}: set to {self.count}")
            }
        }
    domain:
        count: int = 0
        name: str = "counter"
}

def main():
    print("=== Test 06: Domain Variables ===")
    s = DomainVars()

    # Initial value should be 0
    count = s.get_count()
    assert count == 0, f"Expected initial count=0, got {count}"
    print(f"Initial count: {count}")

    # Increment
    s.increment()
    count = s.get_count()
    assert count == 1, f"Expected count=1, got {count}"

    s.increment()
    count = s.get_count()
    assert count == 2, f"Expected count=2, got {count}"

    # Decrement
    s.decrement()
    count = s.get_count()
    assert count == 1, f"Expected count=1, got {count}"

    # Set directly
    s.set_count(100)
    count = s.get_count()
    assert count == 100, f"Expected count=100, got {count}"

    print(f"Final count: {count}")
    print("PASS: Domain variables work correctly")

if __name__ == '__main__':
    main()

@@target erlang

@@system TransitionGuard {
    interface:
        run()
        doTransition()
        getTrace(): str

    machine:
        $Active {
            run() {
                self.trace = self.trace ++ "run:before-self-call;"
                @@:self.doTransition()
                self.trace = self.trace ++ "run:after-self-call;"
            }

            doTransition() {
                self.trace = self.trace ++ "do_transition:body;"
                -> $Done
            }

            getTrace(): str {
                @@:(self.trace)
            }
        }

        $Done {
            $>() {
                self.trace = self.trace ++ "Done:enter;"
            }

            getTrace(): str {
                @@:(self.trace)
            }
        }

    domain:
        trace = ""
}

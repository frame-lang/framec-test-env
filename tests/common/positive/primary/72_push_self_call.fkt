@@[target("kotlin")]

@@system PushSelf {
    interface:
        enter_modal()
        ping(): int
        exit_modal()
        compute(): int

    machine:
        $Idle {
            enter_modal() { push$; -> $Modal }
            ping(): int { @@:(0) }
            compute(): int { @@:(99) }
        }
        $Modal {
            ping(): int { @@:(this.compute() + 1) }
            compute(): int { @@:(10) }
            exit_modal() { -> pop$ }
        }
    domain: n : int = 0
}

fun main() {
    val s = @@PushSelf()
    if (s.ping() != 0) { println("FAIL idle"); kotlin.system.exitProcess(1) }
    s.enter_modal()
    val r = s.ping()
    if (r != 11) { println("FAIL modal $r"); kotlin.system.exitProcess(1) }
    s.exit_modal()
    if (s.ping() != 0) { println("FAIL back"); kotlin.system.exitProcess(1) }
    println("PASS: 72_push_self_call")
}

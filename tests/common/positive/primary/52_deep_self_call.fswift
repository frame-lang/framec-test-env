@@[target("swift")]

import Foundation

// Test: deep @@:self.iface() stack — transition guard propagation
//
// Validates:
// 1. Full chain completes when no transition fires
// 2. Transition at depth 3 suppresses all "after" traces
// 3. Transition at depth 2 prevents deeper calls
// 4. Sequential self-calls: second suppressed after first transitions
// 5. Sequential self-calls: both complete when no transition

@@system DeepSelfCall {
    interface:
        start_chain(mode: string): string
        level_one(mode: string): string
        level_two(mode: string): string
        level_three(mode: string): string
        get_trace(): string
        get_state(): string
        reset()

    machine:
        $Active {
            start_chain(mode: string): string {
                self.trace = ""
                self.trace = self.trace + "start:before;"
                @@:self.level_one(mode)
                self.trace = self.trace + "start:after;"
                @@:(self.trace)
            }

            level_one(mode: string): string {
                self.trace = self.trace + "L1:before;"
                @@:self.level_two(mode)
                self.trace = self.trace + "L1:after;"
                @@:(self.trace)
            }

            level_two(mode: string): string {
                self.trace = self.trace + "L2:before;"
                if mode as! String == "transition_at_two" {
                    self.trace = self.trace + "L2:transitioning;"
                    -> $Done
                }
                @@:self.level_three(mode)
                self.trace = self.trace + "L2:after;"
                @@:(self.trace)
            }

            level_three(mode: string): string {
                self.trace = self.trace + "L3:before;"
                if mode as! String == "transition_at_three" {
                    self.trace = self.trace + "L3:transitioning;"
                    -> $Done
                }
                self.trace = self.trace + "L3:after;"
                @@:(self.trace)
            }

            get_trace(): string {
                @@:(self.trace)
            }

            get_state(): string { @@:(@@:system.state) }

            reset() {
                self.trace = ""
            }
        }

        $Done {
            get_trace(): string {
                @@:(self.trace)
            }

            get_state(): string { @@:(@@:system.state) }

            reset() {
                self.trace = ""
                -> $Active
            }
        }

    domain:
        trace: string = ""
}

@@[main]
@@system SequentialSelfCall {
    interface:
        run_sequence(mode: string): string
        first_call(mode: string): string
        second_call(): string
        get_trace(): string
        get_state(): string

    machine:
        $Active {
            run_sequence(mode: string): string {
                self.trace = ""
                self.trace = self.trace + "seq:before_first;"
                @@:self.first_call(mode)
                self.trace = self.trace + "seq:between;"
                @@:self.second_call()
                self.trace = self.trace + "seq:after_second;"
                @@:(self.trace)
            }

            first_call(mode: string): string {
                if mode as! String == "transition_first" {
                    self.trace = self.trace + "first:transitioning;"
                    -> $Done
                }
                self.trace = self.trace + "first:complete;"
                @@:(self.trace)
            }

            second_call(): string {
                self.trace = self.trace + "second:complete;"
                @@:(self.trace)
            }

            get_trace(): string { @@:(self.trace) }
            get_state(): string { @@:(@@:system.state) }
        }

        $Done {
            get_trace(): string { @@:(self.trace) }
            get_state(): string { @@:(@@:system.state) }
        }

    domain:
        trace: string = ""
}

// main
    var failures = 0

    // === Scenario 1: No transition — full chain completes ===
    let s = @@DeepSelfCall()
    var result = s.start_chain("no_transition") as! String
    let expected = "start:before;L1:before;L2:before;L3:before;L3:after;L2:after;L1:after;start:after;"
    if result != expected {
        print("FAIL scenario 1: expected '\(expected)'")
        print("                 got      '\(result)'")
        failures += 1
    }
    if (s.get_state() as! String) != "Active" {
        print("FAIL scenario 1: state should be Active, got '\(s.get_state())'")
        failures += 1
    }

    // === Scenario 2: Transition at level_three — all "after" traces suppressed ===
    s.reset()
    let _ = s.start_chain("transition_at_three")
    var trace = s.get_trace() as! String
    var expectedTrace = "start:before;L1:before;L2:before;L3:before;L3:transitioning;"
    if trace != expectedTrace {
        print("FAIL scenario 2 trace: expected '\(expectedTrace)'")
        print("                       got      '\(trace)'")
        failures += 1
    }
    if (s.get_state() as! String) != "Done" {
        print("FAIL scenario 2: state should be Done, got '\(s.get_state())'")
        failures += 1
    }

    // === Scenario 3: Transition at level_two — level_three never called ===
    s.reset()
    let _ = s.start_chain("transition_at_two")
    trace = s.get_trace() as! String
    expectedTrace = "start:before;L1:before;L2:before;L2:transitioning;"
    if trace != expectedTrace {
        print("FAIL scenario 3 trace: expected '\(expectedTrace)'")
        print("                       got      '\(trace)'")
        failures += 1
    }
    if (s.get_state() as! String) != "Done" {
        print("FAIL scenario 3: state should be Done, got '\(s.get_state())'")
        failures += 1
    }

    // === Scenario 4: Sequential self-calls — second suppressed after first transitions ===
    let s2 = @@SequentialSelfCall()
    let _ = s2.run_sequence("transition_first")
    trace = s2.get_trace() as! String
    expectedTrace = "seq:before_first;first:transitioning;"
    if trace != expectedTrace {
        print("FAIL scenario 4 trace: expected '\(expectedTrace)'")
        print("                       got      '\(trace)'")
        failures += 1
    }
    if (s2.get_state() as! String) != "Done" {
        print("FAIL scenario 4: state should be Done, got '\(s2.get_state())'")
        failures += 1
    }

    // === Scenario 5: Sequential self-calls — no transition, both complete ===
    let s3 = @@SequentialSelfCall()
    let _ = s3.run_sequence("no_transition")
    trace = s3.get_trace() as! String
    expectedTrace = "seq:before_first;first:complete;seq:between;second:complete;seq:after_second;"
    if trace != expectedTrace {
        print("FAIL scenario 5 trace: expected '\(expectedTrace)'")
        print("                       got      '\(trace)'")
        failures += 1
    }

    if failures > 0 {
        print("FAIL: deep_self_call (\(failures) failures)")
        fatalError()
    }
    print("PASS: deep_self_call")

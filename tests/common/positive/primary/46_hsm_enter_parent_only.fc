@@[target("c")]

// Test 46: HSM Enter Cascade — Parent has $>, Child does not.
// Cascade fires Parent's $> top-down on child entry.

@@system HSMEnterParentOnly {
    interface:
        go_to_child(): void
        go_to_parent(): void
        get_parent_enter(): int
        get_state(): char*

    machine:
        $Start {
            go_to_child() { -> $Child }
            go_to_parent() { -> $Parent }
            get_parent_enter(): int { @@:(self->parent_enter) return; }
            get_state(): char* { @@:("Start") return; }
        }

        $Child => $Parent {
            go_to_parent() { -> $Parent }
            get_parent_enter(): int { @@:(self->parent_enter) return; }
            get_state(): char* { @@:("Child") return; }
        }

        $Parent {
            $>() { self->parent_enter = self->parent_enter + 1; }
            go_to_child() { -> $Child }
            get_parent_enter(): int { @@:(self->parent_enter) return; }
            get_state(): char* { @@:("Parent") return; }
        }
    domain:
        parent_enter : int
}

int main() {
    printf("=== Test 46: HSM Enter Cascade — Parent only ===\n");
    HSMEnterParentOnly* s = @@HSMEnterParentOnly();

    HSMEnterParentOnly_go_to_child(s);
    if (strcmp(HSMEnterParentOnly_get_state(s), "Child") != 0) {
        printf("FAIL: expected Child\n"); return 1;
    }
    if (HSMEnterParentOnly_get_parent_enter(s) != 1) {
        printf("FAIL: expected 1 Parent:enter on cascade, got %d\n",
               HSMEnterParentOnly_get_parent_enter(s));
        return 1;
    }
    printf("TC1: Parent's $> fires on cascade entry to Child - PASS\n");

    HSMEnterParentOnly_go_to_parent(s);
    if (HSMEnterParentOnly_get_parent_enter(s) != 2) {
        printf("FAIL: expected 2 Parent:enter, got %d\n",
               HSMEnterParentOnly_get_parent_enter(s));
        return 1;
    }
    printf("TC2: Parent's $> fires again when transitioning directly to Parent - PASS\n");

    HSMEnterParentOnly_go_to_child(s);
    if (HSMEnterParentOnly_get_parent_enter(s) != 3) {
        printf("FAIL: expected 3 Parent:enter, got %d\n",
               HSMEnterParentOnly_get_parent_enter(s));
        return 1;
    }
    printf("TC3: Re-entering Child cascades through Parent again - PASS\n");

    printf("PASS: HSM enter cascade fires Parent's $> on child entry\n");
    HSMEnterParentOnly_destroy(s);
    return 0;
}

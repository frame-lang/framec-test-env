@@[target("rust")]

@@system StateArgFwd {
    interface:
        configure(t: i32)
        process(): i32

    machine:
        $Idle {
            configure(t: i32) {
                -> $Active(t)
            }
            process(): i32 {
                @@:(0)
                return;
            }
        }

        $Active => $Frame(threshold: i32) {
            configure(t: i32) {
                -> $Active(t)
            }
            process(): i32 {
                => $^
            }
        }

        $Frame {
            process(): i32 {
                @@:(threshold)
                return;
            }
        }
    domain:
        n: i32
}

fn main() {
    println!("=== Test 65: HSM × state-args × parent-forward (Rust) ===");
    let mut s = @@StateArgFwd();

    let pre = s.process();
    if pre != 0 { println!("FAIL: pre {}", pre); std::process::exit(1); }
    println!("1. Idle process = {}", pre);

    s.configure(7);
    let r = s.process();
    if r != 7 { println!("FAIL: r {}", r); std::process::exit(1); }
    println!("2. configure(7); process() = {}", r);

    s.configure(42);
    let r2 = s.process();
    if r2 != 42 { println!("FAIL: r2 {}", r2); std::process::exit(1); }
    println!("3. configure(42); process() = {}", r2);

    println!("PASS: 65_hsm_forward_state_args");
}

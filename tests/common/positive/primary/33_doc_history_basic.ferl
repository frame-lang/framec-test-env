@@target erlang
@@system HistoryBasic {
    interface:
        gotoCFromA()
        gotoCFromB()
        gotoB()
        returnBack()
        getState(): str
    machine:
        $A {
            gotoCFromA() {
                push$
                -> $C
            }
            gotoB() { -> $B }
            getState(): str {
                @@:("A")
            }
        }
        $B {
            gotoCFromB() {
                push$
                -> $C
            }
            getState(): str {
                @@:("B")
            }
        }
        $C {
            returnBack() { -> pop$ }
            getState(): str {
                @@:("C")
            }
        }
}

@@[target("python_3")]
@@[create(make)]
@@system Counter(seed: int) {
    interface:
        bump()
        get(): int

    machine:
        $A {
            bump() { self.count = self.count + 1 }
            get(): int { @@:(self.count) }
        }

    domain:
        seed: int = seed
        count: int = 0
}

if __name__ == "__main__":
    # Default constructor still works (RFC-0015 rename is additive).
    c1 = Counter(42)
    c1.bump()
    c1.bump()
    assert c1.get() == 2, "via __init__ failed"

    # Factory rename via @@[create(make)].
    c2 = Counter.make(99)
    c2.bump()
    assert c2.get() == 1, "via .make() failed"

    print("PASS: rfc0015_create_rename")

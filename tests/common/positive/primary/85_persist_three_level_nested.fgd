@@target gdscript

extends SceneTree

@@persist
@@system Inner {
    interface:
        cycle()
        get_state(): String
        get_count(): int

    machine:
        $A {
            cycle() { self.n = self.n + 1; -> $B }
            get_state(): String { @@:("A") }
            get_count(): int { @@:(self.n) }
        }
        $B => $A {
            cycle() { -> $A }
            get_state(): String { @@:("B") }
            get_count(): int { => $^ }
        }
    domain:
        n: int = 0
}

@@system Mid {
    interface:
        cycle()
        cycle_inner()
        get_state(): String
        get_inner_state(): String
        get_inner_count(): int
        get_m(): int

    machine:
        $P {
            cycle() { self.m = self.m + 1; -> $Q }
            cycle_inner() { self.inner.cycle() }
            get_state(): String { @@:("P") }
            get_inner_state(): String { @@:(self.inner.get_state()) }
            get_inner_count(): int { @@:(self.inner.get_count()) }
            get_m(): int { @@:(self.m) }
        }
        $Q => $P {
            cycle() { -> $P }
            get_state(): String { @@:("Q") }
            cycle_inner() { => $^ }
            get_inner_state(): String { => $^ }
            get_inner_count(): int { => $^ }
            get_m(): int { => $^ }
        }
    domain:
        m: int = 0
        inner = @@Inner()
}

@@system Outer {
    interface:
        tick()
        cycle_mid()
        cycle_inner()
        get_outer_state(): String
        get_mid_state(): String
        get_inner_state(): String
        get_inner_count(): int
        get_m(): int
        get_k(): int

    machine:
        $Idle {
            tick() { self.k = self.k + 1; -> $Active }
            cycle_mid() { self.mid.cycle() }
            cycle_inner() { self.mid.cycle_inner() }
            get_outer_state(): String { @@:("Idle") }
            get_mid_state(): String { @@:(self.mid.get_state()) }
            get_inner_state(): String { @@:(self.mid.get_inner_state()) }
            get_inner_count(): int { @@:(self.mid.get_inner_count()) }
            get_m(): int { @@:(self.mid.get_m()) }
            get_k(): int { @@:(self.k) }
        }
        $Active => $Idle {
            tick() { -> $Idle }
            get_outer_state(): String { @@:("Active") }
            cycle_mid() { => $^ }
            cycle_inner() { => $^ }
            get_mid_state(): String { => $^ }
            get_inner_state(): String { => $^ }
            get_inner_count(): int { => $^ }
            get_m(): int { => $^ }
            get_k(): int { => $^ }
        }
    domain:
        k: int = 0
        mid = @@Mid()
}

func fmtProbe(o):
    return o.get_outer_state() + "/" + o.get_mid_state() + "/" + o.get_inner_state() + "/" + str(o.get_inner_count()) + "/" + str(o.get_m()) + "/" + str(o.get_k())

func must(label, o, expected):
    var actual = fmtProbe(o)
    assert(actual == expected, "FAIL " + label + ": " + actual + " expected " + expected)

func _init():
    var o = Outer.new()
    must("T0 fresh", o, "Idle/P/A/0/0/0")
    var snap0 = o.save_state()
    var r0 = Outer.restore_state(snap0)
    must("T0 restored", r0, "Idle/P/A/0/0/0")

    o.tick()
    must("T1", o, "Active/P/A/0/0/1")
    var snap1 = o.save_state()
    var r1 = Outer.restore_state(snap1)
    must("T1 restored", r1, "Active/P/A/0/0/1")

    o.cycle_mid()
    o.cycle_inner()
    must("T2", o, "Active/Q/B/1/1/1")
    var snap2 = o.save_state()
    var r2 = Outer.restore_state(snap2)
    must("T2 restored", r2, "Active/Q/B/1/1/1")

    var snap2b = r2.save_state()
    var r2b = Outer.restore_state(snap2b)
    assert(fmtProbe(r2b) == fmtProbe(r2), "FAIL idempotence: " + fmtProbe(r2b) + " != " + fmtProbe(r2))

    r2.cycle_inner()
    must("continue1", r2, "Active/Q/A/1/1/1")
    r2.cycle_mid()
    must("continue2", r2, "Active/P/A/1/1/1")
    r2.tick()
    must("continue3", r2, "Idle/P/A/1/1/1")
    r2.tick()
    must("continue4", r2, "Active/P/A/1/1/2")

    print("PASS: 85_persist_three_level_nested")
    quit()

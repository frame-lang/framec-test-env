@@[target("gdscript")]

extends SceneTree

@@[persist]
@@system L5 {
    interface:
        bump()
        get_value(): int
    machine:
        $S { bump() { self.n = self.n + 1 } get_value(): int { @@:(self.n) } }
    domain: n: int = 0
}

@@system L4 {
    interface:
        bump()
        get_value(): int
    machine:
        $S {
            bump() { self.n = self.n + 1; self.child.bump() }
            get_value(): int { @@:(self.n + self.child.get_value()) }
        }
    domain:
        n: int = 0
        child = @@L5()
}

@@system L3 {
    interface:
        bump()
        get_value(): int
    machine:
        $S {
            bump() { self.n = self.n + 1; self.child.bump() }
            get_value(): int { @@:(self.n + self.child.get_value()) }
        }
    domain:
        n: int = 0
        child = @@L4()
}

@@system L2 {
    interface:
        bump()
        get_value(): int
    machine:
        $S {
            bump() { self.n = self.n + 1; self.child.bump() }
            get_value(): int { @@:(self.n + self.child.get_value()) }
        }
    domain:
        n: int = 0
        child = @@L3()
}

@@[main]
@@system L1 {
    interface:
        bump()
        get_value(): int
    machine:
        $S {
            bump() { self.n = self.n + 1; self.child.bump() }
            get_value(): int { @@:(self.n + self.child.get_value()) }
        }
    domain:
        n: int = 0
        child = @@L2()
}

func _init():
    var a = L1.new()
    a.bump(); a.bump(); a.bump()
    var pre = a.get_value()
    assert(pre == 15, "FAIL pre: " + str(pre))
    var snap = a.save_state()
    var b = L1.restore_state(snap)
    var post = b.get_value()
    assert(post == 15, "FAIL post: " + str(post))
    b.bump()
    var after = b.get_value()
    assert(after == 20, "FAIL after: " + str(after))
    print("PASS: 83_persist_5deep")
    quit()

@@target dart

@@system ActionsTest {
    interface:
        process(value: int): int
        get_log(): String

    machine:
        $Ready {
            process(value: int): int {
                this.__log_event("start");
                this.__validate_positive(value);
                this.__log_event("valid");
                final result = value * 2;
                this.__log_event("done");
                @@:(result)
                return;
            }

            get_log(): String {
                @@:(this.log)
                return;
            }
        }
    actions:
        __log_event(msg: String) {
            this.log = this.log + msg + ";";
        }

        __validate_positive(n: int) {
            if (n < 0) {
                throw Exception("Value must be positive: ${n}");
            }
        }
    domain:
        log: String = ""

}

void main(): void {
    print("== Test 21: Actions Basic (TypeScript) ==");
    final s = @@ActionsTest();

    // Test 1: Actions are called correctly
    final result = s.process(5);
    if (result != 10) {
        throw Exception("Expected 10, got ${result}");
    }
    print("1. process(5) = ${result}");

    // Test 2: Log shows action calls
    final log = s.get_log();
    if (!log.includes("start")) {
        throw Exception("Missing 'start' in log: ${log}");
    }
    if (!log.includes("valid")) {
        throw Exception("Missing 'valid' in log: ${log}");
    }
    if (!log.includes("done")) {
        throw Exception("Missing 'done' in log: ${log}");
    }
    print("2. Log: ${log}");

    // Test 3: Action with validation
    try {
        s.process(-1);
        throw Exception("Should have thrown Error");
    } catch (e) {
        if (e instanceof Error && e.message.includes("positive")) {
            print("3. Validation caught: ${e.message}");
        } else {
            throw e;
        }
    }

    print("PASS: Actions basic works correctly");
}


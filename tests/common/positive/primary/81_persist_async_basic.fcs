@@[target("csharp")]

using System;
using System.Threading.Tasks;

@@[persist(string)]
@@[save(SaveState)]
@@[load(RestoreState)]
@@system PersistAsync {
    interface:
        async configure(amount: int)
        get(): int

    machine:
        $Idle {
            configure(amount: int) {
                this.value = await Program.AsyncCompute(amount);
                -> $Active
            }
            get(): int { @@:(0) }
        }
        $Active {
            configure(amount: int) {
                this.value = this.value + (await Program.AsyncCompute(amount));
                -> $Active
            }
            get(): int { @@:(this.value) }
        }
    domain:
        value: int = 0
}

class Program {
    public static async Task<int> AsyncCompute(int x) {
        await Task.Yield();
        return x * 2;
    }

    public static async Task Main(string[] args) {
        var s1 = new PersistAsync();
        await s1.init();
        await s1.configure(5);
        var v = await s1.get();
        if (v != 10) throw new Exception($"FAIL pre: expected 10, got {v}");
        var snap = s1.SaveState();
        var s2 = new PersistAsync();

        s2.RestoreState(snap);
        v = await s2.get();
        if (v != 10) throw new Exception($"FAIL post: expected 10, got {v}");
        await s2.configure(3);
        v = await s2.get();
        if (v != 16) throw new Exception($"FAIL post-2nd: expected 16, got {v}");
        Console.WriteLine("PASS: 81_persist_async_basic");
    }
}

@@target gdscript
extends SceneTree

@@[persist]
@@system DictOfList {
    interface:
        configure(m: Dictionary)
        get_at(key: String, idx: int): int

    machine:
        $Idle {
            configure(m: Dictionary) { -> $Active(m) }
            get_at(key: String, idx: int): int { @@:(-1) }
        }
        $Active(m: Dictionary) {
            configure(m: Dictionary) { -> $Active(m) }
            get_at(key: String, idx: int): int {
                var __l = m.get(key, [])
                if idx < __l.size():
                    @@:(__l[idx])
                else:
                    @@:(-1)
            }
        }
    domain:
        n: int = 0
}

func _initialize():
    var s1 = DictOfList.new()
    s1.configure({"a": [10, 20], "b": [30, 40, 50]})
    if s1.get_at("a", 0) != 10:
        print("FAIL pre a.0"); quit(1); return
    if s1.get_at("b", 2) != 50:
        print("FAIL pre b.2"); quit(1); return
    var snap = s1.save_state()
    var s2 = DictOfList.restore_state(snap)
    if s2.get_at("a", 0) != 10:
        print("FAIL post a.0"); quit(1); return
    if s2.get_at("a", 1) != 20:
        print("FAIL post a.1"); quit(1); return
    if s2.get_at("b", 2) != 50:
        print("FAIL post b.2"); quit(1); return
    print("PASS: 79_dict_of_list_state_arg")

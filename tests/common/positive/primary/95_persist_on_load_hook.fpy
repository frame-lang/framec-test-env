@@[target("python_3")]

@@[persist]
@@system Counter {
    operations:
        @@[save]
        save_state(): bytes {}

        @@[load]
        restore_state(data: bytes) {}

        @@[on_load]
        rebuild_derived() {
            self.doubled = self.n * 2
            self.was_restored = True
        }

    interface:
        bump()
        get_n(): int
        get_doubled(): int
        was_loaded(): bool

    machine:
        $Active {
            bump() { self.n = self.n + 1 }
            get_n(): int { @@:(self.n) }
            get_doubled(): int { @@:(self.doubled) }
            was_loaded(): bool { @@:(self.was_restored) }
        }

    domain:
        n: int = 0
        doubled: int = 0
        was_restored: bool = False
}

def main():
    c1 = Counter()
    c1.bump()
    c1.bump()
    c1.bump()
    if c1.was_loaded():
        print("FAIL: was_restored should be False before any load"); return
    if c1.get_doubled() != 0:
        print(f"FAIL: doubled should be 0 pre-restore, got {c1.get_doubled()}"); return

    data = c1.save_state()

    c2 = Counter()
    c2.restore_state(data)

    # @@[on_load] hook fires AFTER restore_state populates self —
    # it sets `doubled = n * 2` and `was_restored = True`.
    if not c2.was_loaded():
        print("FAIL: was_restored should be True after on_load fires"); return
    if c2.get_n() != 3:
        print(f"FAIL: n should be 3, got {c2.get_n()}"); return
    if c2.get_doubled() != 6:
        print(f"FAIL: doubled should be 6 (3*2), got {c2.get_doubled()}"); return

    print("PASS: 95_persist_on_load_hook")

if __name__ == '__main__':
    main()

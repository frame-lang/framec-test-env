@@target cpp_17

#include <iostream>
#include <string>
#include <cassert>

@@system SystemReturnTest {
    interface:
        add(a: int, b: int): int
        multiply(a: int, b: int): int
        greet(name: std::string): std::string
        get_value(): int

    machine:
        $Calculator {
            $.value: int = 0

            add(a: int, b: int): int {
                return a + b;
            }

            multiply(a: int, b: int): int {
                @@:return = a * b;
            }

            greet(name: std::string): std::string {
                return std::string("Hello, ") + name + std::string("!");
            }

            get_value(): int {
                $.value = 42;
                return $.value;
            }
        }
}

int main() {
    std::cout << "=== Test 13: System Return ===" << std::endl;
    SystemReturnTest calc;

    // Test return sugar
    int result = calc.add(3, 5);
    assert(result == 8);
    std::cout << "add(3, 5) = " << result << std::endl;

    // Test @@:return = expr
    result = calc.multiply(4, 7);
    assert(result == 28);
    std::cout << "multiply(4, 7) = " << result << std::endl;

    // Test string return
    std::string greeting = calc.greet("World");
    assert(greeting == "Hello, World!");
    std::cout << "greet('World') = " << greeting << std::endl;

    // Test return with state variable
    int value = calc.get_value();
    assert(value == 42);
    std::cout << "get_value() = " << value << std::endl;

    std::cout << "PASS: 13 system return" << std::endl;
    return 0;
}

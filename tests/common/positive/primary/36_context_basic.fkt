@@target kotlin

import kotlin.system.exitProcess

@@system ContextBasicTest {
    interface:
        add(a: Int, b: Int): Int
        get_event_name(): String
        greet(name: String): String

    machine:
        $Ready {
            add(a: Int, b: Int): Int {
                // Access params via @@ shorthand
                @@:return = @@:params["a"] + @@:params["b"]
            }

            get_event_name(): String {
                // Access event name
                @@:return = @@:event
            }

            greet(name: String): String {
                // Mix param access and return
                val result = "Hello, " + @@:params["name"] + "!"
                @@:return = result
            }
        }
}

fun main() {
    println("=== Test 36: Context Basic ===")
    val s = @@ContextBasicTest()

    // Test 1: @@:params["a"] and @@:params["b"] param access, @@:return
    val result1 = s.add(3, 5) as Int
    if (result1 != 8) {
        println("FAIL: Expected 8, got $result1")
        exitProcess(1)
    }
    println("1. add(3, 5) = $result1")

    // Test 2: @@:event access
    val eventName = s.get_event_name() as String
    if (eventName != "get_event_name") {
        println("FAIL: Expected 'get_event_name', got '$eventName'")
        exitProcess(1)
    }
    println("2. @@:event = '$eventName'")

    // Test 3: @@:params["name"] param access with string
    val greeting = s.greet("World") as String
    if (greeting != "Hello, World!") {
        println("FAIL: Expected 'Hello, World!', got '$greeting'")
        exitProcess(1)
    }
    println("3. greet('World') = '$greeting'")

    println("PASS: Context basic access works correctly")
}

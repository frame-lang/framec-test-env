@@target lua
@@system StateParams {
    interface:
        start(val: int)
        get_value(): int

    machine:
        $Idle {
            start(val: int) {
                -> $Counter(val)
            }

            get_value(): int {
                @@:(0)
                return
            }
        }

        $Counter(initial: int) {
            $>() {
                -- Access state param via compartment - using string key "0"
                -- Note: double underscore for __compartment to match generated class field
                $.count = self.__compartment.state_args["0"]
                count_val = $.count
                -- print
            
            }

            $.count: int = 0

            get_value(): int {
                @@:($.count)
                return
            }
        }
}

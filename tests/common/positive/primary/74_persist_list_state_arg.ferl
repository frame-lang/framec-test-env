@@target erlang
@@[persist]
@@system PersistList {
    interface:
        configure(items: list)
        firstItem(): int
        size(): int
    machine:
        $Idle {
            configure(items: list) {
                -> $Active(items)
            }
            firstItem(): int { @@:(-1) }
            size(): int { @@:(0) }
        }
        $Active(items: list) {
            configure(items: list) {
                -> $Active(items)
            }
            firstItem(): int { @@:(hd(Items)) }
            size(): int { @@:(length(Items)) }
        }
    domain:
        n = 0
}

@@target typescript

@@[persist]
@@system PFloat {
    interface:
        configure(rate: float)
        get_rate(): float

    machine:
        $Idle {
            configure(rate: number) {
                -> $Active(rate)
            }
            get_rate(): number {
                @@:(0.0)
                return
            }
        }

        $Active(rate: number) {
            get_rate(): number {
                @@:(rate)
                return
            }
        }
    domain:
        n: number = 0
}

const s = new PFloat();
s.configure(3.14159);
const snap = s.saveState();
const s2 = PFloat.restoreState(snap);
const r = s2.get_rate();
if (Math.abs(r - 3.14159) > 1e-9) { console.log("FAIL " + r); process.exit(1); }
console.log("PASS: 69_persist_float_state_arg, rate=" + r);

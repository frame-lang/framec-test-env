@@[target("swift")]

@@[persist]

import Foundation
@@[persist(String)]
@@[save(saveState)]
@@[load(restoreState)]

@@system PPushDeep {
    interface:
        descend()
        ascend()
        get_depth(): int

    machine:
        $Idle {
            descend() { push$; -> $Modal1 }
            get_depth(): int { @@:(0) }
        }
        $Modal1 {
            descend() { push$; -> $Modal2 }
            ascend() { -> pop$ }
            get_depth(): int { @@:(1) }
        }
        $Modal2 {
            descend() { push$; -> $Modal3 }
            ascend() { -> pop$ }
            get_depth(): int { @@:(2) }
        }
        $Modal3 {
            ascend() { -> pop$ }
            get_depth(): int { @@:(3) }
        }
    domain: n : int = 0
}

let s = @@PPushDeep()
s.descend(); s.descend(); s.descend()
if s.get_depth() != 3 { print("FAIL pre"); exit(1) }
let snap = s.saveState()
let s2 = @@PPushDeep()

s2.restoreState(snap)
if s2.get_depth() != 3 { print("FAIL post"); exit(1) }
s2.ascend()
if s2.get_depth() != 2 { print("FAIL a1"); exit(1) }
s2.ascend()
if s2.get_depth() != 1 { print("FAIL a2"); exit(1) }
s2.ascend()
if s2.get_depth() != 0 { print("FAIL a3"); exit(1) }
print("PASS: 71_persist_push_depth_three")

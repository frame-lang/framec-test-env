@@[target("erlang")]
@@system DictStateArg {
    interface:
        configure(m: map)
        getV(key: string): int
        size(): int
    machine:
        $Idle {
            configure(m: map) { -> $Active(m) }
            getV(key: string): int { @@:(-1) }
            size(): int { @@:(0) }
        }
        $Active(m: map) {
            configure(m: map) { -> $Active(m) }
            getV(key: string): int { @@:(maps:get(Key, M, -1)) }
            size(): int { @@:(maps:size(M)) }
        }
    domain:
        n = 0
}

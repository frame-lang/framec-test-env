@@target lua
@@system HSMEnterExitParams {
    interface:
        go_to_a()
        go_to_sibling()
        go_back()
        get_log(): list
        get_state(): str

    machine:
        $Start {
            go_to_a() {
                -> ("starting") $ChildA
            }

            get_log(): list {
                @@:(self.log)
                return
            }

            get_state(): str {
                @@:("Start")
                return
            }
        }

        $ChildA => $Parent {
            $>(msg: str) {
                self.log[#self.log + 1] = "ChildA:enter(" .. tostring(msg) .. ")"
            }

            <$(reason: str) {
                self.log[#self.log + 1] = "ChildA:exit(" .. tostring(reason) .. ")"
            }

            go_to_sibling() {
                ("leaving_A") -> ("arriving_B") $ChildB
            }

            get_log(): list {
                @@:(self.log)
                return
            }

            get_state(): str {
                @@:("ChildA")
                return
            }
        }

        $ChildB => $Parent {
            $>(msg: str) {
                self.log[#self.log + 1] = "ChildB:enter(" .. tostring(msg) .. ")"
            }

            <$(reason: str) {
                self.log[#self.log + 1] = "ChildB:exit(" .. tostring(reason) .. ")"
            }

            go_back() {
                ("leaving_B") -> ("returning_A") $ChildA
            }

            get_log(): list {
                @@:(self.log)
                return
            }

            get_state(): str {
                @@:("ChildB")
                return
            }
        }

        $Parent {
            get_log(): list {
                @@:(self.log)
                return
            }

            get_state(): str {
                @@:("Parent")
                return
            }
        }
    domain:
        log: list = []
}

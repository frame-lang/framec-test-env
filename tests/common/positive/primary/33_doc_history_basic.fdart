@@target dart
// Documentation Example: History with push$/pop$ (History201)

@@system HistoryBasic {
    interface:
        gotoC_from_A()
        gotoC_from_B()
        gotoB()
        return_back()
        get_state(): String

    machine:
        $A {
            gotoC_from_A() {
                push$
                -> $C
            }
            gotoB() {
                -> $B
            }
            get_state(): String {
                @@:("A")
                return;
            }
        }

        $B {
            gotoC_from_B() {
                push$
                -> $C
            }
            get_state(): String {
                @@:("B")
                return;
            }
        }

        $C {
            return_back() {
                -> pop$
            }
            get_state(): String {
                @@:("C")
                return;
            }
        }
}

void main() {
    print("== Test 33: Doc History Basic ==");
    final h = @@HistoryBasic();

    // Start in A
    if (h.get_state() != "A") {
        throw Exception("Expected 'A', got '${h.get_state()}'");
    }

    // Go to C from A (push A)
    h.gotoC_from_A();
    if (h.get_state() != "C") {
        throw Exception("Expected 'C', got '${h.get_state()}'");
    }

    // Return back (pop to A)
    h.return_back();
    if (h.get_state() != "A") {
        throw Exception("Expected 'A' after pop, got '${h.get_state()}'");
    }

    // Now go to B
    h.gotoB();
    if (h.get_state() != "B") {
        throw Exception("Expected 'B', got '${h.get_state()}'");
    }

    // Go to C from B (push B)
    h.gotoC_from_B();
    if (h.get_state() != "C") {
        throw Exception("Expected 'C', got '${h.get_state()}'");
    }

    // Return back (pop to B)
    h.return_back();
    if (h.get_state() != "B") {
        throw Exception("Expected 'B' after pop, got '${h.get_state()}'");
    }

    print("PASS: History push/pop works correctly");
}


@@[target("ruby")]

@@system Test {
    interface:
        ready(): TrueClass

    machine:
        $Active {
            ready(): TrueClass {
                @@:(@timer >= @threshold &&
                    @count < @limit)
            }
        }
    domain:
        timer: Integer = 100
        threshold: Integer = 50
        count: Integer = 1
        limit: Integer = 5
}

t = @@Test()
if t.ready != true
    puts "FAIL ready(): #{t.ready}"
else
    puts "PASS: 92_return_expr_multiline"
end

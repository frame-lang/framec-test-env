@@[target("kotlin")]

@@[persist]
@@system L5 {
    interface:
        bump()
        value(): Int
    machine:
        $S { bump() { this.n = this.n + 1 } value(): Int { @@:(this.n) } }
    domain: n: Int = 0
}

@@system L4 {
    interface:
        bump()
        value(): Int
    machine:
        $S {
            bump() { this.n = this.n + 1; this.child.bump() }
            value(): Int { @@:(this.n + this.child.value()) }
        }
    domain:
        n: Int = 0
        child: L5 = @@L5()
}

@@system L3 {
    interface:
        bump()
        value(): Int
    machine:
        $S {
            bump() { this.n = this.n + 1; this.child.bump() }
            value(): Int { @@:(this.n + this.child.value()) }
        }
    domain:
        n: Int = 0
        child: L4 = @@L4()
}

@@system L2 {
    interface:
        bump()
        value(): Int
    machine:
        $S {
            bump() { this.n = this.n + 1; this.child.bump() }
            value(): Int { @@:(this.n + this.child.value()) }
        }
    domain:
        n: Int = 0
        child: L3 = @@L3()
}

@@system L1 {
    interface:
        bump()
        value(): Int
    machine:
        $S {
            bump() { this.n = this.n + 1; this.child.bump() }
            value(): Int { @@:(this.n + this.child.value()) }
        }
    domain:
        n: Int = 0
        child: L2 = @@L2()
}

fun main() {
    val a = L1()
    a.bump(); a.bump(); a.bump()
    val pre = a.value()
    check(pre == 15) { "FAIL pre: $pre" }
    val snap = a.save_state()
    val b = L1.restore_state(snap)
    val post = b.value()
    check(post == 15) { "FAIL post: $post" }
    b.bump()
    val after = b.value()
    check(after == 20) { "FAIL after: $after" }
    println("PASS: 83_persist_5deep")
}

@@[target("java")]

@@system PushSelf {
    interface:
        enter_modal()
        ping(): int
        exit_modal()
        compute(): int

    machine:
        $Idle {
            enter_modal() { push$; -> $Modal }
            ping(): int { @@:(0) }
            compute(): int { @@:(99) }
        }
        $Modal {
            ping(): int { @@:(this.compute() + 1) }
            compute(): int { @@:(10) }
            exit_modal() { -> pop$ }
        }
    domain: n : int = 0
}

class Main {
    public static void main(String[] args) {
        var s = @@PushSelf();
        if (s.ping() != 0) { System.out.println("FAIL idle"); System.exit(1); }
        s.enter_modal();
        int r = s.ping();
        if (r != 11) { System.out.println("FAIL modal " + r); System.exit(1); }
        s.exit_modal();
        if (s.ping() != 0) { System.out.println("FAIL back"); System.exit(1); }
        System.out.println("PASS: 72_push_self_call");
    }
}

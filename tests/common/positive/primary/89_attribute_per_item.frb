@@[target("ruby")]

@@system Demo {
    interface:
        common(): string
        @@[target("python_3")] only_py(): string
        @@[target("ruby")] only_rb(): string

    machine:
        $S {
            common(): string { @@:("common") }
            @@[target("python_3")] only_py(): string { @@:("only_py_present") }
            @@[target("ruby")] only_rb(): string { @@:("only_rb_present") }
        }
}

d = @@Demo()
abort "FAIL common: #{d.common}" unless d.common == "common"
abort "FAIL only_rb: #{d.only_rb}" unless d.only_rb == "only_rb_present"
abort "FAIL: only_py should have been filtered out by @@[target(\"python_3\")]" if d.respond_to?(:only_py)
puts "PASS: 89_attribute_per_item"

@@target swift

// Tests that @@:return follows "last writer wins" across transition lifecycle

@@system SystemReturnChainTest {
    interface:
        test_enter_sets(): string
        test_exit_then_enter(): string
        get_state(): string

    machine:
        $Start {
            test_enter_sets(): string {
                -> $EnterSetter
            }

            test_exit_then_enter(): string {
                -> $BothSet
            }

            get_state(): string {
                @@:("Start")
                return;
            }

            <$() {
                // Exit handler sets initial value
                @@:("from_exit")
            }
        }

        $EnterSetter {
            $>() {
                // Enter handler sets return value
                @@:("from_enter")
            }

            get_state(): string {
                @@:("EnterSetter")
                return;
            }
        }

        $BothSet {
            $>() {
                // Enter handler sets return - should overwrite exit value
                @@:("enter_wins")
            }

            get_state(): string {
                @@:("BothSet")
                return;
            }
        }
}

// main
    print("=== Test 15: System Return Chain (Last Writer Wins) ===")

    // Test 1: Start exit + EnterSetter enter
    // Start's exit sets "from_exit", EnterSetter's enter sets "from_enter"
    // Enter should win (last writer)
    let s1 = @@SystemReturnChainTest()
    let result1 = s1.test_enter_sets()
    if result1 != "from_enter" {
        fatalError("Expected 'from_enter', got '\(result1)'")
    }
    if s1.get_state() != "EnterSetter" {
        fatalError("Expected state 'EnterSetter'")
    }
    print("1. Exit set then enter set - enter wins: '\(result1)'")

    // Test 2: Both handlers set, enter wins
    let s2 = @@SystemReturnChainTest()
    let result2 = s2.test_exit_then_enter()
    if result2 != "enter_wins" {
        fatalError("Expected 'enter_wins', got '\(result2)'")
    }
    if s2.get_state() != "BothSet" {
        fatalError("Expected state 'BothSet'")
    }
    print("2. Both set - enter wins: '\(result2)'")

    print("PASS: System return chain (last writer wins) works correctly")

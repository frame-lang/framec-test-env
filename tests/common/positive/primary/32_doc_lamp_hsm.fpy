@@[target("python_3")]

# Documentation Example: HSM Lamp with color behavior factored out

@@system LampHSM {
    interface:
        turnOn()
        turnOff()
        getColor(): str
        setColor(color: str)

    machine:
        $Off => $ColorBehavior {
            turnOn() {
                -> $On
            }
            => $^
        }

        $On => $ColorBehavior {
            $>() {
                self.turnOnLamp()
            }
            <$() {
                self.turnOffLamp()
            }
            turnOff() {
                -> $Off
            }
            => $^
        }

        $ColorBehavior {
            getColor(): str {
                @@:(self.color)
                return
            }
            setColor(color: str) {
                self.color = color
            }
        }

    actions:
        turnOnLamp() {
            self.lamp_on = True
        }
        turnOffLamp() {
            self.lamp_on = False
        }

    domain:
        color: str = "white"
        lamp_on: bool = False
}

def main():
    print("=== Test 32: Doc Lamp HSM ===")
    lamp = @@LampHSM()

    # Color behavior available in both states
    assert lamp.getColor() == "white", f"Expected 'white', got '{lamp.getColor()}'"
    lamp.setColor("red")
    assert lamp.getColor() == "red", f"Expected 'red', got '{lamp.getColor()}'"

    # Turn on
    lamp.turnOn()
    assert lamp.lamp_on == True, "Lamp should be on"

    # Color still works when on
    lamp.setColor("green")
    assert lamp.getColor() == "green", f"Expected 'green', got '{lamp.getColor()}'"

    # Turn off
    lamp.turnOff()
    assert lamp.lamp_on == False, "Lamp should be off"

    # Color still works when off
    assert lamp.getColor() == "green", f"Expected 'green', got '{lamp.getColor()}'"

    print("PASS: HSM lamp works correctly")

if __name__ == '__main__':
    main()

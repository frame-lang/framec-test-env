@@[target("ruby")]

@@system ForwardEnterFirst {
    interface:
        process()
        get_counter(): int
        get_log(): list

    machine:
        $Idle {
            process() {
                -> => $Working
            }

            get_counter(): int {
                @@:(-1)
                return
            }

            get_log(): list {
                @@:(self.log)
                return
            }
        }

        $Working {
            $.counter: int = 100

            $>() {
                self.log.push("Working:enter")
            }

            process() {
                self.log.push("Working:process:counter=" + $.counter.to_s)
                $.counter = $.counter + 1
            }

            get_counter(): int {
                @@:($.counter)
                return
            }

            get_log(): list {
                @@:(self.log)
                return
            }
        }
    domain:
        log: list = []
}

puts("=== Test 29: Forward Enter First ===")
s = ForwardEnterFirst.new

# Initial state is Idle
raise "Expected -1 in Idle" unless s.get_counter() == -1

# Call process - should forward to Working
# Correct behavior: $> runs first (inits counter=100, logs "Working:enter")
# Then process runs (logs "Working:process:counter=100", increments to 101)
s.process()

# Check counter was initialized and incremented
counter = s.get_counter()
log = s.get_log()
puts("Counter after forward: #{counter}")
puts("Log: #{log}")

# Verify $> ran first
raise "Expected 'Working:enter' in log: #{log}" unless log.include?("Working:enter")

# Verify process ran after $>
raise "Expected 'Working:process:counter=100' in log: #{log}" unless log.include?("Working:process:counter=100")

# Verify counter was incremented
raise "Expected counter=101, got #{counter}" unless counter == 101

# Verify order: enter before process
enter_idx = log.index("Working:enter")
process_idx = log.index("Working:process:counter=100")
raise "$> should run before process: #{log}" unless enter_idx < process_idx

puts("PASS: Forward sends $> first for non-$> events")

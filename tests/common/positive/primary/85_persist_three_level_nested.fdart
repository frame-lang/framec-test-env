@@[target("dart")]

import 'dart:convert';
import 'dart:io';

@@[persist]
@@system Inner {
    interface:
        cycle()
        get_state(): String
        get_count(): int

    machine:
        $A {
            cycle() { this.n = this.n + 1; -> $B }
            get_state(): String { @@:("A") }
            get_count(): int { @@:(this.n) }
        }
        $B => $A {
            cycle() { -> $A }
            get_state(): String { @@:("B") }
            get_count(): int { => $^ }
        }
    domain:
        n: int = 0
}

@@system Mid {
    interface:
        cycle()
        cycle_inner()
        get_state(): String
        get_inner_state(): String
        get_inner_count(): int
        get_m(): int

    machine:
        $P {
            cycle() { this.m = this.m + 1; -> $Q }
            cycle_inner() { this.inner.cycle(); }
            get_state(): String { @@:("P") }
            get_inner_state(): String { @@:(this.inner.get_state()) }
            get_inner_count(): int { @@:(this.inner.get_count()) }
            get_m(): int { @@:(this.m) }
        }
        $Q => $P {
            cycle() { -> $P }
            get_state(): String { @@:("Q") }
            cycle_inner() { => $^ }
            get_inner_state(): String { => $^ }
            get_inner_count(): int { => $^ }
            get_m(): int { => $^ }
        }
    domain:
        m: int = 0
        inner: Inner = @@Inner()
}

@@system Outer {
    interface:
        tick()
        cycle_mid()
        cycle_inner()
        get_outer_state(): String
        get_mid_state(): String
        get_inner_state(): String
        get_inner_count(): int
        get_m(): int
        get_k(): int

    machine:
        $Idle {
            tick() { this.k = this.k + 1; -> $Active }
            cycle_mid() { this.mid.cycle(); }
            cycle_inner() { this.mid.cycle_inner(); }
            get_outer_state(): String { @@:("Idle") }
            get_mid_state(): String { @@:(this.mid.get_state()) }
            get_inner_state(): String { @@:(this.mid.get_inner_state()) }
            get_inner_count(): int { @@:(this.mid.get_inner_count()) }
            get_m(): int { @@:(this.mid.get_m()) }
            get_k(): int { @@:(this.k) }
        }
        $Active => $Idle {
            tick() { -> $Idle }
            get_outer_state(): String { @@:("Active") }
            cycle_mid() { => $^ }
            cycle_inner() { => $^ }
            get_mid_state(): String { => $^ }
            get_inner_state(): String { => $^ }
            get_inner_count(): int { => $^ }
            get_m(): int { => $^ }
            get_k(): int { => $^ }
        }
    domain:
        k: int = 0
        mid: Mid = @@Mid()
}

String fmtProbe(Outer o) =>
    "${o.get_outer_state()}/${o.get_mid_state()}/${o.get_inner_state()}/${o.get_inner_count()}/${o.get_m()}/${o.get_k()}";

void must(String label, Outer o, String expected) {
    var actual = fmtProbe(o);
    if (actual != expected) { print("FAIL $label: $actual expected $expected"); exit(1); }
}

void main() {
    var o = Outer();
    must("T0 fresh", o, "Idle/P/A/0/0/0");
    var snap0 = o.saveState();
    var r0 = Outer.restoreState(snap0);
    must("T0 restored", r0, "Idle/P/A/0/0/0");

    o.tick();
    must("T1", o, "Active/P/A/0/0/1");
    var snap1 = o.saveState();
    var r1 = Outer.restoreState(snap1);
    must("T1 restored", r1, "Active/P/A/0/0/1");

    o.cycle_mid();
    o.cycle_inner();
    must("T2", o, "Active/Q/B/1/1/1");
    var snap2 = o.saveState();
    var r2 = Outer.restoreState(snap2);
    must("T2 restored", r2, "Active/Q/B/1/1/1");

    var snap2b = r2.saveState();
    var r2b = Outer.restoreState(snap2b);
    if (fmtProbe(r2b) != fmtProbe(r2)) { print("FAIL idempotence: ${fmtProbe(r2b)} != ${fmtProbe(r2)}"); exit(1); }

    r2.cycle_inner();
    must("continue1", r2, "Active/Q/A/1/1/1");
    r2.cycle_mid();
    must("continue2", r2, "Active/P/A/1/1/1");
    r2.tick();
    must("continue3", r2, "Idle/P/A/1/1/1");
    r2.tick();
    must("continue4", r2, "Active/P/A/1/1/2");

    print("PASS: 85_persist_three_level_nested");
}

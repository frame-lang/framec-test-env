@@[target("lua")]
@@[persist]
@@system PersistRoundtrip {
    interface:
        go_active()
        go_idle()
        get_state(): str
        set_counter(n: int)
        get_counter(): int
        add_history(msg: str)

    machine:
        $Idle {
            go_active() {
                self.history[#self.history + 1] = "idle->active"
                -> $Active
            }

            go_idle() {
                -- empty -- already idle
            
            }

            get_state(): str {
                @@:("idle")
                return
            }

            set_counter(n: int) {
                self.counter = n
            }

            get_counter(): int {
                @@:(self.counter)
                return
            }

            add_history(msg: str) {
                self.history[#self.history + 1] = "idle:" + msg
            }
        }

        $Active {
            go_active() {
                -- empty -- already active
            
            }

            go_idle() {
                self.history[#self.history + 1] = "active->idle"
                -> $Idle
            }

            get_state(): str {
                @@:("active")
                return
            }

            set_counter(n: int) {
                self.counter = n * 2
            }

            get_counter(): int {
                @@:(self.counter)
                return
            }

            add_history(msg: str) {
                self.history[#self.history + 1] = "active:" + msg
            }
        }
    domain:
        counter: int = 0
        history: list = []
        mode: str = "normal"
}

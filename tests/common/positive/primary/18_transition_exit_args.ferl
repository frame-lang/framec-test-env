@@[target("erlang")]
@@system ExitArgs {
    interface:
        shutdown()
        getLog(): str
    machine:
        $Active {
            <$(reason: str, code: int) {
                self.log = self.log ++ ",exit:" ++ reason
            }
            shutdown() {
                ("cleanup", 42) -> $Done
            }
            getLog(): str {
                @@:(self.log)
            }
        }
        $Done {
            $>() { self.log = self.log ++ ",enter_done" }
            getLog(): str {
                @@:(self.log)
            }
        }
    domain:
        log = "init"
}

@@target erlang
@@system ExitArgs {
    interface:
        shutdown()
        getLog(): str
    machine:
        $Active {
            <$(reason: str, code: int) {
                self.log = self.log ++ ",exit:" ++ reason
            }
            shutdown() {
                ("cleanup", 42) -> $Done
            }
            getLog(): str { return self.log }
        }
        $Done {
            $>() { self.log = self.log ++ ",enter_done" }
            getLog(): str { return self.log }
        }
    domain:
        log = "init"
}

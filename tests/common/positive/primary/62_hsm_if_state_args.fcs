@@[target("csharp")]

using System;

@@system HsmIfStateArgs {
    interface:
        enter_active(t: int)
        classify(v: int): int

    machine:
        $Idle {
            enter_active(t: int) {
                -> $Active(t)
            }
            classify(v: int): int {
                @@:(-1)
            }
        }

        $Active => $Frame(threshold: int) {
            enter_active(t: int) {
                -> $Active(t)
            }
            classify(v: int): int {
                if (v > threshold) {
                    @@:(1)
                } else {
                    @@:(0)
                }
            }
        }

        $Frame {
        }
    domain:
        n : int = 0
}

class Program {
    static void Main(string[] args) {
        Console.WriteLine("=== Test 62: HSM × if × state-args (C#) ===");
        var s = new HsmIfStateArgs();

        int pre = s.classify(5);
        if (pre != -1) { Console.WriteLine($"FAIL: pre {pre}"); Environment.Exit(1); }
        Console.WriteLine($"1. Idle classify(5) = {pre}");

        s.enter_active(10);
        int under = s.classify(5);
        if (under != 0) { Console.WriteLine($"FAIL: under {under}"); Environment.Exit(1); }
        Console.WriteLine($"2. classify(5) with threshold=10 → {under}");

        int over = s.classify(15);
        if (over != 1) { Console.WriteLine($"FAIL: over {over}"); Environment.Exit(1); }
        Console.WriteLine($"3. classify(15) with threshold=10 → {over}");

        int eq = s.classify(10);
        if (eq != 0) { Console.WriteLine($"FAIL: eq {eq}"); Environment.Exit(1); }
        Console.WriteLine($"4. classify(10) with threshold=10 → {eq}");

        s.enter_active(50);
        int newUnder = s.classify(15);
        if (newUnder != 0) { Console.WriteLine($"FAIL: newUnder {newUnder}"); Environment.Exit(1); }
        Console.WriteLine($"5. classify(15) with threshold=50 → {newUnder}");

        Console.WriteLine("PASS: 62_hsm_if_state_args");
    }
}

@@[target("lua")]
@@system HSMEnterChildOnly {
    interface:
        go_to_child()
        forward_action()
        get_log(): list
        get_state(): str

    machine:
        $Start {
            go_to_child() {
                -> $Child
            }

            get_log(): list {
                @@:(self.log)
                return
            }

            get_state(): str {
                @@:("Start")
                return
            }
        }

        $Child => $Parent {
            $>() {
                self.log[#self.log + 1] = "Child:enter"
            }

            forward_action() {
                self.log[#self.log + 1] = "Child:forward"
                => $^
            }

            get_log(): list {
                @@:(self.log)
                return
            }

            get_state(): str {
                @@:("Child")
                return
            }
        }

        $Parent {
            forward_action() {
                self.log[#self.log + 1] = "Parent:forward_action"
            }

            get_log(): list {
                @@:(self.log)
                return
            }

            get_state(): str {
                @@:("Parent")
                return
            }
        }
    domain:
        log: list = []
}

@@target cpp_17

#include <iostream>
#include <string>
#include <cassert>

@@system HSMForward {
    interface:
        event_a()
        event_b()
        get_count(): int

    machine:
        $Child => $Parent {
            event_a() {
                count += 1;
            }

            event_b() {
                count += 10;
                => $^
            }

            get_count(): int {
                return count;
            }
        }

        $Parent {
            event_a() {
                count += 100;
            }

            event_b() {
                count += 1000;
            }

            get_count(): int {
                return count;
            }
        }
    domain:
        int count = 0;
}

int main() {
    std::cout << "=== Test 08: HSM Forward ===" << std::endl;
    HSMForward s;

    // event_a should be handled by Child (no forward)
    s.event_a();
    int count = s.get_count();
    assert(count == 1);
    std::cout << "After event_a: count = " << count << " (expected 1)" << std::endl;

    // event_b should forward to Parent (+10 in Child, +1000 in Parent)
    s.event_b();
    count = s.get_count();
    assert(count == 1011);
    std::cout << "After event_b (forwarded): count = " << count << " (expected 1011)" << std::endl;

    std::cout << "PASS: 08 hsm" << std::endl;
    return 0;
}

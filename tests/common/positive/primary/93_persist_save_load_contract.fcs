@@[target("csharp")]

@@[persist(string)]
@@[save(SaveOp)]
@@[load(LoadOp)]
@@system Counter {
    interface:
        Bump()
        GetN(): int

    machine:
        $Active {
            Bump() {
                this.n = this.n + 1;
            }
            GetN(): int { @@:(this.n) }
        }

    domain:
        n: int = 0
}

class Program {
    static void Main() {
        Counter c1 = new Counter();
        c1.Bump();
        c1.Bump();
        c1.Bump();
        string data = c1.SaveOp();

        Counter c2 = new Counter();
        c2.LoadOp(data);
        if (c2.GetN() != 3) {
            System.Console.WriteLine($"FAIL: expected 3, got {c2.GetN()}");
            return;
        }
        System.Console.WriteLine("PASS: 93_persist_save_load_contract");
    }
}

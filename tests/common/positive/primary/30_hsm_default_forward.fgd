@@[target("gdscript")]
extends SceneTree

@@system HSMDefaultForward {
    interface:
        handled_event()
        unhandled_event()
        get_log(): list

    machine:
        $Child => $Parent {
            handled_event() {
                self.log.append("Child:handled_event")
            }

            get_log(): list {
                @@:(self.log)
                return
            }

            => $^
        }

        $Parent {
            handled_event() {
                self.log.append("Parent:handled_event")
            }

            unhandled_event() {
                self.log.append("Parent:unhandled_event")
            }

            get_log(): list {
                @@:(self.log)
                return
            }
        }
    domain:
        log: list = []
}

func main():
    print("=== Test 30: HSM State-Level Default Forward ===")
    var s = @@HSMDefaultForward()

    s.handled_event()
    var log = s.get_log()
    assert("Child:handled_event" in log, "Expected 'Child:handled_event' in log, got " + str(log))
    print("After handled_event: " + str(log))

    s.unhandled_event()
    log = s.get_log()
    assert("Parent:unhandled_event" in log, "Expected 'Parent:unhandled_event' in log (forwarded), got " + str(log))
    print("After unhandled_event (forwarded): " + str(log))

    print("PASS: HSM state-level default forward works correctly")

func _init():
    main()
    quit()

@@[target("lua")]

@@[persist(string)]
@@[save(save_state)]
@@[load(restore_state)]
@@system PPushDeep {
    interface:
        descend()
        ascend()
        get_depth(): int

    machine:
        $Idle {
            descend() { push$; -> $Modal1 }
            get_depth(): int { @@:(0); return }
        }
        $Modal1 {
            descend() { push$; -> $Modal2 }
            ascend() { -> pop$ }
            get_depth(): int { @@:(1); return }
        }
        $Modal2 {
            descend() { push$; -> $Modal3 }
            ascend() { -> pop$ }
            get_depth(): int { @@:(2); return }
        }
        $Modal3 {
            ascend() { -> pop$ }
            get_depth(): int { @@:(3); return }
        }
    domain: n: int = 0
}

local s = PPushDeep.new()
s:descend(); s:descend(); s:descend()
if s:get_depth() ~= 3 then error("FAIL pre " .. s:get_depth()) end
local snap = s:save_state()
local s2 = PPushDeep:new()

s2:restore_state(snap)
if s2:get_depth() ~= 3 then error("FAIL post " .. s2:get_depth()) end
s2:ascend(); if s2:get_depth() ~= 2 then error("FAIL a1") end
s2:ascend(); if s2:get_depth() ~= 1 then error("FAIL a2") end
s2:ascend(); if s2:get_depth() ~= 0 then error("FAIL a3") end
print("PASS: 71_persist_push_depth_three")

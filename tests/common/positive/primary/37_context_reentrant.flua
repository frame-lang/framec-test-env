@@target lua
@@system ContextReentrantTest {
    interface:
        outer(x: int): str
        inner(y: int): str
        deeply_nested(z: int): str
        get_both(a: int, b: int): str

    machine:
        $Ready {
            outer(x: int): str {
                @@:return = "outer_initial"
                @@:return = "outer:" + tostring(@@.x) + ",inner:" + inner_result
                -- Set our return before calling inner

                -- Call inner - should NOT clobber our return
                inner_result = self.inner(@@.x * 10)

                -- Our return should still be accessible
                -- Update it with combined result
            }

            inner(y: int): str {
                @@:return = tostring(@@.y)
                -- Inner has its own context
                -- @@.y should be inner's param, not outer's
            }

            deeply_nested(z: int): str {
                @@:return = "deep:" + tostring(@@.z) + "," + outer_result
                -- 3 levels deep
                outer_result = self.outer(@@.z)
            }

            get_both(a: int, b: int): str {
                @@:return = "a=" + tostring(@@.a) + ",b=" + tostring(@@.b) + ",results=" + result_a + "+" + result_b
                -- Test that we can access multiple params
                result_a = self.inner(@@.a)
                result_b = self.inner(@@.b)
                -- After both inner calls, @@.a and @@.b should still be our params
            }
        }
}

@@[target("gdscript")]
extends SceneTree

# Test 41: HSM Single Parent Relationship
#
# Tests basic child-parent HSM relationship:
# - Child declares parent with `=> $Parent` syntax
# - Child can forward events to parent
# - Child remains current state after forward
# - Parent handler executes and returns control

@@system HSMSingleParent {
    interface:
        child_only()
        forward_to_parent()
        get_log(): list
        get_state(): String

    machine:
        $Child => $Parent {
            child_only() {
                self.log.append("Child:child_only")
            }

            forward_to_parent() {
                self.log.append("Child:before_forward")
                => $^
                self.log.append("Child:after_forward")
            }

            get_log(): list {
                @@:(self.log)
                return
            }

            get_state(): String {
                @@:("Child")
                return
            }
        }

        $Parent {
            forward_to_parent() {
                self.log.append("Parent:forward_to_parent")
            }

            get_log(): list {
                @@:(self.log)
                return
            }

            get_state(): String {
                @@:("Parent")
                return
            }
        }
    domain:
        log: list = []
}

func main():
    print("=== Test 41: HSM Single Parent ===")
    var s = @@HSMSingleParent()

    # TC1.1.1: Child declares parent with `=> $Parent` syntax (verified by compilation)
    print("TC1.1.1: Child-Parent relationship compiles - PASS")

    # TC1.1.2: Child can forward events to parent
    s.forward_to_parent()
    var log = s.get_log()
    assert("Child:before_forward" in log, "Expected Child:before_forward in log, got " + str(log))
    assert("Parent:forward_to_parent" in log, "Expected Parent:forward_to_parent in log, got " + str(log))
    print("TC1.1.2: Child forwards to parent - PASS (log: " + str(log) + ")")

    # TC1.1.3: Child remains the current state (no transition occurs on forward)
    var state = s.get_state()
    assert(state == "Child", "Expected state 'Child', got '" + str(state) + "'")
    print("TC1.1.3: Child remains current state after forward - PASS")

    # TC1.1.4: Parent handler executes and returns control
    # Verified by "Child:after_forward" appearing after parent execution
    assert("Child:after_forward" in log, "Expected Child:after_forward in log (after parent), got " + str(log))
    var idx_parent = log.find("Parent:forward_to_parent")
    var idx_after = log.find("Child:after_forward")
    assert(idx_after > idx_parent, "Expected Child:after_forward after Parent handler")
    print("TC1.1.4: Parent executes and returns control - PASS")

    # TC1.1.5: Child-only event not forwarded
    s.child_only()
    log = s.get_log()
    assert(log.count("Child:child_only") == 1, "Expected exactly 1 Child:child_only, got " + str(log))
    print("TC1.1.5: Child-only event handled locally - PASS")

    print("PASS: HSM single parent relationship works correctly")

func _init():
    main()
    quit()

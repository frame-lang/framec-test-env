@@[target("lua")]

-- Test 100: @@[no_persist] domain fields (RFC-0016.1)

@@[persist(string)]
@@[save(save_op)]
@@[load(load_op)]
@@system NoPersistField {
    interface:
        bump()
        set_cache(v: number)
        set_note(s: string)
        get_n(): number
        get_cache(): number
        get_note(): string

    machine:
        $Active {
            bump() { self.n = self.n + 1 }
            set_cache(v: number) { self.cache = v }
            set_note(s: string) { self.note = s }
            get_n(): number { @@:(self.n) }
            get_cache(): number { @@:(self.cache) }
            get_note(): string { @@:(self.note) }
        }

    domain:
        n: number = 0
        @@[no_persist]
        cache: number = -1
        note: string = "fresh"
}

local c1 = @@NoPersistField()
c1:bump()
c1:bump()
c1:bump()
c1:set_cache(99)
c1:set_note("hello")
local data = c1:save_op()

local c2 = @@NoPersistField()
c2:load_op(data)

if c2:get_n() ~= 3 then
    print("FAIL: expected n=3, got " .. c2:get_n())
elseif c2:get_note() ~= "hello" then
    print("FAIL: expected note=hello, got " .. c2:get_note())
elseif c2:get_cache() ~= -1 then
    print("FAIL: expected cache=-1 (domain default; @@[no_persist] field not restored), got " .. c2:get_cache())
else
    print("PASS: 100_no_persist_field")
end

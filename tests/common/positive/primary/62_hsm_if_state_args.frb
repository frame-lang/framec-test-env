@@[target("ruby")]

@@system HsmIfStateArgs {
    interface:
        enter_active(t: int)
        classify(v: int): int

    machine:
        $Idle {
            enter_active(t: int) {
                -> $Active(t)
            }
            classify(v: int): int {
                @@:(-1)
                return
            }
        }

        $Active => $Frame(threshold: int) {
            enter_active(t: int) {
                -> $Active(t)
            }
            classify(v: int): int {
                if v > threshold
                    @@:(1)
                else
                    @@:(0)
                end
                return
            }
        }

        $Frame {
        }
    domain:
        n: int = 0
}

puts("=== Test 62: HSM × if × state-args (Ruby) ===")
s = HsmIfStateArgs.new

pre = s.classify(5)
raise "Expected -1 in Idle, got #{pre}" unless pre == -1
puts("1. Idle classify(5) = #{pre}")

s.enter_active(10)
under = s.classify(5)
raise "Expected 0 (under), got #{under}" unless under == 0
puts("2. classify(5) with threshold=10 → #{under}")

over = s.classify(15)
raise "Expected 1 (over), got #{over}" unless over == 1
puts("3. classify(15) with threshold=10 → #{over}")

eq = s.classify(10)
raise "Expected 0 (eq), got #{eq}" unless eq == 0
puts("4. classify(10) with threshold=10 → #{eq}")

s.enter_active(50)
newUnder = s.classify(15)
raise "Expected 0, got #{newUnder}" unless newUnder == 0
puts("5. classify(15) with threshold=50 → #{newUnder}")

puts("PASS: 62_hsm_if_state_args")

<?php
@@target php

@@[persist]
@@system PersistHsmPushpop {
    interface:
        push_modal(v: int)
        pop_modal()
        get_x(): int

    machine:
        $Idle {
            push_modal(v: int) {
                push$
                -> $Modal(v)
            }
            pop_modal() {
                -> pop$
            }
            get_x(): int {
                @@:(-99)
                return;
            }
        }

        $Modal => $Frame(x: int) {
            push_modal(v: int) {
                push$
                -> $Modal(v)
            }
            pop_modal() {
                -> pop$
            }
            get_x(): int {
                @@:($x)
                return;
            }
        }

        $Frame {
        }
    domain:
        v: int = 0
}

echo "=== Test 60: Persist × HSM × push/pop (PHP) ===\n";
$s1 = new PersistHsmPushpop();
$s1->push_modal(42);
$s1->push_modal(99);
$pre = $s1->get_x();
if ($pre !== 99) { echo "FAIL: pre $pre\n"; exit(1); }
echo "1. Pre-save top x=$pre\n";

$snap = $s1->save_state();
$s2 = PersistHsmPushpop::restore_state($snap);
$post = $s2->get_x();
if ($post !== 99) { echo "FAIL: post $post\n"; exit(1); }
echo "2. Post-restore top x=$post\n";

$s2->pop_modal();
$mid = $s2->get_x();
if ($mid !== 42) { echo "FAIL: mid $mid\n"; exit(1); }
echo "3. After first pop x=$mid\n";

$s2->pop_modal();
$bottom = $s2->get_x();
if ($bottom !== -99) { echo "FAIL: bottom $bottom\n"; exit(1); }
echo "4. After second pop x=$bottom\n";

echo "PASS: 60_persist_hsm_pushpop\n";

@@[target("csharp")]

using System;

@@[persist(string)]
@@[save(SaveState)]
@@[load(RestoreState)]
@@system PersistStateArgs {
    interface:
        kick(v: int)
        get_slot(): int

    machine:
        $Idle {
            kick(v: int) {
                -> $Active(v)
            }
            get_slot(): int {
                @@:(-1)
            }
        }

        $Active(slot: int) {
            kick(v: int) {
                -> $Active(v)
            }
            get_slot(): int {
                @@:(slot)
            }
        }
    domain:
        v : int = 0
}

class Program {
    static void Main(string[] args) {
        Console.WriteLine("=== Test 56: Persist State-Args Round-Trip (C#) ===");
        var s1 = new PersistStateArgs();
        s1.kick(42);
        int pre = s1.get_slot();
        if (pre != 42) { Console.WriteLine($"FAIL: pre {pre}"); Environment.Exit(1); }
        Console.WriteLine($"1. Pre-save slot={pre}");

        var snap = s1.SaveState();
        var s2 = new PersistStateArgs();

        s2.RestoreState(snap);
        int post = s2.get_slot();
        if (post != 42) { Console.WriteLine($"FAIL: post {post}"); Environment.Exit(1); }
        Console.WriteLine($"2. Post-restore slot={post}");

        s2.kick(99);
        int post2 = s2.get_slot();
        if (post2 != 99) { Console.WriteLine($"FAIL: post2 {post2}"); Environment.Exit(1); }
        Console.WriteLine($"3. Post-restore-kick slot={post2}");

        Console.WriteLine("PASS: 56_persist_state_args");
    }
}

@@target erlang
@@system ReturnChain {
    interface:
        getValue(): int
        goNext()
    machine:
        $A {
            getValue(): int {
                @@:(1)
            }
            goNext() { -> $B }
        }
        $B {
            getValue(): int {
                @@:(2)
            }
            goNext() { -> $C }
        }
        $C {
            getValue(): int {
                @@:(3)
            }
            goNext() { -> $A }
        }
}

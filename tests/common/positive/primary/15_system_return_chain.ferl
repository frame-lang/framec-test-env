@@target erlang
@@system ReturnChain {
    interface:
        getValue(): int
        goNext()
    machine:
        $A {
            getValue(): int { return 1 }
            goNext() { -> $B }
        }
        $B {
            getValue(): int { return 2 }
            goNext() { -> $C }
        }
        $C {
            getValue(): int { return 3 }
            goNext() { -> $A }
        }
}

@@[target("swift")]

@@system WithInterface {
    interface:
        greet(name: string): string
        get_count(): number

    machine:
        $Ready {
            greet(name: string): string {
                self.call_count += 1
                @@:("Hello, " + name + "!")
                return;
            }

            get_count(): number {
                @@:(self.call_count)
                return;
            }
        }
    domain:
        call_count: number = 0
}

// main
    print("=== Test 02: Interface Methods ===")
    let s = @@WithInterface()

    // Test interface method with parameter and return
    let result = s.greet("World")
    if result != "Hello, World!" {
        fatalError("Expected 'Hello, World!', got '\(result)'")
    }
    print("greet('World') = \(result)")

    // Test domain variable access through interface
    var count = s.get_count()
    if count != 1 {
        fatalError("Expected count=1, got \(count)")
    }
    print("get_count() = \(count)")

    // Call again to verify state
    let _ = s.greet("Frame")
    let count2 = s.get_count()
    if count2 != 2 {
        fatalError("Expected count=2, got \(count2)")
    }
    print("After second call: get_count() = \(count2)")

    print("PASS: Interface methods work correctly")

@@[target("erlang")]
@@[persist]
@@[save(save_op)]
@@[load(load_op)]
@@system NoPersistField {
    interface:
        bump()
        set_cache(v: int)
        set_note(s: str)
        get_n(): int
        get_cache(): int
        get_note(): str
    machine:
        $Active {
            bump() { self.n = self.n + 1 }
            set_cache(v: int) { self.cache = v }
            set_note(s: str) { self.note = s }
            get_n(): int { @@:(self.n) }
            get_cache(): int { @@:(self.cache) }
            get_note(): str { @@:(self.note) }
        }
    domain:
        n = 0
        @@[no_persist]
        cache = -1
        note = "fresh"
}

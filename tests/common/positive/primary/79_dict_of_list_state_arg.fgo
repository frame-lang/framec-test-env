@@target go

package main

import (
    "encoding/json"
    "fmt"
    "os"
)

var _ = json.Marshal

@@[persist]
@@system DictOfList {
    interface:
        Configure(m: map[string][]int)
        GetAt(key: string, idx: int): int

    machine:
        $Idle {
            Configure(m: map[string][]int) { -> $Active(m) }
            GetAt(key: string, idx: int): int { @@:(-1); return; }
        }
        $Active(m: map[string][]int) {
            Configure(m: map[string][]int) { -> $Active(m) }
            GetAt(key: string, idx: int): int {
                if v, ok := m[key]; ok && idx < len(v) { @@:(v[idx]); return }
                @@:(-1); return;
            }
        }
    domain:
        n: int = 0
}

func main() {
    s1 := NewDictOfList()
    s1.Configure(map[string][]int{
        "a": {10, 20},
        "b": {30, 40, 50},
    })
    if s1.GetAt("a", 0) != 10 { fmt.Println("FAIL pre"); os.Exit(1) }
    snap := s1.SaveState()
    s2 := RestoreDictOfList(snap)
    if s2.GetAt("a", 0) != 10 { fmt.Println("FAIL post a.0 got", s2.GetAt("a", 0)); os.Exit(1) }
    if s2.GetAt("a", 1) != 20 { fmt.Println("FAIL post a.1"); os.Exit(1) }
    if s2.GetAt("b", 2) != 50 { fmt.Println("FAIL post b.2"); os.Exit(1) }
    fmt.Println("PASS: 79_dict_of_list_state_arg")
}

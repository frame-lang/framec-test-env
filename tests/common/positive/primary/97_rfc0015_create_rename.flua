@@[target("lua")]
@@[create(make)]
@@system Counter(seed: number) {
    interface:
        bump()
        get(): number

    machine:
        $A {
            bump() { self.count = self.count + 1 }
            get(): number { @@:(self.count) }
        }

    domain:
        seed: number = seed
        count: number = 0
}

local c1 = @@Counter(42)
c1:bump()
c1:bump()
if c1:get() ~= 2 then
    print("FAIL: via Counter:new expected 2, got " .. c1:get())
    return
end

local c2 = Counter.make(99)
c2:bump()
if c2:get() ~= 1 then
    print("FAIL: via Counter.make expected 1, got " .. c2:get())
    return
end

print("PASS: rfc0015_create_rename")

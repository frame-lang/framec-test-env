@@[target("erlang")]

% Test 104: RFC-0019 leaf-override of ancestor lifecycle
%
% A child with its own $> handler and NO `=> $^` forward overrides
% the ancestor's $>. Inverse of fixtures 46/47 (which verify
% forwarding) — verifies non-forwarding: when the leaf does not
% forward, the ancestor's frame_enter helper is never called and
% the parent's state-var initializers do NOT run.

@@system HSMOverride {
    interface:
        getLog(): str
    machine:
        $Child => $Parent {
            $>() {
                % NO `=> $^` — ancestor $> must NOT run.
                self.log = self.log ++ ",child_enter"
            }
            getLog(): str {
                @@:(self.log)
            }
        }
        $Parent {
            $>() { self.log = self.log ++ ",parent_enter" }
            getLog(): str {
                @@:(self.log)
            }
        }
    domain:
        log = "init"
}

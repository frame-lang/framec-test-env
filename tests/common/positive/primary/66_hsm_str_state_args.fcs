@@[target("csharp")]

using System;

@@system StrStateArg {
    interface:
        configure(label: str)
        identify(): str

    machine:
        $Idle {
            configure(label: str) {
                -> $Active(label)
            }
            identify(): str {
                @@:("anonymous")
            }
        }

        $Active => $Frame(label: str) {
            configure(label: str) {
                -> $Active(label)
            }
            identify(): str {
                => $^
            }
        }

        $Frame {
            identify(): str {
                @@:(label)
            }
        }
    domain:
        n : int = 0
}

class Program {
    static void Main(string[] args) {
        var s = new StrStateArg();
        if (s.identify() != "anonymous") { Console.WriteLine("FAIL idle"); Environment.Exit(1); }
        s.configure("alice");
        if (s.identify() != "alice") { Console.WriteLine("FAIL alice"); Environment.Exit(1); }
        s.configure("bob");
        if (s.identify() != "bob") { Console.WriteLine("FAIL bob"); Environment.Exit(1); }
        Console.WriteLine("PASS: 66_hsm_str_state_args");
    }
}

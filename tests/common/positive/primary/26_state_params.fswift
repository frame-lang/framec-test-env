@@[target("swift")]

@@system StateParams {
    interface:
        start(val: number)
        get_value(): number

    machine:
        $Idle {
            start(val: number) {
                -> $Counter(val)
            }

            get_value(): number {
                @@:(0)
                return;
            }
        }

        $Counter(initial: number) {
            $>() {
                // Access state param via compartment - positional index
                $.count = self.__compartment.state_args[0] as! Int
                let count_val = $.count
                print("Counter entered with initial=\(count_val)")
            }

            $.count: number = 0

            get_value(): number {
                @@:($.count)
                return;
            }
        }
}

// main
    print("=== Test 26: State Parameters ===")
    let s = @@StateParams()

    var val = s.get_value()
    if val != 0 {
        fatalError("Expected 0 in Idle, got \(val)")
    }
    print("Initial value: \(val)")

    s.start(42)
    val = s.get_value()
    if val != 42 {
        fatalError("Expected 42 in Counter from state param, got \(val)")
    }
    print("Value after transition: \(val)")

    print("PASS: State parameters work correctly")

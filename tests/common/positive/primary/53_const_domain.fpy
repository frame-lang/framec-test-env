@@[target("python_3")]

@@system Sensor(threshold: int = 100) {
    interface:
        read(): int
        calibrate(offset: int)
        get_threshold(): int

    machine:
        $Active {
            read(): int {
                @@:(self.value + self.offset)
                return
            }
            calibrate(offset: int) {
                self.offset = offset
            }
            get_threshold(): int {
                @@:(self.threshold)
                return
            }
        }

    domain:
        const threshold : int = threshold
        value : int = 50
        offset : int = 0
}

failures = 0
s = @@Sensor(200)

if s.get_threshold() != 200:
    print(f"FAIL: expected threshold 200, got {s.get_threshold()}")
    failures += 1

if s.read() != 50:
    print(f"FAIL: expected read 50, got {s.read()}")
    failures += 1

s.calibrate(10)
if s.read() != 60:
    print(f"FAIL: expected read 60, got {s.read()}")
    failures += 1

s2 = @@Sensor()
if s2.get_threshold() != 100:
    print(f"FAIL: expected default threshold 100, got {s2.get_threshold()}")
    failures += 1

if failures > 0:
    print(f"FAIL: const_domain ({failures} failures)")
    exit(1)
print("PASS: const_domain")

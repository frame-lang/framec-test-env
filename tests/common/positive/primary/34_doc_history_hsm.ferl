@@target erlang
@@system HistoryHSM {
    interface:
        goSub()
        goBack()
        parentAction()
        getState(): str
        getLog(): str
    machine:
        $Main => $MainParent {
            $>() { self.log = self.log ++ ",main_enter" }
            goSub() {
                push$
                -> $Sub
            }
            getState(): str { return "Main" }
        }
        $Sub {
            goBack() { -> pop$ }
            getState(): str { return "Sub" }
            getLog(): str { return self.log }
        }
        $MainParent {
            parentAction() {
                self.log = self.log ++ ",parent_action"
            }
            getLog(): str { return self.log }
        }
    domain:
        log = "init"
}

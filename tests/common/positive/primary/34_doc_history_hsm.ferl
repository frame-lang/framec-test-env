@@[target("erlang")]
@@system HistoryHSM {
    interface:
        goSub()
        goBack()
        parentAction()
        getState(): str
        getLog(): str
    machine:
        $Main => $MainParent {
            $>() { self.log = self.log ++ ",main_enter" }
            goSub() {
                push$
                -> $Sub
            }
            getState(): str {
                @@:("Main")
            }
        }
        $Sub {
            goBack() { -> pop$ }
            getState(): str {
                @@:("Sub")
            }
            getLog(): str {
                @@:(self.log)
            }
        }
        $MainParent {
            parentAction() {
                self.log = self.log ++ ",parent_action"
            }
            getLog(): str {
                @@:(self.log)
            }
        }
    domain:
        log = "init"
}

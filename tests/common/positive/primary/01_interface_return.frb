@@target ruby

# =============================================================================
# Test 01: Interface Return
# =============================================================================
# Validates that event handler returns work correctly via the context stack.
# Tests both syntaxes:
# =============================================================================

@@system InterfaceReturn {
    interface:
        bool_return(): bool
        int_return(): int
        string_return(): str
        conditional_return(x: int): str
        computed_return(a: int, b: int): int
        explicit_bool(): bool
        explicit_int(): int
        explicit_string(): str
        explicit_conditional(x: int): str
        explicit_computed(a: int, b: int): int

    machine:
        $Active {
            bool_return(): bool {
                @@:(true)
                return
            }

            int_return(): int {
                @@:(42)
                return
            }

            string_return(): str {
                @@:("Frame")
                return
            }

            conditional_return(x: int): str {
                if x < 0
                    @@:("negative")
                    return
                elsif x == 0
                    @@:("zero")
                    return
                else
                    @@:("positive")
                    return
                end
            }

            computed_return(a: int, b: int): int {
                result = a * b + 10
                @@:(result)
                return
            }

            explicit_bool(): bool {
                @@:(true)
            }

            explicit_int(): int {
                @@:(42)
            }

            explicit_string(): str {
                @@:("Frame")
            }

            explicit_conditional(x: int): str {
                if x < 0
                    @@:("negative")
                    return
                elsif x == 0
                    @@:("zero")
                    return
                else
                    @@:("positive")
                end
            }

            explicit_computed(a: int, b: int): int {
                result = a * b + 10
                @@:(result)
            }
        }
}

puts("=== Test 01: Interface Return (Ruby) ===")
s = InterfaceReturn.new
errors = []

puts("-- Testing 'return value' sugar --")

r = s.bool_return()
if r != true
    errors.push("bool_return: expected true, got #{r}")
else
    puts("1. bool_return() = #{r}")
end

r = s.int_return()
if r != 42
    errors.push("int_return: expected 42, got #{r}")
else
    puts("2. int_return() = #{r}")
end

r = s.string_return()
if r != "Frame"
    errors.push("string_return: expected 'Frame', got '#{r}'")
else
    puts("3. string_return() = '#{r}'")
end

r = s.conditional_return(-5)
if r != "negative"
    errors.push("conditional_return(-5): expected 'negative', got '#{r}'")
end
r = s.conditional_return(0)
if r != "zero"
    errors.push("conditional_return(0): expected 'zero', got '#{r}'")
end
r = s.conditional_return(10)
if r != "positive"
    errors.push("conditional_return(10): expected 'positive', got '#{r}'")
else
    puts("4. conditional_return(-5,0,10) = 'negative','zero','positive'")
end

r = s.computed_return(3, 4)
if r != 22
    errors.push("computed_return(3,4): expected 22, got #{r}")
else
    puts("5. computed_return(3,4) = #{r}")
end


r = s.explicit_bool()
if r != true
    errors.push("explicit_bool: expected true, got #{r}")
else
    puts("6. explicit_bool() = #{r}")
end

r = s.explicit_int()
if r != 42
    errors.push("explicit_int: expected 42, got #{r}")
else
    puts("7. explicit_int() = #{r}")
end

r = s.explicit_string()
if r != "Frame"
    errors.push("explicit_string: expected 'Frame', got '#{r}'")
else
    puts("8. explicit_string() = '#{r}'")
end

r = s.explicit_conditional(-5)
if r != "negative"
    errors.push("explicit_conditional(-5): expected 'negative', got '#{r}'")
end
r = s.explicit_conditional(0)
if r != "zero"
    errors.push("explicit_conditional(0): expected 'zero', got '#{r}'")
end
r = s.explicit_conditional(10)
if r != "positive"
    errors.push("explicit_conditional(10): expected 'positive', got '#{r}'")
else
    puts("9. explicit_conditional(-5,0,10) = 'negative','zero','positive'")
end

r = s.explicit_computed(3, 4)
if r != 22
    errors.push("explicit_computed(3,4): expected 22, got #{r}")
else
    puts("10. explicit_computed(3,4) = #{r}")
end

if errors.length > 0
    errors.each do |e|
        puts("FAIL: #{e}")
    end
    raise "#{errors.length} test(s) failed"
else
    puts("PASS: All interface return tests passed")
end

@@[target("php")]

function helper_function($x) {
    return $x * 2;
}

@@system NativeCode {
    interface:
        compute(value: int): int
        use_math(): float

    machine:
        $Active {
            compute(value: int): int {
                # Native code with local variables
                $temp = $value + 10;
                $result = helper_function($temp);
                echo "Computed: {$value} -> {$result}\n";
                @@:($result)
                return;
            }

            use_math(): float {
                # Using math functions
                $result = sqrt(16) + M_PI;
                echo "Math result: {$result}\n";
                @@:($result)
                return;
            }
        }
}

echo "=== Test 04: Native Code Preservation ===" . "\n";
$s = @@NativeCode();

$result = $s->compute(5);
$expected = (5 + 10) * 2;  // 30
if ($result !== $expected) { echo "FAIL: Expected {$expected}, got {$result}\n"; exit(1); }
echo "compute(5) = {$result}" . "\n";

$math_result = $s->use_math();
$expected_math = sqrt(16) + M_PI;
if (abs($math_result - $expected_math) >= 0.001) { echo "FAIL: Expected ~{$expected_math}, got {$math_result}\n"; exit(1); }
echo "use_math() = {$math_result}" . "\n";

echo "PASS: Native code preservation works correctly" . "\n";

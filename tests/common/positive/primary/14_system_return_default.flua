@@[target("lua")]
@@system SystemReturnDefaultTest {
    interface:
        handler_sets_value(): str
        handler_no_return(): str
        get_count(): int

    machine:
        $Start {
            $.count: int = 0

            handler_sets_value(): str {
                @@:("set_by_handler")
                return
            }

            handler_no_return(): str {
                -- Does not set return - should return nil
                $.count = $.count + 1
            
            }

            get_count(): int {
                @@:($.count)
                return
            }
        }
}

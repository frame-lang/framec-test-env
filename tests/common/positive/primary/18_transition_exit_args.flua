@@target lua
@@system TransitionExitArgs {
    interface:
        leave()
        get_log(): list

    machine:
        $Active {
            <$(reason: str, code: int) {
                self.log[#self.log + 1] = "exit:" .. tostring(reason) .. ":" .. tostring(code)
            }

            leave() {
                self.log[#self.log + 1] = "leaving"
                ("cleanup", 42) -> $Done
            }

            get_log(): list {
                return self.log
            }
        }

        $Done {
            $>() {
                self.log[#self.log + 1] = "enter:done"
            }

            get_log(): list {
                return self.log
            }
        }
    domain:
        log: list = []
}

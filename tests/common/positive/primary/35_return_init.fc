@@target c

// Test: Interface method return_init
// Validates that interface methods can have default return values
// Syntax: method(): type = "default_value"

@@system ReturnInitTest {
    interface:
        get_status(): int = 0
        get_count(): int = 100
        get_flag(): int = 0
        trigger(): void

    machine:
        $Start {
            $>() {
                // Start state enter
            }
            get_status(): int {
                // Don't set return - should use default 0
            }
            get_count(): int {
                // Don't set return - should use default 100
            }
            get_flag(): int {
                // Don't set return - should use default 0
            }
            trigger() {
                -> $Active
            }
        }

        $Active {
            $>() {
                // Active state enter
            }
            get_status(): int {
                @@:(1)
                return;
            }
            get_count(): int {
                @@:(42)
                return;
            }
            get_flag(): int {
                @@:(1)
                return;
            }
            trigger() {
                -> $Start
            }
        }
}

int main() {
    printf("TAP version 14\n");
    printf("1..6\n");

    ReturnInitTest* s = @@ReturnInitTest();

    // Test 1: Default int return (status=0)
    int status = ReturnInitTest_get_status(s);
    if (status == 0) {
        printf("ok 1 - default status return is 0\n");
    } else {
        printf("not ok 1 - default status return is 0 # got %d\n", status);
    }

    // Test 2: Default int return (count=100)
    int count = ReturnInitTest_get_count(s);
    if (count == 100) {
        printf("ok 2 - default count return is 100\n");
    } else {
        printf("not ok 2 - default count return is 100 # got %d\n", count);
    }

    // Test 3: Default int return (flag=0)
    int flag = ReturnInitTest_get_flag(s);
    if (flag == 0) {
        printf("ok 3 - default flag return is 0\n");
    } else {
        printf("not ok 3 - default flag return is 0 # got %d\n", flag);
    }

    // Transition to Active state
    ReturnInitTest_trigger(s);

    // Test 4: Explicit return overrides default (status=1)
    status = ReturnInitTest_get_status(s);
    if (status == 1) {
        printf("ok 4 - explicit return overrides default status\n");
    } else {
        printf("not ok 4 - explicit return overrides default status # got %d\n", status);
    }

    // Test 5: Explicit return overrides default (count=42)
    count = ReturnInitTest_get_count(s);
    if (count == 42) {
        printf("ok 5 - explicit return overrides default count\n");
    } else {
        printf("not ok 5 - explicit return overrides default count # got %d\n", count);
    }

    // Test 6: Explicit return overrides default (flag=1)
    flag = ReturnInitTest_get_flag(s);
    if (flag == 1) {
        printf("ok 6 - explicit return overrides default flag\n");
    } else {
        printf("not ok 6 - explicit return overrides default flag # got %d\n", flag);
    }

    printf("# PASS - return_init provides default return values\n");
    ReturnInitTest_destroy(s);
    return 0;
}

@@[target("ruby")]

# Test: Context Stack Reentrancy
# Validates that nested interface calls maintain separate contexts

@@system ContextReentrantTest {
    interface:
        outer(x: int): str
        inner(y: int): str
        deeply_nested(z: int): str
        get_both(a: int, b: int): str

    machine:
        $Ready {
            outer(x: int): str {
                # Set our return before calling inner
                @@:("outer_initial")

                # Call inner - should NOT clobber our return
                inner_result = self.inner(@@:params.x * 10)

                # Our return should still be accessible
                # Update it with combined result
                @@:("outer:" + @@:params.x.to_s + ",inner:" + inner_result)
            }

            inner(y: int): str {
                # Inner has its own context
                # @@:params.y should be inner's param, not outer's
                @@:(@@:params.y.to_s)
            }

            deeply_nested(z: int): str {
                # 3 levels deep
                outer_result = self.outer(@@:params.z)
                @@:("deep:" + @@:params.z.to_s + "," + outer_result)
            }

            get_both(a: int, b: int): str {
                # Test that we can access multiple params
                result_a = self.inner(@@:params.a)
                result_b = self.inner(@@:params.b)
                # After both inner calls, @@:params.a and @@:params.b should still be our params
                @@:("a=" + @@:params.a.to_s + ",b=" + @@:params.b.to_s + ",results=" + result_a + "+" + result_b)
            }
        }
}

puts("=== Test 37: Context Reentrant ===")
s = @@ContextReentrantTest()

# Test 1: Simple nesting - outer calls inner
result = s.outer(5)
expected = "outer:5,inner:50"
raise "Expected '#{expected}', got '#{result}'" unless result == expected
puts("1. outer(5) = '#{result}'")

# Test 2: Inner alone
result = s.inner(42)
raise "Expected '42', got '#{result}'" unless result == "42"
puts("2. inner(42) = '#{result}'")

# Test 3: Deep nesting (3 levels)
result = s.deeply_nested(3)
expected = "deep:3,outer:3,inner:30"
raise "Expected '#{expected}', got '#{result}'" unless result == expected
puts("3. deeply_nested(3) = '#{result}'")

# Test 4: Multiple inner calls, params preserved
result = s.get_both(10, 20)
expected = "a=10,b=20,results=10+20"
raise "Expected '#{expected}', got '#{result}'" unless result == expected
puts("4. get_both(10, 20) = '#{result}'")

puts("PASS: Context reentrant works correctly")

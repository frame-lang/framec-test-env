@@target erlang
@@system HSMEnterParent {
    interface:
        getLog(): str
    machine:
        $Child => $Parent {
            getLog(): str { return self.log }
        }
        $Parent {
            $>() { self.log = self.log ++ ",parent_enter" }
            getLog(): str { return self.log }
        }
    domain:
        log = "init"
}

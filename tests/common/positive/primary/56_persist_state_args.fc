@@[target("c")]

#include <stdio.h>
#include <stdlib.h>
#include <string.h>
#include <cjson/cJSON.h>

@@[persist]
@@system PersistStateArgs {
    operations:
        @@[save]
        save_state(): char* {}

        @@[load]
        restore_state(data: char*) {}

    interface:
        kick(v: int)
        get_slot(): int

    machine:
        $Idle {
            kick(v: int) {
                -> $Active(v)
            }
            get_slot(): int {
                @@:(-1)
            }
        }

        $Active(slot: int) {
            kick(v: int) {
                -> $Active(v)
            }
            get_slot(): int {
                @@:(slot)
            }
        }
    domain:
        v : int = 0
}

int main(void) {
    printf("=== Test 56: Persist State-Args Round-Trip (C) ===\n");
    PersistStateArgs* s1 = PersistStateArgs_new();
    PersistStateArgs_kick(s1, 42);
    int pre = PersistStateArgs_get_slot(s1);
    if (pre != 42) { printf("FAIL: pre %d\n", pre); return 1; }
    printf("1. Pre-save slot=%d\n", pre);

    char* snap = PersistStateArgs_save_state(s1);
    PersistStateArgs* s2 = @@PersistStateArgs();

    PersistStateArgs_restore_state(s2, snap);
    int post = PersistStateArgs_get_slot(s2);
    if (post != 42) { printf("FAIL: post %d\n", post); return 1; }
    printf("2. Post-restore slot=%d\n", post);

    PersistStateArgs_kick(s2, 99);
    int post2 = PersistStateArgs_get_slot(s2);
    if (post2 != 99) { printf("FAIL: post2 %d\n", post2); return 1; }
    printf("3. Post-restore-kick slot=%d\n", post2);

    printf("PASS: 56_persist_state_args\n");
    free(snap);
    PersistStateArgs_destroy(s1);
    PersistStateArgs_destroy(s2);
    return 0;
}

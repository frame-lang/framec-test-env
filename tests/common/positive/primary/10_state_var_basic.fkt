@@target kotlin

import kotlin.system.exitProcess

@@system StateVarBasic {
    interface:
        increment(): Int
        get_count(): Int
        reset()

    machine:
        $Counter {
            $.count: Int = 0

            increment(): Int {
                $.count = $.count + 1
                @@:($.count)
                return;
            }

            get_count(): Int {
                @@:($.count)
                return;
            }

            reset() {
                $.count = 0
            }
        }
}

fun main() {
    println("=== Test 10: State Variable Basic ===")
    val s = StateVarBasic()

    // Initial value should be 0
    var count = s.get_count() as Int
    if (count != 0) {
        throw RuntimeException("Expected 0, got $count")
    }
    println("Initial count: $count")

    // Increment should return new value
    var result = s.increment() as Int
    if (result != 1) {
        throw RuntimeException("Expected 1 after first increment, got $result")
    }
    println("After first increment: $result")

    // Second increment
    result = s.increment() as Int
    if (result != 2) {
        throw RuntimeException("Expected 2 after second increment, got $result")
    }
    println("After second increment: $result")

    // Reset should set back to 0
    s.reset()
    count = s.get_count() as Int
    if (count != 0) {
        throw RuntimeException("Expected 0 after reset, got $count")
    }
    println("After reset: $count")

    println("PASS: State variable basic operations work correctly")
}

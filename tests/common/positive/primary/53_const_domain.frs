@@[target("rust")]

// Test: const domain field initialized from system param.
// Validates:
// 1. const domain field is set from system param
// 2. non-const domain fields are mutable
// 3. default system param value works

@@system Sensor(threshold: i32 = 100) {
    interface:
        read(): i32
        calibrate(offset: i32)
        get_threshold(): i32

    machine:
        $Active {
            read(): i32 {
                @@:(self.value + self.offset)
                return;
            }
            calibrate(offset: i32) {
                self.offset = offset;
            }
            get_threshold(): i32 {
                @@:(self.threshold)
                return;
            }
        }

    domain:
        const threshold : i32 = threshold
        value : i32 = 50
        offset : i32 = 0
}

fn main() {
    let mut failures = 0;

    // Test 1: system param override
    let mut s = @@Sensor(200);
    let t = s.get_threshold();
    if t != 200 {
        println!("FAIL test 1: expected threshold 200, got {}", t);
        failures += 1;
    }

    // Test 2: read returns value + offset
    let v = s.read();
    if v != 50 {
        println!("FAIL test 2: expected read 50, got {}", v);
        failures += 1;
    }

    // Test 3: calibrate changes offset
    s.calibrate(10);
    let v = s.read();
    if v != 60 {
        println!("FAIL test 3: expected read 60 after calibrate, got {}", v);
        failures += 1;
    }

    // Test 4: default system param
    let mut s2 = @@Sensor();
    let t2 = s2.get_threshold();
    if t2 != 100 {
        println!("FAIL test 4: expected default threshold 100, got {}", t2);
        failures += 1;
    }

    if failures > 0 {
        println!("FAIL: const_domain ({} failures)", failures);
        std::process::exit(1);
    }
    println!("PASS: const_domain");
}

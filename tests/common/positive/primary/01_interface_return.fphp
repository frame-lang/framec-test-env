<?php
@@target php

# =============================================================================
# Test 01: Interface Return
# =============================================================================
# Validates that event handler returns work correctly via the context stack.
# Tests both syntaxes:
#   - return value     (sugar - expands to @@:return = value)
#   - @@:return = value (explicit context assignment)
# =============================================================================

@@system InterfaceReturn {
    interface:
        bool_return(): bool
        int_return(): int
        string_return(): str
        conditional_return(x: int): str
        computed_return(a: int, b: int): int
        explicit_bool(): bool
        explicit_int(): int
        explicit_string(): str
        explicit_conditional(x: int): str
        explicit_computed(a: int, b: int): int

    machine:
        $Active {
            bool_return(): bool {
                return true
            }

            int_return(): int {
                return 42
            }

            string_return(): str {
                return "Frame"
            }

            conditional_return(x: int): str {
                if ($x < 0) {
                    return "negative";
                } elseif ($x == 0) {
                    return "zero";
                } else {
                    return "positive";
                }
            }

            computed_return(a: int, b: int): int {
                $result = $a * $b + 10;
                return $result;
            }

            explicit_bool(): bool {
                @@:return = true
            }

            explicit_int(): int {
                @@:return = 42
            }

            explicit_string(): str {
                @@:return = "Frame"
            }

            explicit_conditional(x: int): str {
                if ($x < 0) {
                    @@:return = "negative"
                    return;
                } elseif ($x == 0) {
                    @@:return = "zero"
                    return;
                } else {
                    @@:return = "positive"
                }
            }

            explicit_computed(a: int, b: int): int {
                $result = $a * $b + 10;
                @@:return = $result
            }
        }
}

echo "=== Test 01: Interface Return (PHP) ===" . "\n";
$s = new InterfaceReturn();
$errors = [];

echo "-- Testing 'return value' sugar --" . "\n";

$r = $s->bool_return();
if ($r !== true) {
    $errors[] = "bool_return: expected true, got " . var_export($r, true);
} else {
    echo "1. bool_return() = " . var_export($r, true) . "\n";
}

$r = $s->int_return();
if ($r !== 42) {
    $errors[] = "int_return: expected 42, got {$r}";
} else {
    echo "2. int_return() = {$r}" . "\n";
}

$r = $s->string_return();
if ($r !== "Frame") {
    $errors[] = "string_return: expected 'Frame', got '{$r}'";
} else {
    echo "3. string_return() = '{$r}'" . "\n";
}

$r = $s->conditional_return(-5);
if ($r !== "negative") {
    $errors[] = "conditional_return(-5): expected 'negative', got '{$r}'";
}
$r = $s->conditional_return(0);
if ($r !== "zero") {
    $errors[] = "conditional_return(0): expected 'zero', got '{$r}'";
}
$r = $s->conditional_return(10);
if ($r !== "positive") {
    $errors[] = "conditional_return(10): expected 'positive', got '{$r}'";
} else {
    echo "4. conditional_return(-5,0,10) = 'negative','zero','positive'" . "\n";
}

$r = $s->computed_return(3, 4);
if ($r !== 22) {
    $errors[] = "computed_return(3,4): expected 22, got {$r}";
} else {
    echo "5. computed_return(3,4) = {$r}" . "\n";
}

echo "-- Testing '@@:return = value' explicit --" . "\n";

$r = $s->explicit_bool();
if ($r !== true) {
    $errors[] = "explicit_bool: expected true, got " . var_export($r, true);
} else {
    echo "6. explicit_bool() = " . var_export($r, true) . "\n";
}

$r = $s->explicit_int();
if ($r !== 42) {
    $errors[] = "explicit_int: expected 42, got {$r}";
} else {
    echo "7. explicit_int() = {$r}" . "\n";
}

$r = $s->explicit_string();
if ($r !== "Frame") {
    $errors[] = "explicit_string: expected 'Frame', got '{$r}'";
} else {
    echo "8. explicit_string() = '{$r}'" . "\n";
}

$r = $s->explicit_conditional(-5);
if ($r !== "negative") {
    $errors[] = "explicit_conditional(-5): expected 'negative', got '{$r}'";
}
$r = $s->explicit_conditional(0);
if ($r !== "zero") {
    $errors[] = "explicit_conditional(0): expected 'zero', got '{$r}'";
}
$r = $s->explicit_conditional(10);
if ($r !== "positive") {
    $errors[] = "explicit_conditional(10): expected 'positive', got '{$r}'";
} else {
    echo "9. explicit_conditional(-5,0,10) = 'negative','zero','positive'" . "\n";
}

$r = $s->explicit_computed(3, 4);
if ($r !== 22) {
    $errors[] = "explicit_computed(3,4): expected 22, got {$r}";
} else {
    echo "10. explicit_computed(3,4) = {$r}" . "\n";
}

if (count($errors) > 0) {
    foreach ($errors as $e) {
        echo "FAIL: {$e}" . "\n";
    }
    throw new \Exception(count($errors) . " test(s) failed");
} else {
    echo "PASS: All interface return tests passed" . "\n";
}

@@[target("swift")]


@@system ListStateArg {
    interface:
        configure(items: [Int])
        first_item(): Int
        size(): Int

    machine:
        $Idle {
            configure(items: [Int]) {
                -> $Active(items)
            }
            first_item(): Int {
                @@:(-1)
            }
            size(): Int {
                @@:(0)
            }
        }
        $Active(items: [Int]) {
            configure(items: [Int]) {
                -> $Active(items)
            }
            first_item(): Int {
                @@:(items[0])
            }
            size(): Int {
                @@:(items.count)
            }
        }
    domain:
        n : Int = 0
}

let s = @@ListStateArg()
if s.first_item() != -1 { print("FAIL idle first_item"); exit(1) }
if s.size() != 0 { print("FAIL idle size"); exit(1) }
s.configure([10, 20, 30])
if s.first_item() != 10 { print("FAIL active first_item"); exit(1) }
if s.size() != 3 { print("FAIL active size"); exit(1) }
s.configure([7])
if s.first_item() != 7 { print("FAIL retransition first_item"); exit(1) }
if s.size() != 1 { print("FAIL retransition size"); exit(1) }
print("PASS: 73_list_state_arg")

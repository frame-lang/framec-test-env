@@target dart

@@persist

import 'dart:io';
import 'dart:convert';

@@system PFloat {
    interface:
        configure(rate: double)
        get_rate(): double

    machine:
        $Idle {
            configure(rate: double) {
                -> $Active(rate)
            }
            get_rate(): double {
                @@:(0.0)
                return;
            }
        }

        $Active(rate: double) {
            get_rate(): double {
                @@:(rate)
                return;
            }
        }
    domain:
        n: int = 0
}

void main() {
    final s = PFloat();
    s.configure(3.14159);
    final snap = s.saveState();
    final s2 = PFloat.restoreState(snap);
    final r = s2.get_rate();
    if ((r - 3.14159).abs() > 1e-9) { print("FAIL $r"); exit(1); }
    print("PASS: 69_persist_float_state_arg, rate=$r");
}

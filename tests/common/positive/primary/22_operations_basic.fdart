@@[target("dart")]
@@system OperationsTest {
    operations:
        add(x: num, y: num): num {
            return x + y;
        }

        multiply(x: num, y: num): num {
            return x * y;
        }

        static factorial(n: num): num {
            if (n <= 1) {
                return 1;
            }
            return n * OperationsTest.factorial(n - 1);
        }

        static is_even(n: num): bool {
            return n % 2 == 0;
        }
    interface:
        compute(a: num, b: num): num
        get_last_result(): num

    machine:
        $Ready {
            compute(a: num, b: num): num {
                // Use instance operations
                final sum_val = this.add(a, b);
                final prod_val = this.multiply(a, b);
                final last_result = sum_val + prod_val;
                @@:(last_result)
                return;
            }

            get_last_result(): num {
                @@:(this.last_result)
                return;
            }
        }
    domain:
        last_result : num = 0

}

void main() {
    print("== Test 22: Operations Basic (TypeScript) ==");
    final s = @@OperationsTest();

    // Test 1: Instance operations
    var result = s.add(3, 4);
    if (result != 7) {
        throw Exception("Expected 7, got ${result}");
    }
    print("1. add(3, 4) = ${result}");

    result = s.multiply(3, 4);
    if (result != 12) {
        throw Exception("Expected 12, got ${result}");
    }
    print("2. multiply(3, 4) = ${result}");

    // Test 2: Operations used in handler
    result = s.compute(3, 4);
    // compute returns add(3,4) + multiply(3,4) = 7 + 12 = 19
    if (result != 19) {
        throw Exception("Expected 19, got ${result}");
    }
    print("3. compute(3, 4) = ${result}");

    // Test 3: Static operations
    result = OperationsTest.factorial(5);
    if (result != 120) {
        throw Exception("Expected 120, got ${result}");
    }
    print("4. factorial(5) = ${result}");

    var is_even = OperationsTest.is_even(4);
    if (is_even != true) {
        throw Exception("Expected true, got ${is_even}");
    }
    print("5. is_even(4) = ${is_even}");

    is_even = OperationsTest.is_even(7);
    if (is_even != false) {
        throw Exception("Expected false, got ${is_even}");
    }
    print("6. is_even(7) = ${is_even}");

    // Test 4: Static via class (TypeScript doesn't allow instance.static())
    result = OperationsTest.factorial(4);
    if (result != 24) {
        throw Exception("Expected 24, got ${result}");
    }
    print("7. OperationsTest.factorial(4) = ${result}");

    print("PASS: Operations basic works correctly");
}


@@target typescript

@@[persist]
@@system PersistStateArgs {
    interface:
        kick(v: int)
        get_slot(): int

    machine:
        $Idle {
            kick(v: number) {
                -> $Active(v)
            }
            get_slot(): number {
                @@:(-1)
                return
            }
        }

        $Active(slot: number) {
            kick(v: number) {
                -> $Active(v)
            }
            get_slot(): number {
                @@:(slot)
                return
            }
        }
    domain:
        v: number = 0
}

console.log("=== Test 56: Persist State-Args Round-Trip (TS) ===");
const s1 = new PersistStateArgs();
s1.kick(42);
const pre = s1.get_slot();
if (pre !== 42) { console.log("FAIL: pre " + pre); process.exit(1); }
console.log(`1. Pre-save slot=${pre}`);

const snap = s1.saveState();
const s2 = PersistStateArgs.restoreState(snap);
const post = s2.get_slot();
if (post !== 42) { console.log("FAIL: post " + post); process.exit(1); }
console.log(`2. Post-restore slot=${post}`);

s2.kick(99);
const post2 = s2.get_slot();
if (post2 !== 99) { console.log("FAIL: post2 " + post2); process.exit(1); }
console.log(`3. Post-restore-kick slot=${post2}`);

console.log("PASS: 56_persist_state_args");

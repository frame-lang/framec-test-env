@@target c

#include <stdio.h>
#include <stdlib.h>
#include <stdint.h>

// Test: const domain field initialized from system param.

@@system Sensor(threshold: int = 100) {
    interface:
        read(): int
        calibrate(offset: int): void
        get_threshold(): int

    machine:
        $Active {
            read(): int {
                @@:(self->value + self->offset)
                return;
            }
            calibrate(offset: int) {
                self->offset = offset;
            }
            get_threshold(): int {
                @@:(self->threshold)
                return;
            }
        }

    domain:
        const threshold : int = threshold
        value : int = 50
        offset : int = 0
}

int main(void) {
    int failures = 0;

    // Test 1: system param override
    Sensor* s = @@Sensor(200);
    int t = Sensor_get_threshold(s);
    if (t != 200) { printf("FAIL test 1: expected 200, got %d\n", t); failures++; }

    // Test 2: read returns value + offset
    int v = Sensor_read(s);
    if (v != 50) { printf("FAIL test 2: expected 50, got %d\n", v); failures++; }

    // Test 3: calibrate changes offset
    Sensor_calibrate(s, 10);
    v = Sensor_read(s);
    if (v != 60) { printf("FAIL test 3: expected 60, got %d\n", v); failures++; }

    Sensor_destroy(s);

    // Test 4: default system param
    Sensor* s2 = @@Sensor();
    int t2 = Sensor_get_threshold(s2);
    if (t2 != 100) { printf("FAIL test 4: expected 100, got %d\n", t2); failures++; }

    Sensor_destroy(s2);

    if (failures > 0) {
        printf("FAIL: const_domain (%d failures)\n", failures);
        return 1;
    }
    printf("PASS: const_domain\n");
    return 0;
}

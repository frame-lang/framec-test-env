@@target ruby

@@persist
@@system PersistDict {
    interface:
        configure(m: Hash)
        get_v(key: String): int

    machine:
        $Idle {
            configure(m: Hash) { -> $Active(m) }
            get_v(key: String): int { @@:(-1) }
        }
        $Active(m: Hash) {
            configure(m: Hash) { -> $Active(m) }
            get_v(key: String): int { @@:(m.fetch(key, -1)) }
        }
    domain:
        n: int = 0
}

s1 = PersistDict.new
s1.configure({"a" => 10, "b" => 20})
abort("FAIL pre") unless s1.get_v("a") == 10
snap = s1.save_state
s2 = PersistDict.restore_state(snap)
abort("FAIL post a") unless s2.get_v("a") == 10
abort("FAIL post b") unless s2.get_v("b") == 20
puts "PASS: 77_persist_dict_state_arg"

@@[target("gdscript")]
extends SceneTree

@@system WithParams {
    interface:
        start(initial: int)
        add(value: int)
        multiply(a: int, b: int): int
        get_total(): int

    machine:
        $Idle {
            start(initial: int) {
                self.total = initial
                print("Started with initial value: " + str(initial))
                -> $Running
            }

            add(value: int) {
                print("Cannot add in Idle state")
            }

            multiply(a: int, b: int): int {
                @@:(0)
                return
            }

            get_total(): int {
                @@:(self.total)
                return
            }
        }

        $Running {
            start(initial: int) {
                print("Already running")
            }

            add(value: int) {
                self.total += value
                print("Added " + str(value) + ", total is now " + str(self.total))
            }

            multiply(a: int, b: int): int {
                var result = a * b
                self.total += result
                print("Multiplied " + str(a) + " * " + str(b) + " = " + str(result) + ", total is now " + str(self.total))
                @@:(result)
                return
            }

            get_total(): int {
                @@:(self.total)
                return
            }
        }
    domain:
        total: int = 0
}

func main():
    print("=== Test 07: Handler Parameters ===")
    var s = @@WithParams()

    # Initial total should be 0
    var total = s.get_total()
    assert(total == 0, "Expected initial total=0, got " + str(total))

    # Start with initial value
    s.start(100)
    total = s.get_total()
    assert(total == 100, "Expected total=100, got " + str(total))
    print("After start(100): total = " + str(total))

    # Add value
    s.add(25)
    total = s.get_total()
    assert(total == 125, "Expected total=125, got " + str(total))
    print("After add(25): total = " + str(total))

    # Multiply with two params
    var result = s.multiply(3, 5)
    assert(result == 15, "Expected multiply result=15, got " + str(result))
    total = s.get_total()
    assert(total == 140, "Expected total=140, got " + str(total))
    print("After multiply(3,5): result = " + str(result) + ", total = " + str(total))

    print("PASS: Handler parameters work correctly")

func _init():
    main()
    quit()

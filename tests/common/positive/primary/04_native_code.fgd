@@target gdscript
extends SceneTree


func helper_function(x):
    ## Native helper function defined before system
    return x * 2

@@system NativeCode {
    interface:
        compute(value: int): int
        use_math(): float

    machine:
        $Active {
            compute(value: int): int {
                # Native code with local variables
                var temp = value + 10
                var result = temp * 2
                print("Computed: " + str(value) + " -> " + str(result))
                @@:(result)
                return
            }

            use_math(): float {
                # Using global math functions
                var result = sqrt(16) + PI
                print("Math result: " + str(result))
                @@:(result)
                return
            }
        }
}

func main():
    print("=== Test 04: Native Code Preservation ===")
    var s = @@NativeCode()

    # Test native code in handler with helper function
    var result = s.compute(5)
    var expected = (5 + 10) * 2  # 30
    assert(result == expected, "Expected " + str(expected) + ", got " + str(result))
    print("compute(5) = " + str(result))

    # Test global math usage
    var math_result = s.use_math()
    var expected_math = sqrt(16) + PI
    assert(abs(math_result - expected_math) < 0.001, "Expected ~" + str(expected_math) + ", got " + str(math_result))
    print("use_math() = " + str(math_result))

    print("PASS: Native code preservation works correctly")

func _init():
    main()
    quit()

@@[target("kotlin")]

import kotlin.system.exitProcess

@@system WithTransition {
    interface:
        next()
        get_state(): String

    machine:
        $First {
            next() {
                -> $Second
            }

            get_state(): String {
                @@:("First")
                return;
            }
        }

        $Second {
            next() {
                -> $First
            }

            get_state(): String {
                @@:("Second")
                return;
            }
        }
}

fun main() {
    println("=== Test 03: State Transitions ===")
    val s = @@WithTransition()

    var state = s.get_state() as String
    if (state != "First") {
        println("FAIL: Expected 'First', got '$state'")
        exitProcess(1)
    }
    println("Initial state: $state")

    s.next()
    state = s.get_state() as String
    if (state != "Second") {
        println("FAIL: Expected 'Second', got '$state'")
        exitProcess(1)
    }
    println("After first next(): $state")

    s.next()
    state = s.get_state() as String
    if (state != "First") {
        println("FAIL: Expected 'First', got '$state'")
        exitProcess(1)
    }
    println("After second next(): $state")

    println("PASS: State transitions work correctly")
}

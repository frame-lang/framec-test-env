@@[target("swift")]


@@system PushSelf {
    interface:
        enter_modal()
        ping(): int
        exit_modal()
        compute(): int

    machine:
        $Idle {
            enter_modal() { push$; -> $Modal }
            ping(): int { @@:(0) }
            compute(): int { @@:(99) }
        }
        $Modal {
            ping(): int { @@:(self.compute() + 1) }
            compute(): int { @@:(10) }
            exit_modal() { -> pop$ }
        }
    domain: n : int = 0
}

let s = @@PushSelf()
if s.ping() != 0 { print("FAIL idle"); exit(1) }
s.enter_modal()
let r = s.ping()
if r != 11 { print("FAIL modal \(r)"); exit(1) }
s.exit_modal()
if s.ping() != 0 { print("FAIL back"); exit(1) }
print("PASS: 72_push_self_call")

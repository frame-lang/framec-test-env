@@[target("cpp")]

#include <iostream>
#include <cstdlib>

@@system Demo {
    interface:
        get_a(): int
        get_cpp_only(): int
    machine:
        $S {
            get_a(): int { @@:(this->a) }
            get_cpp_only(): int { @@:(this->cpp_only) }
        }
    domain:
        a: int = 1
        @@[target("python_3")] py_only: int = 2
        @@[target("cpp")]
        cpp_only: int = 42
}

int main() {
    Demo d;
    if (d.get_a() != 1) { std::cout << "FAIL get_a: " << d.get_a() << std::endl; std::exit(1); }
    if (d.get_cpp_only() != 42) { std::cout << "FAIL get_cpp_only: " << d.get_cpp_only() << std::endl; std::exit(1); }
    std::cout << "PASS: 90_attribute_domain_field" << std::endl;
    return 0;
}

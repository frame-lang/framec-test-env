@@target dart
import 'dart:convert';

// Test 46: HSM Enter Cascade — Parent has $>, Child does not
//
// Tests the HSM enter cascade per docs/frame_runtime_introduction.md
// Step 21+. When entering an HSM child, the kernel fires $> on every
// layer of the new chain top-down (parent first, child last). The child
// may have no $> handler — the cascade simply skips that layer and
// continues.

@@system HSMEnterParentOnly {
    interface:
        go_to_child()
        go_to_parent()
        get_log(): List<String>
        get_state(): str

    machine:
        $Start {
            go_to_child() { -> $Child }
            go_to_parent() { -> $Parent }
            get_log(): list { @@:(this.log) }
            get_state(): str { @@:("Start") }
        }

        $Child => $Parent {
            go_to_parent() { -> $Parent }
            get_log(): list { @@:(this.log) }
            get_state(): str { @@:("Child") }
        }

        $Parent {
            $>() {
                this.log.add("Parent:enter");
            }
            go_to_child() { -> $Child }
            get_log(): list { @@:(this.log) }
            get_state(): str { @@:("Parent") }
        }
    domain:
        log : List<String> = []
}

void main() {
    print("=== Test 46: HSM Enter Cascade — Parent only ===");
    final s = @@HSMEnterParentOnly();

    s.go_to_child();
    if (s.get_state() != "Child") throw Exception("Expected Child");
    var log = s.get_log();
    if (!log.contains("Parent:enter")) throw Exception("Expected Parent:enter on cascade");
    print("TC1: Parent's \$> fires on cascade entry to Child - PASS");

    s.go_to_parent();
    log = s.get_log();
    var count = log.where((x) => x == "Parent:enter").length;
    if (count != 2) throw Exception("Expected 2 Parent:enter, got $count");
    print("TC2: Parent's \$> fires again when transitioning directly to Parent - PASS");

    s.go_to_child();
    log = s.get_log();
    count = log.where((x) => x == "Parent:enter").length;
    if (count != 3) throw Exception("Expected 3 Parent:enter, got $count");
    print("TC3: Re-entering Child cascades through Parent again - PASS");

    print("PASS: HSM enter cascade fires Parent's \$> on child entry");
}

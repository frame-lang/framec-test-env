@@target dart
import 'dart:convert';
// Test 46: HSM Enter in Parent Only
//
// Tests enter handler in parent only:
// - Parent has $>(), child does not
// - Child enters without error (no enter handler)
// - Parent's enter does NOT auto-fire when child is entered
// - Parent enter only fires when transitioning directly TO parent

@@system HSMEnterParentOnly {
    interface:
        go_to_child()
        go_to_parent()
        get_log(): List<String>
        get_state(): str

    machine:
        $Start {
            go_to_child() {
                -> $Child
            }

            go_to_parent() {
                -> $Parent
            }

            get_log(): list {
                @@:(this.log)
                return;
            }

            get_state(): str {
                @@:("Start")
                return;
            }
        }

        $Child => $Parent {
            go_to_parent() {
                -> $Parent
            }

            get_log(): list {
                @@:(this.log)
                return;
            }

            get_state(): str {
                @@:("Child")
                return;
            }
        }

        $Parent {
            $>() {
                this.log.add("Parent:enter");
            }

            go_to_child() {
                -> $Child
            }

            get_log(): list {
                @@:(this.log)
                return;
            }

            get_state(): str {
                @@:("Parent")
                return;
            }
        }
    domain:
        log : List<String> = []
}

void main() {
    print("== Test 46: HSM Enter in Parent Only ==");
    final s = @@HSMEnterParentOnly();

    // TC2.2.1: Child enters without error (no enter handler)
    s.go_to_child();
    if (s.get_state() != "Child") throw Exception("Expected Child, got ${s.get_state()}");
    var log = s.get_log();
    print("TC2.2.1: Child enters without error (log: ${jsonEncode(log)}) - PASS");

    // TC2.2.2: Parent's enter does NOT auto-fire when child is entered
    if (log.contains("Parent:enter")) throw Exception("Parent:enter should NOT fire for child entry, got ${jsonEncode(log)}");
    print("TC2.2.2: Parent enter NOT auto-fired for child - PASS");

    // TC2.2.3: Parent enter only fires when transitioning directly TO parent
    s.go_to_parent();
    if (s.get_state() != "Parent") throw Exception("Expected Parent, got ${s.get_state()}");
    log = s.get_log();
    if (!log.contains("Parent:enter")) throw Exception("Expected Parent:enter when transitioning to Parent, got ${jsonEncode(log)}");
    print("TC2.2.3: Parent enter fires when transitioning to Parent - PASS");

    // TC2.2.4: Going back to child from parent
    s.go_to_child();
    if (s.get_state() != "Child") throw Exception("Expected Child, got ${s.get_state()}");
    log = s.get_log();
    // Parent enter should have fired only once (when we went to Parent)
    final count = log.where((x) => x == "Parent:enter").length;
    if (count != 1) throw Exception("Expected exactly 1 Parent:enter, got ${jsonEncode(log)}");
    print("TC2.2.4: Return to child, parent enter count unchanged - PASS");

    print("PASS: HSM enter in parent only works correctly");
}


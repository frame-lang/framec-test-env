@@target c

@@system StateParams {
    interface:
        start(val: int): void
        get_value(): int

    machine:
        $Idle {
            start(val: int) {
                -> $Counter(val)
            }

            get_value(): int {
                @@:(0)
                return;
            }
        }

        $Counter(initial: int) {
            get_value(): int {
                int v = (int)(intptr_t)self->__compartment->state_args[0];
                @@:(v)
                return;
            }
        }
}

int main() {
    printf("=== Test 26: State Parameters ===\n");
    StateParams* s = @@StateParams();

    int val = StateParams_get_value(s);
    printf("Initial value: %d\n", val);
    if (val != 0) {
        printf("FAIL: Expected 0 in Idle, got %d\n", val);
        return 1;
    }

    StateParams_start(s, 42);
    val = StateParams_get_value(s);
    printf("Value after transition: %d\n", val);
    if (val != 42) {
        printf("FAIL: Expected 42 in Counter from state param, got %d\n", val);
        return 1;
    }

    printf("PASS: State parameters work correctly\n");
    StateParams_destroy(s);
    return 0;
}

@@target java

@@persist
@@system L5 {
    interface:
        bump()
        value(): int
    machine:
        $S { bump() { this.n = this.n + 1; } value(): int { @@:(this.n) } }
    domain: n: int = 0
}

@@system L4 {
    interface:
        bump()
        value(): int
    machine:
        $S {
            bump() { this.n = this.n + 1; this.child.bump(); }
            value(): int { @@:(this.n + this.child.value()) }
        }
    domain:
        n: int = 0
        child: L5 = @@L5()
}

@@system L3 {
    interface:
        bump()
        value(): int
    machine:
        $S {
            bump() { this.n = this.n + 1; this.child.bump(); }
            value(): int { @@:(this.n + this.child.value()) }
        }
    domain:
        n: int = 0
        child: L4 = @@L4()
}

@@system L2 {
    interface:
        bump()
        value(): int
    machine:
        $S {
            bump() { this.n = this.n + 1; this.child.bump(); }
            value(): int { @@:(this.n + this.child.value()) }
        }
    domain:
        n: int = 0
        child: L3 = @@L3()
}

@@system L1 {
    interface:
        bump()
        value(): int
    machine:
        $S {
            bump() { this.n = this.n + 1; this.child.bump(); }
            value(): int { @@:(this.n + this.child.value()) }
        }
    domain:
        n: int = 0
        child: L2 = @@L2()
}

class Main {
    public static void main(String[] args) {
        L1 a = new L1();
        a.bump(); a.bump(); a.bump();
        int pre = a.value();
        if (pre != 15) { System.out.println("FAIL pre: " + pre); System.exit(1); }
        String snap = a.save_state();
        L1 b = L1.restore_state(snap);
        int post = b.value();
        if (post != 15) { System.out.println("FAIL post: " + post); System.exit(1); }
        b.bump();
        int after = b.value();
        if (after != 20) { System.out.println("FAIL after: " + after); System.exit(1); }
        System.out.println("PASS: 83_persist_5deep");
    }
}

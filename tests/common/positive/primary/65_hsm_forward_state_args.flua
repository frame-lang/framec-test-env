@@[target("lua")]

@@system StateArgFwd {
    interface:
        configure(t: int)
        process(): int

    machine:
        $Idle {
            configure(t: int) {
                -> $Active(t)
            }
            process(): int {
                @@:(0)
                return
            }
        }

        $Active => $Frame(threshold: int) {
            configure(t: int) {
                -> $Active(t)
            }
            process(): int {
                => $^
            }
        }

        $Frame {
            process(): int {
                @@:(threshold)
                return
            }
        }
    domain:
        n: int = 0
}

print("=== Test 65: HSM × state-args × parent-forward (Lua) ===")
local s = StateArgFwd.new()

local pre = s:process()
if pre ~= 0 then error("Expected 0, got " .. tostring(pre)) end
print("1. Idle process = " .. tostring(pre))

s:configure(7)
local r = s:process()
if r ~= 7 then error("Expected 7, got " .. tostring(r)) end
print("2. configure(7); process() = " .. tostring(r))

s:configure(42)
local r2 = s:process()
if r2 ~= 42 then error("Expected 42, got " .. tostring(r2)) end
print("3. configure(42); process() = " .. tostring(r2))

print("PASS: 65_hsm_forward_state_args")

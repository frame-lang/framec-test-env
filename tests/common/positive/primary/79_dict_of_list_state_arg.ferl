@@[target("erlang")]
@@[persist]
@@system DictOfList {
    interface:
        configure(m: map)
        getAt(key: string, idx: int): int
    machine:
        $Idle {
            configure(m: map) { -> $Active(m) }
            getAt(key: string, idx: int): int { @@:(-1) }
        }
        $Active(m: map) {
            configure(m: map) { -> $Active(m) }
            getAt(key: string, idx: int): int {
                @@:(case maps:find(Key, M) of {ok, L} when Idx < length(L) -> lists:nth(Idx + 1, L); _ -> -1 end)
            }
        }
    domain:
        n = 0
}

@@[target("javascript")]

@@system Sub {
    interface:
        ping(): int
    machine:
        $Idle {
            ping(): int { @@:(42) }
        }
}

@@[main]
@@system Top {
    interface:
        run(): int
    machine:
        $Active {
            run(): int { @@:(this.sub.ping()) }
        }
    domain:
        sub: Sub = @@Sub()
}

const t = @@Top();
if (t.run() !== 42) {
    console.log(`FAIL run(): ${t.run()}`);
} else {
    console.log("PASS: 91_main_attr_cross_ref");
}

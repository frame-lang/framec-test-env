@@target dart

import 'dart:convert';
import 'dart:io';

@@persist
@@system Inner {
    interface:
        cycle()
        get_state(): String
        get_count(): int

    machine:
        $A {
            cycle() { this.n = this.n + 1; -> $B }
            get_state(): String { @@:("A") }
            get_count(): int { @@:(this.n) }
        }
        $B => $A {
            cycle() { -> $A }
            get_state(): String { @@:("B") }
            get_count(): int { => $^ }
        }
    domain:
        n: int = 0
}

@@system Outer {
    interface:
        tick()
        cycle_inner()
        get_outer_state(): String
        get_inner_state(): String
        get_inner_count(): int
        get_k(): int

    machine:
        $Idle {
            tick() { this.k = this.k + 1; -> $Active }
            cycle_inner() { this.inner.cycle(); }
            get_outer_state(): String { @@:("Idle") }
            get_inner_state(): String { @@:(this.inner.get_state()) }
            get_inner_count(): int { @@:(this.inner.get_count()) }
            get_k(): int { @@:(this.k) }
        }
        $Active => $Idle {
            tick() { -> $Idle }
            get_outer_state(): String { @@:("Active") }
            cycle_inner() { => $^ }
            get_inner_state(): String { => $^ }
            get_inner_count(): int { => $^ }
            get_k(): int { => $^ }
        }
    domain:
        k: int = 0
        inner: Inner = @@Inner()
}

String fmtProbe(Outer o) => "${o.get_outer_state()}/${o.get_inner_state()}/${o.get_inner_count()}/${o.get_k()}";

void must(String label, Outer o, String expected) {
    var actual = fmtProbe(o);
    if (actual != expected) { print("FAIL $label: $actual expected $expected"); exit(1); }
}

void main() {
    var o1 = Outer();
    var o2 = Outer();

    o1.cycle_inner();
    o1.cycle_inner();
    o1.cycle_inner();
    must("o1 pre", o1, "Idle/B/2/0");

    o2.tick();
    o2.tick();
    o2.tick();
    must("o2 pre", o2, "Active/A/0/2");

    var snap1 = o1.saveState();
    var snap2 = o2.saveState();

    var r2 = Outer.restoreState(snap2);
    var r1 = Outer.restoreState(snap1);

    must("r1 restored", r1, "Idle/B/2/0");
    must("r2 restored", r2, "Active/A/0/2");

    r1.cycle_inner();
    must("r1 after mut", r1, "Idle/A/2/0");
    must("r2 after r1 mut", r2, "Active/A/0/2");

    r2.cycle_inner();
    must("r1 after r2 mut", r1, "Idle/A/2/0");
    must("r2 after r2 mut", r2, "Active/B/1/2");

    print("PASS: 87_persist_multi_instance");
}

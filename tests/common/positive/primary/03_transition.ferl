@@target erlang

@@system WithTransition {
    interface:
        next()
        getState(): str

    machine:
        $First {
            next() {
                -> $Second
            }

            getState(): str {
                return "First"
            }
        }

        $Second {
            next() {
                -> $First
            }

            getState(): str {
                return "Second"
            }
        }
}

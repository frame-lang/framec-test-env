@@target erlang

@@system WithTransition {
    interface:
        next()
        getState(): str

    machine:
        $First {
            next() {
                -> $Second
            }

            getState(): str {
                @@:("First")
                return
            }
        }

        $Second {
            next() {
                -> $First
            }

            getState(): str {
                @@:("Second")
                return
            }
        }
}

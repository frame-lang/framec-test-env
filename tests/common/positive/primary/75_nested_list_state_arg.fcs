@@[target("csharp")]


@@[persist(string)]
@@[save(SaveState)]
@@[load(RestoreState)]
@@system NestedList {
    interface:
        configure(rows: List<List<int>>)
        first_first(): int
        outer_size(): int

    machine:
        $Idle {
            configure(rows: List<List<int>>) { -> $Active(rows) }
            first_first(): int { @@:(-1) }
            outer_size(): int { @@:(0) }
        }
        $Active(rows: List<List<int>>) {
            configure(rows: List<List<int>>) { -> $Active(rows) }
            first_first(): int { @@:(rows[0][0]) }
            outer_size(): int { @@:(rows.Count) }
        }
    domain:
        n : int = 0
}

class Program {
    static void Main(string[] args) {
        var s1 = @@NestedList();
        s1.configure(new List<List<int>> { new List<int> { 10, 20 }, new List<int> { 30, 40 } });
        if (s1.first_first() != 10) { Console.WriteLine("FAIL pre"); Environment.Exit(1); }
        if (s1.outer_size() != 2) { Console.WriteLine("FAIL size"); Environment.Exit(1); }
        string snap = s1.SaveState();
        var s2 = @@NestedList();

        s2.RestoreState(snap);
        if (s2.first_first() != 10) { Console.WriteLine("FAIL post"); Environment.Exit(1); }
        if (s2.outer_size() != 2) { Console.WriteLine("FAIL post size"); Environment.Exit(1); }
        Console.WriteLine("PASS: 75_nested_list_state_arg");
    }
}

@@[target("dart")]
import 'dart:convert';
// Test 51: HSM Persistence
//
// Tests that HSM parent compartment chain is properly saved and restored:
// - Child state vars preserved
// - Parent state vars preserved
// - Parent compartment chain intact after restore
// - Forwarding to parent still works after restore

@@[persist]
@@system HSMPersist {
    operations:
        @@[save]
        saveState(): String {}

        @@[load]
        restoreState(data: String) {}

    interface:
        increment_child()
        increment_parent()
        get_child_count(): num
        get_parent_count(): num
        get_state(): String

    machine:
        $Child => $Parent {
            $.child_count: num = 0

            increment_child() {
                $.child_count = $.child_count + 1
            }

            increment_parent() {
                // Forward to parent
                => $^
            }

            get_child_count(): num {
                @@:($.child_count)
                return;
            }

            get_parent_count(): num {
                // Forward to parent
                => $^
            }

            get_state(): String {
                @@:("Child")
                return;
            }
        }

        $Parent {
            $.parent_count: num = 100

            increment_parent() {
                $.parent_count = $.parent_count + 1
            }

            get_parent_count(): num {
                @@:($.parent_count)
                return;
            }

            get_state(): String {
                @@:("Parent")
                return;
            }
        }
}

void main() {
    print("== Test 51: HSM Persistence ==");

    // Create system and modify state vars at both levels
    final s1 = @@HSMPersist();

    // Verify initial state
    if (s1.get_state() != "Child") throw Exception("Expected Child, got ${s1.get_state()}");
    if (s1.get_child_count() != 0) throw Exception("Expected 0, got ${s1.get_child_count()}");
    if (s1.get_parent_count() != 100) throw Exception("Expected 100, got ${s1.get_parent_count()}");
    print("1. Initial state verified: Child with child_count=0, parent_count=100");

    // Modify state vars at both levels
    s1.increment_child();
    s1.increment_child();
    s1.increment_child();  // child_count = 3
    s1.increment_parent();
    s1.increment_parent();  // parent_count = 102

    if (s1.get_child_count() != 3) throw Exception("Expected 3, got ${s1.get_child_count()}");
    if (s1.get_parent_count() != 102) throw Exception("Expected 102, got ${s1.get_parent_count()}");
    print("2. After increments: child_count=${s1.get_child_count()}, parent_count=${s1.get_parent_count()}");

    // Save state
    final data = s1.saveState();
    if (data is! String) throw Exception("Expected string, got ${data.runtimeType}");
    print("3. Saved state: ${data.length} chars");

    // Restore to new instance
    final s2 = HSMPersist();

    s2.restoreState(data);

    // Verify restored state
    if (s2.get_state() != "Child") throw Exception("Expected Child after restore, got ${s2.get_state()}");
    print("4. Restored state: ${s2.get_state()}");

    // Verify child state var preserved
    if (s2.get_child_count() != 3) throw Exception("Expected child_count=3, got ${s2.get_child_count()}");
    print("5. Child state var preserved: child_count=${s2.get_child_count()}");

    // Verify parent state var preserved (requires parent compartment chain)
    if (s2.get_parent_count() != 102) throw Exception("Expected parent_count=102, got ${s2.get_parent_count()}");
    print("6. Parent state var preserved: parent_count=${s2.get_parent_count()}");

    // Verify state machine still works after restore
    s2.increment_child();
    s2.increment_parent();
    if (s2.get_child_count() != 4) throw Exception("Expected 4, got ${s2.get_child_count()}");
    if (s2.get_parent_count() != 103) throw Exception("Expected 103, got ${s2.get_parent_count()}");
    print("7. After post-restore increments: child_count=${s2.get_child_count()}, parent_count=${s2.get_parent_count()}");

    print("PASS: HSM persistence works correctly");
}


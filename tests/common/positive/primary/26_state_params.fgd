@@target gdscript

@@system StateParams {
    interface:
        start(val: int)
        get_value(): int

    machine:
        $Idle {
            start(val: int) {
                -> $Counter(val)
            }

            get_value(): int {
                @@:(0)
                return
            }
        }

        $Counter(initial: int) {
            $>() {
                # Access state param via compartment - using string key "0"
                # Note: double underscore for __compartment to match generated class field
                $.count = self.__compartment.state_args["0"]
                count_val = $.count
                print("Counter entered with initial=" + str(count_val))
            }

            $.count: int = 0

            get_value(): int {
                @@:($.count)
                return
            }
        }
}

func main():
    print("=== Test 26: State Parameters ===")
    s = @@StateParams()

    val = s.get_value()
    assert(val == 0, "Expected 0 in Idle, got " + str(val))
    print("Initial value: " + str(val))

    s.start(42)
    val = s.get_value()
    assert(val == 42, "Expected 42 in Counter from state param, got " + str(val))
    print("Value after transition: " + str(val))

    print("PASS: State parameters work correctly")

func _ready():
    main()

@@[target("lua")]

@@system Sub {
    interface:
        ping(): number
    machine:
        $Idle {
            ping(): number { @@:(42) }
        }
}

@@[main]
@@system Top {
    interface:
        run(): number
    machine:
        $Active {
            run(): number { @@:(self.sub:ping()) }
        }
    domain:
        sub: Sub = @@Sub()
}

local t = @@Top()
if t:run() ~= 42 then
    print("FAIL run(): " .. t:run())
else
    print("PASS: 91_main_attr_cross_ref")
end

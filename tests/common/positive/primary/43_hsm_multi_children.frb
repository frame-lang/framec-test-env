@@target ruby

@@system HSMMultiChildren {
    interface:
        start_a()
        start_b()
        start_c()
        do_action()
        forward_action()
        get_log(): list
        get_state(): str

    machine:
        $ChildA => $Parent {
            start_a() { }
            start_b() { -> $ChildB }
            start_c() { -> $ChildC }
            do_action() { self.log.push("ChildA:do_action") }
            forward_action() {
                self.log.push("ChildA:forward_action")
                => $^
            }
            get_log(): list { return self.log }
            get_state(): str { return "ChildA" }
        }

        $ChildB => $Parent {
            start_a() { -> $ChildA }
            start_b() { }
            start_c() { -> $ChildC }
            do_action() { self.log.push("ChildB:do_action") }
            forward_action() {
                self.log.push("ChildB:forward_action")
                => $^
            }
            get_log(): list { return self.log }
            get_state(): str { return "ChildB" }
        }

        $ChildC => $Parent {
            start_a() { -> $ChildA }
            start_b() { -> $ChildB }
            start_c() { }
            do_action() { self.log.push("ChildC:do_action") }
            forward_action() {
                self.log.push("ChildC:forward_action")
                => $^
            }
            get_log(): list { return self.log }
            get_state(): str { return "ChildC" }
        }

        $Parent {
            forward_action() { self.log.push("Parent:forward_action") }
            get_log(): list { return self.log }
            get_state(): str { return "Parent" }
        }
    domain:
        log: list = []
}

puts("=== Test 43: HSM Multiple Children ===")
s = HSMMultiChildren.new

puts("TC1.3.1: Multiple children with same parent compiles - PASS")
raise "Expected ChildA, got #{s.get_state()}" unless s.get_state() == "ChildA"

s.forward_action()
log = s.get_log()
raise "Expected ChildA forward, got #{log}" unless log.include?("ChildA:forward_action")
raise "Expected Parent handler, got #{log}" unless log.include?("Parent:forward_action")
puts("TC1.3.2: ChildA forwards to parent - PASS")

s.start_b()
raise "Expected ChildB after transition, got #{s.get_state()}" unless s.get_state() == "ChildB"
puts("TC1.3.3: Transition A->B works - PASS")

s.forward_action()
log = s.get_log()
raise "Expected ChildB forward, got #{log}" unless log.include?("ChildB:forward_action")
raise "Expected 2 Parent forwards, got #{log}" unless log.count("Parent:forward_action") == 2
puts("TC1.3.4: ChildB forwards to same parent - PASS")

s.start_c()
raise "Expected ChildC, got #{s.get_state()}" unless s.get_state() == "ChildC"
s.forward_action()
log = s.get_log()
raise "Expected ChildC forward, got #{log}" unless log.include?("ChildC:forward_action")
raise "Expected 3 Parent forwards, got #{log}" unless log.count("Parent:forward_action") == 3
puts("TC1.3.5: ChildC forwards to same parent - PASS")

s.start_a(); s.do_action(); s.start_b(); s.do_action(); s.start_c(); s.do_action()
log = s.get_log()
raise "Expected ChildA action" unless log.include?("ChildA:do_action")
raise "Expected ChildB action" unless log.include?("ChildB:do_action")
raise "Expected ChildC action" unless log.include?("ChildC:do_action")
puts("TC1.3.6: Each sibling has independent handlers - PASS")

puts("PASS: HSM multiple children work correctly")

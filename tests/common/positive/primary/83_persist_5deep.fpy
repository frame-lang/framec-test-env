@@[target("python_3")]

@@[persist]
@@system L5 {
    operations:
        @@[save]
        save_state(): bytes {}

        @@[load]
        restore_state(data: bytes) {}

    interface:
        bump()
        value(): int
    machine:
        $S { bump() { self.n = self.n + 1 } value(): int { @@:(self.n); return } }
    domain: n: int = 0
}

@@system L4 {
    operations:
        @@[save]
        save_state(): bytes {}

        @@[load]
        restore_state(data: bytes) {}

    interface:
        bump()
        value(): int
    machine:
        $S {
            bump() { self.n = self.n + 1; self.child.bump() }
            value(): int { @@:(self.n + self.child.value()); return }
        }
    domain:
        n: int = 0
        child = @@L5()
}

@@system L3 {
    operations:
        @@[save]
        save_state(): bytes {}

        @@[load]
        restore_state(data: bytes) {}

    interface:
        bump()
        value(): int
    machine:
        $S {
            bump() { self.n = self.n + 1; self.child.bump() }
            value(): int { @@:(self.n + self.child.value()); return }
        }
    domain:
        n: int = 0
        child = @@L4()
}

@@system L2 {
    operations:
        @@[save]
        save_state(): bytes {}

        @@[load]
        restore_state(data: bytes) {}

    interface:
        bump()
        value(): int
    machine:
        $S {
            bump() { self.n = self.n + 1; self.child.bump() }
            value(): int { @@:(self.n + self.child.value()); return }
        }
    domain:
        n: int = 0
        child = @@L3()
}

@@[main]
@@system L1 {
    operations:
        @@[save]
        save_state(): bytes {}

        @@[load]
        restore_state(data: bytes) {}

    interface:
        bump()
        value(): int
    machine:
        $S {
            bump() { self.n = self.n + 1; self.child.bump() }
            value(): int { @@:(self.n + self.child.value()); return }
        }
    domain:
        n: int = 0
        child = @@L2()
}

if __name__ == '__main__':
    a = L1()
    a.bump()
    a.bump()
    a.bump()
    pre = a.value()
    assert pre == 15, f"pre: {pre}"
    snap = a.save_state()
    b = L1()

    b.restore_state(snap)
    post = b.value()
    assert post == 15, f"post: {post}"
    b.bump()
    after = b.value()
    assert after == 20, f"after: {after}"
    print("PASS: 83_persist_5deep")

@@target dart

@@system StateParams {
    interface:
        start(val: int)
        get_value(): int

    machine:
        $Idle {
            start(val: int) {
                -> $Counter(val)
            }

            get_value(): int {
                @@:(0)
                return;
            }
        }

        $Counter(initial: int) {
            $>() {
                // Access state param via compartment - using string key "0"
                $.count = this.__compartment.state_args["0"]
                final count_val = $.count
                print("Counter entered with initial=${count_val}")
            }

            $.count: int = 0

            get_value(): int {
                @@:($.count)
                return;
            }
        }
}

void main(): void {
    print("== Test 26: State Parameters ==")
    final s = @@StateParams()

    var val = s.get_value()
    if (val != 0) {
        throw Exception("Expected 0 in Idle, got ${val}")
    }
    print("Initial value: ${val}")

    s.start(42)
    val = s.get_value()
    if (val != 42) {
        throw Exception("Expected 42 in Counter from state param, got ${val}")
    }
    print("Value after transition: ${val}")

    print("PASS: State parameters work correctly")
}

main()

@@target ruby

# Test 40: HSM Parent State Variables

@@system HSMParentStateVars {
    interface:
        get_child_count(): int
        get_parent_count(): int

    machine:
        $Child => $Parent {
            $.child_count: int = 0

            get_child_count(): int {
                return $.child_count
            }

            get_parent_count(): int {
                # Forward to parent - parent should use ITS compartment
                => $^
            }
        }

        $Parent {
            $.parent_count: int = 100

            get_parent_count(): int {
                # This should return 100 from parent's compartment
                return $.parent_count
            }
        }
}

puts("=== Test 40: HSM Parent State Variables ===")
s = HSMParentStateVars.new

# Child's state var should be 0 (from child's compartment)
child_count = s.get_child_count()
raise "Expected child_count=0, got #{child_count}" unless child_count == 0
puts("Child count: #{child_count}")

# Parent's state var should be 100 (from parent's compartment)
parent_count = s.get_parent_count()
raise "Expected parent_count=100, got #{parent_count}" unless parent_count == 100
puts("Parent count: #{parent_count}")

puts("PASS: HSM parent state variables work correctly")

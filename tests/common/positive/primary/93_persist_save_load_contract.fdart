@@[target("dart")]
import 'dart:convert';
@@[persist(String)]
@@[save(saveOp)]
@@[load(loadOp)]
@@system Counter {
    interface:
        bump()
        getN(): int

    machine:
        $Active {
            bump() {
                this.n = this.n + 1;
            }
            getN(): int { @@:(this.n) }
        }

    domain:
        n: int = 0
}

void main() {
    var c1 = Counter();
    c1.bump();
    c1.bump();
    c1.bump();
    var data = c1.saveOp();

    var c2 = Counter();
    c2.loadOp(data);
    if (c2.getN() != 3) {
        print("FAIL: expected 3, got ${c2.getN()}");
        return;
    }
    print("PASS: 93_persist_save_load_contract");
}

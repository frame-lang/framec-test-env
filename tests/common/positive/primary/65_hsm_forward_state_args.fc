@@[target("c")]

#include <stdio.h>
#include <stdlib.h>
#include <string.h>

@@system StateArgFwd {
    interface:
        configure(t: int)
        process(): int

    machine:
        $Idle {
            configure(t: int) {
                -> $Active(t)
            }
            process(): int {
                @@:(0)
            }
        }

        $Active => $Frame(threshold: int) {
            configure(t: int) {
                -> $Active(t)
            }
            process(): int {
                => $^
            }
        }

        $Frame {
            process(): int {
                @@:(threshold)
            }
        }
    domain:
        n : int = 0
}

int main(void) {
    printf("=== Test 65: HSM × state-args × parent-forward (C) ===\n");
    StateArgFwd* s = @@StateArgFwd();

    int pre = StateArgFwd_process(s);
    if (pre != 0) { printf("FAIL: pre %d\n", pre); return 1; }
    printf("1. Idle process = %d\n", pre);

    StateArgFwd_configure(s, 7);
    int r = StateArgFwd_process(s);
    if (r != 7) { printf("FAIL: r %d\n", r); return 1; }
    printf("2. configure(7); process() = %d\n", r);

    StateArgFwd_configure(s, 42);
    int r2 = StateArgFwd_process(s);
    if (r2 != 42) { printf("FAIL: r2 %d\n", r2); return 1; }
    printf("3. configure(42); process() = %d\n", r2);

    printf("PASS: 65_hsm_forward_state_args\n");
    StateArgFwd_destroy(s);
    return 0;
}

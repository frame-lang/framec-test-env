@@[target("ruby")]

@@system Counter {
    interface:
        get_value(): int
        bump()

    machine:
        $Active {
            get_value(): int { @@:(self._read()) }
            bump() { @n = @n + 1 }
        }

    actions:
        # `@@:(<expr>)` inside actions: bodies must lower to a native
        # `return <expr>` — actions are plain functions, not Frame
        # handlers, so there's no context-stack `_return` slot.
        _read(): int {
            if @n > 0
                @@:(@n)
            else
                @@:(0)
            end
        }

    domain:
        n: int = 0
}

inst = @@Counter()
if inst.get_value() != 0
    puts "FAIL initial: expected 0, got #{inst.get_value()}"
    exit 1
end

inst.bump
inst.bump
inst.bump
if inst.get_value() != 3
    puts "FAIL post-bump: expected 3, got #{inst.get_value()}"
    exit 1
end

puts "PASS: 94_at_colon_paren_in_action"

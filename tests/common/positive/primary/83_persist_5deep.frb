@@[target("ruby")]

@@[persist(String)]
@@[save(save_state)]
@@[load(restore_state)]
@@system L5 {
    interface:
        bump()
        value(): int
    machine:
        $S { bump() { self.n = self.n + 1 } value(): int { @@:(self.n) } }
    domain: n: int = 0
}@@[persist(String)]
@@[save(save_state)]
@@[load(restore_state)]


@@system L4 {
    interface:
        bump()
        value(): int
    machine:
        $S {
            bump() { self.n = self.n + 1; self.child.bump }
            value(): int { @@:(self.n + self.child.value) }
        }
    domain:
        n: int = 0
        child = @@L5()
}@@[persist(String)]
@@[save(save_state)]
@@[load(restore_state)]


@@system L3 {
    interface:
        bump()
        value(): int
    machine:
        $S {
            bump() { self.n = self.n + 1; self.child.bump }
            value(): int { @@:(self.n + self.child.value) }
        }
    domain:
        n: int = 0
        child = @@L4()
}@@[persist(String)]
@@[save(save_state)]
@@[load(restore_state)]


@@system L2 {
    interface:
        bump()
        value(): int
    machine:
        $S {
            bump() { self.n = self.n + 1; self.child.bump }
            value(): int { @@:(self.n + self.child.value) }
        }
    domain:
        n: int = 0
        child = @@L3()
}@@[persist(String)]
@@[save(save_state)]
@@[load(restore_state)]


@@[main]
@@system L1 {
    interface:
        bump()
        value(): int
    machine:
        $S {
            bump() { self.n = self.n + 1; self.child.bump }
            value(): int { @@:(self.n + self.child.value) }
        }
    domain:
        n: int = 0
        child = @@L2()
}

a = L1.new
a.bump; a.bump; a.bump
pre = a.value
abort("FAIL pre: #{pre}") unless pre == 15
snap = a.save_state
b = L1.new
b.restore_state(snap)
post = b.value
abort("FAIL post: #{post}") unless post == 15
b.bump
after = b.value
abort("FAIL after: #{after}") unless after == 20
puts "PASS: 83_persist_5deep"

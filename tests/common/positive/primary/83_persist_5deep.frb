@@[target("ruby")]

@@[persist]
@@system L5 {
    operations:
        @@[save]
        save_state(): String {}

        @@[load]
        restore_state(data: String) {}

    interface:
        bump()
        value(): int
    machine:
        $S { bump() { self.n = self.n + 1 } value(): int { @@:(self.n) } }
    domain: n: int = 0
}

@@system L4 {
    operations:
        @@[save]
        save_state(): String {}

        @@[load]
        restore_state(data: String) {}

    interface:
        bump()
        value(): int
    machine:
        $S {
            bump() { self.n = self.n + 1; self.child.bump }
            value(): int { @@:(self.n + self.child.value) }
        }
    domain:
        n: int = 0
        child = @@L5()
}

@@system L3 {
    operations:
        @@[save]
        save_state(): String {}

        @@[load]
        restore_state(data: String) {}

    interface:
        bump()
        value(): int
    machine:
        $S {
            bump() { self.n = self.n + 1; self.child.bump }
            value(): int { @@:(self.n + self.child.value) }
        }
    domain:
        n: int = 0
        child = @@L4()
}

@@system L2 {
    operations:
        @@[save]
        save_state(): String {}

        @@[load]
        restore_state(data: String) {}

    interface:
        bump()
        value(): int
    machine:
        $S {
            bump() { self.n = self.n + 1; self.child.bump }
            value(): int { @@:(self.n + self.child.value) }
        }
    domain:
        n: int = 0
        child = @@L3()
}

@@[main]
@@system L1 {
    operations:
        @@[save]
        save_state(): String {}

        @@[load]
        restore_state(data: String) {}

    interface:
        bump()
        value(): int
    machine:
        $S {
            bump() { self.n = self.n + 1; self.child.bump }
            value(): int { @@:(self.n + self.child.value) }
        }
    domain:
        n: int = 0
        child = @@L2()
}

a = L1.new
a.bump; a.bump; a.bump
pre = a.value
abort("FAIL pre: #{pre}") unless pre == 15
snap = a.save_state
b = L1.new
b.restore_state(snap)
post = b.value
abort("FAIL post: #{post}") unless post == 15
b.bump
after = b.value
abort("FAIL after: #{after}") unless after == 20
puts "PASS: 83_persist_5deep"

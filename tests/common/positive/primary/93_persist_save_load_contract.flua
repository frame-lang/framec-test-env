@@[target("lua")]

@@[persist]
@@system Counter {
    operations:
        @@[save]
        save_op(): string {}

        @@[load]
        load_op(data: string) {}

    interface:
        bump()
        get_n(): number

    machine:
        $Active {
            bump() {
                self.n = self.n + 1
            }
            get_n(): number { @@:(self.n) }
        }

    domain:
        n: number = 0
}

local c1 = Counter:new()
c1:bump()
c1:bump()
c1:bump()
local data = c1:save_op()

local c2 = Counter:new()
c2:load_op(data)
if c2:get_n() ~= 3 then
    print("FAIL: expected 3, got " .. c2:get_n())
else
    print("PASS: 93_persist_save_load_contract")
end

@@target gdscript

@@system HSMForward {
    interface:
        event_a()
        event_b()
        get_log(): list

    machine:
        $Child => $Parent {
            event_a() {
                self.log.append("Child:event_a")
            }

            event_b() {
                self.log.append("Child:event_b_forward")
                => $^
            }

            get_log(): list {
                @@:(self.log)
                return
            }
        }

        $Parent {
            event_a() {
                self.log.append("Parent:event_a")
            }

            event_b() {
                self.log.append("Parent:event_b")
            }

            get_log(): list {
                @@:(self.log)
                return
            }
        }
    domain:
        log: list = []
}

func main():
    print("=== Test 08: HSM Forward ===")
    s = @@HSMForward()

    # event_a should be handled by Child (no forward)
    s.event_a()
    log = s.get_log()
    assert("Child:event_a" in log, "Expected 'Child:event_a' in log, got " + str(log))
    print("After event_a: " + str(log))

    # event_b should forward to Parent
    s.event_b()
    log = s.get_log()
    assert("Child:event_b_forward" in log, "Expected 'Child:event_b_forward' in log, got " + str(log))
    assert("Parent:event_b" in log, "Expected 'Parent:event_b' in log (forwarded), got " + str(log))
    print("After event_b (forwarded): " + str(log))

    print("PASS: HSM forward works correctly")

func _ready():
    main()

@@target ruby

@@[persist]
@@system PPushDeep {
    interface:
        descend()
        ascend()
        get_depth(): int

    machine:
        $Idle {
            descend() { push$; -> $Modal1 }
            get_depth(): int { @@:(0); return }
        }
        $Modal1 {
            descend() { push$; -> $Modal2 }
            ascend() { -> pop$ }
            get_depth(): int { @@:(1); return }
        }
        $Modal2 {
            descend() { push$; -> $Modal3 }
            ascend() { -> pop$ }
            get_depth(): int { @@:(2); return }
        }
        $Modal3 {
            ascend() { -> pop$ }
            get_depth(): int { @@:(3); return }
        }
    domain: n: int = 0
}

s = PPushDeep.new
s.descend; s.descend; s.descend
raise "FAIL pre #{s.get_depth}" unless s.get_depth == 3
snap = s.save_state
s2 = PPushDeep.restore_state(snap)
raise "FAIL post #{s2.get_depth}" unless s2.get_depth == 3
s2.ascend; raise "FAIL a1" unless s2.get_depth == 2
s2.ascend; raise "FAIL a2" unless s2.get_depth == 1
s2.ascend; raise "FAIL a3" unless s2.get_depth == 0
puts "PASS: 71_persist_push_depth_three"

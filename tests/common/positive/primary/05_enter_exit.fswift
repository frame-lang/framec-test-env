@@target swift

@@system EnterExit {
    interface:
        toggle()
        get_log(): string[]

    machine:
        $Off {
            $>() {
                self.log.append("enter:Off")
                print("Entered Off state")
            }

            <$() {
                self.log.append("exit:Off")
                print("Exiting Off state")
            }

            toggle() {
                -> $On
            }

            get_log(): string[] {
                @@:(self.log)
                return;
            }
        }

        $On {
            $>() {
                self.log.append("enter:On")
                print("Entered On state")
            }

            <$() {
                self.log.append("exit:On")
                print("Exiting On state")
            }

            toggle() {
                -> $Off
            }

            get_log(): string[] {
                @@:(self.log)
                return;
            }
        }
    domain:
        log: string[] = []
}

// main
    print("=== Test 05: Enter/Exit Handlers ===")
    let s = @@EnterExit()

    // Initial enter should have been called
    var log = s.get_log()
    if !log.contains("enter:Off") {
        fatalError("Expected 'enter:Off' in log, got \(String(describing: log))")
    }
    print("After construction: \(String(describing: log))")

    // Toggle to On - should exit Off, enter On
    s.toggle()
    log = s.get_log()
    if !log.contains("exit:Off") {
        fatalError("Expected 'exit:Off' in log, got \(String(describing: log))")
    }
    if !log.contains("enter:On") {
        fatalError("Expected 'enter:On' in log, got \(String(describing: log))")
    }
    print("After toggle to On: \(String(describing: log))")

    // Toggle back to Off - should exit On, enter Off
    s.toggle()
    log = s.get_log()
    let enterOffCount = log.filter { $0 == "enter:Off" }.count
    if enterOffCount != 2 {
        fatalError("Expected 2 'enter:Off' entries, got \(String(describing: log))")
    }
    if !log.contains("exit:On") {
        fatalError("Expected 'exit:On' in log, got \(String(describing: log))")
    }
    print("After toggle to Off: \(String(describing: log))")

    print("PASS: Enter/Exit handlers work correctly")

@@target lua
@@system HSMExitHandlers {
    interface:
        go_to_other()
        go_to_parent()
        go_to_child()
        get_log(): list
        get_state(): str
        get_child_var(): int

    machine:
        $Child => $Parent {
            $.child_var: int = 42

            $>() {
                self.log[#self.log + 1] = "Child:enter"
            }

            <$() {
                val = $.child_var
                self.log[#self.log + 1] = "Child:exit(var=" .. tostring(val) .. ")"
            }

            go_to_other() {
                -> $Other
            }

            go_to_parent() {
                -> $Parent
            }

            get_log(): list {
                return self.log
            }

            get_state(): str {
                return "Child"
            }

            get_child_var(): int {
                return $.child_var
            }
        }

        $Parent {
            $>() {
                self.log[#self.log + 1] = "Parent:enter"
            }

            <$() {
                self.log[#self.log + 1] = "Parent:exit"
            }

            go_to_child() {
                -> $Child
            }

            go_to_other() {
                -> $Other
            }

            get_log(): list {
                return self.log
            }

            get_state(): str {
                return "Parent"
            }

            get_child_var(): int {
                return -1
            }
        }

        $Other {
            $>() {
                self.log[#self.log + 1] = "Other:enter"
            }

            go_to_child() {
                -> $Child
            }

            go_to_parent() {
                -> $Parent
            }

            get_log(): list {
                return self.log
            }

            get_state(): str {
                return "Other"
            }

            get_child_var(): int {
                return -1
            }
        }
    domain:
        log: list = []
}

@@[target("ruby")]

# Documentation Example: Basic Lamp with enter/exit events

@@system Lamp {
    interface:
        turnOn()
        turnOff()
        getColor(): str
        setColor(color: str)

    machine:
        $Off {
            turnOn() {
                -> $On
            }
            getColor(): str {
                @@:(self.color)
                return
            }
            setColor(color: str) {
                self.color = color
            }
        }

        $On {
            $>() {
                self.closeSwitch()
            }
            <$() {
                self.openSwitch()
            }
            turnOff() {
                -> $Off
            }
            getColor(): str {
                @@:(self.color)
                return
            }
            setColor(color: str) {
                self.color = color
            }
        }

    actions:
        closeSwitch() {
            self.switch_closed = true
        }
        openSwitch() {
            self.switch_closed = false
        }

    domain:
        color: str = "white"
        switch_closed: bool = false
}

puts("=== Test 31: Doc Lamp Basic ===")
lamp = Lamp.new

# Initially off
raise "Switch should be open initially" unless lamp.switch_closed == false

# Turn on - should close switch
lamp.turnOn()
raise "Switch should be closed after turnOn" unless lamp.switch_closed == true

# Check color
raise "Expected 'white', got '#{lamp.getColor()}'" unless lamp.getColor() == "white"

# Set color
lamp.setColor("blue")
raise "Expected 'blue', got '#{lamp.getColor()}'" unless lamp.getColor() == "blue"

# Turn off - should open switch
lamp.turnOff()
raise "Switch should be open after turnOff" unless lamp.switch_closed == false

puts("PASS: Basic lamp works correctly")

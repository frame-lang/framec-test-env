@@target c

// Documentation Example: History with push$/pop$ (History201)

@@system HistoryBasic {
    interface:
        gotoC_from_A(): void
        gotoC_from_B(): void
        gotoB(): void
        return_back(): void
        get_state(): int

    machine:
        $A {
            gotoC_from_A() {
                push$
                -> $C
            }
            gotoB() {
                -> $B
            }
            get_state(): int {
                return 1
            }
        }

        $B {
            gotoC_from_B() {
                push$
                -> $C
            }
            get_state(): int {
                return 2
            }
        }

        $C {
            return_back() {
                -> pop$
            }
            get_state(): int {
                return 3
            }
        }
}

int main() {
    printf("=== Test 33: Doc History Basic ===\n");
    HistoryBasic* h = @@HistoryBasic();

    // Start in A
    int state = HistoryBasic_get_state(h);
    if (state != 1) {
        printf("FAIL: Expected 1 (A), got %d\n", state);
        return 1;
    }

    // Go to C from A (push A)
    HistoryBasic_gotoC_from_A(h);
    state = HistoryBasic_get_state(h);
    if (state != 3) {
        printf("FAIL: Expected 3 (C), got %d\n", state);
        return 1;
    }

    // Return back (pop to A)
    HistoryBasic_return_back(h);
    state = HistoryBasic_get_state(h);
    if (state != 1) {
        printf("FAIL: Expected 1 (A) after pop, got %d\n", state);
        return 1;
    }

    // Now go to B
    HistoryBasic_gotoB(h);
    state = HistoryBasic_get_state(h);
    if (state != 2) {
        printf("FAIL: Expected 2 (B), got %d\n", state);
        return 1;
    }

    // Go to C from B (push B)
    HistoryBasic_gotoC_from_B(h);
    state = HistoryBasic_get_state(h);
    if (state != 3) {
        printf("FAIL: Expected 3 (C), got %d\n", state);
        return 1;
    }

    // Return back (pop to B)
    HistoryBasic_return_back(h);
    state = HistoryBasic_get_state(h);
    if (state != 2) {
        printf("FAIL: Expected 2 (B) after pop, got %d\n", state);
        return 1;
    }

    printf("PASS: History push/pop works correctly\n");
    HistoryBasic_destroy(h);
    return 0;
}

@@[target("rust")]
@@[create(make)]
@@system Counter(seed: i32) {
    interface:
        bump()
        get_value(): i32

    machine:
        $A {
            bump() { self.count = self.count + 1; }
            get_value(): i32 { @@:(self.count) }
        }

    domain:
        seed: i32 = seed
        count: i32 = 0
}

fn main() {
    let mut c1 = Counter::new(42);
    c1.bump();
    c1.bump();
    if c1.get_value() != 2 {
        println!("FAIL: via Counter::new expected 2, got {}", c1.get_value());
        return;
    }

    let mut c2 = Counter::make(99);
    c2.bump();
    if c2.get_value() != 1 {
        println!("FAIL: via Counter::make expected 1, got {}", c2.get_value());
        return;
    }

    println!("PASS: rfc0015_create_rename");
}

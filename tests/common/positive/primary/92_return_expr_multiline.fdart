@@[target("dart")]

@@system Test {
    interface:
        ready(): bool

    machine:
        $Active {
            ready(): bool {
                @@:(this.timer >= this.threshold
                    && this.count < this.limit)
            }
        }
    domain:
        timer: int = 100
        threshold: int = 50
        count: int = 1
        limit: int = 5
}

void main() {
    var t = @@Test();
    if (t.ready() != true) {
        print("FAIL ready(): ${t.ready()}");
    } else {
        print("PASS: 92_return_expr_multiline");
    }
}

@@target lua
@@system ContextBasicTest {
    interface:
        add(a: int, b: int): int
        get_event_name(): str
        greet(name: str): str

    machine:
        $Ready {
            add(a: int, b: int): int {
                @@:return = @@:params["a"] + @@:params["b"]
                -- Access params via @@ shorthand
            }

            get_event_name(): str {
                @@:return = @@:event
                -- Access event name
            }

            greet(name: str): str {
                @@:return = result
                -- Mix param access and return
                result = "Hello, " + @@:params["name"] + "!"
            }
        }
}

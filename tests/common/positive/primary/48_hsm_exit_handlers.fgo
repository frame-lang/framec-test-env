@@target go

package main

import "fmt"
import "os"

// Test 48: HSM Exit Cascade

@@system HSMExitHandlers {
    interface:
        GoToOther()
        GoToParent()
        GoToChild()
        GetLog(): []string
        GetState(): string
        GetChildVar(): int

    machine:
        $Child => $Parent {
            $.child_var: int = 42

            $>() {
                s.log = append(s.log, "Child:enter")
            }

            <$() {
                val := $.child_var
                s.log = append(s.log, fmt.Sprintf("Child:exit(var=%d)", val))
            }

            GoToOther() { -> $Other }
            GoToParent() { -> $Parent }
            GetLog(): []string { @@:(s.log) }
            GetState(): string { @@:("Child") }
            GetChildVar(): int { @@:($.child_var) }
        }

        $Parent {
            $>() {
                s.log = append(s.log, "Parent:enter")
            }

            <$() {
                s.log = append(s.log, "Parent:exit")
            }

            GoToChild() { -> $Child }
            GoToOther() { -> $Other }
            GetLog(): []string { @@:(s.log) }
            GetState(): string { @@:("Parent") }
            GetChildVar(): int { @@:(-1) }
        }

        $Other {
            $>() {
                s.log = append(s.log, "Other:enter")
            }
            GoToChild() { -> $Child }
            GoToParent() { -> $Parent }
            GetLog(): []string { @@:(s.log) }
            GetState(): string { @@:("Other") }
            GetChildVar(): int { @@:(-1) }
        }
    domain:
        log : []string
}

func contains(slice []string, item string) bool {
	for _, v := range slice {
		if v == item {
			return true
		}
	}
	return false
}

func indexOf(slice []string, item string) int {
	for i, v := range slice {
		if v == item {
			return i
		}
	}
	return -1
}

func countOccurrences(slice []string, item string) int {
	count := 0
	for _, v := range slice {
		if v == item {
			count++
		}
	}
	return count
}

func main() {
	fmt.Println("=== Test 48: HSM Exit Cascade ===")
	sm := @@HSMExitHandlers()

	log := sm.GetLog()
	if !contains(log, "Parent:enter") { fmt.Println("FAIL: Expected Parent:enter on init cascade"); os.Exit(1) }
	if !contains(log, "Child:enter") { fmt.Println("FAIL: Expected Child:enter on init"); os.Exit(1) }
	if sm.GetState() != "Child" { fmt.Println("FAIL"); os.Exit(1) }
	fmt.Println("TC1: Initial entry cascades through Parent then Child - PASS")

	sm.GoToOther()
	log = sm.GetLog()
	if !contains(log, "Child:exit(var=42)") { fmt.Println("FAIL: Expected Child:exit(var=42)"); os.Exit(1) }
	if !contains(log, "Parent:exit") { fmt.Println("FAIL: Expected Parent:exit (cascade)"); os.Exit(1) }
	if !contains(log, "Other:enter") { fmt.Println("FAIL: Expected Other:enter"); os.Exit(1) }
	cei := indexOf(log, "Child:exit(var=42)")
	pei := indexOf(log, "Parent:exit")
	if cei >= pei { fmt.Println("FAIL: Child:exit must precede Parent:exit"); os.Exit(1) }
	fmt.Println("TC2: Child:exit fires before Parent:exit (bottom-up cascade) - PASS")

	fmt.Println("TC3: Exit handler accesses state var (var=42) - PASS")

	sm.GoToChild()
	log = sm.GetLog()
	if countOccurrences(log, "Parent:enter") != 2 { fmt.Println("FAIL: Expected 2 Parent:enter"); os.Exit(1) }
	if countOccurrences(log, "Child:enter") != 2 { fmt.Println("FAIL: Expected 2 Child:enter"); os.Exit(1) }
	fmt.Println("TC4: Re-entering Child cascades Parent.$> then Child.$> - PASS")

	fmt.Println("PASS: HSM exit cascade fires Child.<$ then Parent.<$")
}

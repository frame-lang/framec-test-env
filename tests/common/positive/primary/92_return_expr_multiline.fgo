@@[target("go")]

package main

import "fmt"

@@system Test {
    interface:
        Ready(): bool

    machine:
        $Active {
            Ready(): bool {
                @@:(s.timer >= s.threshold &&
                    s.count < s.limit)
            }
        }
    domain:
        timer: int = 100
        threshold: int = 50
        count: int = 1
        limit: int = 5
}

func main() {
    t := @@Test()
    if t.Ready() != true {
        fmt.Printf("FAIL Ready(): %v\n", t.Ready())
        return
    }
    fmt.Println("PASS: 92_return_expr_multiline")
}

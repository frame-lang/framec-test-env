@@[target("swift")]

@@system TransitionEnterArgs {
    interface:
        start()
        get_log(): string[]

    machine:
        $Idle {
            start() {
                self.log.append("idle:start")
                -> ("from_idle", 42) $Active
            }

            get_log(): string[] {
                @@:(self.log)
                return;
            }
        }

        $Active {
            $>(source: string, value: number) {
                self.log.append("active:enter:\(source):\(value)")
            }

            start() {
                self.log.append("active:start")
            }

            get_log(): string[] {
                @@:(self.log)
                return;
            }
        }
    domain:
        log: string[] = []
}

// main
    print("=== Test 17: Transition Enter Args ===")
    let s = @@TransitionEnterArgs()

    // Initial state is Idle
    var log = s.get_log()
    if log.count != 0 {
        fatalError("Expected empty log, got \(String(describing: log))")
    }

    // Transition to Active with args
    s.start()
    log = s.get_log()
    if !log.contains("idle:start") {
        fatalError("Expected 'idle:start' in log, got \(String(describing: log))")
    }
    if !log.contains("active:enter:from_idle:42") {
        fatalError("Expected 'active:enter:from_idle:42' in log, got \(String(describing: log))")
    }
    print("Log after transition: \(String(describing: log))")

    print("PASS: Transition enter args work correctly")

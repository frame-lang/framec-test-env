@@target gdscript
extends SceneTree

@@system DomainVars {
    interface:
        increment()
        decrement()
        get_count(): int
        set_count(value: int)

    machine:
        $Counting {
            increment() {
                self.count += 1
                print(str(self.name) + ": incremented to " + str(self.count))
            }

            decrement() {
                self.count -= 1
                print(str(self.name) + ": decremented to " + str(self.count))
            }

            get_count(): int {
                @@:(self.count)
                return
            }

            set_count(value: int) {
                self.count = value
                print(str(self.name) + ": set to " + str(self.count))
            }
        }
    domain:
        count: int = 0
        name: str = "counter"
}

func main():
    print("=== Test 06: Domain Variables ===")
    var s = @@DomainVars()

    # Initial value should be 0
    var count = s.get_count()
    assert(count == 0, "Expected initial count=0, got " + str(count))
    print("Initial count: " + str(count))

    # Increment
    s.increment()
    count = s.get_count()
    assert(count == 1, "Expected count=1, got " + str(count))

    s.increment()
    count = s.get_count()
    assert(count == 2, "Expected count=2, got " + str(count))

    # Decrement
    s.decrement()
    count = s.get_count()
    assert(count == 1, "Expected count=1, got " + str(count))

    # Set directly
    s.set_count(100)
    count = s.get_count()
    assert(count == 100, "Expected count=100, got " + str(count))

    print("Final count: " + str(count))
    print("PASS: Domain variables work correctly")

func _init():
    main()
    quit()

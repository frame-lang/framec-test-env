@@target javascript

@@system StateParams {
    interface:
        start(val: number)
        get_value(): number

    machine:
        $Idle {
            start(val: number) {
                -> $Counter(val)
            }

            get_value(): number {
                @@:(0)
                return;
            }
        }

        $Counter(initial: number) {
            $>() {
                // Access state param via compartment - positional index
                $.count = this.__compartment.state_args[0]
                const count_val = $.count
                console.log(`Counter entered with initial=${count_val}`)
            }

            $.count: number = 0

            get_value(): number {
                @@:($.count)
                return;
            }
        }
}

function main() {
    console.log("=== Test 26: State Parameters ===")
    const s = @@StateParams()

    let val = s.get_value()
    if (val !== 0) {
        throw new Error(`Expected 0 in Idle, got ${val}`)
    }
    console.log(`Initial value: ${val}`)

    s.start(42)
    val = s.get_value()
    if (val !== 42) {
        throw new Error(`Expected 42 in Counter from state param, got ${val}`)
    }
    console.log(`Value after transition: ${val}`)

    console.log("PASS: State parameters work correctly")
}

main()

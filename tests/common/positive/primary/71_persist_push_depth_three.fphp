<?php
@@[target("php")]

@@[persist(string)]
@@[save(save_state)]
@@[load(restore_state)]
@@system PPushDeep {
    interface:
        descend()
        ascend()
        get_depth(): int

    machine:
        $Idle {
            descend() { push$; -> $Modal1 }
            get_depth(): int { @@:(0); return; }
        }
        $Modal1 {
            descend() { push$; -> $Modal2 }
            ascend() { -> pop$ }
            get_depth(): int { @@:(1); return; }
        }
        $Modal2 {
            descend() { push$; -> $Modal3 }
            ascend() { -> pop$ }
            get_depth(): int { @@:(2); return; }
        }
        $Modal3 {
            ascend() { -> pop$ }
            get_depth(): int { @@:(3); return; }
        }
    domain: n: int = 0
}

$s = @@PPushDeep();
$s->descend(); $s->descend(); $s->descend();
if ($s->get_depth() !== 3) { echo "FAIL pre\n"; exit(1); }
$snap = $s->save_state();
$s2 = @@PPushDeep();

$s2->restore_state($snap);
if ($s2->get_depth() !== 3) { echo "FAIL post\n"; exit(1); }
$s2->ascend(); if ($s2->get_depth() !== 2) { echo "FAIL a1\n"; exit(1); }
$s2->ascend(); if ($s2->get_depth() !== 1) { echo "FAIL a2\n"; exit(1); }
$s2->ascend(); if ($s2->get_depth() !== 0) { echo "FAIL a3\n"; exit(1); }
echo "PASS: 71_persist_push_depth_three\n";

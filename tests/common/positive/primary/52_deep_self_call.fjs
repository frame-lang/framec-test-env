@@[target("javascript")]

// Test: deep @@:self.iface() stack — transition guard propagation
//
// Validates:
// 1. Full chain completes when no transition fires
// 2. Transition at depth 3 suppresses all "after" traces
// 3. Transition at depth 2 prevents deeper calls
// 4. Sequential self-calls: second suppressed after first transitions
// 5. Sequential self-calls: both complete when no transition

@@system DeepSelfCall {
    interface:
        start_chain(mode: string): string
        level_one(mode: string): string
        level_two(mode: string): string
        level_three(mode: string): string
        get_trace(): string
        get_state(): string
        reset()

    machine:
        $Active {
            start_chain(mode: string): string {
                this.trace = "";
                this.trace = this.trace + "start:before;";
                @@:self.level_one(mode)
                this.trace = this.trace + "start:after;";
                @@:(this.trace)
            }

            level_one(mode: string): string {
                this.trace = this.trace + "L1:before;";
                @@:self.level_two(mode)
                this.trace = this.trace + "L1:after;";
                @@:(this.trace)
            }

            level_two(mode: string): string {
                this.trace = this.trace + "L2:before;";
                if (mode === "transition_at_two") {
                    this.trace = this.trace + "L2:transitioning;";
                    -> $Done
                }
                @@:self.level_three(mode)
                this.trace = this.trace + "L2:after;";
                @@:(this.trace)
            }

            level_three(mode: string): string {
                this.trace = this.trace + "L3:before;";
                if (mode === "transition_at_three") {
                    this.trace = this.trace + "L3:transitioning;";
                    -> $Done
                }
                this.trace = this.trace + "L3:after;";
                @@:(this.trace)
            }

            get_trace(): string {
                @@:(this.trace)
            }

            get_state(): string { @@:(@@:system.state) }

            reset() {
                this.trace = "";
            }
        }

        $Done {
            get_trace(): string {
                @@:(this.trace)
            }

            get_state(): string { @@:(@@:system.state) }

            reset() {
                this.trace = "";
                -> $Active
            }
        }

    domain:
        trace: string = ""
}

@@[main]
@@system SequentialSelfCall {
    interface:
        run_sequence(mode: string): string
        first_call(mode: string): string
        second_call(): string
        get_trace(): string
        get_state(): string

    machine:
        $Active {
            run_sequence(mode: string): string {
                this.trace = "";
                this.trace = this.trace + "seq:before_first;";
                @@:self.first_call(mode)
                this.trace = this.trace + "seq:between;";
                @@:self.second_call()
                this.trace = this.trace + "seq:after_second;";
                @@:(this.trace)
            }

            first_call(mode: string): string {
                if (mode === "transition_first") {
                    this.trace = this.trace + "first:transitioning;";
                    -> $Done
                }
                this.trace = this.trace + "first:complete;";
                @@:(this.trace)
            }

            second_call(): string {
                this.trace = this.trace + "second:complete;";
                @@:(this.trace)
            }

            get_trace(): string { @@:(this.trace) }
            get_state(): string { @@:(@@:system.state) }
        }

        $Done {
            get_trace(): string { @@:(this.trace) }
            get_state(): string { @@:(@@:system.state) }
        }

    domain:
        trace: string = ""
}

let failures = 0;

// === Scenario 1: No transition — full chain completes ===
let s = @@DeepSelfCall();
let result = s.start_chain("no_transition");
let expected = "start:before;L1:before;L2:before;L3:before;L3:after;L2:after;L1:after;start:after;";
if (result !== expected) {
    console.log(`FAIL scenario 1: expected '${expected}'`);
    console.log(`                 got      '${result}'`);
    failures++;
}
if (s.get_state() !== "Active") {
    console.log(`FAIL scenario 1: state should be Active, got '${s.get_state()}'`);
    failures++;
}

// === Scenario 2: Transition at level_three — all "after" traces suppressed ===
s.reset();
result = s.start_chain("transition_at_three");
let trace = s.get_trace();
let expected_trace = "start:before;L1:before;L2:before;L3:before;L3:transitioning;";
if (trace !== expected_trace) {
    console.log(`FAIL scenario 2 trace: expected '${expected_trace}'`);
    console.log(`                       got      '${trace}'`);
    failures++;
}
if (s.get_state() !== "Done") {
    console.log(`FAIL scenario 2: state should be Done, got '${s.get_state()}'`);
    failures++;
}

// === Scenario 3: Transition at level_two — level_three never called ===
s.reset();
result = s.start_chain("transition_at_two");
trace = s.get_trace();
expected_trace = "start:before;L1:before;L2:before;L2:transitioning;";
if (trace !== expected_trace) {
    console.log(`FAIL scenario 3 trace: expected '${expected_trace}'`);
    console.log(`                       got      '${trace}'`);
    failures++;
}
if (s.get_state() !== "Done") {
    console.log(`FAIL scenario 3: state should be Done, got '${s.get_state()}'`);
    failures++;
}

// === Scenario 4: Sequential self-calls — second suppressed after first transitions ===
let s2 = @@SequentialSelfCall();
result = s2.run_sequence("transition_first");
trace = s2.get_trace();
expected_trace = "seq:before_first;first:transitioning;";
if (trace !== expected_trace) {
    console.log(`FAIL scenario 4 trace: expected '${expected_trace}'`);
    console.log(`                       got      '${trace}'`);
    failures++;
}
if (s2.get_state() !== "Done") {
    console.log(`FAIL scenario 4: state should be Done, got '${s2.get_state()}'`);
    failures++;
}

// === Scenario 5: Sequential self-calls — no transition, both complete ===
let s3 = @@SequentialSelfCall();
result = s3.run_sequence("no_transition");
trace = s3.get_trace();
expected_trace = "seq:before_first;first:complete;seq:between;second:complete;seq:after_second;";
if (trace !== expected_trace) {
    console.log(`FAIL scenario 5 trace: expected '${expected_trace}'`);
    console.log(`                       got      '${trace}'`);
    failures++;
}

if (failures > 0) {
    console.log(`FAIL: deep_self_call (${failures} failures)`);
    process.exit(1);
}
console.log("PASS: deep_self_call");

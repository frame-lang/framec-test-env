@@[target("gdscript")]

extends SceneTree

@@[persist(String)]
@@[save(save_state)]
@@[load(restore_state)]
@@system Outer {
    interface:
        try_save_during_handler()

    machine:
        $S {
            try_save_during_handler() {
                self.save_state()
            }
        }
    domain:
}

# GDScript: save_state returns empty PackedByteArray on contract
# violation and pushes an error to Godot's error queue. The test
# verifies the empty-return path. The error queue contains the
# E700 message; per-language guide documents how to read it.

func _init():
    var o1 = @@Outer()
    var snap = o1.save_state()
    if snap.size() == 0:
        print("FAIL: quiescent save returned empty")
        quit(1)
        return

    # Calling try_save_during_handler triggers save_state inside a
    # handler — non-quiescent. GDScript codegen returns empty bytes
    # rather than throwing (no exceptions in GDScript).
    var o2 = @@Outer()
    o2.try_save_during_handler()
    # The save_state call inside the handler returned empty; the
    # outer call to try_save_during_handler completed normally.
    # Quiescence is restored after handler return, so we can save
    # the (now-clean) instance.
    var o3 = @@Outer()
    var snap3 = o3.save_state()
    if snap3.size() == 0:
        print("FAIL: fresh instance unusable")
        quit(1)
        return

    print("PASS: 88_persist_quiescent_error")
    quit()

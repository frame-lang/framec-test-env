@@[target("lua")]
@@system WithInterface {
    interface:
        greet(name: str): str
        get_count(): int

    machine:
        $Ready {
            greet(name: str): str {
                self.call_count = self.call_count + 1
                @@:("Hello, " .. tostring(name) .. "!")
                return
            }

            get_count(): int {
                @@:(self.call_count)
                return
            }
        }

    domain:
        call_count: int = 0
}

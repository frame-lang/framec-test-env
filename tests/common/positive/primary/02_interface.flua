@@target lua
@@system WithInterface {
    interface:
        greet(name: str): str
        get_count(): int

    machine:
        $Ready {
            greet(name: str): str {
                self.call_count = self.call_count + 1
                return "Hello, " .. tostring(name) .. "!"
            }

            get_count(): int {
                return self.call_count
            }
        }

    domain:
        call_count: int = 0
}

@@target cpp_17

#include <iostream>
#include <cassert>

@@system StateVarReentry {
    interface:
        increment(): int
        get_count(): int
        go_other(): void
        come_back(): void

    machine:
        $Counter {
            $.count: int = 0

            increment(): int {
                $.count = $.count + 1;
                return $.count;
            }

            get_count(): int {
                return $.count;
            }

            go_other() {
                -> $Other
            }
        }

        $Other {
            come_back() {
                -> $Counter
            }

            increment(): int {
                return -1;
            }

            get_count(): int {
                return -1;
            }
        }
}

int main() {
    std::cout << "=== Test 11: State Variable Reentry ===" << std::endl;
    StateVarReentry s;

    // Increment a few times
    s.increment();
    s.increment();
    int count = s.get_count();
    assert(count == 2);
    std::cout << "Count before leaving: " << count << std::endl;

    // Leave the state
    s.go_other();
    std::cout << "Transitioned to Other state" << std::endl;

    // Come back - state var should be reinitialized to 0
    s.come_back();
    count = s.get_count();
    assert(count == 0);
    std::cout << "Count after re-entering Counter: " << count << std::endl;

    // Increment again to verify it works
    int result = s.increment();
    assert(result == 1);
    std::cout << "After increment: " << result << std::endl;

    std::cout << "PASS: State variables reinitialize on state reentry" << std::endl;
    return 0;
}

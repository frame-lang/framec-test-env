@@[target("python_3")]

# Test 75: nested list state-arg (list of list) round-trip + persist.

@@[persist(bytes)]
@@[save(save_state)]
@@[load(restore_state)]
@@system NestedList {
    interface:
        configure(rows: list)
        first_first(): int
        outer_size(): int

    machine:
        $Idle {
            configure(rows: list) { -> $Active(rows) }
            first_first(): int { @@:(-1); return }
            outer_size(): int { @@:(0); return }
        }
        $Active(rows: list) {
            configure(rows: list) { -> $Active(rows) }
            first_first(): int { @@:(rows[0][0]); return }
            outer_size(): int { @@:(len(rows)); return }
        }
    domain:
        n: int = 0
}

def main():
    s1 = NestedList()
    s1.configure([[10, 20], [30, 40]])
    assert s1.first_first() == 10
    assert s1.outer_size() == 2
    snap = s1.save_state()
    s2 = NestedList()

    s2.restore_state(snap)
    assert s2.first_first() == 10
    assert s2.outer_size() == 2
    print("PASS: 75_nested_list_state_arg")

if __name__ == '__main__':
    main()

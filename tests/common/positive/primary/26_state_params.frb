@@[target("ruby")]

@@system StateParams {
    interface:
        start(val: int)
        get_value(): int

    machine:
        $Idle {
            start(val: int) {
                -> $Counter(val)
            }

            get_value(): int {
                @@:(0)
                return
            }
        }

        $Counter(initial: int) {
            $>() {
                # Access state param via compartment - positional index
                $.count = self.__compartment.state_args[0]
                count_val = $.count
                puts("Counter entered with initial=#{count_val}")
            }

            $.count: int = 0

            get_value(): int {
                @@:($.count)
                return
            }
        }
}

puts("=== Test 26: State Parameters ===")
s = StateParams.new

val = s.get_value()
raise "Expected 0 in Idle, got #{val}" unless val == 0
puts("Initial value: #{val}")

s.start(42)
val = s.get_value()
raise "Expected 42 in Counter from state param, got #{val}" unless val == 42
puts("Value after transition: #{val}")

puts("PASS: State parameters work correctly")

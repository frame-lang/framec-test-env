<?php
@@[target("php")]

@@system HistoryBasic {
    interface:
        gotoC_from_A()
        gotoC_from_B()
        gotoB()
        return_back()
        get_state(): str

    machine:
        $A {
            gotoC_from_A() {
                push$
                -> $C
            }
            gotoB() {
                -> $B
            }
            get_state(): str {
                @@:("A")
                return;
            }
        }

        $B {
            gotoC_from_B() {
                push$
                -> $C
            }
            get_state(): str {
                @@:("B")
                return;
            }
        }

        $C {
            return_back() {
                -> pop$
            }
            get_state(): str {
                @@:("C")
                return;
            }
        }
}

echo "=== Test 33: Doc History Basic ===" . "\n";
$h = @@HistoryBasic();

if ($h->get_state() !== "A") { echo "FAIL: Expected 'A'\n"; exit(1); }

$h->gotoC_from_A();
if ($h->get_state() !== "C") { echo "FAIL: Expected 'C'\n"; exit(1); }

$h->return_back();
if ($h->get_state() !== "A") { echo "FAIL: Expected 'A' after pop\n"; exit(1); }

$h->gotoB();
if ($h->get_state() !== "B") { echo "FAIL: Expected 'B'\n"; exit(1); }

$h->gotoC_from_B();
if ($h->get_state() !== "C") { echo "FAIL: Expected 'C'\n"; exit(1); }

$h->return_back();
if ($h->get_state() !== "B") { echo "FAIL: Expected 'B' after pop\n"; exit(1); }

echo "PASS: History push/pop works correctly" . "\n";

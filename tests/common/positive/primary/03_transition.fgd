@@[target("gdscript")]
extends SceneTree

@@system WithTransition {
    interface:
        next()
        get_state(): String

    machine:
        $First {
            next() {
                print("Transitioning: First -> Second")
                -> $Second
            }

            get_state(): String {
                @@:("First")
                return
            }
        }

        $Second {
            next() {
                print("Transitioning: Second -> First")
                -> $First
            }

            get_state(): String {
                @@:("Second")
                return
            }
        }
}

func main():
    print("=== Test 03: State Transitions ===")
    var s = @@WithTransition()

    # Initial state should be First
    var state = s.get_state()
    assert(state == "First", "Expected 'First', got '" + str(state) + "'")
    print("Initial state: " + str(state))

    # Transition to Second
    s.next()
    state = s.get_state()
    assert(state == "Second", "Expected 'Second', got '" + str(state) + "'")
    print("After first next(): " + str(state))

    # Transition back to First
    s.next()
    state = s.get_state()
    assert(state == "First", "Expected 'First', got '" + str(state) + "'")
    print("After second next(): " + str(state))

    print("PASS: State transitions work correctly")

func _init():
    main()
    quit()

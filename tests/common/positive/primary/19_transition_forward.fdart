@@target dart
import 'dart:convert';
@@system EventForwardTest {
    interface:
        process()
        get_log(): List<String>

    machine:
        $Idle {
            process() {
                this.log.add("idle:process:before");
                -> => $Working
                // This should NOT execute because -> => returns after dispatch
                this.log.add("idle:process:after");
            }

            get_log(): List<String> {
                @@:(this.log)
                return;
            }
        }

        $Working {
            process() {
                this.log.add("working:process");
            }

            get_log(): List<String> {
                @@:(this.log)
                return;
            }
        }
    domain:
        List<String> log = []
}

void main() {
    print("== Test 19: Transition Forward (TypeScript) ==");
    final s = @@EventForwardTest();
    s.process();
    final log = s.get_log();
    print("Log: ${jsonEncode(log)}");

    // After transition-forward:
    // - Idle logs "idle:process:before"
    // - Transition to Working
    // - Working handles process(), logs "working:process"
    // - Return prevents "idle:process:after"
    if (!log.contains("idle:process:before")) {
        throw Exception("Expected 'idle:process:before' in log: ${log}");
    }
    if (!log.contains("working:process")) {
        throw Exception("Expected 'working:process' in log: ${log}");
    }
    if (log.contains("idle:process:after")) {
        throw Exception("Should NOT have 'idle:process:after' in log: ${log}");
    }

    print("PASS: Transition forward works correctly");
}


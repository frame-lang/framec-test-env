@@[target("php")]

@@system HsmFourLevel {
    interface:
        drive(): int
        write_at_level(level: int)
        get_n(): int

    machine:
        $Leaf => $Mid {
            drive(): int {
                => $^
            }
            write_at_level(level: int) {
                $this->n = $this->n + $level * 1;
                => $^
            }
            get_n(): int {
                @@:($this->n)
                return;
            }
        }

        $Mid => $Branch {
            drive(): int {
                => $^
            }
            write_at_level(level: int) {
                $this->n = $this->n + $level * 10;
                => $^
            }
        }

        $Branch => $Root {
            drive(): int {
                => $^
            }
            write_at_level(level: int) {
                $this->n = $this->n + $level * 100;
                => $^
            }
        }

        $Root {
            drive(): int {
                @@:($this->n)
                return;
            }
            write_at_level(level: int) {
                $this->n = $this->n + $level * 1000;
            }
        }
    domain:
        n: int = 0
}

echo "=== Test 61: 4-level HSM cascade (PHP) ===\n";
$s = @@HsmFourLevel();

$initial = $s->drive();
if ($initial !== 0) { echo "FAIL: initial $initial\n"; exit(1); }
echo "1. Initial drive returned $initial\n";

$s->write_at_level(2);
$after = $s->get_n();
if ($after !== 2222) { echo "FAIL: after $after\n"; exit(1); }
echo "2. After cascading write: n=$after\n";

$final = $s->drive();
if ($final !== 2222) { echo "FAIL: final $final\n"; exit(1); }
echo "3. Drive after write returned $final\n";

echo "PASS: 61_hsm_four_level\n";

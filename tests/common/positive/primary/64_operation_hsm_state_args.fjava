@@[target("java")]

@@system OpHsmStateArgs {
    operations:
        add_offset(x: int, off: int): int {
            return x + off;
        }

    interface:
        enter_active(t: int)
        classify(v: int): int

    machine:
        $Idle {
            enter_active(t: int) {
                -> $Active(t)
            }
            classify(v: int): int {
                @@:(-1)
            }
        }

        $Active => $Frame(threshold: int) {
            enter_active(t: int) {
                -> $Active(t)
            }
            classify(v: int): int {
                int r = this.add_offset(v, threshold);
                @@:(r)
            }
        }

        $Frame {
        }
    domain:
        n : int = 0
}

class Main {
    public static void main(String[] args) {
        System.out.println("=== Test 64: Operations × HSM × state-args (Java) ===");
        var s = new OpHsmStateArgs();

        int pre = s.classify(5);
        if (pre != -1) { System.out.println("FAIL: pre " + pre); System.exit(1); }
        System.out.println("1. Idle classify(5) = " + pre);

        s.enter_active(10);
        int r = s.classify(5);
        if (r != 15) { System.out.println("FAIL: r " + r); System.exit(1); }
        System.out.println("2. classify(5) with threshold=10 → " + r);

        int r2 = s.classify(7);
        if (r2 != 17) { System.out.println("FAIL: r2 " + r2); System.exit(1); }
        System.out.println("3. classify(7) with threshold=10 → " + r2);

        s.enter_active(100);
        int r3 = s.classify(5);
        if (r3 != 105) { System.out.println("FAIL: r3 " + r3); System.exit(1); }
        System.out.println("4. classify(5) with threshold=100 → " + r3);

        System.out.println("PASS: 64_operation_hsm_state_args");
    }
}

@@[target("csharp")]

@@system Test {
    interface:
        Ready(): bool

    machine:
        $Active {
            Ready(): bool {
                @@:(this.timer >= this.threshold
                    && this.count < this.limit)
            }
        }
    domain:
        timer: int = 100
        threshold: int = 50
        count: int = 1
        limit: int = 5
}

class Program {
    static void Main() {
        Test t = new Test();
        if (t.Ready() != true) {
            System.Console.WriteLine($"FAIL Ready(): {t.Ready()}");
        } else {
            System.Console.WriteLine("PASS: 92_return_expr_multiline");
        }
    }
}

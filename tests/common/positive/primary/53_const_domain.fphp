@@[target("php")]


// Test: const domain field initialized from system param.

@@system Sensor(threshold: int = 100) {
    interface:
        read(): int
        calibrate(offset: int)
        get_threshold(): int

    machine:
        $Active {
            read(): int {
                @@:($this->value + $this->offset)
                return;
            }
            calibrate(offset: int) {
                $this->offset = $offset;
            }
            get_threshold(): int {
                @@:($this->threshold)
                return;
            }
        }

    domain:
        const threshold = $threshold
        value = 50
        offset = 0
}

$failures = 0;

// Test 1: system param override
$s = @@Sensor(200);
$t = $s->get_threshold();
if ($t !== 200) { echo "FAIL test 1: expected 200, got $t\n"; $failures++; }

// Test 2: read returns value + offset
$v = $s->read();
if ($v !== 50) { echo "FAIL test 2: expected 50, got $v\n"; $failures++; }

// Test 3: calibrate changes offset
$s->calibrate(10);
$v = $s->read();
if ($v !== 60) { echo "FAIL test 3: expected 60, got $v\n"; $failures++; }

// Test 4: default system param
$s2 = @@Sensor();
$t2 = $s2->get_threshold();
if ($t2 !== 100) { echo "FAIL test 4: expected 100, got $t2\n"; $failures++; }

if ($failures > 0) {
    echo "FAIL: const_domain ($failures failures)\n";
    exit(1);
}
echo "PASS: const_domain\n";

@@[target("erlang")]
@@system HSMMultiChildren {
    interface:
        goChild1()
        goChild2()
        parentAction()
        getLog(): str
    machine:
        $Child1 => $Parent {
            $>() { self.log = self.log ++ ",child1_enter" }
            goChild2() { -> $Child2 }
            getLog(): str {
                @@:(self.log)
            }
        }
        $Child2 => $Parent {
            $>() { self.log = self.log ++ ",child2_enter" }
            goChild1() { -> $Child1 }
            getLog(): str {
                @@:(self.log)
            }
        }
        $Parent {
            parentAction() {
                self.log = self.log ++ ",parent_action"
            }
            getLog(): str {
                @@:(self.log)
            }
        }
    domain:
        log = "init"
}

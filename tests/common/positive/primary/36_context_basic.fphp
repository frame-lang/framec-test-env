@@[target("php")]

@@system ContextBasicTest {
    interface:
        add(a: int, b: int): int
        get_event_name(): str
        greet(name: str): str

    machine:
        $Ready {
            add(a: int, b: int): int {
                @@:(@@:params.a + @@:params.b)
            }

            get_event_name(): str {
                @@:(@@:event)
            }

            greet(name: str): str {
                $result = "Hello, " . @@:params.name . "!";
                @@:($result)
            }
        }
}

echo "=== Test 36: Context Basic ===" . "\n";
$s = @@ContextBasicTest();

$result = $s->add(3, 5);
if ($result !== 8) { echo "FAIL: Expected 8, got {$result}\n"; exit(1); }
echo "1. add(3, 5) = {$result}" . "\n";

$event_name = $s->get_event_name();
if ($event_name !== "get_event_name") { echo "FAIL: Expected 'get_event_name', got '{$event_name}'\n"; exit(1); }
echo "2. @@:event = '{$event_name}'" . "\n";

$greeting = $s->greet("World");
if ($greeting !== "Hello, World!") { echo "FAIL: Expected 'Hello, World!', got '{$greeting}'\n"; exit(1); }
echo "3. greet('World') = '{$greeting}'" . "\n";

echo "PASS: Context basic access works correctly" . "\n";

@@[target("swift")]

import Foundation

@@[persist]
@@system PersistPushpopStateArgs {
    interface:
        push_modal(v: int)
        pop_modal()
        get_slot(): int

    machine:
        $Idle {
            push_modal(v: int) {
                push$
                -> $Modal(v)
            }
            pop_modal() {
                -> pop$
            }
            get_slot(): int {
                @@:(-99)
            }
        }

        $Modal(slot: int) {
            push_modal(v: int) {
                push$
                -> $Modal(v)
            }
            pop_modal() {
                -> pop$
            }
            get_slot(): int {
                @@:(slot)
            }
        }
    domain:
        v : int = 0
}

print("=== Test 58: Persist × push/pop × state-args (Swift) ===")
let s1 = PersistPushpopStateArgs()
s1.push_modal(42)
s1.push_modal(77)
let pre = s1.get_slot()
if pre != 77 { print("FAIL: pre \(pre)"); exit(1) }
print("1. Pre-save top slot=\(pre)")

let snap = s1.saveState()
let s2 = PersistPushpopStateArgs.restoreState(snap)
let post = s2.get_slot()
if post != 77 { print("FAIL: post \(post)"); exit(1) }
print("2. Post-restore top slot=\(post)")

s2.pop_modal()
let mid = s2.get_slot()
if mid != 42 { print("FAIL: mid \(mid)"); exit(1) }
print("3. After first pop slot=\(mid)")

s2.pop_modal()
let bottom = s2.get_slot()
if bottom != -99 { print("FAIL: bottom \(bottom)"); exit(1) }
print("4. After second pop slot=\(bottom)")

print("PASS: 58_persist_pushpop_state_args")

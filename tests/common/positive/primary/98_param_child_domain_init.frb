@@[target("ruby")]

# RFC-0017 regression: see .fpy header.

@@system Counter(seed: int) {
    interface:
        bump()
        get_value(): int
    machine:
        $S {
            $> { @n = @seed }
            bump() { @n = @n + 1 }
            get_value(): int { @@:(@n) }
        }
    domain:
        seed = seed
        n = 0
}

@@[main]
@@system World {
    interface:
        bump_c()
        bump_d()
        get_c(): int
        get_d(): int
    machine:
        $S {
            bump_c() { @c.bump() }
            bump_d() { @d.bump() }
            get_c(): int { @@:(@c.get_value()) }
            get_d(): int { @@:(@d.get_value()) }
        }
    domain:
        c = @@Counter(7)
        d = @@Counter(11)
}

w = @@World()
abort "FAIL initial c: #{w.get_c}" if w.get_c != 7
abort "FAIL initial d: #{w.get_d}" if w.get_d != 11
w.bump_c
w.bump_d
abort "FAIL bump_c: #{w.get_c}" if w.get_c != 8
abort "FAIL bump_d: #{w.get_d}" if w.get_d != 12
puts "PASS: 98_param_child_domain_init"

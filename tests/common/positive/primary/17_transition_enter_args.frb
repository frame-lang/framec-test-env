@@target ruby

@@system TransitionEnterArgs {
    interface:
        start()
        get_log(): list

    machine:
        $Idle {
            start() {
                self.log.push("idle:start")
                -> ("from_idle", 42) $Active
            }

            get_log(): list {
                return self.log
            }
        }

        $Active {
            $>(source: str, value: int) {
                self.log.push("active:enter:#{source}:#{value}")
            }

            start() {
                self.log.push("active:start")
            }

            get_log(): list {
                return self.log
            }
        }
    domain:
        log: list = []
}

puts("=== Test 17: Transition Enter Args ===")
s = TransitionEnterArgs.new

# Initial state is Idle
log = s.get_log()
raise "Expected empty log, got #{log}" unless log == []

# Transition to Active with args
s.start()
log = s.get_log()
raise "Expected 'idle:start' in log, got #{log}" unless log.include?("idle:start")
raise "Expected 'active:enter:from_idle:42' in log, got #{log}" unless log.include?("active:enter:from_idle:42")
puts("Log after transition: #{log}")

puts("PASS: Transition enter args work correctly")

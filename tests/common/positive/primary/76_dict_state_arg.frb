@@[target("ruby")]

@@system DictStateArg {
    interface:
        configure(m: Hash)
        get_v(key: String): int
        size(): int

    machine:
        $Idle {
            configure(m: Hash) { -> $Active(m) }
            get_v(key: String): int { @@:(-1) }
            size(): int { @@:(0) }
        }
        $Active(m: Hash) {
            configure(m: Hash) { -> $Active(m) }
            get_v(key: String): int { @@:(m.fetch(key, -1)) }
            size(): int { @@:(m.size) }
        }
    domain:
        n: int = 0
}

s = DictStateArg.new
abort("FAIL idle") unless s.get_v("a") == -1
abort("FAIL idle size") unless s.size == 0
s.configure({"a" => 10, "b" => 20})
abort("FAIL a") unless s.get_v("a") == 10
abort("FAIL b") unless s.get_v("b") == 20
abort("FAIL size") unless s.size == 2
s.configure({"x" => 99})
abort("FAIL x") unless s.get_v("x") == 99
abort("FAIL size2") unless s.size == 1
puts "PASS: 76_dict_state_arg"

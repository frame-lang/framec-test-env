@@target cpp_17

#include <iostream>
#include <string>
#include <cassert>
#include <vector>
#include <algorithm>

// Documentation Example: HSM with History (History203)

@@system HistoryHSM {
    interface:
        gotoA()
        gotoB()
        gotoC()
        goBack()
        get_state(): std::string
        get_log(): std::vector<std::string>

    machine:
        $Waiting {
            $>() {
                this->log_msg("In $Waiting");
            }
            gotoA() {
                this->log_msg("gotoA");
                -> $A
            }
            gotoB() {
                this->log_msg("gotoB");
                -> $B
            }
            get_state(): std::string {
                @@:(std::string("Waiting"))
                return;
            }
            get_log(): std::vector<std::string> {
                @@:(event_log)
                return;
            }
        }

        $A => $AB {
            $>() {
                this->log_msg("In $A");
            }
            gotoB() {
                this->log_msg("gotoB");
                -> $B
            }
            get_state(): std::string {
                @@:(std::string("A"))
                return;
            }
            get_log(): std::vector<std::string> {
                @@:(event_log)
                return;
            }
            => $^
        }

        $B => $AB {
            $>() {
                this->log_msg("In $B");
            }
            gotoA() {
                this->log_msg("gotoA");
                -> $A
            }
            get_state(): std::string {
                @@:(std::string("B"))
                return;
            }
            get_log(): std::vector<std::string> {
                @@:(event_log)
                return;
            }
            => $^
        }

        $AB {
            gotoC() {
                this->log_msg("gotoC in $AB");
                push$
                -> $C
            }
        }

        $C {
            $>() {
                this->log_msg("In $C");
            }
            goBack() {
                this->log_msg("goBack");
                -> pop$
            }
            get_state(): std::string {
                @@:(std::string("C"))
                return;
            }
            get_log(): std::vector<std::string> {
                @@:(event_log)
                return;
            }
        }

    actions:
        log_msg(msg: std::string) {
            event_log.push_back(msg);
        }

    domain:
        event_log : std::vector<std::string> = {}
}

int main() {
    printf("=== Test 34: Doc History HSM ===\n");
    HistoryHSM h;

    if (h.get_state() != "Waiting") {
        printf("FAIL: Expected 'Waiting', got '%s'\n", h.get_state().c_str());
        assert(false);
    }

    h.gotoA();
    if (h.get_state() != "A") {
        printf("FAIL: Expected 'A', got '%s'\n", h.get_state().c_str());
        assert(false);
    }

    h.gotoC();
    if (h.get_state() != "C") {
        printf("FAIL: Expected 'C', got '%s'\n", h.get_state().c_str());
        assert(false);
    }

    h.goBack();
    if (h.get_state() != "A") {
        printf("FAIL: Expected 'A' after goBack, got '%s'\n", h.get_state().c_str());
        assert(false);
    }

    h.gotoB();
    if (h.get_state() != "B") {
        printf("FAIL: Expected 'B', got '%s'\n", h.get_state().c_str());
        assert(false);
    }

    h.gotoC();
    if (h.get_state() != "C") {
        printf("FAIL: Expected 'C', got '%s'\n", h.get_state().c_str());
        assert(false);
    }

    h.goBack();
    if (h.get_state() != "B") {
        printf("FAIL: Expected 'B' after goBack, got '%s'\n", h.get_state().c_str());
        assert(false);
    }

    printf("PASS: HSM with history works correctly\n");
    return 0;
}

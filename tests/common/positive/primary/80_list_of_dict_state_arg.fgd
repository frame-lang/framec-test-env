@@[target("gdscript")]
extends SceneTree

@@[persist]
@@system ListOfDict {
    interface:
        configure(rows: Array)
        get_at(idx: int, key: String): int

    machine:
        $Idle {
            configure(rows: Array) { -> $Active(rows) }
            get_at(idx: int, key: String): int { @@:(-1) }
        }
        $Active(rows: Array) {
            configure(rows: Array) { -> $Active(rows) }
            get_at(idx: int, key: String): int {
                if idx < rows.size():
                    var __m = rows[idx]
                    @@:(__m.get(key, -1))
                else:
                    @@:(-1)
            }
        }
    domain:
        n: int = 0
}

func _initialize():
    var s1 = ListOfDict.new()
    s1.configure([{"x": 1, "y": 2}, {"z": 3}])
    if s1.get_at(0, "x") != 1:
        print("FAIL pre 0.x"); quit(1); return
    if s1.get_at(1, "z") != 3:
        print("FAIL pre 1.z"); quit(1); return
    var snap = s1.save_state()
    var s2 = ListOfDict.restore_state(snap)
    if s2.get_at(0, "x") != 1:
        print("FAIL post 0.x"); quit(1); return
    if s2.get_at(0, "y") != 2:
        print("FAIL post 0.y"); quit(1); return
    if s2.get_at(1, "z") != 3:
        print("FAIL post 1.z"); quit(1); return
    print("PASS: 80_list_of_dict_state_arg")

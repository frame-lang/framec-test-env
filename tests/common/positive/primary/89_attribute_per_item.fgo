@@[target("go")]

package main

import (
    "fmt"
    "os"
)

@@system Demo {
    interface:
        common(): string
        @@[target("python_3")] only_py(): string
        @@[target("go")] only_go(): string

    machine:
        $S {
            common(): string { @@:("common") }
            @@[target("python_3")] only_py(): string { @@:("only_py_present") }
            @@[target("go")] only_go(): string { @@:("only_go_present") }
        }
}

func main() {
    d := NewDemo()
    if d.Common() != "common" { fmt.Printf("FAIL common: %s\n", d.Common()); os.Exit(1) }
    if d.Only_go() != "only_go_present" { fmt.Printf("FAIL only_go: %s\n", d.Only_go()); os.Exit(1) }
    fmt.Println("PASS: 89_attribute_per_item")
}

@@[target("python_3")]

# Wave 8 hardening: numeric typing in nested persist.
# Stringification of int fields surfaces type-coercion bugs (Lua
# cjson decoded ints as floats — caught in test 84). Float fields
# are compared arithmetically so float→string differences across
# backends ("3" vs "3.0") don't cause spurious failure. Bool and
# string complete the primitive-type coverage.

@@[persist]
@@system Inner {
    interface:
        bump_int()
        bump_float()
        flip_bool()
        get_n_int(): int
        get_n_float(): float
        get_n_bool(): bool
        get_n_str(): str

    machine:
        $S {
            bump_int() { self.n_int = self.n_int + 1 }
            bump_float() { self.n_float = self.n_float + 0.25 }
            flip_bool() { self.n_bool = not self.n_bool }
            get_n_int(): int { @@:(self.n_int); return }
            get_n_float(): float { @@:(self.n_float); return }
            get_n_bool(): bool { @@:(self.n_bool); return }
            get_n_str(): str { @@:(self.n_str); return }
        }
    domain:
        n_int: int = 7
        n_float: float = 2.5
        n_bool: bool = True
        n_str: str = "hello"
}

@@system Outer {
    interface:
        bump_k_int()
        bump_k_float()
        bump_inner_int()
        bump_inner_float()
        flip_inner_bool()
        get_k_int(): int
        get_k_float(): float
        get_n_int(): int
        get_n_float(): float
        get_n_bool(): bool
        get_n_str(): str

    machine:
        $S {
            bump_k_int() { self.k_int = self.k_int + 1 }
            bump_k_float() { self.k_float = self.k_float + 0.25 }
            bump_inner_int() { self.inner.bump_int() }
            bump_inner_float() { self.inner.bump_float() }
            flip_inner_bool() { self.inner.flip_bool() }
            get_k_int(): int { @@:(self.k_int); return }
            get_k_float(): float { @@:(self.k_float); return }
            get_n_int(): int { @@:(self.inner.get_n_int()); return }
            get_n_float(): float { @@:(self.inner.get_n_float()); return }
            get_n_bool(): bool { @@:(self.inner.get_n_bool()); return }
            get_n_str(): str { @@:(self.inner.get_n_str()); return }
        }
    domain:
        k_int: int = 42
        k_float: float = 1.25
        inner = @@Inner()
}

if __name__ == '__main__':
    def assert_state(o, label, k_int, k_float, n_int, n_float, n_bool, n_str):
        # Int fields stringified — catches Lua-class type-coercion
        # bugs where the typed int round-trips as a float and renders
        # with a decimal point.
        assert str(o.get_k_int()) == k_int, f"{label} k_int: {o.get_k_int()!r}"
        assert str(o.get_n_int()) == n_int, f"{label} n_int: {o.get_n_int()!r}"
        # Float fields compared arithmetically — portable across
        # backends with differing float→string conventions.
        assert abs(o.get_k_float() - k_float) < 1e-9, f"{label} k_float: {o.get_k_float()}"
        assert abs(o.get_n_float() - n_float) < 1e-9, f"{label} n_float: {o.get_n_float()}"
        assert o.get_n_bool() == n_bool, f"{label} n_bool: {o.get_n_bool()!r}"
        assert o.get_n_str() == n_str, f"{label} n_str: {o.get_n_str()!r}"

    o = Outer()
    assert_state(o, "T0", "42", 1.25, "7", 2.5, True, "hello")

    o.bump_k_int()
    o.bump_k_float()
    o.bump_inner_int()
    o.bump_inner_float()
    o.flip_inner_bool()
    assert_state(o, "T1", "43", 1.5, "8", 2.75, False, "hello")

    snap = o.save_state()
    r = Outer.restore_state(snap)
    assert_state(r, "T1 restored", "43", 1.5, "8", 2.75, False, "hello")

    # Continuation: bump int after restore — proves arithmetic still
    # works on the restored typed int (catches int-stuck-as-string).
    r.bump_k_int()
    r.bump_inner_int()
    assert_state(r, "continue", "44", 1.5, "9", 2.75, False, "hello")

    print("PASS: 86_persist_numeric_typing")

@@[target("python_3")]

@@system Demo {
    interface:
        common(): str
        @@[target("python_3")] only_py(): str
        @@[target("javascript")] only_js(): str

    machine:
        $S {
            common(): str { @@:("common") }
            @@[target("python_3")] only_py(): str { @@:("only_py_present") }
            @@[target("javascript")] only_js(): str { @@:("only_js_present") }
        }
}

if __name__ == "__main__":
    d = @@Demo()
    assert d.common() == "common", f"FAIL common: {d.common()}"
    assert d.only_py() == "only_py_present", f"FAIL only_py: {d.only_py()}"
    assert not hasattr(d, "only_js"), "FAIL: only_js should have been filtered out by @@[target(\"javascript\")]"
    print("PASS: 89_attribute_per_item")

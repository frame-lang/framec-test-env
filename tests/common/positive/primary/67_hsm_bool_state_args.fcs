@@[target("csharp")]


@@system BoolStateArg {
    interface:
        configure(active: bool)
        is_active(): bool

    machine:
        $Idle {
            configure(active: bool) {
                -> $Active(active)
            }
            is_active(): bool {
                @@:(false)
            }
        }

        $Active => $Frame(flag: bool) {
            configure(active: bool) {
                -> $Active(active)
            }
            is_active(): bool {
                => $^
            }
        }

        $Frame {
            is_active(): bool {
                @@:(flag)
            }
        }
    domain:
        n : int = 0
}

class Program {
    static void Main(string[] args) {
        var s = @@BoolStateArg();
        if (s.is_active() != false) { Console.WriteLine("FAIL idle"); Environment.Exit(1); }
        s.configure(true);
        if (s.is_active() != true) { Console.WriteLine("FAIL true"); Environment.Exit(1); }
        s.configure(false);
        if (s.is_active() != false) { Console.WriteLine("FAIL false"); Environment.Exit(1); }
        s.configure(true);
        if (s.is_active() != true) { Console.WriteLine("FAIL re-true"); Environment.Exit(1); }
        Console.WriteLine("PASS: 67_hsm_bool_state_args");
    }
}

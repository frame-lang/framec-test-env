@@[target("python_3")]

# Test 66: HSM cascade × state-args of type str.
# Companion to test 65 (int) — exercises the typed-state-arg
# prefetch path for string state-args.

@@system StrStateArg {
    interface:
        configure(label: str)
        identify(): str

    machine:
        $Idle {
            configure(label: str) {
                -> $Active(label)
            }
            identify(): str {
                @@:("anonymous")
                return
            }
        }

        $Active => $Frame(label: str) {
            configure(label: str) {
                -> $Active(label)
            }
            identify(): str {
                => $^
            }
        }

        $Frame {
            identify(): str {
                @@:(label)
                return
            }
        }
    domain:
        n: int = 0
}

def main():
    s = @@StrStateArg()
    assert s.identify() == "anonymous"
    s.configure("alice")
    assert s.identify() == "alice"
    s.configure("bob")
    assert s.identify() == "bob"
    print("PASS: 66_hsm_str_state_args")

if __name__ == '__main__':
    main()

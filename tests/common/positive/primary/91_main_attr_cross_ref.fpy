@@[target("python_3")]

@@system Sub {
    interface:
        ping(): int
    machine:
        $Idle {
            ping(): int { @@:(42) }
        }
}

@@[main]
@@system Top {
    interface:
        run(): int
    machine:
        $Active {
            run(): int { @@:(self.sub.ping()) }
        }
    domain:
        sub: Sub = @@Sub()
}

if __name__ == "__main__":
    t = @@Top()
    v = t.run()
    assert v == 42, f"FAIL run(): {v}"
    print("PASS: 91_main_attr_cross_ref")

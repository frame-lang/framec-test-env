// @skip - Persistence (pickle) not available in C target
@@target c

// NOTE: This test is skipped for C target because pickle-based persistence
// is a Python-specific feature. C would need a different serialization approach.

@@system PersistTestSkipped {
    interface:
        is_alive(): bool

    machine:
        $Start {
            is_alive(): bool {
                return 1
            }
        }
}

int main() {
    printf("=== Test 23: Persist Basic (SKIPPED - pickle not available in C) ===\n");
    printf("SKIP: Persistence tests require Python pickle\n");
    return 0;
}

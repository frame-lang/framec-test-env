@@[target("lua")]

@@system Demo {
    interface:
        get_a(): int
        get_lua_only(): int
    machine:
        $S {
            get_a(): int { @@:(self.a) }
            get_lua_only(): int { @@:(self.lua_only) }
        }
    domain:
        a: int = 1
        @@[target("python_3")] py_only: int = 2
        @@[target("lua")]
        lua_only: int = 42
}

local d = @@Demo()
if d:get_a() ~= 1 then print("FAIL get_a: " .. tostring(d:get_a())); os.exit(1) end
if d:get_lua_only() ~= 42 then print("FAIL get_lua_only: " .. tostring(d:get_lua_only())); os.exit(1) end
print("PASS: 90_attribute_domain_field")

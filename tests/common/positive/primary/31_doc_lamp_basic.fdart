@@target dart
// Documentation Example: Basic Lamp with enter/exit events

@@system Lamp {
    interface:
        turnOn()
        turnOff()
        getColor(): String
        setColor(color: String)
        isSwitchClosed(): bool

    machine:
        $Off {
            turnOn() {
                -> $On
            }
            getColor(): String {
                @@:(this.color)
                return;
            }
            setColor(color: String) {
                this.color = color;
            }
            isSwitchClosed(): bool {
                @@:(this.switch_closed)
                return;
            }
        }

        $On {
            $>() {
                this.closeSwitch();
            }
            <$() {
                this.openSwitch();
            }
            turnOff() {
                -> $Off
            }
            getColor(): String {
                @@:(this.color)
                return;
            }
            setColor(color: String) {
                this.color = color;
            }
            isSwitchClosed(): bool {
                @@:(this.switch_closed)
                return;
            }
        }

    actions:
        closeSwitch() {
            this.switch_closed = true;
        }
        openSwitch() {
            this.switch_closed = false;
        }

    domain:
        color : String = "white"
        switch_closed : bool = false
}

void main() {
    print("== Test 31: Doc Lamp Basic ==");
    final lamp = @@Lamp();

    // Initially off
    if (lamp.isSwitchClosed() != false) {
        throw Exception("Switch should be open initially");
    }

    // Turn on - should close switch
    lamp.turnOn();
    if (lamp.isSwitchClosed() != true) {
        throw Exception("Switch should be closed after turnOn");
    }

    // Check color
    if (lamp.getColor() != "white") {
        throw Exception("Expected 'white', got '${lamp.getColor()}'");
    }

    // Set color
    lamp.setColor("blue");
    if (lamp.getColor() != "blue") {
        throw Exception("Expected 'blue', got '${lamp.getColor()}'");
    }

    // Turn off - should open switch
    lamp.turnOff();
    if (lamp.isSwitchClosed() != false) {
        throw Exception("Switch should be open after turnOff");
    }

    print("PASS: Basic lamp works correctly");
}


@@target gdscript
extends SceneTree

@@system ListStateArg {
    interface:
        configure(items: Array)
        first_item(): int
        size(): int

    machine:
        $Idle {
            configure(items: Array) {
                -> $Active(items)
            }
            first_item(): int {
                @@:(-1)
            }
            size(): int {
                @@:(0)
            }
        }
        $Active(items: Array) {
            configure(items: Array) {
                -> $Active(items)
            }
            first_item(): int {
                @@:(items[0])
            }
            size(): int {
                @@:(items.size())
            }
        }
    domain:
        n: int = 0
}

func _initialize():
    var s = ListStateArg.new()
    if s.first_item() != -1:
        print("FAIL idle first_item"); quit(1); return
    if s.size() != 0:
        print("FAIL idle size"); quit(1); return
    s.configure([10, 20, 30])
    if s.first_item() != 10:
        print("FAIL active first_item"); quit(1); return
    if s.size() != 3:
        print("FAIL active size"); quit(1); return
    s.configure([7])
    if s.first_item() != 7:
        print("FAIL retransition first_item"); quit(1); return
    if s.size() != 1:
        print("FAIL retransition size"); quit(1); return
    print("PASS: 73_list_state_arg")

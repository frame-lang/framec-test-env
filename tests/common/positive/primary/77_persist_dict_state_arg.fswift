@@[target("swift")]

import Foundation

@@[persist]
@@system PersistDict {
    interface:
        configure(m: [String: Int])
        get_v(key: String): Int

    machine:
        $Idle {
            configure(m: [String: Int]) { -> $Active(m) }
            get_v(key: String): Int { @@:(-1) }
        }
        $Active(m: [String: Int]) {
            configure(m: [String: Int]) { -> $Active(m) }
            get_v(key: String): Int { @@:(m[key] ?? -1) }
        }
    domain:
        n : Int = 0
}

let s1 = PersistDict()
s1.configure(["a": 10, "b": 20])
if s1.get_v("a") != 10 { print("FAIL pre"); exit(1) }
let snap = s1.saveState()
let s2 = PersistDict.restoreState(snap)
if s2.get_v("a") != 10 { print("FAIL post a"); exit(1) }
if s2.get_v("b") != 20 { print("FAIL post b"); exit(1) }
print("PASS: 77_persist_dict_state_arg")

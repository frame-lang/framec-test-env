@@[target("kotlin")]

@@[persist(String)]
@@[save(save_state)]
@@[load(restore_state)]
@@system PersistPushpopStateArgs {
    interface:
        push_modal(v: int)
        pop_modal()
        get_slot(): int

    machine:
        $Idle {
            push_modal(v: int) {
                push$
                -> $Modal(v)
            }
            pop_modal() {
                -> pop$
            }
            get_slot(): int {
                @@:(-99)
            }
        }

        $Modal(slot: int) {
            push_modal(v: int) {
                push$
                -> $Modal(v)
            }
            pop_modal() {
                -> pop$
            }
            get_slot(): int {
                @@:(slot)
            }
        }
    domain:
        v : int = 0
}

fun main() {
    println("=== Test 58: Persist × push/pop × state-args (Kotlin) ===")
    val s1 = @@PersistPushpopStateArgs()
    s1.push_modal(42)
    s1.push_modal(77)
    val pre = s1.get_slot()
    if (pre != 77) { println("FAIL: pre $pre"); kotlin.system.exitProcess(1) }
    println("1. Pre-save top slot=$pre")

    val snap = s1.save_state() as String
    val s2 = @@PersistPushpopStateArgs()

    s2.restore_state(snap)
    val post = s2.get_slot()
    if (post != 77) { println("FAIL: post $post"); kotlin.system.exitProcess(1) }
    println("2. Post-restore top slot=$post")

    s2.pop_modal()
    val mid = s2.get_slot()
    if (mid != 42) { println("FAIL: mid $mid"); kotlin.system.exitProcess(1) }
    println("3. After first pop slot=$mid")

    s2.pop_modal()
    val bottom = s2.get_slot()
    if (bottom != -99) { println("FAIL: bottom $bottom"); kotlin.system.exitProcess(1) }
    println("4. After second pop slot=$bottom")

    println("PASS: 58_persist_pushpop_state_args")
}

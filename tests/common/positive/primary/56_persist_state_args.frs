@@target rust

@@[persist]
@@system PersistStateArgs {
    interface:
        kick(v: i32)
        get_slot(): i32

    machine:
        $Idle {
            kick(v: i32) {
                -> $Active(v)
            }
            get_slot(): i32 {
                @@:(-1)
                return;
            }
        }

        $Active(slot: i32) {
            kick(v: i32) {
                -> $Active(v)
            }
            get_slot(): i32 {
                @@:(slot)
                return;
            }
        }
    domain:
        v: i32
}

fn main() {
    println!("=== Test 56: Persist State-Args Round-Trip (Rust) ===");
    let mut s1 = @@PersistStateArgs();
    s1.kick(42);
    let pre = s1.get_slot();
    if pre != 42 { println!("FAIL: pre {}", pre); std::process::exit(1); }
    println!("1. Pre-save slot={}", pre);

    let json = s1.save_state();
    let mut s2 = PersistStateArgs::restore_state(&json);
    let post = s2.get_slot();
    if post != 42 { println!("FAIL: post {}", post); std::process::exit(1); }
    println!("2. Post-restore slot={}", post);

    s2.kick(99);
    let post2 = s2.get_slot();
    if post2 != 99 { println!("FAIL: post2 {}", post2); std::process::exit(1); }
    println!("3. Post-restore-kick slot={}", post2);

    println!("PASS: 56_persist_state_args");
}

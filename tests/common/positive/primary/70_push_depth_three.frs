@@target rust

@@system PushDeep {
    interface:
        descend()
        ascend()
        get_depth(): i32

    machine:
        $Idle {
            descend() {
                push$
                -> $Modal1
            }
            get_depth(): i32 {
                @@:(0)
                return;
            }
        }

        $Modal1 {
            descend() {
                push$
                -> $Modal2
            }
            ascend() {
                -> pop$
            }
            get_depth(): i32 {
                @@:(1)
                return;
            }
        }

        $Modal2 {
            descend() {
                push$
                -> $Modal3
            }
            ascend() {
                -> pop$
            }
            get_depth(): i32 {
                @@:(2)
                return;
            }
        }

        $Modal3 {
            ascend() {
                -> pop$
            }
            get_depth(): i32 {
                @@:(3)
                return;
            }
        }
    domain:
        n: i32
}

fn main() {
    let mut s = @@PushDeep();
    if s.get_depth() != 0 { println!("FAIL idle"); std::process::exit(1); }
    s.descend();
    if s.get_depth() != 1 { println!("FAIL d1"); std::process::exit(1); }
    s.descend();
    if s.get_depth() != 2 { println!("FAIL d2"); std::process::exit(1); }
    s.descend();
    if s.get_depth() != 3 { println!("FAIL d3"); std::process::exit(1); }
    s.ascend();
    if s.get_depth() != 2 { println!("FAIL a1"); std::process::exit(1); }
    s.ascend();
    if s.get_depth() != 1 { println!("FAIL a2"); std::process::exit(1); }
    s.ascend();
    if s.get_depth() != 0 { println!("FAIL a3"); std::process::exit(1); }
    println!("PASS: 70_push_depth_three");
}

@@[target("javascript")]

@@system Demo {
    interface:
        get_a(): int
        get_c(): int
    machine:
        $S {
            get_a(): int { @@:(this.a) }
            get_c(): int { @@:(this.c) }
        }
    domain:
        a = 1
        @@[target("python_3")] b = 2
        @@[target("javascript")]
        c = 42
}

const d = @@Demo();
if (d.get_a() !== 1) { console.log("FAIL get_a: " + d.get_a()); process.exit(1); }
if (d.get_c() !== 42) { console.log("FAIL get_c: " + d.get_c()); process.exit(1); }
if (typeof d.b !== "undefined") {
    console.log("FAIL: b should be filtered out by @@[target(\"python_3\")]");
    process.exit(1);
}
console.log("PASS: 90_attribute_domain_field");

@@[target("swift")]

@@system TransitionPopTest {
    interface:
        start()
        process()
        get_state(): string
        get_log(): string[]

    machine:
        $Idle {
            start() {
                self.log.append("idle:start:push")
                push$
                -> $Working
            }

            process() {
                self.log.append("idle:process")
            }

            get_state(): string {
                @@:("Idle")
                return;
            }

            get_log(): string[] {
                @@:(self.log)
                return;
            }
        }

        $Working {
            process() {
                self.log.append("working:process:before_pop")
                -> pop$
                // This should NOT execute because pop transitions away
                self.log.append("working:process:after_pop")
            }

            get_state(): string {
                @@:("Working")
                return;
            }

            get_log(): string[] {
                @@:(self.log)
                return;
            }
        }
    domain:
        log: string[] = []
}

// main
    print("=== Test 20: Transition Pop (Swift) ===")
    let s = @@TransitionPopTest()

    // Initial state should be Idle
    if s.get_state() != "Idle" { fatalError("Expected 'Idle', got '\(s.get_state())'") }
    print("Initial state: \(s.get_state())")

    // start() pushes Idle, transitions to Working
    s.start()
    if s.get_state() != "Working" { fatalError("Expected 'Working', got '\(s.get_state())'") }
    print("After start(): \(s.get_state())")

    // process() in Working does pop transition back to Idle
    s.process()
    if s.get_state() != "Idle" { fatalError("Expected 'Idle' after pop, got '\(s.get_state())'") }
    print("After process() with pop: \(s.get_state())")

    let log = s.get_log()
    print("Log: \(String(describing: log))")

    // Verify log contents
    if !log.contains("idle:start:push") { fatalError("Expected 'idle:start:push' in log") }
    if !log.contains("working:process:before_pop") { fatalError("Expected 'working:process:before_pop' in log") }
    if log.contains("working:process:after_pop") { fatalError("Should NOT have 'working:process:after_pop' in log") }

    print("PASS: Transition pop works correctly")

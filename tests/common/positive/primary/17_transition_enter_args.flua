@@target lua
@@system TransitionEnterArgs {
    interface:
        start()
        get_log(): list

    machine:
        $Idle {
            start() {
                self.log[#self.log + 1] = "idle:start"
                -> ("from_idle", 42) $Active
            }

            get_log(): list {
                @@:(self.log)
                return
            }
        }

        $Active {
            $>(source: str, value: int) {
                self.log[#self.log + 1] = "active:enter:" .. tostring(source) .. ":" .. tostring(value)
            }

            start() {
                self.log[#self.log + 1] = "active:start"
            }

            get_log(): list {
                @@:(self.log)
                return
            }
        }
    domain:
        log: list = []
}

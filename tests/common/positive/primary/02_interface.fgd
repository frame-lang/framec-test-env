@@target gdscript

@@system WithInterface {
    interface:
        greet(name: str): str
        get_count(): int

    machine:
        $Ready {
            greet(name: str): str {
                self.call_count += 1
                @@:("Hello, " + str(name) + "!")
                return
            }

            get_count(): int {
                @@:(self.call_count)
                return
            }
        }

    domain:
        call_count: int = 0
}

func main():
    print("=== Test 02: Interface Methods ===")
    s = @@WithInterface()

    # Test interface method with parameter and return
    result = s.greet("World")
    assert(result == "Hello, World!", "Expected 'Hello, World!', got '" + str(result) + "'")
    print("greet('World') = " + str(result))

    # Test domain variable access through interface
    count = s.get_count()
    assert(count == 1, "Expected count=1, got " + str(count))
    print("get_count() = " + str(count))

    # Call again to verify state
    s.greet("Frame")
    count2 = s.get_count()
    assert(count2 == 2, "Expected count=2, got " + str(count2))
    print("After second call: get_count() = " + str(count2))

    print("PASS: Interface methods work correctly")

func _ready():
    main()

@@target ruby

@@persist
@@system NestedList {
    interface:
        configure(rows: Array)
        first_first(): int
        outer_size(): int

    machine:
        $Idle {
            configure(rows: Array) { -> $Active(rows) }
            first_first(): int { @@:(-1) }
            outer_size(): int { @@:(0) }
        }
        $Active(rows: Array) {
            configure(rows: Array) { -> $Active(rows) }
            first_first(): int { @@:(rows[0][0]) }
            outer_size(): int { @@:(rows.length) }
        }
    domain:
        n: int = 0
}

s1 = NestedList.new
s1.configure([[10, 20], [30, 40]])
abort("FAIL pre") unless s1.first_first == 10
abort("FAIL size") unless s1.outer_size == 2
snap = s1.save_state
s2 = NestedList.restore_state(snap)
abort("FAIL post") unless s2.first_first == 10
abort("FAIL post size") unless s2.outer_size == 2
puts "PASS: 75_nested_list_state_arg"

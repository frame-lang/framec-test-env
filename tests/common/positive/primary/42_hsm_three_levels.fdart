@@target dart
import 'dart:convert';
// Test 42: HSM Three-Level Hierarchy
//
// Tests 3+ level deep hierarchies:
// - $Grandchild => $Child => $Parent
// - Forward through multiple levels
// - Each level's state variables remain isolated

@@system HSMThreeLevels {
    interface:
        handle_at_grandchild()
        forward_to_child()
        forward_to_parent()
        forward_through_all()
        get_log(): List<String>

    machine:
        $Grandchild => $Child {
            $.grandchild_var: int = 1

            handle_at_grandchild() {
                var val = $.grandchild_var;
                this.log.add("Grandchild:handled(var=${val})");
            }

            forward_to_child() {
                this.log.add("Grandchild:forward_to_child");
                => $^
            }

            forward_to_parent() {
                this.log.add("Grandchild:forward_to_parent");
                => $^
            }

            forward_through_all() {
                this.log.add("Grandchild:forward_through_all");
                => $^
            }

            get_log(): list {
                @@:(this.log)
                return;
            }
        }

        $Child => $Parent {
            $.child_var: int = 10

            forward_to_child() {
                var val = $.child_var;
                this.log.add("Child:handled(var=${val})");
            }

            forward_to_parent() {
                var val = $.child_var;
                this.log.add("Child:forward_to_parent(var=${val})");
                => $^
            }

            forward_through_all() {
                var val = $.child_var;
                this.log.add("Child:forward_through_all(var=${val})");
                => $^
            }

            get_log(): list {
                @@:(this.log)
                return;
            }
        }

        $Parent {
            $.parent_var: int = 100

            forward_to_parent() {
                var val = $.parent_var;
                this.log.add("Parent:handled(var=${val})");
            }

            forward_through_all() {
                var val = $.parent_var;
                this.log.add("Parent:forward_through_all(var=${val})");
            }

            get_log(): list {
                @@:(this.log)
                return;
            }
        }
    domain:
        log : List<String> = []
}

void main() {
    print("== Test 42: HSM Three-Level Hierarchy ==");
    final s = @@HSMThreeLevels();

    // TC1.2.1: Three-level hierarchy compiles
    print("TC1.2.1: Three-level hierarchy compiles - PASS");

    // TC1.2.2: Handle at grandchild (no forward)
    s.handle_at_grandchild();
    var log = s.get_log();
    if (!log.contains("Grandchild:handled(var=1)")) throw Exception("Expected Grandchild handler, got ${jsonEncode(log)}");
    print("TC1.2.2: Grandchild handles locally - PASS");

    // TC1.2.3: Forward from grandchild to child
    s.forward_to_child();
    log = s.get_log();
    if (!log.contains("Grandchild:forward_to_child")) throw Exception("Expected Grandchild forward, got ${jsonEncode(log)}");
    if (!log.contains("Child:handled(var=10)")) throw Exception("Expected Child handler, got ${jsonEncode(log)}");
    print("TC1.2.3: Forward grandchild->child - PASS");

    // TC1.2.4: Forward from grandchild through child to parent
    s.forward_to_parent();
    log = s.get_log();
    if (!log.contains("Grandchild:forward_to_parent")) throw Exception("Expected Grandchild forward, got ${jsonEncode(log)}");
    if (!log.contains("Child:forward_to_parent(var=10)")) throw Exception("Expected Child forward, got ${jsonEncode(log)}");
    if (!log.contains("Parent:handled(var=100)")) throw Exception("Expected Parent handler, got ${jsonEncode(log)}");
    print("TC1.2.4: Forward grandchild->child->parent - PASS");

    // TC1.2.5: Forward through entire chain
    s.forward_through_all();
    log = s.get_log();
    if (!log.contains("Grandchild:forward_through_all")) throw Exception("Expected Grandchild, got ${jsonEncode(log)}");
    if (!log.contains("Child:forward_through_all(var=10)")) throw Exception("Expected Child, got ${jsonEncode(log)}");
    if (!log.contains("Parent:forward_through_all(var=100)")) throw Exception("Expected Parent, got ${jsonEncode(log)}");
    print("TC1.2.5: Full chain forward - PASS");

    // Verify state variable isolation
    print("TC1.2.6: State vars isolated (grandchild=1, child=10, parent=100) - PASS");

    print("PASS: HSM three-level hierarchy works correctly");
}


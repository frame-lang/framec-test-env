@@[target("dart")]

@@system InterpStress {
    interface:
        test_interp(): String
        test_standalone(): int
        test_return(): int
        test_multi(): String
        test_mixed(): String

    machine:
        $Active {
            $.count: int = 42
            $.label: String = "hello"

            test_interp(): String {
                @@:("count is ${$.count}")
                return;
            }

            test_standalone(): int {
                final x = $.count + 1;
                @@:(x)
                return;
            }

            test_return(): int {
                @@:($.count)
                return;
            }

            test_multi(): String {
                @@:("${$.count} and ${$.label}")
                return;
            }

            test_mixed(): String {
                final total = 100;
                @@:("${$.count}/$total")
                return;
            }
        }
}

void main() {
    final s = @@InterpStress();
    var failures = 0;

    var r = s.test_interp();
    if (r != "count is 42") { print("FAIL interp: got '$r'"); failures++; }

    var n = s.test_standalone();
    if (n != 43) { print("FAIL standalone: got $n"); failures++; }

    n = s.test_return();
    if (n != 42) { print("FAIL return: got $n"); failures++; }

    r = s.test_multi();
    if (r != "42 and hello") { print("FAIL multi: got '$r'"); failures++; }

    r = s.test_mixed();
    if (r != "42/100") { print("FAIL mixed: got '$r'"); failures++; }

    if (failures > 0) {
        print("FAIL: $failures failures");
        throw Exception("test failed");
    }
    print("PASS: stress_interp (5 cases)");
}

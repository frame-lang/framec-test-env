@@[target("ruby")]

# Documentation Example: History with push$/pop$ (History201)

@@system HistoryBasic {
    interface:
        gotoC_from_A()
        gotoC_from_B()
        gotoB()
        return_back()
        get_state(): str

    machine:
        $A {
            gotoC_from_A() {
                push$
                -> $C
            }
            gotoB() {
                -> $B
            }
            get_state(): str {
                @@:("A")
                return
            }
        }

        $B {
            gotoC_from_B() {
                push$
                -> $C
            }
            get_state(): str {
                @@:("B")
                return
            }
        }

        $C {
            return_back() {
                -> pop$
            }
            get_state(): str {
                @@:("C")
                return
            }
        }
}

puts("=== Test 33: Doc History Basic ===")
h = HistoryBasic.new

# Start in A
raise "Expected 'A', got '#{h.get_state()}'" unless h.get_state() == "A"

# Go to C from A (push A)
h.gotoC_from_A()
raise "Expected 'C', got '#{h.get_state()}'" unless h.get_state() == "C"

# Return back (pop to A)
h.return_back()
raise "Expected 'A' after pop, got '#{h.get_state()}'" unless h.get_state() == "A"

# Now go to B
h.gotoB()
raise "Expected 'B', got '#{h.get_state()}'" unless h.get_state() == "B"

# Go to C from B (push B)
h.gotoC_from_B()
raise "Expected 'C', got '#{h.get_state()}'" unless h.get_state() == "C"

# Return back (pop to B)
h.return_back()
raise "Expected 'B' after pop, got '#{h.get_state()}'" unless h.get_state() == "B"

puts("PASS: History push/pop works correctly")

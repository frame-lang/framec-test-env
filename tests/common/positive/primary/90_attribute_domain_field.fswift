@@[target("swift")]

import Foundation

@@system Demo {
    interface:
        get_a(): Int
        get_swift_only(): Int
    machine:
        $S {
            get_a(): Int { @@:(self.a) }
            get_swift_only(): Int { @@:(self.swift_only) }
        }
    domain:
        a: Int = 1
        @@[target("python_3")] py_only: Int = 2
        @@[target("swift")]
        swift_only: Int = 42
}

let d = Demo()
if d.get_a() != 1 { print("FAIL get_a: \(d.get_a())"); exit(1) }
if d.get_swift_only() != 42 { print("FAIL get_swift_only: \(d.get_swift_only())"); exit(1) }
print("PASS: 90_attribute_domain_field")

@@[target("ruby")]

@@system WithTransition {
    interface:
        next()
        get_state(): str

    machine:
        $First {
            next() {
                puts("Transitioning: First -> Second")
                -> $Second
            }

            get_state(): str {
                @@:("First")
                return
            }
        }

        $Second {
            next() {
                puts("Transitioning: Second -> First")
                -> $First
            }

            get_state(): str {
                @@:("Second")
                return
            }
        }
}

puts("=== Test 03: State Transitions ===")
s = WithTransition.new

# Initial state should be First
state = s.get_state()
raise "Expected 'First', got '#{state}'" unless state == "First"
puts("Initial state: #{state}")

# Transition to Second
s.next()
state = s.get_state()
raise "Expected 'Second', got '#{state}'" unless state == "Second"
puts("After first next(): #{state}")

# Transition back to First
s.next()
state = s.get_state()
raise "Expected 'First', got '#{state}'" unless state == "First"
puts("After second next(): #{state}")

puts("PASS: State transitions work correctly")

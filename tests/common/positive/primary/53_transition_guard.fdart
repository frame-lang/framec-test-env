@@target dart

// Test 53: Self-call transition guard
//
// Verifies the automatic transition guard contract: when a handler
// self-calls a method that triggers a transition, code after the
// self-call must NOT execute. The trace must equal exactly
// ["run:before-self-call", "do_transition:body", "Done:enter"].

@@system TransitionGuard {

    interface:
        run()
        do_transition()
        get_trace(): List<String>

    machine:
        $Active {
            run() {
                this.trace.add("run:before-self-call");
                @@:self.do_transition();
                this.trace.add("run:after-self-call");
            }

            do_transition() {
                this.trace.add("do_transition:body");
                -> $Done
            }

            get_trace(): list {
                @@:(this.trace)
                return;
            }
        }

        $Done {
            $>() {
                this.trace.add("Done:enter");
            }

            get_trace(): list {
                @@:(this.trace)
                return;
            }
        }

    domain:
        trace : List<String> = []
}

void main() {
    print("=== Test 53: Self-call transition guard ===");
    final t = @@TransitionGuard();
    t.run();
    var trace = t.get_trace();

    if (!trace.contains("run:before-self-call")) throw Exception("TC1: pre-call statement must execute, got $trace");
    print("TC1: pre-call statement executed - PASS");

    if (!trace.contains("do_transition:body")) throw Exception("TC2: self-called handler body must execute, got $trace");
    print("TC2: self-called handler body executed - PASS");

    if (!trace.contains("Done:enter")) throw Exception("TC3: cascade enter on transition target must fire, got $trace");
    print("TC3: target state \$> handler fired - PASS");

    if (trace.contains("run:after-self-call")) throw Exception("TC4: post-call statement MUST NOT execute (transition guard), got $trace");
    print("TC4: post-call statement suppressed by automatic guard - PASS");

    final expected = ["run:before-self-call", "do_transition:body", "Done:enter"];
    if (trace.length != expected.length) throw Exception("TC5: trace size mismatch, got $trace, expected $expected");
    for (var i = 0; i < expected.length; i++) {
        if (trace[i] != expected[i]) throw Exception("TC5: trace[$i] mismatch, got $trace, expected $expected");
    }
    print("TC5: trace order is exactly [before, body, enter] - PASS");

    print("PASS: automatic transition guard suppresses post-self-call code");
}

@@[target("gdscript")]

extends SceneTree

@@[persist(PackedByteArray)]
@@[save(snapshot)]
@@[load(restore)]
@@system Counter {
    interface:
        bump()
        get_n(): int

    machine:
        $Active {
            bump() {
                self.n = self.n + 1
            }
            get_n(): int { @@:(self.n) }
        }

    domain:
        n: int = 0
}

func _init():
    var c1 = Counter.new()
    c1.bump()
    c1.bump()
    c1.bump()
    var snap = c1.snapshot()

    var c2 = Counter.new()
    c2.restore(snap)
    var got = c2.get_n()
    if got != 3:
        print("FAIL: expected 3, got " + str(got))
        quit()
    print("PASS: 93_persist_save_load_contract")
    quit()

@@[target("c")]

// =============================================================================
// Test 01: Interface Return
// =============================================================================
// Validates that event handler returns work correctly via the context stack.
// Tests both syntaxes:
// =============================================================================

@@system InterfaceReturn {
    interface:
        bool_return(): bool
        int_return(): int
        string_return(): char*
        conditional_return(x: int): char*
        computed_return(a: int, b: int): int
        explicit_bool(): bool
        explicit_int(): int
        explicit_string(): char*
        explicit_conditional(x: int): char*
        explicit_computed(a: int, b: int): int

    machine:
        $Active {
            bool_return(): bool {
                @@:(true)
                return;
            }

            int_return(): int {
                @@:(42)
                return;
            }

            string_return(): char* {
                @@:("Frame")
                return;
            }

            conditional_return(x: int): char* {
                if (x < 0) {
                    @@:("negative")
                    return;
                } else if (x == 0) {
                    @@:("zero")
                    return;
                } else {
                    @@:("positive")
                    return;
                }
            }

            computed_return(a: int, b: int): int {
                int result = a * b + 10;
                @@:(result)
                return;
            }

            explicit_bool(): bool {
                @@:(true)
            }

            explicit_int(): int {
                @@:(42)
            }

            explicit_string(): char* {
                @@:("Frame")
            }

            explicit_conditional(x: int): char* {
                if (x < 0) {
                    @@:("negative")
                    return;
                } else if (x == 0) {
                    @@:("zero")
                    return;
                } else {
                    @@:("positive")
                }
            }

            explicit_computed(a: int, b: int): int {
                int result = a * b + 10;
                @@:(result)
            }
        }
}

int main() {
    printf("=== Test 01: Interface Return (C) ===\n");
    InterfaceReturn* s = @@InterfaceReturn();
    int error_count = 0;

    printf("-- Testing 'return value' sugar --\n");

    bool r_bool = InterfaceReturn_bool_return(s);
    if (r_bool != true) {
        printf("FAIL: bool_return: expected true, got %d\n", r_bool);
        error_count++;
    } else {
        printf("1. bool_return() = %d\n", r_bool);
    }

    int r_int = InterfaceReturn_int_return(s);
    if (r_int != 42) {
        printf("FAIL: int_return: expected 42, got %d\n", r_int);
        error_count++;
    } else {
        printf("2. int_return() = %d\n", r_int);
    }

    char* r_str = InterfaceReturn_string_return(s);
    if (strcmp(r_str, "Frame") != 0) {
        printf("FAIL: string_return: expected 'Frame', got '%s'\n", r_str);
        error_count++;
    } else {
        printf("3. string_return() = '%s'\n", r_str);
    }

    r_str = InterfaceReturn_conditional_return(s, -5);
    if (strcmp(r_str, "negative") != 0) {
        printf("FAIL: conditional_return(-5): expected 'negative', got '%s'\n", r_str);
        error_count++;
    }
    r_str = InterfaceReturn_conditional_return(s, 0);
    if (strcmp(r_str, "zero") != 0) {
        printf("FAIL: conditional_return(0): expected 'zero', got '%s'\n", r_str);
        error_count++;
    }
    r_str = InterfaceReturn_conditional_return(s, 10);
    if (strcmp(r_str, "positive") != 0) {
        printf("FAIL: conditional_return(10): expected 'positive', got '%s'\n", r_str);
        error_count++;
    } else {
        printf("4. conditional_return(-5,0,10) = 'negative','zero','positive'\n");
    }

    r_int = InterfaceReturn_computed_return(s, 3, 4);
    if (r_int != 22) {
        printf("FAIL: computed_return(3,4): expected 22, got %d\n", r_int);
        error_count++;
    } else {
        printf("5. computed_return(3,4) = %d\n", r_int);
    }


    r_bool = InterfaceReturn_explicit_bool(s);
    if (r_bool != true) {
        printf("FAIL: explicit_bool: expected true, got %d\n", r_bool);
        error_count++;
    } else {
        printf("6. explicit_bool() = %d\n", r_bool);
    }

    r_int = InterfaceReturn_explicit_int(s);
    if (r_int != 42) {
        printf("FAIL: explicit_int: expected 42, got %d\n", r_int);
        error_count++;
    } else {
        printf("7. explicit_int() = %d\n", r_int);
    }

    r_str = InterfaceReturn_explicit_string(s);
    if (strcmp(r_str, "Frame") != 0) {
        printf("FAIL: explicit_string: expected 'Frame', got '%s'\n", r_str);
        error_count++;
    } else {
        printf("8. explicit_string() = '%s'\n", r_str);
    }

    r_str = InterfaceReturn_explicit_conditional(s, -5);
    if (strcmp(r_str, "negative") != 0) {
        printf("FAIL: explicit_conditional(-5): expected 'negative', got '%s'\n", r_str);
        error_count++;
    }
    r_str = InterfaceReturn_explicit_conditional(s, 0);
    if (strcmp(r_str, "zero") != 0) {
        printf("FAIL: explicit_conditional(0): expected 'zero', got '%s'\n", r_str);
        error_count++;
    }
    r_str = InterfaceReturn_explicit_conditional(s, 10);
    if (strcmp(r_str, "positive") != 0) {
        printf("FAIL: explicit_conditional(10): expected 'positive', got '%s'\n", r_str);
        error_count++;
    } else {
        printf("9. explicit_conditional(-5,0,10) = 'negative','zero','positive'\n");
    }

    r_int = InterfaceReturn_explicit_computed(s, 3, 4);
    if (r_int != 22) {
        printf("FAIL: explicit_computed(3,4): expected 22, got %d\n", r_int);
        error_count++;
    } else {
        printf("10. explicit_computed(3,4) = %d\n", r_int);
    }

    InterfaceReturn_destroy(s);
    if (error_count > 0) {
        printf("FAIL: %d test(s) failed\n", error_count);
        return 1;
    } else {
        printf("PASS: All interface return tests passed\n");
        return 0;
    }
}

@@[target("csharp")]

using System;

@@[persist(string)]
@@[save(SaveState)]
@@[load(RestoreState)]
@@system Inner {
    interface:
        cycle()
        get_state(): string
        get_count(): int

    machine:
        $A {
            cycle() { this.n = this.n + 1; -> $B }
            get_state(): string { @@:("A") }
            get_count(): int { @@:(this.n) }
        }
        $B => $A {
            cycle() { -> $A }
            get_state(): string { @@:("B") }
            get_count(): int { => $^ }
        }
    domain:
        n: int = 0
}

@@[main]
@@system Outer {
    operations:
        @@[save]
        SaveState(): string {}

        @@[load]
        RestoreState(data: string) {}

    interface:
        tick()
        cycle_inner()
        get_outer_state(): string
        get_inner_state(): string
        get_inner_count(): int
        get_k(): int

    machine:
        $Idle {
            tick() { this.k = this.k + 1; -> $Active }
            cycle_inner() { this.inner.cycle(); }
            get_outer_state(): string { @@:("Idle") }
            get_inner_state(): string { @@:(this.inner.get_state()) }
            get_inner_count(): int { @@:(this.inner.get_count()) }
            get_k(): int { @@:(this.k) }
        }
        $Active => $Idle {
            tick() { -> $Idle }
            get_outer_state(): string { @@:("Active") }
            cycle_inner() { => $^ }
            get_inner_state(): string { => $^ }
            get_inner_count(): int { => $^ }
            get_k(): int { => $^ }
        }
    domain:
        k: int = 0
        inner: Inner = @@Inner()
}

class Program {
    static string fmt(Outer o) => $"{o.get_outer_state()}/{o.get_inner_state()}/{o.get_inner_count()}/{o.get_k()}";
    static void Must(string label, Outer o, string expected) {
        var actual = fmt(o);
        if (actual != expected) throw new Exception($"FAIL {label}: {actual} expected {expected}");
    }
    public static void Main(string[] args) {
        var o1 = new Outer();
        var o2 = new Outer();

        o1.cycle_inner();
        o1.cycle_inner();
        o1.cycle_inner();
        Must("o1 pre", o1, "Idle/B/2/0");

        o2.tick();
        o2.tick();
        o2.tick();
        Must("o2 pre", o2, "Active/A/0/2");

        var snap1 = o1.SaveState();
        var snap2 = o2.SaveState();

        var r2 = new Outer();


        r2.RestoreState(snap2);
        var r1 = new Outer();

        r1.RestoreState(snap1);

        Must("r1 restored", r1, "Idle/B/2/0");
        Must("r2 restored", r2, "Active/A/0/2");

        r1.cycle_inner();
        Must("r1 after mut", r1, "Idle/A/2/0");
        Must("r2 after r1 mut", r2, "Active/A/0/2");

        r2.cycle_inner();
        Must("r1 after r2 mut", r1, "Idle/A/2/0");
        Must("r2 after r2 mut", r2, "Active/B/1/2");

        Console.WriteLine("PASS: 87_persist_multi_instance");
    }
}

@@target cpp_17

#include <iostream>
#include <string>
#include <cassert>

@@system StateParams {
    interface:
        start(val: int)
        get_value(): int

    machine:
        $Idle {
            start(val: int) {
                -> $Counter(val)
            }

            get_value(): int {
                @@:(0)
                return;
            }
        }

        $Counter(initial: int) {
            $>() {
                // Access state param via compartment - positional index
                $.count = std::any_cast<int>(this->__compartment->state_args[0]);
                int count_val = $.count;
                printf("Counter entered with initial=%d\n", count_val);
            }

            $.count: int = 0

            get_value(): int {
                @@:($.count)
                return;
            }
        }
}

int main() {
    printf("=== Test 26: State Parameters ===\n");
    StateParams s;

    int val = s.get_value();
    if (val != 0) {
        printf("FAIL: Expected 0 in Idle, got %d\n", val);
        assert(false);
    }
    printf("Initial value: %d\n", val);

    s.start(42);
    val = s.get_value();
    if (val != 42) {
        printf("FAIL: Expected 42 in Counter from state param, got %d\n", val);
        assert(false);
    }
    printf("Value after transition: %d\n", val);

    printf("PASS: State parameters work correctly\n");
    return 0;
}

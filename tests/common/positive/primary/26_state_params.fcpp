@@target cpp_17

#include <iostream>
#include <cassert>

@@system StateParams {
    interface:
        start(val: int): void
        get_value(): int

    machine:
        $Idle {
            start(val: int) {
                -> $Counter(val)
            }

            get_value(): int {
                return 0
            }
        }

        $Counter(initial: int) {
            get_value(): int {
                int v = (int)(intptr_t)StateParams_FrameDict_get(self->__compartment->state_args, "0");
                return v;
            }
        }
}

int main() {
    std::cout << "=== Test 26: State Parameters ===" << std::endl;
    StateParams s;

    int val = s.get_value();
    std::cout << "Initial value: " << val << std::endl;
    assert(val == 0);

    s.start(42);
    val = s.get_value();
    std::cout << "Value after transition: " << val << std::endl;
    assert(val == 42);

    std::cout << "PASS: State parameters work correctly" << std::endl;
    return 0;
}

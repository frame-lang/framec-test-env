@@target lua
@@system ActionsTest {
    interface:
        process(value: int): int
        get_log(): str

    machine:
        $Ready {
            process(value: int): int {
                self.__log_event("start")
                self.__validate_positive(value)
                self.__log_event("valid")
                result = value * 2
                self.__log_event("done")
                return result
            }

            get_log(): str {
                return self.log
            }
        }

    actions:
        __log_event(msg: str) {
            self.log = self.log + msg + ";"
        }

        __validate_positive(n: int) {
            if n < 0:
                raise ValueError(f"Value must be positive: {n}")
        }

    domain:
        log: str = ""
}

@@[target("dart")]
import 'dart:convert';
@@system TransitionPopTest {
    interface:
        start()
        process()
        get_state(): String
        get_log(): List<String>

    machine:
        $Idle {
            start() {
                this.log.add("idle:start:push");
                push$
                -> $Working
            }

            process() {
                this.log.add("idle:process");
            }

            get_state(): String {
                @@:("Idle")
                return;
            }

            get_log(): List<String> {
                @@:(this.log)
                return;
            }
        }

        $Working {
            process() {
                this.log.add("working:process:before_pop");
                -> pop$
                // This should NOT execute because pop transitions away
                this.log.add("working:process:after_pop");
            }

            get_state(): String {
                @@:("Working")
                return;
            }

            get_log(): List<String> {
                @@:(this.log)
                return;
            }
        }
    domain:
        log : List<String> = []
}

void main() {
    print("== Test 20: Transition Pop (TypeScript) ==");
    final s = @@TransitionPopTest();

    // Initial state should be Idle
    if (s.get_state() != "Idle") throw Exception("Expected 'Idle', got '${s.get_state()}'");
    print("Initial state: ${s.get_state()}");

    // start() pushes Idle, transitions to Working
    s.start();
    if (s.get_state() != "Working") throw Exception("Expected 'Working', got '${s.get_state()}'");
    print("After start(): ${s.get_state()}");

    // process() in Working does pop transition back to Idle
    s.process();
    if (s.get_state() != "Idle") throw Exception("Expected 'Idle' after pop, got '${s.get_state()}'");
    print("After process() with pop: ${s.get_state()}");

    final log = s.get_log();
    print("Log: ${jsonEncode(log)}");

    // Verify log contents
    if (!log.contains("idle:start:push")) throw Exception("Expected 'idle:start:push' in log");
    if (!log.contains("working:process:before_pop")) throw Exception("Expected 'working:process:before_pop' in log");
    if (log.contains("working:process:after_pop")) throw Exception("Should NOT have 'working:process:after_pop' in log");

    print("PASS: Transition pop works correctly");
}


@@[target("erlang")]
@@system ContextReentrant {
    interface:
        outer(x: int): str
        inner(y: int): str
    machine:
        $Ready {
            outer(x: int): str {
                Res = self.inner(x * 10)
                @@:(Res)
            }
            inner(y: int): str {
                @@:("inner_result")
                return
            }
        }
}

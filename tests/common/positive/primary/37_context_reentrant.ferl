@@target erlang
@@system ContextReentrant {
    interface:
        outer(x: int): str
        inner(y: int): str
    machine:
        $Ready {
            outer(x: int): str {
                Res = self.inner(x * 10)
                @@:return = Res
            }
            inner(y: int): str {
                return "inner_result"
            }
        }
}

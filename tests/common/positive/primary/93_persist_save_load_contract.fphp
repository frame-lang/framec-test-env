@@[target("php")]

@@[persist]
@@system Counter {
    operations:
        @@[save]
        save_op(): string {}

        @@[load]
        load_op(data: string) {}

    interface:
        bump()
        get_n(): int

    machine:
        $Active {
            bump() {
                $this->n = $this->n + 1;
            }
            get_n(): int { @@:($this->n) }
        }

    domain:
        n: int = 0
}

$c1 = new Counter();
$c1->bump();
$c1->bump();
$c1->bump();
$data = $c1->save_op();

$c2 = new Counter();
$c2->load_op($data);
if ($c2->get_n() !== 3) {
    echo "FAIL: expected 3, got " . $c2->get_n() . "\n";
} else {
    echo "PASS: 93_persist_save_load_contract\n";
}

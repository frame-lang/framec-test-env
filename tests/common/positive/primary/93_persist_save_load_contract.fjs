@@[target("javascript")]

@@[persist(string)]
@@[save(saveOp)]
@@[load(loadOp)]
@@system Counter {
    interface:
        bump()
        getN(): number

    machine:
        $Active {
            bump() {
                this.n = this.n + 1;
            }
            getN(): number { @@:(this.n) }
        }

    domain:
        n = 0
}

function main() {
    const c1 = @@Counter();
    c1.bump();
    c1.bump();
    c1.bump();
    const data = c1.saveOp();

    const c2 = @@Counter();
    c2.loadOp(data);
    if (c2.getN() !== 3) {
        console.log(`FAIL: expected 3, got ${c2.getN()}`);
        return;
    }
    console.log("PASS: 93_persist_save_load_contract");
}

main();

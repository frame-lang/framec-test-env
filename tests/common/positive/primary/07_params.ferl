@@target erlang

@@system WithParams {
    interface:
        start(initial: int)
        add(value: int)
        multiply(a: int, b: int): int
        getTotal(): int

    machine:
        $Idle {
            start(initial: int) {
                self.total = initial
                -> $Running
            }
            add(value: int) { }
            multiply(a: int, b: int): int {
                return 0
            }
            getTotal(): int {
                return self.total
            }
        }

        $Running {
            start(initial: int) { }
            add(value: int) {
                self.total = self.total + value
            }
            multiply(a: int, b: int): int {
                self.total = self.total + a * b
                return a * b
            }
            getTotal(): int {
                return self.total
            }
        }

    domain:
        total = 0
}

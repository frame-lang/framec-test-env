@@[target("lua")]
@@system HistoryHSM {
    interface:
        gotoA()
        gotoB()
        gotoC()
        goBack()
        get_state(): str
        get_log(): list

    machine:
        $Waiting {
            $>() {
                self.log_msg("In $Waiting")
            }
            gotoA() {
                self.log_msg("gotoA")
                -> $A
            }
            gotoB() {
                self.log_msg("gotoB")
                -> $B
            }
            get_state(): str {
                @@:("Waiting")
                return
            }
            get_log(): list {
                @@:(self.log)
                return
            }
        }

        $A => $AB {
            $>() {
                self.log_msg("In $A")
            }
            gotoB() {
                self.log_msg("gotoB")
                -> $B
            }
            get_state(): str {
                @@:("A")
                return
            }
            get_log(): list {
                @@:(self.log)
                return
            }
            => $^
        }

        $B => $AB {
            $>() {
                self.log_msg("In $B")
            }
            gotoA() {
                self.log_msg("gotoA")
                -> $A
            }
            get_state(): str {
                @@:("B")
                return
            }
            get_log(): list {
                @@:(self.log)
                return
            }
            => $^
        }

        $AB {
            gotoC() {
                self.log_msg("gotoC in $AB")
                push$
                -> $C
            }
        }

        $C {
            $>() {
                self.log_msg("In $C")
            }
            goBack() {
                self.log_msg("goBack")
                -> pop$
            }
            get_state(): str {
                @@:("C")
                return
            }
            get_log(): list {
                @@:(self.log)
                return
            }
        }

    actions:
        log_msg(msg: str) {
            self.log[#self.log + 1] = msg
        }

    domain:
        log: list = []
}

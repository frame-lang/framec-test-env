@@[target("ruby")]

@@system TransitionExitArgs {
    interface:
        leave()
        get_log(): list

    machine:
        $Active {
            <$(reason: str, code: int) {
                self.log.push("exit:#{reason}:#{code}")
            }

            leave() {
                self.log.push("leaving")
                ("cleanup", 42) -> $Done
            }

            get_log(): list {
                @@:(self.log)
                return
            }
        }

        $Done {
            $>() {
                self.log.push("enter:done")
            }

            get_log(): list {
                @@:(self.log)
                return
            }
        }
    domain:
        log: list = []
}

puts("=== Test 18: Transition Exit Args ===")
s = TransitionExitArgs.new

# Initial state is Active
log = s.get_log()
raise "Expected empty log, got #{log}" unless log == []

# Leave - should call exit handler with args
s.leave()
log = s.get_log()
raise "Expected 'leaving' in log, got #{log}" unless log.include?("leaving")
raise "Expected 'exit:cleanup:42' in log, got #{log}" unless log.include?("exit:cleanup:42")
raise "Expected 'enter:done' in log, got #{log}" unless log.include?("enter:done")
puts("Log after transition: #{log}")

puts("PASS: Transition exit args work correctly")

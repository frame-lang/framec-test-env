@@[target("erlang")]
@@skip -- Erlang requires one module per file; multi-system tests live in the multi/ directory layout. The RFC-0017 domain-init factory expansion (`@@Counter(7)` → `counter:create(7)`) is exercised by the Erlang multi-system harness in tests/erlang/multi/.

@@system Counter(seed: int) {
    interface:
        bump()
    machine:
        $S { bump() { self.n = self.n + 1 } }
    domain:
        seed = seed
        n = 0
}

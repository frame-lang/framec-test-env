@@target swift

@@system WithParams {
    interface:
        start(initial: number)
        add(value: number)
        multiply(a: number, b: number): number
        get_total(): number

    machine:
        $Idle {
            start(initial: number) {
                self.total = initial
                print("Started with initial value: \(initial)")
                -> $Running
            }

            add(value: number) {
                print("Cannot add in Idle state")
            }

            multiply(a: number, b: number): number {
                return 0
            }

            get_total(): number {
                return self.total
            }
        }

        $Running {
            start(initial: number) {
                print("Already running")
            }

            add(value: number) {
                self.total += value
                print("Added \(value), total is now \(self.total)")
            }

            multiply(a: number, b: number): number {
                let result = a * b
                self.total += result
                print("Multiplied \(a) * \(b) = \(result), total is now \(self.total)")
                return result
            }

            get_total(): number {
                return self.total
            }
        }
    domain:
        total: number = 0
}

// main
    print("=== Test 07: Handler Parameters ===")
    let s = @@WithParams()

    // Initial total should be 0
    var total = s.get_total()
    if total != 0 {
        fatalError("Expected initial total=0, got \(total)")
    }

    // Start with initial value
    s.start(100)
    total = s.get_total()
    if total != 100 {
        fatalError("Expected total=100, got \(total)")
    }
    print("After start(100): total = \(total)")

    // Add value
    s.add(25)
    total = s.get_total()
    if total != 125 {
        fatalError("Expected total=125, got \(total)")
    }
    print("After add(25): total = \(total)")

    // Multiply with two params
    let result = s.multiply(3, 5)
    if result != 15 {
        fatalError("Expected multiply result=15, got \(result)")
    }
    total = s.get_total()
    if total != 140 {
        fatalError("Expected total=140, got \(total)")
    }
    print("After multiply(3,5): result = \(result), total = \(total)")

    print("PASS: Handler parameters work correctly")

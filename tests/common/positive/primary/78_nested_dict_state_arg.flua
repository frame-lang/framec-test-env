@@[target("lua")]

@@[persist]
@@system NestedDict {
    operations:
        @@[save]
        save_state(): string {}

        @@[load]
        restore_state(data: string) {}

    interface:
        configure(m: table)
        get_inner(outer_key: String, inner_key: String): int

    machine:
        $Idle {
            configure(m: table) { -> $Active(m) }
            get_inner(outer_key: String, inner_key: String): int { @@:(-1) }
        }
        $Active(m: table) {
            configure(m: table) { -> $Active(m) }
            get_inner(outer_key: String, inner_key: String): int {
                local __o = m[outer_key]
                if __o then @@:(__o[inner_key] or -1) else @@:(-1) end
            }
        }
    domain:
        n: int = 0
}

local s1 = NestedDict:new()
s1:configure({u = {x = 1, y = 2}, v = {z = 3}})
if s1:get_inner("u", "x") ~= 1 then print("FAIL pre"); os.exit(1) end
local snap = s1:save_state()
local s2 = NestedDict:new()

s2:restore_state(snap)
if s2:get_inner("u", "x") ~= 1 then print("FAIL post u.x"); os.exit(1) end
if s2:get_inner("u", "y") ~= 2 then print("FAIL post u.y"); os.exit(1) end
if s2:get_inner("v", "z") ~= 3 then print("FAIL post v.z"); os.exit(1) end
print("PASS: 78_nested_dict_state_arg")

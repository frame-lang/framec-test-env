@@target erlang
@@system StateArgFwd {
    interface:
        configure(t: int)
        process(): int
    machine:
        $Idle {
            configure(t: int) {
                -> $Active(t)
            }
            process(): int {
                @@:(0)
            }
        }
        $Active => $Frame(threshold: int) {
            configure(t: int) {
                -> $Active(t)
            }
            process(): int {
                => $^
            }
        }
        $Frame {
            process(): int {
                @@:(Threshold)
            }
        }
    domain:
        n = 0
}

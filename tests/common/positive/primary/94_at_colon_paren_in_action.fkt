@@[target("kotlin")]

@@system Counter {
    interface:
        get_value(): Int
        bump()

    machine:
        $Active {
            get_value(): Int { @@:(this._read()) }
            bump() { this.n = this.n + 1 }
        }

    actions:
        // `@@:(<expr>)` inside actions: bodies must lower to a native
        // `return <expr>` — actions are plain functions, not Frame
        // handlers, so there's no context-stack `_return` slot.
        _read(): Int {
            if (this.n > 0) {
                @@:(this.n)
            } else {
                @@:(0)
            }
        }

    domain:
        n: Int = 0
}

fun main() {
    val inst = Counter()
    if (inst.get_value() != 0) {
        println("FAIL initial: expected 0, got ${inst.get_value()}")
        kotlin.system.exitProcess(1)
    }

    inst.bump()
    inst.bump()
    inst.bump()
    if (inst.get_value() != 3) {
        println("FAIL post-bump: expected 3, got ${inst.get_value()}")
        kotlin.system.exitProcess(1)
    }

    println("PASS: 94_at_colon_paren_in_action")
}

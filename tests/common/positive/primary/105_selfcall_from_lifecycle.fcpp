@@[target("cpp_17")]

#include <iostream>
#include <cassert>

// Test 105: @@:self.method() from lifecycle handlers (F1 regression)

@@system LifecycleSelfCall {
    interface:
        tick()
        go()
        get_count(): int

    machine:
        $A {
            $>() { @@:self.tick() }
            <$() { @@:self.tick() }
            go() { -> $B }
            tick() { count = count + 1; }
            get_count(): int { @@:(count) }
        }

        $B {
            $>() { @@:self.tick() }
            tick() { count = count + 1; }
            get_count(): int { @@:(count) }
        }

    domain:
        count : int = 0
}

int main() {
    printf("=== Test 105: @@:self.method() from lifecycle handlers (F1 regression) ===\n");
    auto s = @@LifecycleSelfCall();
    if (s.get_count() != 1) { printf("FAIL: Expected 1\n"); assert(false); }
    printf("TC1: @@:self from start state $> - PASS\n");
    s.go();
    if (s.get_count() != 3) { printf("FAIL: Expected 3\n"); assert(false); }
    printf("TC2/TC3: @@:self from <$ + post-transition $> - PASS\n");
    printf("PASS: F1 regression\n");
    return 0;
}

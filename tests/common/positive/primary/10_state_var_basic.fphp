<?php
@@target php

@@system StateVarBasic {
    interface:
        increment(): int
        get_count(): int
        reset()

    machine:
        $Counter {
            $.count: int = 0

            increment(): int {
                $.count = $.count + 1;
                @@:($.count)
                return;
            }

            get_count(): int {
                @@:($.count)
                return;
            }

            reset() {
                $.count = 0;
            }
        }
}

echo "=== Test 10: State Variable Basic ===" . "\n";
$s = new StateVarBasic();

if ($s->get_count() !== 0) { echo "FAIL: Expected 0\n"; exit(1); }
echo "Initial count: " . $s->get_count() . "\n";

$result = $s->increment();
if ($result !== 1) { echo "FAIL: Expected 1 after first increment, got {$result}\n"; exit(1); }
echo "After first increment: {$result}" . "\n";

$result = $s->increment();
if ($result !== 2) { echo "FAIL: Expected 2 after second increment, got {$result}\n"; exit(1); }
echo "After second increment: {$result}" . "\n";

$s->reset();
if ($s->get_count() !== 0) { echo "FAIL: Expected 0 after reset\n"; exit(1); }
echo "After reset: " . $s->get_count() . "\n";

echo "PASS: State variable basic operations work correctly" . "\n";

@@[target("typescript")]

@@system Test {
    interface:
        ready(): boolean

    machine:
        $Active {
            ready(): boolean {
                @@:(this.timer >= this.threshold
                    && this.count < this.limit)
            }
        }
    domain:
        timer: int = 100
        threshold: int = 50
        count: int = 1
        limit: int = 5
}

const t = new Test();
if (t.ready() !== true) {
    console.log(`FAIL ready(): ${t.ready()}`);
} else {
    console.log("PASS: 92_return_expr_multiline");
}

@@target ruby

# Test: Basic System Context Access
# Validates @@:params["param"], @@:return, @@:event syntax

@@system ContextBasicTest {
    interface:
        add(a: int, b: int): int
        get_event_name(): str
        greet(name: str): str

    machine:
        $Ready {
            add(a: int, b: int): int {
                # Access params via @@ shorthand
                @@:(@@:params["a"] + @@:params["b"])
            }

            get_event_name(): str {
                # Access event name
                @@:(@@:event)
            }

            greet(name: str): str {
                # Mix param access and return
                result = "Hello, " + @@:params["name"] + "!"
                @@:(result)
            }
        }
}

puts("=== Test 36: Context Basic ===")
s = ContextBasicTest.new

# Test 1: @@:params["a"] and @@:params["b"] param access, @@:return
result = s.add(3, 5)
raise "Expected 8, got #{result}" unless result == 8
puts("1. add(3, 5) = #{result}")

# Test 2: @@:event access
event_name = s.get_event_name()
raise "Expected 'get_event_name', got '#{event_name}'" unless event_name == "get_event_name"
puts("2. @@:event = '#{event_name}'")

# Test 3: @@:params["name"] param access with string
greeting = s.greet("World")
raise "Expected 'Hello, World!', got '#{greeting}'" unless greeting == "Hello, World!"
puts("3. greet('World') = '#{greeting}'")

puts("PASS: Context basic access works correctly")

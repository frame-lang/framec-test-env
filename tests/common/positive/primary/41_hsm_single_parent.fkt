@@target kotlin

import kotlin.system.exitProcess

@@system HSMSingleParent {
    interface:
        child_only()
        forward_to_parent()
        get_log(): MutableList<Any?>
        get_state(): String

    machine:
        $Child => $Parent {
            child_only() {
                this.log.add("Child:child_only")
            }

            forward_to_parent() {
                this.log.add("Child:before_forward")
                => $^
                this.log.add("Child:after_forward")
            }

            get_log(): MutableList<Any?> {
                return this.log
            }

            get_state(): String {
                return "Child"
            }
        }

        $Parent {
            forward_to_parent() {
                this.log.add("Parent:forward_to_parent")
            }

            get_log(): MutableList<Any?> {
                return this.log
            }

            get_state(): String {
                return "Parent"
            }
        }
    domain:
        log = mutableListOf<String>()
}

fun main() {
    println("=== Test 41: HSM Single Parent ===")
    val s = @@HSMSingleParent()

    // TC1.1.1: Child declares parent with `=> $Parent` syntax (verified by compilation)
    println("TC1.1.1: Child-Parent relationship compiles - PASS")

    // TC1.1.2: Child can forward events to parent
    s.forward_to_parent()
    var log = s.get_log() as MutableList<*>
    if (!log.contains("Child:before_forward")) {
        println("FAIL: Expected Child:before_forward in log, got $log")
        exitProcess(1)
    }
    if (!log.contains("Parent:forward_to_parent")) {
        println("FAIL: Expected Parent:forward_to_parent in log, got $log")
        exitProcess(1)
    }
    println("TC1.1.2: Child forwards to parent - PASS (log: $log)")

    // TC1.1.3: Child remains the current state (no transition occurs on forward)
    val state = s.get_state() as String
    if (state != "Child") {
        println("FAIL: Expected state 'Child', got '$state'")
        exitProcess(1)
    }
    println("TC1.1.3: Child remains current state after forward - PASS")

    // TC1.1.4: Parent handler executes and returns control
    if (!log.contains("Child:after_forward")) {
        println("FAIL: Expected Child:after_forward in log (after parent), got $log")
        exitProcess(1)
    }
    val idx_parent = log.indexOf("Parent:forward_to_parent")
    val idx_after = log.indexOf("Child:after_forward")
    if (idx_after <= idx_parent) {
        println("FAIL: Expected Child:after_forward after Parent handler")
        exitProcess(1)
    }
    println("TC1.1.4: Parent executes and returns control - PASS")

    // TC1.1.5: Child-only event not forwarded
    s.child_only()
    log = s.get_log() as MutableList<*>
    var count = 0
    for (item in log) {
        if (item == "Child:child_only") count++
    }
    if (count != 1) {
        println("FAIL: Expected exactly 1 Child:child_only, got $log")
        exitProcess(1)
    }
    println("TC1.1.5: Child-only event handled locally - PASS")

    println("PASS: HSM single parent relationship works correctly")
}

@@[target("ruby")]

@@system OpHsmStateArgs {
    operations:
        add_offset(x: int, off: int): int {
            return x + off
        }

    interface:
        enter_active(t: int)
        classify(v: int): int

    machine:
        $Idle {
            enter_active(t: int) {
                -> $Active(t)
            }
            classify(v: int): int {
                @@:(-1)
                return
            }
        }

        $Active => $Frame(threshold: int) {
            enter_active(t: int) {
                -> $Active(t)
            }
            classify(v: int): int {
                @@:(self.add_offset(v, threshold))
                return
            }
        }

        $Frame {
        }
    domain:
        n: int = 0
}

puts("=== Test 64: Operations × HSM × state-args (Ruby) ===")
s = @@OpHsmStateArgs()

pre = s.classify(5)
raise "pre #{pre}" unless pre == -1
puts("1. Idle classify(5) = #{pre}")

s.enter_active(10)
r = s.classify(5)
raise "r #{r}" unless r == 15
puts("2. classify(5) with threshold=10 → #{r}")

s.enter_active(100)
r3 = s.classify(5)
raise "r3 #{r3}" unless r3 == 105
puts("3. classify(5) with threshold=100 → #{r3}")

puts("PASS: 64_operation_hsm_state_args")

@@[target("csharp")]

using System;
using System.Collections.Generic;

// Test 104: RFC-0019 leaf-override of ancestor lifecycle
//
// A child with its own $> / <$ handler and NO `=> $^` forward
// overrides the ancestor's lifecycle handler. Inverse of fixtures
// 46/47/48 (which verify forwarding) — verifies non-forwarding:
// when the leaf does not forward, the ancestor's $> / <$ MUST NOT run.

@@system HSMOverride {
    interface:
        go_to_child()
        go_to_parent()
        get_log(): List<object>
        get_state(): string

    machine:
        $Start {
            go_to_child() { -> $Child }
            go_to_parent() { -> $Parent }
            get_log(): List<object> { @@:(this.log) }
            get_state(): string { @@:("Start") }
        }

        $Child => $Parent {
            $>() {
                // NO `=> $^` — ancestor $> must NOT run.
                this.log.Add("Child:enter");
            }

            <$() {
                // NO `=> $^` — ancestor <$ must NOT run.
                this.log.Add("Child:exit");
            }

            go_to_parent() { -> $Parent }
            get_log(): List<object> { @@:(this.log) }
            get_state(): string { @@:("Child") }
        }

        $Parent {
            $>() {
                this.log.Add("Parent:enter");
            }

            <$() {
                this.log.Add("Parent:exit");
            }

            go_to_child() { -> $Child }
            get_log(): List<object> { @@:(this.log) }
            get_state(): string { @@:("Parent") }
        }
    domain:
        log : List<object> = new List<object>()
}

class Program {
    static int CountOf(List<object> log, string v) {
        int n = 0;
        foreach (var item in log) if (item.Equals(v)) n++;
        return n;
    }
    static bool Contains(List<object> log, string v) {
        foreach (var item in log) if (item.Equals(v)) return true;
        return false;
    }

    static void Main(string[] args) {
        Console.WriteLine("=== Test 104: RFC-0019 leaf-override of ancestor lifecycle ===");
        var s = @@HSMOverride();

        // TC1: Entering $Child fires Child's $> only; Parent's $> must NOT fire.
        s.go_to_child();
        var log = (List<object>)s.get_log();
        if ((string)s.get_state() != "Child") { Console.WriteLine("FAIL: Expected Child"); Environment.Exit(1); }
        if (!Contains(log, "Child:enter")) { Console.WriteLine("FAIL: Expected Child:enter"); Environment.Exit(1); }
        if (Contains(log, "Parent:enter")) { Console.WriteLine("FAIL: Parent:enter MUST NOT fire when Child overrides"); Environment.Exit(1); }
        Console.WriteLine("TC1: Child's $> overrides Parent's $> (no forward) - PASS");

        // TC2: Leaving $Child fires Child's <$ only; Parent's <$ must NOT fire.
        s.go_to_parent();
        log = (List<object>)s.get_log();
        if ((string)s.get_state() != "Parent") { Console.WriteLine("FAIL: Expected Parent"); Environment.Exit(1); }
        if (!Contains(log, "Child:exit")) { Console.WriteLine("FAIL: Expected Child:exit"); Environment.Exit(1); }
        if (CountOf(log, "Parent:exit") != 0) { Console.WriteLine("FAIL: Parent:exit MUST NOT fire (Child overrides)"); Environment.Exit(1); }
        Console.WriteLine("TC2: Child's <$ overrides Parent's <$ (no forward) - PASS");

        // TC3: Direct $Start -> $Parent transition fires Parent's $> exactly once.
        if (CountOf(log, "Parent:enter") != 1) { Console.WriteLine("FAIL: Expected exactly 1 Parent:enter"); Environment.Exit(1); }
        Console.WriteLine("TC3: Direct Parent entry fires Parent's $> normally - PASS");

        Console.WriteLine("PASS: RFC-0019 leaf-override semantics");
    }
}

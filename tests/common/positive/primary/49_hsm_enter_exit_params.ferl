@@target erlang
@@system HSMEnterExitParams {
    interface:
        goToA()
        goToSibling()
        goBack()
        getLog(): str
        getState(): str
    machine:
        $Start {
            goToA() { -> ("starting") $ChildA }
            getLog(): str { return self.log }
            getState(): str { return "Start" }
        }
        $ChildA => $Parent {
            $>(msg: str) {
                self.log = self.log ++ ",childA_enter:" ++ msg
            }
            <$(reason: str) {
                self.log = self.log ++ ",childA_exit:" ++ reason
            }
            goToSibling() { ("leaving_a") -> ("from_a") $ChildB }
            getLog(): str { return self.log }
            getState(): str { return "ChildA" }
        }
        $ChildB => $Parent {
            $>(msg: str) {
                self.log = self.log ++ ",childB_enter:" ++ msg
            }
            goBack() { ("leaving_b") -> ("returning") $ChildA }
            getLog(): str { return self.log }
            getState(): str { return "ChildB" }
        }
        $Parent {
            getLog(): str { return self.log }
            getState(): str { return "Parent" }
        }
    domain:
        log = "init"
}

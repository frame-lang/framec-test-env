@@[target("ruby")]

# Test 53: Self-call transition guard
#
# Verifies the automatic transition guard contract: when a handler
# self-calls a method that triggers a transition, code after the
# self-call must NOT execute. The trace must equal exactly
# ["run:before-self-call", "do_transition:body", "Done:enter"].

@@system TransitionGuard {

    interface:
        run()
        do_transition()
        get_trace(): list

    machine:
        $Active {
            run() {
                self.trace.push("run:before-self-call")
                @@:self.do_transition()
                self.trace.push("run:after-self-call")
            }

            do_transition() {
                self.trace.push("do_transition:body")
                -> $Done
            }

            get_trace(): list {
                @@:(self.trace)
            }
        }

        $Done {
            $>() {
                self.trace.push("Done:enter")
            }

            get_trace(): list {
                @@:(self.trace)
            }
        }

    domain:
        trace: list = []
}

puts("=== Test 53: Self-call transition guard ===")
t = TransitionGuard.new
t.run()
trace = t.get_trace()

raise "TC1: pre-call statement must execute, got #{trace}" unless trace.include?("run:before-self-call")
puts("TC1: pre-call statement executed - PASS")

raise "TC2: self-called handler body must execute, got #{trace}" unless trace.include?("do_transition:body")
puts("TC2: self-called handler body executed - PASS")

raise "TC3: cascade enter on transition target must fire, got #{trace}" unless trace.include?("Done:enter")
puts("TC3: target state $> handler fired - PASS")

raise "TC4: post-call statement MUST NOT execute (transition guard), got #{trace}" if trace.include?("run:after-self-call")
puts("TC4: post-call statement suppressed by automatic guard - PASS")

expected = ["run:before-self-call", "do_transition:body", "Done:enter"]
raise "TC5: trace order must match expected, got #{trace}, expected #{expected}" unless trace == expected
puts("TC5: trace order is exactly [before, body, enter] - PASS")

puts("PASS: automatic transition guard suppresses post-self-call code")

@@[target("lua")]
@@system StateVarBasic {
    interface:
        increment(): int
        get_count(): int
        reset()

    machine:
        $Counter {
            $.count: int = 0

            increment(): int {
                $.count = $.count + 1
                @@:($.count)
                return
            }

            get_count(): int {
                @@:($.count)
                return
            }

            reset() {
                $.count = 0
            }
        }
}

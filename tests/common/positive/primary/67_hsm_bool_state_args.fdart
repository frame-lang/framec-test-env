@@[target("dart")]

import 'dart:io';

@@system BoolStateArg {
    interface:
        configure(active: bool)
        is_active(): bool

    machine:
        $Idle {
            configure(active: bool) {
                -> $Active(active)
            }
            is_active(): bool {
                @@:(false)
                return;
            }
        }

        $Active => $Frame(flag: bool) {
            configure(active: bool) {
                -> $Active(active)
            }
            is_active(): bool {
                => $^
            }
        }

        $Frame {
            is_active(): bool {
                @@:(flag)
                return;
            }
        }
    domain:
        n: int = 0
}

void main() {
    final s = @@BoolStateArg();
    if (s.is_active() != false) { print("FAIL idle"); exit(1); }
    s.configure(true);
    if (s.is_active() != true) { print("FAIL true"); exit(1); }
    s.configure(false);
    if (s.is_active() != false) { print("FAIL false"); exit(1); }
    s.configure(true);
    if (s.is_active() != true) { print("FAIL re-true"); exit(1); }
    print("PASS: 67_hsm_bool_state_args");
}

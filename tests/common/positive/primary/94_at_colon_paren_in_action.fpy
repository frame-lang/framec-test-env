@@[target("python_3")]

@@system Counter {
    interface:
        get_value(): int
        bump()

    machine:
        $Active {
            get_value(): int { @@:(self._read()) }
            bump() { self.n = self.n + 1 }
        }

    actions:
        # `@@:(<expr>)` inside actions: bodies must lower to a native
        # `return <expr>` — actions are plain functions, not Frame
        # handlers, so there's no context-stack `_return` slot.
        # Per bug_at_at_colon_paren_in_actions_passthrough.md.
        _read(): int {
            if self.n > 0:
                @@:(self.n)
            else:
                @@:(0)
        }

    domain:
        n: int = 0
}

if __name__ == "__main__":
    inst = @@Counter()
    if inst.get_value() != 0:
        print(f"FAIL initial: expected 0, got {inst.get_value()}")
        raise SystemExit(1)

    inst.bump()
    inst.bump()
    inst.bump()
    if inst.get_value() != 3:
        print(f"FAIL post-bump: expected 3, got {inst.get_value()}")
        raise SystemExit(1)

    print("PASS: 94_at_colon_paren_in_action")

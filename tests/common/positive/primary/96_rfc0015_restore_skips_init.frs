@@[target("rust")]

@@[persist(JSON)]
@@[save(snapshot)]
@@[load(rehydrate)]
@@system Counter {
    interface:
        get_fire_count(): i32

    machine:
        $A {
            $>() {
                self.fire_count = self.fire_count + 1;
            }
            get_fire_count(): i32 { @@:(self.fire_count) }
        }

    domain:
        fire_count: i32 = 0
}

fn main() {
    let mut c = Counter::new();
    if c.get_fire_count() != 1 {
        println!("FAIL: expected 1 after construction, got {}", c.get_fire_count());
        return;
    }
    let snap = c.snapshot();

    let mut fresh = Counter::new();
    if fresh.get_fire_count() != 1 {
        println!("FAIL: expected 1 on fresh construction, got {}", fresh.get_fire_count());
        return;
    }

    fresh.rehydrate(&snap);
    if fresh.get_fire_count() != 1 {
        println!("D4 violation: $> re-ran on restore (count={}, expected 1)", fresh.get_fire_count());
        return;
    }

    println!("PASS: rfc0015_restore_skips_init");
}

@@target swift

@@system HSMDefaultForward {
    interface:
        handled_event()
        unhandled_event()
        get_log(): string[]

    machine:
        $Child => $Parent {
            handled_event() {
                self.log.append("Child:handled_event")
            }

            get_log(): string[] {
                @@:(self.log)
                return;
            }

            => $^
        }

        $Parent {
            handled_event() {
                self.log.append("Parent:handled_event")
            }

            unhandled_event() {
                self.log.append("Parent:unhandled_event")
            }

            get_log(): string[] {
                @@:(self.log)
                return;
            }
        }
    domain:
        log: string[] = []
}

// main
    print("=== Test 30: HSM State-Level Default Forward ===")
    let s = @@HSMDefaultForward()

    s.handled_event()
    var log = s.get_log()
    if !log.contains("Child:handled_event") {
        fatalError("Expected 'Child:handled_event' in log, got \(log)")
    }
    print("After handled_event: \(String(describing: log))")

    s.unhandled_event()
    log = s.get_log()
    if !log.contains("Parent:unhandled_event") {
        fatalError("Expected 'Parent:unhandled_event' in log (forwarded), got \(log)")
    }
    print("After unhandled_event (forwarded): \(String(describing: log))")

    print("PASS: HSM state-level default forward works correctly")

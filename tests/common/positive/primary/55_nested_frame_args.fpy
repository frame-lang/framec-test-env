@@target python_3

# Test: Frame syntax nested inside another Frame construct's args
# or sub-expressions. All five patterns below were broken before
# defect #10's fix (2026-04-24); the inner Frame segment leaked
# verbatim to the target source.
#
# Patterns covered:
#   1. @@:return as arg to @@:self.method
#   2. @@:params.X as arg to @@:self.method
#   3. Operation call as arg to @@:self.method
#   4. Nested @@:self — @@:self.foo(@@:self.bar(…))
#   5. State-variable `$.v` read as arg to @@:self.method
#
# All five are recursively expanded at the segmentation layer.

@@system Nest {
    operations:
        Doubler(n: int): int {
            return n * 2
        }

    interface:
        p1(x: int): int
        p2(x: int): int
        p3(x: int): int
        p4(x: int): int
        p5(x: int): int
        echo(n: int): int
        inner(x: int): int

    machine:
        $A {
            p1(x: int): int {
                @@:return = x
                @@:self.echo(@@:return)
                @@:(@@:return)
            }
            p2(x: int): int {
                @@:self.echo(@@:params.x)
                @@:(@@:params.x)
            }
            p3(x: int): int {
                @@:self.echo(self.Doubler(x))
                @@:(self.Doubler(x))
            }
            p4(x: int): int {
                @@:return = x
                @@:self.echo(@@:self.inner(@@:return))
                @@:(@@:return)
            }
            p5(x: int): int {
                $.val = x
                @@:self.echo($.val)
                @@:($.val)
            }
            echo(n: int): int { @@:(n) }
            inner(x: int): int { @@:(x) }

            $.val: int = 0
        }
}


def _assert(name, got, expected):
    if got != expected:
        print(f"FAIL: {name} expected {expected}, got {got}")
        import sys
        sys.exit(1)


if __name__ == '__main__':
    inst = @@Nest()
    _assert("p1(7)", inst.p1(7), 7)                 # @@:return in args
    _assert("p2(8)", inst.p2(8), 8)                 # @@:params.x in args
    _assert("p3(9)", inst.p3(9), 18)                # op call in args (9*2)
    _assert("p4(10)", inst.p4(10), 10)              # @@:self nested in @@:self
    _assert("p5(11)", inst.p5(11), 11)              # $.v in args
    print("PASS: nested_frame_args")

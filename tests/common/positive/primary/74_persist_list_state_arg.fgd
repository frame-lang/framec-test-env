@@[target("gdscript")]
extends SceneTree

@@[persist(String)]
@@[save(save_state)]
@@[load(restore_state)]
@@system PersistList {
    interface:
        configure(items: Array)
        first_item(): int
        size(): int

    machine:
        $Idle {
            configure(items: Array) {
                -> $Active(items)
            }
            first_item(): int { @@:(-1) }
            size(): int { @@:(0) }
        }
        $Active(items: Array) {
            configure(items: Array) {
                -> $Active(items)
            }
            first_item(): int { @@:(items[0]) }
            size(): int { @@:(items.size()) }
        }
    domain:
        n: int = 0
}

func _initialize():
    var s1 = @@PersistList()
    s1.configure([10, 20, 30])
    if s1.first_item() != 10:
        print("FAIL pre"); quit(1); return
    var snap = s1.save_state()

    var s2 = @@PersistList()


    s2.restore_state(snap)
    if s2.first_item() != 10:
        print("FAIL restored first_item"); quit(1); return
    if s2.size() != 3:
        print("FAIL restored size"); quit(1); return
    print("PASS: 74_persist_list_state_arg")

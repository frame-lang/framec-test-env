@@target lua
@@system ForwardEnterFirst {
    interface:
        process()
        get_counter(): int
        get_log(): list

    machine:
        $Idle {
            process() {
                -> => $Working
            }

            get_counter(): int {
                return -1
            }

            get_log(): list {
                return self.log
            }
        }

        $Working {
            $.counter: int = 100

            $>() {
                self.log[#self.log + 1] = "Working:enter"
            }

            process() {
                self.log[#self.log + 1] = "Working:process:counter=" + tostring($.counter)
                $.counter = $.counter + 1
            }

            get_counter(): int {
                return $.counter
            }

            get_log(): list {
                return self.log
            }
        }
    domain:
        log: list = []
}

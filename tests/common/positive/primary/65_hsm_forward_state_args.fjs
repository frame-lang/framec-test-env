@@[target("javascript")]

@@system StateArgFwd {
    interface:
        configure(t: int)
        process(): int

    machine:
        $Idle {
            configure(t: number) {
                -> $Active(t)
            }
            process(): number {
                @@:(0)
                return
            }
        }

        $Active => $Frame(threshold: number) {
            configure(t: number) {
                -> $Active(t)
            }
            process(): number {
                => $^
            }
        }

        $Frame {
            process(): number {
                @@:(threshold)
                return
            }
        }
    domain:
        n: number = 0
}

console.log("=== Test 65: HSM × state-args × parent-forward (JS) ===");
const s = new StateArgFwd();

const pre = s.process();
if (pre !== 0) { console.log("FAIL: pre " + pre); process.exit(1); }
console.log(`1. Idle process = ${pre}`);

s.configure(7);
const r = s.process();
if (r !== 7) { console.log("FAIL: r " + r); process.exit(1); }
console.log(`2. configure(7); process() = ${r}`);

s.configure(42);
const r2 = s.process();
if (r2 !== 42) { console.log("FAIL: r2 " + r2); process.exit(1); }
console.log(`3. configure(42); process() = ${r2}`);

console.log("PASS: 65_hsm_forward_state_args");

@@target kotlin

import kotlin.system.exitProcess

@@system ActionsTest {
    interface:
        process(value: Int): Int
        get_log(): String

    machine:
        $Ready {
            process(value: Int): Int {
                this.__log_event("start")
                this.__validate_positive(value)
                this.__log_event("valid")
                val result = value * 2
                this.__log_event("done")
                return result
            }

            get_log(): String {
                return this.log
            }
        }
    actions:
        __log_event(msg: String) {
            this.log = this.log + msg + ";"
        }

        __validate_positive(n: Int) {
            if (n < 0) {
                throw RuntimeException("Value must be positive: " + n)
            }
        }
    domain:
        log = ""

}

fun main() {
    println("=== Test 21: Actions Basic (Kotlin) ===")
    val s = @@ActionsTest()

    // Test 1: Actions are called correctly
    val result = s.process(5) as Int
    if (result != 10) {
        println("FAIL: Expected 10, got $result")
        exitProcess(1)
    }
    println("1. process(5) = $result")

    // Test 2: Log shows action calls
    val log = s.get_log() as String
    if (!log.contains("start")) {
        println("FAIL: Missing 'start' in log: $log")
        exitProcess(1)
    }
    if (!log.contains("valid")) {
        println("FAIL: Missing 'valid' in log: $log")
        exitProcess(1)
    }
    if (!log.contains("done")) {
        println("FAIL: Missing 'done' in log: $log")
        exitProcess(1)
    }
    println("2. Log: $log")

    // Test 3: Action with validation
    try {
        s.process(-1)
        println("FAIL: Should have thrown RuntimeException")
        exitProcess(1)
    } catch (e: RuntimeException) {
        if (e.message?.contains("positive") == true) {
            println("3. Validation caught: ${e.message}")
        } else {
            throw e
        }
    }

    println("PASS: Actions basic works correctly")
}

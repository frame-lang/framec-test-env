@@[target("rust")]

// Test 46: HSM Enter Cascade — Parent has $>, Child does not.
// Cascade fires Parent's $> top-down on child entry.

@@system HSMEnterParentOnly {
    interface:
        go_to_child()
        go_to_parent()
        get_log(): Vec<String>
        get_state(): String

    machine:
        $Start {
            go_to_child() { -> $Child }
            go_to_parent() { -> $Parent }
            get_log(): Vec<String> { @@:(self.log.clone()) }
            get_state(): String { @@:("Start".to_string()) }
        }

        $Child => $Parent {
            go_to_parent() { -> $Parent }
            get_log(): Vec<String> { @@:(self.log.clone()) }
            get_state(): String { @@:("Child".to_string()) }
        }

        $Parent {
            $>() {
                self.log.push("Parent:enter".to_string());
            }
            go_to_child() { -> $Child }
            get_log(): Vec<String> { @@:(self.log.clone()) }
            get_state(): String { @@:("Parent".to_string()) }
        }
    domain:
        log: Vec<String>
}

fn main() {
    println!("=== Test 46: HSM Enter Cascade — Parent only ===");
    let mut s = @@HSMEnterParentOnly();

    s.go_to_child();
    assert!(s.get_state() == "Child", "Expected Child");
    let log = s.get_log();
    assert!(log.contains(&"Parent:enter".to_string()), "Expected Parent:enter on cascade, got {:?}", log);
    println!("TC1: Parent's $> fires on cascade entry to Child - PASS");

    s.go_to_parent();
    let log = s.get_log();
    let count = log.iter().filter(|x| *x == "Parent:enter").count();
    assert!(count == 2, "Expected 2 Parent:enter, got {}", count);
    println!("TC2: Parent's $> fires again when transitioning directly to Parent - PASS");

    s.go_to_child();
    let log = s.get_log();
    let count = log.iter().filter(|x| *x == "Parent:enter").count();
    assert!(count == 3, "Expected 3 Parent:enter, got {}", count);
    println!("TC3: Re-entering Child cascades through Parent again - PASS");

    println!("PASS: HSM enter cascade fires Parent's $> on child entry");
}

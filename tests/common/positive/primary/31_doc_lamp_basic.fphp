<?php
@@target php

# Documentation Example: Basic Lamp with enter/exit events

@@system Lamp {
    interface:
        turnOn()
        turnOff()
        getColor(): str
        setColor(color: str)

    machine:
        $Off {
            turnOn() {
                -> $On
            }
            getColor(): str {
                return $this->color;
            }
            setColor(color: str) {
                $this->color = $color;
            }
        }

        $On {
            $>() {
                $this->closeSwitch();
            }
            <$() {
                $this->openSwitch();
            }
            turnOff() {
                -> $Off
            }
            getColor(): str {
                return $this->color;
            }
            setColor(color: str) {
                $this->color = $color;
            }
        }

    actions:
        closeSwitch() {
            $this->switch_closed = true;
        }
        openSwitch() {
            $this->switch_closed = false;
        }

    domain:
        color = "white"
        switch_closed = false
}

echo "=== Test 31: Doc Lamp Basic ===" . "\n";
$lamp = new Lamp();

if ($lamp->switch_closed !== false) { echo "FAIL: Switch should be open initially\n"; exit(1); }

$lamp->turnOn();
if ($lamp->switch_closed !== true) { echo "FAIL: Switch should be closed after turnOn\n"; exit(1); }

if ($lamp->getColor() !== "white") { echo "FAIL: Expected 'white'\n"; exit(1); }

$lamp->setColor("blue");
if ($lamp->getColor() !== "blue") { echo "FAIL: Expected 'blue'\n"; exit(1); }

$lamp->turnOff();
if ($lamp->switch_closed !== false) { echo "FAIL: Switch should be open after turnOff\n"; exit(1); }

echo "PASS: Basic lamp works correctly" . "\n";

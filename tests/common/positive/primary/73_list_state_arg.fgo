@@target go

package main

import (
    "fmt"
    "os"
)

@@system ListStateArg {
    interface:
        Configure(items: []int)
        FirstItem(): int
        Size(): int

    machine:
        $Idle {
            Configure(items: []int) {
                -> $Active(items)
            }
            FirstItem(): int {
                @@:(-1)
                return;
            }
            Size(): int {
                @@:(0)
                return;
            }
        }
        $Active(items: []int) {
            Configure(items: []int) {
                -> $Active(items)
            }
            FirstItem(): int {
                @@:(items[0])
                return;
            }
            Size(): int {
                @@:(len(items))
                return;
            }
        }
    domain:
        n: int = 0
}

func main() {
    s := NewListStateArg()
    if s.FirstItem() != -1 { fmt.Println("FAIL idle first_item"); os.Exit(1) }
    if s.Size() != 0 { fmt.Println("FAIL idle size"); os.Exit(1) }
    s.Configure([]int{10, 20, 30})
    if s.FirstItem() != 10 { fmt.Println("FAIL active first_item"); os.Exit(1) }
    if s.Size() != 3 { fmt.Println("FAIL active size"); os.Exit(1) }
    s.Configure([]int{7})
    if s.FirstItem() != 7 { fmt.Println("FAIL retransition first_item"); os.Exit(1) }
    if s.Size() != 1 { fmt.Println("FAIL retransition size"); os.Exit(1) }
    fmt.Println("PASS: 73_list_state_arg")
}

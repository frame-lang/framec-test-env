@@target erlang
@@system HSMDefaultForward {
    interface:
        childOnly()
        parentOnly()
        getLog(): str
    machine:
        $Child => $Parent {
            childOnly() {
                self.log = self.log ++ ",child_only"
            }
            getLog(): str {
                @@:(self.log)
            }
        }
        $Parent {
            parentOnly() {
                self.log = self.log ++ ",parent_only"
            }
            getLog(): str {
                @@:(self.log)
            }
        }
    domain:
        log = "init"
}

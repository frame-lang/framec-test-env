@@target erlang
@@system OpsTest {
    operations:
        static double(x: int): int {
            return x * 2
        }
        addOffset(x: int): int {
            return x + self.offset
        }
    interface:
        compute(value: int): int
    machine:
        $Active {
            compute(value: int): int {
                @@:(self.addOffset(value))
                return
            }
        }
    domain:
        offset = 100
}

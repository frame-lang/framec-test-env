@@target erlang
@@system OpsTest {
    operations:
        static double(x: int): int {
            X * 2
        }
        addOffset(x: int): int {
            X + Data#data.offset
        }
    interface:
        compute(value: int): int
    machine:
        $Active {
            compute(value: int): int {
                @@:(addOffset(Data, Value))
            }
        }
    domain:
        offset = 100
}

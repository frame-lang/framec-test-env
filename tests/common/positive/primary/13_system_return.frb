@@target ruby

@@system SystemReturnTest {
    interface:
        add(a: int, b: int): int
        multiply(a: int, b: int): int
        greet(name: str): str
        get_value(): int

    machine:
        $Calculator {
            $.value: int = 0

            add(a: int, b: int): int {
                return a + b
            }

            multiply(a: int, b: int): int {
                @@:return = a * b
            }

            greet(name: str): str {
                return "Hello, " + name + "!"
            }

            get_value(): int {
                $.value = 42
                return $.value
            }
        }
}

puts("=== Test 13: System Return ===")
calc = SystemReturnTest.new

# Test return sugar
result = calc.add(3, 5)
raise "Expected 8, got #{result}" unless result == 8
puts("add(3, 5) = #{result}")

# Test @@:return = expr
result = calc.multiply(4, 7)
raise "Expected 28, got #{result}" unless result == 28
puts("multiply(4, 7) = #{result}")

# Test string return
greeting = calc.greet("World")
raise "Expected 'Hello, World!', got '#{greeting}'" unless greeting == "Hello, World!"
puts("greet('World') = #{greeting}")

# Test return with state variable
value = calc.get_value()
raise "Expected 42, got #{value}" unless value == 42
puts("get_value() = #{value}")

puts("PASS: System return works correctly")

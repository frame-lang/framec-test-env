@@[target("kotlin")]

@@system StateArgFwd {
    interface:
        configure(t: int)
        process(): int

    machine:
        $Idle {
            configure(t: int) {
                -> $Active(t)
            }
            process(): int {
                @@:(0)
            }
        }

        $Active => $Frame(threshold: int) {
            configure(t: int) {
                -> $Active(t)
            }
            process(): int {
                => $^
            }
        }

        $Frame {
            process(): int {
                @@:(threshold)
            }
        }
    domain:
        n : int = 0
}

fun main() {
    println("=== Test 65: HSM × state-args × parent-forward (Kotlin) ===")
    val s = StateArgFwd()

    val pre = s.process()
    if (pre != 0) { println("FAIL: pre $pre"); kotlin.system.exitProcess(1) }
    println("1. Idle process = $pre")

    s.configure(7)
    val r = s.process()
    if (r != 7) { println("FAIL: r $r"); kotlin.system.exitProcess(1) }
    println("2. configure(7); process() = $r")

    s.configure(42)
    val r2 = s.process()
    if (r2 != 42) { println("FAIL: r2 $r2"); kotlin.system.exitProcess(1) }
    println("3. configure(42); process() = $r2")

    println("PASS: 65_hsm_forward_state_args")
}

<?php
@@target php

@@system StateParams {
    interface:
        start(val: int)
        get_value(): int

    machine:
        $Idle {
            start(val: int) {
                -> $Counter($val)
            }

            get_value(): int {
                @@:(0)
                return;
            }
        }

        $Counter(initial: int) {
            $>() {
                $.count = $this->__compartment->state_args["0"];
                $count_val = $.count;
                echo "Counter entered with initial={$count_val}\n";
            }

            $.count: int = 0

            get_value(): int {
                @@:($.count)
                return;
            }
        }
}

echo "=== Test 26: State Parameters ===" . "\n";
$s = new StateParams();

$val = $s->get_value();
if ($val !== 0) { echo "FAIL: Expected 0 in Idle, got {$val}\n"; exit(1); }
echo "Initial value: {$val}" . "\n";

$s->start(42);
$val = $s->get_value();
if ($val !== 42) { echo "FAIL: Expected 42 in Counter from state param, got {$val}\n"; exit(1); }
echo "Value after transition: {$val}" . "\n";

echo "PASS: State parameters work correctly" . "\n";

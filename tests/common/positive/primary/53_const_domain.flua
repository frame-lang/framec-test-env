@@target lua

-- Test: const domain field initialized from system param.

@@system Sensor(threshold: int = 100) {
    interface:
        read(): int
        calibrate(offset: int)
        get_threshold(): int

    machine:
        $Active {
            read(): int {
                @@:(self.value + self.offset)
                return
            }
            calibrate(offset: int) {
                self.offset = offset
            }
            get_threshold(): int {
                @@:(self.threshold)
                return
            }
        }

    domain:
        const threshold = threshold
        value = 50
        offset = 0
}

local failures = 0

-- Test 1: system param override
local s = @@Sensor(200)
local t = s:get_threshold()
if t ~= 200 then
    print("FAIL test 1: expected 200, got " .. tostring(t))
    failures = failures + 1
end

-- Test 2: read returns value + offset
local v = s:read()
if v ~= 50 then
    print("FAIL test 2: expected 50, got " .. tostring(v))
    failures = failures + 1
end

-- Test 3: calibrate changes offset
s:calibrate(10)
v = s:read()
if v ~= 60 then
    print("FAIL test 3: expected 60, got " .. tostring(v))
    failures = failures + 1
end

-- Test 4: default system param
local s2 = @@Sensor()
local t2 = s2:get_threshold()
if t2 ~= 100 then
    print("FAIL test 4: expected 100, got " .. tostring(t2))
    failures = failures + 1
end

if failures > 0 then
    print("FAIL: const_domain (" .. tostring(failures) .. " failures)")
    os.exit(1)
end
print("PASS: const_domain")

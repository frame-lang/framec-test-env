@@[target("gdscript")]
extends SceneTree

@@system OperationsTest {
    operations:
        add(x: int, y: int): int {
            return x + y
        }

        multiply(x: int, y: int): int {
            return x * y
        }

        static factorial(n: int): int {
            if n <= 1:
                return 1
            return n * OperationsTest.factorial(n - 1)
        }

        static is_even(n: int): bool {
            return n % 2 == 0
        }

    interface:
        compute(a: int, b: int): int
        get_last_result(): int

    machine:
        $Ready {
            compute(a: int, b: int): int {
                # Use instance operations
                var sum_val = self.add(a, b)
                var prod_val = self.multiply(a, b)
                var last_result = sum_val + prod_val
                @@:(last_result)
                return
            }

            get_last_result(): int {
                @@:(last_result)
                return
            }
        }

    domain:
        last_result: int = 0

}

func main():
    print("=== Test 22: Operations Basic ===")
    var s = @@OperationsTest()

    # Test 1: Instance operations
    var result = s.add(3, 4)
    assert(result == 7, "Expected 7, got " + str(result))
    print("1. add(3, 4) = " + str(result))

    result = s.multiply(3, 4)
    assert(result == 12, "Expected 12, got " + str(result))
    print("2. multiply(3, 4) = " + str(result))

    # Test 2: Operations used in handler
    result = s.compute(3, 4)
    # compute returns add(3,4) + multiply(3,4) = 7 + 12 = 19
    assert(result == 19, "Expected 19, got " + str(result))
    print("3. compute(3, 4) = " + str(result))

    # Test 3: Static operations
    result = OperationsTest.factorial(5)
    assert(result == 120, "Expected 120, got " + str(result))
    print("4. factorial(5) = " + str(result))

    result = OperationsTest.is_even(4)
    assert(result == true, "Expected True, got " + str(result))
    print("5. is_even(4) = " + str(result))

    result = OperationsTest.is_even(7)
    assert(result == false, "Expected False, got " + str(result))
    print("6. is_even(7) = " + str(result))

    # Test 4: Static can also be called on instance
    result = s.factorial(4)
    assert(result == 24, "Expected 24, got " + str(result))
    print("7. instance.factorial(4) = " + str(result))

    print("PASS: Operations basic works correctly")

func _init():
    main()
    quit()

@@target c

// Test: Basic System Context Access
// Validates @@.param, @@:return, @@:event syntax

#include <stdio.h>
#include <stdlib.h>
#include <stdint.h>
#include <string.h>

@@system ContextBasicTest {
    interface:
        add(a: int, b: int): int
        get_five(): int

    machine:
        $Ready {
            add(a: int, b: int): int {
                // Access params via @@ shorthand and set return
                @@:return = @@.a + @@.b;
            }

            get_five(): int {
                // Simple return
                @@:return = 5;
            }
        }
}

int main() {
    printf("TAP version 14\n");
    printf("1..2\n");

    ContextBasicTest* s = @@ContextBasicTest();

    // Test 1: @@.a and @@.b param access, @@:return
    int result = ContextBasicTest_add(s, 3, 5);
    if (result == 8) {
        printf("ok 1 - add(3, 5) = 8\n");
    } else {
        printf("not ok 1 - add(3, 5) = 8 # got %d\n", result);
    }

    // Test 2: Simple return
    int five = ContextBasicTest_get_five(s);
    if (five == 5) {
        printf("ok 2 - get_five() = 5\n");
    } else {
        printf("not ok 2 - get_five() = 5 # got %d\n", five);
    }

    ContextBasicTest_destroy(s);
    printf("PASS: Context basic works correctly\n");
    return 0;
}

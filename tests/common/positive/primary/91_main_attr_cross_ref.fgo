@@[target("go")]

package main

import "fmt"

@@system Sub {
    interface:
        Ping(): int
    machine:
        $Idle {
            Ping(): int { @@:(42) }
        }
}

@@[main]
@@system Top {
    interface:
        Run(): int
    machine:
        $Active {
            Run(): int { @@:(s.sub.Ping()) }
        }
    domain:
        sub: Sub = @@Sub()
}

func main() {
    t := NewTop()
    if t.Run() != 42 {
        fmt.Printf("FAIL Run(): %d\n", t.Run())
        return
    }
    fmt.Println("PASS: 91_main_attr_cross_ref")
}

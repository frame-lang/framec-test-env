@@[target("gdscript")]
extends SceneTree

@@system EventForwardTest {
    interface:
        process()
        get_log(): list

    machine:
        $Idle {
            process() {
                self.log.append("idle:process:before")
                -> => $Working
                # This should NOT execute because -> => returns after dispatch
                self.log.append("idle:process:after")
            }

            get_log(): list {
                @@:(self.log)
                return
            }
        }

        $Working {
            process() {
                self.log.append("working:process")
            }

            get_log(): list {
                @@:(self.log)
                return
            }
        }
    domain:
        log: list = []
}

func main():
    print("=== Test 19: Transition Forward ===")
    var s = @@EventForwardTest()
    s.process()
    var log = s.get_log()
    print("Log: " + str(log))

    # After transition-forward:
    # - Idle logs "idle:process:before"
    # - Transition to Working
    # - Working handles process(), logs "working:process"
    # - Return prevents "idle:process:after"
    assert("idle:process:before" in log, "Expected 'idle:process:before' in log: " + str(log))
    assert("working:process" in log, "Expected 'working:process' in log: " + str(log))
    assert("idle:process:after" not in log, "Should NOT have 'idle:process:after' in log: " + str(log))

    print("PASS: Transition forward works correctly")

func _init():
    main()
    quit()

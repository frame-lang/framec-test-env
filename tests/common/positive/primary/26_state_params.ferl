@@target erlang
@@system StateParams {
    interface:
        start(val: int)
        getValue(): int
    machine:
        $Idle {
            start(val: int) {
                -> $Counter
            }
            getValue(): int {
                @@:(0)
            }
        }
        $Counter {
            getValue(): int {
                @@:(self.counter_val)
            }
        }
    domain:
        counter_val = 0
}

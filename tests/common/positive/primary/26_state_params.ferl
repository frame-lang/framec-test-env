@@target erlang
@@system StateParams {
    interface:
        start(val: int)
        getValue(): int
    machine:
        $Idle {
            start(val: int) {
                -> $Counter
            }
            getValue(): int { return 0 }
        }
        $Counter {
            getValue(): int { return self.counter_val }
        }
    domain:
        counter_val = 0
}

<?php
@@target php

@@persist
@@system PersistTest {
    interface:
        set_value(v: int)
        get_value(): int
        go_active()
        go_idle()

    machine:
        $Idle {
            set_value(v: int) {
                $this->value = $v;
            }

            get_value(): int {
                @@:($this->value)
                return;
            }

            go_active() {
                -> $Active
            }

            go_idle() {
                # Already idle
            }
        }

        $Active {
            set_value(v: int) {
                $this->value = $v * 2;
            }

            get_value(): int {
                @@:($this->value)
                return;
            }

            go_active() {
                # Already active
            }

            go_idle() {
                -> $Idle
            }
        }
    domain:
        value = 0
        name = "default"
}

echo "=== Test 23: Persist Basic (json) ===" . "\n";

$s1 = new PersistTest();
$s1->set_value(10);
$s1->go_active();
$s1->set_value(5);  // Should be doubled to 10 in Active state
if ($s1->get_value() !== 10) { echo "FAIL: Expected 10 after doubling, got " . $s1->get_value() . "\n"; exit(1); }

$data = $s1->save_state();
if (!is_string($data)) { echo "FAIL: Expected string, got " . gettype($data) . "\n"; exit(1); }
echo "1. Saved state: " . strlen($data) . " bytes" . "\n";

$s2 = PersistTest::restore_state($data);
if ($s2->get_value() !== 10) { echo "FAIL: Expected 10, got " . $s2->get_value() . "\n"; exit(1); }
echo "2. Restored value: " . $s2->get_value() . "\n";

$s2->set_value(3);  // Should be doubled to 6 in Active state
if ($s2->get_value() !== 6) { echo "FAIL: Expected 6, got " . $s2->get_value() . "\n"; exit(1); }
echo "3. After set_value(3) in Active: " . $s2->get_value() . "\n";

$s2->go_idle();
$s2->set_value(4);  // Should NOT be doubled in Idle state
if ($s2->get_value() !== 4) { echo "FAIL: Expected 4, got " . $s2->get_value() . "\n"; exit(1); }
echo "4. After go_idle, set_value(4): " . $s2->get_value() . "\n";

echo "PASS: Persist basic works correctly" . "\n";

@@[target("gdscript")]
extends SceneTree

@@[persist]
@@system PersistTest {
    operations:
        @@[save]
        save_state(): String {}

        @@[load]
        restore_state(data: String) {}

    interface:
        set_value(v: int)
        get_value(): int
        go_active()
        go_idle()

    machine:
        $Idle {
            set_value(v: int) {
                self.value = v
            }

            get_value(): int {
                @@:(self.value)
                return
            }

            go_active() {
                -> $Active
            }

            go_idle() {
                pass  # Already idle
            }
        }

        $Active {
            set_value(v: int) {
                self.value = v * 2
            }

            get_value(): int {
                @@:(self.value)
                return
            }

            go_active() {
                pass  # Already active
            }

            go_idle() {
                -> $Idle
            }
        }
    domain:
        value: int = 0
        name: str = "default"
}

func main():
    print("=== Test 23: Persist Basic (var_to_bytes) ===")

    # Test 1: Create and modify system
    var s1 = @@PersistTest()
    s1.set_value(10)
    s1.go_active()
    s1.set_value(5)  # Should be doubled to 10 in Active state
    assert(s1.get_value() == 10, "Expected 10 after doubling, got " + str(s1.get_value()))

    # Test 2: Save state (returns bytes)
    var data = s1.save_state()
    assert(typeof(data) == TYPE_PACKED_BYTE_ARRAY, "Expected bytes, got " + str(typeof(data)))
    print("1. Saved state: " + str(data.size()) + " bytes")

    # Test 3: Restore state
    var s2 = PersistTest.new()
    s2.restore_state(data)
    assert(s2.get_value() == 10, "Expected 10, got " + str(s2.get_value()))
    print("2. Restored value: " + str(s2.get_value()))

    # Test 4: Verify state is preserved (Active state doubles)
    s2.set_value(3)  # Should be doubled to 6 in Active state
    assert(s2.get_value() == 6, "Expected 6, got " + str(s2.get_value()))
    print("3. After set_value(3) in Active: " + str(s2.get_value()))

    # Test 5: Verify transitions work after restore
    s2.go_idle()
    s2.set_value(4)  # Should NOT be doubled in Idle state
    assert(s2.get_value() == 4, "Expected 4, got " + str(s2.get_value()))
    print("4. After go_idle, set_value(4): " + str(s2.get_value()))

    print("PASS: Persist basic works correctly")

func _init():
    main()
    quit()

@@[target("gdscript")]
extends SceneTree

# Test 47: HSM Enter Cascade — Both Parent and Child have $>
#
# Tests the HSM enter cascade per docs/frame_runtime_introduction.md
# Step 21+. When entering an HSM child, the kernel fires $> on every
# layer of the new chain top-down (parent first, child last).

@@system HSMEnterBoth {
    interface:
        go_to_child()
        go_to_parent()
        get_log(): list
        get_state(): str

    machine:
        $Start {
            go_to_child() { -> $Child }
            go_to_parent() { -> $Parent }
            get_log(): list { @@:(self.log) }
            get_state(): str { @@:("Start") }
        }

        $Child => $Parent {
            $>() {
                self.log.append("Child:enter")
            }
            go_to_parent() { -> $Parent }
            get_log(): list { @@:(self.log) }
            get_state(): str { @@:("Child") }
        }

        $Parent {
            $>() {
                self.log.append("Parent:enter")
            }
            go_to_child() { -> $Child }
            get_log(): list { @@:(self.log) }
            get_state(): str { @@:("Parent") }
        }
    domain:
        log: list = []
}

func main():
    print("=== Test 47: HSM Enter Cascade — Both ===")
    var s = @@HSMEnterBoth()

    s.go_to_child()
    var log = s.get_log()
    assert(s.get_state() == "Child", "Expected Child")
    var pi = log.find("Parent:enter")
    var ci = log.find("Child:enter")
    assert(pi != -1, "Expected Parent:enter")
    assert(ci != -1, "Expected Child:enter")
    assert(pi < ci, "Parent:enter must precede Child:enter (top-down)")
    print("TC1: Parent's $> fires before Child's $> on cascade entry - PASS")

    s.go_to_parent()
    log = s.get_log()
    assert(s.get_state() == "Parent", "Expected Parent")
    assert(log.count("Parent:enter") == 2, "Expected 2 Parent:enter")
    assert(log.count("Child:enter") == 1, "Expected still 1 Child:enter")
    print("TC2: Direct Parent entry fires only Parent's $> - PASS")

    s.go_to_child()
    log = s.get_log()
    assert(log.count("Parent:enter") == 3, "Expected 3 Parent:enter total")
    assert(log.count("Child:enter") == 2, "Expected 2 Child:enter total")
    print("TC3: Re-entering Child cascades through Parent again - PASS")

    print("PASS: HSM enter cascade fires both layers top-down")

func _init():
    main()
    quit()

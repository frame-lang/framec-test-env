@@[target("go")]

package main

import (
    "fmt"
    "os"
)

@@system Demo {
    interface:
        get_a(): int
        get_go_only(): int
    machine:
        $S {
            get_a(): int { @@:(self.a) }
            get_go_only(): int { @@:(self.go_only) }
        }
    domain:
        a: int = 1
        @@[target("python_3")] py_only: int = 2
        @@[target("go")]
        go_only: int = 42
}

func main() {
    d := NewDemo()
    if d.Get_a() != 1 { fmt.Printf("FAIL get_a: %d\n", d.Get_a()); os.Exit(1) }
    if d.Get_go_only() != 42 { fmt.Printf("FAIL get_go_only: %d\n", d.Get_go_only()); os.Exit(1) }
    fmt.Println("PASS: 90_attribute_domain_field")
}

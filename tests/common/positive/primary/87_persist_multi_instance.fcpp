@@[target("cpp")]

#include <iostream>
#include <string>
#include <sstream>
#include <nlohmann/json.hpp>

@@[persist(std::string)]
@@[save(save_state)]
@@[load(restore_state)]
@@system Inner {
    interface:
        cycle()
        get_state(): std::string
        get_count(): int

    machine:
        $A {
            cycle() { this->n = this->n + 1; -> $B }
            get_state(): std::string { @@:("A") }
            get_count(): int { @@:(this->n) }
        }
        $B => $A {
            cycle() { -> $A }
            get_state(): std::string { @@:("B") }
            get_count(): int { => $^ }
        }
    domain:
        n: int = 0
}@@[persist(std::string)]
@@[save(save_state)]
@@[load(restore_state)]


@@[main]
@@system Outer {
    interface:
        tick()
        cycle_inner()
        get_outer_state(): std::string
        get_inner_state(): std::string
        get_inner_count(): int
        get_k(): int

    machine:
        $Idle {
            tick() { this->k = this->k + 1; -> $Active }
            cycle_inner() { this->inner->cycle(); }
            get_outer_state(): std::string { @@:("Idle") }
            get_inner_state(): std::string { @@:(this->inner->get_state()) }
            get_inner_count(): int { @@:(this->inner->get_count()) }
            get_k(): int { @@:(this->k) }
        }
        $Active => $Idle {
            tick() { -> $Idle }
            get_outer_state(): std::string { @@:("Active") }
            cycle_inner() { => $^ }
            get_inner_state(): std::string { => $^ }
            get_inner_count(): int { => $^ }
            get_k(): int { => $^ }
        }
    domain:
        k: int = 0
        inner: Inner = @@Inner()
}

std::string fmt(Outer& o) {
    std::ostringstream s;
    s << o.get_outer_state() << "/" << o.get_inner_state() << "/" << o.get_inner_count() << "/" << o.get_k();
    return s.str();
}

void must(const std::string& label, Outer& o, const std::string& expected) {
    std::string actual = fmt(o);
    if (actual != expected) { std::cout << "FAIL " << label << ": " << actual << " expected " << expected << std::endl; std::exit(1); }
}

int main() {
    auto o1 = @@Outer();
    auto o2 = @@Outer();

    o1.cycle_inner();
    o1.cycle_inner();
    o1.cycle_inner();
    must("o1 pre", o1, "Idle/B/2/0");

    o2.tick();
    o2.tick();
    o2.tick();
    must("o2 pre", o2, "Active/A/0/2");

    std::string snap1 = o1.save_state();
    std::string snap2 = o2.save_state();

    auto r2 = @@Outer();


    r2.restore_state(snap2);
    auto r1 = @@Outer();

    r1.restore_state(snap1);

    must("r1 restored", r1, "Idle/B/2/0");
    must("r2 restored", r2, "Active/A/0/2");

    r1.cycle_inner();
    must("r1 after mut", r1, "Idle/A/2/0");
    must("r2 after r1 mut", r2, "Active/A/0/2");

    r2.cycle_inner();
    must("r1 after r2 mut", r1, "Idle/A/2/0");
    must("r2 after r2 mut", r2, "Active/B/1/2");

    std::cout << "PASS: 87_persist_multi_instance" << std::endl;
    return 0;
}

@@[target("swift")]

import Foundation

func helper_function(_ x: Int) -> Int {
    // Native helper function defined before system
    return x * 2
}

@@system NativeCode {
    interface:
        compute(value: number): number
        use_math(): Double

    machine:
        $Active {
            compute(value: number): number {
                // Native code with local variables
                let temp = value + 10
                let result = helper_function(temp)
                print("Computed: \(value) -> \(result)")
                @@:(result)
                return;
            }

            use_math(): Double {
                // Using Foundation math
                let result = sqrt(16.0) + Double.pi
                print("Math result: \(result)")
                @@:(result)
                return;
            }
        }
}

// main
    print("=== Test 04: Native Code Preservation ===")
    let s = @@NativeCode()

    // Test native code in handler with helper function
    let result = s.compute(5)
    let expected = (5 + 10) * 2  // 30
    if result != expected {
        fatalError("Expected \(expected), got \(result)")
    }
    print("compute(5) = \(result)")

    // Test math usage
    let mathResult = s.use_math()
    let expectedMath = sqrt(16.0) + Double.pi
    if abs(mathResult - expectedMath) >= 0.001 {
        fatalError("Expected ~\(expectedMath), got \(mathResult)")
    }
    print("use_math() = \(mathResult)")

    print("PASS: Native code preservation works correctly")

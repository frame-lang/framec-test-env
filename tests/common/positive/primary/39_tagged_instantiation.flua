@@[target("lua")]
@@system Calculator {
    interface:
        add(a: int, b: int): int
        get_result(): int

    machine:
        $Ready {
            add(a: int, b: int): int {
                self.result = a + b
                @@:(self.result)
                return
            }

            get_result(): int {
                @@:(self.result)
                return
            }
        }
    domain:
        result: int = 0
}
@@[main]
@@system Counter {
    interface:
        increment()
        get_count(): int

    machine:
        $Active {
            increment() {
                self.count = self.count + 1
            }

            get_count(): int {
                @@:(self.count)
                return
            }
        }
    domain:
        count: int = 0
}

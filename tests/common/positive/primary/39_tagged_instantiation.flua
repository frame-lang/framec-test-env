@@target lua
@@system Calculator {
    interface:
        add(a: int, b: int): int
        get_result(): int

    machine:
        $Ready {
            add(a: int, b: int): int {
                self.result = a + b
                return self.result
            }

            get_result(): int {
                return self.result
            }
        }
    domain:
        result: int = 0
}
@@system Counter {
    interface:
        increment()
        get_count(): int

    machine:
        $Active {
            increment() {
                self.count = self.count + 1
            }

            get_count(): int {
                return self.count
            }
        }
    domain:
        count: int = 0
}

@@[target("javascript")]

@@[persist(string)]
@@[save(saveState)]
@@[load(restoreState)]
@@system Outer {
    interface:
        try_save_during_handler()

    machine:
        $S {
            try_save_during_handler() {
                this.saveState()
            }
        }
    domain:
}

const o1 = new Outer();
const snap = o1.saveState();
if (!snap || snap.length === 0) { console.log("FAIL: quiescent save returned empty"); process.exit(1); }

const o2 = new Outer();
let threw = false;
try {
    o2.try_save_during_handler();
} catch (e) {
    threw = true;
    if (!String(e.message).includes("E700")) { console.log(`FAIL wrong error code: ${e.message}`); process.exit(1); }
    if (!String(e.message).includes("not quiescent")) { console.log(`FAIL wrong message: ${e.message}`); process.exit(1); }
}
if (!threw) { console.log("FAIL: expected E700; got no exception"); process.exit(1); }

const o3 = new Outer();
const snap3 = o3.saveState();
if (!snap3) { console.log("FAIL: fresh instance unusable"); process.exit(1); }

console.log("PASS: 88_persist_quiescent_error");

@@[target("gdscript")]

extends SceneTree

@@system Demo {
    interface:
        get_a(): int
        get_gd_only(): int
    machine:
        $S {
            get_a(): int { @@:(self.a) }
            get_gd_only(): int { @@:(self.gd_only) }
        }
    domain:
        a: int = 1
        @@[target("python_3")] py_only: int = 2
        @@[target("gdscript")]
        gd_only: int = 42
}

func _init():
    var d = @@Demo()
    assert(d.get_a() == 1, "FAIL get_a: " + str(d.get_a()))
    assert(d.get_gd_only() == 42, "FAIL get_gd_only: " + str(d.get_gd_only()))
    print("PASS: 90_attribute_domain_field")
    quit()

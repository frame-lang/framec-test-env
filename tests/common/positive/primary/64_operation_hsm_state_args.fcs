@@[target("csharp")]

using System;

@@system OpHsmStateArgs {
    operations:
        add_offset(x: int, off: int): int {
            return x + off;
        }

    interface:
        enter_active(t: int)
        classify(v: int): int

    machine:
        $Idle {
            enter_active(t: int) {
                -> $Active(t)
            }
            classify(v: int): int {
                @@:(-1)
            }
        }

        $Active => $Frame(threshold: int) {
            enter_active(t: int) {
                -> $Active(t)
            }
            classify(v: int): int {
                int r = this.add_offset(v, threshold);
                @@:(r)
            }
        }

        $Frame {
        }
    domain:
        n : int = 0
}

class Program {
    static void Main(string[] args) {
        Console.WriteLine("=== Test 64: Operations × HSM × state-args (C#) ===");
        var s = @@OpHsmStateArgs();

        int pre = s.classify(5);
        if (pre != -1) { Console.WriteLine($"FAIL: pre {pre}"); Environment.Exit(1); }
        Console.WriteLine($"1. Idle classify(5) = {pre}");

        s.enter_active(10);
        int r = s.classify(5);
        if (r != 15) { Console.WriteLine($"FAIL: r {r}"); Environment.Exit(1); }
        Console.WriteLine($"2. classify(5) with threshold=10 → {r}");

        int r2 = s.classify(7);
        if (r2 != 17) { Console.WriteLine($"FAIL: r2 {r2}"); Environment.Exit(1); }
        Console.WriteLine($"3. classify(7) with threshold=10 → {r2}");

        s.enter_active(100);
        int r3 = s.classify(5);
        if (r3 != 105) { Console.WriteLine($"FAIL: r3 {r3}"); Environment.Exit(1); }
        Console.WriteLine($"4. classify(5) with threshold=100 → {r3}");

        Console.WriteLine("PASS: 64_operation_hsm_state_args");
    }
}

@@[target("dart")]

import 'dart:io';

@@system PushDeep {
    interface:
        descend()
        ascend()
        get_depth(): int

    machine:
        $Idle {
            descend() {
                push$
                -> $Modal1
            }
            get_depth(): int {
                @@:(0)
                return;
            }
        }

        $Modal1 {
            descend() {
                push$
                -> $Modal2
            }
            ascend() {
                -> pop$
            }
            get_depth(): int {
                @@:(1)
                return;
            }
        }

        $Modal2 {
            descend() {
                push$
                -> $Modal3
            }
            ascend() {
                -> pop$
            }
            get_depth(): int {
                @@:(2)
                return;
            }
        }

        $Modal3 {
            ascend() {
                -> pop$
            }
            get_depth(): int {
                @@:(3)
                return;
            }
        }
    domain:
        n: int = 0
}

void main() {
    final s = PushDeep();
    if (s.get_depth() != 0) { print("FAIL idle"); exit(1); }
    s.descend();
    if (s.get_depth() != 1) { print("FAIL d1"); exit(1); }
    s.descend();
    if (s.get_depth() != 2) { print("FAIL d2"); exit(1); }
    s.descend();
    if (s.get_depth() != 3) { print("FAIL d3"); exit(1); }
    s.ascend();
    if (s.get_depth() != 2) { print("FAIL a1"); exit(1); }
    s.ascend();
    if (s.get_depth() != 1) { print("FAIL a2"); exit(1); }
    s.ascend();
    if (s.get_depth() != 0) { print("FAIL a3"); exit(1); }
    print("PASS: 70_push_depth_three");
}

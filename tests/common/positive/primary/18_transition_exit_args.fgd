@@[target("gdscript")]
extends SceneTree

@@system TransitionExitArgs {
    interface:
        leave()
        get_log(): list

    machine:
        $Active {
            <$(reason: str, code: int) {
                self.log.append("exit:" + str(reason) + ":" + str(code))
            }

            leave() {
                self.log.append("leaving")
                ("cleanup", 42) -> $Done
            }

            get_log(): list {
                @@:(self.log)
                return
            }
        }

        $Done {
            $>() {
                self.log.append("enter:done")
            }

            get_log(): list {
                @@:(self.log)
                return
            }
        }
    domain:
        log: list = []
}

func main():
    print("=== Test 18: Transition Exit Args ===")
    var s = @@TransitionExitArgs()

    # Initial state is Active
    var log = s.get_log()
    assert(log == [], "Expected empty log, got " + str(log))

    # Leave - should call exit handler with args
    s.leave()
    log = s.get_log()
    assert("leaving" in log, "Expected 'leaving' in log, got " + str(log))
    assert("exit:cleanup:42" in log, "Expected 'exit:cleanup:42' in log, got " + str(log))
    assert("enter:done" in log, "Expected 'enter:done' in log, got " + str(log))
    print("Log after transition: " + str(log))

    print("PASS: Transition exit args work correctly")

func _init():
    main()
    quit()

@@[target("dart")]

@@system DictStateArg {
    interface:
        configure(m: Map<String, int>)
        get_v(key: String): int
        size(): int

    machine:
        $Idle {
            configure(m: Map<String, int>) { -> $Active(m) }
            get_v(key: String): int { @@:(-1) }
            size(): int { @@:(0) }
        }
        $Active(m: Map<String, int>) {
            configure(m: Map<String, int>) { -> $Active(m) }
            get_v(key: String): int { @@:(m[key] ?? -1) }
            size(): int { @@:(m.length) }
        }
    domain:
        n: int = 0
}

void main() {
    var s = @@DictStateArg();
    if (s.get_v("a") != -1) { print("FAIL idle"); return; }
    if (s.size() != 0) { print("FAIL idle size"); return; }
    s.configure({"a": 10, "b": 20});
    if (s.get_v("a") != 10) { print("FAIL a"); return; }
    if (s.get_v("b") != 20) { print("FAIL b"); return; }
    if (s.size() != 2) { print("FAIL size"); return; }
    s.configure({"x": 99});
    if (s.get_v("x") != 99) { print("FAIL x"); return; }
    if (s.size() != 1) { print("FAIL size2"); return; }
    print("PASS: 76_dict_state_arg");
}

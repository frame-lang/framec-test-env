@@[target("php")]

@@system Sub {
    interface:
        ping(): int
    machine:
        $Idle {
            ping(): int { @@:(42) }
        }
}

@@[main]
@@system Top {
    interface:
        run(): int
    machine:
        $Active {
            run(): int { @@:($this->sub->ping()) }
        }
    domain:
        sub: Sub = @@Sub()
}

$t = @@Top();
if ($t->run() !== 42) {
    echo "FAIL run(): " . $t->run() . "\n";
} else {
    echo "PASS: 91_main_attr_cross_ref\n";
}

@@[target("swift")]

// Test 42: HSM Three-Level Hierarchy

@@system HSMThreeLevels {
    interface:
        handle_at_grandchild()
        forward_to_child()
        forward_to_parent()
        forward_through_all()
        get_log(): string[]

    machine:
        $Grandchild => $Child {
            $.grandchild_var: int = 1

            handle_at_grandchild() {
                let val = $.grandchild_var
                self.log.append("Grandchild:handled(var=\(val))")
            }

            forward_to_child() {
                self.log.append("Grandchild:forward_to_child")
                => $^
            }

            forward_to_parent() {
                self.log.append("Grandchild:forward_to_parent")
                => $^
            }

            forward_through_all() {
                self.log.append("Grandchild:forward_through_all")
                => $^
            }

            get_log(): list {
                @@:(self.log)
                return;
            }
        }

        $Child => $Parent {
            $.child_var: int = 10

            forward_to_child() {
                let val = $.child_var
                self.log.append("Child:handled(var=\(val))")
            }

            forward_to_parent() {
                let val = $.child_var
                self.log.append("Child:forward_to_parent(var=\(val))")
                => $^
            }

            forward_through_all() {
                let val = $.child_var
                self.log.append("Child:forward_through_all(var=\(val))")
                => $^
            }

            get_log(): list {
                @@:(self.log)
                return;
            }
        }

        $Parent {
            $.parent_var: int = 100

            forward_to_parent() {
                let val = $.parent_var
                self.log.append("Parent:handled(var=\(val))")
            }

            forward_through_all() {
                let val = $.parent_var
                self.log.append("Parent:forward_through_all(var=\(val))")
            }

            get_log(): list {
                @@:(self.log)
                return;
            }
        }
    domain:
        log: string[] = []
}

// main
    print("=== Test 42: HSM Three-Level Hierarchy ===")
    let s = @@HSMThreeLevels()

    print("TC1.2.1: Three-level hierarchy compiles - PASS")

    s.handle_at_grandchild()
    var log = s.get_log()
    if !log.contains("Grandchild:handled(var=1)") { fatalError("Expected Grandchild handler, got \(String(describing: log))") }
    print("TC1.2.2: Grandchild handles locally - PASS")

    s.forward_to_child()
    log = s.get_log()
    if !log.contains("Grandchild:forward_to_child") { fatalError("Expected Grandchild forward, got \(String(describing: log))") }
    if !log.contains("Child:handled(var=10)") { fatalError("Expected Child handler, got \(String(describing: log))") }
    print("TC1.2.3: Forward grandchild->child - PASS")

    s.forward_to_parent()
    log = s.get_log()
    if !log.contains("Grandchild:forward_to_parent") { fatalError("Expected Grandchild forward, got \(String(describing: log))") }
    if !log.contains("Child:forward_to_parent(var=10)") { fatalError("Expected Child forward, got \(String(describing: log))") }
    if !log.contains("Parent:handled(var=100)") { fatalError("Expected Parent handler, got \(String(describing: log))") }
    print("TC1.2.4: Forward grandchild->child->parent - PASS")

    s.forward_through_all()
    log = s.get_log()
    if !log.contains("Grandchild:forward_through_all") { fatalError("Expected Grandchild, got \(String(describing: log))") }
    if !log.contains("Child:forward_through_all(var=10)") { fatalError("Expected Child, got \(String(describing: log))") }
    if !log.contains("Parent:forward_through_all(var=100)") { fatalError("Expected Parent, got \(String(describing: log))") }
    print("TC1.2.5: Full chain forward - PASS")

    print("TC1.2.6: State vars isolated (grandchild=1, child=10, parent=100) - PASS")

    print("PASS: HSM three-level hierarchy works correctly")

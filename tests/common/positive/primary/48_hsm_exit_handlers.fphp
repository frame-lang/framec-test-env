<?php
@@target php

@@system HSMExitHandlers {
    interface:
        go_to_other()
        go_to_parent()
        go_to_child()
        get_log(): list
        get_state(): str
        get_child_var(): int

    machine:
        $Child => $Parent {
            $.child_var: int = 42
            $>() { $this->log[] = "Child:enter"; }
            <$() { $val = $.child_var; $this->log[] = "Child:exit(var={$val})"; }
            go_to_other() { -> $Other }
            go_to_parent() { -> $Parent }
            get_log(): list {
                @@:($this->log)
            }
            get_state(): str {
                @@:("Child")
            }
            get_child_var(): int {
                @@:($.child_var)
            }
        }

        $Parent {
            $>() { $this->log[] = "Parent:enter"; }
            <$() { $this->log[] = "Parent:exit"; }
            go_to_child() { -> $Child }
            go_to_other() { -> $Other }
            get_log(): list {
                @@:($this->log)
            }
            get_state(): str {
                @@:("Parent")
            }
            get_child_var(): int {
                @@:(-1)
            }
        }

        $Other {
            $>() { $this->log[] = "Other:enter"; }
            go_to_child() { -> $Child }
            go_to_parent() { -> $Parent }
            get_log(): list {
                @@:($this->log)
            }
            get_state(): str {
                @@:("Other")
            }
            get_child_var(): int {
                @@:(-1)
            }
        }
    domain:
        log = []
}

echo "=== Test 48: HSM Exit Handlers ===" . "\n";
$s = new HSMExitHandlers();

$log = $s->get_log();
if (!in_array("Child:enter", $log)) { echo "FAIL\n"; exit(1); }
echo "TC2.4.0: Initial state is Child with enter - PASS" . "\n";

$s->go_to_other();
$log = $s->get_log();
if (!in_array("Child:exit(var=42)", $log)) { echo "FAIL\n"; exit(1); }
if (!in_array("Other:enter", $log)) { echo "FAIL\n"; exit(1); }
echo "TC2.4.1: Child exit fires when transitioning out - PASS" . "\n";

if (in_array("Parent:exit", $log)) { echo "FAIL: Parent:exit should NOT fire for child exit\n"; exit(1); }
echo "TC2.4.2: Parent exit NOT fired for child exit - PASS" . "\n";
echo "TC2.4.3: Exit handler accesses state var (var=42) - PASS" . "\n";

$s->go_to_parent();
$log = $s->get_log();
if (!in_array("Parent:enter", $log)) { echo "FAIL\n"; exit(1); }

$s->go_to_other();
$log = $s->get_log();
if (!in_array("Parent:exit", $log)) { echo "FAIL\n"; exit(1); }
echo "TC2.4.4: Parent exit fires when leaving parent - PASS" . "\n";

echo "PASS: HSM exit handlers work correctly" . "\n";

@@target swift

import Foundation

@@system HsmFourLevel {
    interface:
        drive(): int
        write_at_level(level: int)
        get_n(): int

    machine:
        $Leaf => $Mid {
            drive(): int {
                => $^
            }
            write_at_level(level: int) {
                self.n = self.n + level * 1
                => $^
            }
            get_n(): int {
                @@:(self.n)
            }
        }

        $Mid => $Branch {
            drive(): int {
                => $^
            }
            write_at_level(level: int) {
                self.n = self.n + level * 10
                => $^
            }
        }

        $Branch => $Root {
            drive(): int {
                => $^
            }
            write_at_level(level: int) {
                self.n = self.n + level * 100
                => $^
            }
        }

        $Root {
            drive(): int {
                @@:(self.n)
            }
            write_at_level(level: int) {
                self.n = self.n + level * 1000
            }
        }
    domain:
        n : int = 0
}

print("=== Test 61: 4-level HSM cascade (Swift) ===")
let s = HsmFourLevel()

let initial = s.drive()
if initial != 0 { print("FAIL: initial \(initial)"); exit(1) }
print("1. Initial drive returned \(initial)")

s.write_at_level(2)
let after = s.get_n()
if after != 2222 { print("FAIL: after \(after)"); exit(1) }
print("2. After cascading write: n=\(after)")

let finalVal = s.drive()
if finalVal != 2222 { print("FAIL: final \(finalVal)"); exit(1) }
print("3. Drive after write returned \(finalVal)")

print("PASS: 61_hsm_four_level")

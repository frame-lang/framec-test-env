@@target gdscript

# Test: Basic System Context Access
# Validates @@:params["param"], @@:return, @@:event syntax

@@system ContextBasicTest {
    interface:
        add(a: int, b: int): int
        get_event_name(): str
        greet(name: str): str

    machine:
        $Ready {
            add(a: int, b: int): int {
                # Access params via @@ shorthand
                @@:return = @@:params["a"] + @@:params["b"]
            }

            get_event_name(): str {
                # Access event name
                @@:return = @@:event
            }

            greet(name: str): str {
                # Mix param access and return
                result = "Hello, " + @@:params["name"] + "!"
                @@:return = result
            }
        }
}

def main():
    print("=== Test 36: Context Basic ===")
    s = @@ContextBasicTest()

    # Test 1: @@:params["a"] and @@:params["b"] param access, @@:return
    result = s.add(3, 5)
    assert result == 8, f"Expected 8, got {result}"
    print("1. add(3, 5) = {result}")

    # Test 2: @@:event access
    event_name = s.get_event_name()
    assert event_name == "get_event_name", f"Expected 'get_event_name', got '{event_name}'"
    print("2. @@:event = '{event_name}'")

    # Test 3: @@:params["name"] param access with string
    greeting = s.greet("World")
    assert greeting == "Hello, World!", f"Expected 'Hello, World!', got '{greeting}'"
    print("3. greet('World') = '{greeting}'")

    print("PASS: Context basic access works correctly")

func _ready():
    main()

@@[target("gdscript")]
extends SceneTree

# Test: Basic System Context Access
# Validates @@:params.param, @@:return, @@:event syntax

@@system ContextBasicTest {
    interface:
        add(a: int, b: int): int
        get_event_name(): String
        greet(name: String): String

    machine:
        $Ready {
            add(a: int, b: int): int {
                # Access params via @@ shorthand
                @@:(@@:params.a + @@:params.b)
            }

            get_event_name(): String {
                # Access event name
                @@:(@@:event)
            }

            greet(name: String): String {
                # Mix param access and return
                var result = "Hello, " + @@:params.name + "!"
                @@:(result)
            }
        }
}

func main():
    print("=== Test 36: Context Basic ===")
    var s = @@ContextBasicTest()

    # Test 1: @@:params.a and @@:params.b param access, @@:return
    var result = s.add(3, 5)
    assert(result == 8, "Expected 8, got " + str(result))
    print("1. add(3, 5) = " + str(result))

    # Test 2: @@:event access
    var event_name = s.get_event_name()
    assert(event_name == "get_event_name", "Expected 'get_event_name', got '" + str(event_name) + "'")
    print("2. @@:event = '" + str(event_name) + "'")

    # Test 3: @@:params.name param access with string
    var greeting = s.greet("World")
    assert(greeting == "Hello, World!", "Expected 'Hello, World!', got '" + str(greeting) + "'")
    print("3. greet('World') = '" + str(greeting) + "'")

    print("PASS: Context basic access works correctly")

func _init():
    main()
    quit()

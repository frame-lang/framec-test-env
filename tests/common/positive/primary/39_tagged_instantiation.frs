@@target rust

// Test 39: Tagged System Instantiation
// Validates the @@System() syntax for tracked instantiation

@@system Calculator {
    interface:
        add(a: i32, b: i32): i32
        get_result(): i32

    machine:
        $Ready {
            add(a: i32, b: i32): i32 {
                self.result = a + b;
                @@:(self.result)
                return;
            }

            get_result(): i32 {
                @@:(self.result)
                return;
            }
        }
    domain:
        result: i32
}

@@system Counter {
    interface:
        increment()
        get_count(): i32

    machine:
        $Active {
            increment() {
                self.count = self.count + 1;
            }

            get_count(): i32 {
                @@:(self.count)
                return;
            }
        }
    domain:
        count: i32
}

fn main() {
    println!("=== Test 39: Tagged System Instantiation ===");

    // Tagged instantiation - validated at transpile time
    let mut calc = @@Calculator();
    let mut counter = @@Counter();

    // Test Calculator
    let result = calc.add(3, 4);
    assert!(result == 7, "Expected 7, got {}", result);
    println!("Calculator.add(3, 4) = {}", result);

    let result = calc.get_result();
    assert!(result == 7, "Expected 7, got {}", result);
    println!("Calculator.get_result() = {}", result);

    // Test Counter
    counter.increment();
    counter.increment();
    counter.increment();
    let count = counter.get_count();
    assert!(count == 3, "Expected 3, got {}", count);
    println!("Counter after 3 increments: {}", count);

    println!("PASS: Tagged instantiation works correctly");
}

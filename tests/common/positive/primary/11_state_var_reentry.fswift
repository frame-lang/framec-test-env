@@[target("swift")]

@@system StateVarReentry {
    interface:
        increment(): number
        get_count(): number
        go_other()
        come_back()

    machine:
        $Counter {
            $.count: number = 0

            increment(): number {
                $.count = $.count + 1
                @@:($.count)
                return;
            }

            get_count(): number {
                @@:($.count)
                return;
            }

            go_other() {
                -> $Other
            }
        }

        $Other {
            come_back() {
                -> $Counter
            }

            increment(): number {
                @@:(-1)
                return;
            }

            get_count(): number {
                @@:(-1)
                return;
            }
        }
}

// main
    print("=== Test 11: State Variable Reentry ===")
    let s = @@StateVarReentry()

    // Increment a few times
    let _ = s.increment()
    let _ = s.increment()
    var count = s.get_count()
    if count != 2 {
        fatalError("Expected 2 after two increments, got \(count)")
    }
    print("Count before leaving: \(count)")

    // Leave the state
    s.go_other()
    print("Transitioned to Other state")

    // Come back - state var should be reinitialized to 0
    s.come_back()
    count = s.get_count()
    if count != 0 {
        fatalError("Expected 0 after re-entering Counter (state var reinit), got \(count)")
    }
    print("Count after re-entering Counter: \(count)")

    // Increment again to verify it works
    let result = s.increment()
    if result != 1 {
        fatalError("Expected 1 after increment, got \(result)")
    }
    print("After increment: \(result)")

    print("PASS: State variables reinitialize on state reentry")

@@target kotlin

import kotlin.system.exitProcess

// Test: @@:self.method() — reentrant interface call with transition guard
//
// Validates:
// 1. Basic self-call dispatch (calls own interface method through kernel)
// 2. Return value propagation from self-call
// 3. Transition guard (code after self-call that transitions is suppressed)

@@system SelfCallTest {
    interface:
        calibrate(): String
        reading(): Double
        trigger_transition()
        check_after_transition(): String
        status(): String

    machine:
        $Active {
            calibrate(): String {
                val baseline = @@:self.reading() as Double
                this.offset = baseline * -1
                @@:("calibrated:offset=${this.offset}")
            }

            reading(): Double {
                @@:(this.raw_value + this.offset)
            }

            trigger_transition() {
                -> $Done
            }

            check_after_transition(): String {
                this.trace = "before"
                @@:self.trigger_transition()
                // This line should NOT execute — transition guard suppresses it
                this.trace = "after"
                @@:(this.trace)
            }

            status(): String {
                @@:("active")
            }
        }

        $Done {
            status(): String {
                @@:("done")
            }
        }

    domain:
        raw_value = 42.0
        offset = 0.0
        trace = ""
}

fun main() {
    val s = @@SelfCallTest()

    // Test 1: Self-call returns correct value
    val result = s.calibrate() as String
    if (result != "calibrated:offset=-42.0") {
        println("FAIL: Expected 'calibrated:offset=-42.0', got '$result'")
        exitProcess(1)
    }

    // Test 2: Self-call modified domain state correctly
    val r = s.reading() as Double
    if (r != 0.0) {
        println("FAIL: Expected 0.0 after calibration, got $r")
        exitProcess(1)
    }

    // Test 3: Transition guard — code after self-call that transitions is suppressed
    val s2 = @@SelfCallTest()
    try { s2.check_after_transition() } catch (_: Exception) { /* guard may null return */ }
    if (s2.trace != "before") {
        println("FAIL: Expected 'before' (guard suppressed 'after'), got '${s2.trace}'")
        exitProcess(1)
    }

    // Test 4: System transitioned to $Done
    val st = s2.status() as String
    if (st != "done") {
        println("FAIL: Expected 'done' after transition, got '$st'")
        exitProcess(1)
    }

    println("PASS: self_call")
}

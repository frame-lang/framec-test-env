@@target gdscript

@@system ActionsTest {
    interface:
        process(value: int): int
        get_log(): str

    machine:
        $Ready {
            process(value: int): int {
                self.__log_event("start")
                self.__validate_positive(value)
                self.__log_event("valid")
                result = value * 2
                self.__log_event("done")
                @@:(result)
                return
            }

            get_log(): str {
                @@:(self.log)
                return
            }
        }

    actions:
        __log_event(msg: str) {
            self.log = self.log + msg + ";"
        }

        __validate_positive(n: int) {
            if n < 0:
                push_error("Value must be positive: " + str(n))
        }

    domain:
        log: str = ""
}

func main():
    print("=== Test 21: Actions Basic ===")
    s = @@ActionsTest()

    # Test 1: Actions are called correctly
    result = s.process(5)
    assert(result == 10, "Expected 10, got " + str(result))
    print("1. process(5) = " + str(result))

    # Test 2: Log shows action calls
    log = s.get_log()
    assert("start" in log, "Missing 'start' in log: " + str(log))
    assert("valid" in log, "Missing 'valid' in log: " + str(log))
    assert("done" in log, "Missing 'done' in log: " + str(log))
    print("2. Log: " + str(log))

    # Test 3: Action with validation
    s.process(-1)
    assert(false, "Should have raised ValueError")
    print("PASS: Actions basic works correctly")

func _ready():
    main()

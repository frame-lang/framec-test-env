@@target gdscript
extends SceneTree

# Test 39: Tagged System Instantiation
# Validates the tagged system instantiation syntax

@@system Calculator {
    interface:
        add(a: int, b: int): int
        get_result(): int

    machine:
        $Ready {
            add(a: int, b: int): int {
                self.result = a + b
                @@:(self.result)
                return
            }

            get_result(): int {
                @@:(self.result)
                return
            }
        }
    domain:
        result: int = 0
}

@@system Counter {
    interface:
        increment()
        get_count(): int

    machine:
        $Active {
            increment() {
                self.count = self.count + 1
            }

            get_count(): int {
                @@:(self.count)
                return
            }
        }
    domain:
        count: int = 0
}

func main():
    print("=== Test 39: Tagged System Instantiation ===")

    # Tagged instantiation - validated at transpile time
    var calc = @@Calculator()
    var counter = @@Counter()

    # Test Calculator
    var result = calc.add(3, 4)
    assert(result == 7, "Expected 7, got " + str(result))
    print("Calculator.add(3, 4) = " + str(result))

    result = calc.get_result()
    assert(result == 7, "Expected 7, got " + str(result))
    print("Calculator.get_result() = " + str(result))

    # Test Counter
    counter.increment()
    counter.increment()
    counter.increment()
    var count = counter.get_count()
    assert(count == 3, "Expected 3, got " + str(count))
    print("Counter after 3 increments: " + str(count))

    print("PASS: Tagged instantiation works correctly")

func _init():
    main()
    quit()

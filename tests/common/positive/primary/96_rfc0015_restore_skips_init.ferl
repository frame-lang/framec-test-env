@@[target("erlang")]

@@[persist(JSON)]
@@[save(snapshot)]
@@[load(rehydrate)]
@@system Counter {
    interface:
        get_fire_count(): int

    machine:
        $A {
            $.fire_count: int = 0
            $>() {
                $.fire_count = $.fire_count + 1
            }
            get_fire_count(): int { @@:($.fire_count) }
        }
}

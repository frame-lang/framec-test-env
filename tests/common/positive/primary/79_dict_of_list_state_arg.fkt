@@[target("kotlin")]

@@[persist]
@@system DictOfList {
    operations:
        @@[save]
        save_state(): String {}

        @@[load]
        restore_state(data: String) {}

    interface:
        configure(m: Map<String, List<Int>>)
        get_at(key: String, idx: Int): Int

    machine:
        $Idle {
            configure(m: Map<String, List<Int>>) { -> $Active(m) }
            get_at(key: String, idx: Int): Int { @@:(-1) }
        }
        $Active(m: Map<String, List<Int>>) {
            configure(m: Map<String, List<Int>>) { -> $Active(m) }
            get_at(key: String, idx: Int): Int {
                val __l = m[key]
                if (__l == null || idx >= __l.size) { @@:(-1) }
                else { @@:(__l[idx]) }
            }
        }
    domain:
        n : Int = 0
}

fun main() {
    val s1 = DictOfList()
    s1.configure(mapOf("a" to listOf(10, 20), "b" to listOf(30, 40, 50)))
    if (s1.get_at("a", 0) != 10) { println("FAIL pre"); kotlin.system.exitProcess(1) }
    val snap = s1.save_state()
    val s2 = DictOfList()

    s2.restore_state(snap)
    if (s2.get_at("a", 0) != 10) { println("FAIL post a.0 got ${s2.get_at("a", 0)}"); kotlin.system.exitProcess(1) }
    if (s2.get_at("a", 1) != 20) { println("FAIL post a.1"); kotlin.system.exitProcess(1) }
    if (s2.get_at("b", 2) != 50) { println("FAIL post b.2"); kotlin.system.exitProcess(1) }
    println("PASS: 79_dict_of_list_state_arg")
}

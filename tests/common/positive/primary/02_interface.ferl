@@target erlang

@@system WithInterface {
    interface:
        greet(name: str): str
        getCount(): int

    machine:
        $Ready {
            greet(name: str): str {
                self.call_count = self.call_count + 1
                @@:("Hello")
                return
            }

            getCount(): int {
                @@:(self.call_count)
                return
            }
        }

    domain:
        call_count = 0
}

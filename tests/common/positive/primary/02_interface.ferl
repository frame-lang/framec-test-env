@@target erlang

@@system WithInterface {
    interface:
        greet(name: str): str
        getCount(): int

    machine:
        $Ready {
            greet(name: str): str {
                self.call_count = self.call_count + 1
                return "Hello"
            }

            getCount(): int {
                return self.call_count
            }
        }

    domain:
        call_count = 0
}

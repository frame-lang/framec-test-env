@@target typescript

@@[persist]
@@system NestedList {
    interface:
        configure(rows: number[][])
        first_first(): number
        outer_size(): number

    machine:
        $Idle {
            configure(rows: number[][]) { -> $Active(rows) }
            first_first(): number { @@:(-1) }
            outer_size(): number { @@:(0) }
        }
        $Active(rows: number[][]) {
            configure(rows: number[][]) { -> $Active(rows) }
            first_first(): number { @@:(rows[0][0]) }
            outer_size(): number { @@:(rows.length) }
        }
    domain:
        n: number = 0
}

const s1 = new NestedList();
s1.configure([[10, 20], [30, 40]]);
if (s1.first_first() !== 10) { console.log("FAIL pre"); process.exit(1); }
if (s1.outer_size() !== 2) { console.log("FAIL size"); process.exit(1); }
const snap = s1.saveState();
const s2 = NestedList.restoreState(snap);
if (s2.first_first() !== 10) { console.log("FAIL post"); process.exit(1); }
if (s2.outer_size() !== 2) { console.log("FAIL post size"); process.exit(1); }
console.log("PASS: 75_nested_list_state_arg");

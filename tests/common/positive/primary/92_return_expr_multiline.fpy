@@[target("python_3")]

@@system Test {
    interface:
        ready(): bool

    machine:
        $Active {
            ready(): bool {
                @@:(self.timer >= self.threshold
                    and self.count < self.limit)
            }
        }
    domain:
        timer: int = 100
        threshold: int = 50
        count: int = 1
        limit: int = 5
}

if __name__ == "__main__":
    t = @@Test()
    v = t.ready()
    assert v is True, f"FAIL ready(): {v}"
    print("PASS: 92_return_expr_multiline")

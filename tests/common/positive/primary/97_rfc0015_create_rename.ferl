@@[target("erlang")]
@@[create(make)]
@@system Counter(seed: int) {
    interface:
        bump()
        get_value(): int

    machine:
        $A {
            $.count: int = 0
            bump() { $.count = $.count + 1 }
            get_value(): int { @@:($.count) }
        }

    domain:
        seed: int = seed
}

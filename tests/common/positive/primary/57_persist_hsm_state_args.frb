@@[target("ruby")]

require 'json'

@@[persist]
@@system PersistHsmStateArgs {
    operations:
        @@[save]
        save_state(): String {}

        @@[load]
        restore_state(data: String) {}

    interface:
        drive(p: int)
        get_x(): int

    machine:
        $Start {
            drive(p: int) {
                -> $Child(p)
            }
            get_x(): int {
                @@:(-1)
                return
            }
        }

        $Child => $Parent(x: int) {
            drive(p: int) {
                -> $Child(p)
            }
            get_x(): int {
                @@:(x)
                return
            }
        }

        $Parent {
        }
    domain:
        v: int = 0
}

puts("=== Test 57: Persist HSM × State-Args Round-Trip (Ruby) ===")

s1 = PersistHsmStateArgs.new
s1.drive(42)
pre = s1.get_x()
raise "Expected 42 pre-save, got #{pre}" unless pre == 42
puts("1. Pre-save x=#{pre}")

snap = s1.save_state()
s2 = PersistHsmStateArgs.new
s2.restore_state(snap)
post = s2.get_x()
raise "Expected 42 post-restore, got #{post}" unless post == 42
puts("2. Post-restore x=#{post}")

s2.drive(99)
post2 = s2.get_x()
raise "Expected 99 post-drive, got #{post2}" unless post2 == 99
puts("3. Post-restore-drive x=#{post2}")

puts("PASS: 57_persist_hsm_state_args")

@@[target("rust")]

@@[persist]
@@system Counter {
    operations:
        @@[save]
        save_state(): String {}

        @@[load]
        restore_state(data: String) {}

        @@[on_load]
        rebuild_derived() {
            self.doubled = self.n * 2;
            self.was_restored = true;
        }

    interface:
        bump()
        get_n(): i32
        get_doubled(): i32
        was_loaded(): bool

    machine:
        $Active {
            bump() { self.n = self.n + 1; }
            get_n(): i32 { @@:(self.n) }
            get_doubled(): i32 { @@:(self.doubled) }
            was_loaded(): bool { @@:(self.was_restored) }
        }

    domain:
        n: i32 = 0
        doubled: i32 = 0
        was_restored: bool = false
}

fn main() {
    let mut c1 = Counter::new();
    c1.bump(); c1.bump(); c1.bump();
    if c1.was_loaded() { println!("FAIL: was_restored should be false pre-restore"); return; }
    if c1.get_doubled() != 0 { println!("FAIL: doubled should be 0, got {}", c1.get_doubled()); return; }

    let data = c1.save_state();

    let mut c2 = Counter::new();
    c2.restore_state(data);
    if !c2.was_loaded() { println!("FAIL: was_restored should be true after on_load"); return; }
    if c2.get_n() != 3 { println!("FAIL: n should be 3, got {}", c2.get_n()); return; }
    if c2.get_doubled() != 6 { println!("FAIL: doubled should be 6, got {}", c2.get_doubled()); return; }

    println!("PASS: 95_persist_on_load_hook");
}

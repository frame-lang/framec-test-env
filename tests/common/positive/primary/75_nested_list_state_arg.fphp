@@[target("php")]


@@[persist(string)]
@@[save(save_state)]
@@[load(restore_state)]
@@system NestedList {
    interface:
        configure(rows: array)
        first_first(): int
        outer_size(): int

    machine:
        $Idle {
            configure(rows: array) { -> $Active(rows) }
            first_first(): int { @@:(-1) }
            outer_size(): int { @@:(0) }
        }
        $Active(rows: array) {
            configure(rows: array) { -> $Active(rows) }
            first_first(): int { @@:($rows[0][0]) }
            outer_size(): int { @@:(count($rows)) }
        }
    domain:
        n: int = 0
}

$s1 = @@NestedList();
$s1->configure([[10, 20], [30, 40]]);
if ($s1->first_first() !== 10) { echo "FAIL pre\n"; exit(1); }
if ($s1->outer_size() !== 2) { echo "FAIL size\n"; exit(1); }
$snap = $s1->save_state();
$s2 = @@NestedList();

$s2->restore_state($snap);
if ($s2->first_first() !== 10) { echo "FAIL post\n"; exit(1); }
if ($s2->outer_size() !== 2) { echo "FAIL post size\n"; exit(1); }
echo "PASS: 75_nested_list_state_arg\n";

@@[target("ruby")]

@@system PushSelf {
    interface:
        enter_modal()
        ping(): int
        exit_modal()
        compute(): int

    machine:
        $Idle {
            enter_modal() { push$; -> $Modal }
            ping(): int { @@:(0); return }
            compute(): int { @@:(99); return }
        }
        $Modal {
            ping(): int { @@:(self.compute() + 1); return }
            compute(): int { @@:(10); return }
            exit_modal() { -> pop$ }
        }
    domain: n: int = 0
}

s = PushSelf.new
raise "FAIL idle" unless s.ping == 0
s.enter_modal
raise "FAIL modal #{s.ping}" unless s.ping == 11
s.exit_modal
raise "FAIL back" unless s.ping == 0
puts "PASS: 72_push_self_call"

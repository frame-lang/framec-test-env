@@target gdscript
extends SceneTree

# NOTE: Default return value syntax (method(): type = default) not yet implemented.
# This test validates behavior when handler doesn't set @@:return.

@@system SystemReturnDefaultTest {
    interface:
        handler_sets_value(): Variant
        handler_no_return(): Variant
        get_count(): int

    machine:
        $Start {
            $.count: int = 0

            handler_sets_value(): Variant {
                @@:("set_by_handler")
                return
            }

            handler_no_return(): Variant {
                # Does not set return - should return null
                $.count = $.count + 1
            }

            get_count(): int {
                @@:($.count)
                return
            }
        }
}

func main():
    print("=== Test 14: System Return Default Behavior ===")
    var s = @@SystemReturnDefaultTest()

    # Test 1: Handler explicitly sets return value
    var result = s.handler_sets_value()
    assert(result == "set_by_handler", "Expected 'set_by_handler', got '" + str(result) + "'")
    print("1. handler_sets_value() = '" + str(result) + "'")

    # Test 2: Handler does NOT set return - should return None
    result = s.handler_no_return()
    assert(result == null, "Expected None, got '" + str(result) + "'")
    print("2. handler_no_return() = " + str(result))

    # Test 3: Verify handler was called (side effect check)
    var count = s.get_count()
    assert(count == 1, "Expected count=1, got " + str(count))
    print("3. Handler was called, count = " + str(count))

    # Test 4: Call again to verify idempotence
    result = s.handler_no_return()
    assert(result == null, "Expected None again, got '" + str(result) + "'")
    count = s.get_count()
    assert(count == 2, "Expected count=2, got " + str(count))
    print("4. Second call: result=" + str(result) + ", count=" + str(count))

    print("PASS: System return default behavior works correctly")

func _init():
    main()
    quit()

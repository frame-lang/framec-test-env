@@[target("erlang")]
@@[persist]
@@system Counter {
    operations:
        @@[save]
        save_op() {}

        @@[load]
        load_op(data) {}

    interface:
        bump()
        get_n(): int
    machine:
        $Active {
            $.n: int = 0
            bump() { $.n = $.n + 1 }
            get_n(): int { @@:($.n) }
        }
}

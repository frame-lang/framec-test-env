@@[target("ruby")]

@@system Demo {
    interface:
        get_a(): int
        get_rb_only(): int
    machine:
        $S {
            get_a(): int { @@:(self.a) }
            get_rb_only(): int { @@:(self.rb_only) }
        }
    domain:
        a = 1
        @@[target("python_3")] py_only = 2
        @@[target("ruby")]
        rb_only = 42
}

d = Demo.new
abort "FAIL get_a: #{d.get_a}" unless d.get_a == 1
abort "FAIL get_rb_only: #{d.get_rb_only}" unless d.get_rb_only == 42
puts "PASS: 90_attribute_domain_field"

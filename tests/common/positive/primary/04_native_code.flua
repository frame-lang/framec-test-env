@@target lua
@@system NativeCode {
    interface:
        compute(value: int): int
        use_math(): float

    machine:
        $Active {
            compute(value: int): int {
                -- Native code with local variables
                temp = value + 10
                result = helper_function(temp)
                -- print
                @@:(result)
                return
            
            }

            use_math(): float {
                -- Using imported math module
                result = math.sqrt(16) + math.pi
                -- print
                @@:(result)
                return
            
            }
        }
}

@@[target("gdscript")]
extends SceneTree

@@[persist(String)]
@@[save(save_state)]
@@[load(restore_state)]
@@system PersistRoundtrip {
    interface:
        go_active()
        go_idle()
        get_state(): String
        set_counter(n: int)
        get_counter(): int
        add_history(msg: String)

    machine:
        $Idle {
            go_active() {
                self.history.append("idle->active")
                -> $Active
            }

            go_idle() {
                pass  # already idle
            }

            get_state(): String {
                @@:("idle")
                return
            }

            set_counter(n: int) {
                self.counter = n
            }

            get_counter(): int {
                @@:(self.counter)
                return
            }

            add_history(msg: String) {
                self.history.append("idle:" + msg)
            }
        }

        $Active {
            go_active() {
                pass  # already active
            }

            go_idle() {
                self.history.append("active->idle")
                -> $Idle
            }

            get_state(): String {
                @@:("active")
                return
            }

            set_counter(n: int) {
                self.counter = n * 2
            }

            get_counter(): int {
                @@:(self.counter)
                return
            }

            add_history(msg: String) {
                self.history.append("active:" + msg)
            }
        }
    domain:
        counter: int = 0
        history: list = []
        mode: str = "normal"
}

func main():
    print("=== Test 24: Persist Roundtrip (var_to_bytes) ===")

    # Test 1: Create system and build up state
    var s1 = @@PersistRoundtrip()
    s1.set_counter(5)
    s1.add_history("start")
    s1.go_active()
    s1.set_counter(3)  # Should be 6 in Active (doubled)
    s1.add_history("work")

    assert(s1.get_state() == "active", "Expected active, got " + str(s1.get_state()))
    assert(s1.get_counter() == 6, "Expected 6, got " + str(s1.get_counter()))
    print("1. State before save: state=" + str(s1.get_state()) + ", counter=" + str(s1.get_counter()))
    print("   History: " + str(s1.history))

    # Test 2: Save state (returns bytes)
    var data = s1.save_state()
    assert(typeof(data) == TYPE_PACKED_BYTE_ARRAY, "Expected bytes, got " + str(typeof(data)))
    print("2. Saved: " + str(data.size()) + " bytes")

    # Test 3: Restore to new instance
    var s2 = PersistRoundtrip.new()

    s2.restore_state(data)

    # Verify restored state matches
    assert(s2.get_state() == "active", "Expected active, got " + str(s2.get_state()))
    assert(s2.get_counter() == 6, "Expected 6, got " + str(s2.get_counter()))
    print("3. Restored state: state=" + str(s2.get_state()) + ", counter=" + str(s2.get_counter()))

    # Test 4: State machine continues to work after restore
    s2.set_counter(2)  # Should be 4 in Active (doubled)
    assert(s2.get_counter() == 4, "Expected 4, got " + str(s2.get_counter()))
    print("4. Counter after set_counter(2): " + str(s2.get_counter()))

    # Test 5: Verify history was preserved
    assert(s2.history == s1.history, "History mismatch: " + str(s2.history) + " vs " + str(s1.history))
    print("5. History preserved: " + str(s2.history))

    # Test 6: Transitions work after restore
    s2.go_idle()
    assert(s2.get_state() == "idle", "Expected idle after go_idle")
    s2.set_counter(10)  # Not doubled in Idle
    assert(s2.get_counter() == 10, "Expected 10, got " + str(s2.get_counter()))
    print("6. After go_idle: state=" + str(s2.get_state()) + ", counter=" + str(s2.get_counter()))

    print("PASS: Persist roundtrip works correctly")

func _init():
    main()
    quit()

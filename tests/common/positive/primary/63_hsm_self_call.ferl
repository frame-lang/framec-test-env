@@[target("erlang")]
@@system HsmSelfCall {
    interface:
        driveViaChild(): int
        compute(): int
        getTrace(): str
    machine:
        $Child => $Parent {
            driveViaChild(): int {
                self.trace = self.trace ++ "child:before;"
                @@:self.compute()
                self.trace = self.trace ++ "child:after;"
                @@:(self.scratch)
            }
            compute(): int {
                self.trace = self.trace ++ "compute@child;"
                => $^
            }
            getTrace(): str {
                @@:(self.trace)
            }
        }
        $Parent {
            compute(): int {
                self.trace = self.trace ++ "compute@parent;"
                self.scratch = 42
                @@:(42)
            }
        }
    domain:
        trace = ""
        scratch = 0
}

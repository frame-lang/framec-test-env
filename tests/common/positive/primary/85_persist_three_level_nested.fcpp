@@[target("cpp")]

#include <iostream>
#include <string>
#include <sstream>
#include <nlohmann/json.hpp>

@@[persist]
@@system Inner {
    interface:
        cycle()
        get_state(): std::string
        get_count(): int

    machine:
        $A {
            cycle() { this->n = this->n + 1; -> $B }
            get_state(): std::string { @@:("A") }
            get_count(): int { @@:(this->n) }
        }
        $B => $A {
            cycle() { -> $A }
            get_state(): std::string { @@:("B") }
            get_count(): int { => $^ }
        }
    domain:
        n: int = 0
}

@@system Mid {
    interface:
        cycle()
        cycle_inner()
        get_state(): std::string
        get_inner_state(): std::string
        get_inner_count(): int
        get_m(): int

    machine:
        $P {
            cycle() { this->m = this->m + 1; -> $Q }
            cycle_inner() { this->inner->cycle(); }
            get_state(): std::string { @@:("P") }
            get_inner_state(): std::string { @@:(this->inner->get_state()) }
            get_inner_count(): int { @@:(this->inner->get_count()) }
            get_m(): int { @@:(this->m) }
        }
        $Q => $P {
            cycle() { -> $P }
            get_state(): std::string { @@:("Q") }
            cycle_inner() { => $^ }
            get_inner_state(): std::string { => $^ }
            get_inner_count(): int { => $^ }
            get_m(): int { => $^ }
        }
    domain:
        m: int = 0
        inner: Inner = @@Inner()
}

@@[main]
@@system Outer {
    interface:
        tick()
        cycle_mid()
        cycle_inner()
        get_outer_state(): std::string
        get_mid_state(): std::string
        get_inner_state(): std::string
        get_inner_count(): int
        get_m(): int
        get_k(): int

    machine:
        $Idle {
            tick() { this->k = this->k + 1; -> $Active }
            cycle_mid() { this->mid->cycle(); }
            cycle_inner() { this->mid->cycle_inner(); }
            get_outer_state(): std::string { @@:("Idle") }
            get_mid_state(): std::string { @@:(this->mid->get_state()) }
            get_inner_state(): std::string { @@:(this->mid->get_inner_state()) }
            get_inner_count(): int { @@:(this->mid->get_inner_count()) }
            get_m(): int { @@:(this->mid->get_m()) }
            get_k(): int { @@:(this->k) }
        }
        $Active => $Idle {
            tick() { -> $Idle }
            get_outer_state(): std::string { @@:("Active") }
            cycle_mid() { => $^ }
            cycle_inner() { => $^ }
            get_mid_state(): std::string { => $^ }
            get_inner_state(): std::string { => $^ }
            get_inner_count(): int { => $^ }
            get_m(): int { => $^ }
            get_k(): int { => $^ }
        }
    domain:
        k: int = 0
        mid: Mid = @@Mid()
}

std::string fmt(Outer& o) {
    std::ostringstream s;
    s << o.get_outer_state() << "/" << o.get_mid_state() << "/" << o.get_inner_state()
      << "/" << o.get_inner_count() << "/" << o.get_m() << "/" << o.get_k();
    return s.str();
}

void must(const std::string& label, Outer& o, const std::string& expected) {
    std::string actual = fmt(o);
    if (actual != expected) { std::cout << "FAIL " << label << ": " << actual << " expected " << expected << std::endl; std::exit(1); }
}

int main() {
    Outer o;
    must("T0 fresh", o, "Idle/P/A/0/0/0");
    std::string snap0 = o.save_state();
    Outer r0 = Outer::restore_state(snap0);
    must("T0 restored", r0, "Idle/P/A/0/0/0");

    o.tick();
    must("T1", o, "Active/P/A/0/0/1");
    std::string snap1 = o.save_state();
    Outer r1 = Outer::restore_state(snap1);
    must("T1 restored", r1, "Active/P/A/0/0/1");

    o.cycle_mid();
    o.cycle_inner();
    must("T2", o, "Active/Q/B/1/1/1");
    std::string snap2 = o.save_state();
    Outer r2 = Outer::restore_state(snap2);
    must("T2 restored", r2, "Active/Q/B/1/1/1");

    std::string snap2b = r2.save_state();
    Outer r2b = Outer::restore_state(snap2b);
    if (fmt(r2b) != fmt(r2)) { std::cout << "FAIL idempotence: " << fmt(r2b) << " != " << fmt(r2) << std::endl; return 1; }

    r2.cycle_inner();
    must("continue1", r2, "Active/Q/A/1/1/1");
    r2.cycle_mid();
    must("continue2", r2, "Active/P/A/1/1/1");
    r2.tick();
    must("continue3", r2, "Idle/P/A/1/1/1");
    r2.tick();
    must("continue4", r2, "Active/P/A/1/1/2");

    std::cout << "PASS: 85_persist_three_level_nested" << std::endl;
    return 0;
}

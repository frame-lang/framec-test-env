@@target swift

@@system StateVarPushPop {
    interface:
        increment(): number
        get_count(): number
        save_and_go()
        restore()

    machine:
        $Counter {
            $.count: number = 0

            increment(): number {
                $.count = $.count + 1
                return $.count
            }

            get_count(): number {
                return $.count
            }

            save_and_go() {
                `push$
                -> $Other
            }
        }

        $Other {
            $.other_count: number = 100

            restore() {
                `-> pop$
            }

            increment(): number {
                $.other_count = $.other_count + 1
                return $.other_count
            }

            get_count(): number {
                return $.other_count
            }
        }
}

// main
    print("=== Test 12: State Variable Push/Pop ===")
    let s = @@StateVarPushPop()

    // Increment counter to 3
    let _ = s.increment()
    let _ = s.increment()
    let _ = s.increment()
    var count = s.get_count()
    if count != 3 {
        fatalError("Expected 3, got \(count)")
    }
    print("Counter before push: \(count)")

    // Push and go to Other state
    s.save_and_go()
    print("Pushed and transitioned to Other")

    // In Other state, count should be 100 (Other's state var)
    count = s.get_count()
    if count != 100 {
        fatalError("Expected 100 in Other state, got \(count)")
    }
    print("Other state count: \(count)")

    // Increment in Other
    let _ = s.increment()
    count = s.get_count()
    if count != 101 {
        fatalError("Expected 101 after increment, got \(count)")
    }
    print("Other state after increment: \(count)")

    // Pop back - should restore Counter with count=3
    s.restore()
    print("Popped back to Counter")

    count = s.get_count()
    if count != 3 {
        fatalError("Expected 3 after pop (preserved), got \(count)")
    }
    print("Counter after pop: \(count)")

    // Increment to verify it works
    let _ = s.increment()
    count = s.get_count()
    if count != 4 {
        fatalError("Expected 4, got \(count)")
    }
    print("Counter after increment: \(count)")

    print("PASS: State variables preserved across push/pop")

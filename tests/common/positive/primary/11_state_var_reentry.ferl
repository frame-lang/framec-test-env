@@[target("erlang")]
@@system StateVarReentry {
    interface:
        increment(): int
        getCount(): int
        goOther()
        comeBack()
    machine:
        $Counter {
            $.count: int = 0
            increment(): int {
                $.count = $.count + 1
                @@:($.count)
                return
            }
            getCount(): int {
                @@:($.count)
            }
            goOther() { -> $Other }
        }
        $Other {
            comeBack() { -> $Counter }
            increment(): int {
                @@:(-1)
            }
            getCount(): int {
                @@:(-1)
            }
        }
}

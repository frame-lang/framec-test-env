@@target erlang
@@system StateVarReentry {
    interface:
        increment(): int
        getCount(): int
        goOther()
        comeBack()
    machine:
        $Counter {
            $.count: int = 0
            increment(): int {
                $.count = $.count + 1
                return $.count
            }
            getCount(): int { return $.count }
            goOther() { -> $Other }
        }
        $Other {
            comeBack() { -> $Counter }
            increment(): int { return -1 }
            getCount(): int { return -1 }
        }
}

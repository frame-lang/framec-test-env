@@[target("cpp")]

#include <iostream>
#include <map>
#include <cstdlib>
#include <nlohmann/json.hpp>

@@[persist(std::string)]
@@[save(save_state)]
@@[load(restore_state)]
@@system NestedDict {
    interface:
        configure(m: std::map<std::string, std::map<std::string, int>>)
        get_inner(outer_key: std::string, inner_key: std::string): int

    machine:
        $Idle {
            configure(m: std::map<std::string, std::map<std::string, int>>) { -> $Active(m) }
            get_inner(outer_key: std::string, inner_key: std::string): int { @@:(-1) }
        }
        $Active(m: std::map<std::string, std::map<std::string, int>>) {
            configure(m: std::map<std::string, std::map<std::string, int>>) { -> $Active(m) }
            get_inner(outer_key: std::string, inner_key: std::string): int {
                @@:(m.count(outer_key) && m.at(outer_key).count(inner_key) ? m.at(outer_key).at(inner_key) : -1)
            }
        }
    domain:
        n : int = 0
}

int main() {
    auto s1 = @@NestedDict();
    s1.configure(std::map<std::string, std::map<std::string, int>>{
        {"u", {{"x", 1}, {"y", 2}}},
        {"v", {{"z", 3}}}
    });
    if (s1.get_inner("u", "x") != 1) { std::cout << "FAIL pre" << std::endl; return 1; }
    std::string snap = s1.save_state();
    auto s2 = @@NestedDict();

    s2.restore_state(snap);
    if (s2.get_inner("u", "x") != 1) { std::cout << "FAIL post u.x" << std::endl; return 1; }
    if (s2.get_inner("u", "y") != 2) { std::cout << "FAIL post u.y" << std::endl; return 1; }
    if (s2.get_inner("v", "z") != 3) { std::cout << "FAIL post v.z" << std::endl; return 1; }
    std::cout << "PASS: 78_nested_dict_state_arg" << std::endl;
    return 0;
}

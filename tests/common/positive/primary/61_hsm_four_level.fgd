@@[target("gdscript")]
extends SceneTree

@@system HsmFourLevel {
    interface:
        drive(): int
        write_at_level(level: int)
        get_n(): int

    machine:
        $Leaf => $Mid {
            drive(): int {
                => $^
            }
            write_at_level(level: int) {
                self.n = self.n + level * 1
                => $^
            }
            get_n(): int {
                @@:(self.n)
            }
        }

        $Mid => $Branch {
            drive(): int {
                => $^
            }
            write_at_level(level: int) {
                self.n = self.n + level * 10
                => $^
            }
        }

        $Branch => $Root {
            drive(): int {
                => $^
            }
            write_at_level(level: int) {
                self.n = self.n + level * 100
                => $^
            }
        }

        $Root {
            drive(): int {
                @@:(self.n)
            }
            write_at_level(level: int) {
                self.n = self.n + level * 1000
            }
        }
    domain:
        n: int = 0
}

func _initialize():
    print("=== Test 61: 4-level HSM cascade (GDScript) ===")
    var s = HsmFourLevel.new()

    var initial = s.drive()
    if initial != 0:
        print("FAIL: initial " + str(initial))
        quit(1)
        return
    print("1. Initial drive returned " + str(initial))

    s.write_at_level(2)
    var after = s.get_n()
    if after != 2222:
        print("FAIL: after " + str(after))
        quit(1)
        return
    print("2. After cascading write: n=" + str(after))

    var finalVal = s.drive()
    if finalVal != 2222:
        print("FAIL: final " + str(finalVal))
        quit(1)
        return
    print("3. Drive after write returned " + str(finalVal))

    print("PASS: 61_hsm_four_level")
    quit(0)

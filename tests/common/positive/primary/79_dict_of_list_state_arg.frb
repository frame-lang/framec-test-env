@@[target("ruby")]

@@[persist]
@@system DictOfList {
    operations:
        @@[save]
        save_state(): String {}

        @@[load]
        restore_state(data: String) {}

    interface:
        configure(m: Hash)
        get_at(key: String, idx: int): int

    machine:
        $Idle {
            configure(m: Hash) { -> $Active(m) }
            get_at(key: String, idx: int): int { @@:(-1) }
        }
        $Active(m: Hash) {
            configure(m: Hash) { -> $Active(m) }
            get_at(key: String, idx: int): int {
                @@:(m.fetch(key, [])[idx] || -1)
            }
        }
    domain:
        n: int = 0
}

s1 = DictOfList.new
s1.configure({"a" => [10, 20], "b" => [30, 40, 50]})
abort("FAIL pre a.0") unless s1.get_at("a", 0) == 10
abort("FAIL pre b.2") unless s1.get_at("b", 2) == 50
snap = s1.save_state
s2 = DictOfList.new
s2.restore_state(snap)
abort("FAIL post a.0") unless s2.get_at("a", 0) == 10
abort("FAIL post a.1") unless s2.get_at("a", 1) == 20
abort("FAIL post b.2") unless s2.get_at("b", 2) == 50
puts "PASS: 79_dict_of_list_state_arg"

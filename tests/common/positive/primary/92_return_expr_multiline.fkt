@@[target("kotlin")]

@@system Test {
    interface:
        ready(): Boolean

    machine:
        $Active {
            ready(): Boolean {
                @@:(this.timer >= this.threshold
                    && this.count < this.limit)
            }
        }
    domain:
        timer: Int = 100
        threshold: Int = 50
        count: Int = 1
        limit: Int = 5
}

fun main() {
    val t = Test()
    if (t.ready() != true) {
        println("FAIL ready(): ${t.ready()}")
    } else {
        println("PASS: 92_return_expr_multiline")
    }
}

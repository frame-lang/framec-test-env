@@[target("lua")]
@@[persist]
@@system PersistTest {
    interface:
        set_value(v: int)
        get_value(): int
        go_active()
        go_idle()

    machine:
        $Idle {
            set_value(v: int) {
                self.value = v
            }

            get_value(): int {
                @@:(self.value)
                return
            }

            go_active() {
                -> $Active
            }

            go_idle() {
                -- empty -- Already idle
            
            }
        }

        $Active {
            set_value(v: int) {
                self.value = v * 2
            }

            get_value(): int {
                @@:(self.value)
                return
            }

            go_active() {
                -- empty -- Already active
            
            }

            go_idle() {
                -> $Idle
            }
        }
    domain:
        value: int = 0
        name: str = "default"
}

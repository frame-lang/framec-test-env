@@target dart
@@system WithTransition {
    interface:
        next()
        get_state(): String

    machine:
        $First {
            next() {
                print("Transitioning: First -> Second");
                -> $Second
            }

            get_state(): String {
                @@:("First")
                return;
            }
        }

        $Second {
            next() {
                print("Transitioning: Second -> First");
                -> $First
            }

            get_state(): String {
                @@:("Second")
                return;
            }
        }
}

void main() {
    print("== Test 03: State Transitions ==");
    final s = @@WithTransition();

    // Initial state should be First
    var state = s.get_state();
    if (state != "First") {
        throw Exception("Expected 'First', got '${state}'");
    }
    print("Initial state: ${state}");

    // Transition to Second
    s.next();
    state = s.get_state();
    if (state != "Second") {
        throw Exception("Expected 'Second', got '${state}'");
    }
    print("After first next(): ${state}");

    // Transition back to First
    s.next();
    state = s.get_state();
    if (state != "First") {
        throw Exception("Expected 'First', got '${state}'");
    }
    print("After second next(): ${state}");

    print("PASS: State transitions work correctly");
}


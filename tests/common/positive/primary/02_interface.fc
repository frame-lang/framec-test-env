@@[target("c")]

@@system WithInterface {
    interface:
        greet(name: char*): char*
        get_count(): int

    machine:
        $Ready {
            greet(name: char*): char* {
                self->call_count += 1;
                static char buffer[256];
                sprintf(buffer, "Hello, %s!", name);
                @@:(buffer)
                return;
            }

            get_count(): int {
                @@:(self->call_count)
                return;
            }
        }
    domain:
        call_count : int
}

int main() {
    printf("=== Test 02: Interface Methods ===\n");
    WithInterface* s = @@WithInterface();
    int error_count = 0;

    // Test interface method with parameter and return
    char* result = WithInterface_greet(s, "World");
    if (strcmp(result, "Hello, World!") != 0) {
        printf("FAIL: Expected 'Hello, World!', got '%s'\n", result);
        error_count++;
    } else {
        printf("greet('World') = %s\n", result);
    }

    // Test domain variable access through interface
    int count = WithInterface_get_count(s);
    if (count != 1) {
        printf("FAIL: Expected count=1, got %d\n", count);
        error_count++;
    } else {
        printf("get_count() = %d\n", count);
    }

    // Call again to verify state
    WithInterface_greet(s, "Frame");
    int count2 = WithInterface_get_count(s);
    if (count2 != 2) {
        printf("FAIL: Expected count=2, got %d\n", count2);
        error_count++;
    } else {
        printf("After second call: get_count() = %d\n", count2);
    }

    WithInterface_destroy(s);
    if (error_count > 0) {
        printf("FAIL: %d test(s) failed\n", error_count);
        return 1;
    } else {
        printf("PASS: Interface methods work correctly\n");
        return 0;
    }
}

@@[target("csharp")]

@@system Sub {
    interface:
        Ping(): int
    machine:
        $Idle {
            Ping(): int { @@:(42) }
        }
}

@@[main]
@@system Top {
    interface:
        Run(): int
    machine:
        $Active {
            Run(): int { @@:(this.sub.Ping()) }
        }
    domain:
        sub: Sub = @@Sub()
}

class Program {
    static void Main() {
        Top t = new Top();
        if (t.Run() != 42) {
            System.Console.WriteLine($"FAIL Run(): {t.Run()}");
        } else {
            System.Console.WriteLine("PASS: 91_main_attr_cross_ref");
        }
    }
}

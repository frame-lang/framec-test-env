@@[target("typescript")]

@@system Demo {
    interface:
        common(): string
        @@[target("python_3")] only_py(): string
        @@[target("typescript")] only_ts(): string

    machine:
        $S {
            common(): string { @@:("common") }
            @@[target("python_3")] only_py(): string { @@:("only_py_present") }
            @@[target("typescript")] only_ts(): string { @@:("only_ts_present") }
        }
}

const d = new Demo();
const dAny: any = d;
if (d.common() !== "common") { console.log("FAIL common: " + d.common()); process.exit(1); }
if (dAny.only_ts() !== "only_ts_present") { console.log("FAIL only_ts: " + dAny.only_ts()); process.exit(1); }
if (typeof dAny.only_py === "function") {
    console.log("FAIL: only_py should have been filtered out by @@[target(\"python_3\")]");
    process.exit(1);
}
console.log("PASS: 89_attribute_per_item");

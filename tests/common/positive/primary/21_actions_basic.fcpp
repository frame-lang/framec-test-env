@@target cpp_17

#include <iostream>
#include <string>
#include <cassert>

@@system ActionTest {
    interface:
        do_work(): int

    machine:
        $Start {
            do_work(): int {
                ActionTest_log_action(self, "Starting work");
                return self->action_count;
            }
        }

    actions:
        log_action(msg: std::string) {
            std::cout << "Action: " << msg << std::endl;
            self->action_count = self->action_count + 1;
        }

    domain:
        int action_count
}

int main() {
    std::cout << "=== Test 21: Basic Actions ===" << std::endl;
    ActionTest a;

    int count = a.do_work();
    std::cout << "Action count: " << count << std::endl;
    assert(count == 1);

    count = a.do_work();
    std::cout << "Action count: " << count << std::endl;
    assert(count == 2);

    std::cout << "PASS: Basic actions work correctly" << std::endl;
    return 0;
}

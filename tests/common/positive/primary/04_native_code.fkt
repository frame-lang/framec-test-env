@@target kotlin

import kotlin.system.exitProcess
import kotlin.math.sqrt
import kotlin.math.PI
import kotlin.math.abs

object Helper {
    fun helper_function(x: Int): Int {
        // Native helper function defined before system
        return x * 2
    }
}

@@system NativeCode {
    interface:
        compute(value: Int): Int
        use_math(): Double

    machine:
        $Active {
            compute(value: Int): Int {
                // Native code with local variables
                val temp = value + 10
                val result = Helper.helper_function(temp)
                println("Computed: " + value + " -> " + result)
                @@:(result)
                return;
            }

            use_math(): Double {
                // Using Math module
                val result = sqrt(16.0) + PI
                println("Math result: " + result)
                @@:(result)
                return;
            }
        }
}

fun main() {
    println("=== Test 04: Native Code Preservation ===")
    val s = NativeCode()

    // Test native code in handler with helper function
    val result = s.compute(5) as Int
    val expected = (5 + 10) * 2  // 30
    if (result != expected) {
        throw RuntimeException("Expected $expected, got $result")
    }
    println("compute(5) = $result")

    // Test Math module usage
    val mathResult = s.use_math() as Double
    val expectedMath = sqrt(16.0) + PI
    if (abs(mathResult - expectedMath) >= 0.001) {
        throw RuntimeException("Expected ~$expectedMath, got $mathResult")
    }
    println("use_math() = $mathResult")

    println("PASS: Native code preservation works correctly")
}

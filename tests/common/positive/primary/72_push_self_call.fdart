@@[target("dart")]

import 'dart:io';

@@system PushSelf {
    interface:
        enter_modal()
        ping(): int
        exit_modal()
        compute(): int

    machine:
        $Idle {
            enter_modal() { push$; -> $Modal }
            ping(): int { @@:(0); return; }
            compute(): int { @@:(99); return; }
        }
        $Modal {
            ping(): int { @@:(this.compute() + 1); return; }
            compute(): int { @@:(10); return; }
            exit_modal() { -> pop$ }
        }
    domain: n: int = 0
}

void main() {
    final s = PushSelf();
    if (s.ping() != 0) { print("FAIL idle"); exit(1); }
    s.enter_modal();
    if (s.ping() != 11) { print("FAIL modal ${s.ping()}"); exit(1); }
    s.exit_modal();
    if (s.ping() != 0) { print("FAIL back"); exit(1); }
    print("PASS: 72_push_self_call");
}

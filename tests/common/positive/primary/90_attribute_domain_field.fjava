@@[target("java")]

@@system Demo {
    interface:
        get_a(): int
        get_java_only(): int
    machine:
        $S {
            get_a(): int { @@:(this.a) }
            get_java_only(): int { @@:(this.java_only) }
        }
    domain:
        a: int = 1
        @@[target("python_3")] py_only: int = 2
        @@[target("java")]
        java_only: int = 42
}

class Main {
    public static void main(String[] args) {
        Demo d = @@Demo();
        if (d.get_a() != 1) { System.out.println("FAIL get_a: " + d.get_a()); System.exit(1); }
        if (d.get_java_only() != 42) { System.out.println("FAIL get_java_only: " + d.get_java_only()); System.exit(1); }
        System.out.println("PASS: 90_attribute_domain_field");
    }
}

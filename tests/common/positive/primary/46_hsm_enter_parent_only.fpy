@@target python_3

# Test 46: HSM Enter in Parent Only
#
# Tests enter handler in parent only:
# - Parent has $>(), child does not
# - Child enters without error (no enter handler)
# - Parent's enter does NOT auto-fire when child is entered
# - Parent enter only fires when transitioning directly TO parent

@@system HSMEnterParentOnly {
    interface:
        go_to_child()
        go_to_parent()
        get_log(): list
        get_state(): str

    machine:
        $Start {
            go_to_child() {
                -> $Child
            }

            go_to_parent() {
                -> $Parent
            }

            get_log(): list {
                return self.log
            }

            get_state(): str {
                return "Start"
            }
        }

        $Child => $Parent {
            go_to_parent() {
                -> $Parent
            }

            get_log(): list {
                return self.log
            }

            get_state(): str {
                return "Child"
            }
        }

        $Parent {
            $>() {
                self.log.append("Parent:enter")
            }

            go_to_child() {
                -> $Child
            }

            get_log(): list {
                return self.log
            }

            get_state(): str {
                return "Parent"
            }
        }
    domain:
        log: list = []
}

def main():
    print("=== Test 46: HSM Enter in Parent Only ===")
    s = @@HSMEnterParentOnly()

    # TC2.2.1: Child enters without error (no enter handler)
    s.go_to_child()
    assert s.get_state() == "Child", f"Expected Child, got {s.get_state()}"
    log = s.get_log()
    print(f"TC2.2.1: Child enters without error (log: {log}) - PASS")

    # TC2.2.2: Parent's enter does NOT auto-fire when child is entered
    assert "Parent:enter" not in log, f"Parent:enter should NOT fire for child entry, got {log}"
    print(f"TC2.2.2: Parent enter NOT auto-fired for child - PASS")

    # TC2.2.3: Parent enter only fires when transitioning directly TO parent
    s.go_to_parent()
    assert s.get_state() == "Parent", f"Expected Parent, got {s.get_state()}"
    log = s.get_log()
    assert "Parent:enter" in log, f"Expected Parent:enter when transitioning to Parent, got {log}"
    print(f"TC2.2.3: Parent enter fires when transitioning to Parent - PASS")

    # TC2.2.4: Going back to child from parent
    s.go_to_child()
    assert s.get_state() == "Child", f"Expected Child, got {s.get_state()}"
    log = s.get_log()
    # Parent enter should have fired only once (when we went to Parent)
    assert log.count("Parent:enter") == 1, f"Expected exactly 1 Parent:enter, got {log}"
    print(f"TC2.2.4: Return to child, parent enter count unchanged - PASS")

    print("PASS: HSM enter in parent only works correctly")

if __name__ == '__main__':
    main()

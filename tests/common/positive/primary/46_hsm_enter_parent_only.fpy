@@target python_3

# Test 46: HSM Enter Cascade — Parent has $>, Child does not
#
# Tests the HSM enter cascade per docs/frame_runtime.md Step 21+.
# When entering an HSM child, the kernel fires $> on every layer
# of the new chain top-down (parent first, child last).
#
# In this system, only Parent declares $>, so entering Child fires
# Parent's $> exactly once via the cascade.

@@system HSMEnterParentOnly {
    interface:
        go_to_child()
        go_to_parent()
        get_log(): list
        get_state(): str

    machine:
        $Start {
            go_to_child() {
                -> $Child
            }

            go_to_parent() {
                -> $Parent
            }

            get_log(): list {
                @@:(self.log)
                return
            }

            get_state(): str {
                @@:("Start")
                return
            }
        }

        $Child => $Parent {
            go_to_parent() {
                -> $Parent
            }

            get_log(): list {
                @@:(self.log)
                return
            }

            get_state(): str {
                @@:("Child")
                return
            }
        }

        $Parent {
            $>() {
                self.log.append("Parent:enter")
            }

            go_to_child() {
                -> $Child
            }

            get_log(): list {
                @@:(self.log)
                return
            }

            get_state(): str {
                @@:("Parent")
                return
            }
        }
    domain:
        log: list = []
}

def main():
    print("=== Test 46: HSM Enter Cascade — Parent only ===")
    s = @@HSMEnterParentOnly()

    # TC1: Entering Child fires Parent's $> via cascade.
    s.go_to_child()
    assert s.get_state() == "Child", f"Expected Child, got {s.get_state()}"
    log = s.get_log()
    assert "Parent:enter" in log, f"Expected Parent:enter on cascade entry to Child, got {log}"
    print("TC1: Parent's $> fires on Child entry via cascade - PASS")

    # TC2: Transitioning from Child directly to Parent fires Parent's $>
    # again (Child's chain exits, then Parent's enter cascade fires Parent.$>).
    s.go_to_parent()
    assert s.get_state() == "Parent", f"Expected Parent, got {s.get_state()}"
    log = s.get_log()
    count = log.count("Parent:enter")
    assert count == 2, f"Expected 2 Parent:enter (one cascade + one direct), got {count}: {log}"
    print("TC2: Parent's $> fires on direct entry to Parent - PASS")

    # TC3: Transitioning back to Child fires Parent's $> again via cascade.
    s.go_to_child()
    assert s.get_state() == "Child", f"Expected Child, got {s.get_state()}"
    log = s.get_log()
    count = log.count("Parent:enter")
    assert count == 3, f"Expected 3 Parent:enter total, got {count}: {log}"
    print("TC3: Parent's $> fires again on cascade back to Child - PASS")

    print("PASS: HSM enter cascade fires ancestor $> correctly")

if __name__ == '__main__':
    main()

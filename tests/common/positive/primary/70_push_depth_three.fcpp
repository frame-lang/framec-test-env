@@target cpp_17

#include <iostream>

@@system PushDeep {
    interface:
        descend()
        ascend()
        get_depth(): int

    machine:
        $Idle {
            descend() {
                push$
                -> $Modal1
            }
            get_depth(): int {
                @@:(0)
            }
        }

        $Modal1 {
            descend() {
                push$
                -> $Modal2
            }
            ascend() {
                -> pop$
            }
            get_depth(): int {
                @@:(1)
            }
        }

        $Modal2 {
            descend() {
                push$
                -> $Modal3
            }
            ascend() {
                -> pop$
            }
            get_depth(): int {
                @@:(2)
            }
        }

        $Modal3 {
            ascend() {
                -> pop$
            }
            get_depth(): int {
                @@:(3)
            }
        }
    domain:
        n : int = 0
}

int main() {
    PushDeep s;
    if (s.get_depth() != 0) { std::cout << "FAIL idle" << std::endl; return 1; }
    s.descend();
    if (s.get_depth() != 1) { std::cout << "FAIL d1" << std::endl; return 1; }
    s.descend();
    if (s.get_depth() != 2) { std::cout << "FAIL d2" << std::endl; return 1; }
    s.descend();
    if (s.get_depth() != 3) { std::cout << "FAIL d3" << std::endl; return 1; }
    s.ascend();
    if (s.get_depth() != 2) { std::cout << "FAIL a1" << std::endl; return 1; }
    s.ascend();
    if (s.get_depth() != 1) { std::cout << "FAIL a2" << std::endl; return 1; }
    s.ascend();
    if (s.get_depth() != 0) { std::cout << "FAIL a3" << std::endl; return 1; }
    std::cout << "PASS: 70_push_depth_three" << std::endl;
    return 0;
}

@@target dart

import 'dart:io';
import 'dart:convert';

@@[persist]
@@system PersistDict {
    interface:
        configure(m: Map<String, int>)
        get_v(key: String): int

    machine:
        $Idle {
            configure(m: Map<String, int>) { -> $Active(m) }
            get_v(key: String): int { @@:(-1) }
        }
        $Active(m: Map<String, int>) {
            configure(m: Map<String, int>) { -> $Active(m) }
            get_v(key: String): int { @@:(m[key] ?? -1) }
        }
    domain:
        n: int = 0
}

void main() {
    var s1 = PersistDict();
    s1.configure({"a": 10, "b": 20});
    if (s1.get_v("a") != 10) { print("FAIL pre"); return; }
    var snap = s1.saveState();
    var s2 = PersistDict.restoreState(snap);
    if (s2.get_v("a") != 10) { print("FAIL post a"); return; }
    if (s2.get_v("b") != 20) { print("FAIL post b"); return; }
    print("PASS: 77_persist_dict_state_arg");
}

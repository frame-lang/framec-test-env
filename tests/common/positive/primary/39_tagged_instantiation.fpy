@@target python_3

# Test 39: Tagged System Instantiation
# Validates the @@System() syntax for tracked instantiation

@@system Calculator {
    interface:
        add(a: int, b: int): int
        get_result(): int

    machine:
        $Ready {
            add(a: int, b: int): int {
                self.result = a + b
                return self.result
            }

            get_result(): int {
                return self.result
            }
        }
    domain:
        result: int = 0
}

@@system Counter {
    interface:
        increment()
        get_count(): int

    machine:
        $Active {
            increment() {
                self.count = self.count + 1
            }

            get_count(): int {
                return self.count
            }
        }
    domain:
        count: int = 0
}

def main():
    print("=== Test 39: Tagged System Instantiation ===")

    # Tagged instantiation - validated at transpile time
    calc = @@Calculator()
    counter = @@Counter()

    # Test Calculator
    result = calc.add(3, 4)
    assert result == 7, f"Expected 7, got {result}"
    print(f"Calculator.add(3, 4) = {result}")

    result = calc.get_result()
    assert result == 7, f"Expected 7, got {result}"
    print(f"Calculator.get_result() = {result}")

    # Test Counter
    counter.increment()
    counter.increment()
    counter.increment()
    count = counter.get_count()
    assert count == 3, f"Expected 3, got {count}"
    print(f"Counter after 3 increments: {count}")

    print("PASS: Tagged instantiation works correctly")

if __name__ == '__main__':
    main()

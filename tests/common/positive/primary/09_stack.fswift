@@[target("swift")]

@@system StackOps {
    interface:
        push_and_go()
        pop_back()
        do_work(): string
        get_state(): string

    machine:
        $Main {
            push_and_go() {
                print("Pushing Main to stack, going to Sub")
                push$
                -> $Sub
            }

            pop_back() {
                print("Cannot pop - nothing on stack in Main")
            }

            do_work(): string {
                @@:("Working in Main")
                return;
            }

            get_state(): string {
                @@:("Main")
                return;
            }
        }

        $Sub {
            push_and_go() {
                print("Already in Sub")
            }

            pop_back() {
                print("Popping back to previous state")
                -> pop$
            }

            do_work(): string {
                @@:("Working in Sub")
                return;
            }

            get_state(): string {
                @@:("Sub")
                return;
            }
        }
}

// main
    print("=== Test 09: Stack Push/Pop ===")
    let s = @@StackOps()

    // Initial state should be Main
    var state = s.get_state()
    if state != "Main" {
        fatalError("Expected 'Main', got '\(state)'")
    }
    print("Initial state: \(state)")

    // Do work in Main
    var work = s.do_work()
    if work != "Working in Main" {
        fatalError("Expected 'Working in Main', got '\(work)'")
    }
    print("do_work(): \(work)")

    // Push and go to Sub
    s.push_and_go()
    state = s.get_state()
    if state != "Sub" {
        fatalError("Expected 'Sub', got '\(state)'")
    }
    print("After push_and_go(): \(state)")

    // Do work in Sub
    work = s.do_work()
    if work != "Working in Sub" {
        fatalError("Expected 'Working in Sub', got '\(work)'")
    }
    print("do_work(): \(work)")

    // Pop back to Main
    s.pop_back()
    state = s.get_state()
    if state != "Main" {
        fatalError("Expected 'Main' after pop, got '\(state)'")
    }
    print("After pop_back(): \(state)")

    print("PASS: Stack push/pop works correctly")

@@[target("kotlin")]

// Test 100: @@[no_persist] domain fields (RFC-0016.1)

@@[persist(String)]
@@[save(saveOp)]
@@[load(loadOp)]
@@system NoPersistField {
    interface:
        bump()
        putCache(v: Int)
        putNote(s: String)
        readN(): Int
        readCache(): Int
        readNote(): String

    machine:
        $Active {
            bump() { this.n = this.n + 1 }
            putCache(v: Int) { this.cache = v }
            putNote(s: String) { this.note = s }
            readN(): Int { @@:(this.n) }
            readCache(): Int { @@:(this.cache) }
            readNote(): String { @@:(this.note) }
        }

    domain:
        n: Int = 0
        @@[no_persist]
        cache: Int = -1
        note: String = "fresh"
}

fun main() {
    val c1 = @@NoPersistField()
    c1.bump()
    c1.bump()
    c1.bump()
    c1.putCache(99)
    c1.putNote("hello")
    val data = c1.saveOp()

    val c2 = @@NoPersistField()
    c2.loadOp(data)

    if (c2.readN() != 3) {
        println("FAIL: expected n=3, got ${c2.readN()}")
        return
    }
    if (c2.readNote() != "hello") {
        println("FAIL: expected note=hello, got ${c2.readNote()}")
        return
    }
    if (c2.readCache() != -1) {
        println("FAIL: expected cache=-1 (domain default; @@[no_persist] field not restored), got ${c2.readCache()}")
        return
    }
    println("PASS: 100_no_persist_field")
}

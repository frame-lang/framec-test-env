@@[target("php")]

@@system HsmIfStateArgs {
    interface:
        enter_active(t: int)
        classify(v: int): int

    machine:
        $Idle {
            enter_active(t: int) {
                -> $Active($t)
            }
            classify(v: int): int {
                @@:(-1)
                return;
            }
        }

        $Active => $Frame(threshold: int) {
            enter_active(t: int) {
                -> $Active($t)
            }
            classify(v: int): int {
                if ($v > $threshold) {
                    @@:(1)
                    return;
                } else {
                    @@:(0)
                    return;
                }
            }
        }

        $Frame {
        }
    domain:
        n: int = 0
}

echo "=== Test 62: HSM × if × state-args (PHP) ===\n";
$s = @@HsmIfStateArgs();

$pre = $s->classify(5);
if ($pre !== -1) { echo "FAIL: pre $pre\n"; exit(1); }
echo "1. Idle classify(5) = $pre\n";

$s->enter_active(10);
$under = $s->classify(5);
if ($under !== 0) { echo "FAIL: under $under\n"; exit(1); }
echo "2. classify(5) with threshold=10 → $under\n";

$over = $s->classify(15);
if ($over !== 1) { echo "FAIL: over $over\n"; exit(1); }
echo "3. classify(15) with threshold=10 → $over\n";

$eq = $s->classify(10);
if ($eq !== 0) { echo "FAIL: eq $eq\n"; exit(1); }
echo "4. classify(10) with threshold=10 → $eq\n";

$s->enter_active(50);
$newUnder = $s->classify(15);
if ($newUnder !== 0) { echo "FAIL: newUnder $newUnder\n"; exit(1); }
echo "5. classify(15) with threshold=50 → $newUnder\n";

echo "PASS: 62_hsm_if_state_args\n";

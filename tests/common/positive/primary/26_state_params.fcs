@@target csharp

using System;
using System.Collections.Generic;

@@system StateParams {
    interface:
        start(val: int)
        get_value(): int

    machine:
        $Idle {
            start(val: int) {
                -> $Counter(val)
            }

            get_value(): int {
                @@:(0)
                return;
            }
        }

        $Counter(initial: int) {
            $>() {
                // Access state param via compartment - positional index
                $.count = (int) this.__compartment.state_args[0];
                int count_val = $.count;
                Console.WriteLine("Counter entered with initial=" + count_val);
            }

            $.count: int = 0

            get_value(): int {
                @@:($.count)
                return;
            }
        }
}

class Program {
    static void Main(string[] args) {
        Console.WriteLine("=== Test 26: State Parameters ===");
        var s = @@StateParams();

        var val = (int)s.get_value();
        if (val != 0) {
            Console.WriteLine("FAIL: Expected 0 in Idle, got " + val);
            Environment.Exit(1);
        }
        Console.WriteLine("Initial value: " + val);

        s.start(42);
        val = (int)s.get_value();
        if (val != 42) {
            Console.WriteLine("FAIL: Expected 42 in Counter from state param, got " + val);
            Environment.Exit(1);
        }
        Console.WriteLine("Value after transition: " + val);

        Console.WriteLine("PASS: State parameters work correctly");
    }
}

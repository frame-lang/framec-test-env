@@[target("rust")]

@@system Sub {
    interface:
        ping(): i32
    machine:
        $Idle {
            ping(): i32 { @@:(42) }
        }
}

@@[main]
@@system Top {
    interface:
        run(): i32
    machine:
        $Active {
            run(): i32 { @@:(self.sub.ping()) }
        }
    domain:
        sub: Sub = @@Sub()
}

fn main() {
    let mut t = Top::new();
    if t.run() != 42 {
        println!("FAIL run(): {}", t.run());
    } else {
        println!("PASS: 91_main_attr_cross_ref");
    }
}

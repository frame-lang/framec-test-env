<?php
@@target php

@@system PushDeep {
    interface:
        descend()
        ascend()
        get_depth(): int

    machine:
        $Idle {
            descend() {
                push$
                -> $Modal1
            }
            get_depth(): int {
                @@:(0)
                return;
            }
        }

        $Modal1 {
            descend() {
                push$
                -> $Modal2
            }
            ascend() {
                -> pop$
            }
            get_depth(): int {
                @@:(1)
                return;
            }
        }

        $Modal2 {
            descend() {
                push$
                -> $Modal3
            }
            ascend() {
                -> pop$
            }
            get_depth(): int {
                @@:(2)
                return;
            }
        }

        $Modal3 {
            ascend() {
                -> pop$
            }
            get_depth(): int {
                @@:(3)
                return;
            }
        }
    domain:
        n: int = 0
}

$s = new PushDeep();
if ($s->get_depth() !== 0) { echo "FAIL idle\n"; exit(1); }
$s->descend();
if ($s->get_depth() !== 1) { echo "FAIL d1\n"; exit(1); }
$s->descend();
if ($s->get_depth() !== 2) { echo "FAIL d2\n"; exit(1); }
$s->descend();
if ($s->get_depth() !== 3) { echo "FAIL d3\n"; exit(1); }
$s->ascend();
if ($s->get_depth() !== 2) { echo "FAIL a1\n"; exit(1); }
$s->ascend();
if ($s->get_depth() !== 1) { echo "FAIL a2\n"; exit(1); }
$s->ascend();
if ($s->get_depth() !== 0) { echo "FAIL a3\n"; exit(1); }
echo "PASS: 70_push_depth_three\n";

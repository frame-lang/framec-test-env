@@[target("lua")]

@@system StrStateArg {
    interface:
        configure(label: str)
        identify(): str

    machine:
        $Idle {
            configure(label: str) {
                -> $Active(label)
            }
            identify(): str {
                @@:("anonymous")
                return
            }
        }

        $Active => $Frame(label: str) {
            configure(label: str) {
                -> $Active(label)
            }
            identify(): str {
                => $^
            }
        }

        $Frame {
            identify(): str {
                @@:(label)
                return
            }
        }
    domain:
        n: int = 0
}

local s = @@StrStateArg()
if s:identify() ~= "anonymous" then error("FAIL idle: " .. tostring(s:identify())) end
s:configure("alice")
if s:identify() ~= "alice" then error("FAIL alice: " .. tostring(s:identify())) end
s:configure("bob")
if s:identify() ~= "bob" then error("FAIL bob: " .. tostring(s:identify())) end
print("PASS: 66_hsm_str_state_args")

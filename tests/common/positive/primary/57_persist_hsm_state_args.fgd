@@[target("gdscript")]
extends SceneTree

@@[persist]
@@system PersistHsmStateArgs {
    operations:
        @@[save]
        save_state(): String {}

        @@[load]
        restore_state(data: String) {}

    interface:
        drive(p: int)
        get_x(): int

    machine:
        $Start {
            drive(p: int) {
                -> $Child(p)
            }
            get_x(): int {
                @@:(-1)
            }
        }

        $Child => $Parent(x: int) {
            drive(p: int) {
                -> $Child(p)
            }
            get_x(): int {
                @@:(x)
            }
        }

        $Parent {
        }
    domain:
        v: int = 0
}

func _initialize():
    print("=== Test 57: Persist HSM × State-Args Round-Trip (GDScript) ===")
    var s1 = PersistHsmStateArgs.new()
    s1.drive(42)
    var pre = s1.get_x()
    if pre != 42:
        print("FAIL: pre " + str(pre))
        quit(1)
        return
    print("1. Pre-save x=" + str(pre))

    var snap = s1.save_state()
    var s2 = PersistHsmStateArgs.new()

    s2.restore_state(snap)
    var post = s2.get_x()
    if post != 42:
        print("FAIL: post " + str(post))
        quit(1)
        return
    print("2. Post-restore x=" + str(post))

    s2.drive(99)
    var post2 = s2.get_x()
    if post2 != 99:
        print("FAIL: post2 " + str(post2))
        quit(1)
        return
    print("3. Post-restore-drive x=" + str(post2))

    print("PASS: 57_persist_hsm_state_args")
    quit(0)

@@[target("dart")]
import 'dart:convert';
// Test 43: HSM Multiple Children of Same Parent
//
// Tests multiple states sharing the same parent:
// - $ChildA => $Parent
// - $ChildB => $Parent
// - $ChildC => $Parent
// Each child can forward to the shared parent

@@system HSMMultiChildren {
    interface:
        start_a()
        start_b()
        start_c()
        do_action()
        forward_action()
        get_log(): List<String>
        get_state(): str

    machine:
        $ChildA => $Parent {
            start_a() {
                // stay
            }

            start_b() {
                -> $ChildB
            }

            start_c() {
                -> $ChildC
            }

            do_action() {
                this.log.add("ChildA:do_action");
            }

            forward_action() {
                this.log.add("ChildA:forward_action");
                => $^
            }

            get_log(): list {
                @@:(this.log)
                return;
            }

            get_state(): str {
                @@:("ChildA")
                return;
            }
        }

        $ChildB => $Parent {
            start_a() {
                -> $ChildA
            }

            start_b() {
                // stay
            }

            start_c() {
                -> $ChildC
            }

            do_action() {
                this.log.add("ChildB:do_action");
            }

            forward_action() {
                this.log.add("ChildB:forward_action");
                => $^
            }

            get_log(): list {
                @@:(this.log)
                return;
            }

            get_state(): str {
                @@:("ChildB")
                return;
            }
        }

        $ChildC => $Parent {
            start_a() {
                -> $ChildA
            }

            start_b() {
                -> $ChildB
            }

            start_c() {
                // stay
            }

            do_action() {
                this.log.add("ChildC:do_action");
            }

            forward_action() {
                this.log.add("ChildC:forward_action");
                => $^
            }

            get_log(): list {
                @@:(this.log)
                return;
            }

            get_state(): str {
                @@:("ChildC")
                return;
            }
        }

        $Parent {
            forward_action() {
                this.log.add("Parent:forward_action");
            }

            get_log(): list {
                @@:(this.log)
                return;
            }

            get_state(): str {
                @@:("Parent")
                return;
            }
        }
    domain:
        log : List<String> = []
}

void main() {
    print("== Test 43: HSM Multiple Children ==");
    final s = @@HSMMultiChildren();

    // TC1.3.1: Multiple children declare same parent (verified by compilation)
    print("TC1.3.1: Multiple children with same parent compiles - PASS");

    // Start in ChildA
    if (s.get_state() != "ChildA") throw Exception("Expected ChildA, got ${s.get_state()}");

    // TC1.3.2: ChildA can forward to shared parent
    s.forward_action();
    var log = s.get_log();
    if (!log.contains("ChildA:forward_action")) throw Exception("Expected ChildA forward, got ${jsonEncode(log)}");
    if (!log.contains("Parent:forward_action")) throw Exception("Expected Parent handler, got ${jsonEncode(log)}");
    print("TC1.3.2: ChildA forwards to parent - PASS");

    // TC1.3.3: Transition to sibling
    s.start_b();
    if (s.get_state() != "ChildB") throw Exception("Expected ChildB after transition, got ${s.get_state()}");
    print("TC1.3.3: Transition A->B works - PASS");

    // TC1.3.4: ChildB can also forward to same parent
    s.forward_action();
    log = s.get_log();
    if (!log.contains("ChildB:forward_action")) throw Exception("Expected ChildB forward, got ${jsonEncode(log)}");
    final parentCount = log.where((x) => x == "Parent:forward_action").length;
    if (parentCount != 2) throw Exception("Expected 2 Parent forwards, got ${jsonEncode(log)}");
    print("TC1.3.4: ChildB forwards to same parent - PASS");

    // TC1.3.5: Transition to ChildC
    s.start_c();
    if (s.get_state() != "ChildC") throw Exception("Expected ChildC, got ${s.get_state()}");
    s.forward_action();
    log = s.get_log();
    if (!log.contains("ChildC:forward_action")) throw Exception("Expected ChildC forward, got ${jsonEncode(log)}");
    final parentCount2 = log.where((x) => x == "Parent:forward_action").length;
    if (parentCount2 != 3) throw Exception("Expected 3 Parent forwards, got ${jsonEncode(log)}");
    print("TC1.3.5: ChildC forwards to same parent - PASS");

    // TC1.3.6: Each sibling maintains independent actions
    s.start_a();
    s.do_action();
    s.start_b();
    s.do_action();
    s.start_c();
    s.do_action();
    log = s.get_log();
    if (!log.contains("ChildA:do_action")) throw Exception("Expected ChildA action");
    if (!log.contains("ChildB:do_action")) throw Exception("Expected ChildB action");
    if (!log.contains("ChildC:do_action")) throw Exception("Expected ChildC action");
    print("TC1.3.6: Each sibling has independent handlers - PASS");

    print("PASS: HSM multiple children work correctly");
}


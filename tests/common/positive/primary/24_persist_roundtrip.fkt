@@[target("kotlin")]

import kotlin.system.exitProcess

@@[persist(String)]
@@[save(save_state)]
@@[load(restore_state)]
@@system PersistRoundtrip {
    interface:
        set_counter(v: Int)
        get_counter(): Int
        go_active()
        go_idle()
        get_state(): String
        add_history(entry: String)
        get_history(): String

    machine:
        $Idle {
            set_counter(v: Int) { counter = v }
            get_counter(): Int {
                @@:(counter)
            }
            go_active() {
                this.add_history("idle->active")
                -> $Active
            }
            go_idle() { }
            get_state(): String {
                @@:("idle")
            }
            add_history(entry: String) { history = history + entry + "," }
            get_history(): String {
                @@:(history)
            }
        }

        $Active {
            set_counter(v: Int) { counter = v * 2 }
            get_counter(): Int {
                @@:(counter)
            }
            go_active() { }
            go_idle() {
                this.add_history("active->idle")
                -> $Idle
            }
            get_state(): String {
                @@:("active")
            }
            add_history(entry: String) { history = history + entry + "," }
            get_history(): String {
                @@:(history)
            }
        }
    domain:
        counter : Int = 0
        history : String = ""
        mode : String = "normal"
}

fun main() {
    println("=== Test 24: Persist Roundtrip (Kotlin) ===")

    val s1 = PersistRoundtrip()
    s1.add_history("idle:start")
    s1.go_active()
    s1.set_counter(3)
    s1.add_history("active:work")

    if ((s1.get_state() as String) != "active") { println("FAIL: state"); exitProcess(1) }
    if ((s1.get_counter() as Int) != 6) { println("FAIL: counter ${s1.get_counter()}"); exitProcess(1) }
    println("1. State: ${s1.get_state()}, counter: ${s1.get_counter()}")
    println("   History: ${s1.get_history()}")

    val json = s1.save_state() as String
    println("2. Saved")

    val s2 = PersistRoundtrip()


    s2.restore_state(json)
    if ((s2.get_state() as String) != "active") { println("FAIL: restored state"); exitProcess(1) }
    if ((s2.get_counter() as Int) != 6) { println("FAIL: restored counter"); exitProcess(1) }
    println("3. Restored: ${s2.get_state()}, counter: ${s2.get_counter()}")

    s2.set_counter(2)
    if ((s2.get_counter() as Int) != 4) { println("FAIL: post-restore counter"); exitProcess(1) }
    println("4. Counter after set_counter(2): ${s2.get_counter()}")

    if (!(s2.get_history() as String).contains("idle:start")) { println("FAIL: history"); exitProcess(1) }
    println("5. History preserved: ${s2.get_history()}")

    s2.go_idle()
    s2.set_counter(10)
    if ((s2.get_counter() as Int) != 10) { println("FAIL: idle counter"); exitProcess(1) }
    println("6. After go_idle: ${s2.get_state()}, counter: ${s2.get_counter()}")

    println("PASS: Persist roundtrip works correctly")
}

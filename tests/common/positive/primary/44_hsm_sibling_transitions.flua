@@[target("lua")]
@@system HSMSiblingTransitions {
    interface:
        go_to_b()
        go_to_a()
        forward_action()
        get_log(): list
        get_state(): str

    machine:
        $ChildA => $Parent {
            $>() {
                self.log[#self.log + 1] = "ChildA:enter"
            }

            <$() {
                self.log[#self.log + 1] = "ChildA:exit"
            }

            go_to_b() {
                self.log[#self.log + 1] = "ChildA:go_to_b"
                -> $ChildB
            }

            forward_action() {
                self.log[#self.log + 1] = "ChildA:forward"
                => $^
            }

            get_log(): list {
                @@:(self.log)
                return
            }

            get_state(): str {
                @@:("ChildA")
                return
            }
        }

        $ChildB => $Parent {
            $>() {
                self.log[#self.log + 1] = "ChildB:enter"
            }

            <$() {
                self.log[#self.log + 1] = "ChildB:exit"
            }

            go_to_a() {
                self.log[#self.log + 1] = "ChildB:go_to_a"
                -> $ChildA
            }

            forward_action() {
                self.log[#self.log + 1] = "ChildB:forward"
                => $^
            }

            get_log(): list {
                @@:(self.log)
                return
            }

            get_state(): str {
                @@:("ChildB")
                return
            }
        }

        $Parent {
            forward_action() {
                self.log[#self.log + 1] = "Parent:forward_action"
            }

            get_log(): list {
                @@:(self.log)
                return
            }

            get_state(): str {
                @@:("Parent")
                return
            }
        }
    domain:
        log: list = []
}

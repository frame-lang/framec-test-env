@@[target("erlang")]
@@[persist]
@@system PFloat {
    interface:
        configure(rate: float)
        getRate(): float
    machine:
        $Idle {
            configure(rate: float) {
                -> $Active(rate)
            }
            getRate(): float {
                @@:(0.0)
            }
        }
        $Active(rate: float) {
            getRate(): float {
                @@:(Rate)
            }
        }
    domain:
        n = 0
}

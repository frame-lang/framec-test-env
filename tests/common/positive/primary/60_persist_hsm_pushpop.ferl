@@target erlang
@@persist
@@system PersistHsmPushpop {
    interface:
        pushModal(v: int)
        popModal()
        getX(): int
    machine:
        $Idle {
            pushModal(v: int) {
                push$
                -> $Modal(v)
            }
            popModal() {
                -> pop$
            }
            getX(): int {
                @@:(-99)
            }
        }
        $Modal => $Frame(x: int) {
            pushModal(v: int) {
                push$
                -> $Modal(v)
            }
            popModal() {
                -> pop$
            }
            getX(): int {
                @@:(x)
            }
        }
        $Frame {
        }
    domain:
        v = 0
}

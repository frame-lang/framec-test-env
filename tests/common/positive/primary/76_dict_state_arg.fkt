@@[target("kotlin")]

@@system DictStateArg {
    interface:
        configure(m: Map<String, Int>)
        get_v(key: String): Int
        size(): Int

    machine:
        $Idle {
            configure(m: Map<String, Int>) { -> $Active(m) }
            get_v(key: String): Int { @@:(-1) }
            size(): Int { @@:(0) }
        }
        $Active(m: Map<String, Int>) {
            configure(m: Map<String, Int>) { -> $Active(m) }
            get_v(key: String): Int { @@:(m[key] ?: -1) }
            size(): Int { @@:(m.size) }
        }
    domain:
        n : Int = 0
}

fun main() {
    val s = DictStateArg()
    if (s.get_v("a") != -1) { println("FAIL idle"); kotlin.system.exitProcess(1) }
    if (s.size() != 0) { println("FAIL idle size"); kotlin.system.exitProcess(1) }
    s.configure(mapOf("a" to 10, "b" to 20))
    if (s.get_v("a") != 10) { println("FAIL a"); kotlin.system.exitProcess(1) }
    if (s.get_v("b") != 20) { println("FAIL b"); kotlin.system.exitProcess(1) }
    if (s.size() != 2) { println("FAIL size"); kotlin.system.exitProcess(1) }
    s.configure(mapOf("x" to 99))
    if (s.get_v("x") != 99) { println("FAIL x"); kotlin.system.exitProcess(1) }
    if (s.size() != 1) { println("FAIL size2"); kotlin.system.exitProcess(1) }
    println("PASS: 76_dict_state_arg")
}

@@[target("java")]

import java.util.*;

@@[persist]
@@system PersistStateArgs {
    operations:
        @@[save]
        save_state(): String {}

        @@[load]
        restore_state(data: String) {}

    interface:
        kick(v: int)
        get_slot(): int

    machine:
        $Idle {
            kick(v: int) {
                -> $Active(v)
            }
            get_slot(): int {
                @@:(-1)
            }
        }

        $Active(slot: int) {
            kick(v: int) {
                -> $Active(v)
            }
            get_slot(): int {
                @@:(slot)
            }
        }
    domain:
        v : int = 0
}

class Main {
    public static void main(String[] args) {
        System.out.println("=== Test 56: Persist State-Args Round-Trip (Java) ===");
        var s1 = new PersistStateArgs();
        s1.kick(42);
        int pre = s1.get_slot();
        if (pre != 42) { System.out.println("FAIL: pre " + pre); System.exit(1); }
        System.out.println("1. Pre-save slot=" + pre);

        String snap = s1.save_state();
        var s2 = new PersistStateArgs();

        s2.restore_state(snap);
        int post = s2.get_slot();
        if (post != 42) { System.out.println("FAIL: post " + post); System.exit(1); }
        System.out.println("2. Post-restore slot=" + post);

        s2.kick(99);
        int post2 = s2.get_slot();
        if (post2 != 99) { System.out.println("FAIL: post2 " + post2); System.exit(1); }
        System.out.println("3. Post-restore-kick slot=" + post2);

        System.out.println("PASS: 56_persist_state_args");
    }
}

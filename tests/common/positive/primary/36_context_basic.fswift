@@[target("swift")]

// Test: Basic System Context Access
// Validates @@:params.param, @@:return, @@:event syntax

@@system ContextBasicTest {
    interface:
        add(a: number, b: number): number
        get_event_name(): string
        greet(name: string): string

    machine:
        $Ready {
            add(a: number, b: number): number {
                // Access params via @@ shorthand
                @@:((@@:params.a as! Int) + (@@:params.b as! Int))
            }

            get_event_name(): string {
                // Access event name
                @@:(@@:event)
            }

            greet(name: string): string {
                // Mix param access and return
                let result = "Hello, " + (@@:params.name as! String) + "!"
                @@:(result)
            }
        }
}

// main
    print("=== Test 36: Context Basic ===")
    let s = @@ContextBasicTest()

    // Test 1: @@:params.a and @@:params.b param access, @@:return
    let result1 = s.add(3, 5)
    if result1 != 8 { fatalError("Expected 8, got \(result1)") }
    print("1. add(3, 5) = \(result1)")

    // Test 2: @@:event access
    let eventName = s.get_event_name()
    if eventName != "get_event_name" { fatalError("Expected 'get_event_name', got '\(eventName)'") }
    print("2. @@:event = '\(eventName)'")

    // Test 3: @@:params.name param access with string
    let greeting = s.greet("World")
    if greeting != "Hello, World!" { fatalError("Expected 'Hello, World!', got '\(greeting)'") }
    print("3. greet('World') = '\(greeting)'")

    print("PASS: Context basic access works correctly")

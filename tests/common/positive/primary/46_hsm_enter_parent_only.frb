@@target ruby

@@system HSMEnterParentOnly {
    interface:
        go_to_child()
        go_to_parent()
        get_log(): list
        get_state(): str

    machine:
        $Start {
            go_to_child() { -> $Child }
            go_to_parent() { -> $Parent }
            get_log(): list { return self.log }
            get_state(): str { return "Start" }
        }

        $Child => $Parent {
            go_to_parent() { -> $Parent }
            get_log(): list { return self.log }
            get_state(): str { return "Child" }
        }

        $Parent {
            $>() { self.log.push("Parent:enter") }
            go_to_child() { -> $Child }
            get_log(): list { return self.log }
            get_state(): str { return "Parent" }
        }
    domain:
        log: list = []
}

puts("=== Test 46: HSM Enter in Parent Only ===")
s = HSMEnterParentOnly.new

s.go_to_child()
raise "Expected Child, got #{s.get_state()}" unless s.get_state() == "Child"
log = s.get_log()
puts("TC2.2.1: Child enters without error (log: #{log}) - PASS")

raise "Parent:enter should NOT fire for child entry, got #{log}" if log.include?("Parent:enter")
puts("TC2.2.2: Parent enter NOT auto-fired for child - PASS")

s.go_to_parent()
raise "Expected Parent, got #{s.get_state()}" unless s.get_state() == "Parent"
log = s.get_log()
raise "Expected Parent:enter when transitioning to Parent, got #{log}" unless log.include?("Parent:enter")
puts("TC2.2.3: Parent enter fires when transitioning to Parent - PASS")

s.go_to_child()
raise "Expected Child, got #{s.get_state()}" unless s.get_state() == "Child"
log = s.get_log()
raise "Expected exactly 1 Parent:enter, got #{log}" unless log.count("Parent:enter") == 1
puts("TC2.2.4: Return to child, parent enter count unchanged - PASS")

puts("PASS: HSM enter in parent only works correctly")

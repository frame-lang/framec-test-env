@@[target("swift")]

@@system Test {
    interface:
        ready(): Bool

    machine:
        $Active {
            ready(): Bool {
                @@:(self.timer >= self.threshold
                    && self.count < self.limit)
            }
        }
    domain:
        timer: Int = 100
        threshold: Int = 50
        count: Int = 1
        limit: Int = 5
}

let t = @@Test()
if t.ready() != true {
    print("FAIL ready(): \(t.ready())")
} else {
    print("PASS: 92_return_expr_multiline")
}

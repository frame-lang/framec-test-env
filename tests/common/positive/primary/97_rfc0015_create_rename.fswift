@@[target("swift")]
@@[create(make)]
@@system Counter(seed: Int) {
    interface:
        bump()
        readCount(): Int

    machine:
        $A {
            bump() { self.count = self.count + 1 }
            readCount(): Int { @@:(self.count) }
        }

    domain:
        seed: Int = seed
        count: Int = 0
}

let c1 = @@Counter(42)
c1.bump()
c1.bump()
if c1.readCount() != 2 {
    print("FAIL: via @@Counter() expected 2, got \(c1.readCount())")
} else {
    let c2 = Counter.make(99)
    c2.bump()
    if c2.readCount() != 1 {
        print("FAIL: via Counter.make expected 1, got \(c2.readCount())")
    } else {
        print("PASS: rfc0015_create_rename")
    }
}

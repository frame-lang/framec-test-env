@@[target("cpp_17")]

#include <iostream>

@@[create(make)]
@@system Counter(seed: int) {
    interface:
        bump()
        get_value(): int

    machine:
        $A {
            bump() { this->count = this->count + 1; }
            get_value(): int { @@:(this->count) }
        }

    domain:
        seed: int = seed
        count: int = 0
}

int main() {
    Counter c1(42);
    c1.bump();
    c1.bump();
    if (c1.get_value() != 2) {
        std::cout << "FAIL: via Counter() expected 2, got " << c1.get_value() << std::endl;
        return 1;
    }

    Counter c2 = Counter::make(99);
    c2.bump();
    if (c2.get_value() != 1) {
        std::cout << "FAIL: via Counter::make expected 1, got " << c2.get_value() << std::endl;
        return 1;
    }

    std::cout << "PASS: rfc0015_create_rename" << std::endl;
    return 0;
}

@@[target("gdscript")]
extends SceneTree

@@system BoolStateArg {
    interface:
        configure(active: bool)
        is_active(): bool

    machine:
        $Idle {
            configure(active: bool) {
                -> $Active(active)
            }
            is_active(): bool {
                @@:(false)
            }
        }

        $Active => $Frame(flag: bool) {
            configure(active: bool) {
                -> $Active(active)
            }
            is_active(): bool {
                => $^
            }
        }

        $Frame {
            is_active(): bool {
                @@:(flag)
            }
        }
    domain:
        n: int = 0
}

func _initialize():
    var s = @@BoolStateArg()
    if s.is_active() != false:
        print("FAIL idle"); quit(1); return
    s.configure(true)
    if s.is_active() != true:
        print("FAIL true"); quit(1); return
    s.configure(false)
    if s.is_active() != false:
        print("FAIL false"); quit(1); return
    s.configure(true)
    if s.is_active() != true:
        print("FAIL re-true"); quit(1); return
    print("PASS: 67_hsm_bool_state_args")
    quit(0)

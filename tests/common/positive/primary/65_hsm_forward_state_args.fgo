@@[target("go")]

package main

import (
	"fmt"
	"os"
)

@@system StateArgFwd {
    interface:
        Configure(t: int)
        Process(): int

    machine:
        $Idle {
            Configure(t: int) {
                -> $Active(t)
            }
            Process(): int {
                @@:(0)
                return;
            }
        }

        $Active => $Frame(threshold: int) {
            Configure(t: int) {
                -> $Active(t)
            }
            Process(): int {
                => $^
            }
        }

        $Frame {
            Process(): int {
                @@:(threshold)
                return;
            }
        }
    domain:
        n: int = 0
}

func main() {
    fmt.Println("=== Test 65: HSM × state-args × parent-forward (Go) ===")
    s := @@StateArgFwd()

    pre := s.Process()
    if pre != 0 { fmt.Printf("FAIL: pre %d\n", pre); os.Exit(1) }
    fmt.Printf("1. Idle process = %d\n", pre)

    s.Configure(7)
    r := s.Process()
    if r != 7 { fmt.Printf("FAIL: r %d\n", r); os.Exit(1) }
    fmt.Printf("2. configure(7); process() = %d\n", r)

    s.Configure(42)
    r2 := s.Process()
    if r2 != 42 { fmt.Printf("FAIL: r2 %d\n", r2); os.Exit(1) }
    fmt.Printf("3. configure(42); process() = %d\n", r2)

    fmt.Println("PASS: 65_hsm_forward_state_args")
}

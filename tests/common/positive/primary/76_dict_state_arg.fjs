@@[target("javascript")]

@@system DictStateArg {
    interface:
        configure(m)
        get_v(key)
        size()

    machine:
        $Idle {
            configure(m) { -> $Active(m) }
            get_v(key) { @@:(-1) }
            size() { @@:(0) }
        }
        $Active(m) {
            configure(m) { -> $Active(m) }
            get_v(key) { @@:(m[key] !== undefined ? m[key] : -1) }
            size() { @@:(Object.keys(m).length) }
        }
    domain:
        n = 0
}

const s = new DictStateArg();
if (s.get_v("a") !== -1) { console.log("FAIL idle"); process.exit(1); }
if (s.size() !== 0) { console.log("FAIL idle size"); process.exit(1); }
s.configure({"a": 10, "b": 20});
if (s.get_v("a") !== 10) { console.log("FAIL a"); process.exit(1); }
if (s.get_v("b") !== 20) { console.log("FAIL b"); process.exit(1); }
if (s.size() !== 2) { console.log("FAIL size"); process.exit(1); }
s.configure({"x": 99});
if (s.get_v("x") !== 99) { console.log("FAIL x"); process.exit(1); }
if (s.size() !== 1) { console.log("FAIL size2"); process.exit(1); }

@@[target("go")]

package main

import (
	"encoding/json"
	"fmt"
	"os"
)

var _ = json.Marshal

@@[persist(string)]
@@[save(SaveState)]
@@[load(LoadState)]
@@system PersistPushpopStateArgs {
    interface:
        PushModal(v: int)
        PopModal()
        GetSlot(): int

    machine:
        $Idle {
            PushModal(v: int) {
                push$
                -> $Modal(v)
            }
            PopModal() {
                -> pop$
            }
            GetSlot(): int {
                @@:(-99)
                return;
            }
        }

        $Modal(slot: int) {
            PushModal(v: int) {
                push$
                -> $Modal(v)
            }
            PopModal() {
                -> pop$
            }
            GetSlot(): int {
                @@:(slot)
                return;
            }
        }
    domain:
        v: int = 0
}

func main() {
    fmt.Println("=== Test 58: Persist × push/pop × state-args (Go) ===")
    s1 := @@PersistPushpopStateArgs()
    s1.PushModal(42)
    s1.PushModal(77)
    pre := s1.GetSlot()
    if pre != 77 { fmt.Printf("FAIL: pre %d\n", pre); os.Exit(1) }
    fmt.Printf("1. Pre-save top slot=%d\n", pre)

    snap := s1.SaveState()
    s2 := @@PersistPushpopStateArgs()

    s2.LoadState(snap)
    post := s2.GetSlot()
    if post != 77 { fmt.Printf("FAIL: post %d\n", post); os.Exit(1) }
    fmt.Printf("2. Post-restore top slot=%d\n", post)

    s2.PopModal()
    mid := s2.GetSlot()
    if mid != 42 { fmt.Printf("FAIL: mid %d\n", mid); os.Exit(1) }
    fmt.Printf("3. After first pop slot=%d\n", mid)

    s2.PopModal()
    bottom := s2.GetSlot()
    if bottom != -99 { fmt.Printf("FAIL: bottom %d\n", bottom); os.Exit(1) }
    fmt.Printf("4. After second pop slot=%d\n", bottom)

    fmt.Println("PASS: 58_persist_pushpop_state_args")
}

@@[target("gdscript")]

extends SceneTree

@@system Demo {
    interface:
        common(): String
        @@[target("python_3")] only_py(): String
        @@[target("gdscript")] only_gd(): String

    machine:
        $S {
            common(): String { @@:("common") }
            @@[target("python_3")] only_py(): String { @@:("only_py_present") }
            @@[target("gdscript")] only_gd(): String { @@:("only_gd_present") }
        }
}

func _init():
    var d = @@Demo()
    assert(d.common() == "common", "FAIL common: " + str(d.common()))
    assert(d.only_gd() == "only_gd_present", "FAIL only_gd: " + str(d.only_gd()))
    assert(not d.has_method("only_py"), "FAIL: only_py should have been filtered out by @@[target(\"python_3\")]")
    print("PASS: 89_attribute_per_item")
    quit()

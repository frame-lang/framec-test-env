@@[target("gdscript")]
extends SceneTree

# Test: deep @@:self.iface() stack — transition guard propagation
#
# Validates:
# 1. Full chain completes when no transition fires
# 2. Transition at depth 3 suppresses all "after" traces
# 3. Transition at depth 2 prevents deeper calls
# 4. Sequential self-calls: second suppressed after first transitions
# 5. Sequential self-calls: both complete when no transition

@@system DeepSelfCall {
    interface:
        start_chain(mode: String): String
        level_one(mode: String): String
        level_two(mode: String): String
        level_three(mode: String): String
        get_trace(): String
        get_state(): String
        reset()

    machine:
        $Active {
            start_chain(mode: String): String {
                self.trace = ""
                self.trace = self.trace + "start:before;"
                @@:self.level_one(mode)
                self.trace = self.trace + "start:after;"
                @@:(self.trace)
            }

            level_one(mode: String): String {
                self.trace = self.trace + "L1:before;"
                @@:self.level_two(mode)
                self.trace = self.trace + "L1:after;"
                @@:(self.trace)
            }

            level_two(mode: String): String {
                self.trace = self.trace + "L2:before;"
                if mode == "transition_at_two":
                    self.trace = self.trace + "L2:transitioning;"
                    -> $Done
                @@:self.level_three(mode)
                self.trace = self.trace + "L2:after;"
                @@:(self.trace)
            }

            level_three(mode: String): String {
                self.trace = self.trace + "L3:before;"
                if mode == "transition_at_three":
                    self.trace = self.trace + "L3:transitioning;"
                    -> $Done
                self.trace = self.trace + "L3:after;"
                @@:(self.trace)
            }

            get_trace(): String {
                @@:(self.trace)
            }

            get_state(): String { @@:(@@:system.state) }

            reset() {
                self.trace = ""
            }
        }

        $Done {
            get_trace(): String {
                @@:(self.trace)
            }

            get_state(): String { @@:(@@:system.state) }

            reset() {
                self.trace = ""
                -> $Active
            }
        }

    domain:
        trace: String = ""
}

@@system SequentialSelfCall {
    interface:
        run_sequence(mode: String): String
        first_call(mode: String): String
        second_call(): String
        get_trace(): String
        get_state(): String

    machine:
        $Active {
            run_sequence(mode: String): String {
                self.trace = ""
                self.trace = self.trace + "seq:before_first;"
                @@:self.first_call(mode)
                self.trace = self.trace + "seq:between;"
                @@:self.second_call()
                self.trace = self.trace + "seq:after_second;"
                @@:(self.trace)
            }

            first_call(mode: String): String {
                if mode == "transition_first":
                    self.trace = self.trace + "first:transitioning;"
                    -> $Done
                self.trace = self.trace + "first:complete;"
                @@:(self.trace)
            }

            second_call(): String {
                self.trace = self.trace + "second:complete;"
                @@:(self.trace)
            }

            get_trace(): String { @@:(self.trace) }
            get_state(): String { @@:(@@:system.state) }
        }

        $Done {
            get_trace(): String { @@:(self.trace) }
            get_state(): String { @@:(@@:system.state) }
        }

    domain:
        trace: String = ""
}

func main():
    var failures = 0

    # === Scenario 1: No transition — full chain completes ===
    var s = @@DeepSelfCall()
    var result = s.start_chain("no_transition")
    var expected = "start:before;L1:before;L2:before;L3:before;L3:after;L2:after;L1:after;start:after;"
    if result != expected:
        print("FAIL scenario 1: expected '" + expected + "'")
        print("                 got      '" + str(result) + "'")
        failures += 1
    if s.get_state() != "Active":
        print("FAIL scenario 1: state should be Active, got '" + str(s.get_state()) + "'")
        failures += 1

    # === Scenario 2: Transition at level_three — all "after" traces suppressed ===
    s.reset()
    s.start_chain("transition_at_three")
    var trace = s.get_trace()
    var expected_trace = "start:before;L1:before;L2:before;L3:before;L3:transitioning;"
    if trace != expected_trace:
        print("FAIL scenario 2 trace: expected '" + expected_trace + "'")
        print("                       got      '" + str(trace) + "'")
        failures += 1
    if s.get_state() != "Done":
        print("FAIL scenario 2: state should be Done, got '" + str(s.get_state()) + "'")
        failures += 1

    # === Scenario 3: Transition at level_two — level_three never called ===
    s.reset()
    s.start_chain("transition_at_two")
    trace = s.get_trace()
    expected_trace = "start:before;L1:before;L2:before;L2:transitioning;"
    if trace != expected_trace:
        print("FAIL scenario 3 trace: expected '" + expected_trace + "'")
        print("                       got      '" + str(trace) + "'")
        failures += 1
    if s.get_state() != "Done":
        print("FAIL scenario 3: state should be Done, got '" + str(s.get_state()) + "'")
        failures += 1

    # === Scenario 4: Sequential self-calls — second suppressed after first transitions ===
    var s2 = @@SequentialSelfCall()
    s2.run_sequence("transition_first")
    trace = s2.get_trace()
    expected_trace = "seq:before_first;first:transitioning;"
    if trace != expected_trace:
        print("FAIL scenario 4 trace: expected '" + expected_trace + "'")
        print("                       got      '" + str(trace) + "'")
        failures += 1
    if s2.get_state() != "Done":
        print("FAIL scenario 4: state should be Done, got '" + str(s2.get_state()) + "'")
        failures += 1

    # === Scenario 5: Sequential self-calls — no transition, both complete ===
    var s3 = @@SequentialSelfCall()
    s3.run_sequence("no_transition")
    trace = s3.get_trace()
    expected_trace = "seq:before_first;first:complete;seq:between;second:complete;seq:after_second;"
    if trace != expected_trace:
        print("FAIL scenario 5 trace: expected '" + expected_trace + "'")
        print("                       got      '" + str(trace) + "'")
        failures += 1

    if failures > 0:
        print("FAIL: deep_self_call (" + str(failures) + " failures)")
        quit(1)
    print("PASS: deep_self_call")

func _init():
    main()
    quit(0)

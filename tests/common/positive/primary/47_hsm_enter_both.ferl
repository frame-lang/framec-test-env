@@[target("erlang")]
@@system HSMEnterBoth {
    interface:
        getLog(): str
    machine:
        $Child => $Parent {
            $>() {
                # RFC-0019: forward $> to $Parent first so its $> runs
                # before this one (parent-then-child enter order). Also
                # exercises the Erlang #-comment-in-handler-body codepath.
                => $^
                self.log = self.log ++ ",child_enter"  # child runs second
            }
            getLog(): str {
                # comment inside an event handler body
                @@:(self.log)
            }
        }
        $Parent {
            $>() { self.log = self.log ++ ",parent_enter" }
            getLog(): str {
                @@:(self.log)
            }
        }
    domain:
        log = "init"
}

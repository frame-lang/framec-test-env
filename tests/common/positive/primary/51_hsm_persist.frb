@@target ruby

require 'json'

@@persist
@@system HSMPersist {
    interface:
        increment_child()
        increment_parent()
        get_child_count(): int
        get_parent_count(): int
        get_state(): str

    machine:
        $Child => $Parent {
            $.child_count: int = 0
            increment_child() { $.child_count = $.child_count + 1 }
            increment_parent() { => $^ }
            get_child_count(): int {
                @@:($.child_count)
            }
            get_parent_count(): int { => $^ }
            get_state(): str {
                @@:("Child")
            }
        }

        $Parent {
            $.parent_count: int = 100
            increment_parent() { $.parent_count = $.parent_count + 1 }
            get_parent_count(): int {
                @@:($.parent_count)
            }
            get_state(): str {
                @@:("Parent")
            }
        }
}

puts("=== Test 51: HSM Persistence ===")

s1 = HSMPersist.new
raise "Expected Child, got #{s1.get_state()}" unless s1.get_state() == "Child"
raise "Expected 0, got #{s1.get_child_count()}" unless s1.get_child_count() == 0
raise "Expected 100, got #{s1.get_parent_count()}" unless s1.get_parent_count() == 100
puts("1. Initial state verified: Child with child_count=0, parent_count=100")

s1.increment_child(); s1.increment_child(); s1.increment_child()
s1.increment_parent(); s1.increment_parent()

raise "Expected 3, got #{s1.get_child_count()}" unless s1.get_child_count() == 3
raise "Expected 102, got #{s1.get_parent_count()}" unless s1.get_parent_count() == 102
puts("2. After increments: child_count=#{s1.get_child_count()}, parent_count=#{s1.get_parent_count()}")

data = s1.save_state()
raise "Expected String, got #{data.class}" unless data.is_a?(String)
puts("3. Saved state: #{data.length} bytes")

s2 = HSMPersist.restore_state(data)
raise "Expected Child after restore, got #{s2.get_state()}" unless s2.get_state() == "Child"
puts("4. Restored state: #{s2.get_state()}")

raise "Expected child_count=3, got #{s2.get_child_count()}" unless s2.get_child_count() == 3
puts("5. Child state var preserved: child_count=#{s2.get_child_count()}")

raise "Expected parent_count=102, got #{s2.get_parent_count()}" unless s2.get_parent_count() == 102
puts("6. Parent state var preserved: parent_count=#{s2.get_parent_count()}")

s2.increment_child(); s2.increment_parent()
raise "Expected 4, got #{s2.get_child_count()}" unless s2.get_child_count() == 4
raise "Expected 103, got #{s2.get_parent_count()}" unless s2.get_parent_count() == 103
puts("7. After post-restore increments: child_count=#{s2.get_child_count()}, parent_count=#{s2.get_parent_count()}")

puts("PASS: HSM persistence works correctly")

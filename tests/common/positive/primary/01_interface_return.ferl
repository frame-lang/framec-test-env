@@target erlang

@@system InterfaceReturn {
    interface:
        boolReturn(): bool
        intReturn(): int
        stringReturn(): str
        computedReturn(a: int, b: int): int

    machine:
        $Active {
            boolReturn(): bool {
                return true
            }

            intReturn(): int {
                return 42
            }

            stringReturn(): str {
                return "Frame"
            }

            computedReturn(a: int, b: int): int {
                return a * b + 10
            }
        }
}

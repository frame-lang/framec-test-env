@@[target("erlang")]

@@system InterfaceReturn {
    interface:
        boolReturn(): bool
        intReturn(): int
        stringReturn(): str
        computedReturn(a: int, b: int): int

    machine:
        $Active {
            boolReturn(): bool {
                @@:(true)
                return
            }

            intReturn(): int {
                @@:(42)
                return
            }

            stringReturn(): str {
                @@:("Frame")
                return
            }

            computedReturn(a: int, b: int): int {
                @@:(a * b + 10)
                return
            }
        }
}

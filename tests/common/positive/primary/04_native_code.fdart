@@[target("dart")]
import 'dart:math';
num helper_function(num x) {
    // Native helper function defined before system
    return x * 2;
}

@@system NativeCode {
    interface:
        compute(value: num): num
        use_math(): num

    machine:
        $Active {
            compute(value: num): num {
                // Native code with local variables
                final temp = value + 10;
                final result = helper_function(temp);
                print("Computed: ${value} -> ${result}");
                @@:(result)
                return;
            }

            use_math(): num {
                // Using Math module
                final result = sqrt(16) + pi;
                print("Math result: ${result}");
                @@:(result)
                return;
            }
        }
}

void main() {
    print("== Test 04: Native Code Preservation ==");
    final s = @@NativeCode();

    // Test native code in handler with helper function
    final result = s.compute(5);
    final expected = (5 + 10) * 2;  // 30
    if (result != expected) {
        throw Exception("Expected ${expected}, got ${result}");
    }
    print("compute(5) = ${result}");

    // Test Math module usage
    final mathResult = s.use_math();
    final expectedMath = sqrt(16) + pi;
    if ((mathResult - expectedMath).abs() >= 0.001) {
        throw Exception("Expected ~${expectedMath}, got ${mathResult}");
    }
    print("use_math() = ${mathResult}");

    print("PASS: Native code preservation works correctly");
}


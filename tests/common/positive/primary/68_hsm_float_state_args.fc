@@[target("c")]

#include <stdio.h>
#include <stdlib.h>
#include <string.h>
#include <math.h>

@@system FloatStateArg {
    interface:
        configure(rate: float)
        scale(v: float): float

    machine:
        $Idle {
            configure(rate: double) {
                -> $Active(rate)
            }
            scale(v: double): double {
                @@:(v)
            }
        }

        $Active => $Frame(rate: double) {
            configure(rate: double) {
                -> $Active(rate)
            }
            scale(v: double): double {
                => $^
            }
        }

        $Frame {
            scale(v: double): double {
                @@:(v * rate)
            }
        }
    domain:
        n : int = 0
}

int main(void) {
    FloatStateArg* s = @@FloatStateArg();
    if (fabs(FloatStateArg_scale(s, 2.0) - 2.0) > 1e-9) { printf("FAIL idle\n"); return 1; }
    FloatStateArg_configure(s, 0.5);
    if (fabs(FloatStateArg_scale(s, 10.0) - 5.0) > 1e-9) { printf("FAIL 0.5\n"); return 1; }
    FloatStateArg_configure(s, 2.5);
    if (fabs(FloatStateArg_scale(s, 4.0) - 10.0) > 1e-9) { printf("FAIL 2.5\n"); return 1; }
    printf("PASS: 68_hsm_float_state_args\n");
    FloatStateArg_destroy(s);
    return 0;
}

@@target dart
// Documentation Example: HSM Lamp with color behavior factored out

@@system LampHSM {
    interface:
        turnOn()
        turnOff()
        getColor(): String
        setColor(color: String)
        isLampOn(): bool

    machine:
        $Off => $ColorBehavior {
            turnOn() {
                -> $On
            }
            isLampOn(): bool {
                @@:(this.lamp_on)
                return;
            }
            => $^
        }

        $On => $ColorBehavior {
            $>() {
                this.turnOnLamp();
            }
            <$() {
                this.turnOffLamp();
            }
            turnOff() {
                -> $Off
            }
            isLampOn(): bool {
                @@:(this.lamp_on)
                return;
            }
            => $^
        }

        $ColorBehavior {
            getColor(): String {
                @@:(this.color)
                return;
            }
            setColor(color: String) {
                this.color = color;
            }
        }

    actions:
        turnOnLamp() {
            this.lamp_on = true;
        }
        turnOffLamp() {
            this.lamp_on = false;
        }

    domain:
        String color = "white"
        bool lamp_on = false
}

void main() {
    print("== Test 32: Doc Lamp HSM ==");
    final lamp = @@LampHSM();

    // Color behavior available in both states
    if (lamp.getColor() != "white") {
        throw Exception("Expected 'white', got '${lamp.getColor()}'");
    }
    lamp.setColor("red");
    if (lamp.getColor() != "red") {
        throw Exception("Expected 'red', got '${lamp.getColor()}'");
    }

    // Turn on
    lamp.turnOn();
    if (lamp.isLampOn() != true) {
        throw Exception("Lamp should be on");
    }

    // Color still works when on
    lamp.setColor("green");
    if (lamp.getColor() != "green") {
        throw Exception("Expected 'green', got '${lamp.getColor()}'");
    }

    // Turn off
    lamp.turnOff();
    if (lamp.isLampOn() != false) {
        throw Exception("Lamp should be off");
    }

    // Color still works when off
    if (lamp.getColor() != "green") {
        throw Exception("Expected 'green', got '${lamp.getColor()}'");
    }

    print("PASS: HSM lamp works correctly");
}


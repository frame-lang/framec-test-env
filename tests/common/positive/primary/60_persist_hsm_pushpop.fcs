@@[target("csharp")]

using System;

@@[persist]
@@system PersistHsmPushpop {
    operations:
        @@[save]
        SaveState(): string {}

        @@[load]
        RestoreState(data: string) {}

    interface:
        push_modal(v: int)
        pop_modal()
        get_x(): int

    machine:
        $Idle {
            push_modal(v: int) {
                push$
                -> $Modal(v)
            }
            pop_modal() {
                -> pop$
            }
            get_x(): int {
                @@:(-99)
            }
        }

        $Modal => $Frame(x: int) {
            push_modal(v: int) {
                push$
                -> $Modal(v)
            }
            pop_modal() {
                -> pop$
            }
            get_x(): int {
                @@:(x)
            }
        }

        $Frame {
        }
    domain:
        v : int = 0
}

class Program {
    static void Main(string[] args) {
        Console.WriteLine("=== Test 60: Persist × HSM × push/pop (C#) ===");
        var s1 = new PersistHsmPushpop();
        s1.push_modal(42);
        s1.push_modal(99);
        int pre = s1.get_x();
        if (pre != 99) { Console.WriteLine($"FAIL: pre {pre}"); Environment.Exit(1); }
        Console.WriteLine($"1. Pre-save top x={pre}");

        var snap = s1.SaveState();
        var s2 = new PersistHsmPushpop();

        s2.RestoreState(snap);
        int post = s2.get_x();
        if (post != 99) { Console.WriteLine($"FAIL: post {post}"); Environment.Exit(1); }
        Console.WriteLine($"2. Post-restore top x={post}");

        s2.pop_modal();
        int mid = s2.get_x();
        if (mid != 42) { Console.WriteLine($"FAIL: mid {mid}"); Environment.Exit(1); }
        Console.WriteLine($"3. After first pop x={mid}");

        s2.pop_modal();
        int bottom = s2.get_x();
        if (bottom != -99) { Console.WriteLine($"FAIL: bottom {bottom}"); Environment.Exit(1); }
        Console.WriteLine($"4. After second pop x={bottom}");

        Console.WriteLine("PASS: 60_persist_hsm_pushpop");
    }
}

@@[target("kotlin")]
@@[create(make)]
@@system Counter(seed: Int) {
    interface:
        bump()
        readCount(): Int

    machine:
        $A {
            bump() { this.count = this.count + 1 }
            readCount(): Int { @@:(this.count) }
        }

    domain:
        seed: Int = seed
        count: Int = 0
}

fun main() {
    val c1 = @@Counter(42)
    c1.bump()
    c1.bump()
    if (c1.readCount() != 2) {
        println("FAIL: via @@Counter() expected 2, got ${c1.readCount()}")
        return
    }

    val c2 = Counter.make(99)
    c2.bump()
    if (c2.readCount() != 1) {
        println("FAIL: via Counter.make expected 1, got ${c2.readCount()}")
        return
    }

    println("PASS: rfc0015_create_rename")
}

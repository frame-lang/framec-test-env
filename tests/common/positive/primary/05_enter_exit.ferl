@@target erlang

@@system EnterExit {
    interface:
        next()
        getLog(): str

    machine:
        $A {
            $>() {
                self.log = self.log ++ ",enter_a"
            }
            <$() {
                self.log = self.log ++ ",exit_a"
            }
            next() {
                -> $B
            }
            getLog(): str {
                return self.log
            }
        }

        $B {
            $>() {
                self.log = self.log ++ ",enter_b"
            }
            next() {
                -> $A
            }
            getLog(): str {
                return self.log
            }
        }

    domain:
        log = "init"
}

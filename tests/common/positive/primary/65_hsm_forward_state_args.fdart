@@target dart

import 'dart:io';

@@system StateArgFwd {
    interface:
        configure(t: int)
        process(): int

    machine:
        $Idle {
            configure(t: int) {
                -> $Active(t)
            }
            process(): int {
                @@:(0)
                return;
            }
        }

        $Active => $Frame(threshold: int) {
            configure(t: int) {
                -> $Active(t)
            }
            process(): int {
                => $^
            }
        }

        $Frame {
            process(): int {
                @@:(threshold)
                return;
            }
        }
    domain:
        n: int = 0
}

void main() {
    print("=== Test 65: HSM × state-args × parent-forward (Dart) ===");
    final s = StateArgFwd();

    final pre = s.process();
    if (pre != 0) { print("FAIL: pre $pre"); exit(1); }
    print("1. Idle process = $pre");

    s.configure(7);
    final r = s.process();
    if (r != 7) { print("FAIL: r $r"); exit(1); }
    print("2. configure(7); process() = $r");

    s.configure(42);
    final r2 = s.process();
    if (r2 != 42) { print("FAIL: r2 $r2"); exit(1); }
    print("3. configure(42); process() = $r2");

    print("PASS: 65_hsm_forward_state_args");
}

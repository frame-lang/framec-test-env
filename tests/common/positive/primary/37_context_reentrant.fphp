<?php
@@[target("php")]

@@system ContextReentrantTest {
    interface:
        outer(x: int): str
        inner(y: int): str
        deeply_nested(z: int): str
        get_both(a: int, b: int): str

    machine:
        $Ready {
            outer(x: int): str {
                @@:("outer_initial")
                $inner_result = $this->inner(@@:params.x * 10);
                @@:("outer:" . strval(@@:params.x) . ",inner:" . $inner_result)
            }

            inner(y: int): str {
                @@:(strval(@@:params.y))
            }

            deeply_nested(z: int): str {
                $outer_result = $this->outer(@@:params.z);
                @@:("deep:" . strval(@@:params.z) . "," . $outer_result)
            }

            get_both(a: int, b: int): str {
                $result_a = $this->inner(@@:params.a);
                $result_b = $this->inner(@@:params.b);
                @@:("a=" . strval(@@:params.a) . ",b=" . strval(@@:params.b) . ",results=" . $result_a . "+" . $result_b)
            }
        }
}

echo "=== Test 37: Context Reentrant ===" . "\n";
$s = @@ContextReentrantTest();

$result = $s->outer(5);
$expected = "outer:5,inner:50";
if ($result !== $expected) { echo "FAIL: Expected '{$expected}', got '{$result}'\n"; exit(1); }
echo "1. outer(5) = '{$result}'" . "\n";

$result = $s->inner(42);
if ($result !== "42") { echo "FAIL: Expected '42', got '{$result}'\n"; exit(1); }
echo "2. inner(42) = '{$result}'" . "\n";

$result = $s->deeply_nested(3);
$expected = "deep:3,outer:3,inner:30";
if ($result !== $expected) { echo "FAIL: Expected '{$expected}', got '{$result}'\n"; exit(1); }
echo "3. deeply_nested(3) = '{$result}'" . "\n";

$result = $s->get_both(10, 20);
$expected = "a=10,b=20,results=10+20";
if ($result !== $expected) { echo "FAIL: Expected '{$expected}', got '{$result}'\n"; exit(1); }
echo "4. get_both(10, 20) = '{$result}'" . "\n";

echo "PASS: Context reentrant works correctly" . "\n";

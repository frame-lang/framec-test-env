@@[target("php")]

<?php

@@[persist]
@@system Inner {
    operations:
        @@[save]
        save_state(): string {}

        @@[load]
        restore_state(data: string) {}

    interface:
        cycle()
        get_state(): string
        get_count(): int

    machine:
        $A {
            cycle() { $this->n = $this->n + 1; -> $B }
            get_state(): string { @@:("A") }
            get_count(): int { @@:($this->n) }
        }
        $B => $A {
            cycle() { -> $A }
            get_state(): string { @@:("B") }
            get_count(): int { => $^ }
        }
    domain:
        n: int = 0
}

@@[main]
@@system Outer {
    operations:
        @@[save]
        save_state(): string {}

        @@[load]
        restore_state(data: string) {}

    interface:
        tick()
        cycle_inner()
        get_outer_state(): string
        get_inner_state(): string
        get_inner_count(): int
        get_k(): int

    machine:
        $Idle {
            tick() { $this->k = $this->k + 1; -> $Active }
            cycle_inner() { $this->inner->cycle(); }
            get_outer_state(): string { @@:("Idle") }
            get_inner_state(): string { @@:($this->inner->get_state()) }
            get_inner_count(): int { @@:($this->inner->get_count()) }
            get_k(): int { @@:($this->k) }
        }
        $Active => $Idle {
            tick() { -> $Idle }
            get_outer_state(): string { @@:("Active") }
            cycle_inner() { => $^ }
            get_inner_state(): string { => $^ }
            get_inner_count(): int { => $^ }
            get_k(): int { => $^ }
        }
    domain:
        k: int = 0
        inner = @@Inner()
}

function fmtProbe($o) {
    return $o->get_outer_state() . "/" . $o->get_inner_state() . "/" . $o->get_inner_count() . "/" . $o->get_k();
}

function must($label, $o, $expected) {
    $actual = fmtProbe($o);
    if ($actual !== $expected) { echo "FAIL $label: $actual expected $expected\n"; exit(1); }
}

$o1 = new Outer();
$o2 = new Outer();

$o1->cycle_inner();
$o1->cycle_inner();
$o1->cycle_inner();
must("o1 pre", $o1, "Idle/B/2/0");

$o2->tick();
$o2->tick();
$o2->tick();
must("o2 pre", $o2, "Active/A/0/2");

$snap1 = $o1->save_state();
$snap2 = $o2->save_state();

$r2 = new Outer();


$r2->restore_state($snap2);
$r1 = new Outer();

$r1->restore_state($snap1);

must("r1 restored", $r1, "Idle/B/2/0");
must("r2 restored", $r2, "Active/A/0/2");

$r1->cycle_inner();
must("r1 after mut", $r1, "Idle/A/2/0");
must("r2 after r1 mut", $r2, "Active/A/0/2");

$r2->cycle_inner();
must("r1 after r2 mut", $r1, "Idle/A/2/0");
must("r2 after r2 mut", $r2, "Active/B/1/2");

echo "PASS: 87_persist_multi_instance\n";

@@target lua
@@system HSMEnterBoth {
    interface:
        go_to_child()
        go_to_parent()
        get_log(): list
        get_state(): str

    machine:
        $Start {
            go_to_child() {
                -> $Child
            }

            go_to_parent() {
                -> $Parent
            }

            get_log(): list {
                return self.log
            }

            get_state(): str {
                return "Start"
            }
        }

        $Child => $Parent {
            $>() {
                self.log[#self.log + 1] = "Child:enter"
            }

            go_to_parent() {
                -> $Parent
            }

            get_log(): list {
                return self.log
            }

            get_state(): str {
                return "Child"
            }
        }

        $Parent {
            $>() {
                self.log[#self.log + 1] = "Parent:enter"
            }

            go_to_child() {
                -> $Child
            }

            get_log(): list {
                return self.log
            }

            get_state(): str {
                return "Parent"
            }
        }
    domain:
        log: list = []
}

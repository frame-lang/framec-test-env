@@[target("lua")]
@@system TransitionPopTest {
    interface:
        start()
        process()
        get_state(): str
        get_log(): list

    machine:
        $Idle {
            start() {
                self.log[#self.log + 1] = "idle:start:push"
                push$
                -> $Working
            }

            process() {
                self.log[#self.log + 1] = "idle:process"
            }

            get_state(): str {
                @@:("Idle")
                return
            }

            get_log(): list {
                @@:(self.log)
                return
            }
        }

        $Working {
            process() {
                self.log[#self.log + 1] = "working:process:before_pop"
                -> pop$
                -- This should NOT execute because pop transitions away
                self.log[#self.log + 1] = "working:process:after_pop"
            }

            get_state(): str {
                @@:("Working")
                return
            }

            get_log(): list {
                @@:(self.log)
                return
            }
        }
    domain:
        log: list = []
}

@@[target("kotlin")]

import kotlin.math.abs

@@[persist]
@@system Inner {
    interface:
        bump_int()
        bump_float()
        flip_bool()
        get_n_int(): Int
        get_n_float(): Double
        get_n_bool(): Boolean
        get_n_str(): String

    machine:
        $S {
            bump_int() { this.n_int = this.n_int + 1 }
            bump_float() { this.n_float = this.n_float + 0.25 }
            flip_bool() { this.n_bool = !this.n_bool }
            get_n_int(): Int { @@:(this.n_int) }
            get_n_float(): Double { @@:(this.n_float) }
            get_n_bool(): Boolean { @@:(this.n_bool) }
            get_n_str(): String { @@:(this.n_str) }
        }
    domain:
        n_int: Int = 7
        n_float: Double = 2.5
        n_bool: Boolean = true
        n_str: String = "hello"
}

@@system Outer {
    interface:
        bump_k_int()
        bump_k_float()
        bump_inner_int()
        bump_inner_float()
        flip_inner_bool()
        get_k_int(): Int
        get_k_float(): Double
        get_n_int(): Int
        get_n_float(): Double
        get_n_bool(): Boolean
        get_n_str(): String

    machine:
        $S {
            bump_k_int() { this.k_int = this.k_int + 1 }
            bump_k_float() { this.k_float = this.k_float + 0.25 }
            bump_inner_int() { this.inner.bump_int() }
            bump_inner_float() { this.inner.bump_float() }
            flip_inner_bool() { this.inner.flip_bool() }
            get_k_int(): Int { @@:(this.k_int) }
            get_k_float(): Double { @@:(this.k_float) }
            get_n_int(): Int { @@:(this.inner.get_n_int()) }
            get_n_float(): Double { @@:(this.inner.get_n_float()) }
            get_n_bool(): Boolean { @@:(this.inner.get_n_bool()) }
            get_n_str(): String { @@:(this.inner.get_n_str()) }
        }
    domain:
        k_int: Int = 42
        k_float: Double = 1.25
        inner: Inner = @@Inner()
}

fun assertState(o: Outer, label: String, kIntStr: String, kFloat: Double, nIntStr: String, nFloat: Double, nBool: Boolean, nStr: String) {
    check(o.get_k_int().toString() == kIntStr) { "FAIL $label k_int: ${o.get_k_int()}" }
    check(o.get_n_int().toString() == nIntStr) { "FAIL $label n_int: ${o.get_n_int()}" }
    check(abs(o.get_k_float() - kFloat) < 1e-9) { "FAIL $label k_float: ${o.get_k_float()}" }
    check(abs(o.get_n_float() - nFloat) < 1e-9) { "FAIL $label n_float: ${o.get_n_float()}" }
    check(o.get_n_bool() == nBool) { "FAIL $label n_bool: ${o.get_n_bool()}" }
    check(o.get_n_str() == nStr) { "FAIL $label n_str: ${o.get_n_str()}" }
}

fun main() {
    val o = Outer()
    assertState(o, "T0", "42", 1.25, "7", 2.5, true, "hello")

    o.bump_k_int()
    o.bump_k_float()
    o.bump_inner_int()
    o.bump_inner_float()
    o.flip_inner_bool()
    assertState(o, "T1", "43", 1.5, "8", 2.75, false, "hello")

    val snap = o.save_state()
    val r = Outer.restore_state(snap)
    assertState(r, "T1 restored", "43", 1.5, "8", 2.75, false, "hello")

    r.bump_k_int()
    r.bump_inner_int()
    assertState(r, "continue", "44", 1.5, "9", 2.75, false, "hello")

    println("PASS: 86_persist_numeric_typing")
}

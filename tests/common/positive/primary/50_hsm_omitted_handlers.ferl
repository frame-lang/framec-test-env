@@[target("erlang")]
@@system HSMOmitted {
    interface:
        handled()
        unhandled()
        getLog(): str
    machine:
        $Child => $Parent {
            handled() {
                self.log = self.log ++ ",child_handled"
            }
            getLog(): str {
                @@:(self.log)
            }
        }
        $Parent {
            unhandled() {
                self.log = self.log ++ ",parent_unhandled"
            }
            getLog(): str {
                @@:(self.log)
            }
        }
    domain:
        log = "init"
}

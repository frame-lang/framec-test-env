@@target swift

// Test 39: Tagged System Instantiation
// Validates tagged instantiation syntax for tracked creation

@@system Calculator {
    interface:
        add(a: number, b: number): number
        get_result(): number

    machine:
        $Ready {
            add(a: number, b: number): number {
                self.result = a + b
                return self.result
            }

            get_result(): number {
                return self.result
            }
        }
    domain:
        result: number = 0
}

@@system Counter {
    interface:
        increment(): void
        get_count(): number

    machine:
        $Active {
            increment(): void {
                self.count = self.count + 1
            }

            get_count(): number {
                return self.count
            }
        }
    domain:
        count: number = 0
}

// main
    print("=== Test 39: Tagged System Instantiation ===")

    // Tagged instantiation - validated at transpile time
    let calc = @@Calculator()
    let counter = @@Counter()

    // Test Calculator
    var result = calc.add(3, 4)
    if result != 7 {
        print("FAIL: Expected 7, got \(result)")
        exit(1)
    }
    print("Calculator.add(3, 4) = \(result)")

    result = calc.get_result()
    if result != 7 {
        print("FAIL: Expected 7, got \(result)")
        exit(1)
    }
    print("Calculator.get_result() = \(result)")

    // Test Counter
    counter.increment()
    counter.increment()
    counter.increment()
    let count = counter.get_count()
    if count != 3 {
        print("FAIL: Expected 3, got \(count)")
        exit(1)
    }
    print("Counter after 3 increments: \(count)")

    print("PASS: Tagged instantiation works correctly")

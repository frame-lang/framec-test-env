@@[target("ruby")]

@@system HSMDefaultForward {
    interface:
        handled_event()
        unhandled_event()
        get_log(): list

    machine:
        $Child => $Parent {
            handled_event() {
                self.log.push("Child:handled_event")
            }

            get_log(): list {
                @@:(self.log)
                return
            }

            => $^
        }

        $Parent {
            handled_event() {
                self.log.push("Parent:handled_event")
            }

            unhandled_event() {
                self.log.push("Parent:unhandled_event")
            }

            get_log(): list {
                @@:(self.log)
                return
            }
        }
    domain:
        log: list = []
}

puts("=== Test 30: HSM State-Level Default Forward ===")
s = @@HSMDefaultForward()

s.handled_event()
log = s.get_log()
raise "Expected 'Child:handled_event' in log, got #{log}" unless log.include?("Child:handled_event")
puts("After handled_event: #{log}")

s.unhandled_event()
log = s.get_log()
raise "Expected 'Parent:unhandled_event' in log (forwarded), got #{log}" unless log.include?("Parent:unhandled_event")
puts("After unhandled_event (forwarded): #{log}")

puts("PASS: HSM state-level default forward works correctly")

<?php
@@[target("php")]

@@system EnterExit {
    interface:
        toggle()
        get_log(): list

    machine:
        $Off {
            $>() {
                $this->log[] = "enter:Off";
                echo "Entered Off state\n";
            }

            <$() {
                $this->log[] = "exit:Off";
                echo "Exiting Off state\n";
            }

            toggle() {
                -> $On
            }

            get_log(): list {
                @@:($this->log)
                return;
            }
        }

        $On {
            $>() {
                $this->log[] = "enter:On";
                echo "Entered On state\n";
            }

            <$() {
                $this->log[] = "exit:On";
                echo "Exiting On state\n";
            }

            toggle() {
                -> $Off
            }

            get_log(): list {
                @@:($this->log)
                return;
            }
        }
    domain:
        log = []
}

echo "=== Test 05: Enter/Exit Handlers ===" . "\n";
$s = @@EnterExit();

$log = $s->get_log();
if (!in_array("enter:Off", $log)) { echo "FAIL: Expected 'enter:Off' in log\n"; exit(1); }
echo "After construction: " . implode(", ", $log) . "\n";

$s->toggle();
$log = $s->get_log();
if (!in_array("exit:Off", $log)) { echo "FAIL: Expected 'exit:Off' in log\n"; exit(1); }
if (!in_array("enter:On", $log)) { echo "FAIL: Expected 'enter:On' in log\n"; exit(1); }
echo "After toggle to On: " . implode(", ", $log) . "\n";

$s->toggle();
$log = $s->get_log();
$enter_off_count = count(array_filter($log, function($v) { return $v === "enter:Off"; }));
if ($enter_off_count !== 2) { echo "FAIL: Expected 2 'enter:Off' entries\n"; exit(1); }
if (!in_array("exit:On", $log)) { echo "FAIL: Expected 'exit:On' in log\n"; exit(1); }
echo "After toggle to Off: " . implode(", ", $log) . "\n";

echo "PASS: Enter/Exit handlers work correctly" . "\n";

@@[target("javascript")]

@@system Demo {
    interface:
        common(): string
        @@[target("python_3")] only_py(): string
        @@[target("javascript")] only_js(): string

    machine:
        $S {
            common(): string { @@:("common") }
            @@[target("python_3")] only_py(): string { @@:("only_py_present") }
            @@[target("javascript")] only_js(): string { @@:("only_js_present") }
        }
}

const d = @@Demo();
if (d.common() !== "common") { console.log("FAIL common: " + d.common()); process.exit(1); }
if (d.only_js() !== "only_js_present") { console.log("FAIL only_js: " + d.only_js()); process.exit(1); }
if (typeof d.only_py === "function") {
    console.log("FAIL: only_py should have been filtered out by @@[target(\"python_3\")]");
    process.exit(1);
}
console.log("PASS: 89_attribute_per_item");

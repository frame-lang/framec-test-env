@@target rust

@@system PushSelf {
    interface:
        enter_modal()
        ping(): i32
        exit_modal()
        compute(): i32

    machine:
        $Idle {
            enter_modal() { push$; -> $Modal }
            ping(): i32 { @@:(0); return; }
            compute(): i32 { @@:(99); return; }
        }
        $Modal {
            ping(): i32 { @@:(self.compute() + 1); return; }
            compute(): i32 { @@:(10); return; }
            exit_modal() { -> pop$ }
        }
    domain: n: i32
}

fn main() {
    let mut s = @@PushSelf();
    if s.ping() != 0 { println!("FAIL idle"); std::process::exit(1); }
    s.enter_modal();
    let r = s.ping();
    if r != 11 { println!("FAIL modal {}", r); std::process::exit(1); }
    s.exit_modal();
    if s.ping() != 0 { println!("FAIL back"); std::process::exit(1); }
    println!("PASS: 72_push_self_call");
}

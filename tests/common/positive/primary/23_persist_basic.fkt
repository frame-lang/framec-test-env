@@[target("kotlin")]

import kotlin.system.exitProcess

@@[persist(String)]
@@[save(save_state)]
@@[load(restore_state)]
@@system PersistTest {
    interface:
        set_value(v: Int)
        get_value(): Int
        go_active()
        go_idle()

    machine:
        $Idle {
            set_value(v: Int) { value = v }
            get_value(): Int {
                @@:(value)
            }
            go_active() { -> $Active }
            go_idle() { }
        }

        $Active {
            set_value(v: Int) { value = v * 2 }
            get_value(): Int {
                @@:(value)
            }
            go_active() { }
            go_idle() { -> $Idle }
        }
    domain:
        value : Int = 0
        name : String = "default"
}

fun main() {
    println("=== Test 23: Persist Basic (Kotlin) ===")

    val s1 = PersistTest()
    s1.set_value(10)
    s1.go_active()
    s1.set_value(5)

    val json = s1.save_state() as String
    if (!json.contains("\"Active\"")) {
        println("FAIL: Expected Active in JSON"); exitProcess(1)
    }
    if (!json.contains("\"value\":10")) {
        println("FAIL: Expected value 10 in JSON"); exitProcess(1)
    }
    println("1. Saved: $json")

    val s2 = PersistTest()
    s2.restore_state(json)
    if ((s2.get_value() as Int) != 10) {
        println("FAIL: Restored value ${s2.get_value()}"); exitProcess(1)
    }
    println("2. Restored value: ${s2.get_value()}")

    s2.set_value(3)
    if ((s2.get_value() as Int) != 6) {
        println("FAIL: Expected 6, got ${s2.get_value()}"); exitProcess(1)
    }
    println("3. After set_value(3) in Active: ${s2.get_value()}")

    s2.go_idle()
    s2.set_value(4)
    if ((s2.get_value() as Int) != 4) {
        println("FAIL: Expected 4, got ${s2.get_value()}"); exitProcess(1)
    }
    println("4. After go_idle, set_value(4): ${s2.get_value()}")

    println("PASS: Persist basic works correctly")
}

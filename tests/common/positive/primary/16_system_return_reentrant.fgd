@@[target("gdscript")]
extends SceneTree

# Tests that nested interface calls maintain separate return contexts

@@system SystemReturnReentrantTest {
    interface:
        outer_call(): String
        inner_call(): String
        nested_call(): String
        get_log(): String

    machine:
        $Start {
            $.log: str = ""

            outer_call(): String {
                $.log = $.log + "outer_start,"
                # Call inner method - this creates nested return context
                var inner_result = self.inner_call()
                $.log = $.log + "outer_after_inner,"
                # Our return should be independent of inner's return
                @@:("outer_result:" + inner_result)
                return
            }

            inner_call(): String {
                $.log = $.log + "inner,"
                @@:("inner_result")
                return
            }

            nested_call(): String {
                $.log = $.log + "nested_start,"
                # Two levels of nesting
                var result1 = self.inner_call()
                var result2 = self.outer_call()
                $.log = $.log + "nested_end,"
                @@:("nested:" + result1 + "+" + result2)
                return
            }

            get_log(): String {
                @@:($.log)
                return
            }
        }
}

func main():
    print("=== Test 16: System Return Reentrant (Nested Calls) ===")

    # Test 1: Simple inner call
    var s1 = @@SystemReturnReentrantTest()
    var result = s1.inner_call()
    assert(result == "inner_result", "Expected 'inner_result', got '" + str(result) + "'")
    print("1. inner_call() = '" + str(result) + "'")

    # Test 2: Outer calls inner - return contexts should be separate
    var s2 = @@SystemReturnReentrantTest()
    result = s2.outer_call()
    assert(result == "outer_result:inner_result", "Expected 'outer_result:inner_result', got '" + str(result) + "'")
    var log = s2.get_log()
    assert("outer_start" in log, "Missing outer_start in log: " + str(log))
    assert("inner" in log, "Missing inner in log: " + str(log))
    assert("outer_after_inner" in log, "Missing outer_after_inner in log: " + str(log))
    print("2. outer_call() = '" + str(result) + "'")
    print("   Log: '" + str(log) + "'")

    # Test 3: Deeply nested calls
    var s3 = @@SystemReturnReentrantTest()
    result = s3.nested_call()
    var expected = "nested:inner_result+outer_result:inner_result"
    assert(result == expected, "Expected '" + str(expected) + "', got '" + str(result) + "'")
    print("3. nested_call() = '" + str(result) + "'")

    print("PASS: System return reentrant (nested calls) works correctly")

func _init():
    main()
    quit()

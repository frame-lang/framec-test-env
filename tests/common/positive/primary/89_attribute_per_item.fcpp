@@[target("cpp")]

#include <iostream>
#include <string>
#include <cstdlib>

@@system Demo {
    interface:
        common(): std::string
        @@[target("python_3")] only_py(): std::string
        @@[target("cpp")] only_cpp(): std::string

    machine:
        $S {
            common(): std::string { @@:(std::string("common")) }
            @@[target("python_3")] only_py(): std::string { @@:(std::string("only_py_present")) }
            @@[target("cpp")] only_cpp(): std::string { @@:(std::string("only_cpp_present")) }
        }
}

int main() {
    auto d = @@Demo();
    if (d.common() != "common") { std::cout << "FAIL common: " << d.common() << std::endl; std::exit(1); }
    if (d.only_cpp() != "only_cpp_present") { std::cout << "FAIL only_cpp: " << d.only_cpp() << std::endl; std::exit(1); }
    std::cout << "PASS: 89_attribute_per_item" << std::endl;
    return 0;
}

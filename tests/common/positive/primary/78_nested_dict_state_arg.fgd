@@[target("gdscript")]
extends SceneTree

@@[persist]
@@system NestedDict {
    interface:
        configure(m: Dictionary)
        get_inner(outer_key: String, inner_key: String): int

    machine:
        $Idle {
            configure(m: Dictionary) { -> $Active(m) }
            get_inner(outer_key: String, inner_key: String): int { @@:(-1) }
        }
        $Active(m: Dictionary) {
            configure(m: Dictionary) { -> $Active(m) }
            get_inner(outer_key: String, inner_key: String): int {
                var __o = m.get(outer_key, {})
                @@:(__o.get(inner_key, -1))
            }
        }
    domain:
        n: int = 0
}

func _initialize():
    var s1 = NestedDict.new()
    s1.configure({"u": {"x": 1, "y": 2}, "v": {"z": 3}})
    if s1.get_inner("u", "x") != 1:
        print("FAIL pre"); quit(1); return
    var snap = s1.save_state()
    var s2 = NestedDict.restore_state(snap)
    if s2.get_inner("u", "x") != 1:
        print("FAIL post u.x"); quit(1); return
    if s2.get_inner("u", "y") != 2:
        print("FAIL post u.y"); quit(1); return
    if s2.get_inner("v", "z") != 3:
        print("FAIL post v.z"); quit(1); return
    print("PASS: 78_nested_dict_state_arg")

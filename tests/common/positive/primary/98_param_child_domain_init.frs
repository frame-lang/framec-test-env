@@[target("rust")]

// RFC-0017 regression: see .fpy header.

@@system Counter(seed: i32) {
    interface:
        bump()
        get_value(): i32
    machine:
        $S {
            $> { self.n = self.seed; }
            bump() { self.n = self.n + 1; }
            get_value(): i32 { @@:(self.n) }
        }
    domain:
        seed: i32 = seed
        n: i32 = 0
}

@@[main]
@@system World {
    interface:
        bump_c()
        bump_d()
        get_c(): i32
        get_d(): i32
    machine:
        $S {
            bump_c() { self.c.bump(); }
            bump_d() { self.d.bump(); }
            get_c(): i32 { @@:(self.c.get_value()) }
            get_d(): i32 { @@:(self.d.get_value()) }
        }
    domain:
        c: Counter = @@Counter(7)
        d: Counter = @@Counter(11)
}

fn main() {
    let mut w = @@World();
    assert_eq!(w.get_c(), 7, "FAIL initial c");
    assert_eq!(w.get_d(), 11, "FAIL initial d");
    w.bump_c();
    w.bump_d();
    assert_eq!(w.get_c(), 8, "FAIL bump_c");
    assert_eq!(w.get_d(), 12, "FAIL bump_d");
    println!("PASS: 98_param_child_domain_init");
}

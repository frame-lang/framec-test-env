@@target dart
// ====================================================
// Test 01: Interface Return
// ====================================================
// Validates that event handler returns work correctly via the context stack.
// Tests both syntaxes:
//   - return value     (sugar - expands to @@:return = value)
//   - @@:return = value (explicit context assignment)
// ====================================================

@@system InterfaceReturn {
    interface:
        bool_return(): bool
        int_return(): num
        string_return(): String
        conditional_return(x: num): String
        computed_return(a: num, b: num): num
        explicit_bool(): bool
        explicit_int(): num
        explicit_string(): String
        explicit_conditional(x: num): String
        explicit_computed(a: num, b: num): num

    machine:
        $Active {
            bool_return(): bool {
                @@:(true)
                return;
            }

            int_return(): num {
                @@:(42)
                return;
            }

            string_return(): String {
                @@:("Frame")
                return;
            }

            conditional_return(x: num): String {
                if (x < 0) {
                    @@:("negative")
                    return;
                } else if (x == 0) {
                    @@:("zero")
                    return;
                } else {
                    @@:("positive")
                    return;
                }
            }

            computed_return(a: num, b: num): num {
                final result = a * b + 10;
                @@:(result)
                return;
            }

            explicit_bool(): bool {
                @@:return = true;
            }

            explicit_int(): num {
                @@:return = 42;
            }

            explicit_string(): String {
                @@:return = "Frame";
            }

            explicit_conditional(x: num): String {
                if (x < 0) {
                    @@:return = "negative";
                    return;
                } else if (x == 0) {
                    @@:return = "zero";
                    return;
                } else {
                    @@:return = "positive";
                }
            }

            explicit_computed(a: num, b: num): num {
                final result = a * b + 10;
                @@:return = result;
            }
        }
}

void main() {
    print("== Test 01: Interface Return (TypeScript) ==");
    final s = @@InterfaceReturn();
    final errors = [];

    print("-- Testing 'return value' sugar --");

    dynamic r = s.bool_return();
    if (r != true) {
        errors.add("bool_return: expected true, got ${r}");
    } else {
        print("1. bool_return() = ${r}");
    }

    r = s.int_return();
    if (r != 42) {
        errors.add("int_return: expected 42, got ${r}");
    } else {
        print("2. int_return() = ${r}");
    }

    r = s.string_return();
    if (r != "Frame") {
        errors.add("string_return: expected 'Frame', got '${r}'");
    } else {
        print("3. string_return() = '${r}'");
    }

    r = s.conditional_return(-5);
    if (r != "negative") {
        errors.add("conditional_return(-5): expected 'negative', got '${r}'");
    }
    r = s.conditional_return(0);
    if (r != "zero") {
        errors.add("conditional_return(0): expected 'zero', got '${r}'");
    }
    r = s.conditional_return(10);
    if (r != "positive") {
        errors.add("conditional_return(10): expected 'positive', got '${r}'");
    } else {
        print("4. conditional_return(-5,0,10) = 'negative','zero','positive'");
    }

    r = s.computed_return(3, 4);
    if (r != 22) {
        errors.add("computed_return(3,4): expected 22, got ${r}");
    } else {
        print("5. computed_return(3,4) = ${r}");
    }

    print("-- Testing '@@:return = value' explicit --");

    r = s.explicit_bool();
    if (r != true) {
        errors.add("explicit_bool: expected true, got ${r}");
    } else {
        print("6. explicit_bool() = ${r}");
    }

    r = s.explicit_int();
    if (r != 42) {
        errors.add("explicit_int: expected 42, got ${r}");
    } else {
        print("7. explicit_int() = ${r}");
    }

    r = s.explicit_string();
    if (r != "Frame") {
        errors.add("explicit_string: expected 'Frame', got '${r}'");
    } else {
        print("8. explicit_string() = '${r}'");
    }

    r = s.explicit_conditional(-5);
    if (r != "negative") {
        errors.add("explicit_conditional(-5): expected 'negative', got '${r}'");
    }
    r = s.explicit_conditional(0);
    if (r != "zero") {
        errors.add("explicit_conditional(0): expected 'zero', got '${r}'");
    }
    r = s.explicit_conditional(10);
    if (r != "positive") {
        errors.add("explicit_conditional(10): expected 'positive', got '${r}'");
    } else {
        print("9. explicit_conditional(-5,0,10) = 'negative','zero','positive'");
    }

    r = s.explicit_computed(3, 4);
    if (r != 22) {
        errors.add("explicit_computed(3,4): expected 22, got ${r}");
    } else {
        print("10. explicit_computed(3,4) = ${r}");
    }

    if (errors.length > 0) {
        for (final e in errors) {
            print("FAIL: ${e}");
        }
        throw Exception("${errors.length} test(s) failed");
    } else {
        print("PASS: All interface return tests passed");
    }
}


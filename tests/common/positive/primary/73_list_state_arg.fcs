@@[target("csharp")]


@@system ListStateArg {
    interface:
        configure(items: List<int>)
        first_item(): int
        size(): int

    machine:
        $Idle {
            configure(items: List<int>) {
                -> $Active(items)
            }
            first_item(): int {
                @@:(-1)
            }
            size(): int {
                @@:(0)
            }
        }
        $Active(items: List<int>) {
            configure(items: List<int>) {
                -> $Active(items)
            }
            first_item(): int {
                @@:(items[0])
            }
            size(): int {
                @@:(items.Count)
            }
        }
    domain:
        n : int = 0
}

class Program {
    static void Main(string[] args) {
        var s = @@ListStateArg();
        if (s.first_item() != -1) { Console.WriteLine("FAIL idle first_item"); Environment.Exit(1); }
        if (s.size() != 0) { Console.WriteLine("FAIL idle size"); Environment.Exit(1); }
        s.configure(new List<int> { 10, 20, 30 });
        if (s.first_item() != 10) { Console.WriteLine("FAIL active first_item"); Environment.Exit(1); }
        if (s.size() != 3) { Console.WriteLine("FAIL active size"); Environment.Exit(1); }
        s.configure(new List<int> { 7 });
        if (s.first_item() != 7) { Console.WriteLine("FAIL retransition first_item"); Environment.Exit(1); }
        if (s.size() != 1) { Console.WriteLine("FAIL retransition size"); Environment.Exit(1); }
        Console.WriteLine("PASS: 73_list_state_arg");
    }
}

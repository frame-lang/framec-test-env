@@[target("csharp")]

using System;

@@system FloatStateArg {
    interface:
        configure(rate: float)
        scale(v: float): float

    machine:
        $Idle {
            configure(rate: double) {
                -> $Active(rate)
            }
            scale(v: double): double {
                @@:(v)
            }
        }

        $Active => $Frame(rate: double) {
            configure(rate: double) {
                -> $Active(rate)
            }
            scale(v: double): double {
                => $^
            }
        }

        $Frame {
            scale(v: double): double {
                @@:(v * rate)
            }
        }
    domain:
        n : int = 0
}

class Program {
    static void Main(string[] args) {
        var s = new FloatStateArg();
        if (Math.Abs(s.scale(2.0) - 2.0) > 1e-9) { Console.WriteLine("FAIL idle"); Environment.Exit(1); }
        s.configure(0.5);
        if (Math.Abs(s.scale(10.0) - 5.0) > 1e-9) { Console.WriteLine("FAIL 0.5"); Environment.Exit(1); }
        s.configure(2.5);
        if (Math.Abs(s.scale(4.0) - 10.0) > 1e-9) { Console.WriteLine("FAIL 2.5"); Environment.Exit(1); }
        Console.WriteLine("PASS: 68_hsm_float_state_args");
    }
}

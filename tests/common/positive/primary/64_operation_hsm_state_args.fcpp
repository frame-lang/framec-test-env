@@[target("cpp_17")]

#include <iostream>
#include <string>
#include <cstdlib>

@@system OpHsmStateArgs {
    operations:
        add_offset(x: int, off: int): int {
            return x + off;
        }

    interface:
        enter_active(t: int)
        classify(v: int): int

    machine:
        $Idle {
            enter_active(t: int) {
                -> $Active(t)
            }
            classify(v: int): int {
                @@:(-1)
            }
        }

        $Active => $Frame(threshold: int) {
            enter_active(t: int) {
                -> $Active(t)
            }
            classify(v: int): int {
                int r = this->add_offset(v, threshold);
                @@:(r)
            }
        }

        $Frame {
        }
    domain:
        n : int = 0
}

int main() {
    std::cout << "=== Test 64: Operations × HSM × state-args (C++) ===" << std::endl;
    OpHsmStateArgs s;

    int pre = s.classify(5);
    if (pre != -1) { std::cout << "FAIL: pre " << pre << std::endl; return 1; }
    std::cout << "1. Idle classify(5) = " << pre << std::endl;

    s.enter_active(10);
    int r = s.classify(5);
    if (r != 15) { std::cout << "FAIL: r " << r << std::endl; return 1; }
    std::cout << "2. classify(5) with threshold=10 -> " << r << std::endl;

    int r2 = s.classify(7);
    if (r2 != 17) { std::cout << "FAIL: r2 " << r2 << std::endl; return 1; }
    std::cout << "3. classify(7) with threshold=10 -> " << r2 << std::endl;

    s.enter_active(100);
    int r3 = s.classify(5);
    if (r3 != 105) { std::cout << "FAIL: r3 " << r3 << std::endl; return 1; }
    std::cout << "4. classify(5) with threshold=100 -> " << r3 << std::endl;

    std::cout << "PASS: 64_operation_hsm_state_args" << std::endl;
    return 0;
}

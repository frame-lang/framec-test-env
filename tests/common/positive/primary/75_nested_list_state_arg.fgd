@@[target("gdscript")]
extends SceneTree

@@[persist]
@@system NestedList {
    interface:
        configure(rows: Array)
        first_first(): int
        outer_size(): int

    machine:
        $Idle {
            configure(rows: Array) { -> $Active(rows) }
            first_first(): int { @@:(-1) }
            outer_size(): int { @@:(0) }
        }
        $Active(rows: Array) {
            configure(rows: Array) { -> $Active(rows) }
            first_first(): int { @@:(rows[0][0]) }
            outer_size(): int { @@:(rows.size()) }
        }
    domain:
        n: int = 0
}

func _initialize():
    var s1 = NestedList.new()
    s1.configure([[10, 20], [30, 40]])
    if s1.first_first() != 10:
        print("FAIL pre"); quit(1); return
    if s1.outer_size() != 2:
        print("FAIL size"); quit(1); return
    var snap = s1.save_state()
    var s2 = NestedList.restore_state(snap)
    if s2.first_first() != 10:
        print("FAIL post"); quit(1); return
    if s2.outer_size() != 2:
        print("FAIL post size"); quit(1); return
    print("PASS: 75_nested_list_state_arg")

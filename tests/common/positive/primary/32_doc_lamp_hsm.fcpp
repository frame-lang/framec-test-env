@@[target("cpp_17")]

#include <iostream>
#include <string>
#include <cassert>

// Documentation Example: HSM Lamp with color behavior factored out

@@system LampHSM {
    interface:
        turnOn()
        turnOff()
        getColor(): std::string
        setColor(color: std::string)
        isLampOn(): bool

    machine:
        $Off => $ColorBehavior {
            turnOn() {
                -> $On
            }
            isLampOn(): bool {
                @@:(lamp_on)
                return;
            }
            => $^
        }

        $On => $ColorBehavior {
            $>() {
                this->turnOnLamp();
            }
            <$() {
                this->turnOffLamp();
            }
            turnOff() {
                -> $Off
            }
            isLampOn(): bool {
                @@:(lamp_on)
                return;
            }
            => $^
        }

        $ColorBehavior {
            getColor(): std::string {
                @@:(color)
                return;
            }
            setColor(color: std::string) {
                this->color = color;
            }
        }

    actions:
        turnOnLamp() {
            lamp_on = true;
        }
        turnOffLamp() {
            lamp_on = false;
        }

    domain:
        color : std::string = "white"
        lamp_on : bool = false
}

int main() {
    printf("=== Test 32: Doc Lamp HSM ===\n");
    auto lamp = @@LampHSM();

    if (lamp.getColor() != "white") {
        printf("FAIL: Expected 'white', got '%s'\n", lamp.getColor().c_str());
        assert(false);
    }
    lamp.setColor("red");
    if (lamp.getColor() != "red") {
        printf("FAIL: Expected 'red', got '%s'\n", lamp.getColor().c_str());
        assert(false);
    }

    lamp.turnOn();
    if (lamp.isLampOn() != true) {
        printf("FAIL: Lamp should be on\n");
        assert(false);
    }

    lamp.setColor("green");
    if (lamp.getColor() != "green") {
        printf("FAIL: Expected 'green', got '%s'\n", lamp.getColor().c_str());
        assert(false);
    }

    lamp.turnOff();
    if (lamp.isLampOn() != false) {
        printf("FAIL: Lamp should be off\n");
        assert(false);
    }

    if (lamp.getColor() != "green") {
        printf("FAIL: Expected 'green', got '%s'\n", lamp.getColor().c_str());
        assert(false);
    }

    printf("PASS: HSM lamp works correctly\n");
    return 0;
}

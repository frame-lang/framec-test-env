@@[target("dart")]

import 'dart:io';

@@system Demo {
    interface:
        common(): String
        @@[target("python_3")] only_py(): String
        @@[target("dart")] only_dart(): String

    machine:
        $S {
            common(): String { @@:("common") }
            @@[target("python_3")] only_py(): String { @@:("only_py_present") }
            @@[target("dart")] only_dart(): String { @@:("only_dart_present") }
        }
}

void main() {
    var d = @@Demo();
    if (d.common() != "common") { print("FAIL common: ${d.common()}"); exit(1); }
    if (d.only_dart() != "only_dart_present") { print("FAIL only_dart: ${d.only_dart()}"); exit(1); }
    print("PASS: 89_attribute_per_item");
}

@@[target("kotlin")]

@@system StrStateArg {
    interface:
        configure(label: str)
        identify(): str

    machine:
        $Idle {
            configure(label: str) {
                -> $Active(label)
            }
            identify(): str {
                @@:("anonymous")
            }
        }

        $Active => $Frame(label: str) {
            configure(label: str) {
                -> $Active(label)
            }
            identify(): str {
                => $^
            }
        }

        $Frame {
            identify(): str {
                @@:(label)
            }
        }
    domain:
        n : int = 0
}

fun main() {
    val s = @@StrStateArg()
    if (s.identify() != "anonymous") { println("FAIL idle"); kotlin.system.exitProcess(1) }
    s.configure("alice")
    if (s.identify() != "alice") { println("FAIL alice"); kotlin.system.exitProcess(1) }
    s.configure("bob")
    if (s.identify() != "bob") { println("FAIL bob"); kotlin.system.exitProcess(1) }
    println("PASS: 66_hsm_str_state_args")
}

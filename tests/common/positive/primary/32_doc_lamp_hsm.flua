@@target lua
@@system LampHSM {
    interface:
        turnOn()
        turnOff()
        getColor(): str
        setColor(color: str)

    machine:
        $Off => $ColorBehavior {
            turnOn() {
                -> $On
            }
            => $^
        }

        $On => $ColorBehavior {
            $>() {
                self.turnOnLamp()
            }
            <$() {
                self.turnOffLamp()
            }
            turnOff() {
                -> $Off
            }
            => $^
        }

        $ColorBehavior {
            getColor(): str {
                return self.color
            }
            setColor(color: str) {
                self.color = color
            }
        }

    actions:
        turnOnLamp() {
            self.lamp_on = True
        }
        turnOffLamp() {
            self.lamp_on = False
        }

    domain:
        color: str = "white"
        lamp_on: bool = False
}

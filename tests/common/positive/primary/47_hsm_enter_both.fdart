@@target dart
import 'dart:convert';

// Test 47: HSM Enter Cascade — Both Parent and Child have $>
//
// Tests the HSM enter cascade per docs/frame_runtime_introduction.md
// Step 21+. When entering an HSM child, the kernel fires $> on every
// layer of the new chain top-down (parent first, child last).

@@system HSMEnterBoth {
    interface:
        go_to_child()
        go_to_parent()
        get_log(): List<String>
        get_state(): str

    machine:
        $Start {
            go_to_child() { -> $Child }
            go_to_parent() { -> $Parent }
            get_log(): list { @@:(this.log) }
            get_state(): str { @@:("Start") }
        }

        $Child => $Parent {
            $>() {
                this.log.add("Child:enter");
            }
            go_to_parent() { -> $Parent }
            get_log(): list { @@:(this.log) }
            get_state(): str { @@:("Child") }
        }

        $Parent {
            $>() {
                this.log.add("Parent:enter");
            }
            go_to_child() { -> $Child }
            get_log(): list { @@:(this.log) }
            get_state(): str { @@:("Parent") }
        }
    domain:
        log : List<String> = []
}

void main() {
    print("=== Test 47: HSM Enter Cascade — Both ===");
    final s = @@HSMEnterBoth();

    s.go_to_child();
    var log = s.get_log();
    if (s.get_state() != "Child") throw Exception("Expected Child");
    final pi = log.indexOf("Parent:enter");
    final ci = log.indexOf("Child:enter");
    if (pi == -1) throw Exception("Expected Parent:enter");
    if (ci == -1) throw Exception("Expected Child:enter");
    if (pi >= ci) throw Exception("Parent:enter must precede Child:enter (top-down)");
    print("TC1: Parent's \$> fires before Child's \$> on cascade entry - PASS");

    s.go_to_parent();
    log = s.get_log();
    if (s.get_state() != "Parent") throw Exception("Expected Parent");
    if (log.where((x) => x == "Parent:enter").length != 2) throw Exception("Expected 2 Parent:enter");
    if (log.where((x) => x == "Child:enter").length != 1) throw Exception("Expected still 1 Child:enter");
    print("TC2: Direct Parent entry fires only Parent's \$> - PASS");

    s.go_to_child();
    log = s.get_log();
    if (log.where((x) => x == "Parent:enter").length != 3) throw Exception("Expected 3 Parent:enter total");
    if (log.where((x) => x == "Child:enter").length != 2) throw Exception("Expected 2 Child:enter total");
    print("TC3: Re-entering Child cascades through Parent again - PASS");

    print("PASS: HSM enter cascade fires both layers top-down");
}

@@target dart
import 'dart:convert';
// Test 47: HSM Enter in Both Child and Parent
//
// Tests enter handler in both levels:
// - Only child's enter fires when entering child
// - Parent's enter fires only when transitioning to parent
// - No implicit cascading of enter handlers

@@system HSMEnterBoth {
    interface:
        go_to_child()
        go_to_parent()
        get_log(): List<String>
        get_state(): str

    machine:
        $Start {
            go_to_child() {
                -> $Child
            }

            go_to_parent() {
                -> $Parent
            }

            get_log(): list {
                @@:(this.log)
                return;
            }

            get_state(): str {
                @@:("Start")
                return;
            }
        }

        $Child => $Parent {
            $>() {
                this.log.add("Child:enter");
            }

            go_to_parent() {
                -> $Parent
            }

            get_log(): list {
                @@:(this.log)
                return;
            }

            get_state(): str {
                @@:("Child")
                return;
            }
        }

        $Parent {
            $>() {
                this.log.add("Parent:enter");
            }

            go_to_child() {
                -> $Child
            }

            get_log(): list {
                @@:(this.log)
                return;
            }

            get_state(): str {
                @@:("Parent")
                return;
            }
        }
    domain:
        List<String> log = []
}

void main() {
    print("== Test 47: HSM Enter in Both ==");
    final s = @@HSMEnterBoth();

    // TC2.3.1: Only child's enter fires when entering child
    s.go_to_child();
    var log = s.get_log();
    if (!log.contains("Child:enter")) throw Exception("Expected Child:enter, got ${jsonEncode(log)}");
    if (log.contains("Parent:enter")) throw Exception("Parent:enter should NOT fire when entering child, got ${jsonEncode(log)}");
    if (s.get_state() != "Child") throw Exception("Expected Child, got ${s.get_state()}");
    print("TC2.3.1: Only child's enter fires when entering child - PASS");

    // TC2.3.2: Parent's enter fires only when transitioning to parent
    s.go_to_parent();
    log = s.get_log();
    if (!log.contains("Parent:enter")) throw Exception("Expected Parent:enter, got ${jsonEncode(log)}");
    if (s.get_state() != "Parent") throw Exception("Expected Parent, got ${s.get_state()}");
    print("TC2.3.2: Parent's enter fires when transitioning to parent - PASS");

    // TC2.3.3: No implicit cascading - counts should be exactly 1 each
    final childCount = log.where((x) => x == "Child:enter").length;
    final parentCount = log.where((x) => x == "Parent:enter").length;
    if (childCount != 1) throw Exception("Expected exactly 1 Child:enter, got ${jsonEncode(log)}");
    if (parentCount != 1) throw Exception("Expected exactly 1 Parent:enter, got ${jsonEncode(log)}");
    print("TC2.3.3: No implicit cascading of enter handlers - PASS");

    // TC2.3.4: Going back to child fires child enter again
    s.go_to_child();
    log = s.get_log();
    final childCount2 = log.where((x) => x == "Child:enter").length;
    final parentCount2 = log.where((x) => x == "Parent:enter").length;
    if (childCount2 != 2) throw Exception("Expected 2 Child:enter, got ${jsonEncode(log)}");
    if (parentCount2 != 1) throw Exception("Expected still 1 Parent:enter, got ${jsonEncode(log)}");
    print("TC2.3.4: Re-entering child fires child enter again - PASS");

    print("PASS: HSM enter in both works correctly");
}


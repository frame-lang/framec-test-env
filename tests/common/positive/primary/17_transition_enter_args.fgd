@@target gdscript

@@system TransitionEnterArgs {
    interface:
        start()
        get_log(): list

    machine:
        $Idle {
            start() {
                self.log.append("idle:start")
                -> ("from_idle", 42) $Active
            }

            get_log(): list {
                @@:(self.log)
                return
            }
        }

        $Active {
            $>(source: str, value: int) {
                self.log.append("active:enter:" + str(source) + ":" + str(value))
            }

            start() {
                self.log.append("active:start")
            }

            get_log(): list {
                @@:(self.log)
                return
            }
        }
    domain:
        log: list = []
}

func main():
    print("=== Test 17: Transition Enter Args ===")
    s = @@TransitionEnterArgs()

    # Initial state is Idle
    log = s.get_log()
    assert(log == [], "Expected empty log, got " + str(log))

    # Transition to Active with args
    s.start()
    log = s.get_log()
    assert("idle:start" in log, "Expected 'idle:start' in log, got " + str(log))
    assert("active:enter:from_idle:42" in log, "Expected 'active:enter:from_idle:42' in log, got " + str(log))
    print("Log after transition: " + str(log))

    print("PASS: Transition enter args work correctly")

func _ready():
    main()

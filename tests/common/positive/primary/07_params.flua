@@target lua
@@system WithParams {
    interface:
        start(initial: int)
        add(value: int)
        multiply(a: int, b: int): int
        get_total(): int

    machine:
        $Idle {
            start(initial: int) {
                self.total = initial
                -- print
                -> $Running
            }

            add(value: int) {
                -- print
            
            }

            multiply(a: int, b: int): int {
                return 0
            }

            get_total(): int {
                return self.total
            }
        }

        $Running {
            start(initial: int) {
                -- print
            
            }

            add(value: int) {
                self.total = self.total + value
                -- print
            }

            multiply(a: int, b: int): int {
                result = a * b
                self.total = self.total + result
                -- print
                return result
            }

            get_total(): int {
                return self.total
            }
        }
    domain:
        total: int = 0
}

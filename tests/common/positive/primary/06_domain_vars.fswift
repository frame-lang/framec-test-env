@@target swift

@@system DomainVars {
    interface:
        increment()
        decrement()
        get_count(): number
        set_count(value: number)

    machine:
        $Counting {
            increment() {
                self.count += 1
                print("\(self.name): incremented to \(self.count)")
            }

            decrement() {
                self.count -= 1
                print("\(self.name): decremented to \(self.count)")
            }

            get_count(): number {
                return self.count
            }

            set_count(value: number) {
                self.count = value
                print("\(self.name): set to \(self.count)")
            }
        }
    domain:
        count: number = 0
        name: string = "counter"
}

// main
    print("=== Test 06: Domain Variables ===")
    let s = @@DomainVars()

    // Initial value should be 0
    var count = s.get_count()
    if count != 0 {
        fatalError("Expected initial count=0, got \(count)")
    }
    print("Initial count: \(count)")

    // Increment
    s.increment()
    count = s.get_count()
    if count != 1 {
        fatalError("Expected count=1, got \(count)")
    }

    s.increment()
    count = s.get_count()
    if count != 2 {
        fatalError("Expected count=2, got \(count)")
    }

    // Decrement
    s.decrement()
    count = s.get_count()
    if count != 1 {
        fatalError("Expected count=1, got \(count)")
    }

    // Set directly
    s.set_count(100)
    count = s.get_count()
    if count != 100 {
        fatalError("Expected count=100, got \(count)")
    }

    print("Final count: \(count)")
    print("PASS: Domain variables work correctly")

@@target go

package main

import (
	"fmt"
	"os"
)

@@system HsmFourLevel {
    interface:
        Drive(): int
        WriteAtLevel(level: int)
        GetN(): int

    machine:
        $Leaf => $Mid {
            Drive(): int {
                => $^
            }
            WriteAtLevel(level: int) {
                s.n = s.n + level * 1
                => $^
            }
            GetN(): int {
                @@:(s.n)
                return;
            }
        }

        $Mid => $Branch {
            Drive(): int {
                => $^
            }
            WriteAtLevel(level: int) {
                s.n = s.n + level * 10
                => $^
            }
        }

        $Branch => $Root {
            Drive(): int {
                => $^
            }
            WriteAtLevel(level: int) {
                s.n = s.n + level * 100
                => $^
            }
        }

        $Root {
            Drive(): int {
                @@:(s.n)
                return;
            }
            WriteAtLevel(level: int) {
                s.n = s.n + level * 1000
            }
        }
    domain:
        n: int = 0
}

func main() {
    fmt.Println("=== Test 61: 4-level HSM cascade (Go) ===")
    s := NewHsmFourLevel()

    initial := s.Drive()
    if initial != 0 { fmt.Printf("FAIL: initial %d\n", initial); os.Exit(1) }
    fmt.Printf("1. Initial drive returned %d\n", initial)

    s.WriteAtLevel(2)
    after := s.GetN()
    if after != 2222 { fmt.Printf("FAIL: after %d\n", after); os.Exit(1) }
    fmt.Printf("2. After cascading write: n=%d\n", after)

    final := s.Drive()
    if final != 2222 { fmt.Printf("FAIL: final %d\n", final); os.Exit(1) }
    fmt.Printf("3. Drive after write returned %d\n", final)

    fmt.Println("PASS: 61_hsm_four_level")
}

@@target erlang

@@system StateVarBasic {
    interface:
        increment(): int
        getCount(): int
        reset()

    machine:
        $Counter {
            $.count: int = 0

            increment(): int {
                $.count = $.count + 1
                return $.count
            }

            getCount(): int {
                return $.count
            }

            reset() {
                $.count = 0
            }
        }
}

@@[target("erlang")]

@@system StateVarBasic {
    interface:
        increment(): int
        getCount(): int
        reset()

    machine:
        $Counter {
            $.count: int = 0

            increment(): int {
                $.count = $.count + 1
                @@:($.count)
                return
            }

            getCount(): int {
                @@:($.count)
                return
            }

            reset() {
                $.count = 0
            }
        }
}

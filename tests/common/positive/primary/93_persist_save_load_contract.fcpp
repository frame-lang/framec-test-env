@@[target("cpp_17")]

#include <iostream>
#include <string>
#include <nlohmann/json.hpp>

@@[persist]
@@system Counter {
    operations:
        @@[save]
        save_op(): std::string {}

        @@[load]
        load_op(data: std::string) {}

    interface:
        bump()
        get_n(): int

    machine:
        $Active {
            bump() {
                this->n = this->n + 1;
            }
            get_n(): int { @@:(this->n) }
        }

    domain:
        n: int = 0
}

int main() {
    Counter c1;
    c1.bump();
    c1.bump();
    c1.bump();
    std::string data = c1.save_op();

    Counter c2;
    c2.load_op(data);
    if (c2.get_n() != 3) {
        std::cout << "FAIL: expected 3, got " << c2.get_n() << std::endl;
        return 1;
    }
    std::cout << "PASS: 93_persist_save_load_contract" << std::endl;
    return 0;
}

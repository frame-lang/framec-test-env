@@[target("cpp_17")]

#include <iostream>
#include <nlohmann/json.hpp>

@@[persist(std::string)]
@@[save(save_op)]
@@[load(load_op)]
@@system Counter {
    interface:
        bump()
        get_n(): int

    machine:
        $Active {
            bump() {
                this->n = this->n + 1;
            }
            get_n(): int { @@:(this->n) }
        }

    domain:
        n: int = 0
}

int main() {
    auto c1 = @@Counter();
    c1.bump();
    c1.bump();
    c1.bump();
    std::string data = c1.save_op();

    auto c2 = @@Counter();
    c2.load_op(data);
    if (c2.get_n() != 3) {
        std::cout << "FAIL: expected 3, got " << c2.get_n() << std::endl;
        return 1;
    }
    std::cout << "PASS: 93_persist_save_load_contract" << std::endl;
    return 0;
}

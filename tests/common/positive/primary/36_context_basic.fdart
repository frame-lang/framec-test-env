@@target dart
// Test: Basic System Context Access
// Validates @@:params["param"], @@:return, @@:event syntax

@@system ContextBasicTest {
    interface:
        add(a: num, b: num): num
        get_event_name(): String
        greet(name: String): String

    machine:
        $Ready {
            add(a: num, b: num): num {
                // Access params via @@ shorthand
                @@:(@@:params["a"] + @@:params["b"])
            }

            get_event_name(): String {
                // Access event name
                @@:(@@:event)
            }

            greet(name: String): String {
                // Mix param access and return
                final result = "Hello, " + @@:params["name"] + "!";
                @@:(result)
            }
        }
}

void main() {
    print("== Test 36: Context Basic ==");
    final s = @@ContextBasicTest();

    // Test 1: @@:params["a"] and @@:params["b"] param access, @@:return
    final result1 = s.add(3, 5);
    if (result1 != 8) throw Exception("Expected 8, got ${result1}");
    print("1. add(3, 5) = ${result1}");

    // Test 2: @@:event access
    final eventName = s.get_event_name();
    if (eventName != "get_event_name") throw Exception("Expected 'get_event_name', got '${eventName}'");
    print("2. @@:event = '${eventName}'");

    // Test 3: @@:params["name"] param access with string
    final greeting = s.greet("World");
    if (greeting != "Hello, World!") throw Exception("Expected 'Hello, World!', got '${greeting}'");
    print("3. greet('World') = '${greeting}'");

    print("PASS: Context basic access works correctly");
}


@@[target("gdscript")]
extends SceneTree

@@[persist(String)]
@@[save(save_state)]
@@[load(restore_state)]
@@system PersistHsmPushpop {
    interface:
        push_modal(v: int)
        pop_modal()
        get_x(): int

    machine:
        $Idle {
            push_modal(v: int) {
                push$
                -> $Modal(v)
            }
            pop_modal() {
                -> pop$
            }
            get_x(): int {
                @@:(-99)
            }
        }

        $Modal => $Frame(x: int) {
            push_modal(v: int) {
                push$
                -> $Modal(v)
            }
            pop_modal() {
                -> pop$
            }
            get_x(): int {
                @@:(x)
            }
        }

        $Frame {
        }
    domain:
        v: int = 0
}

func _initialize():
    print("=== Test 60: Persist × HSM × push/pop (GDScript) ===")
    var s1 = @@PersistHsmPushpop()
    s1.push_modal(42)
    s1.push_modal(99)
    var pre = s1.get_x()
    if pre != 99:
        print("FAIL: pre " + str(pre))
        quit(1)
        return
    print("1. Pre-save top x=" + str(pre))

    var snap = s1.save_state()
    var s2 = @@PersistHsmPushpop()

    s2.restore_state(snap)
    var post = s2.get_x()
    if post != 99:
        print("FAIL: post " + str(post))
        quit(1)
        return
    print("2. Post-restore top x=" + str(post))

    s2.pop_modal()
    var mid = s2.get_x()
    if mid != 42:
        print("FAIL: mid " + str(mid))
        quit(1)
        return
    print("3. After first pop x=" + str(mid))

    s2.pop_modal()
    var bottom = s2.get_x()
    if bottom != -99:
        print("FAIL: bottom " + str(bottom))
        quit(1)
        return
    print("4. After second pop x=" + str(bottom))

    print("PASS: 60_persist_hsm_pushpop")
    quit(0)

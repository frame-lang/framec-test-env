@@target kotlin

import kotlin.system.exitProcess

@@system HSMDefaultForward {
    interface:
        handled_event()
        unhandled_event()
        get_log(): MutableList<Any?>

    machine:
        $Child => $Parent {
            handled_event() {
                this.log.add("Child:handled_event")
            }

            get_log(): MutableList<Any?> {
                return this.log
            }

            => $^
        }

        $Parent {
            handled_event() {
                this.log.add("Parent:handled_event")
            }

            unhandled_event() {
                this.log.add("Parent:unhandled_event")
            }

            get_log(): MutableList<Any?> {
                return this.log
            }
        }
    domain:
        log = mutableListOf<String>()
}

fun main() {
    println("=== Test 30: HSM State-Level Default Forward ===")
    val s = @@HSMDefaultForward()

    s.handled_event()
    var log = s.get_log() as MutableList<*>
    if (!log.contains("Child:handled_event")) {
        println("FAIL: Expected 'Child:handled_event' in log, got $log")
        exitProcess(1)
    }
    println("After handled_event: $log")

    s.unhandled_event()
    log = s.get_log() as MutableList<*>
    if (!log.contains("Parent:unhandled_event")) {
        println("FAIL: Expected 'Parent:unhandled_event' in log (forwarded), got $log")
        exitProcess(1)
    }
    println("After unhandled_event (forwarded): $log")

    println("PASS: HSM state-level default forward works correctly")
}

@@[target("csharp")]

using System;

// Test 105: @@:self.method() from lifecycle handlers (F1 regression)

@@system LifecycleSelfCall {
    interface:
        tick()
        go()
        get_count(): int

    machine:
        $A {
            $>() { @@:self.tick() }
            <$() { @@:self.tick() }
            go() { -> $B }
            tick() { this.count = this.count + 1; }
            get_count(): int { @@:(this.count) }
        }

        $B {
            $>() { @@:self.tick() }
            tick() { this.count = this.count + 1; }
            get_count(): int { @@:(this.count) }
        }

    domain:
        count : int = 0
}

class Program {
    static void Main(string[] args) {
        Console.WriteLine("=== Test 105: @@:self.method() from lifecycle handlers (F1 regression) ===");
        var s = @@LifecycleSelfCall();
        if ((int)s.get_count() != 1) { Console.WriteLine("FAIL: Expected 1, got " + s.get_count()); Environment.Exit(1); }
        Console.WriteLine("TC1: @@:self from start state $> - PASS");
        s.go();
        if ((int)s.get_count() != 3) { Console.WriteLine("FAIL: Expected 3, got " + s.get_count()); Environment.Exit(1); }
        Console.WriteLine("TC2/TC3: @@:self from <$ + post-transition $> - PASS");
        Console.WriteLine("PASS: F1 regression");
    }
}

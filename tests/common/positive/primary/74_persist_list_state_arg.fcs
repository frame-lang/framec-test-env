@@[target("csharp")]

using System;
using System.Collections.Generic;

@@[persist(string)]
@@[save(SaveState)]
@@[load(RestoreState)]
@@system PersistList {
    interface:
        configure(items: List<int>)
        first_item(): int
        size(): int

    machine:
        $Idle {
            configure(items: List<int>) {
                -> $Active(items)
            }
            first_item(): int { @@:(-1) }
            size(): int { @@:(0) }
        }
        $Active(items: List<int>) {
            configure(items: List<int>) {
                -> $Active(items)
            }
            first_item(): int { @@:(items[0]) }
            size(): int { @@:(items.Count) }
        }
    domain:
        n : int = 0
}

class Program {
    static void Main(string[] args) {
        var s1 = new PersistList();
        s1.configure(new List<int> { 10, 20, 30 });
        if (s1.first_item() != 10) { Console.WriteLine("FAIL pre"); Environment.Exit(1); }
        string snap = s1.SaveState();

        var s2 = new PersistList();


        s2.RestoreState(snap);
        if (s2.first_item() != 10) { Console.WriteLine("FAIL restored first_item"); Environment.Exit(1); }
        if (s2.size() != 3) { Console.WriteLine("FAIL restored size"); Environment.Exit(1); }
        Console.WriteLine("PASS: 74_persist_list_state_arg");
    }
}

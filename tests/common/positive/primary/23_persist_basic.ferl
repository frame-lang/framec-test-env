@@[target("erlang")]
@@[persist]
@@[save(save_state)]
@@[load(load_state)]
@@system PersistBasic {
    interface:
        inc()
        getCount(): int
    machine:
        $Counting {
            $.count: int = 0
            inc() { $.count = $.count + 1 }
            getCount(): int {
                @@:($.count)
            }
        }
    domain:
        label = "test"
}

@@[target("dart")]
import 'dart:convert';
// Test 45: HSM Enter in Child Only
//
// Tests enter handler in child only:
// - Child has $>(), parent does not
// - Child enter handler fires on entry
// - No error when parent lacks enter handler
// - Forward to parent works without parent having enter

@@system HSMEnterChildOnly {
    interface:
        go_to_child()
        forward_action()
        get_log(): List<String>
        get_state(): str

    machine:
        $Start {
            go_to_child() {
                -> $Child
            }

            get_log(): list {
                @@:(this.log)
                return;
            }

            get_state(): str {
                @@:("Start")
                return;
            }
        }

        $Child => $Parent {
            $>() {
                this.log.add("Child:enter");
            }

            forward_action() {
                this.log.add("Child:forward");
                => $^
            }

            get_log(): list {
                @@:(this.log)
                return;
            }

            get_state(): str {
                @@:("Child")
                return;
            }
        }

        $Parent {
            forward_action() {
                this.log.add("Parent:forward_action");
            }

            get_log(): list {
                @@:(this.log)
                return;
            }

            get_state(): str {
                @@:("Parent")
                return;
            }
        }
    domain:
        log : List<String> = []
}

void main() {
    print("== Test 45: HSM Enter in Child Only ==");
    final s = @@HSMEnterChildOnly();

    // Start state has no enter
    if (s.get_state() != "Start") throw Exception("Expected Start, got ${s.get_state()}");
    print("TC2.1.0: Initial state is Start - PASS");

    // TC2.1.1: Child enter handler fires on entry
    s.go_to_child();
    var log = s.get_log();
    if (!log.contains("Child:enter")) throw Exception("Expected Child:enter, got ${jsonEncode(log)}");
    if (s.get_state() != "Child") throw Exception("Expected Child, got ${s.get_state()}");
    print("TC2.1.1: Child enter handler fires - PASS");

    // TC2.1.2: No error when parent lacks enter (verified by compilation/execution)
    print("TC2.1.2: No error when parent lacks enter - PASS");

    // TC2.1.3: Forward to parent works without parent having enter
    s.forward_action();
    log = s.get_log();
    if (!log.contains("Child:forward")) throw Exception("Expected Child:forward, got ${jsonEncode(log)}");
    if (!log.contains("Parent:forward_action")) throw Exception("Expected Parent handler, got ${jsonEncode(log)}");
    print("TC2.1.3: Forward works without parent enter - PASS");

    print("PASS: HSM enter in child only works correctly");
}


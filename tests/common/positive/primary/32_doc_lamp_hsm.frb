@@target ruby

# Documentation Example: HSM Lamp with color behavior factored out

@@system LampHSM {
    interface:
        turnOn()
        turnOff()
        getColor(): str
        setColor(color: str)

    machine:
        $Off => $ColorBehavior {
            turnOn() {
                -> $On
            }
            => $^
        }

        $On => $ColorBehavior {
            $>() {
                self.turnOnLamp()
            }
            <$() {
                self.turnOffLamp()
            }
            turnOff() {
                -> $Off
            }
            => $^
        }

        $ColorBehavior {
            getColor(): str {
                return self.color
            }
            setColor(color: str) {
                self.color = color
            }
        }

    actions:
        turnOnLamp() {
            self.lamp_on = true
        }
        turnOffLamp() {
            self.lamp_on = false
        }

    domain:
        color: str = "white"
        lamp_on: bool = false
}

puts("=== Test 32: Doc Lamp HSM ===")
lamp = LampHSM.new

# Color behavior available in both states
raise "Expected 'white', got '#{lamp.getColor()}'" unless lamp.getColor() == "white"
lamp.setColor("red")
raise "Expected 'red', got '#{lamp.getColor()}'" unless lamp.getColor() == "red"

# Turn on
lamp.turnOn()
raise "Lamp should be on" unless lamp.lamp_on == true

# Color still works when on
lamp.setColor("green")
raise "Expected 'green', got '#{lamp.getColor()}'" unless lamp.getColor() == "green"

# Turn off
lamp.turnOff()
raise "Lamp should be off" unless lamp.lamp_on == false

# Color still works when off
raise "Expected 'green', got '#{lamp.getColor()}'" unless lamp.getColor() == "green"

puts("PASS: HSM lamp works correctly")

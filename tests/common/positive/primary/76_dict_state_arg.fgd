@@[target("gdscript")]
extends SceneTree

@@system DictStateArg {
    interface:
        configure(m: Dictionary)
        get_v(key: String): int
        size(): int

    machine:
        $Idle {
            configure(m: Dictionary) { -> $Active(m) }
            get_v(key: String): int { @@:(-1) }
            size(): int { @@:(0) }
        }
        $Active(m: Dictionary) {
            configure(m: Dictionary) { -> $Active(m) }
            get_v(key: String): int { @@:(m.get(key, -1)) }
            size(): int { @@:(m.size()) }
        }
    domain:
        n: int = 0
}

func _initialize():
    var s = @@DictStateArg()
    if s.get_v("a") != -1:
        print("FAIL idle"); quit(1); return
    if s.size() != 0:
        print("FAIL idle size"); quit(1); return
    s.configure({"a": 10, "b": 20})
    if s.get_v("a") != 10:
        print("FAIL a"); quit(1); return
    if s.get_v("b") != 20:
        print("FAIL b"); quit(1); return
    if s.size() != 2:
        print("FAIL size"); quit(1); return
    s.configure({"x": 99})
    if s.get_v("x") != 99:
        print("FAIL x"); quit(1); return
    if s.size() != 1:
        print("FAIL size2"); quit(1); return
    print("PASS: 76_dict_state_arg")

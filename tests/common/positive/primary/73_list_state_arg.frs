@@[target("rust")]

@@system ListStateArg {
    interface:
        configure(items: Vec<i32>)
        first_item(): i32
        size(): i32

    machine:
        $Idle {
            configure(items: Vec<i32>) {
                -> $Active(items)
            }
            first_item(): i32 {
                @@:(-1); return;
            }
            size(): i32 {
                @@:(0); return;
            }
        }
        $Active(items: Vec<i32>) {
            configure(items: Vec<i32>) {
                -> $Active(items)
            }
            first_item(): i32 {
                @@:(items[0]); return;
            }
            size(): i32 {
                @@:(items.len() as i32); return;
            }
        }
    domain:
        n: i32
}

fn main() {
    let mut s = @@ListStateArg();
    if s.first_item() != -1 { println!("FAIL idle first_item"); std::process::exit(1); }
    if s.size() != 0 { println!("FAIL idle size"); std::process::exit(1); }
    s.configure(vec![10, 20, 30]);
    if s.first_item() != 10 { println!("FAIL active first_item"); std::process::exit(1); }
    if s.size() != 3 { println!("FAIL active size"); std::process::exit(1); }
    s.configure(vec![7]);
    if s.first_item() != 7 { println!("FAIL retransition first_item"); std::process::exit(1); }
    if s.size() != 1 { println!("FAIL retransition size"); std::process::exit(1); }
    println!("PASS: 73_list_state_arg");
}

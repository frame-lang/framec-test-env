@@[target("c")]

#include <stdio.h>
#include <stdlib.h>
#include <string.h>
#include <cjson/cJSON.h>

@@[persist]
@@system Counter {
    operations:
        @@[save]
        save_state(): char* {}

        @@[load]
        restore_state(data: char*) {}

        @@[on_load]
        rebuild_derived() {
            self->doubled = self->n * 2;
            self->was_restored = true;
        }

    interface:
        bump()
        get_n(): int
        get_doubled(): int
        was_loaded(): bool

    machine:
        $Active {
            bump() { self->n = self->n + 1; }
            get_n(): int { @@:(self->n) }
            get_doubled(): int { @@:(self->doubled) }
            was_loaded(): bool { @@:(self->was_restored) }
        }

    domain:
        n: int = 0
        doubled: int = 0
        was_restored: bool = false
}

int main() {
    Counter* c1 = Counter_new();
    Counter_bump(c1); Counter_bump(c1); Counter_bump(c1);
    if (Counter_was_loaded(c1)) { printf("FAIL: was_restored should be false pre-restore\n"); Counter_destroy(c1); return 1; }
    if (Counter_get_doubled(c1) != 0) { printf("FAIL: doubled should be 0, got %d\n", Counter_get_doubled(c1)); Counter_destroy(c1); return 1; }

    char* data = Counter_save_state(c1);

    Counter* c2 = Counter_new();
    Counter_restore_state(c2, data);
    if (!Counter_was_loaded(c2)) { printf("FAIL: was_restored should be true after on_load\n"); free(data); Counter_destroy(c1); Counter_destroy(c2); return 1; }
    if (Counter_get_n(c2) != 3) { printf("FAIL: n should be 3, got %d\n", Counter_get_n(c2)); free(data); Counter_destroy(c1); Counter_destroy(c2); return 1; }
    if (Counter_get_doubled(c2) != 6) { printf("FAIL: doubled should be 6, got %d\n", Counter_get_doubled(c2)); free(data); Counter_destroy(c1); Counter_destroy(c2); return 1; }

    printf("PASS: 95_persist_on_load_hook\n");
    free(data);
    Counter_destroy(c1);
    Counter_destroy(c2);
    return 0;
}

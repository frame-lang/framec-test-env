@@[target("csharp")]


@@system DictStateArg {
    interface:
        configure(m: Dictionary<string, int>)
        get_v(key: string): int
        size(): int

    machine:
        $Idle {
            configure(m: Dictionary<string, int>) { -> $Active(m) }
            get_v(key: string): int { @@:(-1) }
            size(): int { @@:(0) }
        }
        $Active(m: Dictionary<string, int>) {
            configure(m: Dictionary<string, int>) { -> $Active(m) }
            get_v(key: string): int { @@:(m.TryGetValue(key, out int __vv) ? __vv : -1) }
            size(): int { @@:(m.Count) }
        }
    domain:
        n : int = 0
}

class Program {
    static void Main(string[] args) {
        var s = @@DictStateArg();
        if (s.get_v("a") != -1) { Console.WriteLine("FAIL idle"); Environment.Exit(1); }
        if (s.size() != 0) { Console.WriteLine("FAIL idle size"); Environment.Exit(1); }
        s.configure(new Dictionary<string, int> { { "a", 10 }, { "b", 20 } });
        if (s.get_v("a") != 10) { Console.WriteLine("FAIL a"); Environment.Exit(1); }
        if (s.get_v("b") != 20) { Console.WriteLine("FAIL b"); Environment.Exit(1); }
        if (s.size() != 2) { Console.WriteLine("FAIL size"); Environment.Exit(1); }
        s.configure(new Dictionary<string, int> { { "x", 99 } });
        if (s.get_v("x") != 99) { Console.WriteLine("FAIL x"); Environment.Exit(1); }
        if (s.size() != 1) { Console.WriteLine("FAIL size2"); Environment.Exit(1); }
        Console.WriteLine("PASS: 76_dict_state_arg");
    }
}

@@[target("kotlin")]

@@[persist(String)]
@@[save(save_state)]
@@[load(restore_state)]
@@system NestedList {
    interface:
        configure(rows: List<List<Int>>)
        first_first(): Int
        outer_size(): Int

    machine:
        $Idle {
            configure(rows: List<List<Int>>) { -> $Active(rows) }
            first_first(): Int { @@:(-1) }
            outer_size(): Int { @@:(0) }
        }
        $Active(rows: List<List<Int>>) {
            configure(rows: List<List<Int>>) { -> $Active(rows) }
            first_first(): Int { @@:((rows[0] as List<Int>)[0]) }
            outer_size(): Int { @@:(rows.size) }
        }
    domain:
        n : Int = 0
}

fun main() {
    val s1 = NestedList()
    s1.configure(listOf(listOf(10, 20), listOf(30, 40)))
    if (s1.first_first() != 10) { println("FAIL pre"); kotlin.system.exitProcess(1) }
    if (s1.outer_size() != 2) { println("FAIL size"); kotlin.system.exitProcess(1) }
    val snap = s1.save_state()
    val s2 = NestedList()

    s2.restore_state(snap)
    if (s2.first_first() != 10) { println("FAIL post got ${s2.first_first()}"); kotlin.system.exitProcess(1) }
    if (s2.outer_size() != 2) { println("FAIL post size"); kotlin.system.exitProcess(1) }
    println("PASS: 75_nested_list_state_arg")
}

@@[target("swift")]


@@[persist(String)]
@@[save(saveState)]
@@[load(restoreState)]
@@system Outer {
    interface:
        try_save_during_handler()

    machine:
        $S {
            try_save_during_handler() {
                self.saveState()
            }
        }
    domain:
}

// Swift uses fatalError which terminates the process; we cannot
// catch it within the same Swift process. The quiescent contract
// for Swift is enforced as a programming error (like an array
// out-of-bounds) — the runtime aborts. Test verifies only the
// quiescent path; the error path is documented in the per-language
// guide.

let o1 = @@Outer()
let snap = o1.saveState()
if snap.isEmpty { print("FAIL: quiescent save returned empty"); exit(1) }

let o3 = @@Outer()
let snap3 = o3.saveState()
if snap3.isEmpty { print("FAIL: fresh instance unusable"); exit(1) }

print("PASS: 88_persist_quiescent_error")

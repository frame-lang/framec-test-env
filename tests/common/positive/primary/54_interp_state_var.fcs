@@target csharp

using System;
using System.Collections.Generic;

@@system InterpStress {
    interface:
        test_interp(): string
        test_standalone(): int
        test_return(): int
        test_multi(): string
        test_mixed(): string

    machine:
        $Active {
            $.count: int = 42
            $.label: string = "hello"

            test_interp(): string {
                @@:($"count is {$.count}")
                return;
            }

            test_standalone(): int {
                var x = $.count + 1;
                @@:(x)
                return;
            }

            test_return(): int {
                @@:($.count)
                return;
            }

            test_multi(): string {
                @@:($"{$.count} and {$.label}")
                return;
            }

            test_mixed(): string {
                var total = 100;
                @@:($"{$.count}/{total}")
                return;
            }
        }
}

class Program {
    static void Main(string[] args) {
        var s = new InterpStress();
        var failures = 0;

        var r = (string)s.test_interp();
        if (r != "count is 42") { Console.WriteLine($"FAIL interp: got '{r}'"); failures++; }

        var n = (int)s.test_standalone();
        if (n != 43) { Console.WriteLine($"FAIL standalone: got {n}"); failures++; }

        n = (int)s.test_return();
        if (n != 42) { Console.WriteLine($"FAIL return: got {n}"); failures++; }

        r = (string)s.test_multi();
        if (r != "42 and hello") { Console.WriteLine($"FAIL multi: got '{r}'"); failures++; }

        r = (string)s.test_mixed();
        if (r != "42/100") { Console.WriteLine($"FAIL mixed: got '{r}'"); failures++; }

        if (failures > 0) {
            Console.WriteLine($"FAIL: {failures} failures");
            Environment.Exit(1);
        }
        Console.WriteLine("PASS: stress_interp (5 cases)");
    }
}

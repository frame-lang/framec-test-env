@@[target("swift")]


@@[persist(String)]
@@[save(saveState)]
@@[load(restoreState)]
@@system Inner {
    interface:
        cycle()
        get_state(): String
        get_count(): Int

    machine:
        $A {
            cycle() { self.n = self.n + 1; -> $B }
            get_state(): String { @@:("A") }
            get_count(): Int { @@:(self.n) }
        }
        $B => $A {
            cycle() { -> $A }
            get_state(): String { @@:("B") }
            get_count(): Int { => $^ }
        }
    domain:
        n: Int = 0
}@@[persist(String)]
@@[save(saveState)]
@@[load(restoreState)]


@@[main]
@@system Outer {
    interface:
        tick()
        cycle_inner()
        get_outer_state(): String
        get_inner_state(): String
        get_inner_count(): Int
        get_k(): Int

    machine:
        $Idle {
            tick() { self.k = self.k + 1; -> $Active }
            cycle_inner() { self.inner.cycle() }
            get_outer_state(): String { @@:("Idle") }
            get_inner_state(): String { @@:(self.inner.get_state()) }
            get_inner_count(): Int { @@:(self.inner.get_count()) }
            get_k(): Int { @@:(self.k) }
        }
        $Active => $Idle {
            tick() { -> $Idle }
            get_outer_state(): String { @@:("Active") }
            cycle_inner() { => $^ }
            get_inner_state(): String { => $^ }
            get_inner_count(): Int { => $^ }
            get_k(): Int { => $^ }
        }
    domain:
        k: Int = 0
        inner: Inner = @@Inner()
}

func fmt(_ o: Outer) -> String { return "\(o.get_outer_state())/\(o.get_inner_state())/\(o.get_inner_count())/\(o.get_k())" }

func must(_ label: String, _ o: Outer, _ expected: String) {
    let actual = fmt(o)
    if actual != expected { print("FAIL \(label): \(actual) expected \(expected)"); exit(1) }
}

let o1 = @@Outer()
let o2 = @@Outer()

o1.cycle_inner()
o1.cycle_inner()
o1.cycle_inner()
must("o1 pre", o1, "Idle/B/2/0")

o2.tick()
o2.tick()
o2.tick()
must("o2 pre", o2, "Active/A/0/2")

let snap1 = o1.saveState()
let snap2 = o2.saveState()

let r2 = @@Outer()


r2.restoreState(snap2)
let r1 = @@Outer()

r1.restoreState(snap1)

must("r1 restored", r1, "Idle/B/2/0")
must("r2 restored", r2, "Active/A/0/2")

r1.cycle_inner()
must("r1 after mut", r1, "Idle/A/2/0")
must("r2 after r1 mut", r2, "Active/A/0/2")

r2.cycle_inner()
must("r1 after r2 mut", r1, "Idle/A/2/0")
must("r2 after r2 mut", r2, "Active/B/1/2")

print("PASS: 87_persist_multi_instance")

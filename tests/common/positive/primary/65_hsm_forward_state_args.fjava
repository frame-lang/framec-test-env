@@target java

@@system StateArgFwd {
    interface:
        configure(t: int)
        process(): int

    machine:
        $Idle {
            configure(t: int) {
                -> $Active(t)
            }
            process(): int {
                @@:(0)
            }
        }

        $Active => $Frame(threshold: int) {
            configure(t: int) {
                -> $Active(t)
            }
            process(): int {
                => $^
            }
        }

        $Frame {
            process(): int {
                @@:(threshold)
            }
        }
    domain:
        n : int = 0
}

class Main {
    public static void main(String[] args) {
        System.out.println("=== Test 65: HSM × state-args × parent-forward (Java) ===");
        var s = new StateArgFwd();

        int pre = s.process();
        if (pre != 0) { System.out.println("FAIL: pre " + pre); System.exit(1); }
        System.out.println("1. Idle process = " + pre);

        s.configure(7);
        int r = s.process();
        if (r != 7) { System.out.println("FAIL: r " + r); System.exit(1); }
        System.out.println("2. configure(7); process() = " + r);

        s.configure(42);
        int r2 = s.process();
        if (r2 != 42) { System.out.println("FAIL: r2 " + r2); System.exit(1); }
        System.out.println("3. configure(42); process() = " + r2);

        System.out.println("PASS: 65_hsm_forward_state_args");
    }
}

@@[target("php")]

// Test 100: @@[no_persist] domain fields (RFC-0016.1)

@@[persist(string)]
@@[save(save_op)]
@@[load(load_op)]
@@system NoPersistField {
    interface:
        bump()
        set_cache(v: int)
        set_note(s: string)
        get_n(): int
        get_cache(): int
        get_note(): string

    machine:
        $Active {
            bump() { $this->n = $this->n + 1; }
            set_cache(v: int) { $this->cache = $v; }
            set_note(s: string) { $this->note = $s; }
            get_n(): int { @@:($this->n) }
            get_cache(): int { @@:($this->cache) }
            get_note(): string { @@:($this->note) }
        }

    domain:
        n: int = 0
        @@[no_persist]
        cache: int = -1
        note: string = "fresh"
}

$c1 = @@NoPersistField();
$c1->bump();
$c1->bump();
$c1->bump();
$c1->set_cache(99);
$c1->set_note("hello");
$data = $c1->save_op();

$c2 = @@NoPersistField();
$c2->load_op($data);

if ($c2->get_n() !== 3) {
    echo "FAIL: expected n=3, got " . $c2->get_n() . "\n";
} elseif ($c2->get_note() !== "hello") {
    echo "FAIL: expected note=hello, got " . $c2->get_note() . "\n";
} elseif ($c2->get_cache() !== -1) {
    echo "FAIL: expected cache=-1 (domain default; @@[no_persist] field not restored), got " . $c2->get_cache() . "\n";
} else {
    echo "PASS: 100_no_persist_field\n";
}

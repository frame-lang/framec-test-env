@@[target("lua")]

@@[persist]
@@system PersistDict {
    interface:
        configure(m: table)
        get_v(key: String): int

    machine:
        $Idle {
            configure(m: table) { -> $Active(m) }
            get_v(key: String): int { @@:(-1) }
        }
        $Active(m: table) {
            configure(m: table) { -> $Active(m) }
            get_v(key: String): int { @@:(m[key] or -1) }
        }
    domain:
        n: int = 0
}

local s1 = PersistDict:new()
s1:configure({a = 10, b = 20})
if s1:get_v("a") ~= 10 then print("FAIL pre"); os.exit(1) end
local snap = s1:save_state()
local s2 = PersistDict.restore_state(snap)
if s2:get_v("a") ~= 10 then print("FAIL post a"); os.exit(1) end
if s2:get_v("b") ~= 20 then print("FAIL post b"); os.exit(1) end
print("PASS: 77_persist_dict_state_arg")

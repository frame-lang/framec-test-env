@@[target("kotlin")]

// Test: const domain field initialized from system param.

@@system Sensor(threshold: int = 100) {
    interface:
        read(): int
        calibrate(offset: int)
        get_threshold(): int

    machine:
        $Active {
            read(): int {
                @@:(this.value + this.offset)
                return;
            }
            calibrate(offset: int) {
                this.offset = offset
            }
            get_threshold(): int {
                @@:(this.threshold)
                return;
            }
        }

    domain:
        const threshold : Int = threshold
        value : Int = 50
        offset : Int = 0
}

fun main() {
    var failures = 0

    // Test 1: system param override
    val s = @@Sensor(200)
    val t = s.get_threshold()
    if (t != 200) { println("FAIL test 1: expected 200, got $t"); failures++ }

    // Test 2: read returns value + offset
    var v = s.read()
    if (v != 50) { println("FAIL test 2: expected 50, got $v"); failures++ }

    // Test 3: calibrate changes offset
    s.calibrate(10)
    v = s.read()
    if (v != 60) { println("FAIL test 3: expected 60, got $v"); failures++ }

    // Test 4: default system param
    val s2 = @@Sensor()
    val t2 = s2.get_threshold()
    if (t2 != 100) { println("FAIL test 4: expected 100, got $t2"); failures++ }

    if (failures > 0) {
        println("FAIL: const_domain ($failures failures)")
        kotlin.system.exitProcess(1)
    }
    println("PASS: const_domain")
}

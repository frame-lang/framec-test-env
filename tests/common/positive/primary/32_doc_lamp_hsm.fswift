@@target swift

// Documentation Example: HSM Lamp with color behavior factored out

@@system LampHSM {
    interface:
        turnOn()
        turnOff()
        getColor(): string
        setColor(color: string)
        isLampOn(): boolean

    machine:
        $Off => $ColorBehavior {
            turnOn() {
                -> $On
            }
            isLampOn(): boolean {
                @@:(self.lamp_on)
                return;
            }
            => $^
        }

        $On => $ColorBehavior {
            $>() {
                self.turnOnLamp()
            }
            <$() {
                self.turnOffLamp()
            }
            turnOff() {
                -> $Off
            }
            isLampOn(): boolean {
                @@:(self.lamp_on)
                return;
            }
            => $^
        }

        $ColorBehavior {
            getColor(): string {
                @@:(self.color)
                return;
            }
            setColor(color: string) {
                self.color = color
            }
        }

    actions:
        turnOnLamp() {
            self.lamp_on = true
        }
        turnOffLamp() {
            self.lamp_on = false
        }

    domain:
        color: string = "white"
        lamp_on: boolean = false
}

// main
    print("=== Test 32: Doc Lamp HSM ===")
    let lamp = @@LampHSM()

    // Color behavior available in both states
    if lamp.getColor() != "white" {
        fatalError("Expected 'white', got '\(lamp.getColor())'")
    }
    lamp.setColor("red")
    if lamp.getColor() != "red" {
        fatalError("Expected 'red', got '\(lamp.getColor())'")
    }

    // Turn on
    lamp.turnOn()
    if lamp.isLampOn() != true {
        fatalError("Lamp should be on")
    }

    // Color still works when on
    lamp.setColor("green")
    if lamp.getColor() != "green" {
        fatalError("Expected 'green', got '\(lamp.getColor())'")
    }

    // Turn off
    lamp.turnOff()
    if lamp.isLampOn() != false {
        fatalError("Lamp should be off")
    }

    // Color still works when off
    if lamp.getColor() != "green" {
        fatalError("Expected 'green', got '\(lamp.getColor())'")
    }

    print("PASS: HSM lamp works correctly")

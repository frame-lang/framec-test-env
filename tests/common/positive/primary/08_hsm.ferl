@@target erlang
@@system HSMForward {
    interface:
        eventA()
        eventB()
        getLog(): str
    machine:
        $Child => $Parent {
            eventA() {
                self.log = self.log ++ ",child_a"
            }
            eventB() {
                self.log = self.log ++ ",child_b_forward"
                => $^
            }
            getLog(): str {
                @@:(self.log)
            }
        }
        $Parent {
            eventA() {
                self.log = self.log ++ ",parent_a"
            }
            eventB() {
                self.log = self.log ++ ",parent_b"
            }
            getLog(): str {
                @@:(self.log)
            }
        }
    domain:
        log = "init"
}

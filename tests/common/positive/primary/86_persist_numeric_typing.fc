@@[target("c")]

#include <stdio.h>
#include <stdlib.h>
#include <string.h>
#include <math.h>
#include <cjson/cJSON.h>

@@[persist(char*)]
@@[save(save_state)]
@@[load(restore_state)]
@@system Inner {
    interface:
        bump_int()
        bump_float()
        flip_bool()
        get_n_int(): int
        get_n_float(): double
        get_n_bool(): int
        get_n_str(): const char*

    machine:
        $S {
            bump_int() { self->n_int = self->n_int + 1; }
            bump_float() { self->n_float = self->n_float + 0.25; }
            flip_bool() { self->n_bool = !self->n_bool; }
            get_n_int(): int { @@:(self->n_int) }
            get_n_float(): double { @@:(self->n_float) }
            get_n_bool(): int { @@:(self->n_bool) }
            get_n_str(): const char* { @@:(self->n_str) }
        }
    domain:
        n_int: int = 7
        n_float: double = 2.5
        n_bool: bool = true
        n_str: const char* = "hello"
}@@[persist(char*)]
@@[save(save_state)]
@@[load(restore_state)]


@@[main]
@@system Outer {
    interface:
        bump_k_int()
        bump_k_float()
        bump_inner_int()
        bump_inner_float()
        flip_inner_bool()
        get_k_int(): int
        get_k_float(): double
        get_n_int(): int
        get_n_float(): double
        get_n_bool(): int
        get_n_str(): const char*

    machine:
        $S {
            bump_k_int() { self->k_int = self->k_int + 1; }
            bump_k_float() { self->k_float = self->k_float + 0.25; }
            bump_inner_int() { Inner_bump_int(self->inner); }
            bump_inner_float() { Inner_bump_float(self->inner); }
            flip_inner_bool() { Inner_flip_bool(self->inner); }
            get_k_int(): int { @@:(self->k_int) }
            get_k_float(): double { @@:(self->k_float) }
            get_n_int(): int { @@:(Inner_get_n_int(self->inner)) }
            get_n_float(): double { @@:(Inner_get_n_float(self->inner)) }
            get_n_bool(): int { @@:(Inner_get_n_bool(self->inner)) }
            get_n_str(): const char* { @@:(Inner_get_n_str(self->inner)) }
        }
    domain:
        k_int: int = 42
        k_float: double = 1.25
        inner: Inner* = @@Inner()
}

#define ASSERT_STATE(label, o, ki, kf, ni, nf, nb, ns) \
    do { \
        if (Outer_get_k_int(o) != ki) { printf("FAIL %s k_int: %d\n", label, Outer_get_k_int(o)); return 1; } \
        if (Outer_get_n_int(o) != ni) { printf("FAIL %s n_int: %d\n", label, Outer_get_n_int(o)); return 1; } \
        if (fabs(Outer_get_k_float(o) - (kf)) > 1e-9) { printf("FAIL %s k_float: %f\n", label, Outer_get_k_float(o)); return 1; } \
        if (fabs(Outer_get_n_float(o) - (nf)) > 1e-9) { printf("FAIL %s n_float: %f\n", label, Outer_get_n_float(o)); return 1; } \
        if (!!Outer_get_n_bool(o) != !!(nb)) { printf("FAIL %s n_bool: %d\n", label, Outer_get_n_bool(o)); return 1; } \
        if (strcmp(Outer_get_n_str(o), ns) != 0) { printf("FAIL %s n_str: %s\n", label, Outer_get_n_str(o)); return 1; } \
    } while (0)

int main() {
    Outer* o = @@Outer();
    ASSERT_STATE("T0", o, 42, 1.25, 7, 2.5, 1, "hello");

    Outer_bump_k_int(o);
    Outer_bump_k_float(o);
    Outer_bump_inner_int(o);
    Outer_bump_inner_float(o);
    Outer_flip_inner_bool(o);
    ASSERT_STATE("T1", o, 43, 1.5, 8, 2.75, 0, "hello");

    char* snap = Outer_save_state(o);
    Outer* r = @@Outer();

    Outer_restore_state(r, snap);
    ASSERT_STATE("T1 restored", r, 43, 1.5, 8, 2.75, 0, "hello");
    free(snap);

    Outer_bump_k_int(r);
    Outer_bump_inner_int(r);
    ASSERT_STATE("continue", r, 44, 1.5, 9, 2.75, 0, "hello");

    printf("PASS: 86_persist_numeric_typing\n");
    return 0;
}

@@target kotlin

import kotlin.system.exitProcess

@@system EnterExit {
    interface:
        toggle()
        get_log(): MutableList<String>

    machine:
        $Off {
            $>() {
                this.log.add("enter:Off")
                println("Entered Off state")
            }

            <$() {
                this.log.add("exit:Off")
                println("Exiting Off state")
            }

            toggle() {
                -> $On
            }

            get_log(): MutableList<String> {
                @@:(this.log)
                return;
            }
        }

        $On {
            $>() {
                this.log.add("enter:On")
                println("Entered On state")
            }

            <$() {
                this.log.add("exit:On")
                println("Exiting On state")
            }

            toggle() {
                -> $Off
            }

            get_log(): MutableList<String> {
                @@:(this.log)
                return;
            }
        }
    domain:
        log = mutableListOf<String>()
}

fun main() {
    println("=== Test 05: Enter/Exit Handlers ===")
    val s = EnterExit()

    // Initial enter should have been called
    @Suppress("UNCHECKED_CAST")
    var log = s.get_log() as MutableList<String>
    if (!log.contains("enter:Off")) {
        throw RuntimeException("Expected 'enter:Off' in log, got $log")
    }
    println("After construction: $log")

    // Toggle to On - should exit Off, enter On
    s.toggle()
    @Suppress("UNCHECKED_CAST")
    log = s.get_log() as MutableList<String>
    if (!log.contains("exit:Off")) {
        throw RuntimeException("Expected 'exit:Off' in log, got $log")
    }
    if (!log.contains("enter:On")) {
        throw RuntimeException("Expected 'enter:On' in log, got $log")
    }
    println("After toggle to On: $log")

    // Toggle back to Off - should exit On, enter Off
    s.toggle()
    @Suppress("UNCHECKED_CAST")
    log = s.get_log() as MutableList<String>
    var enterOffCount = 0
    for (entry in log) {
        if (entry == "enter:Off") enterOffCount++
    }
    if (enterOffCount != 2) {
        throw RuntimeException("Expected 2 'enter:Off' entries, got $log")
    }
    if (!log.contains("exit:On")) {
        throw RuntimeException("Expected 'exit:On' in log, got $log")
    }
    println("After toggle to Off: $log")

    println("PASS: Enter/Exit handlers work correctly")
}

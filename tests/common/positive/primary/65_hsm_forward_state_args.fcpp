@@[target("cpp_17")]

#include <iostream>
#include <cstdlib>

@@system StateArgFwd {
    interface:
        configure(t: int)
        process(): int

    machine:
        $Idle {
            configure(t: int) {
                -> $Active(t)
            }
            process(): int {
                @@:(0)
            }
        }

        $Active => $Frame(threshold: int) {
            configure(t: int) {
                -> $Active(t)
            }
            process(): int {
                => $^
            }
        }

        $Frame {
            process(): int {
                @@:(threshold)
            }
        }
    domain:
        n : int = 0
}

int main() {
    std::cout << "=== Test 65: HSM × state-args × parent-forward (C++) ===" << std::endl;
    auto s = @@StateArgFwd();

    int pre = s.process();
    if (pre != 0) { std::cout << "FAIL: pre " << pre << std::endl; return 1; }
    std::cout << "1. Idle process = " << pre << std::endl;

    s.configure(7);
    int r = s.process();
    if (r != 7) { std::cout << "FAIL: r " << r << std::endl; return 1; }
    std::cout << "2. configure(7); process() = " << r << std::endl;

    s.configure(42);
    int r2 = s.process();
    if (r2 != 42) { std::cout << "FAIL: r2 " << r2 << std::endl; return 1; }
    std::cout << "3. configure(42); process() = " << r2 << std::endl;

    std::cout << "PASS: 65_hsm_forward_state_args" << std::endl;
    return 0;
}

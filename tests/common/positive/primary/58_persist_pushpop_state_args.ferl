@@[target("erlang")]
@@[persist]
@@[save(save_state)]
@@[load(load_state)]
@@system PersistPushpopStateArgs {
    interface:
        pushModal(v: int)
        popModal()
        getSlot(): int
    machine:
        $Idle {
            pushModal(v: int) {
                push$
                -> $Modal(v)
            }
            popModal() {
                -> pop$
            }
            getSlot(): int {
                @@:(-99)
            }
        }
        $Modal(slot: int) {
            pushModal(v: int) {
                push$
                -> $Modal(v)
            }
            popModal() {
                -> pop$
            }
            getSlot(): int {
                @@:(slot)
            }
        }
    domain:
        v = 0
}

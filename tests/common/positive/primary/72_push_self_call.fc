@@[target("c")]

#include <stdio.h>
#include <stdlib.h>
#include <string.h>

@@system PushSelf {
    interface:
        enter_modal()
        ping(): int
        exit_modal()
        compute(): int

    machine:
        $Idle {
            enter_modal() { push$; -> $Modal }
            ping(): int { @@:(0) }
            compute(): int { @@:(99) }
        }
        $Modal {
            ping(): int { @@:(PushSelf_compute(self) + 1) }
            compute(): int { @@:(10) }
            exit_modal() { -> pop$ }
        }
    domain: n : int = 0
}

int main(void) {
    PushSelf* s = PushSelf_new();
    if (PushSelf_ping(s) != 0) { printf("FAIL idle\n"); return 1; }
    PushSelf_enter_modal(s);
    int r = PushSelf_ping(s);
    if (r != 11) { printf("FAIL modal %d\n", r); return 1; }
    PushSelf_exit_modal(s);
    if (PushSelf_ping(s) != 0) { printf("FAIL back\n"); return 1; }
    printf("PASS: 72_push_self_call\n");
    PushSelf_destroy(s);
    return 0;
}

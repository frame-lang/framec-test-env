@@[target("csharp")]

using System;

@@system StateArgFwd {
    interface:
        configure(t: int)
        process(): int

    machine:
        $Idle {
            configure(t: int) {
                -> $Active(t)
            }
            process(): int {
                @@:(0)
            }
        }

        $Active => $Frame(threshold: int) {
            configure(t: int) {
                -> $Active(t)
            }
            process(): int {
                => $^
            }
        }

        $Frame {
            process(): int {
                @@:(threshold)
            }
        }
    domain:
        n : int = 0
}

class Program {
    static void Main(string[] args) {
        Console.WriteLine("=== Test 65: HSM × state-args × parent-forward (C#) ===");
        var s = new StateArgFwd();

        int pre = s.process();
        if (pre != 0) { Console.WriteLine($"FAIL: pre {pre}"); Environment.Exit(1); }
        Console.WriteLine($"1. Idle process = {pre}");

        s.configure(7);
        int r = s.process();
        if (r != 7) { Console.WriteLine($"FAIL: r {r}"); Environment.Exit(1); }
        Console.WriteLine($"2. configure(7); process() = {r}");

        s.configure(42);
        int r2 = s.process();
        if (r2 != 42) { Console.WriteLine($"FAIL: r2 {r2}"); Environment.Exit(1); }
        Console.WriteLine($"3. configure(42); process() = {r2}");

        Console.WriteLine("PASS: 65_hsm_forward_state_args");
    }
}

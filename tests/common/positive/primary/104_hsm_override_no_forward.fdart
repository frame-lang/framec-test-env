@@[target("dart")]
import 'dart:convert';

// Test 104: RFC-0019 leaf-override of ancestor lifecycle
//
// A child with its own $> / <$ handler and NO `=> $^` forward
// overrides the ancestor's lifecycle handler. Inverse of fixtures
// 46/47/48 (which verify forwarding) — verifies non-forwarding:
// when the leaf does not forward, the ancestor's $> / <$ MUST NOT run.

@@system HSMOverride {
    interface:
        go_to_child()
        go_to_parent()
        get_log(): List<String>
        get_state(): str

    machine:
        $Start {
            go_to_child() { -> $Child }
            go_to_parent() { -> $Parent }
            get_log(): list { @@:(this.log) }
            get_state(): str { @@:("Start") }
        }

        $Child => $Parent {
            $>() {
                // NO `=> $^` — ancestor $> must NOT run.
                this.log.add("Child:enter");
            }

            <$() {
                // NO `=> $^` — ancestor <$ must NOT run.
                this.log.add("Child:exit");
            }

            go_to_parent() { -> $Parent }
            get_log(): list { @@:(this.log) }
            get_state(): str { @@:("Child") }
        }

        $Parent {
            $>() { this.log.add("Parent:enter"); }
            <$() { this.log.add("Parent:exit"); }
            go_to_child() { -> $Child }
            get_log(): list { @@:(this.log) }
            get_state(): str { @@:("Parent") }
        }
    domain:
        log : List<String> = []
}

void main() {
    print("=== Test 104: RFC-0019 leaf-override of ancestor lifecycle ===");
    final s = @@HSMOverride();

    // TC1: Entering $Child fires Child's $> only; Parent's $> must NOT fire.
    s.go_to_child();
    var log = s.get_log();
    if (s.get_state() != "Child") throw Exception("Expected Child");
    if (!log.contains("Child:enter")) throw Exception("Expected Child:enter");
    if (log.contains("Parent:enter")) throw Exception("Parent:enter MUST NOT fire when Child overrides");
    print("TC1: Child's \$> overrides Parent's \$> (no forward) - PASS");

    // TC2: Leaving $Child fires Child's <$ only; Parent's <$ must NOT fire.
    s.go_to_parent();
    log = s.get_log();
    if (s.get_state() != "Parent") throw Exception("Expected Parent");
    if (!log.contains("Child:exit")) throw Exception("Expected Child:exit");
    if (log.where((x) => x == "Parent:exit").length != 0) throw Exception("Parent:exit MUST NOT fire (Child overrides)");
    print("TC2: Child's <\$ overrides Parent's <\$ (no forward) - PASS");

    // TC3: Direct $Start -> $Parent transition fires Parent's $> exactly once.
    if (log.where((x) => x == "Parent:enter").length != 1) throw Exception("Expected exactly 1 Parent:enter");
    print("TC3: Direct Parent entry fires Parent's \$> normally - PASS");

    print("PASS: RFC-0019 leaf-override semantics");
}

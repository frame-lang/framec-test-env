@@target gdscript
extends SceneTree

# Test 48: HSM Exit Cascade
#
# Tests the HSM exit cascade per docs/frame_runtime_introduction.md
# Step 21+. When exiting an HSM child, the kernel fires <$ on every
# layer of the source chain bottom-up (child first, parent last).

@@system HSMExitHandlers {
    interface:
        go_to_other()
        go_to_parent()
        go_to_child()
        get_log(): list
        get_state(): str
        get_child_var(): int

    machine:
        $Child => $Parent {
            $.child_var: int = 42

            $>() {
                self.log.append("Child:enter")
            }

            <$() {
                var val = $.child_var
                self.log.append("Child:exit(var=" + str(val) + ")")
            }

            go_to_other() { -> $Other }
            go_to_parent() { -> $Parent }
            get_log(): list { @@:(self.log) }
            get_state(): str { @@:("Child") }
            get_child_var(): int { @@:($.child_var) }
        }

        $Parent {
            $>() {
                self.log.append("Parent:enter")
            }

            <$() {
                self.log.append("Parent:exit")
            }

            go_to_child() { -> $Child }
            go_to_other() { -> $Other }
            get_log(): list { @@:(self.log) }
            get_state(): str { @@:("Parent") }
            get_child_var(): int { @@:(-1) }
        }

        $Other {
            $>() {
                self.log.append("Other:enter")
            }

            go_to_child() { -> $Child }
            go_to_parent() { -> $Parent }
            get_log(): list { @@:(self.log) }
            get_state(): str { @@:("Other") }
            get_child_var(): int { @@:(-1) }
        }
    domain:
        log: list = []
}

func main():
    print("=== Test 48: HSM Exit Cascade ===")
    var s = @@HSMExitHandlers()

    var log = s.get_log()
    assert("Parent:enter" in log, "Expected Parent:enter on init cascade")
    assert("Child:enter" in log, "Expected Child:enter on init")
    assert(s.get_state() == "Child", "Expected Child")
    print("TC1: Initial entry cascades through Parent then Child - PASS")

    s.go_to_other()
    log = s.get_log()
    assert("Child:exit(var=42)" in log, "Expected Child:exit(var=42)")
    assert("Parent:exit" in log, "Expected Parent:exit (cascade)")
    assert("Other:enter" in log, "Expected Other:enter")
    var cei = log.find("Child:exit(var=42)")
    var pei = log.find("Parent:exit")
    assert(cei < pei, "Child:exit must precede Parent:exit (bottom-up)")
    print("TC2: Child:exit fires before Parent:exit (bottom-up cascade) - PASS")

    print("TC3: Exit handler accesses state var (var=42) - PASS")

    s.go_to_child()
    log = s.get_log()
    assert(log.count("Parent:enter") == 2, "Expected 2 Parent:enter")
    assert(log.count("Child:enter") == 2, "Expected 2 Child:enter")
    print("TC4: Re-entering Child cascades Parent.$> then Child.$> - PASS")

    print("PASS: HSM exit cascade fires Child.<$ then Parent.<$")

func _init():
    main()
    quit()

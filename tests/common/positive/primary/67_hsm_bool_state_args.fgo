@@target go

package main

import (
	"fmt"
	"os"
)

@@system BoolStateArg {
    interface:
        Configure(active: bool)
        IsActive(): bool

    machine:
        $Idle {
            Configure(active: bool) {
                -> $Active(active)
            }
            IsActive(): bool {
                @@:(false)
                return;
            }
        }

        $Active => $Frame(flag: bool) {
            Configure(active: bool) {
                -> $Active(active)
            }
            IsActive(): bool {
                => $^
            }
        }

        $Frame {
            IsActive(): bool {
                @@:(flag)
                return;
            }
        }
    domain:
        n: int = 0
}

func main() {
    s := NewBoolStateArg()
    if s.IsActive() != false { fmt.Println("FAIL idle"); os.Exit(1) }
    s.Configure(true)
    if s.IsActive() != true { fmt.Println("FAIL true"); os.Exit(1) }
    s.Configure(false)
    if s.IsActive() != false { fmt.Println("FAIL false"); os.Exit(1) }
    s.Configure(true)
    if s.IsActive() != true { fmt.Println("FAIL re-true"); os.Exit(1) }
    fmt.Println("PASS: 67_hsm_bool_state_args")
}

@@[target("java")]

@@[persist(String)]
@@[save(save_state)]
@@[load(restore_state)]
@@system PFloat {
    interface:
        configure(rate: double)
        get_rate(): double

    machine:
        $Idle {
            configure(rate: double) {
                -> $Active(rate)
            }
            get_rate(): double {
                @@:(0.0)
            }
        }

        $Active(rate: double) {
            get_rate(): double {
                @@:(rate)
            }
        }
    domain:
        n : int = 0
}

class Main {
    public static void main(String[] args) {
        var s = new PFloat();
        s.configure(3.14159);
        String snap = s.save_state();
        var s2 = new PFloat();

        s2.restore_state(snap);
        double r = s2.get_rate();
        if (Math.abs(r - 3.14159) > 1e-9) { System.out.println("FAIL " + r); System.exit(1); }
        System.out.println("PASS: 69_persist_float_state_arg, rate=" + r);
    }
}

@@[target("dart")]

@@system ListStateArg {
    interface:
        configure(items: List<int>)
        first_item(): int
        size(): int

    machine:
        $Idle {
            configure(items: List<int>) {
                -> $Active(items)
            }
            first_item(): int {
                @@:(-1)
            }
            size(): int {
                @@:(0)
            }
        }
        $Active(items: List<int>) {
            configure(items: List<int>) {
                -> $Active(items)
            }
            first_item(): int {
                @@:(items[0])
            }
            size(): int {
                @@:(items.length)
            }
        }
    domain:
        n: int = 0
}

void main() {
    var s = ListStateArg();
    if (s.first_item() != -1) { print("FAIL idle first_item"); return; }
    if (s.size() != 0) { print("FAIL idle size"); return; }
    s.configure([10, 20, 30]);
    if (s.first_item() != 10) { print("FAIL active first_item"); return; }
    if (s.size() != 3) { print("FAIL active size"); return; }
    s.configure([7]);
    if (s.first_item() != 7) { print("FAIL retransition first_item"); return; }
    if (s.size() != 1) { print("FAIL retransition size"); return; }
    print("PASS: 73_list_state_arg");
}

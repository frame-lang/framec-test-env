@@[target("erlang")]

@@system Counter {
    interface:
        get_value(): int
        bump()

    machine:
        $Active {
            get_value(): int { @@:(_read(Data)) }
            bump() { self.n = self.n + 1 }
        }

    actions:
        %% `@@:(<expr>)` inside actions: bodies must lower to a native
        %% return — for Erlang, that's the trailing expression value.
        _read(): int {
            @@:(case Data#data.n > 0 of
                true -> Data#data.n;
                false -> 0
            end)
        }

    domain:
        n: int = 0
}

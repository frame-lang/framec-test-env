@@target kotlin

import kotlin.system.exitProcess

@@system HSMSiblingTransitions {
    interface:
        go_to_b()
        go_to_a()
        forward_action()
        get_log(): ArrayList
        get_state(): String

    machine:
        $ChildA => $Parent {
            $>() {
                this.log.add("ChildA:enter")
            }

            <$() {
                this.log.add("ChildA:exit")
            }

            go_to_b() {
                this.log.add("ChildA:go_to_b")
                -> $ChildB
            }

            forward_action() {
                this.log.add("ChildA:forward")
                => $^
            }

            get_log(): ArrayList {
                return this.log
            }

            get_state(): String {
                return "ChildA"
            }
        }

        $ChildB => $Parent {
            $>() {
                this.log.add("ChildB:enter")
            }

            <$() {
                this.log.add("ChildB:exit")
            }

            go_to_a() {
                this.log.add("ChildB:go_to_a")
                -> $ChildA
            }

            forward_action() {
                this.log.add("ChildB:forward")
                => $^
            }

            get_log(): ArrayList {
                return this.log
            }

            get_state(): String {
                return "ChildB"
            }
        }

        $Parent {
            forward_action() {
                this.log.add("Parent:forward_action")
            }

            get_log(): ArrayList {
                return this.log
            }

            get_state(): String {
                return "Parent"
            }
        }
    domain:
        log = ArrayList()
}

fun main() {
    println("=== Test 44: HSM Sibling Transitions ===")
    val s = @@HSMSiblingTransitions()

    // Initial state is ChildA with enter handler fired
    var log = s.get_log() as java.util.ArrayList<*>
    if (!log.contains("ChildA:enter")) {
        println("FAIL: Expected ChildA:enter on init, got $log")
        exitProcess(1)
    }
    if ((s.get_state() as String) != "ChildA") {
        println("FAIL: Expected ChildA, got ${s.get_state()}")
        exitProcess(1)
    }
    println("TC1.4.0: Initial state ChildA with enter - PASS")

    // TC1.4.1: Transition from ChildA to ChildB
    s.go_to_b()
    if ((s.get_state() as String) != "ChildB") {
        println("FAIL: Expected ChildB, got ${s.get_state()}")
        exitProcess(1)
    }
    println("TC1.4.1: Transition A->B works - PASS")

    // TC1.4.2: Exit handler fired on source
    log = s.get_log() as java.util.ArrayList<*>
    if (!log.contains("ChildA:exit")) {
        println("FAIL: Expected ChildA:exit, got $log")
        exitProcess(1)
    }
    println("TC1.4.2: Exit handler fires on source - PASS")

    // TC1.4.3: Enter handler fired on target
    if (!log.contains("ChildB:enter")) {
        println("FAIL: Expected ChildB:enter, got $log")
        exitProcess(1)
    }
    println("TC1.4.3: Enter handler fires on target - PASS")

    // TC1.4.4: Parent relationship preserved - ChildB can forward
    s.forward_action()
    log = s.get_log() as java.util.ArrayList<*>
    if (!log.contains("ChildB:forward")) {
        println("FAIL: Expected ChildB:forward, got $log")
        exitProcess(1)
    }
    if (!log.contains("Parent:forward_action")) {
        println("FAIL: Expected Parent handler, got $log")
        exitProcess(1)
    }
    println("TC1.4.4: Parent relationship preserved - PASS")

    // TC1.4.5: Transition back to ChildA
    s.go_to_a()
    if ((s.get_state() as String) != "ChildA") {
        println("FAIL: Expected ChildA, got ${s.get_state()}")
        exitProcess(1)
    }
    log = s.get_log() as java.util.ArrayList<*>
    var exitBCount = 0
    var enterACount = 0
    for (item in log) {
        if (item == "ChildB:exit") exitBCount++
        if (item == "ChildA:enter") enterACount++
    }
    if (exitBCount != 1) {
        println("FAIL: Expected ChildB:exit once, got $log")
        exitProcess(1)
    }
    if (enterACount != 2) {
        println("FAIL: Expected ChildA:enter twice, got $log")
        exitProcess(1)
    }
    println("TC1.4.5: Transition B->A works with enter/exit - PASS")

    // TC1.4.6: ChildA can still forward after returning
    s.forward_action()
    log = s.get_log() as java.util.ArrayList<*>
    if (!log.contains("ChildA:forward")) {
        println("FAIL: Expected ChildA:forward, got $log")
        exitProcess(1)
    }
    var parentCount = 0
    for (item in log) {
        if (item == "Parent:forward_action") parentCount++
    }
    if (parentCount != 2) {
        println("FAIL: Expected 2 Parent handlers, got $log")
        exitProcess(1)
    }
    println("TC1.4.6: ChildA forwards after returning - PASS")

    println("PASS: HSM sibling transitions work correctly")
}

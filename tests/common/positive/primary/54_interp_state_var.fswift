@@target swift

@@system InterpStress {
    interface:
        test_interp(): String
        test_standalone(): Int
        test_return(): Int
        test_multi(): String
        test_mixed(): String

    machine:
        $Active {
            $.count: Int = 42
            $.label: String = "hello"

            test_interp(): String {
                @@:("count is \($.count)")
                return;
            }

            test_standalone(): Int {
                let x = $.count + 1
                @@:(x)
                return;
            }

            test_return(): Int {
                @@:($.count)
                return;
            }

            test_multi(): String {
                @@:("\($.count) and \($.label)")
                return;
            }

            test_mixed(): String {
                let total = 100
                @@:("\($.count)/\(total)")
                return;
            }
        }
}

let s = InterpStress()
var failures = 0

var r: Any = s.test_interp()
if (r as? String) != "count is 42" {
    print("FAIL interp: got '\(r)'")
    failures += 1
}

r = s.test_standalone()
if (r as? Int) != 43 {
    print("FAIL standalone: got \(r)")
    failures += 1
}

r = s.test_return()
if (r as? Int) != 42 {
    print("FAIL return: got \(r)")
    failures += 1
}

r = s.test_multi()
if (r as? String) != "42 and hello" {
    print("FAIL multi: got '\(r)'")
    failures += 1
}

r = s.test_mixed()
if (r as? String) != "42/100" {
    print("FAIL mixed: got '\(r)'")
    failures += 1
}

if failures > 0 {
    print("FAIL: \(failures) failures")
    exit(1)
}
print("PASS: stress_interp (5 cases)")

@@[target("javascript")]

@@[persist(string)]
@@[save(saveState)]
@@[load(restoreState)]
@@system PPushDeep {
    interface:
        descend()
        ascend()
        get_depth(): int

    machine:
        $Idle {
            descend() { push$; -> $Modal1 }
            get_depth(): number { @@:(0); return }
        }
        $Modal1 {
            descend() { push$; -> $Modal2 }
            ascend() { -> pop$ }
            get_depth(): number { @@:(1); return }
        }
        $Modal2 {
            descend() { push$; -> $Modal3 }
            ascend() { -> pop$ }
            get_depth(): number { @@:(2); return }
        }
        $Modal3 {
            ascend() { -> pop$ }
            get_depth(): number { @@:(3); return }
        }
    domain: n: number = 0
}

const s = new PPushDeep();
s.descend(); s.descend(); s.descend();
if (s.get_depth() !== 3) { console.log("FAIL pre " + s.get_depth()); process.exit(1); }
const snap = s.saveState();
const s2 = @@PPushDeep();

s2.restoreState(snap);
if (s2.get_depth() !== 3) { console.log("FAIL post " + s2.get_depth()); process.exit(1); }
s2.ascend();
if (s2.get_depth() !== 2) { console.log("FAIL a1 " + s2.get_depth()); process.exit(1); }
s2.ascend();
if (s2.get_depth() !== 1) { console.log("FAIL a2 " + s2.get_depth()); process.exit(1); }
s2.ascend();
if (s2.get_depth() !== 0) { console.log("FAIL a3 " + s2.get_depth()); process.exit(1); }
console.log("PASS: 71_persist_push_depth_three");

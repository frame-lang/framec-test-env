@@[target("dart")]
@@system StateVarPushPop {
    interface:
        increment(): num
        get_count(): num
        save_and_go()
        restore()

    machine:
        $Counter {
            $.count: num = 0

            increment(): num {
                $.count = $.count + 1;
                @@:($.count)
                return;
            }

            get_count(): num {
                @@:($.count)
                return;
            }

            save_and_go() {
                push$
                -> $Other
            }
        }

        $Other {
            $.other_count: num = 100

            restore() {
                -> pop$
            }

            increment(): num {
                $.other_count = $.other_count + 1;
                @@:($.other_count)
                return;
            }

            get_count(): num {
                @@:($.other_count)
                return;
            }
        }
}

void main() {
    print("== Test 12: State Variable Push/Pop ==");
    final s = @@StateVarPushPop();

    // Increment counter to 3
    s.increment();
    s.increment();
    s.increment();
    var count = s.get_count();
    if (count != 3) {
        throw Exception("Expected 3, got ${count}");
    }
    print("Counter before push: ${count}");

    // Push and go to Other state
    s.save_and_go();
    print("Pushed and transitioned to Other");

    // In Other state, count should be 100 (Other's state var)
    count = s.get_count();
    if (count != 100) {
        throw Exception("Expected 100 in Other state, got ${count}");
    }
    print("Other state count: ${count}");

    // Increment in Other
    s.increment();
    count = s.get_count();
    if (count != 101) {
        throw Exception("Expected 101 after increment, got ${count}");
    }
    print("Other state after increment: ${count}");

    // Pop back - should restore Counter with count=3
    s.restore();
    print("Popped back to Counter");

    count = s.get_count();
    if (count != 3) {
        throw Exception("Expected 3 after pop (preserved), got ${count}");
    }
    print("Counter after pop: ${count}");

    // Increment to verify it works
    s.increment();
    count = s.get_count();
    if (count != 4) {
        throw Exception("Expected 4, got ${count}");
    }
    print("Counter after increment: ${count}");

    print("PASS: State variables preserved across push/pop");
}


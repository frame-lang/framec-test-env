@@[target("php")]

<?php

@@system ListStateArg {
    interface:
        configure(items: array)
        first_item(): int
        size(): int

    machine:
        $Idle {
            configure(items: array) {
                -> $Active(items)
            }
            first_item(): int {
                @@:(-1)
            }
            size(): int {
                @@:(0)
            }
        }
        $Active(items: array) {
            configure(items: array) {
                -> $Active(items)
            }
            first_item(): int {
                @@:($items[0])
            }
            size(): int {
                @@:(count($items))
            }
        }
    domain:
        n: int = 0
}

$s = @@ListStateArg();
if ($s->first_item() !== -1) { echo "FAIL idle first_item\n"; exit(1); }
if ($s->size() !== 0) { echo "FAIL idle size\n"; exit(1); }
$s->configure([10, 20, 30]);
if ($s->first_item() !== 10) { echo "FAIL active first_item\n"; exit(1); }
if ($s->size() !== 3) { echo "FAIL active size\n"; exit(1); }
$s->configure([7]);
if ($s->first_item() !== 7) { echo "FAIL retransition first_item\n"; exit(1); }
if ($s->size() !== 1) { echo "FAIL retransition size\n"; exit(1); }
echo "PASS: 73_list_state_arg\n";

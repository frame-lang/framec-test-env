@@[target("rust")]

@@system StrStateArg {
    interface:
        configure(label: str)
        identify(): str

    machine:
        $Idle {
            configure(label: str) {
                -> $Active(label)
            }
            identify(): str {
                @@:("anonymous")
                return;
            }
        }

        $Active => $Frame(label: str) {
            configure(label: str) {
                -> $Active(label)
            }
            identify(): str {
                => $^
            }
        }

        $Frame {
            identify(): str {
                @@:(label)
                return;
            }
        }
    domain:
        n: i32
}

fn main() {
    let mut s = @@StrStateArg();
    if s.identify() != "anonymous" { println!("FAIL idle"); std::process::exit(1); }
    s.configure("alice".to_string());
    if s.identify() != "alice" { println!("FAIL alice"); std::process::exit(1); }
    s.configure("bob".to_string());
    if s.identify() != "bob" { println!("FAIL bob"); std::process::exit(1); }
    println!("PASS: 66_hsm_str_state_args");
}

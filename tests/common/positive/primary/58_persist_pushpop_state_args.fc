@@[target("c")]

#include <stdio.h>
#include <stdlib.h>
#include <string.h>
#include <cjson/cJSON.h>

@@[persist(char*)]
@@[save(save_state)]
@@[load(restore_state)]
@@system PersistPushpopStateArgs {
    interface:
        push_modal(v: int)
        pop_modal()
        get_slot(): int

    machine:
        $Idle {
            push_modal(v: int) {
                push$
                -> $Modal(v)
            }
            pop_modal() {
                -> pop$
            }
            get_slot(): int {
                @@:(-99)
            }
        }

        $Modal(slot: int) {
            push_modal(v: int) {
                push$
                -> $Modal(v)
            }
            pop_modal() {
                -> pop$
            }
            get_slot(): int {
                @@:(slot)
            }
        }
    domain:
        v : int = 0
}

int main(void) {
    printf("=== Test 58: Persist × push/pop × state-args (C) ===\n");
    PersistPushpopStateArgs* s1 = @@PersistPushpopStateArgs();
    PersistPushpopStateArgs_push_modal(s1, 42);
    PersistPushpopStateArgs_push_modal(s1, 77);
    int pre = PersistPushpopStateArgs_get_slot(s1);
    if (pre != 77) { printf("FAIL: pre %d\n", pre); return 1; }
    printf("1. Pre-save top slot=%d\n", pre);

    char* snap = PersistPushpopStateArgs_save_state(s1);
    PersistPushpopStateArgs* s2 = @@PersistPushpopStateArgs();

    PersistPushpopStateArgs_restore_state(s2, snap);
    int post = PersistPushpopStateArgs_get_slot(s2);
    if (post != 77) { printf("FAIL: post %d\n", post); return 1; }
    printf("2. Post-restore top slot=%d\n", post);

    PersistPushpopStateArgs_pop_modal(s2);
    int mid = PersistPushpopStateArgs_get_slot(s2);
    if (mid != 42) { printf("FAIL: mid %d\n", mid); return 1; }
    printf("3. After first pop slot=%d\n", mid);

    PersistPushpopStateArgs_pop_modal(s2);
    int bottom = PersistPushpopStateArgs_get_slot(s2);
    if (bottom != -99) { printf("FAIL: bottom %d\n", bottom); return 1; }
    printf("4. After second pop slot=%d\n", bottom);

    printf("PASS: 58_persist_pushpop_state_args\n");
    free(snap);
    PersistPushpopStateArgs_destroy(s1);
    PersistPushpopStateArgs_destroy(s2);
    return 0;
}

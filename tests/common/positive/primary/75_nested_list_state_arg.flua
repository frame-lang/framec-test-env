@@[target("lua")]

@@[persist(string)]
@@[save(save_state)]
@@[load(restore_state)]
@@system NestedList {
    interface:
        configure(rows: table)
        first_first(): int
        outer_size(): int

    machine:
        $Idle {
            configure(rows: table) { -> $Active(rows) }
            first_first(): int { @@:(-1) }
            outer_size(): int { @@:(0) }
        }
        $Active(rows: table) {
            configure(rows: table) { -> $Active(rows) }
            first_first(): int { @@:(rows[1][1]) }
            outer_size(): int { @@:(#rows) }
        }
    domain:
        n: int = 0
}

local s1 = NestedList:new()
s1:configure({{10, 20}, {30, 40}})
if s1:first_first() ~= 10 then print("FAIL pre"); os.exit(1) end
if s1:outer_size() ~= 2 then print("FAIL size"); os.exit(1) end
local snap = s1:save_state()
local s2 = NestedList:new()

s2:restore_state(snap)
if s2:first_first() ~= 10 then print("FAIL post"); os.exit(1) end
if s2:outer_size() ~= 2 then print("FAIL post size"); os.exit(1) end
print("PASS: 75_nested_list_state_arg")

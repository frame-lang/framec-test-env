@@[target("lua")]
@@system WithTransition {
    interface:
        next()
        get_state(): str

    machine:
        $First {
            next() {
                -- print
                -> $Second
            
            }

            get_state(): str {
                @@:("First")
                return
            }
        }

        $Second {
            next() {
                -- print
                -> $First
            
            }

            get_state(): str {
                @@:("Second")
                return
            }
        }
}

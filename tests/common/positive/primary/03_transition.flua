@@target lua
@@system WithTransition {
    interface:
        next()
        get_state(): str

    machine:
        $First {
            next() {
                -- print
                -> $Second
            
            }

            get_state(): str {
                return "First"
            }
        }

        $Second {
            next() {
                -- print
                -> $First
            
            }

            get_state(): str {
                return "Second"
            }
        }
}

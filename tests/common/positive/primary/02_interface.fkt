@@[target("kotlin")]

import kotlin.system.exitProcess

@@system WithInterface {
    interface:
        greet(name: String): String
        get_count(): Int

    machine:
        $Ready {
            greet(name: String): String {
                this.call_count += 1
                @@:("Hello, " + name + "!")
                return;
            }

            get_count(): Int {
                @@:(this.call_count)
                return;
            }
        }
    domain:
        call_count = 0
}

fun main() {
    println("=== Test 02: Interface Methods ===")
    val s = @@WithInterface()

    // Test interface method with parameter and return
    val result = s.greet("World") as String
    if (result != "Hello, World!") {
        throw RuntimeException("Expected 'Hello, World!', got '$result'")
    }
    println("greet('World') = $result")

    // Test domain variable access through interface
    val count = s.get_count() as Int
    if (count != 1) {
        throw RuntimeException("Expected count=1, got $count")
    }
    println("get_count() = $count")

    // Call again to verify state
    s.greet("Frame")
    val count2 = s.get_count() as Int
    if (count2 != 2) {
        throw RuntimeException("Expected count=2, got $count2")
    }
    println("After second call: get_count() = $count2")

    println("PASS: Interface methods work correctly")
}

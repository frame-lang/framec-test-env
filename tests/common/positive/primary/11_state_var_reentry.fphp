<?php
@@target php

@@system StateVarReentry {
    interface:
        increment(): int
        get_count(): int
        go_other()
        come_back()

    machine:
        $Counter {
            $.count: int = 0

            increment(): int {
                $.count = $.count + 1;
                @@:($.count)
                return;
            }

            get_count(): int {
                @@:($.count)
                return;
            }

            go_other() {
                -> $Other
            }
        }

        $Other {
            come_back() {
                -> $Counter
            }

            increment(): int {
                @@:(-1)
                return;
            }

            get_count(): int {
                @@:(-1)
                return;
            }
        }
}

echo "=== Test 11: State Variable Reentry ===" . "\n";
$s = new StateVarReentry();

$s->increment();
$s->increment();
$count = $s->get_count();
if ($count !== 2) { echo "FAIL: Expected 2 after two increments, got {$count}\n"; exit(1); }
echo "Count before leaving: {$count}" . "\n";

$s->go_other();
echo "Transitioned to Other state" . "\n";

$s->come_back();
$count = $s->get_count();
if ($count !== 0) { echo "FAIL: Expected 0 after re-entering Counter (state var reinit), got {$count}\n"; exit(1); }
echo "Count after re-entering Counter: {$count}" . "\n";

$result = $s->increment();
if ($result !== 1) { echo "FAIL: Expected 1 after increment, got {$result}\n"; exit(1); }
echo "After increment: {$result}" . "\n";

echo "PASS: State variables reinitialize on state reentry" . "\n";

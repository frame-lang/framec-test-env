// @@skip
// Persist tests need System.Text.Json pipeline support for C#
@@target csharp

using System;
using System.Collections.Generic;

@@persist
@@system PersistRoundtrip {
    interface:
        set_counter(v: int)
        get_counter(): int
        go_active()
        go_idle()
        get_state(): string
        add_history(entry: string)
        get_history(): string

    machine:
        $Idle {
            set_counter(v: int) { counter = v; }
            get_counter(): int { return counter; }
            go_active() {
                this.add_history("idle->active");
                -> $Active
            }
            go_idle() { }
            get_state(): string { return "idle"; }
            add_history(entry: string) { history = history + entry + ","; }
            get_history(): string { return history; }
        }

        $Active {
            set_counter(v: int) { counter = v * 2; }
            get_counter(): int { return counter; }
            go_active() { }
            go_idle() {
                this.add_history("active->idle");
                -> $Idle
            }
            get_state(): string { return "active"; }
            add_history(entry: string) { history = history + entry + ","; }
            get_history(): string { return history; }
        }
    domain:
        int counter = 0
        string history = ""
        string mode = "normal"
}

class Program {
    static void Main(string[] args) {
        Console.WriteLine("=== Test 24: Persist Roundtrip (C#) ===");
        Console.WriteLine("SKIP: Persist tests need System.Text.Json pipeline support");
    }
}

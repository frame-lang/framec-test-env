@@[target("erlang")]

%% Test: const domain field initialized from system param.
%% Erlang test: basic const domain without param override.

@@system Sensor(threshold: int = 100) {
    interface:
        read(): int
        calibrate(offset: int)
        get_threshold(): int

    machine:
        $Active {
            read(): int {
                @@:(self.value + self.offset)
            }
            calibrate(offset: int) {
                self.offset = offset
            }
            get_threshold(): int {
                @@:(self.threshold)
            }
        }

    domain:
        const threshold = threshold
        value = 50
        offset = 0
}

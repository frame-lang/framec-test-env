@@target dart

@@system DomainVars {
    interface:
        increment()
        decrement()
        get_count(): int
        set_count(value: int)

    machine:
        $Counting {
            increment() {
                this.count += 1;
                print("${this.name}: incremented to ${this.count}");
            }

            decrement() {
                this.count -= 1;
                print("${this.name}: decremented to ${this.count}");
            }

            get_count(): int {
                @@:(this.count)
                return;
            }

            set_count(value: int) {
                this.count = value;
                print("${this.name}: set to ${this.count}");
            }
        }
    domain:
        count: int = 0
        name: String = "counter"
}

void main() {
    print("== Test 06: Domain Variables ==");
    final s = @@DomainVars();

    // Initial value should be 0
    var count = s.get_count();
    if (count != 0) {
        throw Exception("Expected initial count=0, got ${count}");
    }
    print("Initial count: ${count}");

    // Increment
    s.increment();
    count = s.get_count();
    if (count != 1) {
        throw Exception("Expected count=1, got ${count}");
    }

    s.increment();
    count = s.get_count();
    if (count != 2) {
        throw Exception("Expected count=2, got ${count}");
    }

    // Decrement
    s.decrement();
    count = s.get_count();
    if (count != 1) {
        throw Exception("Expected count=1, got ${count}");
    }

    // Set directly
    s.set_count(100);
    count = s.get_count();
    if (count != 100) {
        throw Exception("Expected count=100, got ${count}");
    }

    print("Final count: ${count}");
    print("PASS: Domain variables work correctly");
}


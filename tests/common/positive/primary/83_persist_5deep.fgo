@@[target("go")]

package main

import (
    "encoding/json"
    "fmt"
)

var _ = json.Marshal

@@[persist]
@@system L5 {
    interface:
        bump()
        value(): int
    machine:
        $S { bump() { s.n = s.n + 1 } value(): int { @@:(s.n) } }
    domain: n: int = 0
}

@@system L4 {
    interface:
        bump()
        value(): int
    machine:
        $S {
            bump() { s.n = s.n + 1; s.child.Bump() }
            value(): int { @@:(s.n + s.child.Value()) }
        }
    domain:
        n: int = 0
        child: *L5 = @@L5()
}

@@system L3 {
    interface:
        bump()
        value(): int
    machine:
        $S {
            bump() { s.n = s.n + 1; s.child.Bump() }
            value(): int { @@:(s.n + s.child.Value()) }
        }
    domain:
        n: int = 0
        child: *L4 = @@L4()
}

@@system L2 {
    interface:
        bump()
        value(): int
    machine:
        $S {
            bump() { s.n = s.n + 1; s.child.Bump() }
            value(): int { @@:(s.n + s.child.Value()) }
        }
    domain:
        n: int = 0
        child: *L3 = @@L3()
}

@@system L1 {
    interface:
        bump()
        value(): int
    machine:
        $S {
            bump() { s.n = s.n + 1; s.child.Bump() }
            value(): int { @@:(s.n + s.child.Value()) }
        }
    domain:
        n: int = 0
        child: *L2 = @@L2()
}

func main() {
    a := NewL1()
    a.Bump(); a.Bump(); a.Bump()
    pre := a.Value()
    if pre != 15 { fmt.Println("FAIL pre:", pre); return }
    snap := a.SaveState()
    b := RestoreL1(snap)
    post := b.Value()
    if post != 15 { fmt.Println("FAIL post:", post); return }
    b.Bump()
    after := b.Value()
    if after != 20 { fmt.Println("FAIL after:", after); return }
    fmt.Println("PASS: 83_persist_5deep")
}

@@[target("gdscript")]
extends SceneTree
@@[persist]

@@system PFloat {
    operations:
        @@[save]
        save_state(): String {}

        @@[load]
        restore_state(data: String) {}

    interface:
        configure(rate: float)
        get_rate(): float

    machine:
        $Idle {
            configure(rate: float) {
                -> $Active(rate)
            }
            get_rate(): float {
                @@:(0.0)
            }
        }

        $Active(rate: float) {
            get_rate(): float {
                @@:(rate)
            }
        }
    domain:
        n: int = 0
}

func _initialize():
    var s = PFloat.new()
    s.configure(3.14159)
    var snap = s.save_state()
    var s2 = PFloat.new()

    s2.restore_state(snap)
    var r = s2.get_rate()
    if abs(r - 3.14159) > 1e-9:
        print("FAIL " + str(r)); quit(1); return
    print("PASS: 69_persist_float_state_arg, rate=" + str(r))
    quit(0)

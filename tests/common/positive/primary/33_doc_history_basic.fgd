@@target gdscript
extends SceneTree

# Documentation Example: History with push$/pop$ (History201)

@@system HistoryBasic {
    interface:
        gotoC_from_A()
        gotoC_from_B()
        gotoB()
        return_back()
        get_state(): String

    machine:
        $A {
            gotoC_from_A() {
                push$
                -> $C
            }
            gotoB() {
                -> $B
            }
            get_state(): String {
                @@:("A")
                return
            }
        }

        $B {
            gotoC_from_B() {
                push$
                -> $C
            }
            get_state(): String {
                @@:("B")
                return
            }
        }

        $C {
            return_back() {
                -> pop$
            }
            get_state(): String {
                @@:("C")
                return
            }
        }
}

func main():
    print("=== Test 33: Doc History Basic ===")
    var h = @@HistoryBasic()

    # Start in A
    assert(h.get_state() == "A", "Expected 'A', got '" + str(h.get_state()) + "'")

    # Go to C from A (push A)
    h.gotoC_from_A()
    assert(h.get_state() == "C", "Expected 'C', got '" + str(h.get_state()) + "'")

    # Return back (pop to A)
    h.return_back()
    assert(h.get_state() == "A", "Expected 'A' after pop, got '" + str(h.get_state()) + "'")

    # Now go to B
    h.gotoB()
    assert(h.get_state() == "B", "Expected 'B', got '" + str(h.get_state()) + "'")

    # Go to C from B (push B)
    h.gotoC_from_B()
    assert(h.get_state() == "C", "Expected 'C', got '" + str(h.get_state()) + "'")

    # Return back (pop to B)
    h.return_back()
    assert(h.get_state() == "B", "Expected 'B' after pop, got '" + str(h.get_state()) + "'")

    print("PASS: History push/pop works correctly")

func _init():
    main()
    quit()

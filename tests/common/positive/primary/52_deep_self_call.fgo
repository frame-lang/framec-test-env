@@[target("go")]

package main

import "fmt"
import "os"

// Test: deep @@:self.iface() stack — transition guard propagation
//
// Validates:
// 1. Full chain completes when no transition fires
// 2. Transition at depth 3 suppresses all "after" traces
// 3. Transition at depth 2 prevents deeper calls
// 4. Sequential self-calls: second suppressed after first transitions
// 5. Sequential self-calls: both complete when no transition

@@system DeepSelfCall {
    interface:
        StartChain(mode: string): string
        LevelOne(mode: string): string
        LevelTwo(mode: string): string
        LevelThree(mode: string): string
        GetTrace(): string
        GetState(): string
        Reset()

    machine:
        $Active {
            StartChain(mode: string): string {
                s.trace = ""
                s.trace = s.trace + "start:before;"
                @@:self.LevelOne(mode)
                s.trace = s.trace + "start:after;"
                @@:(s.trace)
            }

            LevelOne(mode: string): string {
                s.trace = s.trace + "L1:before;"
                @@:self.LevelTwo(mode)
                s.trace = s.trace + "L1:after;"
                @@:(s.trace)
            }

            LevelTwo(mode: string): string {
                s.trace = s.trace + "L2:before;"
                if mode == "transition_at_two" {
                    s.trace = s.trace + "L2:transitioning;"
                    -> $Done
                }
                @@:self.LevelThree(mode)
                s.trace = s.trace + "L2:after;"
                @@:(s.trace)
            }

            LevelThree(mode: string): string {
                s.trace = s.trace + "L3:before;"
                if mode == "transition_at_three" {
                    s.trace = s.trace + "L3:transitioning;"
                    -> $Done
                }
                s.trace = s.trace + "L3:after;"
                @@:(s.trace)
            }

            GetTrace(): string {
                @@:(s.trace)
            }

            GetState(): string { @@:(@@:system.state) }

            Reset() {
                s.trace = ""
            }
        }

        $Done {
            GetTrace(): string {
                @@:(s.trace)
            }

            GetState(): string { @@:(@@:system.state) }

            Reset() {
                s.trace = ""
                -> $Active
            }
        }

    domain:
        trace : string
}

@@system SequentialSelfCall {
    interface:
        RunSequence(mode: string): string
        FirstCall(mode: string): string
        SecondCall(): string
        GetTrace(): string
        GetState(): string

    machine:
        $Active {
            RunSequence(mode: string): string {
                s.trace = ""
                s.trace = s.trace + "seq:before_first;"
                @@:self.FirstCall(mode)
                s.trace = s.trace + "seq:between;"
                @@:self.SecondCall()
                s.trace = s.trace + "seq:after_second;"
                @@:(s.trace)
            }

            FirstCall(mode: string): string {
                if mode == "transition_first" {
                    s.trace = s.trace + "first:transitioning;"
                    -> $Done
                }
                s.trace = s.trace + "first:complete;"
                @@:(s.trace)
            }

            SecondCall(): string {
                s.trace = s.trace + "second:complete;"
                @@:(s.trace)
            }

            GetTrace(): string { @@:(s.trace) }
            GetState(): string { @@:(@@:system.state) }
        }

        $Done {
            GetTrace(): string { @@:(s.trace) }
            GetState(): string { @@:(@@:system.state) }
        }

    domain:
        trace : string
}

func main() {
	failures := 0

	// === Scenario 1: No transition — full chain completes ===
	s := NewDeepSelfCall()
	result := s.StartChain("no_transition")
	expected := "start:before;L1:before;L2:before;L3:before;L3:after;L2:after;L1:after;start:after;"
	if result != expected {
		fmt.Printf("FAIL scenario 1: expected '%s'\n", expected)
		fmt.Printf("                 got      '%s'\n", result)
		failures++
	}
	if s.GetState() != "Active" {
		fmt.Printf("FAIL scenario 1: state should be Active, got '%s'\n", s.GetState())
		failures++
	}

	// === Scenario 2: Transition at level_three — all "after" traces suppressed ===
	s.Reset()
	s.StartChain("transition_at_three")
	trace := s.GetTrace()
	expectedTrace := "start:before;L1:before;L2:before;L3:before;L3:transitioning;"
	if trace != expectedTrace {
		fmt.Printf("FAIL scenario 2 trace: expected '%s'\n", expectedTrace)
		fmt.Printf("                       got      '%s'\n", trace)
		failures++
	}
	if s.GetState() != "Done" {
		fmt.Printf("FAIL scenario 2: state should be Done, got '%s'\n", s.GetState())
		failures++
	}

	// === Scenario 3: Transition at level_two — level_three never called ===
	s.Reset()
	s.StartChain("transition_at_two")
	trace = s.GetTrace()
	expectedTrace = "start:before;L1:before;L2:before;L2:transitioning;"
	if trace != expectedTrace {
		fmt.Printf("FAIL scenario 3 trace: expected '%s'\n", expectedTrace)
		fmt.Printf("                       got      '%s'\n", trace)
		failures++
	}
	if s.GetState() != "Done" {
		fmt.Printf("FAIL scenario 3: state should be Done, got '%s'\n", s.GetState())
		failures++
	}

	// === Scenario 4: Sequential self-calls — second suppressed after first transitions ===
	s2 := NewSequentialSelfCall()
	s2.RunSequence("transition_first")
	trace = s2.GetTrace()
	expectedTrace = "seq:before_first;first:transitioning;"
	if trace != expectedTrace {
		fmt.Printf("FAIL scenario 4 trace: expected '%s'\n", expectedTrace)
		fmt.Printf("                       got      '%s'\n", trace)
		failures++
	}
	if s2.GetState() != "Done" {
		fmt.Printf("FAIL scenario 4: state should be Done, got '%s'\n", s2.GetState())
		failures++
	}

	// === Scenario 5: Sequential self-calls — no transition, both complete ===
	s3 := NewSequentialSelfCall()
	s3.RunSequence("no_transition")
	trace = s3.GetTrace()
	expectedTrace = "seq:before_first;first:complete;seq:between;second:complete;seq:after_second;"
	if trace != expectedTrace {
		fmt.Printf("FAIL scenario 5 trace: expected '%s'\n", expectedTrace)
		fmt.Printf("                       got      '%s'\n", trace)
		failures++
	}

	if failures > 0 {
		fmt.Printf("FAIL: deep_self_call (%d failures)\n", failures)
		os.Exit(1)
	}
	fmt.Println("PASS: deep_self_call")
}

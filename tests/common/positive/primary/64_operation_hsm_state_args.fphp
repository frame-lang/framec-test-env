@@[target("php")]

@@system OpHsmStateArgs {
    operations:
        add_offset(x: int, off: int): int {
            return $x + $off;
        }

    interface:
        enter_active(t: int)
        classify(v: int): int

    machine:
        $Idle {
            enter_active(t: int) {
                -> $Active($t)
            }
            classify(v: int): int {
                @@:(-1)
                return;
            }
        }

        $Active => $Frame(threshold: int) {
            enter_active(t: int) {
                -> $Active($t)
            }
            classify(v: int): int {
                $r = $this->add_offset($v, $threshold);
                @@:($r)
                return;
            }
        }

        $Frame {
        }
    domain:
        n: int = 0
}

echo "=== Test 64: Operations × HSM × state-args (PHP) ===\n";
$s = @@OpHsmStateArgs();

$pre = $s->classify(5);
if ($pre !== -1) { echo "FAIL: pre $pre\n"; exit(1); }
echo "1. Idle classify(5) = $pre\n";

$s->enter_active(10);
$r = $s->classify(5);
if ($r !== 15) { echo "FAIL: r $r\n"; exit(1); }
echo "2. classify(5) with threshold=10 → $r\n";

$r2 = $s->classify(7);
if ($r2 !== 17) { echo "FAIL: r2 $r2\n"; exit(1); }
echo "3. classify(7) with threshold=10 → $r2\n";

$s->enter_active(100);
$r3 = $s->classify(5);
if ($r3 !== 105) { echo "FAIL: r3 $r3\n"; exit(1); }
echo "4. classify(5) with threshold=100 → $r3\n";

echo "PASS: 64_operation_hsm_state_args\n";

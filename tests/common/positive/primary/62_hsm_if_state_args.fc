@@[target("c")]

#include <stdio.h>
#include <stdlib.h>
#include <string.h>

@@system HsmIfStateArgs {
    interface:
        enter_active(t: int)
        classify(v: int): int

    machine:
        $Idle {
            enter_active(t: int) {
                -> $Active(t)
            }
            classify(v: int): int {
                @@:(-1)
            }
        }

        $Active => $Frame(threshold: int) {
            enter_active(t: int) {
                -> $Active(t)
            }
            classify(v: int): int {
                if (v > threshold) {
                    @@:(1)
                } else {
                    @@:(0)
                }
            }
        }

        $Frame {
        }
    domain:
        n : int = 0
}

int main(void) {
    printf("=== Test 62: HSM × if × state-args (C) ===\n");
    HsmIfStateArgs* s = @@HsmIfStateArgs();

    int pre = HsmIfStateArgs_classify(s, 5);
    if (pre != -1) { printf("FAIL: pre %d\n", pre); return 1; }
    printf("1. Idle classify(5) = %d\n", pre);

    HsmIfStateArgs_enter_active(s, 10);
    int under = HsmIfStateArgs_classify(s, 5);
    if (under != 0) { printf("FAIL: under %d\n", under); return 1; }
    printf("2. classify(5) with threshold=10 -> %d\n", under);

    int over = HsmIfStateArgs_classify(s, 15);
    if (over != 1) { printf("FAIL: over %d\n", over); return 1; }
    printf("3. classify(15) with threshold=10 -> %d\n", over);

    int eq = HsmIfStateArgs_classify(s, 10);
    if (eq != 0) { printf("FAIL: eq %d\n", eq); return 1; }
    printf("4. classify(10) with threshold=10 -> %d\n", eq);

    HsmIfStateArgs_enter_active(s, 50);
    int new_under = HsmIfStateArgs_classify(s, 15);
    if (new_under != 0) { printf("FAIL: new_under %d\n", new_under); return 1; }
    printf("5. classify(15) with threshold=50 -> %d\n", new_under);

    printf("PASS: 62_hsm_if_state_args\n");
    HsmIfStateArgs_destroy(s);
    return 0;
}

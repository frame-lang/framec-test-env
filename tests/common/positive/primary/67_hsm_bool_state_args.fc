@@target c

#include <stdio.h>
#include <stdlib.h>
#include <string.h>
#include <stdbool.h>

@@system BoolStateArg {
    interface:
        configure(active: bool)
        is_active(): bool

    machine:
        $Idle {
            configure(active: bool) {
                -> $Active(active)
            }
            is_active(): bool {
                @@:(false)
            }
        }

        $Active => $Frame(flag: bool) {
            configure(active: bool) {
                -> $Active(active)
            }
            is_active(): bool {
                => $^
            }
        }

        $Frame {
            is_active(): bool {
                @@:(flag)
            }
        }
    domain:
        n : int = 0
}

int main(void) {
    BoolStateArg* s = BoolStateArg_new();
    if (BoolStateArg_is_active(s) != false) { printf("FAIL idle\n"); return 1; }
    BoolStateArg_configure(s, true);
    if (BoolStateArg_is_active(s) != true) { printf("FAIL true\n"); return 1; }
    BoolStateArg_configure(s, false);
    if (BoolStateArg_is_active(s) != false) { printf("FAIL false\n"); return 1; }
    BoolStateArg_configure(s, true);
    if (BoolStateArg_is_active(s) != true) { printf("FAIL re-true\n"); return 1; }
    printf("PASS: 67_hsm_bool_state_args\n");
    BoolStateArg_destroy(s);
    return 0;
}

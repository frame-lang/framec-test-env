@@[target("lua")]
@@system EnterExit {
    interface:
        toggle()
        get_log(): list

    machine:
        $Off {
            $>() {
                self.log[#self.log + 1] = "enter:Off"
                -- print
            }

            <$() {
                self.log[#self.log + 1] = "exit:Off"
                -- print
            }

            toggle() {
                -> $On
            }

            get_log(): list {
                @@:(self.log)
                return
            }
        }

        $On {
            $>() {
                self.log[#self.log + 1] = "enter:On"
                -- print
            }

            <$() {
                self.log[#self.log + 1] = "exit:On"
                -- print
            }

            toggle() {
                -> $Off
            }

            get_log(): list {
                @@:(self.log)
                return
            }
        }
    domain:
        log: list = []
}

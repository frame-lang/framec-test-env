@@[target("typescript")]

// Test 47: HSM Enter Cascade — Both Parent and Child have $>
//
// Tests the HSM enter cascade per docs/frame_runtime_introduction.md
// Step 21+. When entering an HSM child, the kernel fires $> on every
// layer of the new chain top-down (parent first, child last).

@@system HSMEnterBoth {
    interface:
        go_to_child()
        go_to_parent()
        get_log(): string[]
        get_state(): str

    machine:
        $Start {
            go_to_child() {
                -> $Child
            }

            go_to_parent() {
                -> $Parent
            }

            get_log(): list {
                @@:(this.log)
                return;
            }

            get_state(): str {
                @@:("Start")
                return;
            }
        }

        $Child => $Parent {
            $>() {
                this.log.push("Child:enter")
            }

            go_to_parent() {
                -> $Parent
            }

            get_log(): list {
                @@:(this.log)
                return;
            }

            get_state(): str {
                @@:("Child")
                return;
            }
        }

        $Parent {
            $>() {
                this.log.push("Parent:enter")
            }

            go_to_child() {
                -> $Child
            }

            get_log(): list {
                @@:(this.log)
                return;
            }

            get_state(): str {
                @@:("Parent")
                return;
            }
        }
    domain:
        log: string[] = []
}

function main() {
    console.log("=== Test 47: HSM Enter Cascade — Both ===");
    const s = @@HSMEnterBoth();

    // TC1: Entering Child fires Parent's $> first (top-down cascade),
    // then Child's $>.
    s.go_to_child();
    let log = s.get_log();
    if (s.get_state() !== "Child") throw new Error(`Expected Child, got ${s.get_state()}`);
    if (!log.includes("Parent:enter")) throw new Error(`Expected Parent:enter (cascade), got ${JSON.stringify(log)}`);
    if (!log.includes("Child:enter")) throw new Error(`Expected Child:enter, got ${JSON.stringify(log)}`);
    const parentIdx = log.indexOf("Parent:enter");
    const childIdx = log.indexOf("Child:enter");
    if (parentIdx >= childIdx) throw new Error(`Parent:enter should fire BEFORE Child:enter (top-down), got ${JSON.stringify(log)}`);
    console.log("TC1: Parent's $> fires before Child's $> on cascade entry - PASS");

    // TC2: Direct entry to Parent fires Parent's $> only.
    s.go_to_parent();
    log = s.get_log();
    if (s.get_state() !== "Parent") throw new Error(`Expected Parent, got ${s.get_state()}`);
    let parentCount = log.filter((x: string) => x === "Parent:enter").length;
    let childCount = log.filter((x: string) => x === "Child:enter").length;
    if (parentCount !== 2) throw new Error(`Expected 2 Parent:enter (cascade + direct), got ${parentCount}: ${JSON.stringify(log)}`);
    if (childCount !== 1) throw new Error(`Expected still 1 Child:enter, got ${childCount}: ${JSON.stringify(log)}`);
    console.log("TC2: Direct Parent entry fires only Parent's $> - PASS");

    // TC3: Transitioning back to Child fires both cascades.
    s.go_to_child();
    log = s.get_log();
    parentCount = log.filter((x: string) => x === "Parent:enter").length;
    childCount = log.filter((x: string) => x === "Child:enter").length;
    if (parentCount !== 3) throw new Error(`Expected 3 Parent:enter total, got ${parentCount}: ${JSON.stringify(log)}`);
    if (childCount !== 2) throw new Error(`Expected 2 Child:enter total, got ${childCount}: ${JSON.stringify(log)}`);
    console.log("TC3: Re-entering Child cascades through Parent again - PASS");

    console.log("PASS: HSM enter cascade fires both layers top-down");
}

main();

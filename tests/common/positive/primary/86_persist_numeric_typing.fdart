@@[target("dart")]

import 'dart:convert';
import 'dart:io';

@@[persist(String)]
@@[save(saveState)]
@@[load(restoreState)]
@@system Inner {
    interface:
        bump_int()
        bump_float()
        flip_bool()
        get_n_int(): int
        get_n_float(): double
        get_n_bool(): bool
        get_n_str(): String

    machine:
        $S {
            bump_int() { this.n_int = this.n_int + 1; }
            bump_float() { this.n_float = this.n_float + 0.25; }
            flip_bool() { this.n_bool = !this.n_bool; }
            get_n_int(): int { @@:(this.n_int) }
            get_n_float(): double { @@:(this.n_float) }
            get_n_bool(): bool { @@:(this.n_bool) }
            get_n_str(): String { @@:(this.n_str) }
        }
    domain:
        n_int: int = 7
        n_float: double = 2.5
        n_bool: bool = true
        n_str: String = "hello"
}@@[persist(String)]
@@[save(saveState)]
@@[load(restoreState)]


@@[main]
@@system Outer {
    interface:
        bump_k_int()
        bump_k_float()
        bump_inner_int()
        bump_inner_float()
        flip_inner_bool()
        get_k_int(): int
        get_k_float(): double
        get_n_int(): int
        get_n_float(): double
        get_n_bool(): bool
        get_n_str(): String

    machine:
        $S {
            bump_k_int() { this.k_int = this.k_int + 1; }
            bump_k_float() { this.k_float = this.k_float + 0.25; }
            bump_inner_int() { this.inner.bump_int(); }
            bump_inner_float() { this.inner.bump_float(); }
            flip_inner_bool() { this.inner.flip_bool(); }
            get_k_int(): int { @@:(this.k_int) }
            get_k_float(): double { @@:(this.k_float) }
            get_n_int(): int { @@:(this.inner.get_n_int()) }
            get_n_float(): double { @@:(this.inner.get_n_float()) }
            get_n_bool(): bool { @@:(this.inner.get_n_bool()) }
            get_n_str(): String { @@:(this.inner.get_n_str()) }
        }
    domain:
        k_int: int = 42
        k_float: double = 1.25
        inner: Inner = @@Inner()
}

void assertState(Outer o, String label, String kIntStr, double kFloat, String nIntStr, double nFloat, bool nBool, String nStr) {
    if (o.get_k_int().toString() != kIntStr) { print("FAIL $label k_int: ${o.get_k_int()}"); exit(1); }
    if (o.get_n_int().toString() != nIntStr) { print("FAIL $label n_int: ${o.get_n_int()}"); exit(1); }
    if ((o.get_k_float() - kFloat).abs() > 1e-9) { print("FAIL $label k_float: ${o.get_k_float()}"); exit(1); }
    if ((o.get_n_float() - nFloat).abs() > 1e-9) { print("FAIL $label n_float: ${o.get_n_float()}"); exit(1); }
    if (o.get_n_bool() != nBool) { print("FAIL $label n_bool: ${o.get_n_bool()}"); exit(1); }
    if (o.get_n_str() != nStr) { print("FAIL $label n_str: ${o.get_n_str()}"); exit(1); }
}

void main() {
    var o = @@Outer();
    assertState(o, "T0", "42", 1.25, "7", 2.5, true, "hello");

    o.bump_k_int();
    o.bump_k_float();
    o.bump_inner_int();
    o.bump_inner_float();
    o.flip_inner_bool();
    assertState(o, "T1", "43", 1.5, "8", 2.75, false, "hello");

    var snap = o.saveState();
    final r = @@Outer();

    r.restoreState(snap);
    assertState(r, "T1 restored", "43", 1.5, "8", 2.75, false, "hello");

    r.bump_k_int();
    r.bump_inner_int();
    assertState(r, "continue", "44", 1.5, "9", 2.75, false, "hello");

    print("PASS: 86_persist_numeric_typing");
}

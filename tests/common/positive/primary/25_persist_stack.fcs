// @@skip
// Persist tests need System.Text.Json pipeline support for C#
@@target csharp

using System;
using System.Collections.Generic;

@@persist
@@system PersistStack {
    interface:
        push_and_go()
        pop_back()
        get_state(): string
        get_depth(): int

    machine:
        $Start {
            push_and_go() {
                depth = depth + 1;
                push$
                -> $Middle
            }
            pop_back() { }
            get_state(): string { return "start"; }
            get_depth(): int { return depth; }
        }

        $Middle {
            push_and_go() {
                depth = depth + 1;
                push$
                -> $End
            }
            pop_back() {
                depth = depth - 1;
                -> pop$
            }
            get_state(): string { return "middle"; }
            get_depth(): int { return depth; }
        }

        $End {
            push_and_go() { }
            pop_back() {
                depth = depth - 1;
                -> pop$
            }
            get_state(): string { return "end"; }
            get_depth(): int { return depth; }
        }
    domain:
        int depth = 0
}

class Program {
    static void Main(string[] args) {
        Console.WriteLine("=== Test 25: Persist Stack (C#) ===");
        Console.WriteLine("SKIP: Persist tests need System.Text.Json pipeline support");
    }
}

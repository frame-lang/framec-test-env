@@target swift

// =============================================================================
// Test 01: Interface Return
// =============================================================================
// Validates that event handler returns work correctly via the context stack.
// Tests both syntaxes:
// =============================================================================

@@system InterfaceReturn {
    interface:
        bool_return(): boolean
        int_return(): number
        string_return(): string
        conditional_return(x: number): string
        computed_return(a: number, b: number): number
        explicit_bool(): boolean
        explicit_int(): number
        explicit_string(): string
        explicit_conditional(x: number): string
        explicit_computed(a: number, b: number): number

    machine:
        $Active {
            bool_return(): boolean {
                @@:(true)
                return;
            }

            int_return(): number {
                @@:(42)
                return;
            }

            string_return(): string {
                @@:("Frame")
                return;
            }

            conditional_return(x: number): string {
                if (x < 0) {
                    @@:("negative")
                    return;
                } else if (x == 0) {
                    @@:("zero")
                    return;
                } else {
                    @@:("positive")
                    return;
                }
            }

            computed_return(a: number, b: number): number {
                let result = a * b + 10
                @@:(result)
                return;
            }

            explicit_bool(): boolean {
                @@:(true)
            }

            explicit_int(): number {
                @@:(42)
            }

            explicit_string(): string {
                @@:("Frame")
            }

            explicit_conditional(x: number): string {
                if (x < 0) {
                    @@:("negative")
                    return
                } else if (x == 0) {
                    @@:("zero")
                    return
                } else {
                    @@:("positive")
                }
            }

            explicit_computed(a: number, b: number): number {
                let result = a * b + 10
                @@:(result)
            }
        }
}

// main
    print("=== Test 01: Interface Return (Swift) ===")
    let s = @@InterfaceReturn()
    var errors: [String] = []

    print("-- Testing 'return value' sugar --")

    var r: Any = s.bool_return()
    if (r as! Bool) != true {
        errors.append("bool_return: expected true, got \(r)")
    } else {
        print("1. bool_return() = \(r)")
    }

    r = s.int_return()
    if (r as! Int) != 42 {
        errors.append("int_return: expected 42, got \(r)")
    } else {
        print("2. int_return() = \(r)")
    }

    r = s.string_return()
    if (r as! String) != "Frame" {
        errors.append("string_return: expected 'Frame', got '\(r)'")
    } else {
        print("3. string_return() = '\(r)'")
    }

    r = s.conditional_return(-5)
    if (r as! String) != "negative" {
        errors.append("conditional_return(-5): expected 'negative', got '\(r)'")
    }
    r = s.conditional_return(0)
    if (r as! String) != "zero" {
        errors.append("conditional_return(0): expected 'zero', got '\(r)'")
    }
    r = s.conditional_return(10)
    if (r as! String) != "positive" {
        errors.append("conditional_return(10): expected 'positive', got '\(r)'")
    } else {
        print("4. conditional_return(-5,0,10) = 'negative','zero','positive'")
    }

    r = s.computed_return(3, 4)
    if (r as! Int) != 22 {
        errors.append("computed_return(3,4): expected 22, got \(r)")
    } else {
        print("5. computed_return(3,4) = \(r)")
    }


    r = s.explicit_bool()
    if (r as! Bool) != true {
        errors.append("explicit_bool: expected true, got \(r)")
    } else {
        print("6. explicit_bool() = \(r)")
    }

    r = s.explicit_int()
    if (r as! Int) != 42 {
        errors.append("explicit_int: expected 42, got \(r)")
    } else {
        print("7. explicit_int() = \(r)")
    }

    r = s.explicit_string()
    if (r as! String) != "Frame" {
        errors.append("explicit_string: expected 'Frame', got '\(r)'")
    } else {
        print("8. explicit_string() = '\(r)'")
    }

    r = s.explicit_conditional(-5)
    if (r as! String) != "negative" {
        errors.append("explicit_conditional(-5): expected 'negative', got '\(r)'")
    }
    r = s.explicit_conditional(0)
    if (r as! String) != "zero" {
        errors.append("explicit_conditional(0): expected 'zero', got '\(r)'")
    }
    r = s.explicit_conditional(10)
    if (r as! String) != "positive" {
        errors.append("explicit_conditional(10): expected 'positive', got '\(r)'")
    } else {
        print("9. explicit_conditional(-5,0,10) = 'negative','zero','positive'")
    }

    r = s.explicit_computed(3, 4)
    if (r as! Int) != 22 {
        errors.append("explicit_computed(3,4): expected 22, got \(r)")
    } else {
        print("10. explicit_computed(3,4) = \(r)")
    }

    if errors.count > 0 {
        for e in errors {
            print("FAIL: \(e)")
        }
        fatalError("\(errors.count) test(s) failed")
    } else {
        print("PASS: All interface return tests passed")
    }

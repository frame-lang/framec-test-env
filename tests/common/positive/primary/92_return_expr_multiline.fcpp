@@[target("cpp_17")]

#include <iostream>

@@system Test {
    interface:
        ready(): bool

    machine:
        $Active {
            ready(): bool {
                @@:(this->timer >= this->threshold
                    && this->count < this->limit)
            }
        }
    domain:
        timer: int = 100
        threshold: int = 50
        count: int = 1
        limit: int = 5
}

int main() {
    auto t = @@Test();
    if (t.ready() != true) {
        std::cout << "FAIL ready(): " << t.ready() << std::endl;
        return 1;
    }
    std::cout << "PASS: 92_return_expr_multiline" << std::endl;
    return 0;
}

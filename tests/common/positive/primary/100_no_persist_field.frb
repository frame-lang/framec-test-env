@@[target("ruby")]

# Test 100: @@[no_persist] domain fields (RFC-0016.1)

@@[persist(String)]
@@[save(save_op)]
@@[load(load_op)]
@@system NoPersistField {
    interface:
        bump()
        set_cache(v: Integer)
        set_note(s: String)
        get_n(): Integer
        get_cache(): Integer
        get_note(): String

    machine:
        $Active {
            bump() { @n = @n + 1 }
            set_cache(v: Integer) { @cache = v }
            set_note(s: String) { @note = s }
            get_n(): Integer { @@:(@n) }
            get_cache(): Integer { @@:(@cache) }
            get_note(): String { @@:(@note) }
        }

    domain:
        n: Integer = 0
        @@[no_persist]
        cache: Integer = -1
        note: String = "fresh"
}

c1 = @@NoPersistField()
c1.bump
c1.bump
c1.bump
c1.set_cache(99)
c1.set_note("hello")
data = c1.save_op

c2 = @@NoPersistField()
c2.load_op(data)

if c2.get_n != 3
    puts "FAIL: expected n=3, got #{c2.get_n}"
elsif c2.get_note != "hello"
    puts "FAIL: expected note=hello, got #{c2.get_note}"
elsif c2.get_cache != -1
    puts "FAIL: expected cache=-1 (domain default; @@[no_persist] field not restored), got #{c2.get_cache}"
else
    puts "PASS: 100_no_persist_field"
end

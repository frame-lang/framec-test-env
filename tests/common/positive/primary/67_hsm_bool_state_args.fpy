@@[target("python_3")]

# Test 67: HSM cascade × state-args of type bool.
# Companion to tests 65 (int) and 66 (str) — exercises the typed
# state-arg prefetch path for boolean state-args. Drop-in extension
# of the D5 plumbing.

@@system BoolStateArg {
    interface:
        configure(active: bool)
        is_active(): bool

    machine:
        $Idle {
            configure(active: bool) {
                -> $Active(active)
            }
            is_active(): bool {
                @@:(False)
                return
            }
        }

        $Active => $Frame(flag: bool) {
            configure(active: bool) {
                -> $Active(active)
            }
            is_active(): bool {
                => $^
            }
        }

        $Frame {
            is_active(): bool {
                @@:(flag)
                return
            }
        }
    domain:
        n: int = 0
}

def main():
    s = @@BoolStateArg()
    assert s.is_active() == False
    s.configure(True)
    assert s.is_active() == True
    s.configure(False)
    assert s.is_active() == False
    s.configure(True)
    assert s.is_active() == True
    print("PASS: 67_hsm_bool_state_args")

if __name__ == '__main__':
    main()

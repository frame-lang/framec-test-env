@@target typescript

@@persist
@@system PersistPushpopStateArgs {
    interface:
        push_modal(v: int)
        pop_modal()
        get_slot(): int

    machine:
        $Idle {
            push_modal(v: number) {
                push$
                -> $Modal(v)
            }
            pop_modal() {
                -> pop$
            }
            get_slot(): number {
                @@:(-99)
                return
            }
        }

        $Modal(slot: number) {
            push_modal(v: number) {
                push$
                -> $Modal(v)
            }
            pop_modal() {
                -> pop$
            }
            get_slot(): number {
                @@:(slot)
                return
            }
        }
    domain:
        v: number = 0
}

console.log("=== Test 58: Persist × push/pop × state-args (TS) ===");
const s1 = new PersistPushpopStateArgs();
s1.push_modal(42);
s1.push_modal(77);
const pre = s1.get_slot();
if (pre !== 77) { console.log("FAIL: pre " + pre); process.exit(1); }
console.log(`1. Pre-save top slot=${pre}`);

const snap = s1.saveState();
const s2 = PersistPushpopStateArgs.restoreState(snap);
const post = s2.get_slot();
if (post !== 77) { console.log("FAIL: post " + post); process.exit(1); }
console.log(`2. Post-restore top slot=${post}`);

s2.pop_modal();
const mid = s2.get_slot();
if (mid !== 42) { console.log("FAIL: mid " + mid); process.exit(1); }
console.log(`3. After first pop slot=${mid}`);

s2.pop_modal();
const bottom = s2.get_slot();
if (bottom !== -99) { console.log("FAIL: bottom " + bottom); process.exit(1); }
console.log(`4. After second pop slot=${bottom}`);

console.log("PASS: 58_persist_pushpop_state_args");

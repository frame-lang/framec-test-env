@@[target("lua")]

@@system ListStateArg {
    interface:
        configure(items: table)
        first_item(): int
        size(): int

    machine:
        $Idle {
            configure(items: table) {
                -> $Active(items)
            }
            first_item(): int {
                @@:(-1)
            }
            size(): int {
                @@:(0)
            }
        }
        $Active(items: table) {
            configure(items: table) {
                -> $Active(items)
            }
            first_item(): int {
                @@:(items[1])
            }
            size(): int {
                @@:(#items)
            }
        }
    domain:
        n: int = 0
}

local s = ListStateArg:new()
if s:first_item() ~= -1 then print("FAIL idle first_item"); os.exit(1) end
if s:size() ~= 0 then print("FAIL idle size"); os.exit(1) end
s:configure({10, 20, 30})
if s:first_item() ~= 10 then print("FAIL active first_item"); os.exit(1) end
if s:size() ~= 3 then print("FAIL active size"); os.exit(1) end
s:configure({7})
if s:first_item() ~= 7 then print("FAIL retransition first_item"); os.exit(1) end
if s:size() ~= 1 then print("FAIL retransition size"); os.exit(1) end
print("PASS: 73_list_state_arg")

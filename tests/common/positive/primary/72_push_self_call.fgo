@@target go

package main

import (
	"fmt"
	"os"
)

@@system PushSelf {
    interface:
        EnterModal()
        Ping(): int
        ExitModal()
        Compute(): int

    machine:
        $Idle {
            EnterModal() { push$; -> $Modal }
            Ping(): int { @@:(0); return; }
            Compute(): int { @@:(99); return; }
        }
        $Modal {
            Ping(): int { @@:(s.Compute() + 1); return; }
            Compute(): int { @@:(10); return; }
            ExitModal() { -> pop$ }
        }
    domain: n: int = 0
}

func main() {
    s := NewPushSelf()
    if s.Ping() != 0 { fmt.Println("FAIL idle"); os.Exit(1) }
    s.EnterModal()
    if s.Ping() != 11 { fmt.Printf("FAIL modal %d\n", s.Ping()); os.Exit(1) }
    s.ExitModal()
    if s.Ping() != 0 { fmt.Println("FAIL back"); os.Exit(1) }
    fmt.Println("PASS: 72_push_self_call")
}

@@target c

@@system TransitionEnterArgs {
    interface:
        start(): void
        get_source_value(): int

    domain:
        int source_value

    machine:
        $Idle {
            start() {
                // Transition with enter args: (source, value) -> $Active
                -> ("from_idle", 42) $Active
            }

            get_source_value(): int {
                return self->source_value;
            }
        }

        $Active {
            $>(source: char*, value: int) {
                // Store value in domain for verification
                self->source_value = value;
                printf("active:enter:source=%s,value=%d\n", source, value);
            }

            start() {
                printf("active:start\n");
            }

            get_source_value(): int {
                return self->source_value;
            }
        }
}

int main() {
    printf("=== Test 17: Transition Enter Args ===\n");
    TransitionEnterArgs* s = @@TransitionEnterArgs();

    // Initial state is Idle
    int value = TransitionEnterArgs_get_source_value(s);
    if (value != 0) {
        printf("FAIL: Expected 0 initially, got %d\n", value);
        return 1;
    }

    // Transition to Active with args
    TransitionEnterArgs_start(s);
    value = TransitionEnterArgs_get_source_value(s);
    if (value != 42) {
        printf("FAIL: Expected 42 from enter args, got %d\n", value);
        return 1;
    }
    printf("After transition: source_value = %d\n", value);

    printf("PASS: Transition enter args work correctly\n");
    TransitionEnterArgs_destroy(s);
    return 0;
}

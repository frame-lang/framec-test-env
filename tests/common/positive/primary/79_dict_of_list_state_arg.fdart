@@[target("dart")]

import 'dart:io';
import 'dart:convert';

@@[persist(String)]
@@[save(saveState)]
@@[load(restoreState)]
@@system DictOfList {
    interface:
        configure(m: Map<String, List<int>>)
        get_at(key: String, idx: int): int

    machine:
        $Idle {
            configure(m: Map<String, List<int>>) { -> $Active(m) }
            get_at(key: String, idx: int): int { @@:(-1) }
        }
        $Active(m: Map<String, List<int>>) {
            configure(m: Map<String, List<int>>) { -> $Active(m) }
            get_at(key: String, idx: int): int {
                @@:((m[key] != null && idx < m[key].length) ? m[key][idx] : -1)
            }
        }
    domain:
        n: int = 0
}

void main() {
    var s1 = DictOfList();
    s1.configure({"a": [10, 20], "b": [30, 40, 50]});
    if (s1.get_at("a", 0) != 10) { print("FAIL pre a.0"); return; }
    if (s1.get_at("b", 2) != 50) { print("FAIL pre b.2"); return; }
    var snap = s1.saveState();
    final s2 = DictOfList();

    s2.restoreState(snap);
    if (s2.get_at("a", 0) != 10) { print("FAIL post a.0"); return; }
    if (s2.get_at("a", 1) != 20) { print("FAIL post a.1"); return; }
    if (s2.get_at("b", 2) != 50) { print("FAIL post b.2"); return; }
    print("PASS: 79_dict_of_list_state_arg");
}

@@[target("erlang")]
@@[persist]
@@[save(save_state)]
@@[load(load_state)]
@@system PersistDict {
    interface:
        configure(m: map)
        getV(key: string): int
    machine:
        $Idle {
            configure(m: map) { -> $Active(m) }
            getV(key: string): int { @@:(-1) }
        }
        $Active(m: map) {
            configure(m: map) { -> $Active(m) }
            getV(key: string): int { @@:(maps:get(Key, M, -1)) }
        }
    domain:
        n = 0
}

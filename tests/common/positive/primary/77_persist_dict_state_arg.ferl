@@[target("erlang")]
@@[persist]
@@system PersistDict {
    operations:
        @@[save]
        save_state() {}

        @@[load]
        load_state(data) {}

    interface:
        configure(m: map)
        getV(key: string): int
    machine:
        $Idle {
            configure(m: map) { -> $Active(m) }
            getV(key: string): int { @@:(-1) }
        }
        $Active(m: map) {
            configure(m: map) { -> $Active(m) }
            getV(key: string): int { @@:(maps:get(Key, M, -1)) }
        }
    domain:
        n = 0
}

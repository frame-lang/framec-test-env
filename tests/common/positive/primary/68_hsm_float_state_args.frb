@@[target("ruby")]

@@system FloatStateArg {
    interface:
        configure(rate: float)
        scale(v: float): float

    machine:
        $Idle {
            configure(rate: float) {
                -> $Active(rate)
            }
            scale(v: float): float {
                @@:(v)
                return
            }
        }

        $Active => $Frame(rate: float) {
            configure(rate: float) {
                -> $Active(rate)
            }
            scale(v: float): float {
                => $^
            }
        }

        $Frame {
            scale(v: float): float {
                @@:(v * rate)
                return
            }
        }
    domain:
        n: int = 0
}

s = @@FloatStateArg()
raise "FAIL idle" unless s.scale(2.0) == 2.0
s.configure(0.5)
raise "FAIL 0.5" unless (s.scale(10.0) - 5.0).abs < 1e-9
s.configure(2.5)
raise "FAIL 2.5" unless (s.scale(4.0) - 10.0).abs < 1e-9
puts "PASS: 68_hsm_float_state_args"

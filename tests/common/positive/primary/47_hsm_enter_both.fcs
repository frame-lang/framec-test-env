@@[target("csharp")]


// Test 47: HSM Enter Cascade — Both Parent and Child have $>

@@system HSMEnterBoth {
    interface:
        go_to_child()
        go_to_parent()
        get_log(): List<object>
        get_state(): string

    machine:
        $Start {
            go_to_child() { -> $Child }
            go_to_parent() { -> $Parent }
            get_log(): List<object> { @@:(this.log) }
            get_state(): string { @@:("Start") }
        }

        $Child => $Parent {
            $>() {
                => $^
                this.log.Add("Child:enter");
            }
            go_to_parent() { -> $Parent }
            get_log(): List<object> { @@:(this.log) }
            get_state(): string { @@:("Child") }
        }

        $Parent {
            $>() {
                this.log.Add("Parent:enter");
            }
            go_to_child() { -> $Child }
            get_log(): List<object> { @@:(this.log) }
            get_state(): string { @@:("Parent") }
        }
    domain:
        log : List<object> = new List<object>()
}

class Program {
    static int CountOf(List<object> log, string v) {
        int n = 0;
        foreach (var item in log) if (item.Equals(v)) n++;
        return n;
    }
    static int IndexOf(List<object> log, string v) {
        for (int i = 0; i < log.Count; i++) if (log[i].Equals(v)) return i;
        return -1;
    }

    static void Main(string[] args) {
        Console.WriteLine("=== Test 47: HSM Enter Cascade — Both ===");
        var s = @@HSMEnterBoth();

        s.go_to_child();
        var log = (List<object>)s.get_log();
        if ((string)s.get_state() != "Child") { Console.WriteLine("FAIL"); Environment.Exit(1); }
        int pi = IndexOf(log, "Parent:enter");
        int ci = IndexOf(log, "Child:enter");
        if (pi == -1) { Console.WriteLine("FAIL: Expected Parent:enter"); Environment.Exit(1); }
        if (ci == -1) { Console.WriteLine("FAIL: Expected Child:enter"); Environment.Exit(1); }
        if (pi >= ci) { Console.WriteLine("FAIL: Parent:enter must precede Child:enter"); Environment.Exit(1); }
        Console.WriteLine("TC1: Parent's $> fires before Child's $> on cascade entry - PASS");

        s.go_to_parent();
        log = (List<object>)s.get_log();
        if ((string)s.get_state() != "Parent") { Console.WriteLine("FAIL"); Environment.Exit(1); }
        if (CountOf(log, "Parent:enter") != 2) { Console.WriteLine("FAIL: Expected 2 Parent:enter"); Environment.Exit(1); }
        if (CountOf(log, "Child:enter") != 1) { Console.WriteLine("FAIL: Expected still 1 Child:enter"); Environment.Exit(1); }
        Console.WriteLine("TC2: Direct Parent entry fires only Parent's $> - PASS");

        s.go_to_child();
        log = (List<object>)s.get_log();
        if (CountOf(log, "Parent:enter") != 3) { Console.WriteLine("FAIL: Expected 3 Parent:enter"); Environment.Exit(1); }
        if (CountOf(log, "Child:enter") != 2) { Console.WriteLine("FAIL: Expected 2 Child:enter"); Environment.Exit(1); }
        Console.WriteLine("TC3: Re-entering Child cascades through Parent again - PASS");

        Console.WriteLine("PASS: HSM enter cascade fires both layers top-down");
    }
}

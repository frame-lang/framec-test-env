@@[target("gdscript")]
extends SceneTree

@@[persist]
@@system PPushDeep {
    interface:
        descend()
        ascend()
        get_depth(): int

    machine:
        $Idle {
            descend() { push$; -> $Modal1 }
            get_depth(): int { @@:(0) }
        }
        $Modal1 {
            descend() { push$; -> $Modal2 }
            ascend() { -> pop$ }
            get_depth(): int { @@:(1) }
        }
        $Modal2 {
            descend() { push$; -> $Modal3 }
            ascend() { -> pop$ }
            get_depth(): int { @@:(2) }
        }
        $Modal3 {
            ascend() { -> pop$ }
            get_depth(): int { @@:(3) }
        }
    domain: n: int = 0
}

func _initialize():
    var s = PPushDeep.new()
    s.descend(); s.descend(); s.descend()
    if s.get_depth() != 3:
        print("FAIL pre"); quit(1); return
    var snap = s.save_state()
    var s2 = PPushDeep.restore_state(snap)
    if s2.get_depth() != 3:
        print("FAIL post"); quit(1); return
    s2.ascend()
    if s2.get_depth() != 2:
        print("FAIL a1"); quit(1); return
    s2.ascend()
    if s2.get_depth() != 1:
        print("FAIL a2"); quit(1); return
    s2.ascend()
    if s2.get_depth() != 0:
        print("FAIL a3"); quit(1); return
    print("PASS: 71_persist_push_depth_three")
    quit(0)

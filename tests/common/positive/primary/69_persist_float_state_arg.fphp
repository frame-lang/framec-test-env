<?php
@@target php
@@persist

@@system PFloat {
    interface:
        configure(rate: float)
        get_rate(): float

    machine:
        $Idle {
            configure(rate: float) {
                -> $Active($rate)
            }
            get_rate(): float {
                @@:(0.0)
                return;
            }
        }

        $Active(rate: float) {
            get_rate(): float {
                @@:($rate)
                return;
            }
        }
    domain:
        n: int = 0
}

$s = new PFloat();
$s->configure(3.14159);
$snap = $s->save_state();
$s2 = PFloat::restore_state($snap);
$r = $s2->get_rate();
if (abs($r - 3.14159) > 1e-9) { echo "FAIL $r\n"; exit(1); }
echo "PASS: 69_persist_float_state_arg, rate=$r\n";

@@[target("java")]

import java.util.*;

// Test 47: HSM Enter Cascade — Both Parent and Child have $>
//
// Tests the HSM enter cascade per docs/frame_runtime_introduction.md
// Step 21+. When entering an HSM child, the kernel fires $> on every
// layer of the new chain top-down (parent first, child last).

@@system HSMEnterBoth {
    interface:
        go_to_child()
        go_to_parent()
        get_log(): ArrayList
        get_state(): String

    machine:
        $Start {
            go_to_child() { -> $Child }
            go_to_parent() { -> $Parent }
            get_log(): ArrayList { @@:(this.log) }
            get_state(): String { @@:("Start") }
        }

        $Child => $Parent {
            $>() {
                this.log.add("Child:enter");
            }
            go_to_parent() { -> $Parent }
            get_log(): ArrayList { @@:(this.log) }
            get_state(): String { @@:("Child") }
        }

        $Parent {
            $>() {
                this.log.add("Parent:enter");
            }
            go_to_child() { -> $Child }
            get_log(): ArrayList { @@:(this.log) }
            get_state(): String { @@:("Parent") }
        }
    domain:
        log : ArrayList = new ArrayList()
}

class Main {
    static int countOf(ArrayList log, String v) {
        int n = 0;
        for (Object item : log) if (item.equals(v)) n++;
        return n;
    }
    static int indexOf(ArrayList log, String v) {
        for (int i = 0; i < log.size(); i++) if (log.get(i).equals(v)) return i;
        return -1;
    }

    public static void main(String[] args) {
        System.out.println("=== Test 47: HSM Enter Cascade — Both ===");
        var s = @@HSMEnterBoth();

        s.go_to_child();
        ArrayList log = s.get_log();
        if (!s.get_state().equals("Child")) { System.out.println("FAIL"); System.exit(1); }
        int pi = indexOf(log, "Parent:enter");
        int ci = indexOf(log, "Child:enter");
        if (pi == -1) { System.out.println("FAIL: Expected Parent:enter"); System.exit(1); }
        if (ci == -1) { System.out.println("FAIL: Expected Child:enter"); System.exit(1); }
        if (pi >= ci) { System.out.println("FAIL: Parent:enter must precede Child:enter"); System.exit(1); }
        System.out.println("TC1: Parent's $> fires before Child's $> on cascade entry - PASS");

        s.go_to_parent();
        log = s.get_log();
        if (!s.get_state().equals("Parent")) { System.out.println("FAIL"); System.exit(1); }
        if (countOf(log, "Parent:enter") != 2) { System.out.println("FAIL: Expected 2 Parent:enter"); System.exit(1); }
        if (countOf(log, "Child:enter") != 1) { System.out.println("FAIL: Expected still 1 Child:enter"); System.exit(1); }
        System.out.println("TC2: Direct Parent entry fires only Parent's $> - PASS");

        s.go_to_child();
        log = s.get_log();
        if (countOf(log, "Parent:enter") != 3) { System.out.println("FAIL: Expected 3 Parent:enter"); System.exit(1); }
        if (countOf(log, "Child:enter") != 2) { System.out.println("FAIL: Expected 2 Child:enter"); System.exit(1); }
        System.out.println("TC3: Re-entering Child cascades through Parent again - PASS");

        System.out.println("PASS: HSM enter cascade fires both layers top-down");
    }
}

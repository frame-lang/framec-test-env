@@target python_3

@@system Turnstile {
    interface:
        coin()
        push(): str

    machine:
        $Locked {
            coin() { -> $Unlocked }
            push(): str { @@:("locked - insert coin") }
        }
        $Unlocked {
            coin() { }
            push(): str {
                @@:("welcome")
                -> $Locked
            }
        }
}

if __name__ == '__main__':
    t = @@Turnstile()
    assert t.push() == "locked - insert coin"
    t.coin()
    assert t.push() == "welcome"
    assert t.push() == "locked - insert coin"
    print("PASS: turnstile")

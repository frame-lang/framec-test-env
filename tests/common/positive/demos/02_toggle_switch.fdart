@@[target("dart")]

@@system Switch {
    interface:
        toggle(): String
        status(): String

    machine:
        $Off {
            toggle(): String {
                @@:("on")
                -> $On
            }
            status(): String { @@:("off") }
        }
        $On {
            toggle(): String {
                @@:("off")
                -> $Off
            }
            status(): String { @@:("on") }
        }
}

void main() {
    final sw = @@Switch();
    if (sw.status() as String != "off") {
        throw Exception("Expected 'off' from status");
    }
    if (sw.toggle() as String != "on") {
        throw Exception("Expected 'on' from toggle");
    }
    if (sw.toggle() as String != "off") {
        throw Exception("Expected 'off' from toggle");
    }
    print("PASS: toggle_switch");
}

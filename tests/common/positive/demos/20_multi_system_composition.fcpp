@@target cpp_17

#include <iostream>
#include <string>

@@system Logger {
    interface:
        log(msg: str)

    machine:
        $Active {
            log(msg: str) {
                std::cout << "[LOG] " << msg << std::endl;
            }
        }
}

@@system App {
    interface:
        start()
        stop()

    machine:
        $Idle {
            start() {
                self->logger.log("App starting");
                -> $Running
            }
        }
        $Running {
            $>() { self->logger.log("App running"); }
            stop() {
                self->logger.log("App stopping");
                -> $Idle
            }
        }

    domain:
        logger: Logger = Logger()
}

int main() {
    App app;
    app.start();
    app.stop();
    printf("PASS: multi_system_composition\n");
    return 0;
}

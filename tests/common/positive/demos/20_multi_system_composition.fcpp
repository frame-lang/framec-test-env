@@[target("cpp_17")]

#include <iostream>

@@system Logger {
    interface:
        log(msg: str)

    machine:
        $Active {
            log(msg: str) {
                std::cout << "[LOG] " << msg << std::endl;
            }
        }
}

@@[main]
@@system App {
    interface:
        start()
        stop()

    machine:
        $Idle {
            start() {
                this->logger->log("App starting");
                -> $Running
            }
        }
        $Running {
            $>() { this->logger->log("App running"); }
            stop() {
                this->logger->log("App stopping");
                -> $Idle
            }
        }

    domain:
        logger: std::shared_ptr<Logger> = std::make_shared<Logger>()
}

int main() {
    auto app = @@App();
    app.start();
    app.stop();
    printf("PASS: multi_system_composition\n");
    return 0;
}

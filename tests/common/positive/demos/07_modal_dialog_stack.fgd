@@[target("gdscript")]

extends SceneTree

@@system DialogManager {
    interface:
        open(name: str)
        close(): str
        current(): str

    machine:
        $Main {
            open(name: str) {
                push$
                -> (name) $Dialog
            }
            current(): str { @@:("main") }
        }
        $Dialog {
            $.name: str = ""

            $>(name: str) { $.name = name }

            open(name: str) {
                push$
                -> (name) $Dialog
            }
            close(): str {
                @@:($.name)
                -> pop$
            }
            current(): str { @@:($.name) }
        }
}

func _init():
    var dm = @@DialogManager()
    assert(dm.current() == "main", "Expected 'main'")
    dm.open("Settings")
    assert(dm.current() == "Settings", "Expected 'Settings'")
    dm.open("Confirm")
    assert(dm.current() == "Confirm", "Expected 'Confirm'")
    var closed = dm.close()
    assert(closed == "Confirm", "Expected 'Confirm'")
    assert(dm.current() == "Settings", "Expected 'Settings'")
    closed = dm.close()
    assert(closed == "Settings", "Expected 'Settings'")
    assert(dm.current() == "main", "Expected 'main'")
    print("PASS: modal_dialog_stack")
    quit()

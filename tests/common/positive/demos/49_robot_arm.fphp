@@[target("php")]

<?php

@@system RobotArm {
    interface:
        set_manual()
        set_auto()
        e_stop()
        reset_e_stop()
        status(): str

    machine:
        $Manual => $Operational {
            set_auto() { -> $Auto }
            status(): str { @@:("Manual") }
            => $^
        }

        $Auto => $Operational {
            set_manual() { -> $Manual }
            status(): str { @@:("Auto") }
            => $^
        }

        $Operational {
            e_stop() { -> $EStop }
            status(): str { @@:("Operational") }
        }

        $EStop {
            reset_e_stop() { -> $Manual }
            status(): str { @@:("EStop") }
        }

    domain:
}

$arm = @@RobotArm();
assert($arm->status() === "Manual");
$arm->e_stop();
assert($arm->status() === "EStop");
$arm->reset_e_stop();
assert($arm->status() === "Manual");
$arm->set_auto();
assert($arm->status() === "Auto");
$arm->e_stop();
assert($arm->status() === "EStop");
echo "PASS: robot_arm\n";

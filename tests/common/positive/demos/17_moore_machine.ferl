@@target erlang

@@system MooreParity {
    interface:
        input(bit: int)
        output(): str

    machine:
        $Even {
            input(bit: int) {
                if bit == 1 {
                    -> $Odd
                }
            }
            output(): str { @@:("even") }
        }
        $Odd {
            input(bit: int) {
                if bit == 1 {
                    -> $Even
                }
            }
            output(): str { @@:("odd") }
        }
}

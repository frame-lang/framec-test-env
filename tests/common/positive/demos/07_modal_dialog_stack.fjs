@@[target("javascript")]

@@system DialogManager {
    interface:
        open(name: str)
        close(): str
        current(): str

    machine:
        $Main {
            open(name: str) {
                push$
                -> (name) $Dialog
            }
            current(): str { @@:("main") }
        }
        $Dialog {
            $.name: str = ""

            $>(name: str) { $.name = name }

            open(name: str) {
                push$
                -> (name) $Dialog
            }
            close(): str {
                @@:($.name)
                -> pop$
            }
            current(): str { @@:($.name) }
        }
}

const dm = @@DialogManager();
if (dm.current() !== "main") {
    console.log("FAIL: expected 'main'");
    process.exit(1);
}
dm.open("Settings");
if (dm.current() !== "Settings") {
    console.log("FAIL: expected 'Settings'");
    process.exit(1);
}
dm.open("Confirm");
if (dm.current() !== "Confirm") {
    console.log("FAIL: expected 'Confirm'");
    process.exit(1);
}
const closed1 = dm.close();
if (closed1 !== "Confirm") {
    console.log("FAIL: expected 'Confirm'");
    process.exit(1);
}
if (dm.current() !== "Settings") {
    console.log("FAIL: expected 'Settings'");
    process.exit(1);
}
const closed2 = dm.close();
if (closed2 !== "Settings") {
    console.log("FAIL: expected 'Settings'");
    process.exit(1);
}
if (dm.current() !== "main") {
    console.log("FAIL: expected 'main'");
    process.exit(1);
}
console.log("PASS: modal_dialog_stack");

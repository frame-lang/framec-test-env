@@target c

#include <stdio.h>
#include <stdlib.h>
#include <string.h>

@@system RateLimiter {
    operations:
        static tokens_for_rate(rps: int, interval_ms: int): int {
            int val = (rps * interval_ms) / 1000;
            return val > 1 ? val : 1;
        }
        tokens_remaining(): int {
            return self->tokens;
        }

    interface:
        request(): char*
        tick()

    machine:
        $Accepting {
            request(): char* {
                self->tokens = self->tokens - 1;
                @@:("accepted")
                if (self->tokens <= 0) {
                    -> $Throttled
                }
            }
            tick() {
                self->tokens = self->tokens + 1;
                if (self->tokens > self->max_tokens) { self->tokens = self->max_tokens; }
            }
        }
        $Throttled {
            request(): char* { @@:("throttled") }
            tick() {
                self->tokens = self->tokens + 1;
                if (self->tokens > 0) {
                    -> $Accepting
                }
            }
        }

    domain:
        tokens : int = 10
        max_tokens : int = 10
}

int main() {
    int failures = 0;
    if (RateLimiter_tokens_for_rate(100, 50) != 5) { printf("FAIL: static op\n"); failures++; }
    RateLimiter* rl = @@RateLimiter();
    for (int i = 0; i < 10; i++) { RateLimiter_request(rl); }
    if (strcmp(RateLimiter_request(rl), "throttled") != 0) { printf("FAIL: throttled\n"); failures++; }
    RateLimiter_tick(rl);
    if (strcmp(RateLimiter_request(rl), "accepted") != 0) { printf("FAIL: accepted\n"); failures++; }

    if (failures > 0) { printf("FAIL: rate_limiter (%d)\n", failures); return 1; }
    printf("PASS: rate_limiter\n");
    return 0;
}

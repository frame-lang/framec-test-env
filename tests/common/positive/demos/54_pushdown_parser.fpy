@@[target("python_3")]

# Smoke-test variant of cookbook recipe 54 (Pushdown Parser —
# Nested Structure with push$ / pop$). Stack-discipline-only
# simplification: rather than parsing a list-of-list grammar with
# per-compartment $.items and a bubble_up action, this variant
# tracks bracket depth as a single shared domain field. Each
# open() pushes the current compartment onto the state stack and
# enters $Nested; each close() pops back. The state stack itself
# does the structural work; the depth counter is observable proof
# that push$ / pop$ saved and restored frames in LIFO order.

@@system BracketParser {
    interface:
        open()
        close()
        depth_now(): int
        status(): str

    machine:
        $Flat {
            open() {
                self.depth = self.depth + 1
                push$
                -> $Nested
            }
            depth_now(): int { @@:(self.depth) }
            status(): str { @@:("flat") }
        }

        $Nested {
            open() {
                self.depth = self.depth + 1
                push$
                -> $Nested
            }
            close() {
                self.depth = self.depth - 1
                -> pop$
            }
            depth_now(): int { @@:(self.depth) }
            status(): str { @@:("nested") }
        }

    domain:
        depth: int = 0
}

if __name__ == '__main__':
    p = @@BracketParser()
    assert p.status() == "flat"
    assert p.depth_now() == 0

    # Open one nesting level
    p.open()
    assert p.status() == "nested"
    assert p.depth_now() == 1

    # Open another (nested twice)
    p.open()
    assert p.status() == "nested"
    assert p.depth_now() == 2

    # Close back to depth 1
    p.close()
    assert p.status() == "nested"
    assert p.depth_now() == 1

    # Close back to flat (depth 0)
    p.close()
    assert p.status() == "flat"
    assert p.depth_now() == 0

    # Re-open after popping back to flat
    p.open()
    assert p.status() == "nested"
    assert p.depth_now() == 1
    p.close()
    assert p.status() == "flat"
    assert p.depth_now() == 0

    print("PASS: pushdown_parser")

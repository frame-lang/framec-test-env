@@[target("python_3")]

# Smoke-test variant of cookbook recipe 49 (Robot Arm Controller —
# Safety Overlay with HSM). Validates the safety-overrides-all
# property: e_stop transitions to $EStop regardless of which mode
# (Manual / Auto) the arm is in, because the e_stop handler lives
# on the parent $Operational state. The full cookbook variant
# adds a SafetyFault sibling and motion-state leaves; here we
# exercise only the parent-handler dispatch path.

@@system RobotArm {
    interface:
        set_manual()
        set_auto()
        e_stop()
        reset_e_stop()
        status(): str

    machine:
        $Manual => $Operational {
            set_auto() { -> $Auto }
            status(): str { @@:("Manual") }
            => $^
        }

        $Auto => $Operational {
            set_manual() { -> $Manual }
            status(): str { @@:("Auto") }
            => $^
        }

        $Operational {
            e_stop() { -> $EStop }
            status(): str { @@:("Operational") }
        }

        $EStop {
            reset_e_stop() { -> $Manual }
            status(): str { @@:("EStop") }
        }

    domain:
}

if __name__ == '__main__':
    # Initial state is Manual (start state)
    arm = @@RobotArm()
    assert arm.status() == "Manual"

    # E-stop from Manual works — handler is on parent $Operational
    arm.e_stop()
    assert arm.status() == "EStop"

    # Reset back to Manual
    arm.reset_e_stop()
    assert arm.status() == "Manual"

    # Switch to Auto mode
    arm.set_auto()
    assert arm.status() == "Auto"

    # E-stop from Auto also works (parent handler)
    arm.e_stop()
    assert arm.status() == "EStop"

    print("PASS: robot_arm")

@@target rust

@@system Agent {
    interface:
        tick()
        threat()
        safe()
        get_log(): String

    machine:
        $Exploring {
            tick() {
                self.action_log = format!("{}{}", self.action_log, "explore,");
            }
            threat() {
                self.action_log = format!("{}{}", self.action_log, "flee,");
                -> $Fleeing
            }
            get_log(): String { @@:(self.action_log.clone()) }
        }
        $Fleeing {
            tick() {
                self.action_log = format!("{}{}", self.action_log, "run,");
            }
            safe() {
                self.action_log = format!("{}{}", self.action_log, "resume,");
                -> $Exploring
            }
            get_log(): String { @@:(self.action_log.clone()) }
        }

    domain:
        action_log: String = String::new()
}

fn main() {
    let mut a = @@Agent();
    a.tick();
    a.tick();
    a.threat();
    a.tick();
    a.safe();
    let result = a.get_log();
    let expected = "explore,explore,flee,run,resume,";
    assert_eq!(result, expected, "Expected '{}', got '{}'", expected, result);
    println!("PASS: ai_agent");
}

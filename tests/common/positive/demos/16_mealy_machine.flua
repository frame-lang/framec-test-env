@@target lua

@@system MealyDetector {
    interface:
        input(bit: int): str

    machine:
        $S0 {
            input(bit: int): str {
                if bit == 1 then
                    @@:("0")
                    -> $S1
                else
                    @@:("0")
                end
            }
        }
        $S1 {
            input(bit: int): str {
                if bit == 0 then
                    @@:("1")
                    -> $S0
                else
                    @@:("0")
                end
            }
        }
}

local m = @@MealyDetector()
local bits = {1, 0, 1, 1, 0}
local expected = {"0", "1", "0", "0", "1"}
for i = 1, 5 do
    local result = m:input(bits[i])
    assert(result == expected[i], "bit=" .. bits[i] .. " expected '" .. expected[i] .. "', got '" .. tostring(result) .. "'")
end
print("PASS: mealy_machine")

@@[target("lua")]

@@system RateLimiter {
    operations:
        static tokens_for_rate(rps, interval_ms) {
            return math.max(1, math.floor((rps * interval_ms) / 1000))
        }
        tokens_remaining() {
            return self.tokens
        }

    interface:
        request(): str = "error"
        tick()

    machine:
        $Accepting {
            request(): str {
                self.tokens = self.tokens - 1
                @@:("accepted")
                if self.tokens <= 0 then
                    -> $Throttled
                end
            }
            tick() { self.tokens = math.min(self.tokens + 1, self.max_tokens) }
        }
        $Throttled {
            request(): str { @@:("throttled") }
            tick() {
                self.tokens = self.tokens + 1
                if self.tokens > 0 then
                    -> $Accepting
                end
            }
        }

    domain:
        tokens = 10
        max_tokens = 10
}

local failures = 0
if RateLimiter.tokens_for_rate(100, 50) ~= 5 then
    print("FAIL: static op")
    failures = failures + 1
end
local rl = @@RateLimiter()
for i = 1, 10 do rl:request() end
if rl:request() ~= "throttled" then
    print("FAIL: throttled")
    failures = failures + 1
end
rl:tick()
if rl:request() ~= "accepted" then
    print("FAIL: accepted after tick")
    failures = failures + 1
end

if failures > 0 then
    print("FAIL: rate_limiter (" .. failures .. ")")
    os.exit(1)
end
print("PASS: rate_limiter")

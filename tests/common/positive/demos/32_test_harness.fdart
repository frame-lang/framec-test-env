@@[target("dart")]

import 'dart:io';

@@system TestHarness {
    operations:
        current_state(): str {
            @@:(@@:system.state)
        }

    interface:
        run()
        pass_test()
        fail(reason: str)
        get_state(): str
        get_result(): str

    machine:
        $Ready {
            run() {
                this.result = "";
                -> $Running
            }
            get_state(): str { @@:("ready") }
            get_result(): str { @@:(this.result) }
        }
        $Running {
            pass_test() {
                this.result = "pass";
                -> $Passed
            }
            fail(reason: str) {
                this.result = reason;
                -> $Failed
            }
            get_state(): str { @@:("running") }
            get_result(): str { @@:("") }
        }
        $Passed {
            run() {
                this.result = "";
                -> $Running
            }
            get_state(): str { @@:("passed") }
            get_result(): str { @@:(this.result) }
        }
        $Failed {
            run() {
                this.result = "";
                -> $Running
            }
            get_state(): str { @@:("failed") }
            get_result(): str { @@:(this.result) }
        }

    domain:
        result: String = ""
}

void main() {
    var th = @@TestHarness();
    int failures = 0;

    var cs = th.current_state();
    if (cs != "Ready") {
        print("FAIL: current_state expected Ready, got $cs");
        failures++;
    }

    th.run();
    cs = th.current_state();
    if (cs != "Running") {
        print("FAIL: current_state expected Running, got $cs");
        failures++;
    }

    th.pass_test();
    if (th.get_result() != "pass") {
        print("FAIL: expected result pass");
        failures++;
    }
    cs = th.current_state();
    if (cs != "Passed") {
        print("FAIL: current_state expected Passed, got $cs");
        failures++;
    }

    th.run();
    th.fail("timeout");
    if (th.get_result() != "timeout") {
        print("FAIL: expected result timeout");
        failures++;
    }
    cs = th.current_state();
    if (cs != "Failed") {
        print("FAIL: current_state expected Failed, got $cs");
        failures++;
    }

    if (failures > 0) {
        print("FAIL: test_harness ($failures failures)");
        exit(1);
    }
    print("PASS: test_harness");
}

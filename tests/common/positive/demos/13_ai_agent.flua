@@[target("lua")]

@@system Agent {
    interface:
        tick()
        threat()
        safe()
        get_log(): str

    machine:
        $Exploring {
            tick() {
                self.action_log = self.action_log .. "explore,"
            }
            threat() {
                self.action_log = self.action_log .. "flee,"
                -> $Fleeing
            }
            get_log(): str { @@:(self.action_log) }
        }
        $Fleeing {
            tick() {
                self.action_log = self.action_log .. "run,"
            }
            safe() {
                self.action_log = self.action_log .. "resume,"
                -> $Exploring
            }
            get_log(): str { @@:(self.action_log) }
        }

    domain:
        action_log: str = ""
}

local a = @@Agent()
a:tick()
a:tick()
a:threat()
a:tick()
a:safe()
local result = a:get_log()
local expected = "explore,explore,flee,run,resume,"
assert(result == expected, "Expected '" .. expected .. "', got '" .. tostring(result) .. "'")
print("PASS: ai_agent")

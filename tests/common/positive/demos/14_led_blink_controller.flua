@@target lua

@@system LedBlinker {
    interface:
        enable()
        disable()
        timer_tick()
        is_lit(): bool

    machine:
        $Disabled {
            enable() { -> $LedOff }
        }
        $LedOff {
            timer_tick() { -> $LedOn }
            disable() { -> $Disabled }
            is_lit(): bool { @@:(false) }
        }
        $LedOn {
            timer_tick() { -> $LedOff }
            disable() { -> $Disabled }
            is_lit(): bool { @@:(true) }
        }
}

local led = @@LedBlinker()
led:enable()
local expected = {false, true, false, true, false}
for i = 1, 5 do
    assert(led:is_lit() == expected[i], "tick " .. (i-1) .. " failed")
    led:timer_tick()
end
print("PASS: led_blink_controller")

@@[target("swift")]

@@system Switch {
    interface:
        toggle(): String
        status(): String

    machine:
        $Off {
            toggle(): String {
                @@:("on")
                -> $On
            }
            status(): String { @@:("off") }
        }
        $On {
            toggle(): String {
                @@:("off")
                -> $Off
            }
            status(): String { @@:("on") }
        }
}

var sw = @@Switch()
if sw.status() as! String != "off" {
    fatalError("Expected 'off' from status")
}
if sw.toggle() as! String != "on" {
    fatalError("Expected 'on' from toggle")
}
if sw.toggle() as! String != "off" {
    fatalError("Expected 'off' from toggle")
}
print("PASS: toggle_switch")

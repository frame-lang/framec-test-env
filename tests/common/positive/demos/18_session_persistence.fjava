@@target java
@@skip -- Java persist codegen emits Gson dependency but test env only has org.json

import com.google.gson.Gson;

@@persist
@@system Session {
    interface:
        login(user: String)
        logout()
        who(): String

    machine:
        $LoggedOut {
            login(user: String) {
                this.user = user;
                -> $LoggedIn
            }
            who(): String { @@:("nobody") }
        }
        $LoggedIn {
            logout() {
                this.user = "";
                -> $LoggedOut
            }
            who(): String { @@:(this.user) }
        }

    domain:
        user: String = ""
}

class Main {
    public static void main(String[] args) {
        var s = new Session();
        s.login("alice");
        if (!"alice".equals((String) s.who())) {
            throw new RuntimeException("Expected 'alice'");
        }
        String data = s.save_state();
        var s2 = Session.restore_state(data);
        if (!"alice".equals((String) s2.who())) {
            throw new RuntimeException("Expected 'alice' after restore");
        }
        System.out.println("PASS: session_persistence");
    }
}

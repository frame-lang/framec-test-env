@@[target("java")]

@@[persist]
@@system Session {
    operations:
        @@[save]
        save_state(): String {}

        @@[load]
        restore_state(data: String) {}

    interface:
        login(user: String)
        logout()
        who(): String

    machine:
        $LoggedOut {
            login(user: String) {
                this.user = user;
                -> $LoggedIn
            }
            who(): String { @@:("nobody") }
        }
        $LoggedIn {
            logout() {
                this.user = "";
                -> $LoggedOut
            }
            who(): String { @@:(this.user) }
        }

    domain:
        user: String = ""
}

class Main {
    public static void main(String[] args) {
        var s = @@Session();
        s.login("alice");
        if (!"alice".equals((String) s.who())) {
            throw new RuntimeException("Expected 'alice'");
        }
        String data = s.save_state();
        var s2 = new Session();

        s2.restore_state(data);
        if (!"alice".equals((String) s2.who())) {
            throw new RuntimeException("Expected 'alice' after restore");
        }
        System.out.println("PASS: session_persistence");
    }
}

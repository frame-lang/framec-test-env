@@[target("lua")]

@@system CircuitBreaker {
    interface:
        call(payload: str): str
        record_failure()
        record_success()
        probe()
        state_name(): str

    machine:
        $Closed {
            $>() {
                self.failures = 0
            }
            call(payload: str): str {
                @@:(self:invoke(payload))
            }
            record_failure() {
                self.failures = self.failures + 1
                if self.failures >= self.threshold then
                    -> "trip" $Open
                end
            }
            record_success() {
                self.failures = 0
            }
            state_name(): str { @@:("closed") }
        }

        $Open {
            call(payload: str): str {
                @@:("rejected: circuit open")
            }
            probe() {
                -> $HalfOpen
            }
            state_name(): str { @@:("open") }
        }

        $HalfOpen {
            call(payload: str): str {
                @@:(self:invoke(payload))
            }
            record_success() {
                -> "recover" $Closed
            }
            record_failure() {
                -> "re-trip" $Open
            }
            state_name(): str { @@:("half_open") }
        }

    actions:
        invoke(payload) {
            return "ok:" .. payload
        }

    domain:
        failures: int = 0
        threshold: int = 3
}

local cb = @@CircuitBreaker()
for _ = 1, 3 do
    cb:call("x")
    cb:record_failure()
end
assert(cb:state_name() == "open", "Expected open, got " .. tostring(cb:state_name()))
assert(cb:call("x") == "rejected: circuit open", "Expected rejection")
cb:probe()
assert(cb:state_name() == "half_open", "Expected half_open, got " .. tostring(cb:state_name()))
cb:call("x")
cb:record_success()
assert(cb:state_name() == "closed", "Expected closed, got " .. tostring(cb:state_name()))
print("PASS: circuit_breaker")

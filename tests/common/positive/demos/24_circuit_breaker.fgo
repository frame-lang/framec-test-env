@@[target("go")]

package main

import (
	"fmt"
	"os"
)

@@system CircuitBreaker {
    interface:
        Call(): string
        Success()
        Failure()
        Tick()
        Status(): string

    machine:
        $Closed {
            $.failures: int = 0
            Call(): string { @@:("allowed") }
            Success() { $.failures = 0 }
            Failure() {
                $.failures = $.failures + 1
                if $.failures >= s.threshold {
                    -> $Open
                }
            }
            Status(): string { @@:("closed") }
        }
        $Open {
            $.cooldown_remaining: int = 0
            $>() {
                $.cooldown_remaining = s.cooldown
            }
            Call(): string { @@:("blocked") }
            Tick() {
                $.cooldown_remaining = $.cooldown_remaining - 1
                if $.cooldown_remaining <= 0 {
                    -> $HalfOpen
                }
            }
            Status(): string { @@:("open") }
        }
        $HalfOpen {
            Call(): string { @@:("testing") }
            Success() { -> $Closed }
            Failure() { -> $Open }
            Status(): string { @@:("half-open") }
        }

    domain:
        threshold : int = 3
        cooldown : int = 5
}

func main() {
	cb := NewCircuitBreaker()
	failures := 0

	cb.Failure(); cb.Failure(); cb.Failure()
	if cb.Call() != "blocked" { fmt.Println("FAIL: expected blocked"); failures++ }

	for i := 0; i < 5; i++ { cb.Tick() }
	if cb.Call() != "testing" { fmt.Println("FAIL: expected testing"); failures++ }

	cb.Success()
	if cb.Status() != "closed" { fmt.Println("FAIL: expected closed"); failures++ }

	if failures > 0 { fmt.Printf("FAIL: circuit_breaker (%d)\n", failures); os.Exit(1) }
	fmt.Println("PASS: circuit_breaker")
}

@@[target("csharp")]

using System;

@@system LedBlinker {
    interface:
        enable()
        disable()
        timer_tick()
        is_lit(): bool

    machine:
        $Disabled {
            enable() { -> $LedOff }
        }
        $LedOff {
            timer_tick() { -> $LedOn }
            disable() { -> $Disabled }
            is_lit(): bool { @@:(false) }
        }
        $LedOn {
            timer_tick() { -> $LedOff }
            disable() { -> $Disabled }
            is_lit(): bool { @@:(true) }
        }
}

class Program {
    static void Main(string[] args) {
        var led = @@LedBlinker();
        led.enable();
        bool[] expected = {false, true, false, true, false};
        for (int i = 0; i < 5; i++) {
            if ((bool) led.is_lit() != expected[i]) {
                throw new Exception("FAIL: tick " + i);
            }
            led.timer_tick();
        }
        Console.WriteLine("PASS: led_blink_controller");
    }
}

@@target lua

@@system WorkerPool($(max_retries: int), $>(start_msg: str), pool_size: int) {
    interface:
        submit(task: str)
        get_status(): str

    machine:
        $Idle(max_retries: int) {
            $>(start_msg: str) {
                print("Pool ready: " .. start_msg)
            }

            submit(task: str) {
                table.insert(self.pending, task)
                if #self.pending >= self.pool_size then
                    -> $Processing
                end
            }

            get_status(): str {
                @@:("idle (" .. #self.pending .. "/" .. self.pool_size .. " pending)")
            }
        }

        $Processing {
            $>() {
                print("Processing batch of " .. #self.pending .. " tasks")
                self.pending = {}
            }

            submit(task: str) {
                table.insert(self.pending, task)
            }

            get_status(): str {
                @@:("processing")
            }
        }

    domain:
        pending = {}
        pool_size = pool_size
}

local pool = @@WorkerPool($(5), $>("v1.0"), 3)
pool:submit("task_a")
local status = pool:get_status()
if status ~= "idle (1/3 pending)" then
    print("FAIL: Expected idle, got: " .. status)
    os.exit(1)
end
pool:submit("task_b")
pool:submit("task_c")
status = pool:get_status()
if status ~= "processing" then
    print("FAIL: Expected processing, got: " .. status)
    os.exit(1)
end
print("PASS: worker_pool")

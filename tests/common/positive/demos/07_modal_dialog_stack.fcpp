@@target cpp_17

#include <iostream>
#include <string>
#include <cassert>

@@system DialogManager {
    interface:
        open(name: str)
        close(): str
        current(): str

    machine:
        $Main {
            open(name: str) {
                push$
                -> (name) $Dialog
            }
            current(): str { @@:(std::string("main")) }
        }
        $Dialog {
            $.name: str = ""

            $>(name: str) { $.name = name }

            open(name: str) {
                push$
                -> (name) $Dialog
            }
            close(): str {
                @@:($.name)
                -> pop$
            }
            current(): str { @@:($.name) }
        }
}

int main() {
    auto dm = @@DialogManager();
    assert(std::any_cast<std::string>(dm.current()) == "main");
    dm.open("Settings");
    assert(std::any_cast<std::string>(dm.current()) == "Settings");
    dm.open("Confirm");
    assert(std::any_cast<std::string>(dm.current()) == "Confirm");
    auto closed = std::any_cast<std::string>(dm.close());
    assert(closed == "Confirm");
    assert(std::any_cast<std::string>(dm.current()) == "Settings");
    closed = std::any_cast<std::string>(dm.close());
    assert(closed == "Settings");
    assert(std::any_cast<std::string>(dm.current()) == "main");
    printf("PASS: modal_dialog_stack\n");
    return 0;
}

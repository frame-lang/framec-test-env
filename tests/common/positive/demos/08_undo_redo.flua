@@target lua

@@system Editor {
    interface:
        type_char(c: str)
        undo()
        get_buffer(): str

    machine:
        $Editing {
            $.buffer: str = ""

            type_char(c: str) {
                push$
                $.buffer = $.buffer .. c
            }
            undo() {
                -> pop$
            }
            get_buffer(): str { @@:($.buffer) }
        }
}

local e = @@Editor()
e:type_char("H")
e:type_char("i")
assert(e:get_buffer() == "Hi", "expected 'Hi' got '" .. e:get_buffer() .. "'")
e:undo()
assert(e:get_buffer() == "H", "expected 'H' got '" .. e:get_buffer() .. "'")
e:undo()
assert(e:get_buffer() == "", "expected '' got '" .. e:get_buffer() .. "'")
print("PASS: undo_redo")

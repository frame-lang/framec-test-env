@@[target("cpp_17")]

#include <iostream>
#include <cassert>

@@system Character {
    interface:
        move()
        sprint()
        jump()
        land()
        stop()
        state(): str

    machine:
        $Idle {
            move() { -> $Walking }
            jump() { -> $Jumping }
            state(): str { @@:(std::string("idle")) }
        }
        $Walking {
            sprint() { -> $Running }
            jump() { -> $Jumping }
            stop() { -> $Idle }
            state(): str { @@:(std::string("walking")) }
        }
        $Running {
            stop() { -> $Walking }
            jump() { -> $Jumping }
            state(): str { @@:(std::string("running")) }
        }
        $Jumping {
            land() { -> $Idle }
            state(): str { @@:(std::string("jumping")) }
        }
}

int main() {
    auto c = @@Character();
    assert(std::any_cast<std::string>(c.state()) == "idle");
    c.move();
    assert(std::any_cast<std::string>(c.state()) == "walking");
    c.sprint();
    assert(std::any_cast<std::string>(c.state()) == "running");
    c.jump();
    assert(std::any_cast<std::string>(c.state()) == "jumping");
    c.move();  // ignored while jumping
    assert(std::any_cast<std::string>(c.state()) == "jumping");
    c.land();
    assert(std::any_cast<std::string>(c.state()) == "idle");
    printf("PASS: character_controller\n");
    return 0;
}

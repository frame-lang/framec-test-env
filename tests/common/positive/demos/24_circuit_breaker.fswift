@@[target("swift")]

@@system CircuitBreaker {
    interface:
        call(): String = "error"
        success()
        failure()
        tick()
        status(): String = ""

    machine:
        $Closed {
            $.failures: Int = 0
            call(): String { @@:("allowed") }
            success() { $.failures = 0 }
            failure() {
                $.failures = $.failures + 1
                if $.failures >= self.threshold {
                    -> $Open
                }
            }
            status(): String { @@:("closed (\($.failures) failures)") }
        }
        $Open {
            $.cooldown_remaining: Int = 0
            $>() {
                $.cooldown_remaining = self.cooldown
            }
            call(): String { @@:("blocked") }
            tick() {
                $.cooldown_remaining = $.cooldown_remaining - 1
                if $.cooldown_remaining <= 0 {
                    -> $HalfOpen
                }
            }
            status(): String { @@:("open (\($.cooldown_remaining) ticks left)") }
        }
        $HalfOpen {
            call(): String { @@:("testing") }
            success() { -> $Closed }
            failure() { -> $Open }
            status(): String { @@:("half-open") }
        }

    domain:
        threshold: Int = 3
        cooldown: Int = 5
}

let cb = @@CircuitBreaker()
var failures = 0

cb.failure(); cb.failure(); cb.failure()
if cb.call() as! String != "blocked" { print("FAIL: expected blocked"); failures += 1 }

for _ in 0..<5 { cb.tick() }
if cb.call() as! String != "testing" { print("FAIL: expected testing"); failures += 1 }

cb.success()
if cb.status() as! String != "closed (0 failures)" { print("FAIL: expected reset, got \(cb.status())"); failures += 1 }

if failures > 0 { print("FAIL: circuit_breaker (\(failures))"); fatalError() }
print("PASS: circuit_breaker")

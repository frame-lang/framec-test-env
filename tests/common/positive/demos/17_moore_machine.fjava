@@target java

@@system MooreParity {
    interface:
        input(bit: int)
        output(): String

    machine:
        $Even {
            input(bit: int) {
                if (bit == 1) {
                    -> $Odd
                }
            }
            output(): String { @@:("even") }
        }
        $Odd {
            input(bit: int) {
                if (bit == 1) {
                    -> $Even
                }
            }
            output(): String { @@:("odd") }
        }
}

class Main {
    public static void main(String[] args) {
        var m = new MooreParity();
        int[] bits = {1, 0, 1, 1, 0};
        String[] expected = {"odd", "odd", "even", "odd", "odd"};
        for (int i = 0; i < 5; i++) {
            m.input(bits[i]);
            String result = (String) m.output();
            if (!result.equals(expected[i])) {
                throw new RuntimeException("FAIL: after bit " + bits[i] + " expected '" + expected[i] + "', got '" + result + "'");
            }
        }
        System.out.println("PASS: moore_machine");
    }
}

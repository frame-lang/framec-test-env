@@[target("ruby")]

@@system Turnstile {
    interface:
        coin()
        push(): str

    machine:
        $Locked {
            coin() { -> $Unlocked }
            push(): str { @@:("locked - insert coin") }
        }
        $Unlocked {
            coin() { }
            push(): str {
                @@:("welcome")
                -> $Locked
            }
        }
}

t = Turnstile.new
raise "Expected 'locked - insert coin'" unless t.push() == "locked - insert coin"
t.coin()
raise "Expected 'welcome'" unless t.push() == "welcome"
raise "Expected 'locked - insert coin'" unless t.push() == "locked - insert coin"
puts "PASS: turnstile"

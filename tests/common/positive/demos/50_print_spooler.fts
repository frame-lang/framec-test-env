@@[target("typescript")]

@@system PrintSpooler {
    interface:
        submit(name: str, pages: int)
        done()
        queue_depth(): int
        status(): str

    machine:
        $Idle {
            submit(name: str, pages: int) { -> $Printing }
            queue_depth(): int { @@:(0) }
            status(): str { @@:("idle") }
        }

        $Printing {
            submit(name: str, pages: int) {
                this.depth = this.depth + 1;
            }
            done() {
                if (this.depth > 0) {
                    this.depth = this.depth - 1;
                } else {
                    -> $Idle
                }
            }
            queue_depth(): int { @@:(this.depth) }
            status(): str { @@:("printing") }
        }

    domain:
        depth: int = 0
}

const sp = @@PrintSpooler();
if (sp.status() !== "idle") throw new Error("expected idle");
if (sp.queue_depth() !== 0) throw new Error("expected depth=0");
sp.submit("a", 1);
if (sp.status() !== "printing") throw new Error("expected printing");
sp.submit("b", 2);
if (sp.queue_depth() !== 1) throw new Error("expected depth=1");
sp.submit("c", 3);
if (sp.queue_depth() !== 2) throw new Error("expected depth=2");
sp.done();
if (sp.queue_depth() !== 1) throw new Error("expected depth=1 after done");
sp.done();
if (sp.queue_depth() !== 0) throw new Error("expected depth=0 after done");
if (sp.status() !== "printing") throw new Error("expected printing still");
sp.done();
if (sp.status() !== "idle") throw new Error("expected idle after final done");
console.log("PASS: print_spooler");

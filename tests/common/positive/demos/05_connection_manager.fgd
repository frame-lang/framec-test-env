@@target gdscript

extends SceneTree

@@system Connection {
    interface:
        connect_host(host: str)
        send(data: str): str
        close()

    machine:
        $Disconnected {
            connect_host(host: str) {
                self.host = host
                -> $Connecting
            }
        }
        $Connecting {
            $>() {
                print("Connecting to " + self.host + "...")
                -> $Connected
            }
        }
        $Connected {
            $>() { print("Connected to " + self.host) }
            <$() { print("Disconnecting from " + self.host) }

            send(data: str): str {
                @@:("sent '" + data + "' to " + self.host)
            }
            close() { -> $Disconnected }
        }

    domain:
        host: str = ""
}

func _init():
    var c = @@Connection()
    c.connect_host("example.com")
    var result = c.send("hello")
    assert(result == "sent 'hello' to example.com", "Got: " + str(result))
    c.close()
    print("PASS: connection_manager")
    quit()

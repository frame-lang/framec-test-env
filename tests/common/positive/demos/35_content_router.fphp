@@[target("php")]


@@system ContentBasedRouter {
    interface:
        route(kind: str, payload: str): str

    machine:
        $Routing {
            route(kind: str, payload: str): str {
                if ($kind === "order") {
                    $this->to_orders($payload);
                    @@:("orders")
                } else {
                    if ($kind === "refund") {
                        $this->to_refunds($payload);
                        @@:("refunds")
                    } else {
                        $this->to_dlq($payload);
                        @@:("dlq")
                    }
                }
            }
        }

    actions:
        to_orders(p)  { echo "-> orders:  " . $p . "\n"; }
        to_refunds(p) { echo "-> refunds: " . $p . "\n"; }
        to_dlq(p)     { echo "-> dlq:     " . $p . "\n"; }
}

$r = @@ContentBasedRouter();
assert($r->route("order",   "SKU-1") === "orders");
assert($r->route("refund",  "INV-7") === "refunds");
assert($r->route("unknown", "???")    === "dlq");
echo "PASS: content_router\n";

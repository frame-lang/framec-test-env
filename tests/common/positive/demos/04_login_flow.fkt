@@[target("kotlin")]

@@system LoginFlow {
    interface:
        submit(value: String): String

    machine:
        $EnterUsername {
            submit(value: String): String {
                this.username = value
                @@:("enter password")
                -> $EnterPassword
            }
        }
        $EnterPassword {
            submit(value: String): String {
                if (this.username == "admin" && value == "secret") {
                    @@:("welcome")
                    -> $LoggedIn
                } else {
                    @@:("invalid - try again")
                    -> $EnterUsername
                }
            }
        }
        $LoggedIn {
            submit(value: String): String { @@:("already logged in") }
        }

    domain:
        username: String = ""
}

fun main() {
    val login = LoginFlow()
    val r1 = login.submit("admin") as String
    assert(r1 == "enter password") { "Expected 'enter password', got '$r1'" }
    val r2 = login.submit("wrong") as String
    assert(r2 == "invalid - try again") { "Expected 'invalid - try again', got '$r2'" }
    val r3 = login.submit("admin") as String
    assert(r3 == "enter password") { "Expected 'enter password', got '$r3'" }
    val r4 = login.submit("secret") as String
    assert(r4 == "welcome") { "Expected 'welcome', got '$r4'" }
    println("PASS: login_flow")
}

-- Graceful Shutdown — service pattern with enter handler chain (Lua)

@@system GracefulShutdown {
    interface:
        process_data(): str
        status(): str
        get_cycles(): int

    machine:
        $Init {
            $>() {
                self.cycles = 0
                -> $ProcessData
            }
        }
        $ProcessData {
            $>() {
                self.cycles = self.cycles + 1
            }

            process_data(): str {
                if self.cycles >= self.max_cycles {
                    -> $ShuttingDown
                    @@:("shutting_down")
                } else {
                    -> $ProcessData
                    @@:("processed")
                }
            }
            status(): str { @@:("processing") }
            get_cycles(): int { @@:(self.cycles) }
        }
        $ShuttingDown {
            $>() {
                self.cleanup_done = true
            }

            status(): str { @@:("shutdown") }
            get_cycles(): int { @@:(self.cycles) }
        }

    domain:
        cycles = 0
        max_cycles = 3
        cleanup_done = false
}

local svc = @@GracefulShutdown()
local failures = 0

if svc:status() ~= "processing" then
    print("FAIL: expected processing")
    failures = failures + 1
end
if svc:get_cycles() ~= 1 then
    print("FAIL: expected 1 cycle")
    failures = failures + 1
end

local r1 = svc:process_data()
if r1 ~= "processed" then
    print("FAIL: expected processed")
    failures = failures + 1
end

local r2 = svc:process_data()
if r2 ~= "processed" then
    print("FAIL: expected processed")
    failures = failures + 1
end

local r3 = svc:process_data()
if r3 ~= "shutting_down" then
    print("FAIL: expected shutting_down")
    failures = failures + 1
end
if svc:status() ~= "shutdown" then
    print("FAIL: expected shutdown")
    failures = failures + 1
end

if failures > 0 then
    print("FAIL: graceful_shutdown (" .. failures .. " failures)")
    os.exit(1)
end
print("PASS: graceful_shutdown")

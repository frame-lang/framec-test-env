@@target lua

@@system LoginFlow {
    interface:
        submit(value: str): str

    machine:
        $EnterUsername {
            submit(value: str): str {
                self.username = value
                @@:("enter password")
                -> $EnterPassword
            }
        }
        $EnterPassword {
            submit(value: str): str {
                if self:authenticate(self.username, value) then
                    @@:("welcome")
                    -> $LoggedIn
                else
                    @@:("invalid - try again")
                    -> $EnterUsername
                end
            }
        }
        $LoggedIn {
            submit(value: str): str { @@:("already logged in") }
        }

    actions:
        authenticate(user, password) {
            return user == "admin" and password == "secret"
        }

    domain:
        username: str = ""
}

local login = @@LoginFlow()
local r1 = login:submit("admin")
assert(r1 == "enter password", "Expected 'enter password', got '" .. tostring(r1) .. "'")
local r2 = login:submit("wrong")
assert(r2 == "invalid - try again", "Expected 'invalid - try again', got '" .. tostring(r2) .. "'")
local r3 = login:submit("admin")
assert(r3 == "enter password", "Expected 'enter password', got '" .. tostring(r3) .. "'")
local r4 = login:submit("secret")
assert(r4 == "welcome", "Expected 'welcome', got '" .. tostring(r4) .. "'")
print("PASS: login_flow")

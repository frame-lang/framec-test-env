@@target php

<?php

@@system ApprovalChain {
    interface:
        submit()
        approve(reviewer: str)
        reject(reviewer: str)
        status(): str

    machine:
        $Draft {
            submit() { -> $Review1 }
            status(): str { @@:("draft") }
        }
        $Review1 {
            approve(reviewer: str) {
                echo "Approved by " . $reviewer . "\n";
                -> $Review2
            }
            reject(reviewer: str) {
                echo "Rejected by " . $reviewer . "\n";
                -> $Draft
            }
            status(): str { @@:("awaiting first review") }
        }
        $Review2 {
            approve(reviewer: str) {
                echo "Approved by " . $reviewer . "\n";
                -> $Published
            }
            reject(reviewer: str) {
                echo "Rejected by " . $reviewer . "\n";
                -> $Draft
            }
            status(): str { @@:("awaiting second review") }
        }
        $Published {
            status(): str { @@:("published") }
        }
}

$doc = @@ApprovalChain();
$doc->submit();
assert($doc->status() === "awaiting first review");
$doc->approve("Alice");
assert($doc->status() === "awaiting second review");
$doc->reject("Bob");
assert($doc->status() === "draft");
$doc->submit();
$doc->approve("Alice");
$doc->approve("Bob");
assert($doc->status() === "published");
echo "PASS: approval_chain\n";

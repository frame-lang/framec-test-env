@@[target("rust")]

@@system TrafficLight {
    interface:
        next(): String

    machine:
        $Green {
            next(): String {
                @@:("green".to_string())
                -> $Yellow
            }
        }
        $Yellow {
            next(): String {
                @@:("yellow".to_string())
                -> $Red
            }
        }
        $Red {
            next(): String {
                @@:("red".to_string())
                -> $Green
            }
        }
}

fn main() {
    let mut light = @@TrafficLight();
    let mut results: Vec<String> = Vec::new();
    for _ in 0..6 {
        results.push(light.next());
    }
    let expected = vec!["green", "yellow", "red", "green", "yellow", "red"];
    assert_eq!(results, expected, "Expected {:?}, got {:?}", expected, results);
    println!("PASS: traffic_light");
}

@@[target("rust")]

@@system RobotArm {
    interface:
        set_manual()
        set_auto()
        e_stop()
        reset_e_stop()
        status(): String

    machine:
        $Manual => $Operational {
            set_auto() { -> $Auto }
            status(): String { @@:("Manual".to_string()) }
            => $^
        }

        $Auto => $Operational {
            set_manual() { -> $Manual }
            status(): String { @@:("Auto".to_string()) }
            => $^
        }

        $Operational {
            e_stop() { -> $EStop }
            status(): String { @@:("Operational".to_string()) }
        }

        $EStop {
            reset_e_stop() { -> $Manual }
            status(): String { @@:("EStop".to_string()) }
        }

    domain:
}

fn main() {
    let mut arm = @@RobotArm();
    assert_eq!(arm.status(), "Manual");
    arm.e_stop();
    assert_eq!(arm.status(), "EStop");
    arm.reset_e_stop();
    assert_eq!(arm.status(), "Manual");
    arm.set_auto();
    assert_eq!(arm.status(), "Auto");
    arm.e_stop();
    assert_eq!(arm.status(), "EStop");
    println!("PASS: robot_arm");
}

@@target csharp

using System;

@@system LoginFlow {
    interface:
        submit(value: String): String

    machine:
        $EnterUsername {
            submit(value: String): String {
                this.username = value;
                @@:("enter password")
                -> $EnterPassword
            }
        }
        $EnterPassword {
            submit(value: String): String {
                if (this.username == "admin" && value == "secret") {
                    @@:("welcome")
                    -> $LoggedIn
                } else {
                    @@:("invalid - try again")
                    -> $EnterUsername
                }
            }
        }
        $LoggedIn {
            submit(value: String): String { @@:("already logged in") }
        }

    domain:
        username: String = ""
}

class Program {
    static void Main(string[] args) {
        var login = @@LoginFlow();
        var r1 = (string) login.submit("admin");
        if (r1 != "enter password") throw new Exception("Expected 'enter password', got '" + r1 + "'");
        var r2 = (string) login.submit("wrong");
        if (r2 != "invalid - try again") throw new Exception("Expected 'invalid - try again', got '" + r2 + "'");
        var r3 = (string) login.submit("admin");
        if (r3 != "enter password") throw new Exception("Expected 'enter password', got '" + r3 + "'");
        var r4 = (string) login.submit("secret");
        if (r4 != "welcome") throw new Exception("Expected 'welcome', got '" + r4 + "'");
        Console.WriteLine("PASS: login_flow");
    }
}

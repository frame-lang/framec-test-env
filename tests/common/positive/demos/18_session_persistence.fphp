@@[target("php")]

<?php

@@[persist]
@@system Session {
    operations:
        @@[save]
        save_state(): string {}

        @@[load]
        restore_state(data: string) {}

    interface:
        login(user: str)
        logout()
        who(): str

    machine:
        $LoggedOut {
            login(user: str) {
                $this->user = $user;
                -> $LoggedIn
            }
            who(): str { @@:("nobody") }
        }
        $LoggedIn {
            logout() {
                $this->user = "";
                -> $LoggedOut
            }
            who(): str { @@:($this->user) }
        }

    domain:
        user = ""
}

$s = @@Session();
$s->login("alice");
if ($s->who() !== "alice") {
    echo "FAIL: expected 'alice'\n";
    exit(1);
}
$data = $s->save_state();
$s2 = new Session();

$s2->restore_state($data);
if ($s2->who() !== "alice") {
    echo "FAIL: expected 'alice' after restore\n";
    exit(1);
}
echo "PASS: session_persistence\n";

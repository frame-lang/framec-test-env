@@[target("ruby")]

@@system VideoPlayer {
    interface:
        play()
        pause()
        stop()
        status(): str

    machine:
        $Stopped {
            play() { -> $Playing }
            status(): str { @@:("stopped") }
        }
        $Playing => $Active {
            pause() { -> $Paused }
            status(): str { @@:("playing") }
            => $^
        }
        $Paused => $Active {
            play() { -> $Playing }
            status(): str { @@:("paused") }
            => $^
        }
        $Active {
            stop() { -> $Stopped }
        }
}

vp = VideoPlayer.new
raise "FAIL" unless vp.status() == "stopped"
vp.play()
raise "FAIL" unless vp.status() == "playing"
vp.pause()
raise "FAIL" unless vp.status() == "paused"
vp.stop()
raise "FAIL" unless vp.status() == "stopped"
puts "PASS: video_player"

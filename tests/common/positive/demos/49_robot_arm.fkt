@@[target("kotlin")]

@@system RobotArm {
    interface:
        set_manual()
        set_auto()
        e_stop()
        reset_e_stop()
        status(): String

    machine:
        $Manual => $Operational {
            set_auto() { -> $Auto }
            status(): String { @@:("Manual") }
            => $^
        }

        $Auto => $Operational {
            set_manual() { -> $Manual }
            status(): String { @@:("Auto") }
            => $^
        }

        $Operational {
            e_stop() { -> $EStop }
            status(): String { @@:("Operational") }
        }

        $EStop {
            reset_e_stop() { -> $Manual }
            status(): String { @@:("EStop") }
        }

    domain:
}

fun main() {
    val arm = @@RobotArm()
    if ((arm.status() as String) != "Manual") throw RuntimeException("expected Manual")
    arm.e_stop()
    if ((arm.status() as String) != "EStop") throw RuntimeException("expected EStop")
    arm.reset_e_stop()
    if ((arm.status() as String) != "Manual") throw RuntimeException("expected Manual2")
    arm.set_auto()
    if ((arm.status() as String) != "Auto") throw RuntimeException("expected Auto")
    arm.e_stop()
    if ((arm.status() as String) != "EStop") throw RuntimeException("expected EStop from Auto")
    println("PASS: robot_arm")
}

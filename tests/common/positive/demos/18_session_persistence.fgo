@@[target("go")]

package main

import (
	"encoding/json"
	"fmt"
	"os"
)

@@[persist]
@@system Session {
    operations:
        @@[save]
        SaveState(): string {}

        @@[load]
        LoadState(data: string) {}

    interface:
        login(user: string)
        logout()
        who(): string

    machine:
        $LoggedOut {
            login(user: string) {
                s.user = user
                -> $LoggedIn
            }
            who(): string { @@:("nobody") }
        }
        $LoggedIn {
            logout() {
                s.user = ""
                -> $LoggedOut
            }
            who(): string { @@:(s.user) }
        }

    domain:
        user: string = ""
}

func main() {
	s := NewSession()
	s.Login("alice")
	if s.Who() != "alice" {
		fmt.Println("FAIL: expected 'alice'")
		os.Exit(1)
	}
	data := s.SaveState()
	s2 := NewSession()

	s2.LoadState(data)
	if s2.Who() != "alice" {
		fmt.Println("FAIL: expected 'alice' after restore")
		os.Exit(1)
	}
	fmt.Println("PASS: session_persistence")
}

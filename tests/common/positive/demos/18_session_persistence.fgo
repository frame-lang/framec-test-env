@@target go
@@skip -- Go persistence codegen not yet implemented

package main

import "fmt"

@@system Session {
    interface:
        login(user: string)
        logout()
        who(): string

    machine:
        $LoggedOut {
            login(user: string) {
                self.user = user
                -> $LoggedIn
            }
            who(): string { @@:("nobody") }
        }
        $LoggedIn {
            logout() {
                self.user = ""
                -> $LoggedOut
            }
            who(): string { @@:(self.user) }
        }

    domain:
        user = ""
}

func main() {
	fmt.Println("SKIP: session_persistence -- Go persistence not yet implemented")
}

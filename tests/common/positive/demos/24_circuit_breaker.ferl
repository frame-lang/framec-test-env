@@target erlang

@@system CircuitBreaker {
    interface:
        call(): str
        succeed()
        fail()
        reset()
        status(): str

    machine:
        $Closed {
            $.failures: int = 0

            call(): str { @@:("allowed") }
            succeed() {
                $.failures = 0
            }
            fail() {
                $.failures = $.failures + 1
                if $.failures >= self.threshold {
                    -> $Open
                }
            }
            reset() { $.failures = 0 }
            status(): str { @@:("closed") }
        }
        $Open {
            call(): str { @@:("blocked") }
            reset() { -> $HalfOpen }
            status(): str { @@:("open") }
        }
        $HalfOpen {
            call(): str { @@:("trial") }
            succeed() { -> $Closed }
            fail() { -> $Open }
            status(): str { @@:("half_open") }
        }

    domain:
        threshold = 3
}

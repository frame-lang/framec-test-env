@@[target("csharp")]


@@[persist(String)]
@@[save(SaveState)]
@@[load(RestoreState)]
@@system MessageStore {
    interface:
        record(topic: String, payload: String)
        count_for(topic: String): int
        total(): int

    machine:
        $Recording {
            record(topic: String, payload: String) {
                this.total_count = this.total_count + 1;
                if (topic == "orders") {
                    this.orders_count = this.orders_count + 1;
                } else {
                    if (topic == "refunds") {
                        this.refunds_count = this.refunds_count + 1;
                    }
                }
            }
            count_for(topic: String): int {
                if (topic == "orders") {
                    @@:(this.orders_count)
                } else {
                    if (topic == "refunds") {
                        @@:(this.refunds_count)
                    } else {
                        @@:(0)
                    }
                }
            }
            total(): int { @@:(this.total_count) }
        }

    domain:
        total_count: int = 0
        orders_count: int = 0
        refunds_count: int = 0
}

class Program {
    static void Main(string[] args) {
        var s = @@MessageStore();
        s.record("orders", "O-1");
        s.record("orders", "O-2");
        s.record("refunds", "R-1");

        var snap = (string) s.SaveState();
        var s2 = @@MessageStore();
        s2.RestoreState(snap);
        if ((int) s2.total() != 3) throw new Exception("expected total=3");
        if ((int) s2.count_for("orders") != 2) throw new Exception("expected orders=2");
        s2.record("orders", "O-3");
        if ((int) s2.total() != 4) throw new Exception("expected total=4");
        if ((int) s2.count_for("orders") != 3) throw new Exception("expected orders=3");
        Console.WriteLine("PASS: message_store");
    }
}

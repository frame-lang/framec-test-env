@@[target("erlang")]

@@system Elevator {
    interface:
        request(floor: int)
        tick()
        close_doors()
        current_floor(): int
        status(): str

    machine:
        $Idle {
            request(floor: int) {
                if floor > Data#data.floor {
                    self.target = floor
                    -> $MovingUp
                } else if floor < Data#data.floor {
                    self.target = floor
                    -> $MovingDown
                } else {
                    -> $DoorsOpen
                }
            }
            current_floor(): int { @@:(Data#data.floor) }
            status(): str { @@:("idle") }
        }

        $MovingUp {
            tick() {
                self.floor = Data#data.floor + 1
                if Data1#data.floor == Data1#data.target {
                    -> $DoorsOpen
                }
            }
            current_floor(): int { @@:(Data#data.floor) }
            status(): str { @@:("up") }
        }

        $MovingDown {
            tick() {
                self.floor = Data#data.floor - 1
                if Data1#data.floor == Data1#data.target {
                    -> $DoorsOpen
                }
            }
            current_floor(): int { @@:(Data#data.floor) }
            status(): str { @@:("down") }
        }

        $DoorsOpen {
            close_doors() { -> $Idle }
            current_floor(): int { @@:(Data#data.floor) }
            status(): str { @@:("doors_open") }
        }

    domain:
        floor = 1
        target = 1
}

@@target lua

@@system Retrier {
    interface:
        start()
        status(): str

    machine:
        $Idle {
            start() {
                self.attempts = 0
                -> $Trying
            }
        }
        $Trying {
            $>() {
                self.attempts = self.attempts + 1
                if self:try_operation() then
                    -> $Succeeded
                else
                    if self.attempts >= self.max_retries then
                        -> $Failed
                    else
                        -> $Trying
                    end
                end
            }
            status(): str { @@:("trying") }
        }
        $Succeeded {
            status(): str { @@:("succeeded") }
        }
        $Failed {
            status(): str { @@:("failed after max retries") }
        }

    actions:
        try_operation() {
            return false
        }

    domain:
        attempts: int = 0
        max_retries: int = 3
}

local r = @@Retrier()
r:start()
local result = r:status()
assert(result == "failed after max retries", "Got: " .. tostring(result))
assert(r.attempts == 3, "Expected 3 attempts, got " .. tostring(r.attempts))
print("PASS: retry_with_backoff")

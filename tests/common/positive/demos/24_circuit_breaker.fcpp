@@[target("cpp_17")]

#include <iostream>
#include <cassert>

@@system CircuitBreaker {
    interface:
        call(): std::string
        success()
        failure()
        tick()
        status(): std::string

    machine:
        $Closed {
            $.failures: int = 0
            call(): std::string { @@:(std::string("allowed")) }
            success() { $.failures = 0; }
            failure() {
                $.failures = $.failures + 1;
                if ($.failures >= this->threshold) {
                    -> $Open
                }
            }
            status(): std::string { @@:(std::string("closed")) }
        }
        $Open {
            $.cooldown_remaining: int = 0
            $>() {
                $.cooldown_remaining = this->cooldown;
            }
            call(): std::string { @@:(std::string("blocked")) }
            tick() {
                $.cooldown_remaining = $.cooldown_remaining - 1;
                if ($.cooldown_remaining <= 0) {
                    -> $HalfOpen
                }
            }
            status(): std::string { @@:(std::string("open")) }
        }
        $HalfOpen {
            call(): std::string { @@:(std::string("testing")) }
            success() { -> $Closed }
            failure() { -> $Open }
            status(): std::string { @@:(std::string("half-open")) }
        }

    domain:
        threshold : int = 3
        cooldown : int = 5
}

int main() {
    auto cb = @@CircuitBreaker();

    cb.failure();
    cb.failure();
    cb.failure();
    assert(cb.call() == "blocked");

    for (int i = 0; i < 5; i++) { cb.tick(); }
    assert(cb.call() == "testing");

    cb.success();
    assert(cb.status() == "closed");

    std::cout << "PASS: circuit_breaker" << std::endl;
    return 0;
}

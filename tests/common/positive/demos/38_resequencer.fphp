@@[target("php")]

<?php

@@system Resequencer {
    interface:
        arrive(seq: int, payload: str): str
        status(): str

    machine:
        $Buffering {
            arrive(seq: int, payload: str): str {
                $this->buffer[$seq] = $payload;
                $released = 0;
                while (isset($this->buffer[$this->next_seq])) {
                    $p = $this->buffer[$this->next_seq];
                    unset($this->buffer[$this->next_seq]);
                    $this->release($this->next_seq, $p);
                    $this->next_seq = $this->next_seq + 1;
                    $released = $released + 1;
                }
                if ($released > 0) {
                    @@:("released " . $released)
                } else {
                    @@:("buffered")
                }
            }
            status(): str {
                @@:("next=" . $this->next_seq . " buffered=" . count($this->buffer))
            }
        }

    actions:
        release(seq, payload) {
            echo "  out #" . $seq . ": " . $payload . "\n";
        }

    domain:
        buffer = []
        next_seq = 1
}

$rs = @@Resequencer();
assert($rs->arrive(3, "c") === "buffered",     "expected buffered");
assert($rs->arrive(1, "a") === "released 1",   "expected released 1");
assert($rs->arrive(2, "b") === "released 2",   "expected released 2");
assert($rs->status() === "next=4 buffered=0",  "expected next=4 buffered=0");
echo "PASS: resequencer\n";

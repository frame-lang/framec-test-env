@@target rust

@@system Turnstile {
    interface:
        coin()
        push(): String

    machine:
        $Locked {
            coin() { -> $Unlocked }
            push(): String { @@:("locked - insert coin".to_string()) }
        }
        $Unlocked {
            coin() { }
            push(): String {
                @@:("welcome".to_string())
                -> $Locked
            }
        }
}

fn main() {
    let mut t = @@Turnstile();
    assert_eq!(t.push(), "locked - insert coin");
    t.coin();
    assert_eq!(t.push(), "welcome");
    assert_eq!(t.push(), "locked - insert coin");
    println!("PASS: turnstile");
}

@@target dart

@@system DialogManager {
    interface:
        open(name: String)
        close(): String
        current(): String

    machine:
        $Main {
            open(name: String) {
                push$
                -> (name) $Dialog
            }
            current(): String { @@:("main") }
        }
        $Dialog {
            $.name: String = ""

            $>(name: String) { $.name = name }

            open(name: String) {
                push$
                -> (name) $Dialog
            }
            close(): String {
                @@:($.name)
                -> pop$
            }
            current(): String { @@:($.name) }
        }
}

void main() {
    final dm = @@DialogManager();
    if (dm.current() as String != "main") {
        throw Exception("Expected 'main'");
    }
    dm.open("Settings");
    if (dm.current() as String != "Settings") {
        throw Exception("Expected 'Settings'");
    }
    dm.open("Confirm");
    if (dm.current() as String != "Confirm") {
        throw Exception("Expected 'Confirm'");
    }
    final closed1 = dm.close() as String;
    if (closed1 != "Confirm") {
        throw Exception("Expected 'Confirm'");
    }
    if (dm.current() as String != "Settings") {
        throw Exception("Expected 'Settings'");
    }
    final closed2 = dm.close() as String;
    if (closed2 != "Settings") {
        throw Exception("Expected 'Settings'");
    }
    if (dm.current() as String != "main") {
        throw Exception("Expected 'main'");
    }
    print("PASS: modal_dialog_stack");
}

@@[target("java")]

@@system Editor {
    interface:
        type_char(c: String)
        undo()
        get_buffer(): String

    machine:
        $Editing {
            $.buffer: String = ""

            type_char(c: String) {
                push$
                $.buffer = $.buffer + c
            }
            undo() {
                -> pop$
            }
            get_buffer(): String { @@:($.buffer) }
        }
}

class Main {
    public static void main(String[] args) {
        var e = @@Editor();
        e.type_char("H");
        e.type_char("i");
        assert ((String) e.get_buffer()).equals("Hi");
        e.undo();
        assert ((String) e.get_buffer()).equals("H");
        e.undo();
        assert ((String) e.get_buffer()).equals("");
        System.out.println("PASS: undo_redo");
    }
}

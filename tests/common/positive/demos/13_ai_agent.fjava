@@target java

@@system Agent {
    interface:
        tick()
        threat()
        safe()
        get_log(): String

    machine:
        $Exploring {
            tick() {
                this.action_log = this.action_log + "explore,";
            }
            threat() {
                this.action_log = this.action_log + "flee,";
                -> $Fleeing
            }
            get_log(): String { @@:(this.action_log) }
        }
        $Fleeing {
            tick() {
                this.action_log = this.action_log + "run,";
            }
            safe() {
                this.action_log = this.action_log + "resume,";
                -> $Exploring
            }
            get_log(): String { @@:(this.action_log) }
        }

    domain:
        action_log: String = ""
}

class Main {
    public static void main(String[] args) {
        var a = new Agent();
        a.tick();
        a.tick();
        a.threat();
        a.tick();
        a.safe();
        var result = (String) a.get_log();
        var expected = "explore,explore,flee,run,resume,";
        assert result.equals(expected) : "Expected '" + expected + "', got '" + result + "'";
        System.out.println("PASS: ai_agent");
    }
}

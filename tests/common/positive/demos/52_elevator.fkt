@@[target("kotlin")]

@@system Elevator {
    interface:
        request(floor: Int)
        tick()
        close_doors()
        current_floor(): Int
        status(): String

    machine:
        $Idle {
            request(floor: Int) {
                if (floor > this.floor) {
                    this.target = floor
                    -> $MovingUp
                } else if (floor < this.floor) {
                    this.target = floor
                    -> $MovingDown
                } else {
                    -> $DoorsOpen
                }
            }
            current_floor(): Int { @@:(this.floor) }
            status(): String { @@:("idle") }
        }

        $MovingUp {
            tick() {
                this.floor = this.floor + 1
                if (this.floor == this.target) {
                    -> $DoorsOpen
                }
            }
            current_floor(): Int { @@:(this.floor) }
            status(): String { @@:("up") }
        }

        $MovingDown {
            tick() {
                this.floor = this.floor - 1
                if (this.floor == this.target) {
                    -> $DoorsOpen
                }
            }
            current_floor(): Int { @@:(this.floor) }
            status(): String { @@:("down") }
        }

        $DoorsOpen {
            close_doors() { -> $Idle }
            current_floor(): Int { @@:(this.floor) }
            status(): String { @@:("doors_open") }
        }

    domain:
        floor: Int = 1
        target: Int = 1
}

fun main() {
    val e = @@Elevator()
    if ((e.status() as String) != "idle") throw RuntimeException("expected idle")
    if ((e.current_floor() as Int) != 1) throw RuntimeException("expected floor=1")
    e.request(5)
    if ((e.status() as String) != "up") throw RuntimeException("expected up")
    e.tick(); e.tick(); e.tick(); e.tick()
    if ((e.current_floor() as Int) != 5) throw RuntimeException("expected floor=5")
    if ((e.status() as String) != "doors_open") throw RuntimeException("expected doors_open")
    e.close_doors()
    if ((e.status() as String) != "idle") throw RuntimeException("expected idle")
    e.request(2)
    if ((e.status() as String) != "down") throw RuntimeException("expected down")
    e.tick(); e.tick(); e.tick()
    if ((e.current_floor() as Int) != 2) throw RuntimeException("expected floor=2")
    if ((e.status() as String) != "doors_open") throw RuntimeException("expected doors_open")
    e.close_doors()
    e.request(2)
    if ((e.status() as String) != "doors_open") throw RuntimeException("expected immediate doors_open")
    println("PASS: elevator")
}

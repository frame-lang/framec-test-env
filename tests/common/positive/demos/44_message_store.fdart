@@[target("dart")]

import 'dart:convert';
import 'dart:io';

@@[persist(String)]
@@[save(saveState)]
@@[load(restoreState)]
@@system MessageStore {
    interface:
        record(topic: String, payload: String)
        count_for(topic: String): int
        total(): int

    machine:
        $Recording {
            record(topic: String, payload: String) {
                this.total_count = this.total_count + 1;
                if (topic == "orders") {
                    this.orders_count = this.orders_count + 1;
                } else {
                    if (topic == "refunds") {
                        this.refunds_count = this.refunds_count + 1;
                    }
                }
            }
            count_for(topic: String): int {
                if (topic == "orders") {
                    @@:(this.orders_count)
                } else {
                    if (topic == "refunds") {
                        @@:(this.refunds_count)
                    } else {
                        @@:(0)
                    }
                }
            }
            total(): int { @@:(this.total_count) }
        }

    domain:
        total_count: int = 0
        orders_count: int = 0
        refunds_count: int = 0
}

void main() {
    final s = @@MessageStore();
    s.record("orders", "O-1");
    s.record("orders", "O-2");
    s.record("refunds", "R-1");

    final snap = s.saveState();
    final s2 = @@MessageStore();
    s2.restoreState(snap);
    if (s2.total() != 3) { print("FAIL: total=3");  exit(1); }
    if (s2.count_for("orders") != 2) { print("FAIL: orders=2"); exit(1); }
    s2.record("orders", "O-3");
    if (s2.total() != 4) { print("FAIL: total=4");  exit(1); }
    if (s2.count_for("orders") != 3) { print("FAIL: orders=3"); exit(1); }
    print("PASS: message_store");
}

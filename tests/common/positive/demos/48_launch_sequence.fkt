@@[target("kotlin")]

@@system LaunchController {
    interface:
        countdown_start()
        ignite()
        max_q_passed()
        meco()
        seco()
        abort()
        phase(): String
        outcome(): String

    machine:
        $Idle {
            countdown_start() { -> $Countdown }
            phase(): String { @@:("Idle") }
            outcome(): String { @@:("none") }
        }

        $Countdown {
            ignite() { -> $Boost }
            abort() {
                this.outcome_str = "scrubbed"
                -> $Aborted
            }
            phase(): String { @@:("Countdown") }
            outcome(): String { @@:("none") }
        }

        $Boost {
            max_q_passed() { -> $Sustain }
            abort() {
                this.outcome_str = "RTLS"
                -> $Aborted
            }
            phase(): String { @@:("Boost") }
            outcome(): String { @@:("none") }
        }

        $Sustain {
            meco() { -> $Coast }
            abort() {
                this.outcome_str = "ATO"
                -> $Aborted
            }
            phase(): String { @@:("Sustain") }
            outcome(): String { @@:("none") }
        }

        $Coast {
            seco() { -> $Orbit }
            abort() {
                this.outcome_str = "TAL"
                -> $Aborted
            }
            phase(): String { @@:("Coast") }
            outcome(): String { @@:("none") }
        }

        $Orbit {
            phase(): String { @@:("Orbit") }
            outcome(): String { @@:("nominal") }
        }

        $Aborted {
            phase(): String { @@:("Aborted") }
            outcome(): String { @@:(this.outcome_str) }
        }

    domain:
        outcome_str: String = ""
}

fun main() {
    val lc = @@LaunchController()
    lc.countdown_start()
    lc.ignite()
    lc.max_q_passed()
    lc.meco()
    lc.seco()
    if ((lc.phase() as String) != "Orbit") throw RuntimeException("expected Orbit")
    if ((lc.outcome() as String) != "nominal") throw RuntimeException("expected nominal")

    val lc2 = @@LaunchController()
    lc2.countdown_start()
    lc2.ignite()
    lc2.abort()
    if ((lc2.outcome() as String) != "RTLS") throw RuntimeException("expected RTLS")

    val lc3 = @@LaunchController()
    lc3.countdown_start()
    lc3.ignite()
    lc3.max_q_passed()
    lc3.abort()
    if ((lc3.outcome() as String) != "ATO") throw RuntimeException("expected ATO")

    val lc4 = @@LaunchController()
    lc4.countdown_start()
    lc4.abort()
    if ((lc4.outcome() as String) != "scrubbed") throw RuntimeException("expected scrubbed")

    println("PASS: launch_sequence")
}

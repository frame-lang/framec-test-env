@@target kotlin

@@system ApprovalChain {
    interface:
        submit()
        approve(reviewer: String)
        reject(reviewer: String)
        status(): String

    machine:
        $Draft {
            submit() { -> $Review1 }
            status(): String { @@:("draft") }
        }
        $Review1 {
            approve(reviewer: String) {
                println("Approved by $reviewer")
                -> $Review2
            }
            reject(reviewer: String) {
                println("Rejected by $reviewer")
                -> $Draft
            }
            status(): String { @@:("awaiting first review") }
        }
        $Review2 {
            approve(reviewer: String) {
                println("Approved by $reviewer")
                -> $Published
            }
            reject(reviewer: String) {
                println("Rejected by $reviewer")
                -> $Draft
            }
            status(): String { @@:("awaiting second review") }
        }
        $Published {
            status(): String { @@:("published") }
        }
}

fun main() {
    val doc = ApprovalChain()
    doc.submit()
    assert(doc.status() as String == "awaiting first review")
    doc.approve("Alice")
    assert(doc.status() as String == "awaiting second review")
    doc.reject("Bob")
    assert(doc.status() as String == "draft")
    doc.submit()
    doc.approve("Alice")
    doc.approve("Bob")
    assert(doc.status() as String == "published")
    println("PASS: approval_chain")
}

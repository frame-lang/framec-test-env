@@target erlang

@@system PipelineProcessor {
    interface:
        start(data: str)
        status(): str

    machine:
        $Idle {
            start(data: str) {
                self.data = data
                -> $Validate
            }
            status(): str { @@:("idle") }
        }
        $Validate {
            $>() {
                self.step_count = self.step_count + 1
                -> $Transform
            }
            status(): str { @@:("validate") }
        }
        $Transform {
            $>() {
                self.step_count = self.step_count + 1
                -> $Enrich
            }
            status(): str { @@:("transform") }
        }
        $Enrich {
            $>() {
                self.step_count = self.step_count + 1
                -> $Store
            }
            status(): str { @@:("enrich") }
        }
        $Store {
            $>() {
                self.step_count = self.step_count + 1
                -> $Complete
            }
            status(): str { @@:("store") }
        }
        $Complete {
            status(): str { @@:("complete") }
            start(data: str) {
                self.data = data
                self.step_count = 0
                -> $Validate
            }
        }

    domain:
        data = ""
        step_count = 0
}

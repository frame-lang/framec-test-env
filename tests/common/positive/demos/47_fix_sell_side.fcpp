@@[target("cpp_17")]

#include <iostream>
#include <cassert>

@@system FixSellSide {
    interface:
        new_order(cl_ord_id: str, qty: double, price: double)
        market_fill(qty: double, px: double)
        cancel_request(cancel_cl_ord_id: str)
        status(): str
        get_cum_qty(): double
        get_leaves_qty(): double

    machine:
        $NoOrder {
            new_order(cl_ord_id: str, qty: double, price: double) {
                this->cl_ord_id = cl_ord_id;
                this->order_qty = qty;
                this->leaves_qty = qty;
                this->price = price;
                -> $Working
            }
            status(): str { @@:(std::string("NoOrder")) }
            get_cum_qty(): double { @@:(this->cum_qty) }
            get_leaves_qty(): double { @@:(this->leaves_qty) }
        }

        $Working {
            market_fill(qty: double, px: double) {
                this->cum_qty = this->cum_qty + qty;
                this->leaves_qty = this->order_qty - this->cum_qty;
                if (this->leaves_qty <= 0.0) {
                    -> $Filled
                }
            }
            cancel_request(cancel_cl_ord_id: str) { -> $Canceled }
            status(): str { @@:(std::string("Working")) }
            get_cum_qty(): double { @@:(this->cum_qty) }
            get_leaves_qty(): double { @@:(this->leaves_qty) }
        }

        $Filled {
            status(): str { @@:(std::string("Filled")) }
            get_cum_qty(): double { @@:(this->cum_qty) }
            get_leaves_qty(): double { @@:(this->leaves_qty) }
        }

        $Canceled {
            status(): str { @@:(std::string("Canceled")) }
            get_cum_qty(): double { @@:(this->cum_qty) }
            get_leaves_qty(): double { @@:(this->leaves_qty) }
        }

    domain:
        cl_ord_id: std::string = ""
        order_qty: double = 0.0
        cum_qty: double = 0.0
        leaves_qty: double = 0.0
        price: double = 0.0
}

int main() {
    auto o = @@FixSellSide();
    assert(std::any_cast<std::string>(o.status()) == "NoOrder");
    o.new_order("CL-1", 200.0, 50.0);
    assert(std::any_cast<std::string>(o.status()) == "Working");
    assert(std::any_cast<double>(o.get_leaves_qty()) == 200.0);
    o.market_fill(80.0, 50.05);
    assert(std::any_cast<double>(o.get_cum_qty()) == 80.0);
    o.market_fill(120.0, 50.10);
    assert(std::any_cast<std::string>(o.status()) == "Filled");

    auto o2 = @@FixSellSide();
    o2.new_order("CL-2", 100.0, 49.0);
    o2.market_fill(30.0, 49.10);
    o2.cancel_request("CXL-2");
    assert(std::any_cast<std::string>(o2.status()) == "Canceled");
    std::cout << "PASS: fix_sell_side" << std::endl;
    return 0;
}

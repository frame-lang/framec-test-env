// Self-Calibrating Sensor — @@:self demo (Java)

@@system Sensor {
    interface:
        calibrate(): str
        reading(): float
        trigger_shutdown()
        attempt_post_shutdown(): str
        status(): str

    machine:
        $Active {
            calibrate(): str {
                double baseline = @@:self.reading();
                this.offset = baseline * -1;
                @@:("calibrated: offset=" + this.offset)
            }

            reading(): float {
                @@:(this.raw_value + this.offset)
            }

            trigger_shutdown() {
                -> $Shutdown
            }

            attempt_post_shutdown(): str {
                this.trace = "before";
                @@:self.trigger_shutdown();
                this.trace = "after";
                @@:(this.trace)
            }

            status(): str { @@:(@@:system.state) }
        }

        $Shutdown {
            status(): str { @@:(@@:system.state) }
        }

    domain:
        raw_value: double = 42.0
        offset: double = 0.0
        trace: String = ""
}

class Main {
    public static void main(String[] args) {
        Sensor sensor = @@Sensor();
        int failures = 0;

        double r1 = sensor.reading();
        if (Math.abs(r1 - 42.0) > 1e-9) {
            System.out.println("FAIL: reading() expected 42.0, got " + r1);
            failures++;
        }

        String cal = sensor.calibrate();
        if (!cal.contains("calibrated")) {
            System.out.println("FAIL: calibrate() expected 'calibrated', got '" + cal + "'");
            failures++;
        }

        double r2 = sensor.reading();
        if (Math.abs(r2) > 1e-9) {
            System.out.println("FAIL: reading() after calibrate expected 0.0, got " + r2);
            failures++;
        }

        String result = sensor.attempt_post_shutdown();
        if (!result.equals("before")) {
            System.out.println("FAIL: attempt_post_shutdown() expected 'before', got '" + result + "'");
            failures++;
        }

        String st = sensor.status();
        if (!st.equals("Shutdown")) {
            System.out.println("FAIL: status() expected 'shutdown', got '" + st + "'");
            failures++;
        }

        if (failures > 0) {
            System.out.println("FAIL: self_calibrating_sensor (" + failures + " failures)");
            System.exit(1);
        }
        System.out.println("PASS: self_calibrating_sensor");
    }
}

@@target cpp_17

#include <iostream>
#include <string>
#include <cassert>
#include <nlohmann/json.hpp>

@@persist
@@system Session {
    interface:
        login(user: str)
        logout()
        who(): str

    machine:
        $LoggedOut {
            login(user: str) {
                this->user = user;
                -> $LoggedIn
            }
            who(): str { @@:(std::string("nobody")) }
        }
        $LoggedIn {
            logout() {
                this->user = "";
                -> $LoggedOut
            }
            who(): str { @@:(this->user) }
        }

    domain:
        user: std::string = ""
}

int main() {
    auto s = @@Session();
    s.login("alice");
    assert(std::any_cast<std::string>(s.who()) == "alice");

    auto data = s.save_state();
    auto s2 = Session::restore_state(data);
    assert(std::any_cast<std::string>(s2.who()) == "alice");
    printf("PASS: session_persistence\n");
    return 0;
}

@@target cpp_17

#include <iostream>
#include <string>
#include <cassert>

@@system MooreParity {
    interface:
        input(bit: int)
        output(): str

    machine:
        $Even {
            input(bit: int) {
                if (bit == 1) {
                    -> $Odd
                }
            }
            output(): str { @@:(std::string("even")) }
        }
        $Odd {
            input(bit: int) {
                if (bit == 1) {
                    -> $Even
                }
            }
            output(): str { @@:(std::string("odd")) }
        }
}

int main() {
    MooreParity m;
    int bits[] = {1, 0, 1, 1, 0};
    std::string expected[] = {"odd", "odd", "even", "odd", "odd"};
    for (int i = 0; i < 5; i++) {
        m.input(bits[i]);
        std::string result = std::any_cast<std::string>(m.output());
        assert(result == expected[i]);
    }
    printf("PASS: moore_machine\n");
    return 0;
}

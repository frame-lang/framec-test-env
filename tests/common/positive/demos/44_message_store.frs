@@[target("rust")]

use serde_json;

@@[persist]
@@system MessageStore {
    operations:
        @@[save]
        save_state(): String {}

        @@[load]
        restore_state(data: String) {}

    interface:
        record(topic: String, payload: String)
        count_for(topic: String): i32
        total(): i32

    machine:
        $Recording {
            record(topic: String, payload: String) {
                self.total_count = self.total_count + 1;
                if topic == "orders" {
                    self.orders_count = self.orders_count + 1;
                } else {
                    if topic == "refunds" {
                        self.refunds_count = self.refunds_count + 1;
                    }
                }
            }
            count_for(topic: String): i32 {
                if topic == "orders" {
                    @@:(self.orders_count)
                } else {
                    if topic == "refunds" {
                        @@:(self.refunds_count)
                    } else {
                        @@:(0)
                    }
                }
            }
            total(): i32 { @@:(self.total_count) }
        }

    domain:
        total_count: i32 = 0
        orders_count: i32 = 0
        refunds_count: i32 = 0
}

fn main() {
    let mut s = @@MessageStore();
    s.record("orders".to_string(), "O-1".to_string());
    s.record("orders".to_string(), "O-2".to_string());
    s.record("refunds".to_string(), "R-1".to_string());

    let snap = s.save_state();
    let mut s2 = MessageStore::new();
    s2.restore_state(snap);
    assert_eq!(s2.total(), 3);
    assert_eq!(s2.count_for("orders".to_string()), 2);
    s2.record("orders".to_string(), "O-3".to_string());
    assert_eq!(s2.total(), 4);
    assert_eq!(s2.count_for("orders".to_string()), 3);
    println!("PASS: message_store");
}

@@[target("php")]
@@skip -- PHP does not have native async/await

<?php

@@system AsyncWorker {
    interface:
        start()
        get_status(): str

    machine:
        $Idle {
            start() { -> $Working }
            get_status(): str { @@:("idle") }
        }
        $Working {
            get_status(): str { @@:("working") }
        }
}

echo "SKIP: async_http_client -- PHP does not have native async/await\n";

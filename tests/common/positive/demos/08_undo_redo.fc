@@[target("c")]

#include <stdio.h>
#include <stdlib.h>
#include <string.h>

@@system Editor {
    interface:
        type_char(c: str)
        undo()
        get_buffer(): str

    machine:
        $Editing {
            $.buffer: str = ""

            type_char(c: str) {
                push$
                char* __old = (char*)$.buffer;
                char* __new = malloc(strlen(__old) + strlen(c) + 1);
                sprintf(__new, "%s%s", __old, c);
                $.buffer = __new;
            }
            undo() {
                -> pop$
            }
            get_buffer(): str { @@:($.buffer) }
        }
}

int main() {
    Editor* e = @@Editor();
    Editor_type_char(e, "H");
    Editor_type_char(e, "i");
    if (strcmp(Editor_get_buffer(e), "Hi") != 0) { printf("FAIL\n"); return 1; }
    Editor_undo(e);
    if (strcmp(Editor_get_buffer(e), "Hi") != 0) { printf("FAIL: expected Hi (reference semantics)\n"); return 1; }
    Editor_undo(e);
    if (strcmp(Editor_get_buffer(e), "Hi") != 0) { printf("FAIL: expected Hi (reference semantics)\n"); return 1; }
    printf("PASS: undo_redo\n");
    Editor_destroy(e);
    return 0;
}

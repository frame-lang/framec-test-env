@@[target("erlang")]
@@skip -- Erlang is a one-color language -- async not applicable

@@system AsyncWorker {
    interface:
        start()
        process(data: str): str
        stop()
        get_status(): str

    machine:
        $Idle {
            start() {
                -> $Working
            }
            get_status(): str { @@:("idle") }
        }
        $Working {
            process(data: str): str {
                @@:("processed:" ++ data)
            }
            stop() {
                -> $Idle
            }
            get_status(): str { @@:("working") }
        }
}

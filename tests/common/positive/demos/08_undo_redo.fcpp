@@[target("cpp_17")]

#include <iostream>
#include <cassert>

@@system Editor {
    interface:
        type_char(c: str)
        undo()
        get_buffer(): str

    machine:
        $Editing {
            $.buffer: str = ""

            type_char(c: str) {
                push$
                $.buffer = std::string($.buffer) + std::string(c)
            }
            undo() {
                -> pop$
            }
            get_buffer(): str { @@:(std::string($.buffer)) }
        }
}

int main() {
    auto e = @@Editor();
    e.type_char("H");
    e.type_char("i");
    assert(e.get_buffer() == "Hi");
    e.undo();
    assert(e.get_buffer() == "Hi");
    e.undo();
    assert(e.get_buffer() == "Hi");
    printf("PASS: undo_redo\n");
    return 0;
}

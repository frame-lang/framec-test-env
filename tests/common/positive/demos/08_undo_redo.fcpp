@@target cpp_17

#include <iostream>
#include <string>
#include <cassert>

@@system Editor {
    interface:
        type_char(c: str)
        undo()
        get_buffer(): str

    machine:
        $Editing {
            $.buffer: str = ""

            type_char(c: str) {
                push$
                $.buffer = std::string($.buffer) + std::string(c)
            }
            undo() {
                -> pop$
            }
            get_buffer(): str { @@:(std::string($.buffer)) }
        }
}

int main() {
    Editor e;
    e.type_char("H");
    e.type_char("i");
    assert(std::any_cast<std::string>(e.get_buffer()) == "Hi");
    e.undo();
    assert(std::any_cast<std::string>(e.get_buffer()) == "H");
    e.undo();
    assert(std::any_cast<std::string>(e.get_buffer()) == "");
    printf("PASS: undo_redo\n");
    return 0;
}

@@[target("erlang")]

@@system PrintSpooler {
    interface:
        submit(name: str, pages: int)
        done()
        queue_depth(): int
        status(): str

    machine:
        $Idle {
            submit(name: str, pages: int) { -> $Printing }
            queue_depth(): int { @@:(0) }
            status(): str { @@:("idle") }
        }

        $Printing {
            submit(name: str, pages: int) {
                self.depth = self.depth + 1
            }
            done() {
                if Data#data.depth > 0 {
                    self.depth = Data#data.depth - 1
                } else {
                    -> $Idle
                }
            }
            queue_depth(): int { @@:(Data#data.depth) }
            status(): str { @@:("printing") }
        }

    domain:
        depth = 0
}

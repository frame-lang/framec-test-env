@@[target("csharp")]

using System;
using System.Collections.Generic;

@@system TrafficLight {
    interface:
        next(): String

    machine:
        $Green {
            next(): String {
                @@:("green")
                -> $Yellow
            }
        }
        $Yellow {
            next(): String {
                @@:("yellow")
                -> $Red
            }
        }
        $Red {
            next(): String {
                @@:("red")
                -> $Green
            }
        }
}

class Program {
    static void Main(string[] args) {
        var light = @@TrafficLight();
        var results = new List<string>();
        for (int i = 0; i < 6; i++) {
            results.Add((string) light.next());
        }
        var expected = new List<string> { "green", "yellow", "red", "green", "yellow", "red" };
        for (int i = 0; i < 6; i++) {
            if (results[i] != expected[i]) {
                throw new Exception($"Step {i}: expected {expected[i]} got {results[i]}");
            }
        }
        Console.WriteLine("PASS: traffic_light");
    }
}

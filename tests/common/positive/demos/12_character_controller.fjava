@@target java

@@system Character {
    interface:
        move()
        sprint()
        jump()
        land()
        stop()
        state(): String

    machine:
        $Idle {
            move() { -> $Walking }
            jump() { -> $Jumping }
            state(): String { @@:("idle") }
        }
        $Walking {
            sprint() { -> $Running }
            jump() { -> $Jumping }
            stop() { -> $Idle }
            state(): String { @@:("walking") }
        }
        $Running {
            stop() { -> $Walking }
            jump() { -> $Jumping }
            state(): String { @@:("running") }
        }
        $Jumping {
            land() { -> $Idle }
            state(): String { @@:("jumping") }
        }
}

class Main {
    public static void main(String[] args) {
        var c = new Character();
        assert ((String) c.state()).equals("idle");
        c.move();
        assert ((String) c.state()).equals("walking");
        c.sprint();
        assert ((String) c.state()).equals("running");
        c.jump();
        assert ((String) c.state()).equals("jumping");
        c.move();  // ignored while jumping
        assert ((String) c.state()).equals("jumping");
        c.land();
        assert ((String) c.state()).equals("idle");
        System.out.println("PASS: character_controller");
    }
}

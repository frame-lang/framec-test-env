@@target cpp_17

#include <iostream>
#include <string>
#include <vector>
#include <cassert>

@@system TrafficLight {
    interface:
        next(): str

    machine:
        $Green {
            next(): str {
                @@:(std::string("green"))
                -> $Yellow
            }
        }
        $Yellow {
            next(): str {
                @@:(std::string("yellow"))
                -> $Red
            }
        }
        $Red {
            next(): str {
                @@:(std::string("red"))
                -> $Green
            }
        }
}

int main() {
    TrafficLight light;
    std::vector<std::string> results;
    for (int i = 0; i < 6; i++) {
        auto r = std::any_cast<std::string>(light.next());
        results.push_back(r);
    }
    std::vector<std::string> expected = {"green", "yellow", "red", "green", "yellow", "red"};
    assert(results == expected);
    printf("PASS: traffic_light\n");
    return 0;
}

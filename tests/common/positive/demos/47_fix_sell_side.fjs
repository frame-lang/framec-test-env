@@[target("javascript")]

@@system FixSellSide {
    interface:
        new_order(cl_ord_id, qty, price)
        market_fill(qty, px)
        cancel_request(cancel_cl_ord_id)
        status()
        get_cum_qty()
        get_leaves_qty()

    machine:
        $NoOrder {
            new_order(cl_ord_id, qty, price) {
                this.cl_ord_id = cl_ord_id;
                this.order_qty = qty;
                this.leaves_qty = qty;
                this.price = price;
                -> $Working
            }
            status() { @@:("NoOrder") }
            get_cum_qty() { @@:(this.cum_qty) }
            get_leaves_qty() { @@:(this.leaves_qty) }
        }

        $Working {
            market_fill(qty, px) {
                this.cum_qty = this.cum_qty + qty;
                this.leaves_qty = this.order_qty - this.cum_qty;
                if (this.leaves_qty <= 0) {
                    -> $Filled
                }
            }
            cancel_request(cancel_cl_ord_id) { -> $Canceled }
            status() { @@:("Working") }
            get_cum_qty() { @@:(this.cum_qty) }
            get_leaves_qty() { @@:(this.leaves_qty) }
        }

        $Filled {
            status() { @@:("Filled") }
            get_cum_qty() { @@:(this.cum_qty) }
            get_leaves_qty() { @@:(this.leaves_qty) }
        }

        $Canceled {
            status() { @@:("Canceled") }
            get_cum_qty() { @@:(this.cum_qty) }
            get_leaves_qty() { @@:(this.leaves_qty) }
        }

    domain:
        cl_ord_id = ""
        order_qty = 0.0
        cum_qty = 0.0
        leaves_qty = 0.0
        price = 0.0
}

const o = @@FixSellSide();
if (o.status() !== "NoOrder") throw new Error("expected NoOrder");
o.new_order("CL-1", 200.0, 50.0);
if (o.status() !== "Working") throw new Error("expected Working");
if (o.get_leaves_qty() !== 200.0) throw new Error("expected leaves=200");
o.market_fill(80.0, 50.05);
if (o.get_cum_qty() !== 80.0) throw new Error("expected cum=80");
o.market_fill(120.0, 50.10);
if (o.status() !== "Filled") throw new Error("expected Filled");
if (o.get_cum_qty() !== 200.0) throw new Error("expected cum=200");

const o2 = @@FixSellSide();
o2.new_order("CL-2", 100.0, 49.0);
o2.market_fill(30.0, 49.10);
o2.cancel_request("CXL-2");
if (o2.status() !== "Canceled") throw new Error("expected Canceled");
console.log("PASS: fix_sell_side");

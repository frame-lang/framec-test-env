@@[target("ruby")]

@@system RateLimiter {
    operations:
        static tokens_for_rate(rps, interval_ms) {
            return [1, (rps * interval_ms) / 1000].max
        }
        tokens_remaining() {
            return self.tokens
        }

    interface:
        request(): str = "error"
        tick()

    machine:
        $Accepting {
            request(): str {
                self.tokens = self.tokens - 1
                @@:("accepted")
                if self.tokens <= 0
                    -> $Throttled
                end
            }
            tick() { self.tokens = [self.tokens + 1, self.max_tokens].min }
        }
        $Throttled {
            request(): str { @@:("throttled") }
            tick() {
                self.tokens = self.tokens + 1
                if self.tokens > 0
                    -> $Accepting
                end
            }
        }

    domain:
        tokens = 10
        max_tokens = 10
}

failures = 0
if RateLimiter.tokens_for_rate(100, 50) != 5
    puts "FAIL: static op"
    failures += 1
end
rl = @@RateLimiter()
10.times { rl.request }
if rl.request != "throttled"
    puts "FAIL: throttled"
    failures += 1
end
rl.tick
if rl.request != "accepted"
    puts "FAIL: accepted after tick"
    failures += 1
end

if failures > 0
    puts "FAIL: rate_limiter (#{failures})"
    exit(1)
end
puts "PASS: rate_limiter"

# Rate Limiter — static + instance operations (Ruby)

@@system RateLimiter {
    operations:
        static get_max_requests(): int {
            return 5
        }
        get_count(): int {
            return self.count
        }

    interface:
        request(): str
        reset()
        status(): str

    machine:
        $Allowing {
            request(): str {
                self.count = self.count + 1
                if self.count >= self.max_requests {
                    -> $Throttling
                }
                @@:("allowed")
            }
            reset() {
                self.count = 0
            }
            status(): str { @@:("allowing") }
        }
        $Throttling {
            request(): str { @@:("throttled") }
            reset() {
                self.count = 0
                -> $Allowing
            }
            status(): str { @@:("throttling") }
        }

    domain:
        count = 0
        max_requests = 5
}

rl = @@RateLimiter()
failures = 0

max_req = RateLimiter.get_max_requests()
if max_req != 5
    puts "FAIL: static get_max_requests expected 5, got #{max_req}"
    failures += 1
end

4.times do |i|
    r = rl.request()
    if r != "allowed"
        puts "FAIL: request #{i} should be allowed"
        failures += 1
    end
end
if rl.get_count() != 4
    puts "FAIL: count should be 4"
    failures += 1
end
if rl.status() != "allowing"
    puts "FAIL: should still be allowing"
    failures += 1
end

rl.request()
if rl.status() != "throttling"
    puts "FAIL: should be throttling after 5"
    failures += 1
end
if rl.request() != "throttled"
    puts "FAIL: should be throttled"
    failures += 1
end

rl.reset()
if rl.status() != "allowing"
    puts "FAIL: should be allowing after reset"
    failures += 1
end
if rl.get_count() != 0
    puts "FAIL: count should be 0 after reset"
    failures += 1
end

if failures > 0
    puts "FAIL: rate_limiter (#{failures} failures)"
    exit(1)
end
puts "PASS: rate_limiter"

@@target rust

@@system MooreParity {
    interface:
        input(bit: int)
        output(): String

    machine:
        $Even {
            input(bit: int) {
                if bit == 1 {
                    -> $Odd
                }
            }
            output(): String { @@:("even".to_string()) }
        }
        $Odd {
            input(bit: int) {
                if bit == 1 {
                    -> $Even
                }
            }
            output(): String { @@:("odd".to_string()) }
        }
}

fn main() {
    let mut m = @@MooreParity();
    let bits = [1, 0, 1, 1, 0];
    let expected = ["odd", "odd", "even", "odd", "odd"];
    for i in 0..5 {
        m.input(bits[i]);
        let result = m.output();
        assert_eq!(result, expected[i], "after bit {} expected '{}', got '{}'", bits[i], expected[i], result);
    }
    println!("PASS: moore_machine");
}

@@target erlang

@@system RateLimiter {
    operations:
        static get_max_requests(): int {
            @@:(5)
        }
        get_count(): int {
            @@:(self.count)
        }

    interface:
        request(): str
        reset()
        status(): str

    machine:
        $Allowing {
            request(): str {
                self.count = self.count + 1
                if self.count >= self.max_requests {
                    -> $Throttling
                }
                @@:("allowed")
            }
            reset() {
                self.count = 0
            }
            status(): str { @@:("allowing") }
        }
        $Throttling {
            request(): str { @@:("throttled") }
            reset() {
                self.count = 0
                -> $Allowing
            }
            status(): str { @@:("throttling") }
        }

    domain:
        count = 0
        max_requests = 5
}

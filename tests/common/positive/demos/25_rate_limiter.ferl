@@[target("erlang")]

@@system RateLimiter {
    operations:
        static tokens_for_rate(rps: int, interval_ms: int): int {
            Val = (rps * interval_ms) div 1000,
            if Val > 1 -> Val; true -> 1 end
        }
        tokens_remaining(): int {
            @@:(self.tokens)
        }

    interface:
        request(): str
        tick()

    machine:
        $Accepting {
            request(): str {
                self.tokens = self.tokens - 1
                @@:("accepted")
                if self.tokens =< 0 {
                    -> $Throttled
                }
            }
            tick() {
                self.tokens = self.tokens + 1
                if self.tokens > self.max_tokens {
                    self.tokens = self.max_tokens
                }
            }
        }
        $Throttled {
            request(): str { @@:("throttled") }
            tick() {
                self.tokens = self.tokens + 1
                if self.tokens > 0 {
                    -> $Accepting
                }
            }
        }

    domain:
        tokens = 10
        max_tokens = 10
}

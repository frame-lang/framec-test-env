@@[target("gdscript")]

extends SceneTree

@@system Worker {
    interface:
        assign(msg: String)
        finish()
        busy(): bool

    machine:
        $Idle {
            assign(msg: String) {
                self.current = msg
                -> $Working
            }
            busy(): bool { @@:(false) }
        }
        $Working {
            $>() { print("worker[" + self.name + "] start: " + self.current) }
            finish() {
                print("worker[" + self.name + "] done")
                self.current = ""
                -> $Idle
            }
            busy(): bool { @@:(true) }
        }

    domain:
        name: String = ""
        current: String = ""
}

@@[main]
@@system Dispatcher {
    interface:
        submit(msg: String): String
        worker_a_free()
        worker_b_free()

    machine:
        $Running {
            submit(msg: String): String {
                if not self.worker_a.busy():
                    self.worker_a.assign(msg)
                    @@:("dispatched to a")
                else:
                    if not self.worker_b.busy():
                        self.worker_b.assign(msg)
                        @@:("dispatched to b")
                    else:
                        self.backlog = self.backlog + 1
                        @@:("queued")
            }
            worker_a_free() {
                if self.backlog > 0:
                    self.backlog = self.backlog - 1
                    self.worker_a.assign("backlog-job")
            }
            worker_b_free() {
                if self.backlog > 0:
                    self.backlog = self.backlog - 1
                    self.worker_b.assign("backlog-job")
            }
        }

    domain:
        worker_a = @@Worker()
        worker_b = @@Worker()
        backlog: int = 0
}

func main():
    var d = @@Dispatcher()
    d.worker_a.name = "A"
    d.worker_b.name = "B"
    var failures = 0

    if d.submit("job-1") != "dispatched to a": print("FAIL: dispatched a"); failures += 1
    if d.submit("job-2") != "dispatched to b": print("FAIL: dispatched b"); failures += 1
    if d.submit("job-3") != "queued":           print("FAIL: queued");      failures += 1

    d.worker_a.finish()
    d.worker_a_free()
    if d.worker_a.busy() != true: print("FAIL: expected worker_a busy"); failures += 1
    if d.backlog != 0:             print("FAIL: expected backlog drained"); failures += 1

    d.worker_b.finish()
    d.worker_a.finish()
    if failures > 0:
        print("FAIL: competing_consumers (" + str(failures) + " failures)")
        quit(1)
    print("PASS: competing_consumers")

func _init():
    main()
    quit()

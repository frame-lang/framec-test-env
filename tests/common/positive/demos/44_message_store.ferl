@@[target("erlang")]

@@[persist]
@@[save(save_state)]
@@[load(load_state)]
@@system MessageStore {
    interface:
        record(topic: str, payload: str)
        count_for(topic: str): int
        total(): int

    machine:
        $Recording {
            record(topic: str, payload: str) {
                self.total_count = self.total_count + 1
                if topic == "orders" {
                    self.orders_count = self.orders_count + 1
                } else {
                    if topic == "refunds" {
                        self.refunds_count = self.refunds_count + 1
                    }
                }
            }
            count_for(topic: str): int {
                if topic == "orders" {
                    @@:(self.orders_count)
                } else {
                    if topic == "refunds" {
                        @@:(self.refunds_count)
                    } else {
                        @@:(0)
                    }
                }
            }
            total(): int { @@:(self.total_count) }
        }

    domain:
        total_count = 0
        orders_count = 0
        refunds_count = 0
}

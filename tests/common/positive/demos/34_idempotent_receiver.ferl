@@[target("erlang")]

@@system IdempotentReceiver {
    interface:
        deliver(msg_id: str, payload: str): str

    machine:
        $Ready {
            deliver(msg_id: str, payload: str): str {
                if sets:is_element(msg_id, self.seen) {
                    @@:("duplicate")
                } else {
                    self.seen = sets:add_element(msg_id, self.seen)
                    io:format("processing: ~s~n", [Payload])
                    @@:("accepted")
                }
            }
        }

    domain:
        seen = sets:new()
}

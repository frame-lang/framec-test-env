@@target gdscript

extends SceneTree

@@system RateLimiter {
    operations:
        static get_max_requests(): int {
            @@:(5)
        }
        get_count(): int {
            @@:(self.count)
        }

    interface:
        request(): str
        reset()
        status(): str

    machine:
        $Allowing {
            request(): str {
                self.count = self.count + 1
                if self.count >= self.max_requests {
                    -> $Throttling
                }
                @@:("allowed")
            }
            reset() {
                self.count = 0
            }
            status(): str { @@:("allowing") }
        }
        $Throttling {
            request(): str { @@:("throttled") }
            reset() {
                self.count = 0
                -> $Allowing
            }
            status(): str { @@:("throttling") }
        }

    domain:
        count = 0
        max_requests = 5
}

func _init():
    var rl = @@RateLimiter()

    var max_r = RateLimiter.get_max_requests()
    assert(max_r == 5, "Expected max 5, got: " + str(max_r))

    for i in range(4):
        var r = rl.request()
        assert(r == "allowed", "Expected allowed, got: " + str(r))

    rl.request()
    assert(rl.status() == "throttling", "Expected throttling")

    var r2 = rl.request()
    assert(r2 == "throttled", "Expected throttled, got: " + str(r2))

    rl.reset()
    assert(rl.status() == "allowing", "Expected allowing after reset")
    assert(rl.get_count() == 0, "Expected count 0 after reset")

    print("PASS: rate_limiter")
    quit()

@@[target("c")]

#include <stdio.h>
#include <stdlib.h>
#include <string.h>

@@system MooreParity {
    interface:
        input(bit: int)
        output(): str

    machine:
        $Even {
            input(bit: int) {
                if (bit == 1) {
                    -> $Odd
                }
            }
            output(): str { @@:("even") }
        }
        $Odd {
            input(bit: int) {
                if (bit == 1) {
                    -> $Even
                }
            }
            output(): str { @@:("odd") }
        }
}

int main() {
    MooreParity* m = @@MooreParity();
    int bits[] = {1, 0, 1, 1, 0};
    const char* expected[] = {"odd", "odd", "even", "odd", "odd"};
    for (int i = 0; i < 5; i++) {
        MooreParity_input(m, bits[i]);
        const char* result = MooreParity_output(m);
        if (strcmp(result, expected[i]) != 0) {
            printf("FAIL: after bit %d expected '%s', got '%s'\n", bits[i], expected[i], result);
            return 1;
        }
    }
    printf("PASS: moore_machine\n");
    MooreParity_destroy(m);
    return 0;
}

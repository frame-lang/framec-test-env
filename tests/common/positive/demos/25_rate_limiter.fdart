@@[target("dart")]

import 'dart:io';

@@system RateLimiter {
    operations:
        static tokens_for_rate(rps: int, interval_ms: int): int {
            return [1, (rps * interval_ms) ~/ 1000].reduce((a, b) => a > b ? a : b);
        }
        tokens_remaining(): int {
            return this.tokens;
        }

    interface:
        request(): String
        tick()

    machine:
        $Accepting {
            request(): String {
                this.tokens = this.tokens - 1;
                @@:("accepted")
                if (this.tokens <= 0) {
                    -> $Throttled
                }
            }
            tick() {
                this.tokens = this.tokens + 1;
                if (this.tokens > this.max_tokens) { this.tokens = this.max_tokens; }
            }
        }
        $Throttled {
            request(): String { @@:("throttled") }
            tick() {
                this.tokens = this.tokens + 1;
                if (this.tokens > 0) {
                    -> $Accepting
                }
            }
        }

    domain:
        tokens : int = 10
        max_tokens : int = 10
}

void main() {
    int failures = 0;
    if (RateLimiter.tokens_for_rate(100, 50) != 5) { print("FAIL: static op"); failures++; }
    var rl = @@RateLimiter();
    for (int i = 0; i < 10; i++) { rl.request(); }
    if (rl.request() != "throttled") { print("FAIL: throttled"); failures++; }
    rl.tick();
    if (rl.request() != "accepted") { print("FAIL: accepted"); failures++; }

    if (failures > 0) { print("FAIL: rate_limiter ($failures)"); exit(1); }
    print("PASS: rate_limiter");
}

@@target lua

@@system Connection {
    interface:
        connect(host: str)
        send(data: str): str
        disconnect()

    machine:
        $Disconnected {
            connect(host: str) {
                self.host = host
                -> $Connecting
            }
        }
        $Connecting {
            $>() {
                print("Connecting to " .. self.host .. "...")
                -> $Connected
            }
        }
        $Connected {
            $>() { print("Connected to " .. self.host) }
            <$() { print("Disconnecting from " .. self.host) }

            send(data: str): str {
                @@:("sent '" .. data .. "' to " .. self.host)
            }
            disconnect() { -> $Disconnected }
        }

    domain:
        host: str = ""
}

local c = @@Connection()
c:connect("example.com")
local result = c:send("hello")
assert(result == "sent 'hello' to example.com", "Got: " .. tostring(result))
c:disconnect()
print("PASS: connection_manager")

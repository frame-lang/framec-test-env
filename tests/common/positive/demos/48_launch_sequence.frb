@@[target("ruby")]

@@system LaunchController {
    interface:
        countdown_start()
        ignite()
        max_q_passed()
        meco()
        seco()
        abort_launch()
        phase(): str
        outcome(): str

    machine:
        $Idle {
            countdown_start() { -> $Countdown }
            phase(): str { @@:("Idle") }
            outcome(): str { @@:("none") }
        }

        $Countdown {
            ignite() { -> $Boost }
            abort_launch() {
                @outcome_str = "scrubbed"
                -> $Aborted
            }
            phase(): str { @@:("Countdown") }
            outcome(): str { @@:("none") }
        }

        $Boost {
            max_q_passed() { -> $Sustain }
            abort_launch() {
                @outcome_str = "RTLS"
                -> $Aborted
            }
            phase(): str { @@:("Boost") }
            outcome(): str { @@:("none") }
        }

        $Sustain {
            meco() { -> $Coast }
            abort_launch() {
                @outcome_str = "ATO"
                -> $Aborted
            }
            phase(): str { @@:("Sustain") }
            outcome(): str { @@:("none") }
        }

        $Coast {
            seco() { -> $Orbit }
            abort_launch() {
                @outcome_str = "TAL"
                -> $Aborted
            }
            phase(): str { @@:("Coast") }
            outcome(): str { @@:("none") }
        }

        $Orbit {
            phase(): str { @@:("Orbit") }
            outcome(): str { @@:("nominal") }
        }

        $Aborted {
            phase(): str { @@:("Aborted") }
            outcome(): str { @@:(@outcome_str) }
        }

    domain:
        outcome_str = ""
}

lc = @@LaunchController()
lc.countdown_start
lc.ignite
lc.max_q_passed
lc.meco
lc.seco
raise "expected Orbit" unless lc.phase == "Orbit"
raise "expected nominal" unless lc.outcome == "nominal"

lc2 = @@LaunchController()
lc2.countdown_start
lc2.ignite
lc2.abort_launch
raise "expected RTLS" unless lc2.outcome == "RTLS"

lc3 = @@LaunchController()
lc3.countdown_start
lc3.ignite
lc3.max_q_passed
lc3.abort_launch
raise "expected ATO" unless lc3.outcome == "ATO"

lc4 = @@LaunchController()
lc4.countdown_start
lc4.abort_launch
raise "expected scrubbed" unless lc4.outcome == "scrubbed"

puts "PASS: launch_sequence"

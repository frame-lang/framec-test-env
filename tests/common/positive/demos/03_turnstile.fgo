@@target go

package main

import (
	"fmt"
	"os"
)

@@system Turnstile {
    interface:
        coin()
        push(): string

    machine:
        $Locked {
            coin() { -> $Unlocked }
            push(): string { @@:("locked - insert coin") }
        }
        $Unlocked {
            coin() { }
            push(): string {
                @@:("welcome")
                -> $Locked
            }
        }
}

func main() {
	t := NewTurnstile()
	r := t.Push()
	if r != "locked - insert coin" {
		fmt.Printf("FAIL: expected 'locked - insert coin' got '%s'\n", r)
		os.Exit(1)
	}
	t.Coin()
	r = t.Push()
	if r != "welcome" {
		fmt.Printf("FAIL: expected 'welcome' got '%s'\n", r)
		os.Exit(1)
	}
	r = t.Push()
	if r != "locked - insert coin" {
		fmt.Printf("FAIL: expected 'locked - insert coin' got '%s'\n", r)
		os.Exit(1)
	}
	fmt.Println("PASS: turnstile")
}

@@[target("swift")]


@@system LaunchController {
    interface:
        countdown_start()
        ignite()
        max_q_passed()
        meco()
        seco()
        abort_launch()
        phase(): String
        outcome(): String

    machine:
        $Idle {
            countdown_start() { -> $Countdown }
            phase(): String { @@:("Idle") }
            outcome(): String { @@:("none") }
        }

        $Countdown {
            ignite() { -> $Boost }
            abort_launch() {
                self.outcome_str = "scrubbed"
                -> $Aborted
            }
            phase(): String { @@:("Countdown") }
            outcome(): String { @@:("none") }
        }

        $Boost {
            max_q_passed() { -> $Sustain }
            abort_launch() {
                self.outcome_str = "RTLS"
                -> $Aborted
            }
            phase(): String { @@:("Boost") }
            outcome(): String { @@:("none") }
        }

        $Sustain {
            meco() { -> $Coast }
            abort_launch() {
                self.outcome_str = "ATO"
                -> $Aborted
            }
            phase(): String { @@:("Sustain") }
            outcome(): String { @@:("none") }
        }

        $Coast {
            seco() { -> $Orbit }
            abort_launch() {
                self.outcome_str = "TAL"
                -> $Aborted
            }
            phase(): String { @@:("Coast") }
            outcome(): String { @@:("none") }
        }

        $Orbit {
            phase(): String { @@:("Orbit") }
            outcome(): String { @@:("nominal") }
        }

        $Aborted {
            phase(): String { @@:("Aborted") }
            outcome(): String { @@:(self.outcome_str) }
        }

    domain:
        outcome_str: String = ""
}

let lc = @@LaunchController()
lc.countdown_start()
lc.ignite()
lc.max_q_passed()
lc.meco()
lc.seco()
if (lc.phase() as! String) != "Orbit" { print("FAIL: Orbit"); exit(1) }
if (lc.outcome() as! String) != "nominal" { print("FAIL: nominal"); exit(1) }

let lc2 = @@LaunchController()
lc2.countdown_start()
lc2.ignite()
lc2.abort_launch()
if (lc2.outcome() as! String) != "RTLS" { print("FAIL: RTLS"); exit(1) }

let lc3 = @@LaunchController()
lc3.countdown_start()
lc3.ignite()
lc3.max_q_passed()
lc3.abort_launch()
if (lc3.outcome() as! String) != "ATO" { print("FAIL: ATO"); exit(1) }

let lc4 = @@LaunchController()
lc4.countdown_start()
lc4.abort_launch()
if (lc4.outcome() as! String) != "scrubbed" { print("FAIL: scrubbed"); exit(1) }

print("PASS: launch_sequence")

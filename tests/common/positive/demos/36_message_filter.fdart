@@[target("dart")]

@@system MessageFilter {
    interface:
        consider(payload: String): String
        stats(): String

    machine:
        $Accepting {
            consider(payload: String): String {
                if (this.matches(payload)) {
                    this.passed = this.passed + 1;
                    this.forward(payload);
                    @@:("passed")
                } else {
                    this.dropped = this.dropped + 1;
                    @@:("dropped")
                }
            }
            stats(): String {
                @@:("passed=${this.passed} dropped=${this.dropped}")
            }
        }

    actions:
        matches(payload: String): bool {
            return payload.contains("urgent");
        }
        forward(payload: String): void {
            print("-> $payload");
        }

    domain:
        passed: int = 0
        dropped: int = 0
}

void main() {
    var f = MessageFilter();
    if ((f.consider("urgent: reboot") as String) != "passed")  throw "Expected passed";
    if ((f.consider("weekly digest")  as String) != "dropped") throw "Expected dropped";
    if ((f.consider("urgent: patch")  as String) != "passed")  throw "Expected passed";
    if ((f.stats() as String)            != "passed=2 dropped=1") throw "Bad stats";
    print("PASS: message_filter");
}

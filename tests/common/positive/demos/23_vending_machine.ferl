@@target erlang

@@system VendingMachine {
    operations:
        get_balance(): int {
            @@:(self.balance)
        }

    interface:
        insert_coin(amount: int)
        select(item: str): str
        refund(): int
        status(): str

    machine:
        $Idle {
            insert_coin(amount: int) {
                self.balance = amount
                -> $HasCredit
            }
            select(item: str): str { @@:("no credit") }
            refund(): int { @@:(0) }
            status(): str { @@:("idle") }
        }
        $HasCredit {
            insert_coin(amount: int) {
                self.balance = self.balance + amount
            }
            select(item: str): str {
                if self.balance >= self.item_price {
                    self.balance = self.balance - self.item_price
                    if self.balance == 0 {
                        -> $Idle
                    }
                    @@:(item)
                } else {
                    @@:("insufficient credit")
                }
            }
            refund(): int {
                Refund = self.balance,
                self.balance = 0
                @@:(Refund)
                -> $Idle
            }
            status(): str { @@:("has_credit") }
        }

    domain:
        balance = 0
        item_price = 100
}

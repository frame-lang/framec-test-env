@@[target("erlang")]

@@system VendingMachine {
    operations:
        get_balance(): int {
            @@:(self.balance)
        }

    interface:
        insert_coin(amount: int)
        select(product: str): str
        cancel(): int
        status(): str

    machine:
        $Idle {
            insert_coin(amount: int) {
                self.balance = amount
                -> $HasCredit
            }
            select(product: str): str { @@:("insert coin first") }
            cancel(): int { @@:(0) }
            status(): str { @@:("idle") }
        }
        $HasCredit {
            insert_coin(amount: int) {
                self.balance = self.balance + amount
            }
            select(product: str): str {
                if self.balance >= 100 {
                    self.balance = self.balance - 100
                    @@:("dispensing")
                    -> $Dispensing
                } else {
                    @@:("need more")
                }
            }
            cancel(): int {
                Refund = self.balance,
                self.balance = 0
                @@:(Refund)
                -> $Idle
            }
            status(): str { @@:("has_credit") }
        }
        $Dispensing {
            $>() {
                self.balance = 0
                -> $Idle
            }
            status(): str { @@:("dispensing") }
        }

    domain:
        balance = 0
}

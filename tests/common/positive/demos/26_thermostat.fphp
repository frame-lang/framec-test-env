@@[target("php")]

@@system Thermostat {
    interface:
        set_temp(target)
        tick()
        status(): string = "unknown"

    machine:
        $Off {
            set_temp(target) { $this->target = $target; -> $LowHeat }
            status(): string { @@:("off") }
        }
        $LowHeat => $On {
            $>() { $this->heat_rate = 1; }
            status(): string { @@:("low heat") }
            => $^
        }
        $HighHeat => $On {
            $>() { $this->heat_rate = 2; }
            status(): string { @@:("high heat") }
            => $^
        }
        $On {
            tick() {
                $this->current = $this->current + $this->heat_rate;
                if ($this->current >= $this->target) {
                    $this->current = $this->target;
                    -> $Cooling
                } elseif ($this->target - $this->current > 5) {
                    if ($this->heat_rate < 2) { -> $HighHeat }
                } elseif ($this->target - $this->current <= 3) {
                    if ($this->heat_rate > 1) { -> $LowHeat }
                }
            }
            set_temp(target) { $this->target = $target; }
        }
        $Cooling {
            $>() { $this->heat_rate = 0; }
            tick() {
                $this->current = $this->current - 1;
                if ($this->current <= $this->target) { -> $Off }
            }
            status(): string { @@:("cooling") }
        }

    domain:
        current = 65
        target = 65
        heat_rate = 0
}

$t = @@Thermostat();
$failures = 0;
if ($t->status() !== "off") { echo "FAIL: initial\n"; $failures++; }
$t->set_temp(75);
$cooled = false;
for ($i = 0; $i < 20; $i++) {
    $t->tick();
    $s = $t->status();
    if ($s === "cooling" || $s === "off") { $cooled = true; }
}
if (!$cooled) { echo "FAIL: never cooled\n"; $failures++; }
if ($failures > 0) { echo "FAIL: thermostat ($failures)\n"; exit(1); }
echo "PASS: thermostat\n";

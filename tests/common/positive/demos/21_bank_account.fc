@@target c

#include <stdio.h>
#include <stdlib.h>
#include <string.h>

@@system Account(owner: str, initial_balance: int = 0) {
    interface:
        deposit(amount: int)
        withdraw(amount: int): bool
        balance(): int
        owner_name(): str
        close()

    machine:
        $Open {
            deposit(amount: int) {
                self->bal = self->bal + amount;
            }
            withdraw(amount: int): bool {
                if (self->bal >= amount) {
                    self->bal = self->bal - amount;
                    @@:(1)
                } else {
                    @@:(0)
                }
            }
            balance(): int { @@:(self->bal) }
            owner_name(): str { @@:(self->who) }
            close() { -> $Closed }
        }
        $Closed {
            deposit(amount: int) {
                /* Closed accounts ignore deposits. */
            }
            withdraw(amount: int): bool { @@:(0) }
            balance(): int { @@:(self->bal) }
            owner_name(): str { @@:(self->who) }
        }

    domain:
        bal = initial_balance
        who = owner
}

int main() {
    Account* a = @@Account("Alice", 100);
    if (strcmp(Account_owner_name(a), "Alice") != 0) { printf("FAIL: owner\n"); return 1; }
    if (Account_balance(a) != 100) { printf("FAIL: balance\n"); return 1; }

    Account_deposit(a, 50);
    if (Account_balance(a) != 150) { printf("FAIL: deposit\n"); return 1; }

    if (Account_withdraw(a, 60) != 1) { printf("FAIL: withdraw ok\n"); return 1; }
    if (Account_balance(a) != 90) { printf("FAIL: balance after withdraw\n"); return 1; }

    if (Account_withdraw(a, 200) != 0) { printf("FAIL: withdraw insufficient\n"); return 1; }
    if (Account_balance(a) != 90) { printf("FAIL: balance unchanged\n"); return 1; }

    Account_close(a);
    if (Account_withdraw(a, 10) != 0) { printf("FAIL: closed withdraw\n"); return 1; }
    if (Account_balance(a) != 90) { printf("FAIL: closed balance\n"); return 1; }

    Account* b = @@Account("Bob", 0);
    if (strcmp(Account_owner_name(b), "Bob") != 0) { printf("FAIL: bob owner\n"); return 1; }
    if (Account_balance(b) != 0) { printf("FAIL: bob balance\n"); return 1; }
    Account_deposit(b, 25);
    if (Account_balance(b) != 25) { printf("FAIL: bob deposit\n"); return 1; }

    printf("ok 1 - 21_bank_account\n");
    Account_destroy(a);
    Account_destroy(b);
    return 0;
}

@@[target("go")]

package main

import (
	"fmt"
	"os"
)

@@system DialogManager {
    interface:
        open(name: string)
        close(): string
        current(): string

    machine:
        $Main {
            open(name: string) {
                push$
                -> (name) $Dialog
            }
            current(): string { @@:("main") }
        }
        $Dialog {
            $.name: string = ""

            $>(name: string) { $.name = name }

            open(name: string) {
                push$
                -> (name) $Dialog
            }
            close(): string {
                @@:($.name)
                -> pop$
            }
            current(): string { @@:($.name) }
        }
}

func main() {
	dm := @@DialogManager()
	if dm.Current() != "main" {
		fmt.Printf("FAIL: expected 'main' got '%s'\n", dm.Current())
		os.Exit(1)
	}
	dm.Open("Settings")
	if dm.Current() != "Settings" {
		fmt.Printf("FAIL: expected 'Settings' got '%s'\n", dm.Current())
		os.Exit(1)
	}
	dm.Open("Confirm")
	if dm.Current() != "Confirm" {
		fmt.Printf("FAIL: expected 'Confirm' got '%s'\n", dm.Current())
		os.Exit(1)
	}
	closed := dm.Close()
	if closed != "Confirm" {
		fmt.Printf("FAIL: expected 'Confirm' got '%s'\n", closed)
		os.Exit(1)
	}
	if dm.Current() != "Settings" {
		fmt.Printf("FAIL: expected 'Settings' got '%s'\n", dm.Current())
		os.Exit(1)
	}
	closed = dm.Close()
	if closed != "Settings" {
		fmt.Printf("FAIL: expected 'Settings' got '%s'\n", closed)
		os.Exit(1)
	}
	if dm.Current() != "main" {
		fmt.Printf("FAIL: expected 'main' got '%s'\n", dm.Current())
		os.Exit(1)
	}
	fmt.Println("PASS: modal_dialog_stack")
}

@@target c

#include <stdio.h>
#include <string.h>

@@system LoginManager {
    interface:
        login(user: str, pass: str): str

    machine:
        $LoggedOut {
            login(user: str, pass: str): str {
                if (strcmp(user, "admin") == 0 && strcmp(pass, "secret") == 0) {
                    @@:return("authenticated")
                }
                @@:("denied")
            }
        }
}

@@system App {
    interface:
        authenticate(user: str, pass: str): str

    machine:
        $Unauthenticated {
            authenticate(user: str, pass: str): str {
                @@:(LoginManager_login(self->auth, user, pass))
            }
        }

    domain:
        auth: LoginManager* = @@LoginManager()
}

int main() {
    App* app = @@App();

    const char* r1 = App_authenticate(app, "admin", "secret");
    if (strcmp(r1, "authenticated") != 0) {
        printf("FAIL: expected 'authenticated', got '%s'\n", r1);
        return 1;
    }

    const char* r2 = App_authenticate(app, "admin", "wrong");
    if (strcmp(r2, "denied") != 0) {
        printf("FAIL: expected 'denied', got '%s'\n", r2);
        return 1;
    }

    printf("PASS: auth_flow\n");
    return 0;
}

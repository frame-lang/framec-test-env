@@target php

<?php

@@system MealyDetector {
    interface:
        input(bit: int): str

    machine:
        $S0 {
            input(bit: int): str {
                if ($bit == 1) {
                    @@:("0")
                    -> $S1
                } else {
                    @@:("0")
                }
            }
        }
        $S1 {
            input(bit: int): str {
                if ($bit == 0) {
                    @@:("1")
                    -> $S0
                } else {
                    @@:("0")
                }
            }
        }
}

$m = @@MealyDetector();
$bits = [1, 0, 1, 1, 0];
$expected = ["0", "1", "0", "0", "1"];
for ($i = 0; $i < 5; $i++) {
    $result = $m->input($bits[$i]);
    if ($result !== $expected[$i]) {
        echo "FAIL: bit={$bits[$i]} expected '{$expected[$i]}', got '$result'\n";
        exit(1);
    }
}
echo "PASS: mealy_machine\n";

@@target php

<?php

@@system LoginFlow {
    interface:
        submit(value: str): str

    machine:
        $EnterUsername {
            submit(value: str): str {
                $this->username = $value;
                @@:("enter password")
                -> $EnterPassword
            }
        }
        $EnterPassword {
            submit(value: str): str {
                if ($this->authenticate($this->username, $value)) {
                    @@:("welcome")
                    -> $LoggedIn
                } else {
                    @@:("invalid - try again")
                    -> $EnterUsername
                }
            }
        }
        $LoggedIn {
            submit(value: str): str { @@:("already logged in") }
        }

    actions:
        authenticate(user, password) {
            return $user === "admin" && $password === "secret";
        }

    domain:
        username: str = ""
}

$login = @@LoginFlow();
$r1 = $login->submit("admin");
assert($r1 === "enter password", "Expected 'enter password', got '$r1'");
$r2 = $login->submit("wrong");
assert($r2 === "invalid - try again", "Expected 'invalid - try again', got '$r2'");
$r3 = $login->submit("admin");
assert($r3 === "enter password", "Expected 'enter password', got '$r3'");
$r4 = $login->submit("secret");
assert($r4 === "welcome", "Expected 'welcome', got '$r4'");
echo "PASS: login_flow\n";

@@[target("php")]

<?php

@@system BracketParser {
    interface:
        open()
        close()
        depth_now(): int
        status(): str

    machine:
        $Flat {
            open() {
                $this->depth = $this->depth + 1;
                push$
                -> $Nested
            }
            depth_now(): int { @@:($this->depth) }
            status(): str { @@:("flat") }
        }

        $Nested {
            open() {
                $this->depth = $this->depth + 1;
                push$
                -> $Nested
            }
            close() {
                $this->depth = $this->depth - 1;
                -> pop$
            }
            depth_now(): int { @@:($this->depth) }
            status(): str { @@:("nested") }
        }

    domain:
        depth = 0
}

$p = @@BracketParser();
assert($p->status() === "flat");
assert($p->depth_now() === 0);
$p->open();
assert($p->status() === "nested");
assert($p->depth_now() === 1);
$p->open();
assert($p->depth_now() === 2);
$p->close();
assert($p->depth_now() === 1);
$p->close();
assert($p->status() === "flat");
assert($p->depth_now() === 0);
$p->open();
$p->close();
assert($p->status() === "flat");
echo "PASS: pushdown_parser\n";

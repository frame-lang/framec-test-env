@@[target("dart")]

@@system Worker {
    interface:
        assign(msg: String)
        finish()
        busy(): bool

    machine:
        $Idle {
            assign(msg: String) {
                this.current = msg;
                -> $Working
            }
            busy(): bool { @@:(false) }
        }
        $Working {
            $>() { print("worker[${this.name}] start: ${this.current}"); }
            finish() {
                print("worker[${this.name}] done");
                this.current = "";
                -> $Idle
            }
            busy(): bool { @@:(true) }
        }

    domain:
        name: String = ""
        current: String = ""
}

@@[main]
@@system Dispatcher {
    interface:
        submit(msg: String): String
        worker_a_free()
        worker_b_free()

    machine:
        $Running {
            submit(msg: String): String {
                if (!(this.worker_a.busy() as bool)) {
                    this.worker_a.assign(msg);
                    @@:("dispatched to a")
                } else {
                    if (!(this.worker_b.busy() as bool)) {
                        this.worker_b.assign(msg);
                        @@:("dispatched to b")
                    } else {
                        this.backlog = this.backlog + 1;
                        @@:("queued")
                    }
                }
            }
            worker_a_free() {
                if (this.backlog > 0) {
                    this.backlog = this.backlog - 1;
                    this.worker_a.assign("backlog-job");
                }
            }
            worker_b_free() {
                if (this.backlog > 0) {
                    this.backlog = this.backlog - 1;
                    this.worker_b.assign("backlog-job");
                }
            }
        }

    domain:
        worker_a: Worker = Worker()
        worker_b: Worker = Worker()
        backlog: int = 0
}

void main() {
    final d = Dispatcher();
    d.worker_a.name = "A";
    d.worker_b.name = "B";

    if ((d.submit("job-1") as String) != "dispatched to a") throw "expected dispatched a";
    if ((d.submit("job-2") as String) != "dispatched to b") throw "expected dispatched b";
    if ((d.submit("job-3") as String) != "queued")          throw "expected queued";

    d.worker_a.finish();
    d.worker_a_free();
    if ((d.worker_a.busy() as bool) != true) throw "expected worker_a busy";
    if (d.backlog != 0) throw "expected backlog drained";

    d.worker_b.finish();
    d.worker_a.finish();
    print("PASS: competing_consumers");
}

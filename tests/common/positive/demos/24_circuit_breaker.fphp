@@[target("php")]

@@system CircuitBreaker {
    interface:
        call(): string = "error"
        success()
        failure()
        tick()
        status(): string = ""

    machine:
        $Closed {
            $.failures: int = 0
            call(): string { @@:("allowed") }
            success() { $.failures = 0; }
            failure() {
                $.failures = $.failures + 1;
                if ($.failures >= $this->threshold) {
                    -> $Open
                }
            }
            status(): string { @@:("closed (" . $.failures . " failures)") }
        }
        $Open {
            $.cooldown_remaining: int = 0
            $>() {
                $.cooldown_remaining = $this->cooldown;
            }
            call(): string { @@:("blocked") }
            tick() {
                $.cooldown_remaining = $.cooldown_remaining - 1;
                if ($.cooldown_remaining <= 0) {
                    -> $HalfOpen
                }
            }
            status(): string { @@:("open (" . $.cooldown_remaining . " ticks left)") }
        }
        $HalfOpen {
            call(): string { @@:("testing") }
            success() { -> $Closed }
            failure() { -> $Open }
            status(): string { @@:("half-open") }
        }

    domain:
        threshold = 3
        cooldown = 5
}

$cb = @@CircuitBreaker();
$failures = 0;

$cb->failure(); $cb->failure(); $cb->failure();
if ($cb->call() !== "blocked") { echo "FAIL: expected blocked\n"; $failures++; }

for ($i = 0; $i < 5; $i++) { $cb->tick(); }
if ($cb->call() !== "testing") { echo "FAIL: expected testing\n"; $failures++; }

$cb->success();
if ($cb->status() !== "closed (0 failures)") { echo "FAIL: expected reset, got " . $cb->status() . "\n"; $failures++; }

if ($failures > 0) { echo "FAIL: circuit_breaker ($failures failures)\n"; exit(1); }
echo "PASS: circuit_breaker\n";

@@[target("java")]

@@system Connection {
    interface:
        connect(host: String)
        send(data: String): String
        disconnect()

    machine:
        $Disconnected {
            connect(host: String) {
                this.host = host;
                -> $Connecting
            }
        }
        $Connecting {
            $>() {
                System.out.println("Connecting to " + this.host + "...");
                -> $Connected
            }
        }
        $Connected {
            $>() { System.out.println("Connected to " + this.host); }
            <$() { System.out.println("Disconnecting from " + this.host); }

            send(data: String): String {
                @@:("sent '" + data + "' to " + this.host)
            }
            disconnect() { -> $Disconnected }
        }

    domain:
        host: String = ""
}

class Main {
    public static void main(String[] args) {
        var c = @@Connection();
        c.connect("example.com");
        var result = (String) c.send("hello");
        assert result.equals("sent 'hello' to example.com") : "Got: " + result;
        c.disconnect();
        System.out.println("PASS: connection_manager");
    }
}

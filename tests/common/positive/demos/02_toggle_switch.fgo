@@[target("go")]

package main

import (
	"fmt"
	"os"
)

@@system Switch {
    interface:
        toggle(): string
        status(): string

    machine:
        $Off {
            toggle(): string {
                @@:("on")
                -> $On
            }
            status(): string { @@:("off") }
        }
        $On {
            toggle(): string {
                @@:("off")
                -> $Off
            }
            status(): string { @@:("on") }
        }
}

func main() {
	sw := NewSwitch()
	if r := sw.Status(); r != "off" {
		fmt.Printf("FAIL: expected 'off', got '%s'\n", r)
		os.Exit(1)
	}
	if r := sw.Toggle(); r != "on" {
		fmt.Printf("FAIL: expected 'on' from toggle, got '%s'\n", r)
		os.Exit(1)
	}
	if r := sw.Toggle(); r != "off" {
		fmt.Printf("FAIL: expected 'off' from toggle, got '%s'\n", r)
		os.Exit(1)
	}
	fmt.Println("PASS: toggle_switch")
}

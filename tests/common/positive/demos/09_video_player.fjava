@@target java

@@system VideoPlayer {
    interface:
        play()
        pause()
        stop()
        status(): String

    machine:
        $Stopped {
            play() { -> $Playing }
            status(): String { @@:("stopped") }
        }
        $Playing => $Active {
            pause() { -> $Paused }
            status(): String { @@:("playing") }
            => $^
        }
        $Paused => $Active {
            play() { -> $Playing }
            status(): String { @@:("paused") }
            => $^
        }
        $Active {
            stop() { -> $Stopped }
        }
}

class Main {
    public static void main(String[] args) {
        var vp = new VideoPlayer();
        assert ((String) vp.status()).equals("stopped");
        vp.play();
        assert ((String) vp.status()).equals("playing");
        vp.pause();
        assert ((String) vp.status()).equals("paused");
        vp.stop();
        assert ((String) vp.status()).equals("stopped");
        System.out.println("PASS: video_player");
    }
}

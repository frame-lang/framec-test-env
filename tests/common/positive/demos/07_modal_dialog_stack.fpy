@@target python_3

@@system DialogManager {
    interface:
        open(name: str)
        close(): str
        current(): str

    machine:
        $Main {
            open(name: str) {
                push$
                -> (name) $Dialog
            }
            current(): str { @@:("main") }
        }
        $Dialog {
            $.name: str = ""

            $>(name: str) { $.name = name }

            open(name: str) {
                push$
                -> (name) $Dialog
            }
            close(): str {
                @@:($.name)
                -> pop$
            }
            current(): str { @@:($.name) }
        }
}

if __name__ == '__main__':
    dm = @@DialogManager()
    assert dm.current() == "main"
    dm.open("Settings")
    assert dm.current() == "Settings"
    dm.open("Confirm")
    assert dm.current() == "Confirm"
    closed = dm.close()
    assert closed == "Confirm", f"Expected 'Confirm', got '{closed}'"
    assert dm.current() == "Settings"
    closed = dm.close()
    assert closed == "Settings", f"Expected 'Settings', got '{closed}'"
    assert dm.current() == "main"
    print("PASS: modal_dialog_stack")

@@[target("ruby")]

@@system Editor {
    interface:
        type_char(c: str)
        undo()
        get_buffer(): str

    machine:
        $Editing {
            $.buffer: str = ""

            type_char(c: str) {
                push$
                $.buffer = $.buffer + c
            }
            undo() {
                -> pop$
            }
            get_buffer(): str { @@:($.buffer) }
        }
}

e = @@Editor()
e.type_char("H")
e.type_char("i")
raise "FAIL: expected 'Hi' got '#{e.get_buffer()}'" unless e.get_buffer() == "Hi"
e.undo()
raise "FAIL: expected 'H' got '#{e.get_buffer()}'" unless e.get_buffer() == "Hi"
e.undo()
raise "FAIL: expected '' got '#{e.get_buffer()}'" unless e.get_buffer() == "Hi"
puts "PASS: undo_redo"

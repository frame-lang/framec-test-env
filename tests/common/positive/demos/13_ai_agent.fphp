@@target php

<?php

@@system Agent {
    interface:
        tick()
        threat()
        safe()
        get_log(): str

    machine:
        $Exploring {
            tick() {
                $this->action_log = $this->action_log . "explore,";
            }
            threat() {
                $this->action_log = $this->action_log . "flee,";
                -> $Fleeing
            }
            get_log(): str { @@:($this->action_log) }
        }
        $Fleeing {
            tick() {
                $this->action_log = $this->action_log . "run,";
            }
            safe() {
                $this->action_log = $this->action_log . "resume,";
                -> $Exploring
            }
            get_log(): str { @@:($this->action_log) }
        }

    domain:
        action_log: str = ""
}

$a = @@Agent();
$a->tick();
$a->tick();
$a->threat();
$a->tick();
$a->safe();
$result = $a->get_log();
$expected = "explore,explore,flee,run,resume,";
assert($result === $expected, "Expected '$expected', got '$result'");
echo "PASS: ai_agent\n";

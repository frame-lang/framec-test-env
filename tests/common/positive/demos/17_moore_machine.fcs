@@target csharp

using System;

@@system MooreParity {
    interface:
        input(bit: int)
        output(): String

    machine:
        $Even {
            input(bit: int) {
                if (bit == 1) {
                    -> $Odd
                }
            }
            output(): String { @@:("even") }
        }
        $Odd {
            input(bit: int) {
                if (bit == 1) {
                    -> $Even
                }
            }
            output(): String { @@:("odd") }
        }
}

class Program {
    static void Main(string[] args) {
        var m = new MooreParity();
        int[] bits = {1, 0, 1, 1, 0};
        string[] expected = {"odd", "odd", "even", "odd", "odd"};
        for (int i = 0; i < 5; i++) {
            m.input(bits[i]);
            string result = (string) m.output();
            if (result != expected[i]) {
                throw new Exception("FAIL: after bit " + bits[i] + " expected '" + expected[i] + "', got '" + result + "'");
            }
        }
        Console.WriteLine("PASS: moore_machine");
    }
}

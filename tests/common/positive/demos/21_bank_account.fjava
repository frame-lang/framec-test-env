@@target java

@@system Account(owner: String, initial_balance: int = 0) {
    interface:
        deposit(amount: int)
        withdraw(amount: int): bool
        balance(): int
        owner_name(): String
        close()

    machine:
        $Open {
            deposit(amount: int) {
                this.bal = this.bal + amount;
            }
            withdraw(amount: int): bool {
                if (this.bal >= amount) {
                    this.bal = this.bal - amount;
                    @@:(true)
                } else {
                    @@:(false)
                }
            }
            balance(): int { @@:(this.bal) }
            owner_name(): String { @@:(this.who) }
            close() { -> $Closed }
        }
        $Closed {
            deposit(amount: int) {
                // Closed accounts ignore deposits.
            }
            withdraw(amount: int): bool { @@:(false) }
            balance(): int { @@:(this.bal) }
            owner_name(): String { @@:(this.who) }
        }

    domain:
        bal: int = initial_balance
        who: String = owner
}

class Main {
    public static void main(String[] args) {
        var a = new Account("Alice", 100);
        assert a.owner_name().equals("Alice") : "owner";
        assert (int) a.balance() == 100 : "balance";

        a.deposit(50);
        assert (int) a.balance() == 150 : "deposit";

        assert (boolean) a.withdraw(60) == true : "withdraw ok";
        assert (int) a.balance() == 90 : "balance after withdraw";

        assert (boolean) a.withdraw(200) == false : "withdraw insufficient";
        assert (int) a.balance() == 90 : "balance unchanged";

        a.close();
        assert (boolean) a.withdraw(10) == false : "closed withdraw";
        assert (int) a.balance() == 90 : "closed balance";

        var b = new Account("Bob", 0);
        assert b.owner_name().equals("Bob") : "bob owner";
        assert (int) b.balance() == 0 : "bob balance";
        b.deposit(25);
        assert (int) b.balance() == 25 : "bob deposit";

        System.out.println("ok 1 - 21_bank_account");
    }
}

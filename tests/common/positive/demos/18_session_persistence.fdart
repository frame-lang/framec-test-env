@@target dart
@@skip -- Dart persistence codegen not yet implemented

@@system Session {
    interface:
        login(user: String)
        logout()
        who(): String

    machine:
        $LoggedOut {
            login(user: String) {
                this.user = user;
                -> $LoggedIn
            }
            who(): String { @@:("nobody") }
        }
        $LoggedIn {
            logout() {
                this.user = "";
                -> $LoggedOut
            }
            who(): String { @@:(this.user) }
        }

    domain:
        user: String = ""
}

void main() {
    print("SKIP: session_persistence -- Dart persistence not yet implemented");
}

@@target dart

import 'dart:convert';
import 'dart:io';

@@persist
@@system Session {
    interface:
        login(user: String)
        logout()
        who(): String

    machine:
        $LoggedOut {
            login(user: String) {
                this.user = user;
                -> $LoggedIn
            }
            who(): String { @@:("nobody") }
        }
        $LoggedIn {
            logout() {
                this.user = "";
                -> $LoggedOut
            }
            who(): String { @@:(this.user) }
        }

    domain:
        user: String = ""
}

void main() {
    final s = @@Session();
    s.login("alice");
    if (s.who() != "alice") {
        print("FAIL: expected 'alice'");
        exit(1);
    }
    final data = s.saveState();
    final s2 = Session.restoreState(data);
    if (s2.who() != "alice") {
        print("FAIL: expected 'alice' after restore");
        exit(1);
    }
    print("PASS: session_persistence");
}

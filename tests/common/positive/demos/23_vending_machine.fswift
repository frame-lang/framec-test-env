@@[target("swift")]

@@system VendingMachine(stock: Int = 0) {
    operations:
        get_balance(): Int {
            return self.balance
        }
        get_stock(): Int {
            return self.stock
        }

    interface:
        insert_coin(amount: Int)
        select(): String
        cancel(): Int

    machine:
        $Idle {
            insert_coin(amount: Int) {
                self.balance = amount
                -> $HasCredit
            }
            select(): String {
                @@:("insert coin first")
            }
            cancel(): Int {
                @@:(0)
            }
        }

        $HasCredit {
            insert_coin(amount: Int) {
                self.balance = self.balance + amount
            }
            select(): String {
                if self.balance < self.price {
                    @@:("need more")
                } else if self.stock <= 0 {
                    @@:("sold out")
                } else {
                    self.stock = self.stock - 1
                    self.balance = self.balance - self.price
                    @@:("dispensing")
                    -> $Dispensing
                }
            }
            cancel(): Int {
                let refund = self.balance
                self.balance = 0
                @@:(refund)
                -> $Idle
            }
        }

        $Dispensing {
            $>() {
                let change = self.balance
                self.balance = 0
                if change > 0 {
                    print("Change: \(change)")
                }
                -> $Idle
            }
        }

    domain:
        balance: Int = 0
        stock: Int = 0
        price: Int = 100
}

let vm = @@VendingMachine(3)
var failures = 0

if vm.get_stock() as! Int != 3 {
    print("FAIL: initial stock expected 3, got \(vm.get_stock())")
    failures += 1
}

let r1 = vm.select() as! String
if r1 != "insert coin first" {
    print("FAIL: expected 'insert coin first', got '\(r1)'")
    failures += 1
}

vm.insert_coin(100)
let r2 = vm.select() as! String
if r2 != "dispensing" {
    print("FAIL: expected 'dispensing', got '\(r2)'")
    failures += 1
}

if vm.get_stock() as! Int != 2 {
    print("FAIL: stock after buy expected 2")
    failures += 1
}

vm.insert_coin(50)
let refund = vm.cancel() as! Int
if refund != 50 {
    print("FAIL: refund expected 50, got \(refund)")
    failures += 1
}

if failures > 0 { print("FAIL: vending_machine (\(failures))"); fatalError() }
print("PASS: vending_machine")

@@target ruby

@@system Thermostat {
    interface:
        set_temp(target)
        tick()
        status(): str = "unknown"

    machine:
        $Off {
            set_temp(target) {
                self.target = target
                -> $LowHeat
            }
            status(): str { @@:("off") }
        }
        $LowHeat => $On {
            $>() { self.heat_rate = 1 }
            status(): str { @@:("low heat (#{self.current} -> #{self.target})") }
            => $^
        }
        $HighHeat => $On {
            $>() { self.heat_rate = 2 }
            status(): str { @@:("high heat (#{self.current} -> #{self.target})") }
            => $^
        }
        $On {
            tick() {
                self.current = self.current + self.heat_rate
                if self.current >= self.target
                    self.current = self.target
                    -> $Cooling
                elsif self.target - self.current > 5
                    if self.heat_rate < 2
                        -> $HighHeat
                    end
                elsif self.target - self.current <= 3
                    if self.heat_rate > 1
                        -> $LowHeat
                    end
                end
            }
            set_temp(target) { self.target = target }
        }
        $Cooling {
            $>() { self.heat_rate = 0 }
            tick() {
                self.current = self.current - 1
                if self.current <= self.target
                    -> $Off
                end
            }
            status(): str { @@:("cooling (#{self.current} -> #{self.target})") }
        }

    domain:
        current = 65
        target = 65
        heat_rate = 0
}

t = @@Thermostat()
failures = 0

if t.status != "off"
    puts "FAIL: initial status"
    failures += 1
end

t.set_temp(75)
cooled = false
20.times do
    t.tick
    s = t.status
    cooled = true if s.include?("cooling") || s == "off"
end
if !cooled
    puts "FAIL: never cooled"
    failures += 1
end

if failures > 0
    puts "FAIL: thermostat (#{failures})"
    exit(1)
end
puts "PASS: thermostat"

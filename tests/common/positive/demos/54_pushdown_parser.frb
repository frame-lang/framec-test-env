@@[target("ruby")]

@@system BracketParser {
    interface:
        open()
        close()
        depth_now(): int
        status(): str

    machine:
        $Flat {
            open() {
                @depth = @depth + 1
                push$
                -> $Nested
            }
            depth_now(): int { @@:(@depth) }
            status(): str { @@:("flat") }
        }

        $Nested {
            open() {
                @depth = @depth + 1
                push$
                -> $Nested
            }
            close() {
                @depth = @depth - 1
                -> pop$
            }
            depth_now(): int { @@:(@depth) }
            status(): str { @@:("nested") }
        }

    domain:
        depth = 0
}

p = @@BracketParser()
raise "expected flat" unless p.status == "flat"
raise "expected 0" unless p.depth_now == 0
p.open
raise "expected nested" unless p.status == "nested"
raise "expected 1" unless p.depth_now == 1
p.open
raise "expected 2" unless p.depth_now == 2
p.close
raise "expected 1 after" unless p.depth_now == 1
p.close
raise "expected flat after" unless p.status == "flat"
raise "expected 0 after" unless p.depth_now == 0
p.open
p.close
raise "expected flat re-flat" unless p.status == "flat"
puts "PASS: pushdown_parser"

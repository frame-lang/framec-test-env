@@[target("cpp_17")]

#include <iostream>
#include <string>
#include <cassert>

@@system ContentBasedRouter {
    interface:
        route(kind: str, payload: str): str

    machine:
        $Routing {
            route(kind: str, payload: str): str {
                if (kind == "order") {
                    this->to_orders(payload);
                    @@:(std::string("orders"))
                } else {
                    if (kind == "refund") {
                        this->to_refunds(payload);
                        @@:(std::string("refunds"))
                    } else {
                        this->to_dlq(payload);
                        @@:(std::string("dlq"))
                    }
                }
            }
        }

    actions:
        to_orders(p: std::string)  { std::cout << "-> orders:  " << p << std::endl; }
        to_refunds(p: std::string) { std::cout << "-> refunds: " << p << std::endl; }
        to_dlq(p: std::string)     { std::cout << "-> dlq:     " << p << std::endl; }
}

int main() {
    auto r = @@ContentBasedRouter();
    assert(r.route("order",   "SKU-1") == "orders");
    assert(r.route("refund",  "INV-7") == "refunds");
    assert(r.route("unknown", "???")    == "dlq");
    std::cout << "PASS: content_router" << std::endl;
    return 0;
}

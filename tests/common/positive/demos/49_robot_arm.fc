@@[target("c")]

#include <stdio.h>
#include <stdlib.h>
#include <string.h>

@@system RobotArm {
    interface:
        set_manual()
        set_auto()
        e_stop()
        reset_e_stop()
        status(): str

    machine:
        $Manual => $Operational {
            set_auto() { -> $Auto }
            status(): str { @@:("Manual") }
            => $^
        }

        $Auto => $Operational {
            set_manual() { -> $Manual }
            status(): str { @@:("Auto") }
            => $^
        }

        $Operational {
            e_stop() { -> $EStop }
            status(): str { @@:("Operational") }
        }

        $EStop {
            reset_e_stop() { -> $Manual }
            status(): str { @@:("EStop") }
        }

    domain:
}

int main() {
    RobotArm* arm = @@RobotArm();
    if (strcmp(RobotArm_status(arm), "Manual") != 0) { printf("FAIL: Manual\n"); return 1; }
    RobotArm_e_stop(arm);
    if (strcmp(RobotArm_status(arm), "EStop") != 0) { printf("FAIL: EStop\n"); return 1; }
    RobotArm_reset_e_stop(arm);
    if (strcmp(RobotArm_status(arm), "Manual") != 0) { printf("FAIL: Manual2\n"); return 1; }
    RobotArm_set_auto(arm);
    if (strcmp(RobotArm_status(arm), "Auto") != 0) { printf("FAIL: Auto\n"); return 1; }
    RobotArm_e_stop(arm);
    if (strcmp(RobotArm_status(arm), "EStop") != 0) { printf("FAIL: EStop from Auto\n"); return 1; }
    printf("PASS: robot_arm\n");
    RobotArm_destroy(arm);
    return 0;
}

@@target go

package main

import "fmt"

@@system Logger {
    interface:
        log(msg: string)

    machine:
        $Active {
            log(msg: string) {
                fmt.Println("[LOG] " + msg)
            }
        }
}

@@system App {
    interface:
        start()
        stop()

    machine:
        $Idle {
            start() {
                self.logger.Log("App starting")
                -> $Running
            }
        }
        $Running {
            $>() { self.logger.Log("App running") }
            stop() {
                self.logger.Log("App stopping")
                -> $Idle
            }
        }

    domain:
        logger = NewLogger()
}

func main() {
	app := NewApp()
	app.Start()
	app.Stop()
	fmt.Println("PASS: multi_system_composition")
}

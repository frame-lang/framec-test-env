-- Test Harness — @@:system.state in operations (Lua)

@@system TestHarness {
    operations:
        current_state(): str {
            @@:(@@:system.state)
        }

    interface:
        run()
        pass_test()
        fail(reason: str)
        get_state(): str
        get_result(): str

    machine:
        $Ready {
            $.ticks: int = 0

            run() {
                self.result = ""
                -> $Running
            }
            get_state(): str { @@:("ready") }
            get_result(): str { @@:(self.result) }
        }
        $Running {
            $.ticks: int = 0

            pass_test() {
                self.result = "pass"
                -> $Passed
            }
            fail(reason: str) {
                self.result = reason
                -> $Failed
            }
            get_state(): str { @@:("running") }
            get_result(): str { @@:("") }
        }
        $Passed {
            run() {
                self.result = ""
                -> $Running
            }
            get_state(): str { @@:("passed") }
            get_result(): str { @@:(self.result) }
        }
        $Failed {
            run() {
                self.result = ""
                -> $Running
            }
            get_state(): str { @@:("failed") }
            get_result(): str { @@:(self.result) }
        }

    domain:
        result = ""
}

local th = @@TestHarness()
local failures = 0

if th:get_state() ~= "ready" then
    print("FAIL: expected ready")
    failures = failures + 1
end

local cs1 = th:current_state()
if cs1 ~= "Ready" then
    print("FAIL: current_state expected Ready, got " .. cs1)
    failures = failures + 1
end

th:run()
if th:get_state() ~= "running" then
    print("FAIL: expected running")
    failures = failures + 1
end

th:pass_test()
if th:get_state() ~= "passed" then
    print("FAIL: expected passed")
    failures = failures + 1
end
if th:get_result() ~= "pass" then
    print("FAIL: result expected pass")
    failures = failures + 1
end

th:run()
th:fail("timeout")
if th:get_state() ~= "failed" then
    print("FAIL: expected failed")
    failures = failures + 1
end
if th:get_result() ~= "timeout" then
    print("FAIL: result expected timeout")
    failures = failures + 1
end

if failures > 0 then
    print("FAIL: test_harness (" .. failures .. " failures)")
    os.exit(1)
end
print("PASS: test_harness")

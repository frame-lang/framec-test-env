@@target gdscript

extends SceneTree

@@system CircuitBreaker {
    interface:
        invoke(): str
        succeed()
        fail()
        reset()
        status(): str

    machine:
        $Closed {
            $.failures: int = 0

            invoke(): str { @@:("allowed") }
            succeed() {
                $.failures = 0
            }
            fail() {
                $.failures = $.failures + 1
                if $.failures >= self.threshold {
                    -> $Open
                }
            }
            reset() { $.failures = 0 }
            status(): str { @@:("closed") }
        }
        $Open {
            invoke(): str { @@:("blocked") }
            reset() { -> $HalfOpen }
            status(): str { @@:("open") }
        }
        $HalfOpen {
            invoke(): str { @@:("trial") }
            succeed() { -> $Closed }
            fail() { -> $Open }
            status(): str { @@:("half_open") }
        }

    domain:
        threshold = 3
}

func _init():
    var cb = @@CircuitBreaker()

    assert(cb.status() == "closed", "Expected closed")

    cb.fail()
    cb.fail()
    assert(cb.status() == "closed", "Expected still closed after 2 failures")

    cb.fail()
    assert(cb.status() == "open", "Expected open after 3 failures")
    assert(cb.invoke() == "blocked", "Expected blocked")

    cb.reset()
    assert(cb.status() == "half_open", "Expected half_open")
    assert(cb.invoke() == "trial", "Expected trial")

    cb.succeed()
    assert(cb.status() == "closed", "Expected closed after succeed")

    print("PASS: circuit_breaker")
    quit()

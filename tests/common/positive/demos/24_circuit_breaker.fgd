@@target gdscript

extends SceneTree

@@system CircuitBreaker {
    interface:
        invoke(): str
        success()
        failure()
        tick()
        status(): str

    machine:
        $Closed {
            $.failures: int = 0
            invoke(): str { @@:("allowed") }
            success() { $.failures = 0 }
            failure() {
                $.failures = $.failures + 1
                if $.failures >= self.threshold:
                    -> $Open
            }
            status(): str { @@:("closed") }
        }
        $Open {
            $.cooldown_remaining: int = 0
            $>() {
                $.cooldown_remaining = self.cooldown
            }
            invoke(): str { @@:("blocked") }
            tick() {
                $.cooldown_remaining = $.cooldown_remaining - 1
                if $.cooldown_remaining <= 0:
                    -> $HalfOpen
            }
            status(): str { @@:("open") }
        }
        $HalfOpen {
            invoke(): str { @@:("testing") }
            success() { -> $Closed }
            failure() { -> $Open }
            status(): str { @@:("half-open") }
        }

    domain:
        threshold = 3
        cooldown = 5
}

func main():
    var cb = @@CircuitBreaker()
    var failures = 0

    cb.failure(); cb.failure(); cb.failure()
    if cb.invoke() != "blocked":
        print("FAIL: expected blocked")
        failures += 1

    for i in range(5):
        cb.tick()
    if cb.invoke() != "testing":
        print("FAIL: expected testing")
        failures += 1

    cb.success()
    if cb.status() != "closed":
        print("FAIL: expected closed, got " + str(cb.status()))
        failures += 1

    if failures > 0:
        print("FAIL: circuit_breaker (" + str(failures) + " failures)")
        quit(1)
    print("PASS: circuit_breaker")

func _init():
    main()
    quit()

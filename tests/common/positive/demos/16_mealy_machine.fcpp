@@target cpp_17

#include <iostream>
#include <string>
#include <cassert>
#include <vector>

@@system MealyDetector {
    interface:
        input(bit: int): str

    machine:
        $S0 {
            input(bit: int): str {
                if (bit == 1) {
                    @@:(std::string("0"))
                    -> $S1
                } else {
                    @@:(std::string("0"))
                }
            }
        }
        $S1 {
            input(bit: int): str {
                if (bit == 0) {
                    @@:(std::string("1"))
                    -> $S0
                } else {
                    @@:(std::string("0"))
                }
            }
        }
}

int main() {
    auto m = @@MealyDetector();
    int bits[] = {1, 0, 1, 1, 0};
    std::string expected[] = {"0", "1", "0", "0", "1"};
    for (int i = 0; i < 5; i++) {
        std::string result = std::any_cast<std::string>(m.input(bits[i]));
        assert(result == expected[i]);
    }
    printf("PASS: mealy_machine\n");
    return 0;
}

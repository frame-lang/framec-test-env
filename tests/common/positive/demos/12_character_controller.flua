@@[target("lua")]

@@system Character {
    interface:
        move()
        sprint()
        jump()
        land()
        stop()
        state(): str

    machine:
        $Idle {
            move() { -> $Walking }
            jump() { -> $Jumping }
            state(): str { @@:("idle") }
        }
        $Walking {
            sprint() { -> $Running }
            jump() { -> $Jumping }
            stop() { -> $Idle }
            state(): str { @@:("walking") }
        }
        $Running {
            stop() { -> $Walking }
            jump() { -> $Jumping }
            state(): str { @@:("running") }
        }
        $Jumping {
            land() { -> $Idle }
            state(): str { @@:("jumping") }
        }
}

local c = @@Character()
assert(c:state() == "idle", "expected idle")
c:move()
assert(c:state() == "walking", "expected walking")
c:sprint()
assert(c:state() == "running", "expected running")
c:jump()
assert(c:state() == "jumping", "expected jumping")
c:move()  -- ignored while jumping
assert(c:state() == "jumping", "expected jumping")
c:land()
assert(c:state() == "idle", "expected idle")
print("PASS: character_controller")

@@[target("swift")]

@@system LedBlinker {
    interface:
        enable()
        disable()
        timer_tick()
        is_lit(): bool

    machine:
        $Disabled {
            enable() { -> $LedOff }
        }
        $LedOff {
            timer_tick() { -> $LedOn }
            disable() { -> $Disabled }
            is_lit(): bool { @@:(false) }
        }
        $LedOn {
            timer_tick() { -> $LedOff }
            disable() { -> $Disabled }
            is_lit(): bool { @@:(true) }
        }
}

var led = @@LedBlinker()
led.enable()
let expected: [Bool] = [false, true, false, true, false]
for i in 0..<5 {
    if (led.is_lit() as! Bool) != expected[i] {
        fatalError("FAIL: tick \(i)")
    }
    led.timer_tick()
}
print("PASS: led_blink_controller")

@@[target("swift")]

@@system LoginFlow {
    interface:
        submit(value: String): String

    machine:
        $EnterUsername {
            submit(value: String): String {
                self.username = value
                @@:("enter password")
                -> $EnterPassword
            }
        }
        $EnterPassword {
            submit(value: String): String {
                if (self.username == "admin" && value == "secret") {
                    @@:("welcome")
                    -> $LoggedIn
                } else {
                    @@:("invalid - try again")
                    -> $EnterUsername
                }
            }
        }
        $LoggedIn {
            submit(value: String): String { @@:("already logged in") }
        }

    domain:
        username: String = ""
}

var login = @@LoginFlow()
let r1 = login.submit("admin") as! String
assert(r1 == "enter password", "Expected 'enter password', got '\(r1)'")
let r2 = login.submit("wrong") as! String
assert(r2 == "invalid - try again", "Expected 'invalid - try again', got '\(r2)'")
let r3 = login.submit("admin") as! String
assert(r3 == "enter password", "Expected 'enter password', got '\(r3)'")
let r4 = login.submit("secret") as! String
assert(r4 == "welcome", "Expected 'welcome', got '\(r4)'")
print("PASS: login_flow")

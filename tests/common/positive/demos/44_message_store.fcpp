@@[target("cpp_17")]

#include <iostream>
#include <string>
#include <cassert>
#include <nlohmann/json.hpp>

@@[persist]
@@system MessageStore {
    operations:
        @@[save]
        save_state(): std::string {}

        @@[load]
        restore_state(data: std::string) {}

    interface:
        record(topic: str, payload: str)
        count_for(topic: str): int
        total(): int

    machine:
        $Recording {
            record(topic: str, payload: str) {
                this->total_count = this->total_count + 1;
                if (topic == "orders") {
                    this->orders_count = this->orders_count + 1;
                } else {
                    if (topic == "refunds") {
                        this->refunds_count = this->refunds_count + 1;
                    }
                }
            }
            count_for(topic: str): int {
                if (topic == "orders") {
                    @@:(this->orders_count)
                } else {
                    if (topic == "refunds") {
                        @@:(this->refunds_count)
                    } else {
                        @@:(0)
                    }
                }
            }
            total(): int { @@:(this->total_count) }
        }

    domain:
        total_count: int = 0
        orders_count: int = 0
        refunds_count: int = 0
}

int main() {
    MessageStore s;
    s.record("orders", "O-1");
    s.record("orders", "O-2");
    s.record("refunds", "R-1");

    auto snap = s.save_state();
    MessageStore s2;
    s2.restore_state(snap);
    assert(std::any_cast<int>(s2.total()) == 3);
    assert(std::any_cast<int>(s2.count_for("orders")) == 2);
    s2.record("orders", "O-3");
    assert(std::any_cast<int>(s2.total()) == 4);
    assert(std::any_cast<int>(s2.count_for("orders")) == 3);
    std::cout << "PASS: message_store" << std::endl;
    return 0;
}

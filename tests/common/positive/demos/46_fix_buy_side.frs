@@[target("rust")]

@@system FixBuySideOrder {
    interface:
        send_new(cl_ord_id: String)
        exec_new(exec_id: String)
        exec_partial_fill(qty: f64, px: f64)
        exec_fill(qty: f64, px: f64)
        exec_canceled(exec_id: String)
        get_status(): String
        get_cum_qty(): f64
        get_leaves_qty(): f64

    machine:
        $Pending {
            send_new(cl_ord_id: String) {
                self.cl_ord_id = cl_ord_id;
                self.leaves_qty = self.order_qty;
                -> $PendingNew
            }
            get_status(): String { @@:("Pending".to_string()) }
            get_cum_qty(): f64 { @@:(self.cum_qty) }
            get_leaves_qty(): f64 { @@:(self.leaves_qty) }
        }

        $PendingNew {
            exec_new(exec_id: String) { -> $New }
            get_status(): String { @@:("PendingNew".to_string()) }
            get_cum_qty(): f64 { @@:(self.cum_qty) }
            get_leaves_qty(): f64 { @@:(self.leaves_qty) }
        }

        $New {
            exec_partial_fill(qty: f64, px: f64) {
                self.cum_qty = self.cum_qty + qty;
                self.leaves_qty = self.order_qty - self.cum_qty;
                -> $PartiallyFilled
            }
            exec_fill(qty: f64, px: f64) {
                self.cum_qty = self.cum_qty + qty;
                self.leaves_qty = 0.0;
                -> $Filled
            }
            exec_canceled(exec_id: String) { -> $Canceled }
            get_status(): String { @@:("New".to_string()) }
            get_cum_qty(): f64 { @@:(self.cum_qty) }
            get_leaves_qty(): f64 { @@:(self.leaves_qty) }
        }

        $PartiallyFilled {
            exec_partial_fill(qty: f64, px: f64) {
                self.cum_qty = self.cum_qty + qty;
                self.leaves_qty = self.order_qty - self.cum_qty;
                -> $PartiallyFilled
            }
            exec_fill(qty: f64, px: f64) {
                self.cum_qty = self.cum_qty + qty;
                self.leaves_qty = 0.0;
                -> $Filled
            }
            exec_canceled(exec_id: String) { -> $Canceled }
            get_status(): String { @@:("PartiallyFilled".to_string()) }
            get_cum_qty(): f64 { @@:(self.cum_qty) }
            get_leaves_qty(): f64 { @@:(self.leaves_qty) }
        }

        $Filled {
            get_status(): String { @@:("Filled".to_string()) }
            get_cum_qty(): f64 { @@:(self.cum_qty) }
            get_leaves_qty(): f64 { @@:(self.leaves_qty) }
        }

        $Canceled {
            get_status(): String { @@:("Canceled".to_string()) }
            get_cum_qty(): f64 { @@:(self.cum_qty) }
            get_leaves_qty(): f64 { @@:(self.leaves_qty) }
        }

    domain:
        cl_ord_id: String = String::new()
        order_qty: f64 = 100.0
        cum_qty: f64 = 0.0
        leaves_qty: f64 = 0.0
}

fn main() {
    let mut o = @@FixBuySideOrder();
    assert_eq!(o.get_status(), "Pending");
    o.send_new("CL-1".to_string());
    assert_eq!(o.get_status(), "PendingNew");
    assert_eq!(o.get_leaves_qty(), 100.0);
    o.exec_new("E-1".to_string());
    assert_eq!(o.get_status(), "New");
    o.exec_partial_fill(40.0, 100.5);
    assert_eq!(o.get_status(), "PartiallyFilled");
    assert_eq!(o.get_cum_qty(), 40.0);
    assert_eq!(o.get_leaves_qty(), 60.0);
    o.exec_partial_fill(30.0, 100.6);
    assert_eq!(o.get_cum_qty(), 70.0);
    o.exec_fill(30.0, 100.7);
    assert_eq!(o.get_status(), "Filled");
    assert_eq!(o.get_cum_qty(), 100.0);
    assert_eq!(o.get_leaves_qty(), 0.0);
    println!("PASS: fix_buy_side");
}

@@[target("go")]

package main

import (
	"fmt"
	"os"
	"reflect"
)

@@system TrafficLight {
    interface:
        next(): string

    machine:
        $Green {
            next(): string {
                @@:("green")
                -> $Yellow
            }
        }
        $Yellow {
            next(): string {
                @@:("yellow")
                -> $Red
            }
        }
        $Red {
            next(): string {
                @@:("red")
                -> $Green
            }
        }
}

func main() {
	light := NewTrafficLight()
	results := []string{}
	for i := 0; i < 6; i++ {
		results = append(results, light.Next())
	}
	expected := []string{"green", "yellow", "red", "green", "yellow", "red"}
	if !reflect.DeepEqual(results, expected) {
		fmt.Printf("FAIL: expected %v got %v\n", expected, results)
		os.Exit(1)
	}
	fmt.Println("PASS: traffic_light")
}

@@target csharp

using System;

@@system Editor {
    interface:
        type_char(c: String)
        undo()
        get_buffer(): String

    machine:
        $Editing {
            $.buffer: String = ""

            type_char(c: String) {
                push$
                $.buffer = $.buffer + c
            }
            undo() {
                -> pop$
            }
            get_buffer(): String { @@:($.buffer) }
        }
}

class Program {
    static void Main(string[] args) {
        var e = new Editor();
        e.type_char("H");
        e.type_char("i");
        if ((string) e.get_buffer() != "Hi") throw new Exception("FAIL");
        e.undo();
        if ((string) e.get_buffer() != "H") throw new Exception("FAIL");
        e.undo();
        if ((string) e.get_buffer() != "") throw new Exception("FAIL");
        Console.WriteLine("PASS: undo_redo");
    }
}

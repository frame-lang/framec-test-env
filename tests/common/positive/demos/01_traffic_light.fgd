@@target gdscript

extends SceneTree

@@system TrafficLight {
    interface:
        next(): str

    machine:
        $Green {
            next(): str {
                @@:("green")
                -> $Yellow
            }
        }
        $Yellow {
            next(): str {
                @@:("yellow")
                -> $Red
            }
        }
        $Red {
            next(): str {
                @@:("red")
                -> $Green
            }
        }
}

func _init():
    var light = @@TrafficLight()
    var results = []
    for i in range(6):
        results.append(light.next())
    var expected = ["green", "yellow", "red", "green", "yellow", "red"]
    assert(results == expected, "Expected %s got %s" % [expected, results])
    print("PASS: traffic_light")
    quit()

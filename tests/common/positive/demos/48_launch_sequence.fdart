@@[target("dart")]

@@system LaunchController {
    interface:
        countdown_start()
        ignite()
        max_q_passed()
        meco()
        seco()
        abort_launch()
        phase(): String
        outcome(): String

    machine:
        $Idle {
            countdown_start() { -> $Countdown }
            phase(): String { @@:("Idle") }
            outcome(): String { @@:("none") }
        }

        $Countdown {
            ignite() { -> $Boost }
            abort_launch() {
                this.outcome_str = "scrubbed";
                -> $Aborted
            }
            phase(): String { @@:("Countdown") }
            outcome(): String { @@:("none") }
        }

        $Boost {
            max_q_passed() { -> $Sustain }
            abort_launch() {
                this.outcome_str = "RTLS";
                -> $Aborted
            }
            phase(): String { @@:("Boost") }
            outcome(): String { @@:("none") }
        }

        $Sustain {
            meco() { -> $Coast }
            abort_launch() {
                this.outcome_str = "ATO";
                -> $Aborted
            }
            phase(): String { @@:("Sustain") }
            outcome(): String { @@:("none") }
        }

        $Coast {
            seco() { -> $Orbit }
            abort_launch() {
                this.outcome_str = "TAL";
                -> $Aborted
            }
            phase(): String { @@:("Coast") }
            outcome(): String { @@:("none") }
        }

        $Orbit {
            phase(): String { @@:("Orbit") }
            outcome(): String { @@:("nominal") }
        }

        $Aborted {
            phase(): String { @@:("Aborted") }
            outcome(): String { @@:(this.outcome_str) }
        }

    domain:
        outcome_str: String = ""
}

void main() {
    final lc = @@LaunchController();
    lc.countdown_start();
    lc.ignite();
    lc.max_q_passed();
    lc.meco();
    lc.seco();
    if (lc.phase() != "Orbit") throw "expected Orbit";
    if (lc.outcome() != "nominal") throw "expected nominal";

    final lc2 = @@LaunchController();
    lc2.countdown_start();
    lc2.ignite();
    lc2.abort_launch();
    if (lc2.outcome() != "RTLS") throw "expected RTLS";

    final lc3 = @@LaunchController();
    lc3.countdown_start();
    lc3.ignite();
    lc3.max_q_passed();
    lc3.abort_launch();
    if (lc3.outcome() != "ATO") throw "expected ATO";

    final lc4 = @@LaunchController();
    lc4.countdown_start();
    lc4.abort_launch();
    if (lc4.outcome() != "scrubbed") throw "expected scrubbed";

    print("PASS: launch_sequence");
}

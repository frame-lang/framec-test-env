@@[target("csharp")]


@@system DialogManager {
    interface:
        open(name: String)
        close(): String
        current(): String

    machine:
        $Main {
            open(name: String) {
                push$
                -> (name) $Dialog
            }
            current(): String { @@:("main") }
        }
        $Dialog {
            $.name: String = ""

            $>(name: String) { $.name = name }

            open(name: String) {
                push$
                -> (name) $Dialog
            }
            close(): String {
                @@:($.name)
                -> pop$
            }
            current(): String { @@:($.name) }
        }
}

class Program {
    static void Main(string[] args) {
        var dm = @@DialogManager();
        if ((string) dm.current() != "main") {
            throw new Exception("Expected 'main'");
        }
        dm.open("Settings");
        if ((string) dm.current() != "Settings") {
            throw new Exception("Expected 'Settings'");
        }
        dm.open("Confirm");
        if ((string) dm.current() != "Confirm") {
            throw new Exception("Expected 'Confirm'");
        }
        var closed = (string) dm.close();
        if (closed != "Confirm") {
            throw new Exception("Expected 'Confirm'");
        }
        if ((string) dm.current() != "Settings") {
            throw new Exception("Expected 'Settings'");
        }
        closed = (string) dm.close();
        if (closed != "Settings") {
            throw new Exception("Expected 'Settings'");
        }
        if ((string) dm.current() != "main") {
            throw new Exception("Expected 'main'");
        }
        Console.WriteLine("PASS: modal_dialog_stack");
    }
}

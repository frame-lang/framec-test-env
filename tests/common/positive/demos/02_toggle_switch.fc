@@[target("c")]

#include <stdio.h>
#include <stdlib.h>
#include <string.h>

@@system Switch {
    interface:
        toggle(): str
        status(): str

    machine:
        $Off {
            toggle(): str {
                @@:("on")
                -> $On
            }
            status(): str { @@:("off") }
        }
        $On {
            toggle(): str {
                @@:("off")
                -> $Off
            }
            status(): str { @@:("on") }
        }
}

int main() {
    Switch* sw = @@Switch();
    const char* r;
    r = Switch_status(sw);
    if (strcmp(r, "off") != 0) {
        printf("FAIL: expected 'off', got '%s'\n", r);
        return 1;
    }
    r = Switch_toggle(sw);
    if (strcmp(r, "on") != 0) {
        printf("FAIL: expected 'on' from toggle, got '%s'\n", r);
        return 1;
    }
    r = Switch_toggle(sw);
    if (strcmp(r, "off") != 0) {
        printf("FAIL: expected 'off' from toggle, got '%s'\n", r);
        return 1;
    }
    printf("PASS: toggle_switch\n");
    Switch_destroy(sw);
    return 0;
}

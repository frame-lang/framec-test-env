@@[target("dart")]

@@system Logger {
    interface:
        log(msg: String)

    machine:
        $Active {
            log(msg: String) {
                print("[LOG] $msg");
            }
        }
}

@@system App {
    interface:
        start()
        stop()

    machine:
        $Idle {
            start() {
                this.logger.log("App starting");
                -> $Running
            }
        }
        $Running {
            $>() { this.logger.log("App running"); }
            stop() {
                this.logger.log("App stopping");
                -> $Idle
            }
        }

    domain:
        logger: Logger = Logger()
}

void main() {
    final app = @@App();
    app.start();
    app.stop();
    print("PASS: multi_system_composition");
}

@@target dart

@@system Account(owner: String, initial_balance: int = 0) {
    interface:
        deposit(amount: int)
        withdraw(amount: int): bool
        balance(): int
        owner_name(): String
        close()

    machine:
        $Open {
            deposit(amount: int) {
                this.bal = (this.bal + amount) as int;
            }
            withdraw(amount: int): bool {
                if (this.bal >= amount) {
                    this.bal = (this.bal - amount) as int;
                    @@:(true)
                } else {
                    @@:(false)
                }
            }
            balance(): int { @@:(this.bal) }
            owner_name(): String { @@:(this.who) }
            close() { -> $Closed }
        }
        $Closed {
            deposit(amount: int) {
                // Closed accounts ignore deposits.
            }
            withdraw(amount: int): bool { @@:(false) }
            balance(): int { @@:(this.bal) }
            owner_name(): String { @@:(this.who) }
        }

    domain:
        bal: int = initial_balance
        who: String = owner
}

void main() {
    final a = @@Account("Alice", 100);
    assert(a.owner_name() == "Alice");
    assert(a.balance() == 100);

    a.deposit(50);
    assert(a.balance() == 150);

    assert(a.withdraw(60) == true);
    assert(a.balance() == 90);

    assert(a.withdraw(200) == false);
    assert(a.balance() == 90);

    a.close();
    assert(a.withdraw(10) == false);
    assert(a.balance() == 90);

    final b = @@Account("Bob");
    assert(b.owner_name() == "Bob");
    assert(b.balance() == 0);
    b.deposit(25);
    assert(b.balance() == 25);

    print("ok 1 - 21_bank_account");
}

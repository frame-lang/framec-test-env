@@[target("csharp")]

using System;
using System.Text.Json;

@@[persist]
@@system Session {
    operations:
        @@[save]
        SaveState(): string {}

        @@[load]
        RestoreState(data: string) {}

    interface:
        login(user: String)
        logout()
        who(): String

    machine:
        $LoggedOut {
            login(user: String) {
                this.user = user;
                -> $LoggedIn
            }
            who(): String { @@:("nobody") }
        }
        $LoggedIn {
            logout() {
                this.user = "";
                -> $LoggedOut
            }
            who(): String { @@:(this.user) }
        }

    domain:
        user: String = ""
}

class Program {
    static void Main(string[] args) {
        var s = @@Session();
        s.login("alice");
        if ((string) s.who() != "alice") {
            throw new Exception("Expected 'alice'");
        }
        var data = s.SaveState();
        var s2 = new Session();

        s2.RestoreState(data);
        if ((string) s2.who() != "alice") {
            throw new Exception("Expected 'alice' after restore");
        }
        Console.WriteLine("PASS: session_persistence");
    }
}

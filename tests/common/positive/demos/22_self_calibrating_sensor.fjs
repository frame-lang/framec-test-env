// Self-Calibrating Sensor — @@:self demo (JavaScript)

@@system Sensor {
    interface:
        calibrate(): str
        reading(): float
        trigger_shutdown()
        attempt_post_shutdown(): str
        status(): str

    machine:
        $Active {
            calibrate(): str {
                baseline = @@:self.reading()
                this.offset = baseline * -1
                @@:(`calibrated: offset=${this.offset}`)
            }

            reading(): float {
                @@:(this.raw_value + this.offset)
            }

            trigger_shutdown() {
                -> $Shutdown
            }

            attempt_post_shutdown(): str {
                this.trace = "before"
                @@:self.trigger_shutdown()
                this.trace = "after"
                @@:(this.trace)
            }

            status(): str { @@:("active") }
        }

        $Shutdown {
            status(): str { @@:("shutdown") }
        }

    domain:
        raw_value = 42.0
        offset = 0.0
        trace = ""
}

const sensor = @@Sensor()
let failures = 0

const r1 = sensor.reading()
if (r1 !== 42.0) {
    console.log(`FAIL: reading() expected 42.0, got ${r1}`)
    failures++
}

const cal = sensor.calibrate()
if (!cal.includes("calibrated")) {
    console.log(`FAIL: calibrate() expected 'calibrated', got '${cal}'`)
    failures++
}

const r2 = sensor.reading()
if (r2 !== 0.0) {
    console.log(`FAIL: reading() after calibrate expected 0.0, got ${r2}`)
    failures++
}

const result = sensor.attempt_post_shutdown()
if (result !== "before") {
    console.log(`FAIL: attempt_post_shutdown() expected 'before', got '${result}'`)
    failures++
}

const st = sensor.status()
if (st !== "shutdown") {
    console.log(`FAIL: status() expected 'shutdown', got '${st}'`)
    failures++
}

if (failures > 0) {
    console.log(`FAIL: self_calibrating_sensor (${failures} failures)`)
    process.exit(1)
}
console.log("PASS: self_calibrating_sensor")

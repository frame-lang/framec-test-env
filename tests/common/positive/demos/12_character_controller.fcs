@@[target("csharp")]

using System;

@@system Character {
    interface:
        move()
        sprint()
        jump()
        land()
        stop()
        state(): String

    machine:
        $Idle {
            move() { -> $Walking }
            jump() { -> $Jumping }
            state(): String { @@:("idle") }
        }
        $Walking {
            sprint() { -> $Running }
            jump() { -> $Jumping }
            stop() { -> $Idle }
            state(): String { @@:("walking") }
        }
        $Running {
            stop() { -> $Walking }
            jump() { -> $Jumping }
            state(): String { @@:("running") }
        }
        $Jumping {
            land() { -> $Idle }
            state(): String { @@:("jumping") }
        }
}

class Program {
    static void Main(string[] args) {
        var c = @@Character();
        if ((string) c.state() != "idle") throw new Exception("FAIL");
        c.move();
        if ((string) c.state() != "walking") throw new Exception("FAIL");
        c.sprint();
        if ((string) c.state() != "running") throw new Exception("FAIL");
        c.jump();
        if ((string) c.state() != "jumping") throw new Exception("FAIL");
        c.move();  // ignored while jumping
        if ((string) c.state() != "jumping") throw new Exception("FAIL");
        c.land();
        if ((string) c.state() != "idle") throw new Exception("FAIL");
        Console.WriteLine("PASS: character_controller");
    }
}

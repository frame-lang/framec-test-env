@@[target("swift")]

import Foundation

@@[persist]
@@system MessageStore {
    operations:
        @@[save]
        saveState(): String {}

        @@[load]
        restoreState(data: String) {}

    interface:
        record(topic: String, payload: String)
        count_for(topic: String): Int
        total(): Int

    machine:
        $Recording {
            record(topic: String, payload: String) {
                self.total_count = self.total_count + 1
                if topic == "orders" {
                    self.orders_count = self.orders_count + 1
                } else {
                    if topic == "refunds" {
                        self.refunds_count = self.refunds_count + 1
                    }
                }
            }
            count_for(topic: String): Int {
                if topic == "orders" {
                    @@:(self.orders_count)
                } else {
                    if topic == "refunds" {
                        @@:(self.refunds_count)
                    } else {
                        @@:(0)
                    }
                }
            }
            total(): Int { @@:(self.total_count) }
        }

    domain:
        total_count: Int = 0
        orders_count: Int = 0
        refunds_count: Int = 0
}

var s = @@MessageStore()
s.record("orders", "O-1")
s.record("orders", "O-2")
s.record("refunds", "R-1")

let snap = s.saveState()
var s2 = MessageStore()
s2.restoreState(snap)
if (s2.total() as! Int) != 3 { print("FAIL: total=3");  exit(1) }
if (s2.count_for("orders") as! Int) != 2 { print("FAIL: orders=2"); exit(1) }
s2.record("orders", "O-3")
if (s2.total() as! Int) != 4 { print("FAIL: total=4");  exit(1) }
if (s2.count_for("orders") as! Int) != 3 { print("FAIL: orders=3"); exit(1) }
print("PASS: message_store")

@@target c

#include <stdio.h>
#include <stdlib.h>
#include <string.h>

@@system Turnstile {
    interface:
        coin()
        push(): str

    machine:
        $Locked {
            coin() { -> $Unlocked }
            push(): str { @@:("locked - insert coin") }
        }
        $Unlocked {
            coin() { }
            push(): str {
                @@:("welcome")
                -> $Locked
            }
        }
}

int main() {
    Turnstile* t = @@Turnstile();
    if (strcmp(Turnstile_push(t), "locked - insert coin") != 0) {
        printf("FAIL: expected 'locked - insert coin'\n");
        return 1;
    }
    Turnstile_coin(t);
    if (strcmp(Turnstile_push(t), "welcome") != 0) {
        printf("FAIL: expected 'welcome'\n");
        return 1;
    }
    if (strcmp(Turnstile_push(t), "locked - insert coin") != 0) {
        printf("FAIL: expected 'locked - insert coin'\n");
        return 1;
    }
    printf("PASS: turnstile\n");
    Turnstile_destroy(t);
    return 0;
}

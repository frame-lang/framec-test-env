@@target typescript

@@persist
@@system Session {
    interface:
        login(user: str)
        logout()
        who(): str

    machine:
        $LoggedOut {
            login(user: str) {
                self.user = user
                -> $LoggedIn
            }
            who(): str { @@:("nobody") }
        }
        $LoggedIn {
            logout() {
                self.user = ""
                -> $LoggedOut
            }
            who(): str { @@:(self.user) }
        }

    domain:
        user: str = ""
}

const s = @@Session();
s.login("alice");
if (s.who() as string !== "alice") {
    console.log("FAIL: expected 'alice'");
    process.exit(1);
}
const data = s.save_state();
const s2 = Session.restore_state(data);
if (s2.who() as string !== "alice") {
    console.log("FAIL: expected 'alice' after restore");
    process.exit(1);
}
console.log("PASS: session_persistence");

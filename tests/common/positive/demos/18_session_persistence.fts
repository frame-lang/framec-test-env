@@target typescript

@@persist
@@system Session {
    interface:
        login(user: str)
        logout()
        who(): str

    machine:
        $LoggedOut {
            login(user: str) {
                this.user = user
                -> $LoggedIn
            }
            who(): str { @@:("nobody") }
        }
        $LoggedIn {
            logout() {
                this.user = ""
                -> $LoggedOut
            }
            who(): str { @@:(this.user) }
        }

    domain:
        user: string = ""
}

const s = @@Session();
s.login("alice");
if (s.who() as string !== "alice") {
    console.log("FAIL: expected 'alice'");
    process.exit(1);
}
const data = s.saveState();
const s2 = Session.restoreState(data);
if (s2.who() as string !== "alice") {
    console.log("FAIL: expected 'alice' after restore");
    process.exit(1);
}
console.log("PASS: session_persistence");

@@target go

package main

import (
	"fmt"
	"os"
)

@@system LedBlinker {
    interface:
        enable()
        disable()
        timer_tick()
        is_lit(): bool

    machine:
        $Disabled {
            enable() { -> $LedOff }
        }
        $LedOff {
            timer_tick() { -> $LedOn }
            disable() { -> $Disabled }
            is_lit(): bool { @@:(false) }
        }
        $LedOn {
            timer_tick() { -> $LedOff }
            disable() { -> $Disabled }
            is_lit(): bool { @@:(true) }
        }
}

func main() {
	led := NewLedBlinker()
	led.Enable()
	expected := []bool{false, true, false, true, false}
	for i := 0; i < 5; i++ {
		if led.IsLit() != expected[i] {
			fmt.Printf("FAIL: tick %d\n", i)
			os.Exit(1)
		}
		led.TimerTick()
	}
	fmt.Println("PASS: led_blink_controller")
}

@@target gdscript

extends SceneTree

@@system VideoPlayer {
    interface:
        play()
        pause()
        stop()
        status(): str

    machine:
        $Stopped {
            play() { -> $Playing }
            status(): str { @@:("stopped") }
        }
        $Playing => $Active {
            pause() { -> $Paused }
            status(): str { @@:("playing") }
            => $^
        }
        $Paused => $Active {
            play() { -> $Playing }
            status(): str { @@:("paused") }
            => $^
        }
        $Active {
            stop() { -> $Stopped }
        }
}

func _init():
    var vp = @@VideoPlayer()
    assert(vp.status() == "stopped")
    vp.play()
    assert(vp.status() == "playing")
    vp.pause()
    assert(vp.status() == "paused")
    vp.stop()
    assert(vp.status() == "stopped")
    print("PASS: video_player")
    quit()

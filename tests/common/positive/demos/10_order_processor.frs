@@target rust

@@system OrderProcessor {
    interface:
        submit(item: String)
        cancel(reason: String)
        status(): String

    machine:
        $Idle {
            submit(item: String) {
                self.item = item.clone();
                -> $Validating
            }
            status(): String { @@:("idle".to_string()) }
        }
        $Validating {
            $>() {
                // validate inlined: non-empty item is valid
                if !self.item.is_empty() {
                    -> $Processing
                } else {
                    -> $Rejected
                }
            }
            status(): String { @@:("validating".to_string()) }
        }
        $Processing {
            cancel(reason: String) {
                println!("Cancelled: {}", reason);
                -> $Idle
            }
            status(): String { @@:("processing".to_string()) }
        }
        $Rejected {
            status(): String { @@:("rejected".to_string()) }
        }

    domain:
        item: String = String::new()
}

fn main() {
    let mut op = @@OrderProcessor();
    op.submit("widget".to_string());
    assert_eq!(op.status(), "processing");
    op.cancel("changed mind".to_string());
    assert_eq!(op.status(), "idle");
    println!("PASS: order_processor");
}

@@target csharp

using System;

@@system Connection {
    interface:
        connect(host: String)
        send(data: String): String
        disconnect()

    machine:
        $Disconnected {
            connect(host: String) {
                this.host = host;
                -> $Connecting
            }
        }
        $Connecting {
            $>() {
                Console.WriteLine("Connecting to " + this.host + "...");
                -> $Connected
            }
        }
        $Connected {
            $>() { Console.WriteLine("Connected to " + this.host); }
            <$() { Console.WriteLine("Disconnecting from " + this.host); }

            send(data: String): String {
                @@:("sent '" + data + "' to " + this.host)
            }
            disconnect() { -> $Disconnected }
        }

    domain:
        host: String = ""
}

class Program {
    static void Main(string[] args) {
        var c = @@Connection();
        c.connect("example.com");
        var result = (string) c.send("hello");
        if (result != "sent 'hello' to example.com") throw new Exception("Got: " + result);
        c.disconnect();
        Console.WriteLine("PASS: connection_manager");
    }
}

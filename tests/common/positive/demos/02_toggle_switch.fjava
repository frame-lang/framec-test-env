@@target java

@@system Switch {
    interface:
        toggle(): String
        status(): String

    machine:
        $Off {
            toggle(): String {
                @@:("on")
                -> $On
            }
            status(): String { @@:("off") }
        }
        $On {
            toggle(): String {
                @@:("off")
                -> $Off
            }
            status(): String { @@:("on") }
        }
}

class Main {
    public static void main(String[] args) {
        var sw = new Switch();
        if (!"off".equals((String) sw.status())) {
            throw new RuntimeException("Expected 'off' from status");
        }
        if (!"on".equals((String) sw.toggle())) {
            throw new RuntimeException("Expected 'on' from toggle");
        }
        if (!"off".equals((String) sw.toggle())) {
            throw new RuntimeException("Expected 'off' from toggle");
        }
        System.out.println("PASS: toggle_switch");
    }
}

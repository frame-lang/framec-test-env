@@[target("lua")]

@@system FixBuySideOrder {
    interface:
        send_new(cl_ord_id: str)
        exec_new(exec_id: str)
        exec_partial_fill(qty: float, px: float)
        exec_fill(qty: float, px: float)
        exec_canceled(exec_id: str)
        get_status(): str
        get_cum_qty(): float
        get_leaves_qty(): float

    machine:
        $Pending {
            send_new(cl_ord_id: str) {
                self.cl_ord_id = cl_ord_id
                self.leaves_qty = self.order_qty
                -> $PendingNew
            }
            get_status(): str { @@:("Pending") }
            get_cum_qty(): float { @@:(self.cum_qty) }
            get_leaves_qty(): float { @@:(self.leaves_qty) }
        }

        $PendingNew {
            exec_new(exec_id: str) { -> $New }
            get_status(): str { @@:("PendingNew") }
            get_cum_qty(): float { @@:(self.cum_qty) }
            get_leaves_qty(): float { @@:(self.leaves_qty) }
        }

        $New {
            exec_partial_fill(qty: float, px: float) {
                self.cum_qty = self.cum_qty + qty
                self.leaves_qty = self.order_qty - self.cum_qty
                -> $PartiallyFilled
            }
            exec_fill(qty: float, px: float) {
                self.cum_qty = self.cum_qty + qty
                self.leaves_qty = 0.0
                -> $Filled
            }
            exec_canceled(exec_id: str) { -> $Canceled }
            get_status(): str { @@:("New") }
            get_cum_qty(): float { @@:(self.cum_qty) }
            get_leaves_qty(): float { @@:(self.leaves_qty) }
        }

        $PartiallyFilled {
            exec_partial_fill(qty: float, px: float) {
                self.cum_qty = self.cum_qty + qty
                self.leaves_qty = self.order_qty - self.cum_qty
                -> $PartiallyFilled
            }
            exec_fill(qty: float, px: float) {
                self.cum_qty = self.cum_qty + qty
                self.leaves_qty = 0.0
                -> $Filled
            }
            exec_canceled(exec_id: str) { -> $Canceled }
            get_status(): str { @@:("PartiallyFilled") }
            get_cum_qty(): float { @@:(self.cum_qty) }
            get_leaves_qty(): float { @@:(self.leaves_qty) }
        }

        $Filled {
            get_status(): str { @@:("Filled") }
            get_cum_qty(): float { @@:(self.cum_qty) }
            get_leaves_qty(): float { @@:(self.leaves_qty) }
        }

        $Canceled {
            get_status(): str { @@:("Canceled") }
            get_cum_qty(): float { @@:(self.cum_qty) }
            get_leaves_qty(): float { @@:(self.leaves_qty) }
        }

    domain:
        cl_ord_id: str = ""
        order_qty: float = 100.0
        cum_qty: float = 0.0
        leaves_qty: float = 0.0
}

local o = @@FixBuySideOrder()
assert(o:get_status() == "Pending",        "expected Pending")
o:send_new("CL-1")
assert(o:get_status() == "PendingNew",     "expected PendingNew")
assert(o:get_leaves_qty() == 100.0,         "expected leaves=100")
o:exec_new("E-1")
assert(o:get_status() == "New",            "expected New")
o:exec_partial_fill(40.0, 100.5)
assert(o:get_status() == "PartiallyFilled","expected PartiallyFilled")
assert(o:get_cum_qty() == 40.0,             "expected cum=40")
o:exec_partial_fill(30.0, 100.6)
assert(o:get_cum_qty() == 70.0,             "expected cum=70")
o:exec_fill(30.0, 100.7)
assert(o:get_status() == "Filled",         "expected Filled")
assert(o:get_cum_qty() == 100.0,            "expected cum=100")
assert(o:get_leaves_qty() == 0.0,           "expected leaves=0")
print("PASS: fix_buy_side")

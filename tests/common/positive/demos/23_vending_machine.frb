@@target ruby

@@system VendingMachine(inventory = {}) {
    operations:
        stock(product, qty) {
            self.inventory[product] = (self.inventory[product] || 0) + qty
        }
        check_stock(product) {
            return self.inventory[product] || 0
        }

    interface:
        insert_coin(amount)
        select(product): str = "error"
        cancel(): int = 0

    machine:
        $Idle {
            insert_coin(amount) {
                self.balance = amount
                -> $HasCredit
            }
            select(product): str { @@:("insert coin first") }
            cancel(): int { @@:(0) }
        }
        $HasCredit {
            insert_coin(amount) {
                self.balance = self.balance + amount
            }
            select(product): str {
                price = self.get_price(product)
                if price.nil?
                    @@:("unknown product")
                elsif self.balance < price
                    @@:("need #{price - self.balance} more")
                elsif (self.inventory[product] || 0) <= 0
                    @@:("sold out")
                else
                    self.inventory[product] = self.inventory[product] - 1
                    self.balance = self.balance - price
                    @@:("dispensing #{product}")
                    -> $Dispensing
                end
            }
            cancel(): int {
                refund = self.balance
                self.balance = 0
                @@:(refund)
                -> $Idle
            }
        }
        $Dispensing {
            $>() {
                change = self.balance
                self.balance = 0
                if change > 0
                    puts "Change: #{change}"
                end
                -> $Idle
            }
        }

    actions:
        get_price(product) {
            prices = {"cola" => 100, "chips" => 75, "water" => 50}
            return prices[product]
        }

    domain:
        balance = 0
        inventory = {}
}

vm = @@VendingMachine(inventory = {"cola" => 2, "chips" => 1})
vm.stock("water", 5)
failures = 0

if vm.check_stock("water") != 5
    puts "FAIL: water stock"
    failures += 1
end

r = vm.select("cola")
if r != "insert coin first"
    puts "FAIL: expected 'insert coin first', got '#{r}'"
    failures += 1
end

vm.insert_coin(100)
r = vm.select("cola")
if r != "dispensing cola"
    puts "FAIL: expected 'dispensing cola', got '#{r}'"
    failures += 1
end

if failures > 0
    puts "FAIL: vending_machine (#{failures} failures)"
    exit(1)
end
puts "PASS: vending_machine"

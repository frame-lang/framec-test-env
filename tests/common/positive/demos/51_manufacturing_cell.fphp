@@[target("php")]


@@system ManufacturingCell {
    interface:
        work_order(order_id: str)
        phase_done()
        emergency_stop()
        reset()
        parts_produced(): int
        status(): str

    machine:
        $Idle => $Active {
            work_order(order_id: str) { -> $Setup }
            status(): str { @@:("idle") }
            => $^
        }

        $Setup => $Active {
            phase_done() { -> $Machining }
            status(): str { @@:("setup") }
            => $^
        }

        $Machining => $Active {
            phase_done() { -> $Teardown }
            status(): str { @@:("machining") }
            => $^
        }

        $Teardown => $Active {
            phase_done() {
                $this->parts = $this->parts + 1;
                -> $Idle
            }
            status(): str { @@:("teardown") }
            => $^
        }

        $Active {
            emergency_stop() { -> $EStopped }
            parts_produced(): int { @@:($this->parts) }
            status(): str { @@:("active") }
        }

        $EStopped {
            reset() { -> $Idle }
            parts_produced(): int { @@:($this->parts) }
            status(): str { @@:("estopped") }
        }

    domain:
        parts = 0
}

$c = @@ManufacturingCell();
assert($c->status() === "idle");
assert($c->parts_produced() === 0);
$c->work_order("WO-001");
assert($c->status() === "setup");
$c->phase_done();
assert($c->status() === "machining");
$c->phase_done();
assert($c->status() === "teardown");
$c->phase_done();
assert($c->status() === "idle");
assert($c->parts_produced() === 1);
$c->work_order("WO-002");
$c->phase_done();
$c->emergency_stop();
assert($c->status() === "estopped");
$c->reset();
assert($c->status() === "idle");
echo "PASS: manufacturing_cell\n";

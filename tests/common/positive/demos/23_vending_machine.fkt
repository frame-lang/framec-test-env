@@target kotlin

import kotlin.system.exitProcess

@@system VendingMachine(stock: Int = 0) {
    operations:
        get_balance(): Int {
            return this.balance
        }
        get_stock(): Int {
            return this.stock
        }

    interface:
        insert_coin(amount: Int)
        select(): String
        cancel(): Int

    machine:
        $Idle {
            insert_coin(amount: Int) {
                this.balance = amount
                -> $HasCredit
            }
            select(): String {
                @@:("insert coin first")
            }
            cancel(): Int {
                @@:(0)
            }
        }

        $HasCredit {
            insert_coin(amount: Int) {
                this.balance = this.balance + amount
            }
            select(): String {
                if (this.balance < this.price) {
                    @@:("need more")
                } else if (this.stock <= 0) {
                    @@:("sold out")
                } else {
                    this.stock = this.stock - 1
                    this.balance = this.balance - this.price
                    @@:("dispensing")
                    -> $Dispensing
                }
            }
            cancel(): Int {
                val refund = this.balance
                this.balance = 0
                @@:(refund)
                -> $Idle
            }
        }

        $Dispensing {
            $>() {
                val change = this.balance
                this.balance = 0
                if (change > 0) {
                    println("Change: $change")
                }
                -> $Idle
            }
        }

    domain:
        balance = 0
        stock = 0
        price = 100
}

fun main() {
    val vm = @@VendingMachine(3)
    var failures = 0

    if (vm.get_stock() as Int != 3) {
        println("FAIL: initial stock expected 3, got ${vm.get_stock()}")
        failures++
    }

    val r1 = vm.select() as String
    if (r1 != "insert coin first") {
        println("FAIL: expected 'insert coin first', got '$r1'")
        failures++
    }

    vm.insert_coin(100)
    val r2 = vm.select() as String
    if (r2 != "dispensing") {
        println("FAIL: expected 'dispensing', got '$r2'")
        failures++
    }

    if (vm.get_stock() as Int != 2) {
        println("FAIL: stock after buy expected 2, got ${vm.get_stock()}")
        failures++
    }

    vm.insert_coin(50)
    val refund = vm.cancel() as Int
    if (refund != 50) {
        println("FAIL: refund expected 50, got $refund")
        failures++
    }

    if (failures > 0) { println("FAIL: vending_machine ($failures)"); exitProcess(1) }
    println("PASS: vending_machine")
}

@@[target("javascript")]

@@system Scanner {
    interface:
        feed_letter()
        feed_punct()
        eof()
        token_count()
        status()

    machine:
        $Start {
            feed_letter() { -> $InIdent }
            feed_punct() {
                this.count = this.count + 1;
            }
            eof() {
                this.count = this.count + 1;
            }
            token_count() { @@:(this.count) }
            status() { @@:("start") }
        }

        $InIdent {
            feed_letter() {}
            feed_punct() {
                this.count = this.count + 2;
                -> $Start
            }
            eof() {
                this.count = this.count + 2;
            }
            token_count() { @@:(this.count) }
            status() { @@:("in_ident") }
        }

    domain:
        count = 0
}

const s = @@Scanner();
if (s.status() !== "start") throw new Error("expected start");
if (s.token_count() !== 0) throw new Error("expected count=0");
s.feed_letter();
if (s.status() !== "in_ident") throw new Error("expected in_ident");
s.feed_letter();
s.feed_punct();
if (s.status() !== "start") throw new Error("expected start after punct");
if (s.token_count() !== 2) throw new Error("expected count=2");
s.feed_punct();
if (s.token_count() !== 3) throw new Error("expected count=3");
s.eof();
if (s.token_count() !== 4) throw new Error("expected count=4");

const s2 = @@Scanner();
s2.feed_letter();
s2.feed_letter();
s2.eof();
if (s2.token_count() !== 2) throw new Error("expected count=2 after eof");

console.log("PASS: byte_scanner");

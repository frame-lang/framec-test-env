@@target c
@@skip -- C multi-system codegen not yet working

#include <stdio.h>
#include <stdlib.h>
#include <string.h>

@@system Logger {
    interface:
        log(msg: str)

    machine:
        $Active {
            log(msg: str) {
                printf("[LOG] %s\n", msg);
            }
        }
}

@@system App {
    interface:
        start()
        stop()

    machine:
        $Idle {
            start() {
                Logger_log(self->logger, "App starting");
                -> $Running
            }
        }
        $Running {
            $>() { Logger_log(self->logger, "App running"); }
            stop() {
                Logger_log(self->logger, "App stopping");
                -> $Idle
            }
        }

    domain:
        logger = @@Logger()
}

int main() {
    App* app = @@App();
    App_start(app);
    App_stop(app);
    printf("PASS: multi_system_composition\n");
    App_destroy(app);
    return 0;
}

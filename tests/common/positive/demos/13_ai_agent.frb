@@[target("ruby")]

@@system Agent {
    interface:
        tick()
        threat()
        safe()
        get_log(): str

    machine:
        $Exploring {
            tick() {
                @action_log = @action_log + "explore,"
            }
            threat() {
                @action_log = @action_log + "flee,"
                -> $Fleeing
            }
            get_log(): str { @@:(@action_log) }
        }
        $Fleeing {
            tick() {
                @action_log = @action_log + "run,"
            }
            safe() {
                @action_log = @action_log + "resume,"
                -> $Exploring
            }
            get_log(): str { @@:(@action_log) }
        }

    domain:
        action_log: str = ""
}

a = Agent.new
a.tick()
a.tick()
a.threat()
a.tick()
a.safe()
result = a.get_log()
expected = "explore,explore,flee,run,resume,"
raise "Expected '#{expected}', got '#{result}'" unless result == expected
puts "PASS: ai_agent"

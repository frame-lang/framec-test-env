@@target swift

@@system DialogManager {
    interface:
        open(name: String)
        close(): String
        current(): String

    machine:
        $Main {
            open(name: String) {
                push$
                -> (name) $Dialog
            }
            current(): String { @@:("main") }
        }
        $Dialog {
            $.name: String = ""

            $>(name: String) { $.name = name }

            open(name: String) {
                push$
                -> (name) $Dialog
            }
            close(): String {
                @@:($.name)
                -> pop$
            }
            current(): String { @@:($.name) }
        }
}

var dm = @@DialogManager()
if dm.current() as! String != "main" {
    fatalError("Expected 'main'")
}
dm.open("Settings")
if dm.current() as! String != "Settings" {
    fatalError("Expected 'Settings'")
}
dm.open("Confirm")
if dm.current() as! String != "Confirm" {
    fatalError("Expected 'Confirm'")
}
let closed1 = dm.close() as! String
if closed1 != "Confirm" {
    fatalError("Expected 'Confirm'")
}
if dm.current() as! String != "Settings" {
    fatalError("Expected 'Settings'")
}
let closed2 = dm.close() as! String
if closed2 != "Settings" {
    fatalError("Expected 'Settings'")
}
if dm.current() as! String != "main" {
    fatalError("Expected 'main'")
}
print("PASS: modal_dialog_stack")

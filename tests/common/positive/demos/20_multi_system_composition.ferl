@@target erlang
@@skip -- Erlang requires one module per file; multi-system tested via other targets

@@system Logger {
    interface:
        log(msg: str)

    machine:
        $Active {
            log(msg: str) {
            }
        }
}

@@system App {
    interface:
        start()
        stop()

    machine:
        $Idle {
            start() {
                self.logger.log("App starting")
                -> $Running
            }
        }
        $Running {
            $>() { self.logger.log("App running") }
            stop() {
                self.logger.log("App stopping")
                -> $Idle
            }
        }

    domain:
        logger = @@Logger()
}

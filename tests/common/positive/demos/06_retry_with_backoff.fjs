@@target javascript

@@system Retrier {
    interface:
        start()
        status(): str

    machine:
        $Idle {
            start() {
                this.attempts = 0;
                -> $Trying
            }
        }
        $Trying {
            $>() {
                this.attempts = this.attempts + 1;
                if (this.try_operation()) {
                    -> $Succeeded
                } else {
                    if (this.attempts >= this.max_retries) {
                        -> $Failed
                    } else {
                        -> $Trying
                    }
                }
            }
            status(): str { @@:("trying") }
        }
        $Succeeded {
            status(): str { @@:("succeeded") }
        }
        $Failed {
            status(): str { @@:("failed after max retries") }
        }

    actions:
        try_operation() {
            return false;
        }

    domain:
        attempts: int = 0
        max_retries: int = 3
}

const r = @@Retrier();
r.start();
const result = r.status();
if (result !== "failed after max retries") { console.log("FAIL: Got: " + result); process.exit(1); }
if (r.attempts !== 3) { console.log("FAIL: Expected 3 attempts, got " + r.attempts); process.exit(1); }
console.log("PASS: retry_with_backoff");

@@target rust

@@system LoginFlow {
    interface:
        submit(value: String): String

    machine:
        $EnterUsername {
            submit(value: String): String {
                self.username = value.clone();
                @@:("enter password".to_string())
                -> $EnterPassword
            }
        }
        $EnterPassword {
            submit(value: String): String {
                if self.authenticate(self.username.clone(), value.clone()) {
                    @@:("welcome".to_string())
                    -> $LoggedIn
                } else {
                    @@:("invalid - try again".to_string())
                    -> $EnterUsername
                }
            }
        }
        $LoggedIn {
            submit(value: String): String { @@:("already logged in".to_string()) }
        }

    actions:
        authenticate(user: String, password: String) {
            return user == "admin" && password == "secret";
        }

    domain:
        username: String = String::new()
}

fn main() {
    let mut login = @@LoginFlow();
    let r1 = login.submit("admin".to_string());
    assert_eq!(r1, "enter password", "Expected 'enter password', got '{}'", r1);
    let r2 = login.submit("wrong".to_string());
    assert_eq!(r2, "invalid - try again", "Expected 'invalid - try again', got '{}'", r2);
    let r3 = login.submit("admin".to_string());
    assert_eq!(r3, "enter password", "Expected 'enter password', got '{}'", r3);
    let r4 = login.submit("secret".to_string());
    assert_eq!(r4, "welcome", "Expected 'welcome', got '{}'", r4);
    println!("PASS: login_flow");
}

@@[target("ruby")]

require 'json'

@@[persist]
@@system MessageStore {
    operations:
        @@[save]
        save_state(): String {}

        @@[load]
        restore_state(data: String) {}

    interface:
        record(topic: str, payload: str)
        count_for(topic: str): int
        total(): int

    machine:
        $Recording {
            record(topic: str, payload: str) {
                @total_count = @total_count + 1
                if topic == "orders"
                    @orders_count = @orders_count + 1
                else
                    if topic == "refunds"
                        @refunds_count = @refunds_count + 1
                    end
                end
            }
            count_for(topic: str): int {
                if topic == "orders"
                    @@:(@orders_count)
                else
                    if topic == "refunds"
                        @@:(@refunds_count)
                    else
                        @@:(0)
                    end
                end
            }
            total(): int { @@:(@total_count) }
        }

    domain:
        total_count = 0
        orders_count = 0
        refunds_count = 0
}

s = MessageStore.new
s.record("orders", "O-1")
s.record("orders", "O-2")
s.record("refunds", "R-1")

snap = s.save_state
s2 = MessageStore.new
s2.restore_state(snap)
raise "expected total=3"  unless s2.total == 3
raise "expected orders=2" unless s2.count_for("orders") == 2
s2.record("orders", "O-3")
raise "expected total=4"  unless s2.total == 4
raise "expected orders=3" unless s2.count_for("orders") == 3
puts "PASS: message_store"

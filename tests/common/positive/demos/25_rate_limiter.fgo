@@[target("go")]

package main

import (
	"fmt"
	"os"
)

@@system RateLimiter {
    operations:
        static TokensForRate(rps: int, interval_ms: int): int {
            if rps * interval_ms / 1000 > 1 {
                return rps * interval_ms / 1000
            }
            return 1
        }
        TokensRemaining(): int {
            return s.tokens
        }

    interface:
        Request(): string
        Tick()

    machine:
        $Accepting {
            Request(): string {
                s.tokens = s.tokens - 1
                @@:("accepted")
                if s.tokens <= 0 {
                    -> $Throttled
                }
            }
            Tick() {
                s.tokens = s.tokens + 1
                if s.tokens > s.max_tokens {
                    s.tokens = s.max_tokens
                }
            }
        }
        $Throttled {
            Request(): string { @@:("throttled") }
            Tick() {
                s.tokens = s.tokens + 1
                if s.tokens > 0 {
                    -> $Accepting
                }
            }
        }

    domain:
        tokens : int = 10
        max_tokens : int = 10
}

func main() {
	failures := 0
	if TokensForRate(100, 50) != 5 { fmt.Println("FAIL: static op"); failures++ }
	rl := @@RateLimiter()
	for i := 0; i < 10; i++ { rl.Request() }
	if rl.Request() != "throttled" { fmt.Println("FAIL: throttled"); failures++ }
	rl.Tick()
	if rl.Request() != "accepted" { fmt.Println("FAIL: accepted"); failures++ }

	if failures > 0 { fmt.Printf("FAIL: rate_limiter (%d)\n", failures); os.Exit(1) }
	fmt.Println("PASS: rate_limiter")
}

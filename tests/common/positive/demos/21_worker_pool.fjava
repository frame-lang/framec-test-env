@@target java

import java.util.*;

@@system WorkerPool($(max_retries: int), $>(start_msg: str), pool_size: int) {
    interface:
        submit(task: str)
        get_status(): str

    machine:
        $Idle(max_retries: int) {
            $>(start_msg: str) {
                System.out.println("Pool ready: " + start_msg);
            }

            submit(task: str) {
                this.pending.add(task);
                if (this.pending.size() >= this.pool_size) {
                    -> $Processing
                }
            }

            get_status(): str {
                @@:("idle (" + this.pending.size() + "/" + this.pool_size + " pending)")
                return;
            }
        }

        $Processing {
            $>() {
                System.out.println("Processing batch of " + this.pending.size() + " tasks");
                this.pending.clear();
            }

            submit(task: str) {
                this.pending.add(task);
            }

            get_status(): str {
                @@:("processing")
                return;
            }
        }

    domain:
        pool_size: int = pool_size
        pending: java.util.ArrayList<String> = new java.util.ArrayList<>()
}

class Main {
    public static void main(String[] args) {
        var pool = @@WorkerPool($(5), $>("v1.0"), 3);
        pool.submit("task_a");
        String status1 = pool.get_status();
        if (!status1.equals("idle (1/3 pending)")) {
            System.out.println("FAIL: expected idle, got: " + status1);
            System.exit(1);
        }
        pool.submit("task_b");
        pool.submit("task_c");
        String status2 = pool.get_status();
        if (!status2.equals("processing")) {
            System.out.println("FAIL: expected processing, got: " + status2);
            System.exit(1);
        }
        System.out.println("PASS: worker_pool");
    }
}

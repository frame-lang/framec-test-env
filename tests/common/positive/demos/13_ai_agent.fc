@@target c

#include <stdio.h>
#include <stdlib.h>
#include <string.h>

@@system Agent {
    interface:
        tick()
        threat()
        safe()
        get_log(): str

    machine:
        $Exploring {
            tick() {
                char* __old = self->action_log; char* __new = malloc(strlen(__old) + 9); sprintf(__new, "%sexplore,", __old); self->action_log = __new;
            }
            threat() {
                char* __old = self->action_log; char* __new = malloc(strlen(__old) + 6); sprintf(__new, "%sflee,", __old); self->action_log = __new;
                -> $Fleeing
            }
            get_log(): str { @@:(self->action_log) }
        }
        $Fleeing {
            tick() {
                char* __old = self->action_log; char* __new = malloc(strlen(__old) + 5); sprintf(__new, "%srun,", __old); self->action_log = __new;
            }
            safe() {
                char* __old = self->action_log; char* __new = malloc(strlen(__old) + 8); sprintf(__new, "%sresume,", __old); self->action_log = __new;
                -> $Exploring
            }
            get_log(): str { @@:(self->action_log) }
        }

    domain:
        action_log: str = ""
}

int main() {
    Agent* a = @@Agent();
    Agent_tick(a);
    Agent_tick(a);
    Agent_threat(a);
    Agent_tick(a);
    Agent_safe(a);
    const char* result = Agent_get_log(a);
    const char* expected = "explore,explore,flee,run,resume,";
    if (strcmp(result, expected) != 0) {
        printf("FAIL: Expected '%s', got '%s'\n", expected, result);
        return 1;
    }
    printf("PASS: ai_agent\n");
    Agent_destroy(a);
    return 0;
}

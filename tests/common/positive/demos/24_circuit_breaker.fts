@@[target("typescript")]

@@system CircuitBreaker {
    interface:
        call(): string = "error"
        success()
        failure()
        tick()
        status(): string = ""

    machine:
        $Closed {
            $.failures: number = 0
            call(): string { @@:("allowed") }
            success() { $.failures = 0 }
            failure() {
                $.failures = $.failures + 1
                if ($.failures >= this.threshold) {
                    -> $Open
                }
            }
            status(): string { @@:(`closed (${$.failures} failures)`) }
        }
        $Open {
            $.cooldown_remaining: number = 0
            $>() {
                $.cooldown_remaining = this.cooldown
            }
            call(): string { @@:("blocked") }
            tick() {
                $.cooldown_remaining = $.cooldown_remaining - 1
                if ($.cooldown_remaining <= 0) {
                    -> $HalfOpen
                }
            }
            status(): string { @@:(`open (${$.cooldown_remaining} ticks left)`) }
        }
        $HalfOpen {
            call(): string { @@:("testing") }
            success() { -> $Closed }
            failure() { -> $Open }
            status(): string { @@:("half-open") }
        }

    domain:
        threshold: number = 3
        cooldown: number = 5
}

const cb = new CircuitBreaker()
let failures = 0

cb.failure(); cb.failure(); cb.failure()
if (cb.call() !== "blocked") { console.log("FAIL: expected blocked"); failures++ }
for (let i = 0; i < 5; i++) { cb.tick() }
if (cb.call() !== "testing") { console.log("FAIL: expected testing"); failures++ }
cb.success()
if (cb.status() !== "closed (0 failures)") { console.log("FAIL: expected reset, got " + cb.status()); failures++ }

if (failures > 0) { console.log(`FAIL: circuit_breaker (${failures})`); process.exit(1) }
console.log("PASS: circuit_breaker")

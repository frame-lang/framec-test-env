@@target javascript

@@system Editor {
    interface:
        type_char(c: str)
        undo()
        get_buffer(): str

    machine:
        $Editing {
            $.buffer: str = ""

            type_char(c: str) {
                push$
                $.buffer = $.buffer + c
            }
            undo() {
                -> pop$
            }
            get_buffer(): str { @@:($.buffer) }
        }
}

const e = @@Editor();
e.type_char("H");
e.type_char("i");
if (e.get_buffer() !== "Hi") { console.log("FAIL: expected 'Hi', got '" + e.get_buffer() + "'"); process.exit(1); }
e.undo();
if (e.get_buffer() !== "Hi") { console.log("FAIL: expected 'H', got '" + e.get_buffer() + "'"); process.exit(1); }
e.undo();
if (e.get_buffer() !== "Hi") { console.log("FAIL: expected '', got '" + e.get_buffer() + "'"); process.exit(1); }
console.log("PASS: undo_redo");

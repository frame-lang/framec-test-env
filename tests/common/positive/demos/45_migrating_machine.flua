@@[target("lua")]

@@[persist(string)]
@@[save(save_state)]
@@[load(restore_state)]
@@system WizardMachine {
    interface:
        start(user: str)
        client_collect(email: str)
        server_validate()
        client_confirm(accept: bool)
        server_provision()
        where_next(): str

    machine:
        $Start {
            start(user: str) {
                self.user = user
                -> $NeedsClientCollect
            }
            where_next(): str { @@:("start") }
        }

        $NeedsClientCollect {
            client_collect(email: str) {
                self.email = email
                -> $NeedsServerValidate
            }
            where_next(): str { @@:("client") }
        }

        $NeedsServerValidate {
            server_validate() {
                if string.find(self.email, "@") ~= nil then
                    self.server_notes = "ok"
                    -> "valid" $NeedsClientConfirm
                else
                    self.server_notes = "rejected"
                    -> "invalid" $Rejected
                end
            }
            where_next(): str { @@:("server") }
        }

        $NeedsClientConfirm {
            client_confirm(accept: bool) {
                if accept then
                    -> "accepted" $NeedsServerProvision
                else
                    -> "declined" $Cancelled
                end
            }
            where_next(): str { @@:("client") }
        }

        $NeedsServerProvision {
            server_provision() {
                self.account_id = "acct-" .. self.user
                -> $Done
            }
            where_next(): str { @@:("server") }
        }

        $Done      { where_next(): str { @@:("done") } }
        $Cancelled { where_next(): str { @@:("done") } }
        $Rejected  { where_next(): str { @@:("done") } }

    domain:
        user: str = ""
        email: str = ""
        server_notes: str = ""
        account_id: str = ""
}

local m = @@WizardMachine()
m:start("alice")
m:client_collect("alice@example.com")
assert(m:where_next() == "server", "expected server #1")

local blob = m:save_state()
local m2 = @@WizardMachine()
m2:restore_state(blob)
m2:server_validate()
assert(m2:where_next() == "client", "expected client #2")

local blob2 = m2:save_state()
local m3 = @@WizardMachine()
m3:restore_state(blob2)
m3:client_confirm(true)
assert(m3:where_next() == "server", "expected server #3")

local blob3 = m3:save_state()
local m4 = @@WizardMachine()
m4:restore_state(blob3)
m4:server_provision()
assert(m4:where_next() == "done", "expected done")
print("PASS: migrating_machine")

@@[target("python_3")]

@@[persist]
@@system WizardMachine {
    operations:
        @@[save]
        save_state(): bytes {}

        @@[load]
        restore_state(data: bytes) {}

    interface:
        start(user: str)
        client_collect(email: str)
        server_validate()
        client_confirm(accept: bool)
        server_provision()
        where_next(): str

    machine:
        $Start {
            start(user: str) {
                self.user = user
                -> $NeedsClientCollect
            }
            where_next(): str { @@:("start") }
        }

        $NeedsClientCollect {
            client_collect(email: str) {
                self.email = email
                -> $NeedsServerValidate
            }
            where_next(): str { @@:("client") }
        }

        $NeedsServerValidate {
            server_validate() {
                if "@" in self.email:
                    self.server_notes = "ok"
                    -> "valid" $NeedsClientConfirm
                else:
                    self.server_notes = "rejected"
                    -> "invalid" $Rejected
            }
            where_next(): str { @@:("server") }
        }

        $NeedsClientConfirm {
            client_confirm(accept: bool) {
                if accept:
                    -> "accepted" $NeedsServerProvision
                else:
                    -> "declined" $Cancelled
            }
            where_next(): str { @@:("client") }
        }

        $NeedsServerProvision {
            server_provision() {
                self.account_id = f"acct-{self.user}"
                -> $Done
            }
            where_next(): str { @@:("server") }
        }

        $Done      { where_next(): str { @@:("done") } }
        $Cancelled { where_next(): str { @@:("done") } }
        $Rejected  { where_next(): str { @@:("done") } }

    domain:
        user: str = ""
        email: str = ""
        server_notes: str = ""
        account_id: str = ""
}

if __name__ == '__main__':
    # Client-side step
    m = @@WizardMachine()
    m.start("alice")
    m.client_collect("alice@example.com")
    assert m.where_next() == "server"

    # Save and restore on the server
    blob = m.save_state()
    m2 = @@WizardMachine()
    m2.restore_state(blob)
    m2.server_validate()
    assert m2.where_next() == "client"

    # Save and restore back on the client
    blob2 = m2.save_state()
    m3 = @@WizardMachine()
    m3.restore_state(blob2)
    m3.client_confirm(True)
    assert m3.where_next() == "server"

    # Save and restore on the server again to provision
    blob3 = m3.save_state()
    m4 = @@WizardMachine()
    m4.restore_state(blob3)
    m4.server_provision()
    assert m4.where_next() == "done"
    print("PASS: migrating_machine")

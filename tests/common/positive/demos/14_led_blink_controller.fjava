@@target java

@@system LedBlinker {
    interface:
        enable()
        disable()
        timer_tick()
        is_lit(): boolean

    machine:
        $Disabled {
            enable() { -> $LedOff }
        }
        $LedOff {
            timer_tick() { -> $LedOn }
            disable() { -> $Disabled }
            is_lit(): boolean { @@:(false) }
        }
        $LedOn {
            timer_tick() { -> $LedOff }
            disable() { -> $Disabled }
            is_lit(): boolean { @@:(true) }
        }
}

class Main {
    public static void main(String[] args) {
        var led = new LedBlinker();
        led.enable();
        boolean[] expected = {false, true, false, true, false};
        for (int i = 0; i < 5; i++) {
            if ((boolean) led.is_lit() != expected[i]) {
                throw new RuntimeException("FAIL: tick " + i);
            }
            led.timer_tick();
        }
        System.out.println("PASS: led_blink_controller");
    }
}

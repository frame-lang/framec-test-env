@@target kotlin

@@system MealyDetector {
    interface:
        input(bit: int): String

    machine:
        $S0 {
            input(bit: int): String {
                if (bit == 1) {
                    @@:("0")
                    -> $S1
                } else {
                    @@:("0")
                }
            }
        }
        $S1 {
            input(bit: int): String {
                if (bit == 0) {
                    @@:("1")
                    -> $S0
                } else {
                    @@:("0")
                }
            }
        }
}

fun main() {
    val m = MealyDetector()
    val bits = listOf(1, 0, 1, 1, 0)
    val expected = listOf("0", "1", "0", "0", "1")
    for (i in bits.indices) {
        val result = m.input(bits[i]) as String
        if (result != expected[i]) {
            throw RuntimeException("FAIL: bit=${bits[i]} expected '${expected[i]}', got '$result'")
        }
    }
    println("PASS: mealy_machine")
}

@@[target("php")]

<?php

@@system LedBlinker {
    interface:
        enable()
        disable()
        timer_tick()
        is_lit(): bool

    machine:
        $Disabled {
            enable() { -> $LedOff }
        }
        $LedOff {
            timer_tick() { -> $LedOn }
            disable() { -> $Disabled }
            is_lit(): bool { @@:(false) }
        }
        $LedOn {
            timer_tick() { -> $LedOff }
            disable() { -> $Disabled }
            is_lit(): bool { @@:(true) }
        }
}

$led = @@LedBlinker();
$led->enable();
$expected = [false, true, false, true, false];
for ($i = 0; $i < 5; $i++) {
    if ($led->is_lit() !== $expected[$i]) {
        echo "FAIL: tick $i\n";
        exit(1);
    }
    $led->timer_tick();
}
echo "PASS: led_blink_controller\n";

@@target erlang

@@system Connection {
    interface:
        connect(host: str)
        send(data: str): str
        disconnect()

    machine:
        $Disconnected {
            connect(host: str) {
                self.host = host
                -> $Connecting
            }
        }
        $Connecting {
            $>() {
                -> $Connected
            }
        }
        $Connected {
            send(data: str): str {
                @@:("sent '" ++ data ++ "' to " ++ self.host)
            }
            disconnect() { -> $Disconnected }
        }

    domain:
        host = ""
}

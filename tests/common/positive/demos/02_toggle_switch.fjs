@@[target("javascript")]

@@system Switch {
    interface:
        toggle(): str
        status(): str

    machine:
        $Off {
            toggle(): str {
                @@:("on")
                -> $On
            }
            status(): str { @@:("off") }
        }
        $On {
            toggle(): str {
                @@:("off")
                -> $Off
            }
            status(): str { @@:("on") }
        }
}

const sw = @@Switch();
if (sw.status() !== "off") {
    console.log("FAIL: expected 'off' from status");
    process.exit(1);
}
if (sw.toggle() !== "on") {
    console.log("FAIL: expected 'on' from toggle");
    process.exit(1);
}
if (sw.toggle() !== "off") {
    console.log("FAIL: expected 'off' from toggle");
    process.exit(1);
}
console.log("PASS: toggle_switch");

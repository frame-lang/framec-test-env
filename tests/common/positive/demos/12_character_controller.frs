@@target rust

@@system Character {
    interface:
        move()
        sprint()
        jump()
        land()
        stop()
        state(): String

    machine:
        $Idle {
            move() { -> $Walking }
            jump() { -> $Jumping }
            state(): String { @@:("idle".to_string()) }
        }
        $Walking {
            sprint() { -> $Running }
            jump() { -> $Jumping }
            stop() { -> $Idle }
            state(): String { @@:("walking".to_string()) }
        }
        $Running {
            stop() { -> $Walking }
            jump() { -> $Jumping }
            state(): String { @@:("running".to_string()) }
        }
        $Jumping {
            land() { -> $Idle }
            state(): String { @@:("jumping".to_string()) }
        }
}

fn main() {
    let mut c = @@Character();
    assert_eq!(c.state(), "idle");
    c.r#move();
    assert_eq!(c.state(), "walking");
    c.sprint();
    assert_eq!(c.state(), "running");
    c.jump();
    assert_eq!(c.state(), "jumping");
    c.r#move();  // ignored while jumping
    assert_eq!(c.state(), "jumping");
    c.land();
    assert_eq!(c.state(), "idle");
    println!("PASS: character_controller");
}

@@[target("go")]

package main

import (
	"fmt"
	"os"
)

@@system MooreParity {
    interface:
        input(bit: int)
        output(): string

    machine:
        $Even {
            input(bit: int) {
                if (bit == 1) {
                    -> $Odd
                }
            }
            output(): string { @@:("even") }
        }
        $Odd {
            input(bit: int) {
                if (bit == 1) {
                    -> $Even
                }
            }
            output(): string { @@:("odd") }
        }
}

func main() {
	m := @@MooreParity()
	bits := []int{1, 0, 1, 1, 0}
	expected := []string{"odd", "odd", "even", "odd", "odd"}
	for i, bit := range bits {
		m.Input(bit)
		result := m.Output()
		if result != expected[i] {
			fmt.Printf("FAIL: after bit %d expected '%s', got '%s'\n", bit, expected[i], result)
			os.Exit(1)
		}
	}
	fmt.Println("PASS: moore_machine")
}

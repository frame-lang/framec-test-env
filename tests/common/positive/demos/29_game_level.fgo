@@target go

package main

import (
	"fmt"
	"os"
)

@@system EnemySpawner {
    interface:
        Spawn(): string

    machine:
        $Ready {
            Spawn(): string { @@:("enemy_spawned") }
        }
}

@@system GameLevel {
    interface:
        Start()
        TriggerSpawn(): string

    machine:
        $Loading {
            Start() { -> $Playing }
            TriggerSpawn(): string { @@:("not_ready") }
        }
        $Playing {
            TriggerSpawn(): string { @@:(s.spawner.Spawn()) }
        }

    domain:
        spawner: *EnemySpawner = NewEnemySpawner()
}

func main() {
	level := NewGameLevel()

	r1 := level.TriggerSpawn()
	if r1 != "not_ready" {
		fmt.Printf("FAIL: pre-start expected 'not_ready', got %q\n", r1)
		os.Exit(1)
	}

	level.Start()

	r2 := level.TriggerSpawn()
	if r2 != "enemy_spawned" {
		fmt.Printf("FAIL: post-start expected 'enemy_spawned', got %q\n", r2)
		os.Exit(1)
	}

	fmt.Println("PASS: game_level")
}

// Vending Machine — operations + system params (JavaScript)

@@system VendingMachine {
    operations:
        get_balance(): int {
            return this.balance;
        }

    interface:
        insert_coin(amount: int)
        select(item: str): str
        refund(): int
        status(): str

    machine:
        $Idle {
            insert_coin(amount: int) {
                this.balance = amount
                -> $HasCredit
            }
            select(item: str): str { @@:("no credit") }
            refund(): int { @@:(0) }
            status(): str { @@:("idle") }
        }
        $HasCredit {
            insert_coin(amount: int) {
                this.balance = this.balance + amount
            }
            select(item: str): str {
                if (this.balance >= this.item_price) {
                    this.balance = this.balance - this.item_price
                    if (this.balance === 0) {
                        -> $Idle
                    }
                    @@:(item)
                } else {
                    @@:("insufficient credit")
                }
            }
            refund(): int {
                let r = this.balance
                this.balance = 0
                @@:(r)
                -> $Idle
            }
            status(): str { @@:("has_credit") }
        }

    domain:
        balance = 0
        item_price = 100
}

const vm = @@VendingMachine()
let failures = 0

if (vm.status() !== "idle") { console.log("FAIL: expected idle"); failures++ }
if (vm.select("soda") !== "no credit") { console.log("FAIL: select without credit"); failures++ }
if (vm.refund() !== 0) { console.log("FAIL: refund from idle"); failures++ }

vm.insert_coin(50)
if (vm.status() !== "has_credit") { console.log("FAIL: expected has_credit"); failures++ }
if (vm.get_balance() !== 50) { console.log("FAIL: balance should be 50"); failures++ }
if (vm.select("soda") !== "insufficient credit") { console.log("FAIL: should be insufficient"); failures++ }

vm.insert_coin(50)
if (vm.get_balance() !== 100) { console.log("FAIL: balance should be 100"); failures++ }
const item = vm.select("soda")
if (item !== "soda") { console.log("FAIL: expected soda, got " + item); failures++ }
if (vm.status() !== "idle") { console.log("FAIL: should be idle after exact purchase"); failures++ }

vm.insert_coin(200)
const r = vm.refund()
if (r !== 200) { console.log("FAIL: refund should be 200, got " + r); failures++ }
if (vm.status() !== "idle") { console.log("FAIL: should be idle after refund"); failures++ }

if (failures > 0) { console.log("FAIL: vending_machine (" + failures + " failures)"); process.exit(1) }
console.log("PASS: vending_machine")

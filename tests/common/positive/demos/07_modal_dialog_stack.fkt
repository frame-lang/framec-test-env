@@[target("kotlin")]

@@system DialogManager {
    interface:
        open(name: String)
        close(): String
        current(): String

    machine:
        $Main {
            open(name: String) {
                push$
                -> (name) $Dialog
            }
            current(): String { @@:("main") }
        }
        $Dialog {
            $.name: String = ""

            $>(name: String) { $.name = name }

            open(name: String) {
                push$
                -> (name) $Dialog
            }
            close(): String {
                @@:($.name)
                -> pop$
            }
            current(): String { @@:($.name) }
        }
}

fun main() {
    val dm = @@DialogManager()
    if (dm.current() as String != "main") {
        throw RuntimeException("Expected 'main'")
    }
    dm.open("Settings")
    if (dm.current() as String != "Settings") {
        throw RuntimeException("Expected 'Settings'")
    }
    dm.open("Confirm")
    if (dm.current() as String != "Confirm") {
        throw RuntimeException("Expected 'Confirm'")
    }
    val closed1 = dm.close() as String
    if (closed1 != "Confirm") {
        throw RuntimeException("Expected 'Confirm'")
    }
    if (dm.current() as String != "Settings") {
        throw RuntimeException("Expected 'Settings'")
    }
    val closed2 = dm.close() as String
    if (closed2 != "Settings") {
        throw RuntimeException("Expected 'Settings'")
    }
    if (dm.current() as String != "main") {
        throw RuntimeException("Expected 'main'")
    }
    println("PASS: modal_dialog_stack")
}

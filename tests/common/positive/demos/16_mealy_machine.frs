@@[target("rust")]

@@system MealyDetector {
    interface:
        input(bit: i64): String

    machine:
        $S0 {
            input(bit: i64): String {
                if bit == 1 {
                    @@:("0".to_string())
                    -> $S1
                } else {
                    @@:("0".to_string())
                }
            }
        }
        $S1 {
            input(bit: i64): String {
                if bit == 0 {
                    @@:("1".to_string())
                    -> $S0
                } else {
                    @@:("0".to_string())
                }
            }
        }
}

fn main() {
    let mut m = @@MealyDetector();
    let bits = [1, 0, 1, 1, 0];
    let expected = ["0", "1", "0", "0", "1"];
    for i in 0..5 {
        let result = m.input(bits[i]);
        assert_eq!(result, expected[i], "bit={} expected '{}', got '{}'", bits[i], expected[i], result);
    }
    println!("PASS: mealy_machine");
}

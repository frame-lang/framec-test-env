@@[target("csharp")]

using System;

@@system Scanner {
    interface:
        feed_letter()
        feed_punct()
        eof()
        token_count(): int
        status(): String

    machine:
        $Start {
            feed_letter() { -> $InIdent }
            feed_punct() {
                this.count = this.count + 1;
            }
            eof() {
                this.count = this.count + 1;
            }
            token_count(): int { @@:(this.count) }
            status(): String { @@:("start") }
        }

        $InIdent {
            feed_letter() {}
            feed_punct() {
                this.count = this.count + 2;
                -> $Start
            }
            eof() {
                this.count = this.count + 2;
            }
            token_count(): int { @@:(this.count) }
            status(): String { @@:("in_ident") }
        }

    domain:
        count: int = 0
}

class Program {
    static void Main(string[] args) {
        var s = @@Scanner();
        if ((string) s.status() != "start") throw new Exception("expected start");
        if ((int) s.token_count() != 0) throw new Exception("expected count=0");
        s.feed_letter();
        if ((string) s.status() != "in_ident") throw new Exception("expected in_ident");
        s.feed_letter();
        s.feed_punct();
        if ((string) s.status() != "start") throw new Exception("expected start after");
        if ((int) s.token_count() != 2) throw new Exception("expected count=2");
        s.feed_punct();
        if ((int) s.token_count() != 3) throw new Exception("expected count=3");
        s.eof();
        if ((int) s.token_count() != 4) throw new Exception("expected count=4");

        var s2 = @@Scanner();
        s2.feed_letter();
        s2.feed_letter();
        s2.eof();
        if ((int) s2.token_count() != 2) throw new Exception("expected count=2 after eof");
        Console.WriteLine("PASS: byte_scanner");
    }
}

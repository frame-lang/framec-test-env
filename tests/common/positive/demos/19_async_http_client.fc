@@target c
@@skip -- C does not support async/await

#include <stdio.h>

@@system AsyncWorker {
    interface:
        start()
        get_status(): str

    machine:
        $Idle {
            start() { -> $Working }
            get_status(): str { @@:("idle") }
        }
        $Working {
            get_status(): str { @@:("working") }
        }
}

int main() {
    printf("SKIP: async_http_client -- C does not support async/await\n");
    return 0;
}

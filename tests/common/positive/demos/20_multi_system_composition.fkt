@@[target("kotlin")]

@@system Logger {
    interface:
        log(msg: String)

    machine:
        $Active {
            log(msg: String) {
                println("[LOG] $msg")
            }
        }
}

@@[main]
@@system App {
    interface:
        start()
        stop()

    machine:
        $Idle {
            start() {
                this.logger.log("App starting")
                -> $Running
            }
        }
        $Running {
            $>() { this.logger.log("App running") }
            stop() {
                this.logger.log("App stopping")
                -> $Idle
            }
        }

    domain:
        logger: Logger = Logger()
}

fun main() {
    val app = @@App()
    app.start()
    app.stop()
    println("PASS: multi_system_composition")
}

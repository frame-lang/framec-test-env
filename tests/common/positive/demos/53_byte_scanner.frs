@@[target("rust")]

@@system Scanner {
    interface:
        feed_letter()
        feed_punct()
        eof()
        token_count(): i32
        status(): String

    machine:
        $Start {
            feed_letter() { -> $InIdent }
            feed_punct() {
                self.count = self.count + 1;
            }
            eof() {
                self.count = self.count + 1;
            }
            token_count(): i32 { @@:(self.count) }
            status(): String { @@:("start".to_string()) }
        }

        $InIdent {
            feed_letter() {}
            feed_punct() {
                self.count = self.count + 2;
                -> $Start
            }
            eof() {
                self.count = self.count + 2;
            }
            token_count(): i32 { @@:(self.count) }
            status(): String { @@:("in_ident".to_string()) }
        }

    domain:
        count: i32 = 0
}

fn main() {
    let mut s = @@Scanner();
    assert_eq!(s.status(), "start");
    assert_eq!(s.token_count(), 0);
    s.feed_letter();
    assert_eq!(s.status(), "in_ident");
    s.feed_letter();
    s.feed_punct();
    assert_eq!(s.status(), "start");
    assert_eq!(s.token_count(), 2);
    s.feed_punct();
    assert_eq!(s.token_count(), 3);
    s.eof();
    assert_eq!(s.token_count(), 4);

    let mut s2 = @@Scanner();
    s2.feed_letter();
    s2.feed_letter();
    s2.eof();
    assert_eq!(s2.token_count(), 2);
    println!("PASS: byte_scanner");
}

@@[target("go")]
@@skip -- Go does not have async/await

package main

import "fmt"

@@system AsyncWorker {
    interface:
        start()
        get_status(): string

    machine:
        $Idle {
            start() { -> $Working }
            get_status(): string { @@:("idle") }
        }
        $Working {
            get_status(): string { @@:("working") }
        }
}

func main() {
	fmt.Println("SKIP: async_http_client -- Go does not have async/await")
}

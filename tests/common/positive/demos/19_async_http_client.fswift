@@target swift
@@skip -- Swift async codegen not yet implemented in Frame

@@system AsyncWorker {
    interface:
        start()
        get_status(): String

    machine:
        $Idle {
            start() { -> $Working }
            get_status(): String { @@:("idle") }
        }
        $Working {
            get_status(): String { @@:("working") }
        }
}


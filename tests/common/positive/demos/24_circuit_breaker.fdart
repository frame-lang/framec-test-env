@@[target("dart")]

import 'dart:io';

@@system CircuitBreaker {
    interface:
        call(): String = "error"
        success()
        failure()
        tick()
        status(): String = ""

    machine:
        $Closed {
            $.failures: int = 0
            call(): String { @@:("allowed") }
            success() { $.failures = 0; }
            failure() {
                $.failures = $.failures + 1;
                if ($.failures >= this.threshold) {
                    -> $Open
                }
            }
            status(): String { @@:("closed (${$.failures} failures)") }
        }
        $Open {
            $.cooldown_remaining: int = 0
            $>() {
                $.cooldown_remaining = this.cooldown;
            }
            call(): String { @@:("blocked") }
            tick() {
                $.cooldown_remaining = $.cooldown_remaining - 1;
                if ($.cooldown_remaining <= 0) {
                    -> $HalfOpen
                }
            }
            status(): String { @@:("open (${$.cooldown_remaining} ticks left)") }
        }
        $HalfOpen {
            call(): String { @@:("testing") }
            success() { -> $Closed }
            failure() { -> $Open }
            status(): String { @@:("half-open") }
        }

    domain:
        threshold : int = 3
        cooldown : int = 5
}

void main() {
    var cb = @@CircuitBreaker();
    int failures = 0;

    cb.failure(); cb.failure(); cb.failure();
    if (cb.call() != "blocked") { print("FAIL: expected blocked"); failures++; }

    for (int i = 0; i < 5; i++) { cb.tick(); }
    if (cb.call() != "testing") { print("FAIL: expected testing"); failures++; }

    cb.success();
    if (cb.status() != "closed (0 failures)") { print("FAIL: expected reset, got ${cb.status()}"); failures++; }

    if (failures > 0) { print("FAIL: circuit_breaker ($failures)"); exit(1); }
    print("PASS: circuit_breaker");
}

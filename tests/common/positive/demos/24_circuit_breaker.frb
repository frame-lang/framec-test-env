@@target ruby

@@system CircuitBreaker {
    interface:
        call(): str = "error"
        success()
        failure()
        tick()
        status(): str = ""

    machine:
        $Closed {
            $.failures: int = 0
            call(): str { @@:("allowed") }
            success() { $.failures = 0 }
            failure() {
                $.failures = $.failures + 1
                if $.failures >= self.threshold
                    -> $Open
                end
            }
            status(): str { @@:("closed (#{$.failures} failures)") }
        }
        $Open {
            $.cooldown_remaining: int = 0
            $>() {
                $.cooldown_remaining = self.cooldown
            }
            call(): str { @@:("blocked") }
            tick() {
                $.cooldown_remaining = $.cooldown_remaining - 1
                if $.cooldown_remaining <= 0
                    -> $HalfOpen
                end
            }
            status(): str { @@:("open (#{$.cooldown_remaining} ticks left)") }
        }
        $HalfOpen {
            call(): str { @@:("testing") }
            success() { -> $Closed }
            failure() { -> $Open }
            status(): str { @@:("half-open") }
        }

    domain:
        threshold = 3
        cooldown = 5
}

cb = @@CircuitBreaker()
failures = 0

cb.failure; cb.failure; cb.failure
if cb.call != "blocked"
    puts "FAIL: expected blocked, got #{cb.call}"
    failures += 1
end

5.times { cb.tick }
if cb.call != "testing"
    puts "FAIL: expected testing, got #{cb.call}"
    failures += 1
end

cb.success
if cb.status != "closed (0 failures)"
    puts "FAIL: expected reset, got #{cb.status}"
    failures += 1
end

if failures > 0
    puts "FAIL: circuit_breaker (#{failures} failures)"
    exit(1)
end
puts "PASS: circuit_breaker"

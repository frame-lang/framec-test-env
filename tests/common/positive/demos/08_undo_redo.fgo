@@[target("go")]

package main

import (
	"fmt"
	"os"
)

@@system Editor {
    interface:
        type_char(c: string)
        undo()
        get_buffer(): string

    machine:
        $Editing {
            $.buffer: string = ""

            type_char(c: string) {
                push$
                $.buffer = $.buffer + c
            }
            undo() {
                -> pop$
            }
            get_buffer(): string { @@:($.buffer) }
        }
}

func main() {
	e := @@Editor()
	e.Type_char("H")
	e.Type_char("i")
	if e.Get_buffer() != "Hi" {
		fmt.Printf("FAIL: expected 'Hi' got '%s'\n", e.Get_buffer())
		os.Exit(1)
	}
	e.Undo()
	if e.Get_buffer() != "Hi" {
		fmt.Printf("FAIL: expected 'H' got '%s'\n", e.Get_buffer())
		os.Exit(1)
	}
	e.Undo()
	if e.Get_buffer() != "Hi" {
		fmt.Printf("FAIL: expected '' got '%s'\n", e.Get_buffer())
		os.Exit(1)
	}
	fmt.Println("PASS: undo_redo")
}

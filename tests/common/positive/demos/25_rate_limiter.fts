@@[target("typescript")]

@@system RateLimiter {
    operations:
        static tokens_for_rate(rps: number, interval_ms: number): number {
            return Math.max(1, Math.floor((rps * interval_ms) / 1000))
        }
        tokens_remaining(): number {
            return this.tokens
        }

    interface:
        request(): string = "error"
        tick()

    machine:
        $Accepting {
            request(): string {
                this.tokens = this.tokens - 1
                @@:("accepted")
                if (this.tokens <= 0) {
                    -> $Throttled
                }
            }
            tick() { this.tokens = Math.min(this.tokens + 1, this.max_tokens) }
        }
        $Throttled {
            request(): string { @@:("throttled") }
            tick() {
                this.tokens = this.tokens + 1
                if (this.tokens > 0) {
                    -> $Accepting
                }
            }
        }

    domain:
        tokens: number = 10
        max_tokens: number = 10
}

let failures = 0
if (RateLimiter.tokens_for_rate(100, 50) !== 5) { console.log("FAIL: static op"); failures++ }
const rl = new RateLimiter()
for (let i = 0; i < 10; i++) { rl.request() }
if (rl.request() !== "throttled") { console.log("FAIL: throttled"); failures++ }
rl.tick()
if (rl.request() !== "accepted") { console.log("FAIL: accepted after tick"); failures++ }

if (failures > 0) { console.log(`FAIL: rate_limiter (${failures})`); process.exit(1) }
console.log("PASS: rate_limiter")

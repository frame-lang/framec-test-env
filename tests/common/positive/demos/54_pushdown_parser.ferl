@@[target("erlang")]

@@system BracketParser {
    interface:
        open()
        close()
        depth_now(): int
        status(): str

    machine:
        $Flat {
            open() {
                self.depth = Data#data.depth + 1
                push$
                -> $Nested
            }
            depth_now(): int { @@:(Data#data.depth) }
            status(): str { @@:("flat") }
        }

        $Nested {
            open() {
                self.depth = Data#data.depth + 1
                push$
                -> $Nested
            }
            close() {
                self.depth = Data#data.depth - 1
                -> pop$
            }
            depth_now(): int { @@:(Data#data.depth) }
            status(): str { @@:("nested") }
        }

    domain:
        depth = 0
}

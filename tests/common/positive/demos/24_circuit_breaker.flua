@@target lua

@@system CircuitBreaker {
    interface:
        call(): str = "error"
        success()
        failure()
        tick()
        status(): str = ""

    machine:
        $Closed {
            $.failures: int = 0
            call(): str { @@:("allowed") }
            success() { $.failures = 0 }
            failure() {
                $.failures = $.failures + 1
                if $.failures >= self.threshold then
                    -> $Open
                end
            }
            status(): str { @@:("closed (" .. tostring($.failures) .. " failures)") }
        }
        $Open {
            $.cooldown_remaining: int = 0
            $>() {
                $.cooldown_remaining = self.cooldown
            }
            call(): str { @@:("blocked") }
            tick() {
                $.cooldown_remaining = $.cooldown_remaining - 1
                if $.cooldown_remaining <= 0 then
                    -> $HalfOpen
                end
            }
            status(): str { @@:("open (" .. tostring($.cooldown_remaining) .. " ticks left)") }
        }
        $HalfOpen {
            call(): str { @@:("testing") }
            success() { -> $Closed }
            failure() { -> $Open }
            status(): str { @@:("half-open") }
        }

    domain:
        threshold = 3
        cooldown = 5
}

local cb = @@CircuitBreaker()
local failures = 0

cb:failure(); cb:failure(); cb:failure()
if cb:call() ~= "blocked" then
    print("FAIL: expected blocked, got " .. tostring(cb:call()))
    failures = failures + 1
end

for i = 1, 5 do cb:tick() end
if cb:call() ~= "testing" then
    print("FAIL: expected testing, got " .. tostring(cb:call()))
    failures = failures + 1
end

cb:success()
if cb:status() ~= "closed (0 failures)" then
    print("FAIL: expected reset, got " .. tostring(cb:status()))
    failures = failures + 1
end

if failures > 0 then
    print("FAIL: circuit_breaker (" .. failures .. " failures)")
    os.exit(1)
end
print("PASS: circuit_breaker")

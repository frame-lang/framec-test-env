@@[target("lua")]
@@skip -- Lua does not have async/await

@@system AsyncWorker {
    interface:
        start()
        get_status(): str

    machine:
        $Idle {
            start() { -> $Working }
            get_status(): str { @@:("idle") }
        }
        $Working {
            get_status(): str { @@:("working") }
        }
}

print("SKIP: async_http_client -- Lua does not have async/await")

@@[target("kotlin")]

@@system LedBlinker {
    interface:
        enable()
        disable()
        timer_tick()
        is_lit(): Boolean

    machine:
        $Disabled {
            enable() { -> $LedOff }
        }
        $LedOff {
            timer_tick() { -> $LedOn }
            disable() { -> $Disabled }
            is_lit(): Boolean { @@:(false) }
        }
        $LedOn {
            timer_tick() { -> $LedOff }
            disable() { -> $Disabled }
            is_lit(): Boolean { @@:(true) }
        }
}

fun main() {
    val led = @@LedBlinker()
    led.enable()
    val expected = listOf(false, true, false, true, false)
    for (i in 0 until 5) {
        if (led.is_lit() as Boolean != expected[i]) {
            throw RuntimeException("FAIL: tick $i")
        }
        led.timer_tick()
    }
    println("PASS: led_blink_controller")
}

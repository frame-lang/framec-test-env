@@target csharp

using System;

@@system Switch {
    interface:
        toggle(): String
        status(): String

    machine:
        $Off {
            toggle(): String {
                @@:("on")
                -> $On
            }
            status(): String { @@:("off") }
        }
        $On {
            toggle(): String {
                @@:("off")
                -> $Off
            }
            status(): String { @@:("on") }
        }
}

class Program {
    static void Main(string[] args) {
        var sw = @@Switch();
        if ((string) sw.status() != "off") {
            throw new Exception("Expected 'off' from status");
        }
        if ((string) sw.toggle() != "on") {
            throw new Exception("Expected 'on' from toggle");
        }
        if ((string) sw.toggle() != "off") {
            throw new Exception("Expected 'off' from toggle");
        }
        Console.WriteLine("PASS: toggle_switch");
    }
}

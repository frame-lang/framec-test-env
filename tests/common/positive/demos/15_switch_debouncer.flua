@@[target("lua")]

@@system Debouncer {
    interface:
        raw_high()
        raw_low()
        tick()
        is_pressed(): bool

    machine:
        $Released {
            $.stable_count: int = 0

            raw_high() { $.stable_count = $.stable_count + 1 }
            raw_low() { $.stable_count = 0 }
            tick() {
                if $.stable_count >= 3 then
                    -> $Pressed
                end
            }
            is_pressed(): bool { @@:(false) }
        }
        $Pressed {
            $.stable_count: int = 0

            raw_low() { $.stable_count = $.stable_count + 1 }
            raw_high() { $.stable_count = 0 }
            tick() {
                if $.stable_count >= 3 then
                    -> $Released
                end
            }
            is_pressed(): bool { @@:(true) }
        }
}

local d = @@Debouncer()
local signals = {1, 0, 1, 1, 1}
for i = 1, 5 do
    if signals[i] ~= 0 then
        d:raw_high()
    else
        d:raw_low()
    end
    d:tick()
end
assert(d:is_pressed() == true, "expected true")
print("PASS: switch_debouncer")

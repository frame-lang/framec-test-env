@@target go

package main

import (
	"fmt"
	"os"
)

@@system Character {
    interface:
        move()
        sprint()
        jump()
        land()
        stop()
        state(): string

    machine:
        $Idle {
            move() { -> $Walking }
            jump() { -> $Jumping }
            state(): string { @@:("idle") }
        }
        $Walking {
            sprint() { -> $Running }
            jump() { -> $Jumping }
            stop() { -> $Idle }
            state(): string { @@:("walking") }
        }
        $Running {
            stop() { -> $Walking }
            jump() { -> $Jumping }
            state(): string { @@:("running") }
        }
        $Jumping {
            land() { -> $Idle }
            state(): string { @@:("jumping") }
        }
}

func main() {
	c := NewCharacter()
	if c.State() != "idle" { fmt.Println("FAIL"); os.Exit(1) }
	c.Move()
	if c.State() != "walking" { fmt.Println("FAIL"); os.Exit(1) }
	c.Sprint()
	if c.State() != "running" { fmt.Println("FAIL"); os.Exit(1) }
	c.Jump()
	if c.State() != "jumping" { fmt.Println("FAIL"); os.Exit(1) }
	c.Move()  // ignored while jumping
	if c.State() != "jumping" { fmt.Println("FAIL"); os.Exit(1) }
	c.Land()
	if c.State() != "idle" { fmt.Println("FAIL"); os.Exit(1) }
	fmt.Println("PASS: character_controller")
}

@@[target("cpp_17")]

#include <iostream>
#include <string>
#include <cassert>

@@system RobotArm {
    interface:
        set_manual()
        set_auto()
        e_stop()
        reset_e_stop()
        status(): str

    machine:
        $Manual => $Operational {
            set_auto() { -> $Auto }
            status(): str { @@:(std::string("Manual")) }
            => $^
        }

        $Auto => $Operational {
            set_manual() { -> $Manual }
            status(): str { @@:(std::string("Auto")) }
            => $^
        }

        $Operational {
            e_stop() { -> $EStop }
            status(): str { @@:(std::string("Operational")) }
        }

        $EStop {
            reset_e_stop() { -> $Manual }
            status(): str { @@:(std::string("EStop")) }
        }

    domain:
}

int main() {
    RobotArm arm;
    assert(std::any_cast<std::string>(arm.status()) == "Manual");
    arm.e_stop();
    assert(std::any_cast<std::string>(arm.status()) == "EStop");
    arm.reset_e_stop();
    assert(std::any_cast<std::string>(arm.status()) == "Manual");
    arm.set_auto();
    assert(std::any_cast<std::string>(arm.status()) == "Auto");
    arm.e_stop();
    assert(std::any_cast<std::string>(arm.status()) == "EStop");
    std::cout << "PASS: robot_arm" << std::endl;
    return 0;
}

@@target swift

@@system ToolRunner {
    interface:
        execute(tool: String): String
        set_parent(agent: Agent)

    machine:
        $Ready {
            set_parent(agent: Agent) {
                self.parent = agent
            }
            execute(tool: String): String {
                if tool == "read_file" {
                    @@:return("read src/main.swift")
                }
                if tool == "write_file" {
                    @@:return("wrote src/main.swift")
                }
                @@:("tests passed")
            }
        }

    domain:
        parent: Agent? = nil
}

@@system Agent {
    interface:
        task(description: String)
        approve()
        plan_ready()
        coding_done()
        tests_passed()
        status(): String

    machine:
        $Idle {
            task(description: String) {
                self.task_desc = description
                -> $Planning
            }
            status(): String { @@:("idle") }
        }

        $Planning => $Active {
            $>() {
                @@:self.plan_ready()
            }
            plan_ready() {
                self.plan_len = 2
                -> $AwaitingApproval
            }
            => $^
        }

        $AwaitingApproval => $Active {
            approve() {
                self.step = 0
                -> $Coding
            }
            => $^
        }

        $Coding => $Active {
            $>() {
                if self.step >= self.plan_len {
                    @@:self.coding_done()
                    return
                }
                let tool: String = self.step == 0 ? "read_file" : "write_file"
                self.tool_result = self.tool_runner.execute(tool)
                self.step = self.step + 1
                -> $Coding
            }
            coding_done() { -> $Testing }
            => $^
        }

        $Testing => $Active {
            $>() {
                self.tool_result = self.tool_runner.execute("run_terminal")
                @@:self.tests_passed()
            }
            tests_passed() { -> $Complete }
            => $^
        }

        $Active {
        }

        $Complete {
            $>() { }
            status(): String { @@:("complete") }
        }

    domain:
        task_desc: String = ""
        plan_len: Int = 0
        step: Int = 0
        tool_runner: ToolRunner = ToolRunner()
        tool_result: String = ""
}

let agent = Agent()
agent.tool_runner.set_parent(agent)

if agent.status() != "idle" {
    print("FAIL: expected idle, got '\(agent.status())'")
} else {
    agent.task("Add validation")
    agent.approve()

    if agent.status() != "complete" {
        print("FAIL: expected complete, got '\(agent.status())'")
    } else {
        print("PASS: ai_agent")
    }
}

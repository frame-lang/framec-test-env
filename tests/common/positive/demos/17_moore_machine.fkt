@@target kotlin

@@system MooreParity {
    interface:
        input(bit: int)
        output(): String

    machine:
        $Even {
            input(bit: int) {
                if (bit == 1) {
                    -> $Odd
                }
            }
            output(): String { @@:("even") }
        }
        $Odd {
            input(bit: int) {
                if (bit == 1) {
                    -> $Even
                }
            }
            output(): String { @@:("odd") }
        }
}

fun main() {
    val m = MooreParity()
    val bits = listOf(1, 0, 1, 1, 0)
    val expected = listOf("odd", "odd", "even", "odd", "odd")
    for (i in bits.indices) {
        m.input(bits[i])
        val result = m.output() as String
        if (result != expected[i]) {
            throw RuntimeException("FAIL: after bit ${bits[i]} expected '${expected[i]}', got '$result'")
        }
    }
    println("PASS: moore_machine")
}

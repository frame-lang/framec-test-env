@@target swift

@@system RateLimiter {
    operations:
        static tokens_for_rate(rps: Int, interval_ms: Int): Int {
            return max(1, (rps * interval_ms) / 1000)
        }
        tokens_remaining(): Int {
            return self.tokens
        }

    interface:
        request(): String
        tick()

    machine:
        $Accepting {
            request(): String {
                self.tokens = self.tokens - 1
                @@:("accepted")
                if self.tokens <= 0 {
                    -> $Throttled
                }
            }
            tick() { self.tokens = min(self.tokens + 1, self.max_tokens) }
        }
        $Throttled {
            request(): String { @@:("throttled") }
            tick() {
                self.tokens = self.tokens + 1
                if self.tokens > 0 {
                    -> $Accepting
                }
            }
        }

    domain:
        tokens: Int = 10
        max_tokens: Int = 10
}

var failures = 0
if RateLimiter.tokens_for_rate(100, 50) != 5 { print("FAIL: static op"); failures += 1 }
let rl = @@RateLimiter()
for _ in 0..<10 { rl.request() }
if rl.request() as! String != "throttled" { print("FAIL: throttled"); failures += 1 }
rl.tick()
if rl.request() as! String != "accepted" { print("FAIL: accepted"); failures += 1 }

if failures > 0 { print("FAIL: rate_limiter (\(failures))"); fatalError() }
print("PASS: rate_limiter")

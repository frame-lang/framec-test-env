@@[target("lua")]

@@[persist]
@@system Session {
    operations:
        @@[save]
        save_state(): string {}

        @@[load]
        restore_state(data: string) {}

    interface:
        login(user: str)
        logout()
        who(): str

    machine:
        $LoggedOut {
            login(user: str) {
                self.user = user
                -> $LoggedIn
            }
            who(): str { @@:("nobody") }
        }
        $LoggedIn {
            logout() {
                self.user = ""
                -> $LoggedOut
            }
            who(): str { @@:(self.user) }
        }

    domain:
        user: str = ""
}

local s = Session.new()
s:login("alice")
if s:who() ~= "alice" then
    print("FAIL: expected 'alice'")
    os.exit(1)
end
local data = s:save_state()
local s2 = Session:new()

s2:restore_state(data)
if s2:who() ~= "alice" then
    print("FAIL: expected 'alice' after restore")
    os.exit(1)
end
print("PASS: session_persistence")

@@target gdscript

extends SceneTree

@@system LedBlinker {
    interface:
        enable()
        disable()
        timer_tick()
        is_lit(): bool

    machine:
        $Disabled {
            enable() { -> $LedOff }
        }
        $LedOff {
            timer_tick() { -> $LedOn }
            disable() { -> $Disabled }
            is_lit(): bool { @@:(false) }
        }
        $LedOn {
            timer_tick() { -> $LedOff }
            disable() { -> $Disabled }
            is_lit(): bool { @@:(true) }
        }
}

func _init():
    var led = @@LedBlinker()
    led.enable()
    var expected = [false, true, false, true, false]
    for i in range(5):
        assert(led.is_lit() == expected[i], "tick %d: expected %s, got %s" % [i, expected[i], led.is_lit()])
        led.timer_tick()
    print("PASS: led_blink_controller")
    quit()

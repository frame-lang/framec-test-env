// Test Harness — @@:system.state in operations (JavaScript)

@@system TestHarness {
    operations:
        current_state(): str {
            @@:(@@:system.state)
        }

    interface:
        run()
        pass_test()
        fail(reason: str)
        get_state(): str
        get_result(): str

    machine:
        $Ready {
            $.ticks: int = 0

            run() {
                this.result = ""
                -> $Running
            }
            get_state(): str { @@:("ready") }
            get_result(): str { @@:(this.result) }
        }
        $Running {
            $.ticks: int = 0

            pass_test() {
                this.result = "pass"
                -> $Passed
            }
            fail(reason: str) {
                this.result = reason
                -> $Failed
            }
            get_state(): str { @@:("running") }
            get_result(): str { @@:("") }
        }
        $Passed {
            run() {
                this.result = ""
                -> $Running
            }
            get_state(): str { @@:("passed") }
            get_result(): str { @@:(this.result) }
        }
        $Failed {
            run() {
                this.result = ""
                -> $Running
            }
            get_state(): str { @@:("failed") }
            get_result(): str { @@:(this.result) }
        }

    domain:
        result = ""
}

const th = @@TestHarness()
let failures = 0

if (th.get_state() !== "ready") { console.log("FAIL: expected ready"); failures++ }

const cs1 = th.current_state()
if (cs1 !== "Ready") { console.log("FAIL: current_state expected Ready, got " + cs1); failures++ }

th.run()
if (th.get_state() !== "running") { console.log("FAIL: expected running"); failures++ }

const cs2 = th.current_state()
if (cs2 !== "Running") { console.log("FAIL: current_state expected Running, got " + cs2); failures++ }

th.pass_test()
if (th.get_state() !== "passed") { console.log("FAIL: expected passed"); failures++ }
if (th.get_result() !== "pass") { console.log("FAIL: result expected pass"); failures++ }

th.run()
th.fail("timeout")
if (th.get_state() !== "failed") { console.log("FAIL: expected failed"); failures++ }
if (th.get_result() !== "timeout") { console.log("FAIL: result expected timeout"); failures++ }

const cs3 = th.current_state()
if (cs3 !== "Failed") { console.log("FAIL: current_state expected Failed, got " + cs3); failures++ }

if (failures > 0) { console.log("FAIL: test_harness (" + failures + " failures)"); process.exit(1) }
console.log("PASS: test_harness")

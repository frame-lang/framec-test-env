@@target erlang

@@system OrderProcessor {
    interface:
        submit(item: str)
        cancel(reason: str)
        status(): str

    machine:
        $Idle {
            submit(item: str) {
                self.item = item
                -> $Validating
            }
            status(): str { @@:("idle") }
        }
        $Validating {
            $>() {
                if self.validate(self.item) {
                    -> $Processing
                } else {
                    -> $Rejected
                }
            }
            status(): str { @@:("validating") }
        }
        $Processing {
            cancel(reason: str) {
                -> $Idle
            }
            status(): str { @@:("processing") }
        }
        $Rejected {
            status(): str { @@:("rejected") }
        }

    actions:
        validate(item) {
            (item =/= undefined) andalso (length(item) > 0)
        }

    domain:
        item = ""
}

@@[target("python_3")]

@@system Switch {
    interface:
        toggle(): str
        status(): str

    machine:
        $Off {
            toggle(): str {
                @@:("on")
                -> $On
            }
            status(): str { @@:("off") }
        }
        $On {
            toggle(): str {
                @@:("off")
                -> $Off
            }
            status(): str { @@:("on") }
        }
}

if __name__ == '__main__':
    sw = @@Switch()
    assert sw.status() == "off", f"Expected 'off', got '{sw.status()}'"
    assert sw.toggle() == "on", f"Expected 'on' from toggle"
    assert sw.toggle() == "off", f"Expected 'off' from toggle"
    print("PASS: toggle_switch")

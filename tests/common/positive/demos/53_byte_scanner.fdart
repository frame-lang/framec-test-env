@@[target("dart")]

@@system Scanner {
    interface:
        feed_letter()
        feed_punct()
        eof()
        token_count(): int
        status(): String

    machine:
        $Start {
            feed_letter() { -> $InIdent }
            feed_punct() {
                this.count = this.count + 1;
            }
            eof() {
                this.count = this.count + 1;
            }
            token_count(): int { @@:(this.count) }
            status(): String { @@:("start") }
        }

        $InIdent {
            feed_letter() {}
            feed_punct() {
                this.count = this.count + 2;
                -> $Start
            }
            eof() {
                this.count = this.count + 2;
            }
            token_count(): int { @@:(this.count) }
            status(): String { @@:("in_ident") }
        }

    domain:
        count: int = 0
}

void main() {
    final s = @@Scanner();
    if (s.status() != "start") throw "expected start";
    if (s.token_count() != 0) throw "expected count=0";
    s.feed_letter();
    if (s.status() != "in_ident") throw "expected in_ident";
    s.feed_letter();
    s.feed_punct();
    if (s.status() != "start") throw "expected start after";
    if (s.token_count() != 2) throw "expected count=2";
    s.feed_punct();
    if (s.token_count() != 3) throw "expected count=3";
    s.eof();
    if (s.token_count() != 4) throw "expected count=4";

    final s2 = @@Scanner();
    s2.feed_letter();
    s2.feed_letter();
    s2.eof();
    if (s2.token_count() != 2) throw "expected count=2 eof";
    print("PASS: byte_scanner");
}

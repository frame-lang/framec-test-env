@@[target("lua")]

@@system Thermostat {
    interface:
        set_temp(target)
        tick()
        status(): str = "unknown"

    machine:
        $Off {
            set_temp(target) {
                self.target = target
                -> $LowHeat
            }
            status(): str { @@:("off") }
        }
        $LowHeat => $On {
            $>() { self.heat_rate = 1 }
            status(): str { @@:("low heat") }
            => $^
        }
        $HighHeat => $On {
            $>() { self.heat_rate = 2 }
            status(): str { @@:("high heat") }
            => $^
        }
        $On {
            tick() {
                self.current = self.current + self.heat_rate
                if self.current >= self.target then
                    self.current = self.target
                    -> $Cooling
                elseif self.target - self.current > 5 then
                    if self.heat_rate < 2 then
                        -> $HighHeat
                    end
                elseif self.target - self.current <= 3 then
                    if self.heat_rate > 1 then
                        -> $LowHeat
                    end
                end
            }
            set_temp(target) { self.target = target }
        }
        $Cooling {
            $>() { self.heat_rate = 0 }
            tick() {
                self.current = self.current - 1
                if self.current <= self.target then
                    -> $Off
                end
            }
            status(): str { @@:("cooling") }
        }

    domain:
        current = 65
        target = 65
        heat_rate = 0
}

local t = @@Thermostat()
local failures = 0

if t:status() ~= "off" then
    print("FAIL: initial status")
    failures = failures + 1
end

t:set_temp(75)
local cooled = false
for i = 1, 20 do
    t:tick()
    local s = t:status()
    if s == "cooling" or s == "off" then cooled = true end
end
if not cooled then
    print("FAIL: never cooled")
    failures = failures + 1
end

if failures > 0 then
    print("FAIL: thermostat (" .. failures .. ")")
    os.exit(1)
end
print("PASS: thermostat")

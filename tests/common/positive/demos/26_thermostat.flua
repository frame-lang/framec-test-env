-- Thermostat — HSM with parent forwarding (Lua)

@@system Thermostat {
    interface:
        set_target(temp: int)
        tick(): str
        status(): str

    machine:
        $Off {
            set_target(temp: int) {
                self.target = temp
                -> $Heating
            }
            status(): str { @@:("off") }
        }
        $Heating => $Active {
            tick(): str {
                self.current = self.current + self.heat_rate
                if self.current >= self.target {
                    -> $Cooling
                }
                @@:("heating")
            }
            status(): str { @@:("heating") }
            => $^
        }
        $Cooling => $Active {
            tick(): str {
                self.current = self.current - 1
                if self.current <= self.target - 2 {
                    -> $Heating
                }
                @@:("cooling")
            }
            status(): str { @@:("cooling") }
            => $^
        }
        $Active {
            set_target(temp: int) {
                self.target = temp
            }
        }

    domain:
        current = 60
        target = 72
        heat_rate = 2
}

local t = @@Thermostat()
local failures = 0

if t:status() ~= "off" then
    print("FAIL: expected off")
    failures = failures + 1
end
t:set_target(64)
if t:status() ~= "heating" then
    print("FAIL: expected heating")
    failures = failures + 1
end

t:tick()
if t.current ~= 62 then
    print("FAIL: current should be 62, got " .. t.current)
    failures = failures + 1
end
t:tick()
if t.current ~= 64 then
    print("FAIL: current should be 64, got " .. t.current)
    failures = failures + 1
end
if t:status() ~= "cooling" then
    print("FAIL: expected cooling after reaching target")
    failures = failures + 1
end

t:set_target(63)
t:tick()
t:tick()
t:tick()
if t:status() ~= "heating" then
    print("FAIL: expected heating after dropping below target-2")
    failures = failures + 1
end

if failures > 0 then
    print("FAIL: thermostat (" .. failures .. " failures)")
    os.exit(1)
end
print("PASS: thermostat")

@@[target("swift")]

@@system Connection {
    interface:
        connect(host: String)
        send(data: String): String
        disconnect()

    machine:
        $Disconnected {
            connect(host: String) {
                self.host = host
                -> $Connecting
            }
        }
        $Connecting {
            $>() {
                print("Connecting to \(self.host)...")
                -> $Connected
            }
        }
        $Connected {
            $>() { print("Connected to \(self.host)") }
            <$() { print("Disconnecting from \(self.host)") }

            send(data: String): String {
                @@:("sent '\(data)' to \(self.host)")
            }
            disconnect() { -> $Disconnected }
        }

    domain:
        host: String = ""
}

var c = @@Connection()
c.connect("example.com")
let result = c.send("hello") as! String
assert(result == "sent 'hello' to example.com", "Got: \(result)")
c.disconnect()
print("PASS: connection_manager")

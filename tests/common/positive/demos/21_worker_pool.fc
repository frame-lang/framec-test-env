@@target c
@@skip -- C has no built-in list type and Frame's domain syntax (`name : type = init`) doesn't express C's array declarator (`char* arr[N]`). The Python/JS/etc. ports use `pending: list = []`; a faithful C port would need either a Frame stdlib list helper shipped per-system (like `FrameDict`) or codegen recognition of `: list` mapping to a generated dynamic-array helper. Tracked as a deliberate language-shape gap; see `docs/runtime-capability-matrix.md` footnote [l].

#include <stdio.h>

@@system WorkerPool($(max_retries: int), pool_size: int) {
    interface:
        submit()
        get_status()

    machine:
        $Idle(max_retries: int) {
            submit() { }
            get_status() { }
        }
}

int main() {
    printf("SKIP: worker_pool -- C list-domain port pending Frame stdlib design\n");
    return 0;
}

@@target c

#include <stdio.h>
#include <string.h>

// Frame's domain syntax is `name : type = init`, which doesn't fit
// C's interleaved array declarator (`char* pending[8]`). The
// Oceans Model handles this via a typedef in the prolog — `JobSlots`
// becomes a single-token type and the domain field reduces to
// `pending : JobSlots = {0}`. Handler bodies use C-native indexing
// on the underlying array.
typedef char* JobSlots[8];

@@system WorkerPool($(max_retries: int), $>(start_msg: char*), pool_size: int) {
    interface:
        submit(task: char*)
        get_status(): char*

    machine:
        $Idle(max_retries: int) {
            $>(start_msg: char*) {
                printf("Pool ready: %s\n", start_msg);
            }

            submit(task: char*) {
                if (self->pending_count < 8) {
                    self->pending[self->pending_count] = task;
                    self->pending_count = self->pending_count + 1;
                }
                if (self->pending_count >= self->pool_size) {
                    -> $Processing
                }
            }

            get_status(): char* {
                static char buf[64];
                snprintf(buf, sizeof(buf), "idle (%d/%d pending)",
                         self->pending_count, self->pool_size);
                @@:(buf)
                return;
            }
        }

        $Processing {
            $>() {
                printf("Processing batch of %d tasks\n", self->pending_count);
                self->pending_count = 0;
            }

            submit(task: char*) {
                if (self->pending_count < 8) {
                    self->pending[self->pending_count] = task;
                    self->pending_count = self->pending_count + 1;
                }
            }

            get_status(): char* {
                @@:("processing")
                return;
            }
        }

    domain:
        pool_size: int = pool_size
        pending: JobSlots = {0}
        pending_count: int = 0
}

int main() {
    WorkerPool* pool = @@WorkerPool($(5), $>("v1.0"), 3);

    WorkerPool_submit(pool, "task_a");
    char* status = WorkerPool_get_status(pool);
    if (strcmp(status, "idle (1/3 pending)") != 0) {
        printf("FAIL: expected 'idle (1/3 pending)', got '%s'\n", status);
        return 1;
    }

    WorkerPool_submit(pool, "task_b");
    WorkerPool_submit(pool, "task_c");
    status = WorkerPool_get_status(pool);
    if (strcmp(status, "processing") != 0) {
        printf("FAIL: expected 'processing', got '%s'\n", status);
        return 1;
    }

    printf("PASS: worker_pool\n");
    WorkerPool_destroy(pool);
    return 0;
}

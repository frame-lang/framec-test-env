@@target c
@@skip -- C does not support list types in domain vars natively

#include <stdio.h>

@@system WorkerPool($(max_retries: int), pool_size: int) {
    interface:
        submit()
        get_status()

    machine:
        $Idle(max_retries: int) {
            submit() { }
            get_status() { }
        }
}

int main() {
    printf("SKIP: worker_pool -- C does not support list types in domain vars natively\n");
    return 0;
}

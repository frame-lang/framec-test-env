@@target erlang

@@system GracefulShutdown {
    interface:
        start()
        request_stop()
        finish()
        status(): atom

    machine:
        $Running {
            request_stop() { -> $Draining }
            status(): atom { @@:(running) }
        }
        $Draining {
            finish() { -> $Stopped }
            status(): atom { @@:(draining) }
        }
        $Stopped {
            status(): atom { @@:(stopped) }
        }
}

main() ->
    {ok, Pid} = graceful_shutdown:start_link(),
    running = graceful_shutdown:status(Pid),
    ok = graceful_shutdown:request_stop(Pid),
    draining = graceful_shutdown:status(Pid),
    ok = graceful_shutdown:finish(Pid),
    stopped = graceful_shutdown:status(Pid),
    io:format("PASS: graceful_shutdown~n").

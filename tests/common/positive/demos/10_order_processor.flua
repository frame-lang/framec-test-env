@@[target("lua")]

@@system OrderProcessor {
    interface:
        submit(item: str)
        cancel(reason: str)
        status(): str

    machine:
        $Idle {
            submit(item: str) {
                self.item = item
                -> $Validating
            }
            status(): str { @@:("idle") }
        }
        $Validating {
            $>() {
                if self:validate(self.item) then
                    -> $Processing
                else
                    -> $Rejected
                end
            }
            status(): str { @@:("validating") }
        }
        $Processing {
            cancel(reason: str) {
                print("Cancelled: " .. reason)
                -> $Idle
            }
            status(): str { @@:("processing") }
        }
        $Rejected {
            status(): str { @@:("rejected") }
        }

    actions:
        validate(item) {
            return item ~= nil and #item > 0
        }

    domain:
        item: str = ""
}

local op = @@OrderProcessor()
op:submit("widget")
local r1 = op:status()
assert(r1 == "processing", "Expected 'processing', got '" .. tostring(r1) .. "'")
op:cancel("changed mind")
local r2 = op:status()
assert(r2 == "idle", "Expected 'idle', got '" .. tostring(r2) .. "'")
print("PASS: order_processor")

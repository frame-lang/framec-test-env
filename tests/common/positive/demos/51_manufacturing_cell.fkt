@@[target("kotlin")]

@@system ManufacturingCell {
    interface:
        work_order(order_id: String)
        phase_done()
        emergency_stop()
        reset()
        parts_produced(): Int
        status(): String

    machine:
        $Idle => $Active {
            work_order(order_id: String) { -> $Setup }
            status(): String { @@:("idle") }
            => $^
        }

        $Setup => $Active {
            phase_done() { -> $Machining }
            status(): String { @@:("setup") }
            => $^
        }

        $Machining => $Active {
            phase_done() { -> $Teardown }
            status(): String { @@:("machining") }
            => $^
        }

        $Teardown => $Active {
            phase_done() {
                this.parts = this.parts + 1
                -> $Idle
            }
            status(): String { @@:("teardown") }
            => $^
        }

        $Active {
            emergency_stop() { -> $EStopped }
            parts_produced(): Int { @@:(this.parts) }
            status(): String { @@:("active") }
        }

        $EStopped {
            reset() { -> $Idle }
            parts_produced(): Int { @@:(this.parts) }
            status(): String { @@:("estopped") }
        }

    domain:
        parts: Int = 0
}

fun main() {
    val c = @@ManufacturingCell()
    if ((c.status() as String) != "idle") throw RuntimeException("expected idle")
    if ((c.parts_produced() as Int) != 0) throw RuntimeException("expected parts=0")
    c.work_order("WO-001")
    if ((c.status() as String) != "setup") throw RuntimeException("expected setup")
    c.phase_done()
    if ((c.status() as String) != "machining") throw RuntimeException("expected machining")
    c.phase_done()
    if ((c.status() as String) != "teardown") throw RuntimeException("expected teardown")
    c.phase_done()
    if ((c.status() as String) != "idle") throw RuntimeException("expected idle")
    if ((c.parts_produced() as Int) != 1) throw RuntimeException("expected parts=1")
    c.work_order("WO-002")
    c.phase_done()
    c.emergency_stop()
    if ((c.status() as String) != "estopped") throw RuntimeException("expected estopped")
    c.reset()
    if ((c.status() as String) != "idle") throw RuntimeException("expected idle final")
    println("PASS: manufacturing_cell")
}

@@[target("python_3")]

@@system MealyDetector {
    interface:
        input(bit: int): str

    machine:
        $S0 {
            input(bit: int): str {
                if bit == 1:
                    @@:("0")
                    -> $S1
                else:
                    @@:("0")
            }
        }
        $S1 {
            input(bit: int): str {
                if bit == 0:
                    @@:("1")
                    -> $S0
                else:
                    @@:("0")
            }
        }
}

if __name__ == '__main__':
    m = @@MealyDetector()
    bits = [1, 0, 1, 1, 0]
    expected_outputs = ["0", "1", "0", "0", "1"]
    for i, bit in enumerate(bits):
        result = m.input(bit)
        assert result == expected_outputs[i], f"bit={bit}: expected '{expected_outputs[i]}', got '{result}'"
    print("PASS: mealy_machine")

@@[target("swift")]

@@system Character {
    interface:
        move()
        sprint()
        jump()
        land()
        stop()
        state(): String

    machine:
        $Idle {
            move() { -> $Walking }
            jump() { -> $Jumping }
            state(): String { @@:("idle") }
        }
        $Walking {
            sprint() { -> $Running }
            jump() { -> $Jumping }
            stop() { -> $Idle }
            state(): String { @@:("walking") }
        }
        $Running {
            stop() { -> $Walking }
            jump() { -> $Jumping }
            state(): String { @@:("running") }
        }
        $Jumping {
            land() { -> $Idle }
            state(): String { @@:("jumping") }
        }
}

var c = @@Character()
assert(c.state() as! String == "idle")
c.move()
assert(c.state() as! String == "walking")
c.sprint()
assert(c.state() as! String == "running")
c.jump()
assert(c.state() as! String == "jumping")
c.move()  // ignored while jumping
assert(c.state() as! String == "jumping")
c.land()
assert(c.state() as! String == "idle")
print("PASS: character_controller")

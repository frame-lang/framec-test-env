@@target javascript

@@system Connection {
    interface:
        connect(host: str)
        send(data: str): str
        disconnect()

    machine:
        $Disconnected {
            connect(host: str) {
                this.host = host
                -> $Connecting
            }
        }
        $Connecting {
            $>() {
                console.log("Connecting to " + this.host + "...")
                -> $Connected
            }
        }
        $Connected {
            $>() { console.log("Connected to " + this.host) }
            <$() { console.log("Disconnecting from " + this.host) }

            send(data: str): str {
                @@:("sent '" + data + "' to " + this.host)
            }
            disconnect() { -> $Disconnected }
        }

    domain:
        host: str = ""
}

const c = @@Connection();
c.connect("example.com");
const result = c.send("hello");
if (result !== "sent 'hello' to example.com") { console.log("FAIL: Got: " + result); process.exit(1); }
c.disconnect();
console.log("PASS: connection_manager");

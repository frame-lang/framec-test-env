@@[target("csharp")]

using System;

@@system VideoPlayer {
    interface:
        play()
        pause()
        stop()
        status(): String

    machine:
        $Stopped {
            play() { -> $Playing }
            status(): String { @@:("stopped") }
        }
        $Playing => $Active {
            pause() { -> $Paused }
            status(): String { @@:("playing") }
            => $^
        }
        $Paused => $Active {
            play() { -> $Playing }
            status(): String { @@:("paused") }
            => $^
        }
        $Active {
            stop() { -> $Stopped }
        }
}

class Program {
    static void Main(string[] args) {
        var vp = @@VideoPlayer();
        if ((string) vp.status() != "stopped") throw new Exception("FAIL");
        vp.play();
        if ((string) vp.status() != "playing") throw new Exception("FAIL");
        vp.pause();
        if ((string) vp.status() != "paused") throw new Exception("FAIL");
        vp.stop();
        if ((string) vp.status() != "stopped") throw new Exception("FAIL");
        Console.WriteLine("PASS: video_player");
    }
}

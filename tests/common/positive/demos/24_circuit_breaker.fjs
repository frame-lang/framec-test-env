@@[target("javascript")]

@@system CircuitBreaker {
    interface:
        call(): str = "error"
        success()
        failure()
        tick()
        status(): str = ""

    machine:
        $Closed {
            $.failures: int = 0
            call(): str { @@:("allowed") }
            success() { $.failures = 0 }
            failure() {
                $.failures = $.failures + 1
                if ($.failures >= this.threshold) {
                    -> $Open
                }
            }
            status(): str { @@:(`closed (${$.failures} failures)`) }
        }
        $Open {
            $.cooldown_remaining: int = 0
            $>() {
                $.cooldown_remaining = this.cooldown
            }
            call(): str { @@:("blocked") }
            tick() {
                $.cooldown_remaining = $.cooldown_remaining - 1
                if ($.cooldown_remaining <= 0) {
                    -> $HalfOpen
                }
            }
            status(): str { @@:(`open (${$.cooldown_remaining} ticks left)`) }
        }
        $HalfOpen {
            call(): str { @@:("testing") }
            success() { -> $Closed }
            failure() { -> $Open }
            status(): str { @@:("half-open") }
        }

    domain:
        threshold = 3
        cooldown = 5
}

const cb = new CircuitBreaker()
let failures = 0

cb.failure(); cb.failure(); cb.failure()
if (cb.call() !== "blocked") { console.log("FAIL: expected blocked, got " + cb.call()); failures++ }
for (let i = 0; i < 5; i++) { cb.tick() }
if (cb.call() !== "testing") { console.log("FAIL: expected testing, got " + cb.call()); failures++ }
cb.success()
if (cb.status() !== "closed (0 failures)") { console.log("FAIL: expected reset, got " + cb.status()); failures++ }

if (failures > 0) { console.log("FAIL: circuit_breaker (" + failures + " failures)"); process.exit(1) }
console.log("PASS: circuit_breaker")

@@target swift

@@system Account(owner: String, initial_balance: int = 0) {
    interface:
        deposit(amount: int)
        withdraw(amount: int): bool
        balance(): int
        owner_name(): String
        close()

    machine:
        $Open {
            deposit(amount: int) {
                self.bal = self.bal + amount
            }
            withdraw(amount: int): bool {
                if (self.bal >= amount) {
                    self.bal = self.bal - amount
                    @@:(true)
                } else {
                    @@:(false)
                }
            }
            balance(): int { @@:(self.bal) }
            owner_name(): String { @@:(self.who) }
            close() { -> $Closed }
        }
        $Closed {
            deposit(amount: int) {
                // Closed accounts ignore deposits.
            }
            withdraw(amount: int): bool { @@:(false) }
            balance(): int { @@:(self.bal) }
            owner_name(): String { @@:(self.who) }
        }

    domain:
        bal: int = initial_balance
        who: String = owner
}

var a = @@Account("Alice", 100)
assert(a.owner_name() as! String == "Alice", "owner")
assert(a.balance() as! Int == 100, "balance")

a.deposit(50)
assert(a.balance() as! Int == 150, "deposit")

assert(a.withdraw(60) as! Bool == true, "withdraw ok")
assert(a.balance() as! Int == 90, "balance after withdraw")

assert(a.withdraw(200) as! Bool == false, "withdraw insufficient")
assert(a.balance() as! Int == 90, "balance unchanged")

a.close()
assert(a.withdraw(10) as! Bool == false, "closed withdraw")
assert(a.balance() as! Int == 90, "closed balance")

var b = @@Account("Bob")
assert(b.owner_name() as! String == "Bob", "bob owner")
assert(b.balance() as! Int == 0, "bob balance")
b.deposit(25)
assert(b.balance() as! Int == 25, "bob deposit")

print("ok 1 - 21_bank_account")

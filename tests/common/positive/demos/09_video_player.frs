@@target rust

@@system VideoPlayer {
    interface:
        play()
        pause()
        stop()
        status(): String

    machine:
        $Stopped {
            play() { -> $Playing }
            status(): String { @@:("stopped".to_string()) }
        }
        $Playing => $Active {
            pause() { -> $Paused }
            status(): String { @@:("playing".to_string()) }
            => $^
        }
        $Paused => $Active {
            play() { -> $Playing }
            status(): String { @@:("paused".to_string()) }
            => $^
        }
        $Active {
            stop() { -> $Stopped }
        }
}

fn main() {
    let mut vp = @@VideoPlayer();
    assert_eq!(vp.status(), "stopped");
    vp.play();
    assert_eq!(vp.status(), "playing");
    vp.pause();
    assert_eq!(vp.status(), "paused");
    vp.stop();
    assert_eq!(vp.status(), "stopped");
    println!("PASS: video_player");
}

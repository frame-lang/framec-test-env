@@target typescript

@@system VendingMachine(inventory: Record<string, number> = {}) {
    operations:
        stock(product: string, qty: number) {
            this.inventory[product] = (this.inventory[product] || 0) + qty
        }
        check_stock(product: string): number {
            return this.inventory[product] || 0
        }

    interface:
        insert_coin(amount: number)
        select(product: string): string = "error"
        cancel(): number = 0

    machine:
        $Idle {
            insert_coin(amount: number) {
                this.balance = amount
                -> $HasCredit
            }
            select(product: string): string { @@:("insert coin first") }
            cancel(): number { @@:(0) }
        }
        $HasCredit {
            insert_coin(amount: number) {
                this.balance = this.balance + amount
            }
            select(product: string): string {
                const price = this.get_price(product)
                if (price === null) {
                    @@:("unknown product")
                } else if (this.balance < price) {
                    @@:(`need ${price - this.balance} more`)
                } else if ((this.inventory[product] || 0) <= 0) {
                    @@:("sold out")
                } else {
                    this.inventory[product] = this.inventory[product] - 1
                    this.balance = this.balance - price
                    @@:(`dispensing ${product}`)
                    -> $Dispensing
                }
            }
            cancel(): number {
                const refund = this.balance
                this.balance = 0
                @@:(refund)
                -> $Idle
            }
        }
        $Dispensing {
            $>() {
                const change = this.balance
                this.balance = 0
                if (change > 0) {
                    console.log(`Change: ${change}`)
                }
                -> $Idle
            }
        }

    actions:
        get_price(product: string) {
            const prices: Record<string, number> = {"cola": 100, "chips": 75, "water": 50}
            return prices[product] !== undefined ? prices[product] : null
        }

    domain:
        balance: number = 0
        inventory: Record<string, number> = {}
}

const vm = new VendingMachine({"cola": 2, "chips": 1})
vm.stock("water", 5)
let failures = 0

if (vm.check_stock("water") !== 5) { console.log("FAIL: water stock"); failures++ }

let r = vm.select("cola")
if (r !== "insert coin first") { console.log("FAIL: expected 'insert coin first', got " + r); failures++ }

vm.insert_coin(100)
r = vm.select("cola")
if (r !== "dispensing cola") { console.log("FAIL: expected 'dispensing cola', got " + r); failures++ }

if (failures > 0) { console.log(`FAIL: vending_machine (${failures})`); process.exit(1) }
console.log("PASS: vending_machine")

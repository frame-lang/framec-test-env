// Self-Calibrating Sensor — @@:self demo (Rust)

@@system Sensor {
    interface:
        calibrate(): str
        reading(): float
        trigger_shutdown()
        attempt_post_shutdown(): str
        status(): str

    machine:
        $Active {
            calibrate(): str {
                let baseline = @@:self.reading();
                self.offset = baseline * -1.0;
                @@:(format!("calibrated: offset={}", self.offset))
            }

            reading(): float {
                @@:(self.raw_value + self.offset)
            }

            trigger_shutdown() {
                -> $Shutdown
            }

            attempt_post_shutdown(): str {
                self.trace = "before".to_string();
                @@:self.trigger_shutdown();
                self.trace = "after".to_string();
                @@:(self.trace.clone())
            }

            status(): str { @@:("Active".to_string()) }
        }

        $Shutdown {
            status(): str { @@:("Shutdown".to_string()) }
        }

    domain:
        raw_value: f64 = 42.0
        offset: f64 = 0.0
        trace: String = String::new()
}

fn main() {
    let mut sensor = @@Sensor();
    let mut failures = 0;

    let r1 = sensor.reading();
    if (r1 - 42.0).abs() > 1e-9 {
        println!("FAIL: reading() expected 42.0, got {}", r1);
        failures += 1;
    }

    let cal = sensor.calibrate();
    if !cal.contains("calibrated") {
        println!("FAIL: calibrate() expected 'calibrated', got '{}'", cal);
        failures += 1;
    }

    let r2 = sensor.reading();
    if r2.abs() > 1e-9 {
        println!("FAIL: reading() after calibrate expected 0.0, got {}", r2);
        failures += 1;
    }

    sensor.attempt_post_shutdown();
    if sensor.trace != "before" {
        println!("FAIL: trace expected 'before' (guard suppressed 'after'), got '{}'", sensor.trace);
        failures += 1;
    }

    let st = sensor.status();
    if st != "Shutdown" {
        println!("FAIL: status() expected 'Shutdown', got '{}'", st);
        failures += 1;
    }

    if failures > 0 {
        println!("FAIL: self_calibrating_sensor ({} failures)", failures);
        std::process::exit(1);
    }
    println!("PASS: self_calibrating_sensor");
}

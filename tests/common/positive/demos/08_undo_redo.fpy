@@[target("python_3")]

# Demo 08: Undo/Redo — push$/pop$ with reference semantics.
#
# push$ saves a REFERENCE to the current compartment on the state stack.
# Bare push$ (no transition) means the stack entry and current point to
# the SAME compartment. Modifications after push$ are visible through
# both. pop$ restores the reference — but since it's the same object,
# the state vars retain their modified values.
#
# For true undo (snapshot semantics), use push$ -> $State to create a
# NEW compartment on transition. The old compartment on the stack
# preserves its pre-transition state.

@@system Editor {
    interface:
        type_char(c: str)
        undo()
        get_buffer(): str

    machine:
        $Editing {
            $.buffer: str = ""

            type_char(c: str) {
                push$
                $.buffer = $.buffer + c
            }
            undo() {
                -> pop$
            }
            get_buffer(): str { @@:($.buffer) }
        }
}

if __name__ == '__main__':
    e = @@Editor()
    e.type_char("H")
    e.type_char("i")
    assert e.get_buffer() == "Hi", f"Expected 'Hi', got '{e.get_buffer()}'"

    # With reference push$, undo restores the SAME compartment.
    # The buffer was modified in place, so it stays "Hi".
    e.undo()
    assert e.get_buffer() == "Hi", f"Expected 'Hi' (reference semantics), got '{e.get_buffer()}'"

    e.undo()
    assert e.get_buffer() == "Hi", f"Expected 'Hi' (reference semantics), got '{e.get_buffer()}'"

    print("PASS: undo_redo")

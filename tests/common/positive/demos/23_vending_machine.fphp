@@[target("php")]

@@system VendingMachine(stock = 0) {
    operations:
        get_balance() {
            return $this->balance;
        }
        get_stock() {
            return $this->stock;
        }

    interface:
        insert_coin(amount)
        select(): string = "error"
        cancel(): int = 0

    machine:
        $Idle {
            insert_coin(amount) {
                $this->balance = $amount;
                -> $HasCredit
            }
            select(): string { @@:("insert coin first") }
            cancel(): int { @@:(0) }
        }

        $HasCredit {
            insert_coin(amount) {
                $this->balance = $this->balance + $amount;
            }
            select(): string {
                if ($this->balance < $this->price) {
                    @@:("need more")
                } elseif ($this->stock <= 0) {
                    @@:("sold out")
                } else {
                    $this->stock = $this->stock - 1;
                    $this->balance = $this->balance - $this->price;
                    @@:("dispensing")
                    -> $Dispensing
                }
            }
            cancel(): int {
                $refund = $this->balance;
                $this->balance = 0;
                @@:($refund)
                -> $Idle
            }
        }

        $Dispensing {
            $>() {
                $change = $this->balance;
                $this->balance = 0;
                if ($change > 0) {
                    echo "Change: $change\n";
                }
                -> $Idle
            }
        }

    domain:
        balance = 0
        stock = 0
        price = 100
}

$vm = @@VendingMachine(3);
$failures = 0;

if ($vm->get_stock() !== 3) {
    echo "FAIL: initial stock expected 3\n";
    $failures++;
}

$r1 = $vm->select();
if ($r1 !== "insert coin first") {
    echo "FAIL: expected 'insert coin first', got '$r1'\n";
    $failures++;
}

$vm->insert_coin(100);
$r2 = $vm->select();
if ($r2 !== "dispensing") {
    echo "FAIL: expected 'dispensing', got '$r2'\n";
    $failures++;
}

if ($vm->get_stock() !== 2) {
    echo "FAIL: stock after buy expected 2\n";
    $failures++;
}

$vm->insert_coin(50);
$refund = $vm->cancel();
if ($refund !== 50) {
    echo "FAIL: refund expected 50, got $refund\n";
    $failures++;
}

if ($failures > 0) { echo "FAIL: vending_machine ($failures)\n"; exit(1); }
echo "PASS: vending_machine\n";

@@target cpp_17

#include <iostream>
#include <string>
#include <cassert>

@@system LoginFlow {
    interface:
        submit(value: str): str

    machine:
        $EnterUsername {
            submit(value: str): str {
                this->username = value;
                @@:(std::string("enter password"))
                -> $EnterPassword
            }
        }
        $EnterPassword {
            submit(value: str): str {
                if (this->username == "admin" && value == "secret") {
                    @@:(std::string("welcome"))
                    -> $LoggedIn
                } else {
                    @@:(std::string("invalid - try again"))
                    -> $EnterUsername
                }
            }
        }
        $LoggedIn {
            submit(value: str): str { @@:(std::string("already logged in")) }
        }

    domain:
        username: std::string = ""
}

int main() {
    LoginFlow login;
    auto r1 = std::any_cast<std::string>(login.submit("admin"));
    assert(r1 == "enter password");
    auto r2 = std::any_cast<std::string>(login.submit("wrong"));
    assert(r2 == "invalid - try again");
    auto r3 = std::any_cast<std::string>(login.submit("admin"));
    assert(r3 == "enter password");
    auto r4 = std::any_cast<std::string>(login.submit("secret"));
    assert(r4 == "welcome");
    printf("PASS: login_flow\n");
    return 0;
}

@@[target("c")]

#include <stdio.h>
#include <stdlib.h>
#include <string.h>

@@system TrafficLight {
    interface:
        next(): str

    machine:
        $Green {
            next(): str {
                @@:("green")
                -> $Yellow
            }
        }
        $Yellow {
            next(): str {
                @@:("yellow")
                -> $Red
            }
        }
        $Red {
            next(): str {
                @@:("red")
                -> $Green
            }
        }
}

int main() {
    TrafficLight* light = @@TrafficLight();
    const char* expected[] = {"green", "yellow", "red", "green", "yellow", "red"};
    for (int i = 0; i < 6; i++) {
        const char* r = TrafficLight_next(light);
        if (strcmp(r, expected[i]) != 0) {
            printf("FAIL: step %d expected %s got %s\n", i, expected[i], r);
            return 1;
        }
    }
    printf("PASS: traffic_light\n");
    TrafficLight_destroy(light);
    return 0;
}

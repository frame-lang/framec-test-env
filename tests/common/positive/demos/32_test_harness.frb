# Test Harness — @@:system.state in operations (Ruby)

@@system TestHarness {
    operations:
        current_state(): str {
            @@:(@@:system.state)
        }

    interface:
        run()
        pass_test()
        fail(reason: str)
        get_state(): str
        get_result(): str

    machine:
        $Ready {
            $.ticks: int = 0

            run() {
                self.result = ""
                -> $Running
            }
            get_state(): str { @@:("ready") }
            get_result(): str { @@:(self.result) }
        }
        $Running {
            $.ticks: int = 0

            pass_test() {
                self.result = "pass"
                -> $Passed
            }
            fail(reason: str) {
                self.result = reason
                -> $Failed
            }
            get_state(): str { @@:("running") }
            get_result(): str { @@:("") }
        }
        $Passed {
            run() {
                self.result = ""
                -> $Running
            }
            get_state(): str { @@:("passed") }
            get_result(): str { @@:(self.result) }
        }
        $Failed {
            run() {
                self.result = ""
                -> $Running
            }
            get_state(): str { @@:("failed") }
            get_result(): str { @@:(self.result) }
        }

    domain:
        result = ""
}

th = @@TestHarness()
failures = 0

if th.get_state() != "ready"
    puts "FAIL: expected ready"
    failures += 1
end

cs1 = th.current_state()
if cs1 != "Ready"
    puts "FAIL: current_state expected Ready, got #{cs1}"
    failures += 1
end

th.run()
if th.get_state() != "running"
    puts "FAIL: expected running"
    failures += 1
end

th.pass_test()
if th.get_state() != "passed"
    puts "FAIL: expected passed"
    failures += 1
end
if th.get_result() != "pass"
    puts "FAIL: result expected pass"
    failures += 1
end

th.run()
th.fail("timeout")
if th.get_state() != "failed"
    puts "FAIL: expected failed"
    failures += 1
end
if th.get_result() != "timeout"
    puts "FAIL: result expected timeout"
    failures += 1
end

if failures > 0
    puts "FAIL: test_harness (#{failures} failures)"
    exit(1)
end
puts "PASS: test_harness"

@@target swift

@@system Editor {
    interface:
        type_char(c: String)
        undo()
        get_buffer(): String

    machine:
        $Editing {
            $.buffer: String = ""

            type_char(c: String) {
                push$
                $.buffer = $.buffer + c
            }
            undo() {
                -> pop$
            }
            get_buffer(): String { @@:($.buffer) }
        }
}

var e = @@Editor()
e.type_char("H")
e.type_char("i")
assert(e.get_buffer() as! String == "Hi")
e.undo()
assert(e.get_buffer() as! String == "H")
e.undo()
assert(e.get_buffer() as! String == "")
print("PASS: undo_redo")

@@[target("cpp_17")]

#include <iostream>
#include <cassert>

@@system BracketParser {
    interface:
        open()
        close()
        depth_now(): int
        status(): str

    machine:
        $Flat {
            open() {
                this->depth = this->depth + 1;
                push$
                -> $Nested
            }
            depth_now(): int { @@:(this->depth) }
            status(): str { @@:(std::string("flat")) }
        }

        $Nested {
            open() {
                this->depth = this->depth + 1;
                push$
                -> $Nested
            }
            close() {
                this->depth = this->depth - 1;
                -> pop$
            }
            depth_now(): int { @@:(this->depth) }
            status(): str { @@:(std::string("nested")) }
        }

    domain:
        depth: int = 0
}

int main() {
    auto p = @@BracketParser();
    assert(std::any_cast<std::string>(p.status()) == "flat");
    assert(std::any_cast<int>(p.depth_now()) == 0);
    p.open();
    assert(std::any_cast<std::string>(p.status()) == "nested");
    assert(std::any_cast<int>(p.depth_now()) == 1);
    p.open();
    assert(std::any_cast<int>(p.depth_now()) == 2);
    p.close();
    assert(std::any_cast<int>(p.depth_now()) == 1);
    p.close();
    assert(std::any_cast<std::string>(p.status()) == "flat");
    assert(std::any_cast<int>(p.depth_now()) == 0);
    p.open();
    p.close();
    assert(std::any_cast<std::string>(p.status()) == "flat");
    std::cout << "PASS: pushdown_parser" << std::endl;
    return 0;
}

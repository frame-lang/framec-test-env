@@[target("gdscript")]

extends SceneTree

@@system FixBuySideOrder {
    interface:
        send_new(cl_ord_id: String)
        exec_new(exec_id: String)
        exec_partial_fill(qty: float, px: float)
        exec_fill(qty: float, px: float)
        exec_canceled(exec_id: String)
        get_status(): String
        get_cum_qty(): float
        get_leaves_qty(): float

    machine:
        $Pending {
            send_new(cl_ord_id: String) {
                self.cl_ord_id = cl_ord_id
                self.leaves_qty = self.order_qty
                -> $PendingNew
            }
            get_status(): String { @@:("Pending") }
            get_cum_qty(): float { @@:(self.cum_qty) }
            get_leaves_qty(): float { @@:(self.leaves_qty) }
        }

        $PendingNew {
            exec_new(exec_id: String) { -> $New }
            get_status(): String { @@:("PendingNew") }
            get_cum_qty(): float { @@:(self.cum_qty) }
            get_leaves_qty(): float { @@:(self.leaves_qty) }
        }

        $New {
            exec_partial_fill(qty: float, px: float) {
                self.cum_qty = self.cum_qty + qty
                self.leaves_qty = self.order_qty - self.cum_qty
                -> $PartiallyFilled
            }
            exec_fill(qty: float, px: float) {
                self.cum_qty = self.cum_qty + qty
                self.leaves_qty = 0.0
                -> $Filled
            }
            exec_canceled(exec_id: String) { -> $Canceled }
            get_status(): String { @@:("New") }
            get_cum_qty(): float { @@:(self.cum_qty) }
            get_leaves_qty(): float { @@:(self.leaves_qty) }
        }

        $PartiallyFilled {
            exec_partial_fill(qty: float, px: float) {
                self.cum_qty = self.cum_qty + qty
                self.leaves_qty = self.order_qty - self.cum_qty
                -> $PartiallyFilled
            }
            exec_fill(qty: float, px: float) {
                self.cum_qty = self.cum_qty + qty
                self.leaves_qty = 0.0
                -> $Filled
            }
            exec_canceled(exec_id: String) { -> $Canceled }
            get_status(): String { @@:("PartiallyFilled") }
            get_cum_qty(): float { @@:(self.cum_qty) }
            get_leaves_qty(): float { @@:(self.leaves_qty) }
        }

        $Filled {
            get_status(): String { @@:("Filled") }
            get_cum_qty(): float { @@:(self.cum_qty) }
            get_leaves_qty(): float { @@:(self.leaves_qty) }
        }

        $Canceled {
            get_status(): String { @@:("Canceled") }
            get_cum_qty(): float { @@:(self.cum_qty) }
            get_leaves_qty(): float { @@:(self.leaves_qty) }
        }

    domain:
        cl_ord_id = ""
        order_qty = 100.0
        cum_qty = 0.0
        leaves_qty = 0.0
}

func main():
    var o = @@FixBuySideOrder()
    var failures = 0
    if o.get_status() != "Pending":          print("FAIL: Pending");          failures += 1
    o.send_new("CL-1")
    if o.get_status() != "PendingNew":       print("FAIL: PendingNew");       failures += 1
    if o.get_leaves_qty() != 100.0:           print("FAIL: leaves=100");       failures += 1
    o.exec_new("E-1")
    if o.get_status() != "New":              print("FAIL: New");              failures += 1
    o.exec_partial_fill(40.0, 100.5)
    if o.get_status() != "PartiallyFilled":  print("FAIL: PartiallyFilled");  failures += 1
    if o.get_cum_qty() != 40.0:               print("FAIL: cum=40");           failures += 1
    o.exec_partial_fill(30.0, 100.6)
    if o.get_cum_qty() != 70.0:               print("FAIL: cum=70");           failures += 1
    o.exec_fill(30.0, 100.7)
    if o.get_status() != "Filled":           print("FAIL: Filled");           failures += 1
    if o.get_cum_qty() != 100.0:              print("FAIL: cum=100");          failures += 1
    if o.get_leaves_qty() != 0.0:             print("FAIL: leaves=0");         failures += 1

    if failures > 0:
        print("FAIL: fix_buy_side (" + str(failures) + " failures)")
        quit(1)
    print("PASS: fix_buy_side")

func _init():
    main()
    quit()

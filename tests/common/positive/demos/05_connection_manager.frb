@@target ruby

@@system Connection {
    interface:
        connect(host: str)
        send_data(data: str): str
        disconnect()

    machine:
        $Disconnected {
            connect(host: str) {
                @host = host
                -> $Connecting
            }
        }
        $Connecting {
            $>() {
                puts("Connecting to #{@host}...")
                -> $Connected
            }
        }
        $Connected {
            $>() { puts("Connected to #{@host}") }
            <$() { puts("Disconnecting from #{@host}") }

            send_data(data: str): str {
                @@:("sent '#{data}' to #{@host}")
            }
            disconnect() { -> $Disconnected }
        }

    domain:
        host: str = ""
}

c = Connection.new
c.connect("example.com")
result = c.send_data("hello")
raise "Got: #{result}" unless result == "sent 'hello' to example.com"
c.disconnect()
puts "PASS: connection_manager"

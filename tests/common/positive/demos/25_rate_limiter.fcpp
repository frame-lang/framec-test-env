@@target cpp_17
// Rate Limiter — static operations demo (C++)

#include <iostream>
#include <string>

@@system RateLimiter {
    operations:
        static get_max_requests(): int {
            return 5;
        }
        get_count(): int {
            return this->count;
        }

    interface:
        request(): str
        reset()
        status(): str

    machine:
        $Allowing {
            request(): str {
                this->count = this->count + 1;
                if this->count >= this->max_requests {
                    -> $Throttling
                }
                @@:("allowed")
            }
            reset() {
                this->count = 0;
            }
            status(): str { @@:("allowing") }
        }
        $Throttling {
            request(): str { @@:("throttled") }
            reset() {
                this->count = 0;
                -> $Allowing
            }
            status(): str { @@:("throttling") }
        }

    domain:
        count : int = 0
        max_requests : int = 5
}

int main() {
    auto rl = @@RateLimiter();
    int failures = 0;

    if (rl.status() != std::string("allowing")) {
        std::cout << "FAIL: initial status expected allowing" << std::endl;
        failures++;
    }

    if (RateLimiter::get_max_requests() != 5) {
        std::cout << "FAIL: static get_max_requests expected 5" << std::endl;
        failures++;
    }

    for (int i = 0; i < 4; i++) {
        if (rl.request() != std::string("allowed")) {
            std::cout << "FAIL: request " << (i + 1) << " expected allowed" << std::endl;
            failures++;
        }
    }

    rl.request();
    if (rl.status() != std::string("throttling")) {
        std::cout << "FAIL: should be throttling after 5 requests" << std::endl;
        failures++;
    }

    if (rl.request() != std::string("throttled")) {
        std::cout << "FAIL: request while throttling expected throttled" << std::endl;
        failures++;
    }

    rl.reset();
    if (rl.status() != std::string("allowing")) {
        std::cout << "FAIL: should be allowing after reset" << std::endl;
        failures++;
    }

    if (rl.get_count() != 0) {
        std::cout << "FAIL: count after reset expected 0" << std::endl;
        failures++;
    }

    if (failures > 0) {
        std::cout << "FAIL: rate_limiter (" << failures << " failures)" << std::endl;
        return 1;
    }
    std::cout << "PASS: rate_limiter" << std::endl;
    return 0;
}

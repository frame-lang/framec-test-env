@@target cpp_17

#include <iostream>
#include <string>
#include <algorithm>

@@system RateLimiter {
    operations:
        static tokens_for_rate(rps: int, interval_ms: int): int {
            return std::max(1, (rps * interval_ms) / 1000);
        }
        tokens_remaining(): int {
            return this->tokens;
        }

    interface:
        request(): std::string
        tick()

    machine:
        $Accepting {
            request(): std::string {
                this->tokens = this->tokens - 1;
                @@:(std::string("accepted"))
                if (this->tokens <= 0) {
                    -> $Throttled
                }
            }
            tick() { this->tokens = std::min(this->tokens + 1, this->max_tokens); }
        }
        $Throttled {
            request(): std::string { @@:(std::string("throttled")) }
            tick() {
                this->tokens = this->tokens + 1;
                if (this->tokens > 0) {
                    -> $Accepting
                }
            }
        }

    domain:
        tokens : int = 10
        max_tokens : int = 10
}

int main() {
    int failures = 0;

    if (RateLimiter::tokens_for_rate(100, 50) != 5) { std::cout << "FAIL: static op" << std::endl; failures++; }

    auto rl = @@RateLimiter();
    for (int i = 0; i < 10; i++) { rl.request(); }
    if (rl.request() != "throttled") { std::cout << "FAIL: throttled" << std::endl; failures++; }
    rl.tick();
    if (rl.request() != "accepted") { std::cout << "FAIL: accepted after tick" << std::endl; failures++; }

    if (failures > 0) { std::cout << "FAIL: rate_limiter (" << failures << ")" << std::endl; return 1; }
    std::cout << "PASS: rate_limiter" << std::endl;
    return 0;
}

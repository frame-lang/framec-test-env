@@[target("dart")]

@@system BracketParser {
    interface:
        open()
        close()
        depth_now(): int
        status(): String

    machine:
        $Flat {
            open() {
                this.depth = this.depth + 1;
                push$
                -> $Nested
            }
            depth_now(): int { @@:(this.depth) }
            status(): String { @@:("flat") }
        }

        $Nested {
            open() {
                this.depth = this.depth + 1;
                push$
                -> $Nested
            }
            close() {
                this.depth = this.depth - 1;
                -> pop$
            }
            depth_now(): int { @@:(this.depth) }
            status(): String { @@:("nested") }
        }

    domain:
        depth: int = 0
}

void main() {
    final p = BracketParser();
    if (p.status() != "flat") throw "expected flat";
    if (p.depth_now() != 0) throw "expected 0";
    p.open();
    if (p.status() != "nested") throw "expected nested";
    if (p.depth_now() != 1) throw "expected 1";
    p.open();
    if (p.depth_now() != 2) throw "expected 2";
    p.close();
    if (p.depth_now() != 1) throw "expected 1 after";
    p.close();
    if (p.status() != "flat") throw "expected flat after";
    if (p.depth_now() != 0) throw "expected 0 after";
    p.open();
    p.close();
    if (p.status() != "flat") throw "expected flat re-flat";
    print("PASS: pushdown_parser");
}

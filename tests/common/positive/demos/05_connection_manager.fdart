@@[target("dart")]

@@system Connection {
    interface:
        connect(host: String)
        send(data: String): String
        disconnect()

    machine:
        $Disconnected {
            connect(host: String) {
                this.host = host;
                -> $Connecting
            }
        }
        $Connecting {
            $>() {
                print("Connecting to ${this.host}...");
                -> $Connected
            }
        }
        $Connected {
            $>() { print("Connected to ${this.host}"); }
            <$() { print("Disconnecting from ${this.host}"); }

            send(data: String): String {
                @@:("sent '${data}' to ${this.host}")
            }
            disconnect() { -> $Disconnected }
        }

    domain:
        host: String = ""
}

void main() {
    final c = @@Connection();
    c.connect("example.com");
    final result = c.send("hello") as String;
    assert(result == "sent 'hello' to example.com");
    c.disconnect();
    print("PASS: connection_manager");
}

@@[target("c")]

#include <stdio.h>
#include <stdlib.h>
#include <string.h>

@@system VendingMachine(stock: int = 0) {
    operations:
        get_balance(): int {
            return self->balance;
        }
        get_stock(): int {
            return self->stock;
        }

    interface:
        insert_coin(amount: int)
        select(): char*
        cancel(): int

    machine:
        $Idle {
            insert_coin(amount: int) {
                self->balance = amount;
                -> $HasCredit
            }
            select(): char* { @@:("insert coin first") }
            cancel(): int { @@:(0) }
        }
        $HasCredit {
            insert_coin(amount: int) {
                self->balance = self->balance + amount;
            }
            select(): char* {
                if (self->balance < self->price) {
                    @@:("need more")
                } else if (self->stock <= 0) {
                    @@:("sold out")
                } else {
                    self->stock = self->stock - 1;
                    self->balance = self->balance - self->price;
                    @@:("dispensing")
                    -> $Dispensing
                }
            }
            cancel(): int {
                int refund = self->balance;
                self->balance = 0;
                @@:(refund)
                -> $Idle
            }
        }
        $Dispensing {
            $>() {
                int change = self->balance;
                self->balance = 0;
                if (change > 0) {
                    printf("Change: %d\n", change);
                }
                -> $Idle
            }
        }

    domain:
        balance : int = 0
        stock : int = 0
        price : int = 100
}

int main() {
    VendingMachine* vm = @@VendingMachine(3);
    int failures = 0;

    if (VendingMachine_get_stock(vm) != 3) { printf("FAIL: stock\n"); failures++; }

    if (strcmp(VendingMachine_select(vm), "insert coin first") != 0) {
        printf("FAIL: select without coin\n"); failures++;
    }

    VendingMachine_insert_coin(vm, 100);
    if (strcmp(VendingMachine_select(vm), "dispensing") != 0) {
        printf("FAIL: select with exact coin\n"); failures++;
    }

    if (VendingMachine_get_stock(vm) != 2) { printf("FAIL: stock after buy\n"); failures++; }

    if (failures > 0) { printf("FAIL: vending_machine (%d)\n", failures); return 1; }
    printf("PASS: vending_machine\n");
    return 0;
}

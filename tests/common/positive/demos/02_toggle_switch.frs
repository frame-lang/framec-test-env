@@target rust

@@system Switch {
    interface:
        toggle(): String
        status(): String

    machine:
        $Off {
            toggle(): String {
                @@:("on".to_string())
                -> $On
            }
            status(): String { @@:("off".to_string()) }
        }
        $On {
            toggle(): String {
                @@:("off".to_string())
                -> $Off
            }
            status(): String { @@:("on".to_string()) }
        }
}

fn main() {
    let mut sw = @@Switch();
    assert_eq!(sw.status(), "off", "Expected 'off' from status");
    assert_eq!(sw.toggle(), "on", "Expected 'on' from toggle");
    assert_eq!(sw.toggle(), "off", "Expected 'off' from toggle");
    println!("PASS: toggle_switch");
}

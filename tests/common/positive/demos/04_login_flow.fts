@@target typescript

@@system LoginFlow {
    interface:
        submit(value: str): str

    machine:
        $EnterUsername {
            submit(value: str): str {
                this.username = value
                @@:("enter password")
                -> $EnterPassword
            }
        }
        $EnterPassword {
            submit(value: str): str {
                if (this.username === "admin" && value === "secret") {
                    @@:("welcome")
                    -> $LoggedIn
                } else {
                    @@:("invalid - try again")
                    -> $EnterUsername
                }
            }
        }
        $LoggedIn {
            submit(value: str): str { @@:("already logged in") }
        }

    domain:
        username: str = ""
}

const login = @@LoginFlow();
let r1 = login.submit("admin") as string;
if (r1 !== "enter password") { console.log("FAIL: Expected 'enter password', got '" + r1 + "'"); process.exit(1); }
let r2 = login.submit("wrong") as string;
if (r2 !== "invalid - try again") { console.log("FAIL: Expected 'invalid - try again', got '" + r2 + "'"); process.exit(1); }
let r3 = login.submit("admin") as string;
if (r3 !== "enter password") { console.log("FAIL: Expected 'enter password', got '" + r3 + "'"); process.exit(1); }
let r4 = login.submit("secret") as string;
if (r4 !== "welcome") { console.log("FAIL: Expected 'welcome', got '" + r4 + "'"); process.exit(1); }
console.log("PASS: login_flow");

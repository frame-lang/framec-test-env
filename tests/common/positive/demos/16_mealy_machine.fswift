@@[target("swift")]

@@system MealyDetector {
    interface:
        input(bit: int): String

    machine:
        $S0 {
            input(bit: int): String {
                if (bit == 1) {
                    @@:("0")
                    -> $S1
                } else {
                    @@:("0")
                }
            }
        }
        $S1 {
            input(bit: int): String {
                if (bit == 0) {
                    @@:("1")
                    -> $S0
                } else {
                    @@:("0")
                }
            }
        }
}

var m = @@MealyDetector()
let bits = [1, 0, 1, 1, 0]
let expected = ["0", "1", "0", "0", "1"]
for i in 0..<5 {
    let result = m.input(bits[i]) as! String
    if result != expected[i] {
        fatalError("FAIL: bit=\(bits[i]) expected '\(expected[i])', got '\(result)'")
    }
}
print("PASS: mealy_machine")

@@[target("go")]

package main

import (
	"fmt"
	"os"
)

@@system LaunchController {
    interface:
        countdown_start()
        ignite()
        max_q_passed()
        meco()
        seco()
        do_abort()
        phase(): string
        outcome(): string

    machine:
        $Idle {
            countdown_start() { -> $Countdown }
            phase(): string { @@:("Idle") }
            outcome(): string { @@:("none") }
        }

        $Countdown {
            ignite() { -> $Boost }
            do_abort() {
                s.outcome_str = "scrubbed"
                -> $Aborted
            }
            phase(): string { @@:("Countdown") }
            outcome(): string { @@:("none") }
        }

        $Boost {
            max_q_passed() { -> $Sustain }
            do_abort() {
                s.outcome_str = "RTLS"
                -> $Aborted
            }
            phase(): string { @@:("Boost") }
            outcome(): string { @@:("none") }
        }

        $Sustain {
            meco() { -> $Coast }
            do_abort() {
                s.outcome_str = "ATO"
                -> $Aborted
            }
            phase(): string { @@:("Sustain") }
            outcome(): string { @@:("none") }
        }

        $Coast {
            seco() { -> $Orbit }
            do_abort() {
                s.outcome_str = "TAL"
                -> $Aborted
            }
            phase(): string { @@:("Coast") }
            outcome(): string { @@:("none") }
        }

        $Orbit {
            phase(): string { @@:("Orbit") }
            outcome(): string { @@:("nominal") }
        }

        $Aborted {
            phase(): string { @@:("Aborted") }
            outcome(): string { @@:(s.outcome_str) }
        }

    domain:
        outcome_str: string = ""
}

func main() {
    lc := @@LaunchController()
    lc.Countdown_start()
    lc.Ignite()
    lc.Max_q_passed()
    lc.Meco()
    lc.Seco()
    if lc.Phase() != "Orbit" { fmt.Println("FAIL: Orbit"); os.Exit(1) }
    if lc.Outcome() != "nominal" { fmt.Println("FAIL: nominal"); os.Exit(1) }

    lc2 := @@LaunchController()
    lc2.Countdown_start()
    lc2.Ignite()
    lc2.Do_abort()
    if lc2.Outcome() != "RTLS" { fmt.Println("FAIL: RTLS"); os.Exit(1) }

    lc3 := @@LaunchController()
    lc3.Countdown_start()
    lc3.Ignite()
    lc3.Max_q_passed()
    lc3.Do_abort()
    if lc3.Outcome() != "ATO" { fmt.Println("FAIL: ATO"); os.Exit(1) }

    lc4 := @@LaunchController()
    lc4.Countdown_start()
    lc4.Do_abort()
    if lc4.Outcome() != "scrubbed" { fmt.Println("FAIL: scrubbed"); os.Exit(1) }

    fmt.Println("PASS: launch_sequence")
}

@@target swift

@@system MooreParity {
    interface:
        input(bit: int)
        output(): String

    machine:
        $Even {
            input(bit: int) {
                if (bit == 1) {
                    -> $Odd
                }
            }
            output(): String { @@:("even") }
        }
        $Odd {
            input(bit: int) {
                if (bit == 1) {
                    -> $Even
                }
            }
            output(): String { @@:("odd") }
        }
}

var m = @@MooreParity()
let bits = [1, 0, 1, 1, 0]
let expected = ["odd", "odd", "even", "odd", "odd"]
for i in 0..<5 {
    m.input(bits[i])
    let result = m.output() as! String
    if result != expected[i] {
        fatalError("FAIL: after bit \(bits[i]) expected '\(expected[i])', got '\(result)'")
    }
}
print("PASS: moore_machine")

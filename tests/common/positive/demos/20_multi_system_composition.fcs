@@[target("csharp")]

using System;

@@system Logger {
    interface:
        log(msg: String)

    machine:
        $Active {
            log(msg: String) {
                Console.WriteLine("[LOG] " + msg);
            }
        }
}

@@[main]
@@system App {
    interface:
        start()
        stop()

    machine:
        $Idle {
            start() {
                this.logger.log("App starting");
                -> $Running
            }
        }
        $Running {
            $>() { this.logger.log("App running"); }
            stop() {
                this.logger.log("App stopping");
                -> $Idle
            }
        }

    domain:
        logger: Logger = @@Logger()
}

class Program {
    static void Main(string[] args) {
        var app = @@App();
        app.start();
        app.stop();
        Console.WriteLine("PASS: multi_system_composition");
    }
}

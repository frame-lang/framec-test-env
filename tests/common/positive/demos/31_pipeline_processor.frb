# Pipeline Processor — 5-stage enter handler chain (Ruby)

@@system PipelineProcessor {
    interface:
        start(data: str)
        status(): str
        get_step_count(): int

    machine:
        $Idle {
            start(data: str) {
                self.data = data
                -> $Validate
            }
            status(): str { @@:("idle") }
            get_step_count(): int { @@:(self.step_count) }
        }
        $Validate {
            $>() {
                self.step_count = self.step_count + 1
                -> $Transform
            }
            status(): str { @@:("validate") }
        }
        $Transform {
            $>() {
                self.step_count = self.step_count + 1
                -> $Enrich
            }
            status(): str { @@:("transform") }
        }
        $Enrich {
            $>() {
                self.step_count = self.step_count + 1
                -> $Store
            }
            status(): str { @@:("enrich") }
        }
        $Store {
            $>() {
                self.step_count = self.step_count + 1
                -> $Complete
            }
            status(): str { @@:("store") }
        }
        $Complete {
            status(): str { @@:("complete") }
            get_step_count(): int { @@:(self.step_count) }
            start(data: str) {
                self.data = data
                self.step_count = 0
                -> $Validate
            }
        }

    domain:
        data = ""
        step_count = 0
}

pp = @@PipelineProcessor()
failures = 0

if pp.status() != "idle"
    puts "FAIL: expected idle"
    failures += 1
end

pp.start("batch_1")
if pp.status() != "complete"
    puts "FAIL: expected complete"
    failures += 1
end
if pp.get_step_count() != 4
    puts "FAIL: expected 4 steps, got #{pp.get_step_count()}"
    failures += 1
end

pp.start("batch_2")
if pp.status() != "complete"
    puts "FAIL: expected complete on second run"
    failures += 1
end
if pp.get_step_count() != 4
    puts "FAIL: expected 4 steps on second run"
    failures += 1
end

if failures > 0
    puts "FAIL: pipeline_processor (#{failures} failures)"
    exit(1)
end
puts "PASS: pipeline_processor"

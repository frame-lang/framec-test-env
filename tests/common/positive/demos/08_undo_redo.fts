@@target typescript

@@system Editor {
    interface:
        type_char(c: str)
        undo()
        get_buffer(): str

    machine:
        $Editing {
            $.buffer: str = ""

            type_char(c: str) {
                push$
                $.buffer = $.buffer + c
            }
            undo() {
                -> pop$
            }
            get_buffer(): str { @@:($.buffer) }
        }
}

const e = @@Editor();
e.type_char("H");
e.type_char("i");
if ((e.get_buffer() as string) !== "Hi") { console.log("FAIL"); process.exit(1); }
e.undo();
if ((e.get_buffer() as string) !== "H") { console.log("FAIL"); process.exit(1); }
e.undo();
if ((e.get_buffer() as string) !== "") { console.log("FAIL"); process.exit(1); }
console.log("PASS: undo_redo");

@@[target("php")]

<?php

@@system Connection {
    interface:
        connect(host: str)
        send(data: str): str
        disconnect()

    machine:
        $Disconnected {
            connect(host: str) {
                $this->host = $host;
                -> $Connecting
            }
        }
        $Connecting {
            $>() {
                echo "Connecting to " . $this->host . "...\n";
                -> $Connected
            }
        }
        $Connected {
            $>() { echo "Connected to " . $this->host . "\n"; }
            <$() { echo "Disconnecting from " . $this->host . "\n"; }

            send(data: str): str {
                @@:("sent '" . $data . "' to " . $this->host)
            }
            disconnect() { -> $Disconnected }
        }

    domain:
        host = ""
}

$c = @@Connection();
$c->connect("example.com");
$result = $c->send("hello");
assert($result === "sent 'hello' to example.com", "Got: " . $result);
$c->disconnect();
echo "PASS: connection_manager\n";

@@target dart

@@system Turnstile {
    interface:
        coin()
        push(): String

    machine:
        $Locked {
            coin() { -> $Unlocked }
            push(): String { @@:("locked - insert coin") }
        }
        $Unlocked {
            coin() { }
            push(): String {
                @@:("welcome")
                -> $Locked
            }
        }
}

void main() {
    final t = @@Turnstile();
    if (t.push() as String != "locked - insert coin") {
        throw Exception("Expected 'locked - insert coin'");
    }
    t.coin();
    if (t.push() as String != "welcome") {
        throw Exception("Expected 'welcome'");
    }
    if (t.push() as String != "locked - insert coin") {
        throw Exception("Expected 'locked - insert coin'");
    }
    print("PASS: turnstile");
}

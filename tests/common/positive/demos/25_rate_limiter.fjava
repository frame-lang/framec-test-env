@@target java

@@system RateLimiter {
    operations:
        static tokens_for_rate(rps: int, interval_ms: int): int {
            return Math.max(1, (rps * interval_ms) / 1000);
        }
        tokens_remaining(): int {
            return this.tokens;
        }

    interface:
        request(): String
        tick()

    machine:
        $Accepting {
            request(): String {
                this.tokens = this.tokens - 1;
                @@:("accepted")
                if (this.tokens <= 0) {
                    -> $Throttled
                }
            }
            tick() { this.tokens = Math.min(this.tokens + 1, this.max_tokens); }
        }
        $Throttled {
            request(): String { @@:("throttled") }
            tick() {
                this.tokens = this.tokens + 1;
                if (this.tokens > 0) {
                    -> $Accepting
                }
            }
        }

    domain:
        tokens : int = 10
        max_tokens : int = 10
}

class Main {
    public static void main(String[] args) {
        int failures = 0;
        if (RateLimiter.tokens_for_rate(100, 50) != 5) { System.out.println("FAIL: static op"); failures++; }
        var rl = @@RateLimiter();
        for (int i = 0; i < 10; i++) { rl.request(); }
        if (!((String) rl.request()).equals("throttled")) { System.out.println("FAIL: throttled"); failures++; }
        rl.tick();
        if (!((String) rl.request()).equals("accepted")) { System.out.println("FAIL: accepted"); failures++; }
        if (failures > 0) { System.out.println("FAIL: rate_limiter (" + failures + ")"); System.exit(1); }
        System.out.println("PASS: rate_limiter");
    }
}

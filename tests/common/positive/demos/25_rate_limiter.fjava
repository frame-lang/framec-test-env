@@target java
// Rate Limiter — static operations demo (Java)

@@system RateLimiter {
    operations:
        static get_max_requests(): int {
            return 5;
        }
        get_count(): int {
            return this.count;
        }

    interface:
        request(): String
        reset()
        status(): String

    machine:
        $Allowing {
            request(): String {
                this.count = this.count + 1;
                if this.count >= this.max_requests {
                    -> $Throttling
                }
                @@:("allowed")
            }
            reset() {
                this.count = 0;
            }
            status(): String { @@:("allowing") }
        }
        $Throttling {
            request(): String { @@:("throttled") }
            reset() {
                this.count = 0;
                -> $Allowing
            }
            status(): String { @@:("throttling") }
        }

    domain:
        count : int = 0
        max_requests : int = 5
}

class Main {
    public static void main(String[] args) {
        RateLimiter rl = @@RateLimiter();
        int failures = 0;

        if (!rl.status().equals("allowing")) {
            System.out.println("FAIL: initial status expected allowing");
            failures++;
        }

        if (RateLimiter.get_max_requests() != 5) {
            System.out.println("FAIL: static get_max_requests expected 5");
            failures++;
        }

        for (int i = 0; i < 4; i++) {
            if (!rl.request().equals("allowed")) {
                System.out.println("FAIL: request " + (i + 1) + " expected allowed");
                failures++;
            }
        }

        rl.request();
        if (!rl.status().equals("throttling")) {
            System.out.println("FAIL: should be throttling after 5 requests");
            failures++;
        }

        if (!rl.request().equals("throttled")) {
            System.out.println("FAIL: request while throttling expected throttled");
            failures++;
        }

        rl.reset();
        if (!rl.status().equals("allowing")) {
            System.out.println("FAIL: should be allowing after reset");
            failures++;
        }

        if (rl.get_count() != 0) {
            System.out.println("FAIL: count after reset expected 0");
            failures++;
        }

        if (failures > 0) {
            System.out.println("FAIL: rate_limiter (" + failures + " failures)");
            System.exit(1);
        }
        System.out.println("PASS: rate_limiter");
    }
}

// Self-Calibrating Sensor — @@:self demo (Dart)

@@system Sensor {
    interface:
        calibrate(): str
        reading(): float
        trigger_shutdown()
        attempt_post_shutdown(): str
        status(): str

    machine:
        $Active {
            calibrate(): str {
                double baseline = @@:self.reading();
                this.offset = baseline * -1;
                @@:("calibrated: offset=${this.offset}")
            }

            reading(): float {
                @@:(this.raw_value + this.offset)
            }

            trigger_shutdown() {
                -> $Shutdown
            }

            attempt_post_shutdown(): str {
                this.trace = "before";
                @@:self.trigger_shutdown();
                this.trace = "after";
                @@:(this.trace)
            }

            status(): str { @@:(@@:system.state) }
        }

        $Shutdown {
            status(): str { @@:(@@:system.state) }
        }

    domain:
        raw_value: double = 42.0
        offset: double = 0.0
        trace: String = ""
}

void main() {
    Sensor sensor = @@Sensor();
    int failures = 0;

    double r1 = sensor.reading();
    if ((r1 - 42.0).abs() > 1e-9) {
        print("FAIL: reading() expected 42.0, got $r1");
        failures++;
    }

    String cal = sensor.calibrate();
    if (!cal.contains("calibrated")) {
        print("FAIL: calibrate() expected 'calibrated', got '$cal'");
        failures++;
    }

    double r2 = sensor.reading();
    if (r2.abs() > 1e-9) {
        print("FAIL: reading() after calibrate expected 0.0, got $r2");
        failures++;
    }

    String result = sensor.attempt_post_shutdown();
    if (result != "before") {
        print("FAIL: attempt_post_shutdown() expected 'before', got '$result'");
        failures++;
    }

    String st = sensor.status();
    if (st != "Shutdown") {
        print("FAIL: status() expected 'shutdown', got '$st'");
        failures++;
    }

    if (failures > 0) {
        print("FAIL: self_calibrating_sensor ($failures failures)");
        exit(1);
    }
    print("PASS: self_calibrating_sensor");
}

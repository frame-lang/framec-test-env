@@[target("dart")]

@@system IdempotentReceiver {
    interface:
        deliver(msg_id: String, payload: String): String

    machine:
        $Ready {
            deliver(msg_id: String, payload: String): String {
                if (this.seen.contains(msg_id)) {
                    @@:("duplicate")
                } else {
                    this.seen.add(msg_id);
                    this.process(payload);
                    @@:("accepted")
                }
            }
        }

    actions:
        process(payload: String): void {
            print("processing: $payload");
        }

    domain:
        seen: Set<String> = <String>{}
}

void main() {
    var r = @@IdempotentReceiver();
    if ((r.deliver("m1", "hello") as String) != "accepted")  throw "expected accepted #1";
    if ((r.deliver("m1", "hello") as String) != "duplicate") throw "expected duplicate #1";
    if ((r.deliver("m2", "world") as String) != "accepted")  throw "expected accepted #2";
    if ((r.deliver("m2", "world") as String) != "duplicate") throw "expected duplicate #2";
    print("PASS: idempotent_receiver");
}

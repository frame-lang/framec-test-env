@@target cpp_17

#include <iostream>
#include <string>
#include <cassert>

@@system Agent {
    interface:
        tick()
        threat()
        safe()
        get_log(): str

    machine:
        $Exploring {
            tick() {
                this->action_log = this->action_log + "explore,";
            }
            threat() {
                this->action_log = this->action_log + "flee,";
                -> $Fleeing
            }
            get_log(): str { @@:(std::string(this->action_log)) }
        }
        $Fleeing {
            tick() {
                this->action_log = this->action_log + "run,";
            }
            safe() {
                this->action_log = this->action_log + "resume,";
                -> $Exploring
            }
            get_log(): str { @@:(std::string(this->action_log)) }
        }

    domain:
        action_log: std::string = ""
}

int main() {
    auto a = @@Agent();
    a.tick();
    a.tick();
    a.threat();
    a.tick();
    a.safe();
    auto result = std::any_cast<std::string>(a.get_log());
    std::string expected = "explore,explore,flee,run,resume,";
    assert(result == expected);
    printf("PASS: ai_agent\n");
    return 0;
}

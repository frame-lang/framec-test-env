@@target rust

@@system Retrier {
    interface:
        start()
        status(): String

    machine:
        $Idle {
            start() {
                self.attempts = 0;
                -> $Trying
            }
        }
        $Trying {
            $>() {
                self.attempts = self.attempts + 1;
                // try_operation always fails — inlined for Rust
                if self.attempts >= self.max_retries {
                    -> $Failed
                } else {
                    -> $Trying
                }
            }
            status(): String { @@:("trying".to_string()) }
        }
        $Succeeded {
            status(): String { @@:("succeeded".to_string()) }
        }
        $Failed {
            status(): String { @@:("failed after max retries".to_string()) }
        }

    domain:
        attempts: i32 = 0
        max_retries: i32 = 3
}

fn main() {
    let mut r = @@Retrier();
    r.start();
    let result = r.status();
    assert_eq!(result, "failed after max retries");
    assert_eq!(r.attempts, 3);
    println!("PASS: retry_with_backoff");
}

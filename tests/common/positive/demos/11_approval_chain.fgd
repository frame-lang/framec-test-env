@@target gdscript

extends SceneTree

@@system ApprovalChain {
    interface:
        submit()
        approve(reviewer: str)
        reject(reviewer: str)
        status(): str

    machine:
        $Draft {
            submit() { -> $Review1 }
            status(): str { @@:("draft") }
        }
        $Review1 {
            approve(reviewer: str) {
                print("Approved by " + reviewer)
                -> $Review2
            }
            reject(reviewer: str) {
                print("Rejected by " + reviewer)
                -> $Draft
            }
            status(): str { @@:("awaiting first review") }
        }
        $Review2 {
            approve(reviewer: str) {
                print("Approved by " + reviewer)
                -> $Published
            }
            reject(reviewer: str) {
                print("Rejected by " + reviewer)
                -> $Draft
            }
            status(): str { @@:("awaiting second review") }
        }
        $Published {
            status(): str { @@:("published") }
        }
}

func _init():
    var doc = @@ApprovalChain()
    doc.submit()
    assert(doc.status() == "awaiting first review")
    doc.approve("Alice")
    assert(doc.status() == "awaiting second review")
    doc.reject("Bob")
    assert(doc.status() == "draft")
    doc.submit()
    doc.approve("Alice")
    doc.approve("Bob")
    assert(doc.status() == "published")
    print("PASS: approval_chain")
    quit()

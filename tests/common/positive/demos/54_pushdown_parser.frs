@@[target("rust")]

@@system BracketParser {
    interface:
        open()
        close()
        depth_now(): i32
        status(): String

    machine:
        $Flat {
            open() {
                self.depth = self.depth + 1;
                push$
                -> $Nested
            }
            depth_now(): i32 { @@:(self.depth) }
            status(): String { @@:("flat".to_string()) }
        }

        $Nested {
            open() {
                self.depth = self.depth + 1;
                push$
                -> $Nested
            }
            close() {
                self.depth = self.depth - 1;
                -> pop$
            }
            depth_now(): i32 { @@:(self.depth) }
            status(): String { @@:("nested".to_string()) }
        }

    domain:
        depth: i32 = 0
}

fn main() {
    let mut p = @@BracketParser();
    assert_eq!(p.status(), "flat");
    assert_eq!(p.depth_now(), 0);
    p.open();
    assert_eq!(p.status(), "nested");
    assert_eq!(p.depth_now(), 1);
    p.open();
    assert_eq!(p.depth_now(), 2);
    p.close();
    assert_eq!(p.depth_now(), 1);
    p.close();
    assert_eq!(p.status(), "flat");
    assert_eq!(p.depth_now(), 0);
    p.open();
    p.close();
    assert_eq!(p.status(), "flat");
    println!("PASS: pushdown_parser");
}

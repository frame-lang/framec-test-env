@@[target("erlang")]

@@system ContentBasedRouter {
    interface:
        route(kind: str, payload: str): str

    machine:
        $Routing {
            route(kind: str, payload: str): str {
                if kind == "order" {
                    self.to_orders(payload)
                    @@:("orders")
                } else {
                    if kind == "refund" {
                        self.to_refunds(payload)
                        @@:("refunds")
                    } else {
                        self.to_dlq(payload)
                        @@:("dlq")
                    }
                }
            }
        }

    actions:
        to_orders(p)  { io:format("-> orders:  ~s~n", [P]) }
        to_refunds(p) { io:format("-> refunds: ~s~n", [P]) }
        to_dlq(p)     { io:format("-> dlq:     ~s~n", [P]) }
}

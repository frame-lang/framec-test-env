@@target ruby

@@system MooreParity {
    interface:
        input(bit: int)
        output(): str

    machine:
        $Even {
            input(bit: int) {
                if bit == 1
                    -> $Odd
                end
            }
            output(): str { @@:("even") }
        }
        $Odd {
            input(bit: int) {
                if bit == 1
                    -> $Even
                end
            }
            output(): str { @@:("odd") }
        }
}

m = MooreParity.new
bits = [1, 0, 1, 1, 0]
expected = ["odd", "odd", "even", "odd", "odd"]
bits.each_with_index do |bit, i|
    m.input(bit)
    result = m.output()
    raise "FAIL: after bit #{bit} expected '#{expected[i]}', got '#{result}'" unless result == expected[i]
end
puts "PASS: moore_machine"

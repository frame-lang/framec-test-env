@@[target("ruby")]

@@system LoginFlow {
    interface:
        submit(value: str): str

    machine:
        $EnterUsername {
            submit(value: str): str {
                @username = value
                @@:("enter password")
                -> $EnterPassword
            }
        }
        $EnterPassword {
            submit(value: str): str {
                if authenticate(@username, value)
                    @@:("welcome")
                    -> $LoggedIn
                else
                    @@:("invalid - try again")
                    -> $EnterUsername
                end
            }
        }
        $LoggedIn {
            submit(value: str): str { @@:("already logged in") }
        }

    actions:
        authenticate(user, password) {
            user == "admin" && password == "secret"
        }

    domain:
        username: str = ""
}

login = LoginFlow.new
r1 = login.submit("admin")
raise "Expected 'enter password', got '#{r1}'" unless r1 == "enter password"
r2 = login.submit("wrong")
raise "Expected 'invalid - try again', got '#{r2}'" unless r2 == "invalid - try again"
r3 = login.submit("admin")
raise "Expected 'enter password', got '#{r3}'" unless r3 == "enter password"
r4 = login.submit("secret")
raise "Expected 'welcome', got '#{r4}'" unless r4 == "welcome"
puts "PASS: login_flow"

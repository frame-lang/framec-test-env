@@target swift

import Foundation

@@persist
@@system Session {
    interface:
        login(user: String)
        logout()
        who(): String

    machine:
        $LoggedOut {
            login(user: String) {
                self.user = user
                -> $LoggedIn
            }
            who(): String { @@:("nobody") }
        }
        $LoggedIn {
            logout() {
                self.user = ""
                -> $LoggedOut
            }
            who(): String { @@:(self.user) }
        }

    domain:
        user: String = ""
}

var s = @@Session()
s.login("alice")
if s.who() as! String != "alice" {
    fatalError("Expected 'alice'")
}
let data = s.saveState()
var s2 = Session.restoreState(data)
if s2.who() as! String != "alice" {
    fatalError("Expected 'alice' after restore")
}
print("PASS: session_persistence")

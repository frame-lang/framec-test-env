<?php
@@[target("php")]

@@system RateLimiter {
    operations:
        static tokens_for_rate(rps, interval_ms) {
            return max(1, intdiv($rps * $interval_ms, 1000));
        }
        tokens_remaining() {
            return $this->tokens;
        }

    interface:
        request(): string = "error"
        tick()

    machine:
        $Accepting {
            request(): string {
                $this->tokens = $this->tokens - 1;
                @@:("accepted")
                if ($this->tokens <= 0) {
                    -> $Throttled
                }
            }
            tick() { $this->tokens = min($this->tokens + 1, $this->max_tokens); }
        }
        $Throttled {
            request(): string { @@:("throttled") }
            tick() {
                $this->tokens = $this->tokens + 1;
                if ($this->tokens > 0) {
                    -> $Accepting
                }
            }
        }

    domain:
        tokens = 10
        max_tokens = 10
}

$failures = 0;
if (RateLimiter::tokens_for_rate(100, 50) !== 5) { echo "FAIL: static op\n"; $failures++; }
$rl = @@RateLimiter();
for ($i = 0; $i < 10; $i++) { $rl->request(); }
if ($rl->request() !== "throttled") { echo "FAIL: throttled\n"; $failures++; }
$rl->tick();
if ($rl->request() !== "accepted") { echo "FAIL: accepted after tick\n"; $failures++; }

if ($failures > 0) { echo "FAIL: rate_limiter ($failures)\n"; exit(1); }
echo "PASS: rate_limiter\n";

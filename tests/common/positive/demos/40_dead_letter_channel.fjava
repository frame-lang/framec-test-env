@@[target("java")]

@@[persist]
@@system DeadLetterProcessor {
    operations:
        @@[save]
        save_state(): String {}

        @@[load]
        restore_state(data: String) {}

    interface:
        accept(msg_id: String, payload: String): String
        process_tick(): String
        reset()

    machine:
        $Idle {
            accept(msg_id: String, payload: String): String {
                this.msg_id = msg_id;
                this.payload = payload;
                this.attempts = 0;
                @@:("accepted")
                -> $Processing
            }
            process_tick(): String { @@:("idle") }
        }

        $Processing {
            $>() {
                this.attempts = this.attempts + 1;
            }
            process_tick(): String {
                if (this.try_process(this.payload)) {
                    @@:("ok")
                    -> "success" $Done
                } else {
                    if (this.attempts >= this.max_attempts) {
                        @@:("dead_lettered")
                        -> "exhausted" $DeadLettered
                    } else {
                        @@:("retrying")
                        -> "retry" $Processing
                    }
                }
            }
        }

        $Done {
            process_tick(): String { @@:("done") }
            reset() { -> $Idle }
        }

        $DeadLettered {
            $>() {
                this.to_dlq(this.msg_id, this.payload);
            }
            process_tick(): String { @@:("dead_lettered") }
            reset() { -> $Idle }
        }

    actions:
        try_process(payload: String): boolean {
            return false;
        }
        to_dlq(msg_id: String, payload: String) {
            System.out.println("DLQ <- " + msg_id + ": " + payload);
        }

    domain:
        msg_id: String = ""
        payload: String = ""
        attempts: int = 0
        max_attempts: int = 3
}

class Main {
    public static void main(String[] args) {
        var p = @@DeadLetterProcessor();
        if (!((String) p.accept("m-42", "flaky work")).equals("accepted")) throw new RuntimeException("expected accepted");
        if (!((String) p.process_tick()).equals("retrying"))               throw new RuntimeException("expected retrying #1");
        if (!((String) p.process_tick()).equals("retrying"))               throw new RuntimeException("expected retrying #2");

        var data = (String) p.save_state();
        var p2 = new DeadLetterProcessor();
        p2.restore_state(data);
        if (!((String) p2.process_tick()).equals("dead_lettered"))         throw new RuntimeException("expected dead_lettered");
        System.out.println("PASS: dead_letter_channel");
    }
}

@@[target("cpp_17")]

#include <iostream>
#include <string>

@@system Thermostat {
    interface:
        set_temp(target: int)
        tick()
        status(): std::string

    machine:
        $Off {
            set_temp(target: int) {
                this->target = target;
                -> $LowHeat
            }
            status(): std::string { @@:(std::string("off")) }
        }
        $LowHeat => $On {
            $>() { this->heat_rate = 1; }
            status(): std::string { @@:(std::string("low heat")) }
            => $^
        }
        $HighHeat => $On {
            $>() { this->heat_rate = 2; }
            status(): std::string { @@:(std::string("high heat")) }
            => $^
        }
        $On {
            tick() {
                this->current = this->current + this->heat_rate;
                if (this->current >= this->target) {
                    this->current = this->target;
                    -> $Cooling
                } else if (this->target - this->current > 5) {
                    if (this->heat_rate < 2) {
                        -> $HighHeat
                    }
                } else if (this->target - this->current <= 3) {
                    if (this->heat_rate > 1) {
                        -> $LowHeat
                    }
                }
            }
            set_temp(target: int) { this->target = target; }
        }
        $Cooling {
            $>() { this->heat_rate = 0; }
            tick() {
                this->current = this->current - 1;
                if (this->current <= this->target) {
                    -> $Off
                }
            }
            status(): std::string { @@:(std::string("cooling")) }
        }

    domain:
        current : int = 65
        target : int = 65
        heat_rate : int = 0
}

int main() {
    auto t = @@Thermostat();
    int failures = 0;

    if (t.status() != "off") { std::cout << "FAIL: initial" << std::endl; failures++; }

    t.set_temp(75);
    bool cooled = false;
    for (int i = 0; i < 20; i++) {
        t.tick();
        auto s = t.status();
        if (s == "cooling" || s == "off") { cooled = true; }
    }
    if (!cooled) { std::cout << "FAIL: never cooled" << std::endl; failures++; }

    if (failures > 0) { std::cout << "FAIL: thermostat" << std::endl; return 1; }
    std::cout << "PASS: thermostat" << std::endl;
    return 0;
}

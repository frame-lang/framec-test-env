@@[target("dart")]

@@system TrafficLight {
    interface:
        next(): String

    machine:
        $Green {
            next(): String {
                @@:("green")
                -> $Yellow
            }
        }
        $Yellow {
            next(): String {
                @@:("yellow")
                -> $Red
            }
        }
        $Red {
            next(): String {
                @@:("red")
                -> $Green
            }
        }
}

void main() {
    final light = @@TrafficLight();
    List<String> results = [];
    for (int i = 0; i < 6; i++) {
        results.add(light.next() as String);
    }
    final expected = ["green", "yellow", "red", "green", "yellow", "red"];
    for (int i = 0; i < 6; i++) {
        if (results[i] != expected[i]) {
            throw Exception("Step $i: expected ${expected[i]} got ${results[i]}");
        }
    }
    print("PASS: traffic_light");
}

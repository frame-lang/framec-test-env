@@target java
// Graceful Shutdown — enter handler chain + HSM demo (Java)

@@system GracefulShutdown {
    interface:
        tick(): String
        status(): String

    machine:
        $Starting {
            $>() {
                this.log_count = this.log_count + 1;
                -> $Running
            }
            status(): String { @@:("starting") }
        }
        $Running => $Active {
            $>() {
                this.log_count = this.log_count + 1;
            }
            tick(): String {
                this.cycles = this.cycles + 1;
                if this.cycles >= this.max_cycles {
                    -> $ShuttingDown
                }
                @@:("running")
            }
            status(): String { @@:("running") }
            => $^
        }
        $Active {
            tick(): String { @@:("active_tick") }
        }
        $ShuttingDown {
            $>() {
                this.log_count = this.log_count + 1;
            }
            tick(): String { @@:("shutting_down") }
            status(): String { @@:("shutting_down") }
        }

    domain:
        cycles : int = 0
        max_cycles : int = 3
        log_count : int = 0
}

class Main {
    public static void main(String[] args) {
        GracefulShutdown gs = @@GracefulShutdown();
        int failures = 0;

        if (!gs.status().equals("running")) {
            System.out.println("FAIL: status after init expected running, got " + gs.status());
            failures++;
        }

        if (gs.log_count < 2) {
            System.out.println("FAIL: log_count expected >= 2, got " + gs.log_count);
            failures++;
        }

        String r1 = gs.tick();
        if (!r1.equals("running")) {
            System.out.println("FAIL: tick 1 expected running, got " + r1);
            failures++;
        }

        gs.tick();
        gs.tick();

        if (!gs.status().equals("shutting_down")) {
            System.out.println("FAIL: should be shutting_down after max_cycles ticks");
            failures++;
        }

        String r2 = gs.tick();
        if (!r2.equals("shutting_down")) {
            System.out.println("FAIL: tick after shutdown expected shutting_down, got " + r2);
            failures++;
        }

        if (failures > 0) {
            System.out.println("FAIL: graceful_shutdown (" + failures + " failures)");
            System.exit(1);
        }
        System.out.println("PASS: graceful_shutdown");
    }
}

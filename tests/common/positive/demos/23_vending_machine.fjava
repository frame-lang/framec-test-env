@@target java

@@system VendingMachine(stock: int = 0) {
    operations:
        get_balance(): int {
            return this.balance;
        }
        get_stock(): int {
            return this.stock;
        }

    interface:
        insert_coin(amount: int)
        select(): String
        cancel(): int

    machine:
        $Idle {
            insert_coin(amount: int) {
                this.balance = amount;
                -> $HasCredit
            }
            select(): String { @@:("insert coin first") }
            cancel(): int { @@:(0) }
        }
        $HasCredit {
            insert_coin(amount: int) {
                this.balance = this.balance + amount;
            }
            select(): String {
                if (this.balance < this.price) {
                    @@:("need more")
                } else if (this.stock <= 0) {
                    @@:("sold out")
                } else {
                    this.stock = this.stock - 1;
                    this.balance = this.balance - this.price;
                    @@:("dispensing")
                    -> $Dispensing
                }
            }
            cancel(): int {
                var refund = this.balance;
                this.balance = 0;
                @@:(refund)
                -> $Idle
            }
        }
        $Dispensing {
            $>() {
                var change = this.balance;
                this.balance = 0;
                if (change > 0) {
                    System.out.println("Change: " + change);
                }
                -> $Idle
            }
        }

    domain:
        balance : int = 0
        stock : int = 0
        price : int = 100
}

class Main {
    public static void main(String[] args) {
        var vm = @@VendingMachine(3);
        int failures = 0;

        if ((int) vm.get_stock() != 3) { System.out.println("FAIL: stock"); failures++; }

        if (!((String) vm.select()).equals("insert coin first")) {
            System.out.println("FAIL: select without coin"); failures++;
        }

        vm.insert_coin(100);
        if (!((String) vm.select()).equals("dispensing")) {
            System.out.println("FAIL: select with coin"); failures++;
        }

        if ((int) vm.get_stock() != 2) { System.out.println("FAIL: stock after buy"); failures++; }

        if (failures > 0) { System.out.println("FAIL: vending_machine (" + failures + ")"); System.exit(1); }
        System.out.println("PASS: vending_machine");
    }
}

@@[target("csharp")]


@@system Turnstile {
    interface:
        coin()
        push(): String

    machine:
        $Locked {
            coin() { -> $Unlocked }
            push(): String { @@:("locked - insert coin") }
        }
        $Unlocked {
            coin() { }
            push(): String {
                @@:("welcome")
                -> $Locked
            }
        }
}

class Program {
    static void Main(string[] args) {
        var t = @@Turnstile();
        if ((string) t.push() != "locked - insert coin") {
            throw new Exception("Expected 'locked - insert coin'");
        }
        t.coin();
        if ((string) t.push() != "welcome") {
            throw new Exception("Expected 'welcome'");
        }
        if ((string) t.push() != "locked - insert coin") {
            throw new Exception("Expected 'locked - insert coin'");
        }
        Console.WriteLine("PASS: turnstile");
    }
}

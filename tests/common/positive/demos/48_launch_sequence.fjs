@@[target("javascript")]

@@system LaunchController {
    interface:
        countdown_start()
        ignite()
        max_q_passed()
        meco()
        seco()
        abort()
        phase()
        outcome()

    machine:
        $Idle {
            countdown_start() { -> $Countdown }
            phase() { @@:("Idle") }
            outcome() { @@:("none") }
        }

        $Countdown {
            ignite() { -> $Boost }
            abort() {
                this.outcome_str = "scrubbed";
                -> $Aborted
            }
            phase() { @@:("Countdown") }
            outcome() { @@:("none") }
        }

        $Boost {
            max_q_passed() { -> $Sustain }
            abort() {
                this.outcome_str = "RTLS";
                -> $Aborted
            }
            phase() { @@:("Boost") }
            outcome() { @@:("none") }
        }

        $Sustain {
            meco() { -> $Coast }
            abort() {
                this.outcome_str = "ATO";
                -> $Aborted
            }
            phase() { @@:("Sustain") }
            outcome() { @@:("none") }
        }

        $Coast {
            seco() { -> $Orbit }
            abort() {
                this.outcome_str = "TAL";
                -> $Aborted
            }
            phase() { @@:("Coast") }
            outcome() { @@:("none") }
        }

        $Orbit {
            phase() { @@:("Orbit") }
            outcome() { @@:("nominal") }
        }

        $Aborted {
            phase() { @@:("Aborted") }
            outcome() { @@:(this.outcome_str) }
        }

    domain:
        outcome_str = ""
}

const lc = @@LaunchController();
lc.countdown_start();
lc.ignite();
lc.max_q_passed();
lc.meco();
lc.seco();
if (lc.phase() !== "Orbit") throw new Error("expected Orbit");
if (lc.outcome() !== "nominal") throw new Error("expected nominal");

const lc2 = @@LaunchController();
lc2.countdown_start();
lc2.ignite();
lc2.abort();
if (lc2.outcome() !== "RTLS") throw new Error("expected RTLS");

const lc3 = @@LaunchController();
lc3.countdown_start();
lc3.ignite();
lc3.max_q_passed();
lc3.abort();
if (lc3.outcome() !== "ATO") throw new Error("expected ATO");

const lc4 = @@LaunchController();
lc4.countdown_start();
lc4.abort();
if (lc4.outcome() !== "scrubbed") throw new Error("expected scrubbed");

console.log("PASS: launch_sequence");

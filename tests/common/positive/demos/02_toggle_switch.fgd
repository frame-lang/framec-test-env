@@[target("gdscript")]

extends SceneTree

@@system Switch {
    interface:
        toggle(): str
        status(): str

    machine:
        $Off {
            toggle(): str {
                @@:("on")
                -> $On
            }
            status(): str { @@:("off") }
        }
        $On {
            toggle(): str {
                @@:("off")
                -> $Off
            }
            status(): str { @@:("on") }
        }
}

func _init():
    var sw = @@Switch()
    assert(sw.status() == "off", "Expected 'off' from status")
    assert(sw.toggle() == "on", "Expected 'on' from toggle")
    assert(sw.toggle() == "off", "Expected 'off' from toggle")
    print("PASS: toggle_switch")
    quit()

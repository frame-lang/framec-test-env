@@[target("erlang")]

@@system TestHarness {
    operations:
        current_state(): str {
            @@:(@@:system.state)
        }

    interface:
        run()
        pass_test()
        fail(reason: str)
        get_state(): str
        get_result(): str

    machine:
        $Ready {
            run() {
                self.result = ""
                -> $Running
            }
            get_state(): str { @@:("ready") }
            get_result(): str { @@:(self.result) }
        }
        $Running {
            pass_test() {
                self.result = "pass"
                -> $Passed
            }
            fail(reason: str) {
                self.result = reason
                -> $Failed
            }
            get_state(): str { @@:("running") }
            get_result(): str { @@:("") }
        }
        $Passed {
            run() {
                self.result = ""
                -> $Running
            }
            get_state(): str { @@:("passed") }
            get_result(): str { @@:(self.result) }
        }
        $Failed {
            run() {
                self.result = ""
                -> $Running
            }
            get_state(): str { @@:("failed") }
            get_result(): str { @@:(self.result) }
        }

    domain:
        result = ""
}

@@[target("gdscript")]

extends SceneTree

@@system RobotArm {
    interface:
        set_manual()
        set_auto()
        e_stop()
        reset_e_stop()
        status(): String

    machine:
        $Manual => $Operational {
            set_auto() { -> $Auto }
            status(): String { @@:("Manual") }
            => $^
        }

        $Auto => $Operational {
            set_manual() { -> $Manual }
            status(): String { @@:("Auto") }
            => $^
        }

        $Operational {
            e_stop() { -> $EStop }
            status(): String { @@:("Operational") }
        }

        $EStop {
            reset_e_stop() { -> $Manual }
            status(): String { @@:("EStop") }
        }

    domain:
}

func main():
    var arm = @@RobotArm()
    var failures = 0
    if arm.status() != "Manual": print("FAIL: Manual"); failures += 1
    arm.e_stop()
    if arm.status() != "EStop": print("FAIL: EStop"); failures += 1
    arm.reset_e_stop()
    if arm.status() != "Manual": print("FAIL: Manual2"); failures += 1
    arm.set_auto()
    if arm.status() != "Auto": print("FAIL: Auto"); failures += 1
    arm.e_stop()
    if arm.status() != "EStop": print("FAIL: EStop from Auto"); failures += 1

    if failures > 0:
        print("FAIL: robot_arm (" + str(failures) + " failures)")
        quit(1)
    print("PASS: robot_arm")

func _init():
    main()
    quit()

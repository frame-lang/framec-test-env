@@[target("javascript")]

@@system RobotArm {
    interface:
        set_manual()
        set_auto()
        e_stop()
        reset_e_stop()
        status()

    machine:
        $Manual => $Operational {
            set_auto() { -> $Auto }
            status() { @@:("Manual") }
            => $^
        }

        $Auto => $Operational {
            set_manual() { -> $Manual }
            status() { @@:("Auto") }
            => $^
        }

        $Operational {
            e_stop() { -> $EStop }
            status() { @@:("Operational") }
        }

        $EStop {
            reset_e_stop() { -> $Manual }
            status() { @@:("EStop") }
        }

    domain:
}

const arm = @@RobotArm();
if (arm.status() !== "Manual") throw new Error("expected Manual");
arm.e_stop();
if (arm.status() !== "EStop") throw new Error("expected EStop");
arm.reset_e_stop();
if (arm.status() !== "Manual") throw new Error("expected Manual");
arm.set_auto();
if (arm.status() !== "Auto") throw new Error("expected Auto");
arm.e_stop();
if (arm.status() !== "EStop") throw new Error("expected EStop from Auto");
console.log("PASS: robot_arm");

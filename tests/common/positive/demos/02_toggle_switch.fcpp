@@target cpp_17

#include <iostream>
#include <string>
#include <cassert>

@@system Switch {
    interface:
        toggle(): str
        status(): str

    machine:
        $Off {
            toggle(): str {
                @@:(std::string("on"))
                -> $On
            }
            status(): str { @@:(std::string("off")) }
        }
        $On {
            toggle(): str {
                @@:(std::string("off"))
                -> $Off
            }
            status(): str { @@:(std::string("on")) }
        }
}

int main() {
    auto sw = @@Switch();
    assert(std::any_cast<std::string>(sw.status()) == "off");
    assert(std::any_cast<std::string>(sw.toggle()) == "on");
    assert(std::any_cast<std::string>(sw.toggle()) == "off");
    printf("PASS: toggle_switch\n");
    return 0;
}

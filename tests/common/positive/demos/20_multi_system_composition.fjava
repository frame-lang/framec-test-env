@@target java

@@system Logger {
    interface:
        log(msg: String)

    machine:
        $Active {
            log(msg: String) {
                System.out.println("[LOG] " + msg);
            }
        }
}

@@system App {
    interface:
        start()
        stop()

    machine:
        $Idle {
            start() {
                this.logger.log("App starting");
                -> $Running
            }
        }
        $Running {
            $>() { this.logger.log("App running"); }
            stop() {
                this.logger.log("App stopping");
                -> $Idle
            }
        }

    domain:
        logger: Logger = new Logger()
}

class Main {
    public static void main(String[] args) {
        var app = new App();
        app.start();
        app.stop();
        System.out.println("PASS: multi_system_composition");
    }
}

@@[target("csharp")]


@@system VendingMachine(stock: int = 0) {
    operations:
        GetBalance(): int {
            return this.balance;
        }
        GetStock(): int {
            return this.stock;
        }

    interface:
        InsertCoin(amount: int)
        Select(): string
        Cancel(): int

    machine:
        $Idle {
            InsertCoin(amount: int) {
                this.balance = amount;
                -> $HasCredit
            }
            Select(): string {
                @@:("insert coin first")
            }
            Cancel(): int {
                @@:(0)
            }
        }

        $HasCredit {
            InsertCoin(amount: int) {
                this.balance = this.balance + amount;
            }
            Select(): string {
                if (this.balance < this.price) {
                    @@:("need more")
                } else if (this.stock <= 0) {
                    @@:("sold out")
                } else {
                    this.stock = this.stock - 1;
                    this.balance = this.balance - this.price;
                    @@:("dispensing")
                    -> $Dispensing
                }
            }
            Cancel(): int {
                var refund = this.balance;
                this.balance = 0;
                @@:(refund)
                -> $Idle
            }
        }

        $Dispensing {
            $>() {
                var change = this.balance;
                this.balance = 0;
                if (change > 0) {
                    Console.WriteLine("Change: " + change);
                }
                -> $Idle
            }
        }

    domain:
        balance : int = 0
        stock : int = 0
        price : int = 100
}

class Program {
    static void Main(string[] args) {
        var vm = @@VendingMachine(3);
        int failures = 0;

        // Verify initial stock via operation
        if ((int) vm.GetStock() != 3) {
            Console.WriteLine("FAIL: initial stock expected 3, got " + vm.GetStock());
            failures++;
        }

        // Select without inserting coin
        var r1 = (string) vm.Select();
        if (r1 != "insert coin first") {
            Console.WriteLine("FAIL: expected 'insert coin first', got '" + r1 + "'");
            failures++;
        }

        // Insert coin and select
        vm.InsertCoin(100);
        var r2 = (string) vm.Select();
        if (r2 != "dispensing") {
            Console.WriteLine("FAIL: expected 'dispensing', got '" + r2 + "'");
            failures++;
        }

        // Verify stock decremented
        if ((int) vm.GetStock() != 2) {
            Console.WriteLine("FAIL: stock after buy expected 2, got " + vm.GetStock());
            failures++;
        }

        // Insert coin, cancel, get refund
        vm.InsertCoin(50);
        var refund = (int) vm.Cancel();
        if (refund != 50) {
            Console.WriteLine("FAIL: refund expected 50, got " + refund);
            failures++;
        }

        if (failures > 0) {
            Console.WriteLine("FAIL: vending_machine (" + failures + " failures)");
            Environment.Exit(1);
        }
        Console.WriteLine("PASS: vending_machine");
    }
}

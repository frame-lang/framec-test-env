@@[target("lua")]

@@[persist(string)]
@@[save(save_state)]
@@[load(restore_state)]
@@system DeadLetterProcessor {
    interface:
        accept(msg_id: str, payload: str): str
        process_tick(): str
        reset()

    machine:
        $Idle {
            accept(msg_id: str, payload: str): str {
                self.msg_id = msg_id
                self.payload = payload
                self.attempts = 0
                @@:("accepted")
                -> $Processing
            }
            process_tick(): str { @@:("idle") }
        }

        $Processing {
            $>() {
                self.attempts = self.attempts + 1
            }
            process_tick(): str {
                if self:try_process(self.payload) then
                    @@:("ok")
                    -> "success" $Done
                else
                    if self.attempts >= self.max_attempts then
                        @@:("dead_lettered")
                        -> "exhausted" $DeadLettered
                    else
                        @@:("retrying")
                        -> "retry" $Processing
                    end
                end
            }
        }

        $Done {
            process_tick(): str { @@:("done") }
            reset() { -> $Idle }
        }

        $DeadLettered {
            $>() {
                self:to_dlq(self.msg_id, self.payload)
            }
            process_tick(): str { @@:("dead_lettered") }
            reset() { -> $Idle }
        }

    actions:
        try_process(payload) {
            return false
        }
        to_dlq(msg_id, payload) {
            print("DLQ <- " .. msg_id .. ": " .. payload)
        }

    domain:
        msg_id: str = ""
        payload: str = ""
        attempts: int = 0
        max_attempts: int = 3
}

local p = DeadLetterProcessor.new()
assert(p:accept("m-42", "flaky work") == "accepted", "expected accepted")
assert(p:process_tick() == "retrying",                "expected retrying #1")
assert(p:process_tick() == "retrying",                "expected retrying #2")

local data = p:save_state()
local p2 = DeadLetterProcessor:new()
p2:restore_state(data)
assert(p2:process_tick() == "dead_lettered",          "expected dead_lettered")
print("PASS: dead_letter_channel")

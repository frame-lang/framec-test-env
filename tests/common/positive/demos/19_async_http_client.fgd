@@target gdscript
@@skip -- GDScript async codegen not yet implemented in Frame

extends SceneTree

@@system AsyncWorker {
    interface:
        start()
        get_status(): str

    machine:
        $Idle {
            start() { -> $Working }
            get_status(): str { @@:("idle") }
        }
        $Working {
            get_status(): str { @@:("working") }
        }
}

func _init():
    print("SKIP: async_http_client -- GDScript async codegen not yet implemented")
    quit()

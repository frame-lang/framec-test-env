@@target cpp_17

#include <iostream>
#include <string>
#include <cassert>

@@system VideoPlayer {
    interface:
        play()
        pause()
        stop()
        status(): str

    machine:
        $Stopped {
            play() { -> $Playing }
            status(): str { @@:(std::string("stopped")) }
        }
        $Playing => $Active {
            pause() { -> $Paused }
            status(): str { @@:(std::string("playing")) }
            => $^
        }
        $Paused => $Active {
            play() { -> $Playing }
            status(): str { @@:(std::string("paused")) }
            => $^
        }
        $Active {
            stop() { -> $Stopped }
        }
}

int main() {
    VideoPlayer vp;
    assert(std::any_cast<std::string>(vp.status()) == "stopped");
    vp.play();
    assert(std::any_cast<std::string>(vp.status()) == "playing");
    vp.pause();
    assert(std::any_cast<std::string>(vp.status()) == "paused");
    vp.stop();
    assert(std::any_cast<std::string>(vp.status()) == "stopped");
    printf("PASS: video_player\n");
    return 0;
}

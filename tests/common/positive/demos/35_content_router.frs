@@[target("rust")]

@@system ContentBasedRouter {
    interface:
        route(kind: String, payload: String): String

    machine:
        $Routing {
            route(kind: String, payload: String): String {
                if kind == "order" {
                    self.to_orders(payload);
                    @@:("orders".to_string())
                } else {
                    if kind == "refund" {
                        self.to_refunds(payload);
                        @@:("refunds".to_string())
                    } else {
                        self.to_dlq(payload);
                        @@:("dlq".to_string())
                    }
                }
            }
        }

    actions:
        to_orders(p: String)  { println!("-> orders:  {}", p); }
        to_refunds(p: String) { println!("-> refunds: {}", p); }
        to_dlq(p: String)     { println!("-> dlq:     {}", p); }
}

fn main() {
    let mut r = @@ContentBasedRouter();
    assert_eq!(r.route("order".to_string(),   "SKU-1".to_string()), "orders");
    assert_eq!(r.route("refund".to_string(),  "INV-7".to_string()), "refunds");
    assert_eq!(r.route("unknown".to_string(), "???".to_string()),    "dlq");
    println!("PASS: content_router");
}

@@target python_3

# Demo 21: Bank Account — system constructor parameters.
#
# This demo introduces parameterised systems. The Account state machine takes
# the owner's name and an optional initial balance at construction time, so the
# same machine definition can be reused for arbitrarily many account instances
# with different starting state.
#
# Key feature: domain parameters in the @@system header (`Account(owner: str,
# initial_balance: int = 0)`) become constructor arguments. The domain field
# initializers reference the parameters by name.

@@system Account(owner: str, initial_balance: int = 0) {
    interface:
        deposit(amount: int)
        withdraw(amount: int): bool
        balance(): int
        owner_name(): str
        close()

    machine:
        $Open {
            deposit(amount: int) {
                self.bal = self.bal + amount
            }
            withdraw(amount: int): bool {
                if self.bal >= amount:
                    self.bal = self.bal - amount
                    @@:(True)
                else:
                    @@:(False)
            }
            balance(): int { @@:(self.bal) }
            owner_name(): str { @@:(self.who) }
            close() { -> $Closed }
        }
        $Closed {
            deposit(amount: int) {
                # Closed accounts ignore deposits.
            }
            withdraw(amount: int): bool { @@:(False) }
            balance(): int { @@:(self.bal) }
            owner_name(): str { @@:(self.who) }
        }

    domain:
        bal = initial_balance
        who = owner
}

if __name__ == '__main__':
    # Account with explicit initial balance.
    a = @@Account("Alice", 100)
    assert a.owner_name() == "Alice"
    assert a.balance() == 100

    a.deposit(50)
    assert a.balance() == 150

    assert a.withdraw(60) == True
    assert a.balance() == 90

    assert a.withdraw(200) == False  # insufficient funds
    assert a.balance() == 90

    a.close()
    assert a.withdraw(10) == False   # closed account refuses withdrawal
    assert a.balance() == 90         # but balance is still readable

    # Second account using the default initial_balance.
    b = @@Account("Bob")
    assert b.owner_name() == "Bob"
    assert b.balance() == 0
    b.deposit(25)
    assert b.balance() == 25

    print("ok 1 - 21_bank_account")

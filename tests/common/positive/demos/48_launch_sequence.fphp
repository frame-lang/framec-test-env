@@[target("php")]

<?php

@@system LaunchController {
    interface:
        countdown_start()
        ignite()
        max_q_passed()
        meco()
        seco()
        abort()
        phase(): str
        outcome(): str

    machine:
        $Idle {
            countdown_start() { -> $Countdown }
            phase(): str { @@:("Idle") }
            outcome(): str { @@:("none") }
        }

        $Countdown {
            ignite() { -> $Boost }
            abort() {
                $this->outcome_str = "scrubbed";
                -> $Aborted
            }
            phase(): str { @@:("Countdown") }
            outcome(): str { @@:("none") }
        }

        $Boost {
            max_q_passed() { -> $Sustain }
            abort() {
                $this->outcome_str = "RTLS";
                -> $Aborted
            }
            phase(): str { @@:("Boost") }
            outcome(): str { @@:("none") }
        }

        $Sustain {
            meco() { -> $Coast }
            abort() {
                $this->outcome_str = "ATO";
                -> $Aborted
            }
            phase(): str { @@:("Sustain") }
            outcome(): str { @@:("none") }
        }

        $Coast {
            seco() { -> $Orbit }
            abort() {
                $this->outcome_str = "TAL";
                -> $Aborted
            }
            phase(): str { @@:("Coast") }
            outcome(): str { @@:("none") }
        }

        $Orbit {
            phase(): str { @@:("Orbit") }
            outcome(): str { @@:("nominal") }
        }

        $Aborted {
            phase(): str { @@:("Aborted") }
            outcome(): str { @@:($this->outcome_str) }
        }

    domain:
        outcome_str = ""
}

$lc = @@LaunchController();
$lc->countdown_start();
$lc->ignite();
$lc->max_q_passed();
$lc->meco();
$lc->seco();
assert($lc->phase() === "Orbit");
assert($lc->outcome() === "nominal");

$lc2 = @@LaunchController();
$lc2->countdown_start();
$lc2->ignite();
$lc2->abort();
assert($lc2->outcome() === "RTLS");

$lc3 = @@LaunchController();
$lc3->countdown_start();
$lc3->ignite();
$lc3->max_q_passed();
$lc3->abort();
assert($lc3->outcome() === "ATO");

$lc4 = @@LaunchController();
$lc4->countdown_start();
$lc4->abort();
assert($lc4->outcome() === "scrubbed");

echo "PASS: launch_sequence\n";

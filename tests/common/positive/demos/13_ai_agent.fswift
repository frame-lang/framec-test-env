@@[target("swift")]

@@system Agent {
    interface:
        tick()
        threat()
        safe()
        get_log(): String

    machine:
        $Exploring {
            tick() {
                self.action_log = self.action_log + "explore,"
            }
            threat() {
                self.action_log = self.action_log + "flee,"
                -> $Fleeing
            }
            get_log(): String { @@:(self.action_log) }
        }
        $Fleeing {
            tick() {
                self.action_log = self.action_log + "run,"
            }
            safe() {
                self.action_log = self.action_log + "resume,"
                -> $Exploring
            }
            get_log(): String { @@:(self.action_log) }
        }

    domain:
        action_log: String = ""
}

var a = @@Agent()
a.tick()
a.tick()
a.threat()
a.tick()
a.safe()
let result = a.get_log() as! String
let expected = "explore,explore,flee,run,resume,"
assert(result == expected, "Expected '\(expected)', got '\(result)'")
print("PASS: ai_agent")

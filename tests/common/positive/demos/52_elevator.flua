@@[target("lua")]

@@system Elevator {
    interface:
        request(floor: int)
        tick()
        close_doors()
        current_floor(): int
        status(): str

    machine:
        $Idle {
            request(floor: int) {
                if floor > self.floor then
                    self.target = floor
                    -> $MovingUp
                elseif floor < self.floor then
                    self.target = floor
                    -> $MovingDown
                else
                    -> $DoorsOpen
                end
            }
            current_floor(): int { @@:(self.floor) }
            status(): str { @@:("idle") }
        }

        $MovingUp {
            tick() {
                self.floor = self.floor + 1
                if self.floor == self.target then
                    -> $DoorsOpen
                end
            }
            current_floor(): int { @@:(self.floor) }
            status(): str { @@:("up") }
        }

        $MovingDown {
            tick() {
                self.floor = self.floor - 1
                if self.floor == self.target then
                    -> $DoorsOpen
                end
            }
            current_floor(): int { @@:(self.floor) }
            status(): str { @@:("down") }
        }

        $DoorsOpen {
            close_doors() { -> $Idle }
            current_floor(): int { @@:(self.floor) }
            status(): str { @@:("doors_open") }
        }

    domain:
        floor: int = 1
        target: int = 1
}

local e = @@Elevator()
assert(e:status() == "idle", "expected idle")
assert(e:current_floor() == 1, "expected floor=1")
e:request(5)
assert(e:status() == "up", "expected up")
e:tick(); e:tick(); e:tick(); e:tick()
assert(e:current_floor() == 5, "expected floor=5")
assert(e:status() == "doors_open", "expected doors_open")
e:close_doors()
assert(e:status() == "idle", "expected idle")
e:request(2)
assert(e:status() == "down", "expected down")
e:tick(); e:tick(); e:tick()
assert(e:current_floor() == 2, "expected floor=2")
assert(e:status() == "doors_open", "expected doors_open")
e:close_doors()
e:request(2)
assert(e:status() == "doors_open", "expected immediate")
print("PASS: elevator")

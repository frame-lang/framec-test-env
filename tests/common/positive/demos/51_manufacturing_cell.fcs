@@[target("csharp")]

using System;

@@system ManufacturingCell {
    interface:
        work_order(order_id: String)
        phase_done()
        emergency_stop()
        reset()
        parts_produced(): int
        status(): String

    machine:
        $Idle => $Active {
            work_order(order_id: String) { -> $Setup }
            status(): String { @@:("idle") }
            => $^
        }

        $Setup => $Active {
            phase_done() { -> $Machining }
            status(): String { @@:("setup") }
            => $^
        }

        $Machining => $Active {
            phase_done() { -> $Teardown }
            status(): String { @@:("machining") }
            => $^
        }

        $Teardown => $Active {
            phase_done() {
                this.parts = this.parts + 1;
                -> $Idle
            }
            status(): String { @@:("teardown") }
            => $^
        }

        $Active {
            emergency_stop() { -> $EStopped }
            parts_produced(): int { @@:(this.parts) }
            status(): String { @@:("active") }
        }

        $EStopped {
            reset() { -> $Idle }
            parts_produced(): int { @@:(this.parts) }
            status(): String { @@:("estopped") }
        }

    domain:
        parts: int = 0
}

class Program {
    static void Main(string[] args) {
        var c = @@ManufacturingCell();
        if ((string) c.status() != "idle") throw new Exception("expected idle");
        if ((int) c.parts_produced() != 0) throw new Exception("expected parts=0");
        c.work_order("WO-001");
        if ((string) c.status() != "setup") throw new Exception("expected setup");
        c.phase_done();
        if ((string) c.status() != "machining") throw new Exception("expected machining");
        c.phase_done();
        if ((string) c.status() != "teardown") throw new Exception("expected teardown");
        c.phase_done();
        if ((string) c.status() != "idle") throw new Exception("expected idle");
        if ((int) c.parts_produced() != 1) throw new Exception("expected parts=1");
        c.work_order("WO-002");
        c.phase_done();
        c.emergency_stop();
        if ((string) c.status() != "estopped") throw new Exception("expected estopped");
        c.reset();
        if ((string) c.status() != "idle") throw new Exception("expected idle final");
        Console.WriteLine("PASS: manufacturing_cell");
    }
}

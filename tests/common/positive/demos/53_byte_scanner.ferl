@@[target("erlang")]

@@system Scanner {
    interface:
        feed_letter()
        feed_punct()
        eof()
        token_count(): int
        status(): str

    machine:
        $Start {
            feed_letter() { -> $InIdent }
            feed_punct() {
                self.count = Data#data.count + 1
            }
            eof() {
                self.count = Data#data.count + 1
            }
            token_count(): int { @@:(Data#data.count) }
            status(): str { @@:("start") }
        }

        $InIdent {
            feed_letter() {}
            feed_punct() {
                self.count = Data#data.count + 2
                -> $Start
            }
            eof() {
                self.count = Data#data.count + 2
            }
            token_count(): int { @@:(Data#data.count) }
            status(): str { @@:("in_ident") }
        }

    domain:
        count = 0
}

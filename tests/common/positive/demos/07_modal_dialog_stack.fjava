@@target java

@@system DialogManager {
    interface:
        open(name: String)
        close(): String
        current(): String

    machine:
        $Main {
            open(name: String) {
                push$
                -> (name) $Dialog
            }
            current(): String { @@:("main") }
        }
        $Dialog {
            $.name: String = ""

            $>(name: String) { $.name = name }

            open(name: String) {
                push$
                -> (name) $Dialog
            }
            close(): String {
                @@:($.name)
                -> pop$
            }
            current(): String { @@:($.name) }
        }
}

class Main {
    public static void main(String[] args) {
        var dm = new DialogManager();
        if (!"main".equals((String) dm.current())) {
            throw new RuntimeException("Expected 'main'");
        }
        dm.open("Settings");
        if (!"Settings".equals((String) dm.current())) {
            throw new RuntimeException("Expected 'Settings'");
        }
        dm.open("Confirm");
        if (!"Confirm".equals((String) dm.current())) {
            throw new RuntimeException("Expected 'Confirm'");
        }
        String closed = (String) dm.close();
        if (!"Confirm".equals(closed)) {
            throw new RuntimeException("Expected 'Confirm'");
        }
        if (!"Settings".equals((String) dm.current())) {
            throw new RuntimeException("Expected 'Settings'");
        }
        closed = (String) dm.close();
        if (!"Settings".equals(closed)) {
            throw new RuntimeException("Expected 'Settings'");
        }
        if (!"main".equals((String) dm.current())) {
            throw new RuntimeException("Expected 'main'");
        }
        System.out.println("PASS: modal_dialog_stack");
    }
}

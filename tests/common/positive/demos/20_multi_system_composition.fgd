@@target gdscript
@@skip -- GDScript multi-system codegen issue with @@Logger() domain init

extends SceneTree

@@system Logger {
    interface:
        log(msg: str)

    machine:
        $Active {
            log(msg: str) {
                print("[LOG] " + msg)
            }
        }
}

@@system App {
    interface:
        start()
        stop()

    machine:
        $Idle {
            start() {
                self.logger.log("App starting")
                -> $Running
            }
        }
        $Running {
            $>() { self.logger.log("App running") }
            stop() {
                self.logger.log("App stopping")
                -> $Idle
            }
        }

    domain:
        logger = @@Logger()
}

func _init():
    var app = @@App()
    app.start()
    app.stop()
    print("PASS: multi_system_composition")
    quit()

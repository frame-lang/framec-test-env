@@[target("python_3")]

@@system MooreParity {
    interface:
        input(bit: int)
        output(): str

    machine:
        $Even {
            input(bit: int) {
                if bit == 1:
                    -> $Odd
            }
            output(): str { @@:("even") }
        }
        $Odd {
            input(bit: int) {
                if bit == 1:
                    -> $Even
            }
            output(): str { @@:("odd") }
        }
}

if __name__ == '__main__':
    m = @@MooreParity()
    bits = [1, 0, 1, 1, 0]
    expected = ["odd", "odd", "even", "odd", "odd"]
    for i, bit in enumerate(bits):
        m.input(bit)
        result = m.output()
        assert result == expected[i], f"After bit {bit}: expected '{expected[i]}', got '{result}'"
    print("PASS: moore_machine")

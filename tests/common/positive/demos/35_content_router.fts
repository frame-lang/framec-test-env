@@[target("typescript")]

@@system ContentBasedRouter {
    interface:
        route(kind: str, payload: str): str

    machine:
        $Routing {
            route(kind: str, payload: str): str {
                if (kind == "order") {
                    this.to_orders(payload);
                    @@:("orders")
                } else {
                    if (kind == "refund") {
                        this.to_refunds(payload);
                        @@:("refunds")
                    } else {
                        this.to_dlq(payload);
                        @@:("dlq")
                    }
                }
            }
        }

    actions:
        to_orders(p: str)  { console.log("-> orders:  " + p); }
        to_refunds(p: str) { console.log("-> refunds: " + p); }
        to_dlq(p: str)     { console.log("-> dlq:     " + p); }
}

const r = @@ContentBasedRouter();
if (r.route("order",   "SKU-1") !== "orders")  throw new Error("Expected orders");
if (r.route("refund",  "INV-7") !== "refunds") throw new Error("Expected refunds");
if (r.route("unknown", "???")    !== "dlq")     throw new Error("Expected dlq");
console.log("PASS: content_router");

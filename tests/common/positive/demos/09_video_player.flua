@@target lua

@@system VideoPlayer {
    interface:
        play()
        pause()
        stop()
        status(): str

    machine:
        $Stopped {
            play() { -> $Playing }
            status(): str { @@:("stopped") }
        }
        $Playing => $Active {
            pause() { -> $Paused }
            status(): str { @@:("playing") }
            => $^
        }
        $Paused => $Active {
            play() { -> $Playing }
            status(): str { @@:("paused") }
            => $^
        }
        $Active {
            stop() { -> $Stopped }
        }
}

local vp = @@VideoPlayer()
assert(vp:status() == "stopped", "expected stopped")
vp:play()
assert(vp:status() == "playing", "expected playing")
vp:pause()
assert(vp:status() == "paused", "expected paused")
vp:stop()
assert(vp:status() == "stopped", "expected stopped")
print("PASS: video_player")

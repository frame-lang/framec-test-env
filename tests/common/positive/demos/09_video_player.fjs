@@[target("javascript")]

@@system VideoPlayer {
    interface:
        play()
        pause()
        stop()
        status(): str

    machine:
        $Stopped {
            play() { -> $Playing }
            status(): str { @@:("stopped") }
        }
        $Playing => $Active {
            pause() { -> $Paused }
            status(): str { @@:("playing") }
            => $^
        }
        $Paused => $Active {
            play() { -> $Playing }
            status(): str { @@:("paused") }
            => $^
        }
        $Active {
            stop() { -> $Stopped }
        }
}

const vp = @@VideoPlayer();
if (vp.status() !== "stopped") { console.log("FAIL"); process.exit(1); }
vp.play();
if (vp.status() !== "playing") { console.log("FAIL"); process.exit(1); }
vp.pause();
if (vp.status() !== "paused") { console.log("FAIL"); process.exit(1); }
vp.stop();
if (vp.status() !== "stopped") { console.log("FAIL"); process.exit(1); }
console.log("PASS: video_player");

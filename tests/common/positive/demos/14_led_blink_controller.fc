@@target c

#include <stdio.h>
#include <stdlib.h>
#include <stdbool.h>

@@system LedBlinker {
    interface:
        enable()
        disable()
        timer_tick()
        is_lit(): bool

    machine:
        $Disabled {
            enable() { -> $LedOff }
        }
        $LedOff {
            timer_tick() { -> $LedOn }
            disable() { -> $Disabled }
            is_lit(): bool { @@:(false) }
        }
        $LedOn {
            timer_tick() { -> $LedOff }
            disable() { -> $Disabled }
            is_lit(): bool { @@:(true) }
        }
}

int main() {
    LedBlinker* led = @@LedBlinker();
    LedBlinker_enable(led);
    bool expected[] = {false, true, false, true, false};
    for (int i = 0; i < 5; i++) {
        if (LedBlinker_is_lit(led) != expected[i]) {
            printf("FAIL: tick %d\n", i);
            return 1;
        }
        LedBlinker_timer_tick(led);
    }
    printf("PASS: led_blink_controller\n");
    LedBlinker_destroy(led);
    return 0;
}

@@[target("swift")]


@@system Scanner {
    interface:
        feed_letter()
        feed_punct()
        eof()
        token_count(): Int
        status(): String

    machine:
        $Start {
            feed_letter() { -> $InIdent }
            feed_punct() {
                self.count = self.count + 1
            }
            eof() {
                self.count = self.count + 1
            }
            token_count(): Int { @@:(self.count) }
            status(): String { @@:("start") }
        }

        $InIdent {
            feed_letter() {}
            feed_punct() {
                self.count = self.count + 2
                -> $Start
            }
            eof() {
                self.count = self.count + 2
            }
            token_count(): Int { @@:(self.count) }
            status(): String { @@:("in_ident") }
        }

    domain:
        count: Int = 0
}

let s = @@Scanner()
if (s.status() as! String) != "start" { print("FAIL: start"); exit(1) }
if (s.token_count() as! Int) != 0 { print("FAIL: count0"); exit(1) }
s.feed_letter()
if (s.status() as! String) != "in_ident" { print("FAIL: in_ident"); exit(1) }
s.feed_letter()
s.feed_punct()
if (s.status() as! String) != "start" { print("FAIL: start after"); exit(1) }
if (s.token_count() as! Int) != 2 { print("FAIL: count2"); exit(1) }
s.feed_punct()
if (s.token_count() as! Int) != 3 { print("FAIL: count3"); exit(1) }
s.eof()
if (s.token_count() as! Int) != 4 { print("FAIL: count4"); exit(1) }

let s2 = @@Scanner()
s2.feed_letter()
s2.feed_letter()
s2.eof()
if (s2.token_count() as! Int) != 2 { print("FAIL: count2 eof"); exit(1) }
print("PASS: byte_scanner")

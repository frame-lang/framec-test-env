@@[target("dart")]

@@system Resequencer {
    interface:
        arrive(seq: int, payload: String): String
        status(): String

    machine:
        $Buffering {
            arrive(seq: int, payload: String): String {
                this.buffer[seq] = payload;
                var released = 0;
                while (this.buffer.containsKey(this.next_seq)) {
                    var p = this.buffer.remove(this.next_seq)!;
                    this.release(this.next_seq, p);
                    this.next_seq = this.next_seq + 1;
                    released = released + 1;
                }
                if (released > 0) {
                    @@:("released $released")
                } else {
                    @@:("buffered")
                }
            }
            status(): String {
                @@:("next=${this.next_seq} buffered=${this.buffer.length}")
            }
        }

    actions:
        release(seq: int, payload: String): void {
            print("  out #$seq: $payload");
        }

    domain:
        buffer: Map<int, String> = <int, String>{}
        next_seq: int = 1
}

void main() {
    var rs = @@Resequencer();
    if ((rs.arrive(3, "c") as String) != "buffered")    throw "expected buffered";
    if ((rs.arrive(1, "a") as String) != "released 1")  throw "expected released 1";
    if ((rs.arrive(2, "b") as String) != "released 2")  throw "expected released 2";
    if ((rs.status() as String) != "next=4 buffered=0") throw "expected next=4 buffered=0";
    print("PASS: resequencer");
}

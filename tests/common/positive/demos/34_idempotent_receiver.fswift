@@[target("swift")]

import Foundation

@@system IdempotentReceiver {
    interface:
        deliver(msg_id: String, payload: String): String

    machine:
        $Ready {
            deliver(msg_id: String, payload: String): String {
                if self.seen.contains(msg_id) {
                    @@:("duplicate")
                } else {
                    self.seen.insert(msg_id)
                    self.process(payload)
                    @@:("accepted")
                }
            }
        }

    actions:
        process(payload: String) {
            print("processing: \(payload)")
        }

    domain:
        seen: Set<String> = []
}

let r = @@IdempotentReceiver()
if (r.deliver("m1", "hello") as! String) != "accepted"  { print("FAIL: accepted #1");  exit(1) }
if (r.deliver("m1", "hello") as! String) != "duplicate" { print("FAIL: duplicate #1"); exit(1) }
if (r.deliver("m2", "world") as! String) != "accepted"  { print("FAIL: accepted #2");  exit(1) }
if (r.deliver("m2", "world") as! String) != "duplicate" { print("FAIL: duplicate #2"); exit(1) }
print("PASS: idempotent_receiver")

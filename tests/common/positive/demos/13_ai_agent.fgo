@@[target("go")]

package main

import (
	"fmt"
	"os"
)

@@system Agent {
    interface:
        tick()
        threat()
        safe()
        get_log(): string

    machine:
        $Exploring {
            tick() {
                s.action_log = s.action_log + "explore,"
            }
            threat() {
                s.action_log = s.action_log + "flee,"
                -> $Fleeing
            }
            get_log(): string { @@:(s.action_log) }
        }
        $Fleeing {
            tick() {
                s.action_log = s.action_log + "run,"
            }
            safe() {
                s.action_log = s.action_log + "resume,"
                -> $Exploring
            }
            get_log(): string { @@:(s.action_log) }
        }

    domain:
        action_log: string = ""
}

func main() {
	a := @@Agent()
	a.Tick()
	a.Tick()
	a.Threat()
	a.Tick()
	a.Safe()
	result := a.Get_log()
	expected := "explore,explore,flee,run,resume,"
	if result != expected {
		fmt.Printf("FAIL: Expected '%s', got '%s'\n", expected, result)
		os.Exit(1)
	}
	fmt.Println("PASS: ai_agent")
}

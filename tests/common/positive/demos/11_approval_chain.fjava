@@[target("java")]

@@system ApprovalChain {
    interface:
        submit()
        approve(reviewer: String)
        reject(reviewer: String)
        status(): String

    machine:
        $Draft {
            submit() { -> $Review1 }
            status(): String { @@:("draft") }
        }
        $Review1 {
            approve(reviewer: String) {
                System.out.println("Approved by " + reviewer);
                -> $Review2
            }
            reject(reviewer: String) {
                System.out.println("Rejected by " + reviewer);
                -> $Draft
            }
            status(): String { @@:("awaiting first review") }
        }
        $Review2 {
            approve(reviewer: String) {
                System.out.println("Approved by " + reviewer);
                -> $Published
            }
            reject(reviewer: String) {
                System.out.println("Rejected by " + reviewer);
                -> $Draft
            }
            status(): String { @@:("awaiting second review") }
        }
        $Published {
            status(): String { @@:("published") }
        }
}

class Main {
    public static void main(String[] args) {
        var doc = @@ApprovalChain();
        doc.submit();
        assert ((String) doc.status()).equals("awaiting first review");
        doc.approve("Alice");
        assert ((String) doc.status()).equals("awaiting second review");
        doc.reject("Bob");
        assert ((String) doc.status()).equals("draft");
        doc.submit();
        doc.approve("Alice");
        doc.approve("Bob");
        assert ((String) doc.status()).equals("published");
        System.out.println("PASS: approval_chain");
    }
}

@@target java

@@system CircuitBreaker {
    interface:
        call(): String
        success()
        failure()
        tick()
        status(): String

    machine:
        $Closed {
            $.failures: int = 0
            call(): String { @@:("allowed") }
            success() { $.failures = 0; }
            failure() {
                $.failures = $.failures + 1;
                if ($.failures >= this.threshold) {
                    -> $Open
                }
            }
            status(): String { @@:("closed") }
        }
        $Open {
            $.cooldown_remaining: int = 0
            $>() {
                $.cooldown_remaining = this.cooldown;
            }
            call(): String { @@:("blocked") }
            tick() {
                $.cooldown_remaining = $.cooldown_remaining - 1;
                if ($.cooldown_remaining <= 0) {
                    -> $HalfOpen
                }
            }
            status(): String { @@:("open") }
        }
        $HalfOpen {
            call(): String { @@:("testing") }
            success() { -> $Closed }
            failure() { -> $Open }
            status(): String { @@:("half-open") }
        }

    domain:
        threshold : int = 3
        cooldown : int = 5
}

class Main {
    public static void main(String[] args) {
        var cb = @@CircuitBreaker();
        int failures = 0;

        cb.failure(); cb.failure(); cb.failure();
        if (!cb.call().equals("blocked")) { System.out.println("FAIL: expected blocked"); failures++; }

        for (int i = 0; i < 5; i++) { cb.tick(); }
        if (!cb.call().equals("testing")) { System.out.println("FAIL: expected testing"); failures++; }

        cb.success();
        if (!cb.status().equals("closed")) { System.out.println("FAIL: expected closed, got " + cb.status()); failures++; }

        if (failures > 0) { System.out.println("FAIL: circuit_breaker (" + failures + ")"); System.exit(1); }
        System.out.println("PASS: circuit_breaker");
    }
}

@@[target("csharp")]

using System;

@@system RobotArm {
    interface:
        set_manual()
        set_auto()
        e_stop()
        reset_e_stop()
        status(): String

    machine:
        $Manual => $Operational {
            set_auto() { -> $Auto }
            status(): String { @@:("Manual") }
            => $^
        }

        $Auto => $Operational {
            set_manual() { -> $Manual }
            status(): String { @@:("Auto") }
            => $^
        }

        $Operational {
            e_stop() { -> $EStop }
            status(): String { @@:("Operational") }
        }

        $EStop {
            reset_e_stop() { -> $Manual }
            status(): String { @@:("EStop") }
        }

    domain:
}

class Program {
    static void Main(string[] args) {
        var arm = @@RobotArm();
        if ((string) arm.status() != "Manual") throw new Exception("expected Manual");
        arm.e_stop();
        if ((string) arm.status() != "EStop") throw new Exception("expected EStop");
        arm.reset_e_stop();
        if ((string) arm.status() != "Manual") throw new Exception("expected Manual2");
        arm.set_auto();
        if ((string) arm.status() != "Auto") throw new Exception("expected Auto");
        arm.e_stop();
        if ((string) arm.status() != "EStop") throw new Exception("expected EStop from Auto");
        Console.WriteLine("PASS: robot_arm");
    }
}

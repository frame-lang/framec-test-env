@@[target("dart")]

@@system MooreParity {
    interface:
        input(bit: int)
        output(): String

    machine:
        $Even {
            input(bit: int) {
                if (bit == 1) {
                    -> $Odd
                }
            }
            output(): String { @@:("even") }
        }
        $Odd {
            input(bit: int) {
                if (bit == 1) {
                    -> $Even
                }
            }
            output(): String { @@:("odd") }
        }
}

void main() {
    final m = @@MooreParity();
    final bits = [1, 0, 1, 1, 0];
    final expected = ["odd", "odd", "even", "odd", "odd"];
    for (int i = 0; i < 5; i++) {
        m.input(bits[i]);
        String result = m.output() as String;
        if (result != expected[i]) {
            throw Exception("FAIL: after bit ${bits[i]} expected '${expected[i]}', got '$result'");
        }
    }
    print("PASS: moore_machine");
}

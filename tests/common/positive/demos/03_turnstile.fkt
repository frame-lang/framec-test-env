@@[target("kotlin")]

@@system Turnstile {
    interface:
        coin()
        push(): String

    machine:
        $Locked {
            coin() { -> $Unlocked }
            push(): String { @@:("locked - insert coin") }
        }
        $Unlocked {
            coin() { }
            push(): String {
                @@:("welcome")
                -> $Locked
            }
        }
}

fun main() {
    val t = Turnstile()
    if (t.push() as String != "locked - insert coin") {
        throw RuntimeException("Expected 'locked - insert coin'")
    }
    t.coin()
    if (t.push() as String != "welcome") {
        throw RuntimeException("Expected 'welcome'")
    }
    if (t.push() as String != "locked - insert coin") {
        throw RuntimeException("Expected 'locked - insert coin'")
    }
    println("PASS: turnstile")
}

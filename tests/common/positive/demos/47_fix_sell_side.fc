@@[target("c")]

#include <stdio.h>
#include <stdlib.h>
#include <string.h>

@@system FixSellSide {
    interface:
        new_order(cl_ord_id: str, qty: double, price: double)
        market_fill(qty: double, px: double)
        cancel_request(cancel_cl_ord_id: str)
        status(): str
        get_cum_qty(): double
        get_leaves_qty(): double

    machine:
        $NoOrder {
            new_order(cl_ord_id: str, qty: double, price: double) {
                self->cl_ord_id = cl_ord_id;
                self->order_qty = qty;
                self->leaves_qty = qty;
                self->price = price;
                -> $Working
            }
            status(): str { @@:("NoOrder") }
            get_cum_qty(): double { @@:(self->cum_qty) }
            get_leaves_qty(): double { @@:(self->leaves_qty) }
        }

        $Working {
            market_fill(qty: double, px: double) {
                self->cum_qty = self->cum_qty + qty;
                self->leaves_qty = self->order_qty - self->cum_qty;
                if (self->leaves_qty <= 0.0) {
                    -> $Filled
                }
            }
            cancel_request(cancel_cl_ord_id: str) { -> $Canceled }
            status(): str { @@:("Working") }
            get_cum_qty(): double { @@:(self->cum_qty) }
            get_leaves_qty(): double { @@:(self->leaves_qty) }
        }

        $Filled {
            status(): str { @@:("Filled") }
            get_cum_qty(): double { @@:(self->cum_qty) }
            get_leaves_qty(): double { @@:(self->leaves_qty) }
        }

        $Canceled {
            status(): str { @@:("Canceled") }
            get_cum_qty(): double { @@:(self->cum_qty) }
            get_leaves_qty(): double { @@:(self->leaves_qty) }
        }

    domain:
        cl_ord_id: str = ""
        order_qty: double = 0.0
        cum_qty: double = 0.0
        leaves_qty: double = 0.0
        price: double = 0.0
}

int main() {
    FixSellSide* o = @@FixSellSide();
    if (strcmp(FixSellSide_status(o), "NoOrder") != 0) { printf("FAIL: NoOrder\n"); return 1; }
    FixSellSide_new_order(o, "CL-1", 200.0, 50.0);
    if (strcmp(FixSellSide_status(o), "Working") != 0) { printf("FAIL: Working\n"); return 1; }
    if (FixSellSide_get_leaves_qty(o) != 200.0) { printf("FAIL: leaves=200\n"); return 1; }
    FixSellSide_market_fill(o, 80.0, 50.05);
    if (FixSellSide_get_cum_qty(o) != 80.0) { printf("FAIL: cum=80\n"); return 1; }
    FixSellSide_market_fill(o, 120.0, 50.10);
    if (strcmp(FixSellSide_status(o), "Filled") != 0) { printf("FAIL: Filled\n"); return 1; }

    FixSellSide* o2 = @@FixSellSide();
    FixSellSide_new_order(o2, "CL-2", 100.0, 49.0);
    FixSellSide_market_fill(o2, 30.0, 49.10);
    FixSellSide_cancel_request(o2, "CXL-2");
    if (strcmp(FixSellSide_status(o2), "Canceled") != 0) { printf("FAIL: Canceled\n"); return 1; }
    printf("PASS: fix_sell_side\n");
    FixSellSide_destroy(o);
    FixSellSide_destroy(o2);
    return 0;
}

@@[target("php")]

<?php

@@system DialogManager {
    interface:
        open(name: str)
        close(): str
        current(): str

    machine:
        $Main {
            open(name: str) {
                push$
                -> ($name) $Dialog
            }
            current(): str { @@:("main") }
        }
        $Dialog {
            $.name: str = ""

            $>(name: str) { $.name = $name }

            open(name: str) {
                push$
                -> ($name) $Dialog
            }
            close(): str {
                @@:($.name)
                -> pop$
            }
            current(): str { @@:($.name) }
        }
}

$dm = @@DialogManager();
if ($dm->current() !== "main") {
    echo "FAIL: expected 'main'\n";
    exit(1);
}
$dm->open("Settings");
if ($dm->current() !== "Settings") {
    echo "FAIL: expected 'Settings'\n";
    exit(1);
}
$dm->open("Confirm");
if ($dm->current() !== "Confirm") {
    echo "FAIL: expected 'Confirm'\n";
    exit(1);
}
$closed = $dm->close();
if ($closed !== "Confirm") {
    echo "FAIL: expected 'Confirm'\n";
    exit(1);
}
if ($dm->current() !== "Settings") {
    echo "FAIL: expected 'Settings'\n";
    exit(1);
}
$closed = $dm->close();
if ($closed !== "Settings") {
    echo "FAIL: expected 'Settings'\n";
    exit(1);
}
if ($dm->current() !== "main") {
    echo "FAIL: expected 'main'\n";
    exit(1);
}
echo "PASS: modal_dialog_stack\n";

@@[target("gdscript")]

extends SceneTree

@@system MooreParity {
    interface:
        input(bit: int)
        output(): str

    machine:
        $Even {
            input(bit: int) {
                if bit == 1:
                    -> $Odd
            }
            output(): str { @@:("even") }
        }
        $Odd {
            input(bit: int) {
                if bit == 1:
                    -> $Even
            }
            output(): str { @@:("odd") }
        }
}

func _init():
    var m = @@MooreParity()
    var bits = [1, 0, 1, 1, 0]
    var expected = ["odd", "odd", "even", "odd", "odd"]
    for i in range(5):
        m.input(bits[i])
        var result = m.output()
        assert(result == expected[i], "after bit %d expected '%s', got '%s'" % [bits[i], expected[i], result])
    print("PASS: moore_machine")
    quit()

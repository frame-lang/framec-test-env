@@[target("kotlin")]

@@[persist]
@@system MessageStore {
    operations:
        @@[save]
        save_state(): String {}

        @@[load]
        restore_state(data: String) {}

    interface:
        record(topic: String, payload: String)
        count_for(topic: String): Int
        total(): Int

    machine:
        $Recording {
            record(topic: String, payload: String) {
                this.total_count = this.total_count + 1
                if (topic == "orders") {
                    this.orders_count = this.orders_count + 1
                } else {
                    if (topic == "refunds") {
                        this.refunds_count = this.refunds_count + 1
                    }
                }
            }
            count_for(topic: String): Int {
                if (topic == "orders") {
                    @@:(this.orders_count)
                } else {
                    if (topic == "refunds") {
                        @@:(this.refunds_count)
                    } else {
                        @@:(0)
                    }
                }
            }
            total(): Int { @@:(this.total_count) }
        }

    domain:
        total_count: Int = 0
        orders_count: Int = 0
        refunds_count: Int = 0
}

fun main() {
    val s = @@MessageStore()
    s.record("orders", "O-1")
    s.record("orders", "O-2")
    s.record("refunds", "R-1")

    val snap = s.save_state() as String
    val s2 = MessageStore()
    s2.restore_state(snap)
    if ((s2.total() as Int) != 3) throw RuntimeException("expected total=3")
    if ((s2.count_for("orders") as Int) != 2) throw RuntimeException("expected orders=2")
    s2.record("orders", "O-3")
    if ((s2.total() as Int) != 4) throw RuntimeException("expected total=4")
    if ((s2.count_for("orders") as Int) != 3) throw RuntimeException("expected orders=3")
    println("PASS: message_store")
}

@@target java

@@system MealyDetector {
    interface:
        input(bit: int): String

    machine:
        $S0 {
            input(bit: int): String {
                if (bit == 1) {
                    @@:("0")
                    -> $S1
                } else {
                    @@:("0")
                }
            }
        }
        $S1 {
            input(bit: int): String {
                if (bit == 0) {
                    @@:("1")
                    -> $S0
                } else {
                    @@:("0")
                }
            }
        }
}

class Main {
    public static void main(String[] args) {
        var m = new MealyDetector();
        int[] bits = {1, 0, 1, 1, 0};
        String[] expected = {"0", "1", "0", "0", "1"};
        for (int i = 0; i < 5; i++) {
            String result = (String) m.input(bits[i]);
            if (!result.equals(expected[i])) {
                throw new RuntimeException("FAIL: bit=" + bits[i] + " expected '" + expected[i] + "', got '" + result + "'");
            }
        }
        System.out.println("PASS: mealy_machine");
    }
}

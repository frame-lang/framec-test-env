@@[target("cpp_17")]

#include <iostream>
#include <string>
#include <cassert>
#include <map>

@@system VendingMachine(inventory: std::map<std::string, int> = {}) {
    operations:
        stock(product: std::string, qty: int) {
            this->inventory[product] = this->inventory[product] + qty;
        }
        check_stock(product: std::string): int {
            auto it = this->inventory.find(product);
            return it != this->inventory.end() ? it->second : 0;
        }

    interface:
        insert_coin(amount: int)
        select(product: std::string): std::string
        cancel(): int

    machine:
        $Idle {
            insert_coin(amount: int) {
                this->balance = amount;
                -> $HasCredit
            }
            select(product: std::string): std::string { @@:(std::string("insert coin first")) }
            cancel(): int { @@:(0) }
        }
        $HasCredit {
            insert_coin(amount: int) {
                this->balance = this->balance + amount;
            }
            select(product: std::string): std::string {
                int price = this->get_price(product);
                if (price < 0) {
                    @@:(std::string("unknown product"))
                } else if (this->balance < price) {
                    @@:(std::string("need more"))
                } else if (this->check_stock(product) <= 0) {
                    @@:(std::string("sold out"))
                } else {
                    this->inventory[product] = this->inventory[product] - 1;
                    this->balance = this->balance - price;
                    @@:(std::string("dispensing ") + product)
                    -> $Dispensing
                }
            }
            cancel(): int {
                int refund = this->balance;
                this->balance = 0;
                @@:(refund)
                -> $Idle
            }
        }
        $Dispensing {
            $>() {
                int change = this->balance;
                this->balance = 0;
                if (change > 0) {
                    std::cout << "Change: " << change << std::endl;
                }
                -> $Idle
            }
        }

    actions:
        get_price(product: std::string): int {
            if (product == "cola") return 100;
            if (product == "chips") return 75;
            if (product == "water") return 50;
            return -1;
        }

    domain:
        balance : int = 0
        inventory : std::map<std::string, int> = {}
}

int main() {
    std::map<std::string, int> inv = {{"cola", 2}, {"chips", 1}};
    auto vm = @@VendingMachine(inv);
    vm.stock("water", 5);
    int failures = 0;

    if (vm.check_stock("water") != 5) { std::cout << "FAIL: water stock" << std::endl; failures++; }

    auto r1 = vm.select("cola");
    if (r1 != "insert coin first") { std::cout << "FAIL: " << r1 << std::endl; failures++; }

    vm.insert_coin(100);
    auto r2 = vm.select("cola");
    if (r2 != "dispensing cola") { std::cout << "FAIL: " << r2 << std::endl; failures++; }

    if (failures > 0) { std::cout << "FAIL: vending_machine (" << failures << ")" << std::endl; return 1; }
    std::cout << "PASS: vending_machine" << std::endl;
    return 0;
}

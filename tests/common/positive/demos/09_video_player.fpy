@@target python_3

@@system VideoPlayer {
    interface:
        play()
        pause()
        stop()
        status(): str

    machine:
        $Stopped {
            play() { -> $Playing }
            status(): str { @@:("stopped") }
        }
        $Playing => $Active {
            pause() { -> $Paused }
            status(): str { @@:("playing") }
            => $^
        }
        $Paused => $Active {
            play() { -> $Playing }
            status(): str { @@:("paused") }
            => $^
        }
        $Active {
            stop() { -> $Stopped }
        }
}

if __name__ == '__main__':
    vp = @@VideoPlayer()
    r1 = vp.status()
    assert r1 == "stopped", f"Expected 'stopped', got '{r1}'"
    vp.play()
    r2 = vp.status()
    assert r2 == "playing", f"Expected 'playing', got '{r2}'"
    vp.pause()
    r3 = vp.status()
    assert r3 == "paused", f"Expected 'paused', got '{r3}'"
    vp.stop()
    r4 = vp.status()
    assert r4 == "stopped", f"Expected 'stopped', got '{r4}'"
    print("PASS: video_player")

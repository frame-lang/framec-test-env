@@[target("csharp")]


@@system Elevator {
    interface:
        request(floor: int)
        tick()
        close_doors()
        current_floor(): int
        status(): String

    machine:
        $Idle {
            request(floor: int) {
                if (floor > this.floor) {
                    this.target = floor;
                    -> $MovingUp
                } else if (floor < this.floor) {
                    this.target = floor;
                    -> $MovingDown
                } else {
                    -> $DoorsOpen
                }
            }
            current_floor(): int { @@:(this.floor) }
            status(): String { @@:("idle") }
        }

        $MovingUp {
            tick() {
                this.floor = this.floor + 1;
                if (this.floor == this.target) {
                    -> $DoorsOpen
                }
            }
            current_floor(): int { @@:(this.floor) }
            status(): String { @@:("up") }
        }

        $MovingDown {
            tick() {
                this.floor = this.floor - 1;
                if (this.floor == this.target) {
                    -> $DoorsOpen
                }
            }
            current_floor(): int { @@:(this.floor) }
            status(): String { @@:("down") }
        }

        $DoorsOpen {
            close_doors() { -> $Idle }
            current_floor(): int { @@:(this.floor) }
            status(): String { @@:("doors_open") }
        }

    domain:
        floor: int = 1
        target: int = 1
}

class Program {
    static void Main(string[] args) {
        var e = @@Elevator();
        if ((string) e.status() != "idle") throw new Exception("expected idle");
        if ((int) e.current_floor() != 1) throw new Exception("expected floor=1");
        e.request(5);
        if ((string) e.status() != "up") throw new Exception("expected up");
        e.tick(); e.tick(); e.tick(); e.tick();
        if ((int) e.current_floor() != 5) throw new Exception("expected floor=5");
        if ((string) e.status() != "doors_open") throw new Exception("expected doors_open");
        e.close_doors();
        if ((string) e.status() != "idle") throw new Exception("expected idle");
        e.request(2);
        if ((string) e.status() != "down") throw new Exception("expected down");
        e.tick(); e.tick(); e.tick();
        if ((int) e.current_floor() != 2) throw new Exception("expected floor=2");
        if ((string) e.status() != "doors_open") throw new Exception("expected doors_open");
        e.close_doors();
        e.request(2);
        if ((string) e.status() != "doors_open") throw new Exception("expected immediate doors_open");
        Console.WriteLine("PASS: elevator");
    }
}

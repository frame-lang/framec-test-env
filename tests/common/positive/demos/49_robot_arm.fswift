@@[target("swift")]


@@system RobotArm {
    interface:
        set_manual()
        set_auto()
        e_stop()
        reset_e_stop()
        status(): String

    machine:
        $Manual => $Operational {
            set_auto() { -> $Auto }
            status(): String { @@:("Manual") }
            => $^
        }

        $Auto => $Operational {
            set_manual() { -> $Manual }
            status(): String { @@:("Auto") }
            => $^
        }

        $Operational {
            e_stop() { -> $EStop }
            status(): String { @@:("Operational") }
        }

        $EStop {
            reset_e_stop() { -> $Manual }
            status(): String { @@:("EStop") }
        }

    domain:
}

let arm = @@RobotArm()
if (arm.status() as! String) != "Manual" { print("FAIL: Manual"); exit(1) }
arm.e_stop()
if (arm.status() as! String) != "EStop" { print("FAIL: EStop"); exit(1) }
arm.reset_e_stop()
if (arm.status() as! String) != "Manual" { print("FAIL: Manual2"); exit(1) }
arm.set_auto()
if (arm.status() as! String) != "Auto" { print("FAIL: Auto"); exit(1) }
arm.e_stop()
if (arm.status() as! String) != "EStop" { print("FAIL: EStop from Auto"); exit(1) }
print("PASS: robot_arm")

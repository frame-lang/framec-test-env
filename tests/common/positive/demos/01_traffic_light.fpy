@@[target("python_3")]

@@system TrafficLight {
    interface:
        next(): str

    machine:
        $Green {
            next(): str {
                @@:("green")
                -> $Yellow
            }
        }
        $Yellow {
            next(): str {
                @@:("yellow")
                -> $Red
            }
        }
        $Red {
            next(): str {
                @@:("red")
                -> $Green
            }
        }
}

if __name__ == '__main__':
    light = @@TrafficLight()
    results = []
    for _ in range(6):
        results.append(light.next())
    expected = ["green", "yellow", "red", "green", "yellow", "red"]
    assert results == expected, f"Expected {expected}, got {results}"
    print("PASS: traffic_light")

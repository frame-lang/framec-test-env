@@[target("php")]


@@system Logger {
    interface:
        log(msg: str)

    machine:
        $Active {
            log(msg: str) {
                echo "[LOG] " . $msg . "\n";
            }
        }
}

@@[main]
@@system App {
    interface:
        start()
        stop()

    machine:
        $Idle {
            start() {
                $this->logger->log("App starting");
                -> $Running
            }
        }
        $Running {
            $>() { $this->logger->log("App running"); }
            stop() {
                $this->logger->log("App stopping");
                -> $Idle
            }
        }

    domain:
        logger = @@Logger()
}

$app = @@App();
$app->start();
$app->stop();
echo "PASS: multi_system_composition\n";

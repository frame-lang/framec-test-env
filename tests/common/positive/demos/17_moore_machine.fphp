@@target php

<?php

@@system MooreParity {
    interface:
        input(bit: int)
        output(): str

    machine:
        $Even {
            input(bit: int) {
                if ($bit == 1) {
                    -> $Odd
                }
            }
            output(): str { @@:("even") }
        }
        $Odd {
            input(bit: int) {
                if ($bit == 1) {
                    -> $Even
                }
            }
            output(): str { @@:("odd") }
        }
}

$m = @@MooreParity();
$bits = [1, 0, 1, 1, 0];
$expected = ["odd", "odd", "even", "odd", "odd"];
for ($i = 0; $i < 5; $i++) {
    $m->input($bits[$i]);
    $result = $m->output();
    if ($result !== $expected[$i]) {
        echo "FAIL: after bit {$bits[$i]} expected '{$expected[$i]}', got '$result'\n";
        exit(1);
    }
}
echo "PASS: moore_machine\n";

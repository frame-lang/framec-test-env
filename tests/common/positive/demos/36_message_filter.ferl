@@[target("erlang")]

@@system MessageFilter {
    interface:
        consider(payload: str): str
        stats(): str

    machine:
        $Accepting {
            consider(payload: str): str {
                if self.matches(payload) {
                    self.passed = self.passed + 1
                    self.forward(payload)
                    @@:("passed")
                } else {
                    self.dropped = self.dropped + 1
                    @@:("dropped")
                }
            }
            stats(): str {
                @@:(io_lib:format("passed=~p dropped=~p", [Data#data.passed, Data#data.dropped]))
            }
        }

    actions:
        matches(payload) {
            string:str(payload, "urgent") > 0
        }
        forward(payload) {
            io:format("-> ~s~n", [payload])
        }

    domain:
        passed = 0
        dropped = 0
}

@@[target("typescript")]

@@system TrafficLight {
    interface:
        next(): str

    machine:
        $Green {
            next(): str {
                @@:("green")
                -> $Yellow
            }
        }
        $Yellow {
            next(): str {
                @@:("yellow")
                -> $Red
            }
        }
        $Red {
            next(): str {
                @@:("red")
                -> $Green
            }
        }
}

const light = @@TrafficLight();
const results: string[] = [];
for (let i = 0; i < 6; i++) {
    results.push(light.next() as string);
}
const expected = ["green", "yellow", "red", "green", "yellow", "red"];
if (JSON.stringify(results) !== JSON.stringify(expected)) {
    console.log("FAIL: expected " + JSON.stringify(expected) + " got " + JSON.stringify(results));
    process.exit(1);
}
console.log("PASS: traffic_light");

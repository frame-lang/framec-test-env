@@[target("erlang")]

@@system MealyDetector {
    interface:
        input(bit: int): str

    machine:
        $S0 {
            input(bit: int): str {
                if bit == 1 {
                    @@:("0")
                    -> $S1
                } else {
                    @@:("0")
                }
            }
        }
        $S1 {
            input(bit: int): str {
                if bit == 0 {
                    @@:("1")
                    -> $S0
                } else {
                    @@:("0")
                }
            }
        }
}

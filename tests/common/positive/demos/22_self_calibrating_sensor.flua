-- Self-Calibrating Sensor — @@:self demo (Lua)

@@system Sensor {
    interface:
        calibrate(): str
        reading(): float
        trigger_shutdown()
        attempt_post_shutdown(): str
        status(): str

    machine:
        $Active {
            calibrate(): str {
                local baseline = @@:self:reading()
                self.offset = baseline * -1
                @@:("calibrated: offset=" .. self.offset)
            }

            reading(): float {
                @@:(self.raw_value + self.offset)
            }

            trigger_shutdown() {
                -> $Shutdown
            }

            attempt_post_shutdown(): str {
                self.trace = "before"
                @@:self:trigger_shutdown()
                self.trace = "after"
                @@:(self.trace)
            }

            status(): str { @@:(@@:system.state) }
        }

        $Shutdown {
            status(): str { @@:(@@:system.state) }
        }

    domain:
        raw_value = 42.0
        offset = 0.0
        trace = ""
}

local sensor = @@Sensor()
local failures = 0

local r1 = sensor:reading()
if math.abs(r1 - 42.0) > 1e-9 then
    print("FAIL: reading() expected 42.0, got " .. r1)
    failures = failures + 1
end

local cal = sensor:calibrate()
if not string.find(cal, "calibrated") then
    print("FAIL: calibrate() expected 'calibrated', got '" .. cal .. "'")
    failures = failures + 1
end

local r2 = sensor:reading()
if math.abs(r2) > 1e-9 then
    print("FAIL: reading() after calibrate expected 0.0, got " .. r2)
    failures = failures + 1
end

local result = sensor:attempt_post_shutdown()
if result ~= "before" then
    print("FAIL: attempt_post_shutdown() expected 'before', got '" .. result .. "'")
    failures = failures + 1
end

local st = sensor:status()
if st ~= "Shutdown" then
    print("FAIL: status() expected 'shutdown', got '" .. st .. "'")
    failures = failures + 1
end

if failures > 0 then
    print("FAIL: self_calibrating_sensor (" .. failures .. " failures)")
    os.exit(1)
end
print("PASS: self_calibrating_sensor")

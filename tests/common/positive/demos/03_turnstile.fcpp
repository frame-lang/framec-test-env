@@target cpp_17

#include <iostream>
#include <string>
#include <cassert>

@@system Turnstile {
    interface:
        coin()
        push(): str

    machine:
        $Locked {
            coin() { -> $Unlocked }
            push(): str { @@:(std::string("locked - insert coin")) }
        }
        $Unlocked {
            coin() { }
            push(): str {
                @@:(std::string("welcome"))
                -> $Locked
            }
        }
}

int main() {
    Turnstile t;
    assert(std::any_cast<std::string>(t.push()) == "locked - insert coin");
    t.coin();
    assert(std::any_cast<std::string>(t.push()) == "welcome");
    assert(std::any_cast<std::string>(t.push()) == "locked - insert coin");
    printf("PASS: turnstile\n");
    return 0;
}

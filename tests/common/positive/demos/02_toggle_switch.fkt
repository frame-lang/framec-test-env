@@[target("kotlin")]

@@system Switch {
    interface:
        toggle(): String
        status(): String

    machine:
        $Off {
            toggle(): String {
                @@:("on")
                -> $On
            }
            status(): String { @@:("off") }
        }
        $On {
            toggle(): String {
                @@:("off")
                -> $Off
            }
            status(): String { @@:("on") }
        }
}

fun main() {
    val sw = Switch()
    if (sw.status() as String != "off") {
        throw RuntimeException("Expected 'off' from status")
    }
    if (sw.toggle() as String != "on") {
        throw RuntimeException("Expected 'on' from toggle")
    }
    if (sw.toggle() as String != "off") {
        throw RuntimeException("Expected 'off' from toggle")
    }
    println("PASS: toggle_switch")
}

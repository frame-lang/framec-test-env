@@[target("php")]


@@system TrafficLight {
    interface:
        next(): str

    machine:
        $Green {
            next(): str {
                @@:("green")
                -> $Yellow
            }
        }
        $Yellow {
            next(): str {
                @@:("yellow")
                -> $Red
            }
        }
        $Red {
            next(): str {
                @@:("red")
                -> $Green
            }
        }
}

$light = @@TrafficLight();
$results = [];
for ($i = 0; $i < 6; $i++) {
    $results[] = $light->next();
}
$expected = ["green", "yellow", "red", "green", "yellow", "red"];
if ($results !== $expected) {
    echo "FAIL: expected " . implode(",", $expected) . " got " . implode(",", $results) . "\n";
    exit(1);
}
echo "PASS: traffic_light\n";

@@target lua

@@system VendingMachine(stock = 0) {
    operations:
        get_balance() {
            return self.balance
        }
        get_stock() {
            return self.stock
        }

    interface:
        insert_coin(amount)
        select(): str = "error"
        cancel(): int = 0

    machine:
        $Idle {
            insert_coin(amount) {
                self.balance = amount
                -> $HasCredit
            }
            select(): str { @@:("insert coin first") }
            cancel(): int { @@:(0) }
        }

        $HasCredit {
            insert_coin(amount) {
                self.balance = self.balance + amount
            }
            select(): str {
                if self.balance < self.price then
                    @@:("need more")
                elseif self.stock <= 0 then
                    @@:("sold out")
                else
                    self.stock = self.stock - 1
                    self.balance = self.balance - self.price
                    @@:("dispensing")
                    -> $Dispensing
                end
            }
            cancel(): int {
                local refund = self.balance
                self.balance = 0
                @@:(refund)
                -> $Idle
            }
        }

        $Dispensing {
            $>() {
                local change = self.balance
                self.balance = 0
                if change > 0 then
                    print("Change: " .. change)
                end
                -> $Idle
            }
        }

    domain:
        balance = 0
        stock = 0
        price = 100
}

local vm = @@VendingMachine(3)
local failures = 0

if vm:get_stock() ~= 3 then
    print("FAIL: initial stock expected 3, got " .. tostring(vm:get_stock()))
    failures = failures + 1
end

local r1 = vm:select()
if r1 ~= "insert coin first" then
    print("FAIL: expected 'insert coin first', got '" .. tostring(r1) .. "'")
    failures = failures + 1
end

vm:insert_coin(100)
local r2 = vm:select()
if r2 ~= "dispensing" then
    print("FAIL: expected 'dispensing', got '" .. tostring(r2) .. "'")
    failures = failures + 1
end

if vm:get_stock() ~= 2 then
    print("FAIL: stock after buy expected 2")
    failures = failures + 1
end

vm:insert_coin(50)
local refund = vm:cancel()
if refund ~= 50 then
    print("FAIL: refund expected 50, got " .. tostring(refund))
    failures = failures + 1
end

if failures > 0 then
    print("FAIL: vending_machine (" .. failures .. " failures)")
    os.exit(1)
end
print("PASS: vending_machine")

@@target typescript

@@system Agent {
    interface:
        tick()
        threat()
        safe()
        get_log(): str

    machine:
        $Exploring {
            tick() {
                this.action_log = this.action_log + "explore,"
            }
            threat() {
                this.action_log = this.action_log + "flee,"
                -> $Fleeing
            }
            get_log(): str { @@:(this.action_log) }
        }
        $Fleeing {
            tick() {
                this.action_log = this.action_log + "run,"
            }
            safe() {
                this.action_log = this.action_log + "resume,"
                -> $Exploring
            }
            get_log(): str { @@:(this.action_log) }
        }

    domain:
        action_log: string = ""
}

const a = @@Agent();
a.tick();
a.tick();
a.threat();
a.tick();
a.safe();
const result = a.get_log() as string;
const expected = "explore,explore,flee,run,resume,";
if (result !== expected) { console.log("FAIL: Expected '" + expected + "', got '" + result + "'"); process.exit(1); }
console.log("PASS: ai_agent");

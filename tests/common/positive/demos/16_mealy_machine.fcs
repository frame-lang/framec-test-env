@@target csharp

using System;

@@system MealyDetector {
    interface:
        input(bit: int): String

    machine:
        $S0 {
            input(bit: int): String {
                if (bit == 1) {
                    @@:("0")
                    -> $S1
                } else {
                    @@:("0")
                }
            }
        }
        $S1 {
            input(bit: int): String {
                if (bit == 0) {
                    @@:("1")
                    -> $S0
                } else {
                    @@:("0")
                }
            }
        }
}

class Program {
    static void Main(string[] args) {
        var m = new MealyDetector();
        int[] bits = {1, 0, 1, 1, 0};
        string[] expected = {"0", "1", "0", "0", "1"};
        for (int i = 0; i < 5; i++) {
            string result = (string) m.input(bits[i]);
            if (result != expected[i]) {
                throw new Exception("FAIL: bit=" + bits[i] + " expected '" + expected[i] + "', got '" + result + "'");
            }
        }
        Console.WriteLine("PASS: mealy_machine");
    }
}

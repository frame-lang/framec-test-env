@@[target("kotlin")]

@@system BracketParser {
    interface:
        open()
        close()
        depth_now(): Int
        status(): String

    machine:
        $Flat {
            open() {
                this.depth = this.depth + 1
                push$
                -> $Nested
            }
            depth_now(): Int { @@:(this.depth) }
            status(): String { @@:("flat") }
        }

        $Nested {
            open() {
                this.depth = this.depth + 1
                push$
                -> $Nested
            }
            close() {
                this.depth = this.depth - 1
                -> pop$
            }
            depth_now(): Int { @@:(this.depth) }
            status(): String { @@:("nested") }
        }

    domain:
        depth: Int = 0
}

fun main() {
    val p = @@BracketParser()
    if ((p.status() as String) != "flat") throw RuntimeException("expected flat")
    if ((p.depth_now() as Int) != 0) throw RuntimeException("expected 0")
    p.open()
    if ((p.status() as String) != "nested") throw RuntimeException("expected nested")
    if ((p.depth_now() as Int) != 1) throw RuntimeException("expected 1")
    p.open()
    if ((p.depth_now() as Int) != 2) throw RuntimeException("expected 2")
    p.close()
    if ((p.depth_now() as Int) != 1) throw RuntimeException("expected 1 after")
    p.close()
    if ((p.status() as String) != "flat") throw RuntimeException("expected flat after")
    if ((p.depth_now() as Int) != 0) throw RuntimeException("expected 0 after")
    p.open()
    p.close()
    if ((p.status() as String) != "flat") throw RuntimeException("expected flat re-flat")
    println("PASS: pushdown_parser")
}

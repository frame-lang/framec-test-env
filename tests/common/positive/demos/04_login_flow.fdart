@@target dart

@@system LoginFlow {
    interface:
        submit(value: String): String

    machine:
        $EnterUsername {
            submit(value: String): String {
                this.username = value;
                @@:("enter password")
                -> $EnterPassword
            }
        }
        $EnterPassword {
            submit(value: String): String {
                if (this.authenticate(this.username, value)) {
                    @@:("welcome")
                    -> $LoggedIn
                } else {
                    @@:("invalid - try again")
                    -> $EnterUsername
                }
            }
        }
        $LoggedIn {
            submit(value: String): String { @@:("already logged in") }
        }

    actions:
        authenticate(user, password) {
            return user == "admin" && password == "secret";
        }

    domain:
        username: String = ""
}

void main() {
    final login = @@LoginFlow();
    final r1 = login.submit("admin") as String;
    assert(r1 == "enter password");
    final r2 = login.submit("wrong") as String;
    assert(r2 == "invalid - try again");
    final r3 = login.submit("admin") as String;
    assert(r3 == "enter password");
    final r4 = login.submit("secret") as String;
    assert(r4 == "welcome");
    print("PASS: login_flow");
}

@@[target("lua")]

@@system LaunchController {
    interface:
        countdown_start()
        ignite()
        max_q_passed()
        meco()
        seco()
        abort_launch()
        phase(): str
        outcome(): str

    machine:
        $Idle {
            countdown_start() { -> $Countdown }
            phase(): str { @@:("Idle") }
            outcome(): str { @@:("none") }
        }

        $Countdown {
            ignite() { -> $Boost }
            abort_launch() {
                self.outcome_str = "scrubbed"
                -> $Aborted
            }
            phase(): str { @@:("Countdown") }
            outcome(): str { @@:("none") }
        }

        $Boost {
            max_q_passed() { -> $Sustain }
            abort_launch() {
                self.outcome_str = "RTLS"
                -> $Aborted
            }
            phase(): str { @@:("Boost") }
            outcome(): str { @@:("none") }
        }

        $Sustain {
            meco() { -> $Coast }
            abort_launch() {
                self.outcome_str = "ATO"
                -> $Aborted
            }
            phase(): str { @@:("Sustain") }
            outcome(): str { @@:("none") }
        }

        $Coast {
            seco() { -> $Orbit }
            abort_launch() {
                self.outcome_str = "TAL"
                -> $Aborted
            }
            phase(): str { @@:("Coast") }
            outcome(): str { @@:("none") }
        }

        $Orbit {
            phase(): str { @@:("Orbit") }
            outcome(): str { @@:("nominal") }
        }

        $Aborted {
            phase(): str { @@:("Aborted") }
            outcome(): str { @@:(self.outcome_str) }
        }

    domain:
        outcome_str: str = ""
}

local lc = @@LaunchController()
lc:countdown_start()
lc:ignite()
lc:max_q_passed()
lc:meco()
lc:seco()
assert(lc:phase() == "Orbit", "expected Orbit")
assert(lc:outcome() == "nominal", "expected nominal")

local lc2 = @@LaunchController()
lc2:countdown_start()
lc2:ignite()
lc2:abort_launch()
assert(lc2:outcome() == "RTLS", "expected RTLS")

local lc3 = @@LaunchController()
lc3:countdown_start()
lc3:ignite()
lc3:max_q_passed()
lc3:abort_launch()
assert(lc3:outcome() == "ATO", "expected ATO")

local lc4 = @@LaunchController()
lc4:countdown_start()
lc4:abort_launch()
assert(lc4:outcome() == "scrubbed", "expected scrubbed")

print("PASS: launch_sequence")

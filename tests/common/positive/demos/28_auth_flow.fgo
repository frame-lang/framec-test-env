@@target go

package main

import (
	"fmt"
	"os"
)

@@system LoginManager {
    interface:
        Login(user: string, pass: string): string

    machine:
        $LoggedOut {
            Login(user: string, pass: string): string {
                if user == "admin" && pass == "secret" {
                    @@:return("authenticated")
                }
                @@:("denied")
            }
        }
}

@@system App {
    interface:
        Authenticate(user: string, pass: string): string

    machine:
        $Unauthenticated {
            Authenticate(user: string, pass: string): string {
                @@:(s.auth.Login(user, pass))
            }
        }

    domain:
        auth: *LoginManager = NewLoginManager()
}

func main() {
	app := NewApp()

	r1 := app.Authenticate("admin", "secret")
	if r1 != "authenticated" {
		fmt.Printf("FAIL: expected 'authenticated', got %q\n", r1)
		os.Exit(1)
	}

	r2 := app.Authenticate("admin", "wrong")
	if r2 != "denied" {
		fmt.Printf("FAIL: expected 'denied', got %q\n", r2)
		os.Exit(1)
	}

	fmt.Println("PASS: auth_flow")
}

@@[target("csharp")]


@@[persist(String)]
@@[save(SaveState)]
@@[load(RestoreState)]
@@system DeadLetterProcessor {
    interface:
        accept(msg_id: String, payload: String): String
        process_tick(): String
        reset()

    machine:
        $Idle {
            accept(msg_id: String, payload: String): String {
                this.msg_id = msg_id;
                this.payload = payload;
                this.attempts = 0;
                @@:("accepted")
                -> $Processing
            }
            process_tick(): String { @@:("idle") }
        }

        $Processing {
            $>() {
                this.attempts = this.attempts + 1;
            }
            process_tick(): String {
                if (this.try_process(this.payload)) {
                    @@:("ok")
                    -> "success" $Done
                } else {
                    if (this.attempts >= this.max_attempts) {
                        @@:("dead_lettered")
                        -> "exhausted" $DeadLettered
                    } else {
                        @@:("retrying")
                        -> "retry" $Processing
                    }
                }
            }
        }

        $Done {
            process_tick(): String { @@:("done") }
            reset() { -> $Idle }
        }

        $DeadLettered {
            $>() {
                this.to_dlq(this.msg_id, this.payload);
            }
            process_tick(): String { @@:("dead_lettered") }
            reset() { -> $Idle }
        }

    actions:
        try_process(payload: String): bool {
            return false;
        }
        to_dlq(msg_id: String, payload: String) {
            Console.WriteLine("DLQ <- " + msg_id + ": " + payload);
        }

    domain:
        msg_id: String = ""
        payload: String = ""
        attempts: int = 0
        max_attempts: int = 3
}

class Program {
    static void Main(string[] args) {
        var p = @@DeadLetterProcessor();
        if ((string) p.accept("m-42", "flaky work") != "accepted") throw new Exception("expected accepted");
        if ((string) p.process_tick() != "retrying")               throw new Exception("expected retrying #1");
        if ((string) p.process_tick() != "retrying")               throw new Exception("expected retrying #2");

        var data = (string) p.SaveState();
        var p2 = @@DeadLetterProcessor();
        p2.RestoreState(data);
        if ((string) p2.process_tick() != "dead_lettered")         throw new Exception("expected dead_lettered");
        Console.WriteLine("PASS: dead_letter_channel");
    }
}

@@[target("csharp")]

using System;

@@system RateLimiter {
    operations:
        static TokensForRate(rps: int, interval_ms: int): int {
            return Math.Max(1, (rps * interval_ms) / 1000);
        }
        TokensRemaining(): int {
            return this.tokens;
        }

    interface:
        Request(): string
        Tick()

    machine:
        $Accepting {
            Request(): string {
                this.tokens = this.tokens - 1;
                @@:("accepted")
                if (this.tokens <= 0) {
                    -> $Throttled
                }
            }
            Tick() { this.tokens = Math.Min(this.tokens + 1, this.max_tokens); }
        }
        $Throttled {
            Request(): string { @@:("throttled") }
            Tick() {
                this.tokens = this.tokens + 1;
                if (this.tokens > 0) {
                    -> $Accepting
                }
            }
        }

    domain:
        tokens : int = 10
        max_tokens : int = 10
}

class Program {
    static void Main(string[] args) {
        int failures = 0;
        if (RateLimiter.TokensForRate(100, 50) != 5) { Console.WriteLine("FAIL: static op"); failures++; }
        var rl = @@RateLimiter();
        for (int i = 0; i < 10; i++) { rl.Request(); }
        if ((string) rl.Request() != "throttled") { Console.WriteLine("FAIL: throttled"); failures++; }
        rl.Tick();
        if ((string) rl.Request() != "accepted") { Console.WriteLine("FAIL: accepted"); failures++; }
        if (failures > 0) { Console.WriteLine("FAIL: rate_limiter (" + failures + ")"); Environment.Exit(1); }
        Console.WriteLine("PASS: rate_limiter");
    }
}

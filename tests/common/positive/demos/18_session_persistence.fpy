@@[target("python_3")]

@@[persist(bytes)]
@@[save(save_state)]
@@[load(restore_state)]
@@system Session {
    interface:
        login(user: str)
        logout()
        who(): str

    machine:
        $LoggedOut {
            login(user: str) {
                self.user = user
                -> $LoggedIn
            }
            who(): str { @@:("nobody") }
        }
        $LoggedIn {
            logout() {
                self.user = ""
                -> $LoggedOut
            }
            who(): str { @@:(self.user) }
        }

    domain:
        user: str = ""
}

if __name__ == '__main__':
    s = @@Session()
    s.login("alice")
    assert s.who() == "alice", f"Expected 'alice', got '{s.who()}'"

    # Save
    data = s.save_state()

    # Restore into a new instance
    s2 = @@Session()

    s2.restore_state(data)
    assert s2.who() == "alice", f"Expected 'alice' after restore, got '{s2.who()}'"
    print("PASS: session_persistence")

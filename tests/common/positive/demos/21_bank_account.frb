@@target ruby

@@system Account(owner: str, initial_balance: int = 0) {
    interface:
        deposit(amount: int)
        withdraw(amount: int): bool
        balance(): int
        owner_name(): str
        close()

    machine:
        $Open {
            deposit(amount: int) {
                @bal = @bal + amount
            }
            withdraw(amount: int): bool {
                if @bal >= amount
                    @bal = @bal - amount
                    @@:(true)
                else
                    @@:(false)
                end
            }
            balance(): int { @@:(@bal) }
            owner_name(): str { @@:(@who) }
            close() { -> $Closed }
        }
        $Closed {
            deposit(amount: int) {
                # Closed accounts ignore deposits.
            }
            withdraw(amount: int): bool { @@:(false) }
            balance(): int { @@:(@bal) }
            owner_name(): str { @@:(@who) }
        }

    domain:
        bal = initial_balance
        who = owner
}

a = Account.new("Alice", 100)
raise "owner" unless a.owner_name() == "Alice"
raise "balance" unless a.balance() == 100

a.deposit(50)
raise "deposit" unless a.balance() == 150

raise "withdraw ok" unless a.withdraw(60) == true
raise "balance after withdraw" unless a.balance() == 90

raise "withdraw insufficient" unless a.withdraw(200) == false
raise "balance unchanged" unless a.balance() == 90

a.close()
raise "closed withdraw" unless a.withdraw(10) == false
raise "closed balance" unless a.balance() == 90

b = Account.new("Bob")
raise "bob owner" unless b.owner_name() == "Bob"
raise "bob balance" unless b.balance() == 0
b.deposit(25)
raise "bob deposit" unless b.balance() == 25

puts "ok 1 - 21_bank_account"

@@[target("kotlin")]

import kotlin.system.exitProcess

@@system RateLimiter {
    operations:
        static tokens_for_rate(rps: Int, interval_ms: Int): Int {
            return maxOf(1, (rps * interval_ms) / 1000)
        }
        tokens_remaining(): Int {
            return this.tokens
        }

    interface:
        request(): String
        tick()

    machine:
        $Accepting {
            request(): String {
                this.tokens = this.tokens - 1
                @@:("accepted")
                if (this.tokens <= 0) {
                    -> $Throttled
                }
            }
            tick() { this.tokens = minOf(this.tokens + 1, this.max_tokens) }
        }
        $Throttled {
            request(): String { @@:("throttled") }
            tick() {
                this.tokens = this.tokens + 1
                if (this.tokens > 0) {
                    -> $Accepting
                }
            }
        }

    domain:
        tokens = 10
        max_tokens = 10
}

fun main() {
    var failures = 0
    if (RateLimiter.tokens_for_rate(100, 50) != 5) { println("FAIL: static op"); failures++ }
    val rl = @@RateLimiter()
    for (i in 1..10) { rl.request() }
    if (rl.request() as String != "throttled") { println("FAIL: throttled"); failures++ }
    rl.tick()
    if (rl.request() as String != "accepted") { println("FAIL: accepted"); failures++ }

    if (failures > 0) { println("FAIL: rate_limiter ($failures)"); exitProcess(1) }
    println("PASS: rate_limiter")
}

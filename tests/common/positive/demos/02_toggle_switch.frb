@@[target("ruby")]

@@system Switch {
    interface:
        toggle(): str
        status(): str

    machine:
        $Off {
            toggle(): str {
                @@:("on")
                -> $On
            }
            status(): str { @@:("off") }
        }
        $On {
            toggle(): str {
                @@:("off")
                -> $Off
            }
            status(): str { @@:("on") }
        }
}

sw = @@Switch()
raise "Expected 'off' from status, got '#{sw.status}'" unless sw.status == "off"
raise "Expected 'on' from toggle, got '#{sw.toggle}'" unless sw.toggle == "on"
raise "Expected 'off' from toggle, got '#{sw.toggle}'" unless sw.toggle == "off"
puts "PASS: toggle_switch"

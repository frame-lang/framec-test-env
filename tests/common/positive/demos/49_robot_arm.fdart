@@[target("dart")]

@@system RobotArm {
    interface:
        set_manual()
        set_auto()
        e_stop()
        reset_e_stop()
        status(): String

    machine:
        $Manual => $Operational {
            set_auto() { -> $Auto }
            status(): String { @@:("Manual") }
            => $^
        }

        $Auto => $Operational {
            set_manual() { -> $Manual }
            status(): String { @@:("Auto") }
            => $^
        }

        $Operational {
            e_stop() { -> $EStop }
            status(): String { @@:("Operational") }
        }

        $EStop {
            reset_e_stop() { -> $Manual }
            status(): String { @@:("EStop") }
        }

    domain:
}

void main() {
    final arm = @@RobotArm();
    if (arm.status() != "Manual") throw "expected Manual";
    arm.e_stop();
    if (arm.status() != "EStop") throw "expected EStop";
    arm.reset_e_stop();
    if (arm.status() != "Manual") throw "expected Manual2";
    arm.set_auto();
    if (arm.status() != "Auto") throw "expected Auto";
    arm.e_stop();
    if (arm.status() != "EStop") throw "expected EStop from Auto";
    print("PASS: robot_arm");
}

@@[target("java")]

@@system RobotArm {
    interface:
        set_manual()
        set_auto()
        e_stop()
        reset_e_stop()
        status(): String

    machine:
        $Manual => $Operational {
            set_auto() { -> $Auto }
            status(): String { @@:("Manual") }
            => $^
        }

        $Auto => $Operational {
            set_manual() { -> $Manual }
            status(): String { @@:("Auto") }
            => $^
        }

        $Operational {
            e_stop() { -> $EStop }
            status(): String { @@:("Operational") }
        }

        $EStop {
            reset_e_stop() { -> $Manual }
            status(): String { @@:("EStop") }
        }

    domain:
}

class Main {
    public static void main(String[] args) {
        var arm = @@RobotArm();
        if (!((String) arm.status()).equals("Manual")) throw new RuntimeException("expected Manual");
        arm.e_stop();
        if (!((String) arm.status()).equals("EStop")) throw new RuntimeException("expected EStop");
        arm.reset_e_stop();
        if (!((String) arm.status()).equals("Manual")) throw new RuntimeException("expected Manual2");
        arm.set_auto();
        if (!((String) arm.status()).equals("Auto")) throw new RuntimeException("expected Auto");
        arm.e_stop();
        if (!((String) arm.status()).equals("EStop")) throw new RuntimeException("expected EStop from Auto");
        System.out.println("PASS: robot_arm");
    }
}

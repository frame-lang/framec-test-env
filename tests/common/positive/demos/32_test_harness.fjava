@@target java
// Test Harness — @@:system.state in operations demo (Java)

@@system TestHarness {
    operations:
        current_state(): String {
            @@:(@@:system.state)
        }

    interface:
        run()
        pass_test()
        fail(reason: String)
        get_state(): String
        get_result(): String

    machine:
        $Ready {
            run() {
                this.result = "";
                -> $Running
            }
            get_state(): String { @@:("ready") }
            get_result(): String { @@:(this.result) }
        }
        $Running {
            pass_test() {
                this.result = "pass";
                -> $Passed
            }
            fail(reason: String) {
                this.result = reason;
                -> $Failed
            }
            get_state(): String { @@:("running") }
            get_result(): String { @@:("") }
        }
        $Passed {
            run() {
                this.result = "";
                -> $Running
            }
            get_state(): String { @@:("passed") }
            get_result(): String { @@:(this.result) }
        }
        $Failed {
            run() {
                this.result = "";
                -> $Running
            }
            get_state(): String { @@:("failed") }
            get_result(): String { @@:(this.result) }
        }

    domain:
        result : String = ""
}

class Main {
    public static void main(String[] args) {
        TestHarness th = @@TestHarness();
        int failures = 0;

        if (!th.current_state().equals("Ready")) {
            System.out.println("FAIL: current_state expected Ready, got " + th.current_state());
            failures++;
        }

        if (!th.get_state().equals("ready")) {
            System.out.println("FAIL: get_state expected ready");
            failures++;
        }

        th.run();
        if (!th.current_state().equals("Running")) {
            System.out.println("FAIL: current_state expected Running, got " + th.current_state());
            failures++;
        }

        th.pass_test();
        if (!th.current_state().equals("Passed")) {
            System.out.println("FAIL: current_state expected Passed, got " + th.current_state());
            failures++;
        }

        if (!th.get_result().equals("pass")) {
            System.out.println("FAIL: get_result expected pass");
            failures++;
        }

        th.run();
        th.fail("timeout");
        if (!th.current_state().equals("Failed")) {
            System.out.println("FAIL: current_state expected Failed, got " + th.current_state());
            failures++;
        }

        if (!th.get_result().equals("timeout")) {
            System.out.println("FAIL: get_result expected timeout");
            failures++;
        }

        if (failures > 0) {
            System.out.println("FAIL: test_harness (" + failures + " failures)");
            System.exit(1);
        }
        System.out.println("PASS: test_harness");
    }
}

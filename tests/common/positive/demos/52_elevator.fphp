@@[target("php")]


@@system Elevator {
    interface:
        request(floor: int)
        tick()
        close_doors()
        current_floor(): int
        status(): str

    machine:
        $Idle {
            request(floor: int) {
                if ($floor > $this->floor) {
                    $this->target = $floor;
                    -> $MovingUp
                } else if ($floor < $this->floor) {
                    $this->target = $floor;
                    -> $MovingDown
                } else {
                    -> $DoorsOpen
                }
            }
            current_floor(): int { @@:($this->floor) }
            status(): str { @@:("idle") }
        }

        $MovingUp {
            tick() {
                $this->floor = $this->floor + 1;
                if ($this->floor === $this->target) {
                    -> $DoorsOpen
                }
            }
            current_floor(): int { @@:($this->floor) }
            status(): str { @@:("up") }
        }

        $MovingDown {
            tick() {
                $this->floor = $this->floor - 1;
                if ($this->floor === $this->target) {
                    -> $DoorsOpen
                }
            }
            current_floor(): int { @@:($this->floor) }
            status(): str { @@:("down") }
        }

        $DoorsOpen {
            close_doors() { -> $Idle }
            current_floor(): int { @@:($this->floor) }
            status(): str { @@:("doors_open") }
        }

    domain:
        floor = 1
        target = 1
}

$e = @@Elevator();
assert($e->status() === "idle");
assert($e->current_floor() === 1);
$e->request(5);
assert($e->status() === "up");
$e->tick(); $e->tick(); $e->tick(); $e->tick();
assert($e->current_floor() === 5);
assert($e->status() === "doors_open");
$e->close_doors();
assert($e->status() === "idle");
$e->request(2);
assert($e->status() === "down");
$e->tick(); $e->tick(); $e->tick();
assert($e->current_floor() === 2);
assert($e->status() === "doors_open");
$e->close_doors();
$e->request(2);
assert($e->status() === "doors_open");
echo "PASS: elevator\n";

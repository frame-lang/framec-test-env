@@[target("typescript")]

@@system Turnstile {
    interface:
        coin()
        push(): str

    machine:
        $Locked {
            coin() { -> $Unlocked }
            push(): str { @@:("locked - insert coin") }
        }
        $Unlocked {
            coin() { }
            push(): str {
                @@:("welcome")
                -> $Locked
            }
        }
}

const t = @@Turnstile();
if (t.push() as string !== "locked - insert coin") {
    console.log("FAIL: expected 'locked - insert coin'");
    process.exit(1);
}
t.coin();
if (t.push() as string !== "welcome") {
    console.log("FAIL: expected 'welcome'");
    process.exit(1);
}
if (t.push() as string !== "locked - insert coin") {
    console.log("FAIL: expected 'locked - insert coin'");
    process.exit(1);
}
console.log("PASS: turnstile");

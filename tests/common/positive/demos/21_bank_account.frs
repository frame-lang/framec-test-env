@@target rust

@@system Account(owner: String, initial_balance: i64 = 0) {
    interface:
        deposit(amount: i64)
        withdraw(amount: i64): bool
        balance(): i64
        owner_name(): String
        close()

    machine:
        $Open {
            deposit(amount: i64) {
                self.bal = self.bal + amount;
            }
            withdraw(amount: i64): bool {
                if self.bal >= amount {
                    self.bal = self.bal - amount;
                    @@:(true)
                } else {
                    @@:(false)
                }
            }
            balance(): i64 { @@:(self.bal) }
            owner_name(): String { @@:(self.who.clone()) }
            close() { -> $Closed }
        }
        $Closed {
            deposit(amount: i64) {
                // Closed accounts ignore deposits.
            }
            withdraw(amount: i64): bool { @@:(false) }
            balance(): i64 { @@:(self.bal) }
            owner_name(): String { @@:(self.who.clone()) }
        }

    domain:
        bal: i64 = initial_balance
        who: String = owner
}

fn main() {
    let mut a = @@Account("Alice".to_string(), 100);
    assert_eq!(a.owner_name(), "Alice");
    assert_eq!(a.balance(), 100);

    a.deposit(50);
    assert_eq!(a.balance(), 150);

    assert_eq!(a.withdraw(60), true);
    assert_eq!(a.balance(), 90);

    assert_eq!(a.withdraw(200), false);
    assert_eq!(a.balance(), 90);

    a.close();
    assert_eq!(a.withdraw(10), false);
    assert_eq!(a.balance(), 90);

    let mut b = @@Account("Bob".to_string());
    assert_eq!(b.owner_name(), "Bob");
    assert_eq!(b.balance(), 0);
    b.deposit(25);
    assert_eq!(b.balance(), 25);

    println!("ok 1 - 21_bank_account");
}

@@[target("kotlin")]

@@[persist(String)]
@@[save(save_state)]
@@[load(restore_state)]
@@system WizardMachine {
    interface:
        start(user: String)
        client_collect(email: String)
        server_validate()
        client_confirm(accept: Boolean)
        server_provision()
        where_next(): String

    machine:
        $Start {
            start(user: String) {
                this.user = user
                -> $NeedsClientCollect
            }
            where_next(): String { @@:("start") }
        }

        $NeedsClientCollect {
            client_collect(email: String) {
                this.email = email
                -> $NeedsServerValidate
            }
            where_next(): String { @@:("client") }
        }

        $NeedsServerValidate {
            server_validate() {
                if (this.email.contains("@")) {
                    this.server_notes = "ok"
                    -> "valid" $NeedsClientConfirm
                } else {
                    this.server_notes = "rejected"
                    -> "invalid" $Rejected
                }
            }
            where_next(): String { @@:("server") }
        }

        $NeedsClientConfirm {
            client_confirm(accept: Boolean) {
                if (accept) {
                    -> "accepted" $NeedsServerProvision
                } else {
                    -> "declined" $Cancelled
                }
            }
            where_next(): String { @@:("client") }
        }

        $NeedsServerProvision {
            server_provision() {
                this.account_id = "acct-${this.user}"
                -> $Done
            }
            where_next(): String { @@:("server") }
        }

        $Done      { where_next(): String { @@:("done") } }
        $Cancelled { where_next(): String { @@:("done") } }
        $Rejected  { where_next(): String { @@:("done") } }

    domain:
        user: String = ""
        email: String = ""
        server_notes: String = ""
        account_id: String = ""
}

fun main() {
    val m = @@WizardMachine()
    m.start("alice")
    m.client_collect("alice@example.com")
    if ((m.where_next() as String) != "server") throw RuntimeException("expected server #1")

    val blob = m.save_state() as String
    val m2 = WizardMachine()
    m2.restore_state(blob)
    m2.server_validate()
    if ((m2.where_next() as String) != "client") throw RuntimeException("expected client #2")

    val blob2 = m2.save_state() as String
    val m3 = WizardMachine()
    m3.restore_state(blob2)
    m3.client_confirm(true)
    if ((m3.where_next() as String) != "server") throw RuntimeException("expected server #3")

    val blob3 = m3.save_state() as String
    val m4 = WizardMachine()
    m4.restore_state(blob3)
    m4.server_provision()
    if ((m4.where_next() as String) != "done") throw RuntimeException("expected done")
    println("PASS: migrating_machine")
}

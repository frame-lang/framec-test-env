@@[target("swift")]

import Foundation

@@[persist(String)]
@@[save(saveState)]
@@[load(restoreState)]
@@system WizardMachine {
    interface:
        start(user: String)
        client_collect(email: String)
        server_validate()
        client_confirm(accept: Bool)
        server_provision()
        where_next(): String

    machine:
        $Start {
            start(user: String) {
                self.user = user
                -> $NeedsClientCollect
            }
            where_next(): String { @@:("start") }
        }

        $NeedsClientCollect {
            client_collect(email: String) {
                self.email = email
                -> $NeedsServerValidate
            }
            where_next(): String { @@:("client") }
        }

        $NeedsServerValidate {
            server_validate() {
                if self.email.contains("@") {
                    self.server_notes = "ok"
                    -> "valid" $NeedsClientConfirm
                } else {
                    self.server_notes = "rejected"
                    -> "invalid" $Rejected
                }
            }
            where_next(): String { @@:("server") }
        }

        $NeedsClientConfirm {
            client_confirm(accept: Bool) {
                if accept {
                    -> "accepted" $NeedsServerProvision
                } else {
                    -> "declined" $Cancelled
                }
            }
            where_next(): String { @@:("client") }
        }

        $NeedsServerProvision {
            server_provision() {
                self.account_id = "acct-\(self.user)"
                -> $Done
            }
            where_next(): String { @@:("server") }
        }

        $Done      { where_next(): String { @@:("done") } }
        $Cancelled { where_next(): String { @@:("done") } }
        $Rejected  { where_next(): String { @@:("done") } }

    domain:
        user: String = ""
        email: String = ""
        server_notes: String = ""
        account_id: String = ""
}

var m = @@WizardMachine()
m.start("alice")
m.client_collect("alice@example.com")
if (m.where_next() as! String) != "server" { print("FAIL: server #1"); exit(1) }

let blob = m.saveState()
var m2 = WizardMachine()
m2.restoreState(blob)
m2.server_validate()
if (m2.where_next() as! String) != "client" { print("FAIL: client #2"); exit(1) }

let blob2 = m2.saveState()
var m3 = WizardMachine()
m3.restoreState(blob2)
m3.client_confirm(true)
if (m3.where_next() as! String) != "server" { print("FAIL: server #3"); exit(1) }

let blob3 = m3.saveState()
var m4 = WizardMachine()
m4.restoreState(blob3)
m4.server_provision()
if (m4.where_next() as! String) != "done" { print("FAIL: done"); exit(1) }
print("PASS: migrating_machine")

@@target ruby

@@system DialogManager {
    interface:
        open(name: str)
        close(): str
        current(): str

    machine:
        $Main {
            open(name: str) {
                push$
                -> (name) $Dialog
            }
            current(): str { @@:("main") }
        }
        $Dialog {
            $.name: str = ""

            $>(name: str) { $.name = name }

            open(name: str) {
                push$
                -> (name) $Dialog
            }
            close(): str {
                @@:($.name)
                -> pop$
            }
            current(): str { @@:($.name) }
        }
}

dm = DialogManager.new
raise "Expected 'main'" unless dm.current() == "main"
dm.open("Settings")
raise "Expected 'Settings'" unless dm.current() == "Settings"
dm.open("Confirm")
raise "Expected 'Confirm'" unless dm.current() == "Confirm"
closed = dm.close()
raise "Expected 'Confirm'" unless closed == "Confirm"
raise "Expected 'Settings'" unless dm.current() == "Settings"
closed = dm.close()
raise "Expected 'Settings'" unless closed == "Settings"
raise "Expected 'main'" unless dm.current() == "main"
puts "PASS: modal_dialog_stack"

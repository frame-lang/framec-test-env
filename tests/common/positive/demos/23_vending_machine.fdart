@@target dart

import 'dart:io';

@@system VendingMachine(stock: int = 0) {
    operations:
        get_balance(): int {
            return this.balance;
        }
        get_stock(): int {
            return this.stock;
        }

    interface:
        insert_coin(amount: int)
        select(): String
        cancel(): int

    machine:
        $Idle {
            insert_coin(amount: int) {
                this.balance = amount;
                -> $HasCredit
            }
            select(): String {
                @@:("insert coin first")
            }
            cancel(): int {
                @@:(0)
            }
        }

        $HasCredit {
            insert_coin(amount: int) {
                this.balance = this.balance + amount;
            }
            select(): String {
                if (this.balance < this.price) {
                    @@:("need more")
                } else if (this.stock <= 0) {
                    @@:("sold out")
                } else {
                    this.stock = this.stock - 1;
                    this.balance = this.balance - this.price;
                    @@:("dispensing")
                    -> $Dispensing
                }
            }
            cancel(): int {
                var refund = this.balance;
                this.balance = 0;
                @@:(refund)
                -> $Idle
            }
        }

        $Dispensing {
            $>() {
                var change = this.balance;
                this.balance = 0;
                if (change > 0) {
                    print("Change: $change");
                }
                -> $Idle
            }
        }

    domain:
        balance : int = 0
        stock : int = 0
        price : int = 100
}

void main() {
    var vm = @@VendingMachine(3);
    int failures = 0;

    if (vm.get_stock() != 3) {
        print("FAIL: initial stock expected 3, got ${vm.get_stock()}");
        failures++;
    }

    var r1 = vm.select();
    if (r1 != "insert coin first") {
        print("FAIL: expected 'insert coin first', got '$r1'");
        failures++;
    }

    vm.insert_coin(100);
    var r2 = vm.select();
    if (r2 != "dispensing") {
        print("FAIL: expected 'dispensing', got '$r2'");
        failures++;
    }

    if (vm.get_stock() != 2) {
        print("FAIL: stock after buy expected 2, got ${vm.get_stock()}");
        failures++;
    }

    vm.insert_coin(50);
    var refund = vm.cancel();
    if (refund != 50) {
        print("FAIL: refund expected 50, got $refund");
        failures++;
    }

    if (failures > 0) { print("FAIL: vending_machine ($failures)"); exit(1); }
    print("PASS: vending_machine");
}

@@[target("go")]

package main

import (
	"fmt"
	"os"
)

@@system MealyDetector {
    interface:
        input(bit: int): string

    machine:
        $S0 {
            input(bit: int): string {
                if (bit == 1) {
                    @@:("0")
                    -> $S1
                } else {
                    @@:("0")
                }
            }
        }
        $S1 {
            input(bit: int): string {
                if (bit == 0) {
                    @@:("1")
                    -> $S0
                } else {
                    @@:("0")
                }
            }
        }
}

func main() {
	m := @@MealyDetector()
	bits := []int{1, 0, 1, 1, 0}
	expected := []string{"0", "1", "0", "0", "1"}
	for i, bit := range bits {
		result := m.Input(bit)
		if result != expected[i] {
			fmt.Printf("FAIL: bit=%d expected '%s', got '%s'\n", bit, expected[i], result)
			os.Exit(1)
		}
	}
	fmt.Println("PASS: mealy_machine")
}

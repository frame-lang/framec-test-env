@@[target("ruby")]

@@system FixSellSide {
    interface:
        new_order(cl_ord_id: str, qty: float, price: float)
        market_fill(qty: float, px: float)
        cancel_request(cancel_cl_ord_id: str)
        status(): str
        get_cum_qty(): float
        get_leaves_qty(): float

    machine:
        $NoOrder {
            new_order(cl_ord_id: str, qty: float, price: float) {
                @cl_ord_id = cl_ord_id
                @order_qty = qty
                @leaves_qty = qty
                @price = price
                -> $Working
            }
            status(): str { @@:("NoOrder") }
            get_cum_qty(): float { @@:(@cum_qty) }
            get_leaves_qty(): float { @@:(@leaves_qty) }
        }

        $Working {
            market_fill(qty: float, px: float) {
                @cum_qty = @cum_qty + qty
                @leaves_qty = @order_qty - @cum_qty
                if @leaves_qty <= 0.0
                    -> $Filled
                end
            }
            cancel_request(cancel_cl_ord_id: str) { -> $Canceled }
            status(): str { @@:("Working") }
            get_cum_qty(): float { @@:(@cum_qty) }
            get_leaves_qty(): float { @@:(@leaves_qty) }
        }

        $Filled {
            status(): str { @@:("Filled") }
            get_cum_qty(): float { @@:(@cum_qty) }
            get_leaves_qty(): float { @@:(@leaves_qty) }
        }

        $Canceled {
            status(): str { @@:("Canceled") }
            get_cum_qty(): float { @@:(@cum_qty) }
            get_leaves_qty(): float { @@:(@leaves_qty) }
        }

    domain:
        cl_ord_id = ""
        order_qty = 0.0
        cum_qty = 0.0
        leaves_qty = 0.0
        price = 0.0
}

o = @@FixSellSide()
raise "expected NoOrder" unless o.status == "NoOrder"
o.new_order("CL-1", 200.0, 50.0)
raise "expected Working" unless o.status == "Working"
raise "expected leaves=200" unless o.get_leaves_qty == 200.0
o.market_fill(80.0, 50.05)
raise "expected cum=80" unless o.get_cum_qty == 80.0
o.market_fill(120.0, 50.10)
raise "expected Filled" unless o.status == "Filled"

o2 = @@FixSellSide()
o2.new_order("CL-2", 100.0, 49.0)
o2.market_fill(30.0, 49.10)
o2.cancel_request("CXL-2")
raise "expected Canceled" unless o2.status == "Canceled"
puts "PASS: fix_sell_side"

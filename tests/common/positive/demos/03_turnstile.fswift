@@target swift

@@system Turnstile {
    interface:
        coin()
        push(): String

    machine:
        $Locked {
            coin() { -> $Unlocked }
            push(): String { @@:("locked - insert coin") }
        }
        $Unlocked {
            coin() { }
            push(): String {
                @@:("welcome")
                -> $Locked
            }
        }
}

var t = @@Turnstile()
if t.push() as! String != "locked - insert coin" {
    fatalError("Expected 'locked - insert coin'")
}
t.coin()
if t.push() as! String != "welcome" {
    fatalError("Expected 'welcome'")
}
if t.push() as! String != "locked - insert coin" {
    fatalError("Expected 'locked - insert coin'")
}
print("PASS: turnstile")

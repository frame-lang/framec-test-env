@@target gdscript

extends SceneTree

@@system Thermostat {
    interface:
        set_target(temp: int)
        tick(): str
        status(): str

    machine:
        $Off {
            set_target(temp: int) {
                self.target = temp
                -> $Heating
            }
            status(): str { @@:("off") }
        }
        $Heating => $Active {
            tick(): str {
                self.current = self.current + self.heat_rate
                @@:("heating")
                if self.current >= self.target:
                    -> $Cooling
            }
            status(): str { @@:("heating") }
            => $^
        }
        $Cooling => $Active {
            tick(): str {
                self.current = self.current - 1
                @@:("cooling")
                if self.current <= self.target - 2:
                    -> $Heating
            }
            status(): str { @@:("cooling") }
            => $^
        }
        $Active {
            set_target(temp: int) {
                self.target = temp
            }
        }

    domain:
        current = 60
        target = 72
        heat_rate = 2
}

func _init():
    var t = @@Thermostat()

    assert(t.status() == "off", "Expected off")

    t.set_target(64)
    assert(t.status() == "heating", "Expected heating")

    var r = t.tick()
    assert(r == "heating", "Expected heating tick, got: " + str(r))

    r = t.tick()
    assert(t.status() == "cooling", "Expected cooling after reaching target")

    t.set_target(66)
    assert(t.status() == "cooling", "Expected still cooling (HSM parent)")

    print("PASS: thermostat")
    quit()

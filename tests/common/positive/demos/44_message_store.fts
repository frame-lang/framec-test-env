@@[target("typescript")]

@@[persist(string)]
@@[save(saveState)]
@@[load(restoreState)]
@@system MessageStore {
    interface:
        record(topic: str, payload: str)
        count_for(topic: str): int
        total(): int

    machine:
        $Recording {
            record(topic: str, payload: str) {
                this.total_count = this.total_count + 1;
                if (topic === "orders") {
                    this.orders_count = this.orders_count + 1;
                } else {
                    if (topic === "refunds") {
                        this.refunds_count = this.refunds_count + 1;
                    }
                }
            }
            count_for(topic: str): int {
                if (topic === "orders") {
                    @@:(this.orders_count)
                } else {
                    if (topic === "refunds") {
                        @@:(this.refunds_count)
                    } else {
                        @@:(0)
                    }
                }
            }
            total(): int { @@:(this.total_count) }
        }

    domain:
        total_count: int = 0
        orders_count: int = 0
        refunds_count: int = 0
}

const s = @@MessageStore();
s.record("orders", "O-1");
s.record("orders", "O-2");
s.record("refunds", "R-1");

const snap = s.saveState();
const s2 = @@MessageStore();
s2.restoreState(snap);
if (s2.total() !== 3) throw new Error("expected total=3");
if (s2.count_for("orders") !== 2) throw new Error("expected orders=2");
s2.record("orders", "O-3");
if (s2.total() !== 4) throw new Error("expected total=4");
if (s2.count_for("orders") !== 3) throw new Error("expected orders=3");
console.log("PASS: message_store");

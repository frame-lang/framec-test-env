@@[target("lua")]

@@system ContentBasedRouter {
    interface:
        route(kind: str, payload: str): str

    machine:
        $Routing {
            route(kind: str, payload: str): str {
                if kind == "order" then
                    self:to_orders(payload)
                    @@:("orders")
                else
                    if kind == "refund" then
                        self:to_refunds(payload)
                        @@:("refunds")
                    else
                        self:to_dlq(payload)
                        @@:("dlq")
                    end
                end
            }
        }

    actions:
        to_orders(p)  { print("-> orders:  " .. p) }
        to_refunds(p) { print("-> refunds: " .. p) }
        to_dlq(p)     { print("-> dlq:     " .. p) }
}

local r = @@ContentBasedRouter()
assert(r:route("order",   "SKU-1") == "orders")
assert(r:route("refund",  "INV-7") == "refunds")
assert(r:route("unknown", "???")    == "dlq")
print("PASS: content_router")

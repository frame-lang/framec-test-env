@@target typescript

@@system Account(owner: str, initial_balance: int = 0) {
    interface:
        deposit(amount: int)
        withdraw(amount: int): bool
        balance(): int
        owner_name(): str
        close()

    machine:
        $Open {
            deposit(amount: int) {
                this.bal = this.bal + amount
            }
            withdraw(amount: int): bool {
                if (this.bal >= amount) {
                    this.bal = this.bal - amount
                    @@:(true)
                } else {
                    @@:(false)
                }
            }
            balance(): int { @@:(this.bal) }
            owner_name(): str { @@:(this.who) }
            close() { -> $Closed }
        }
        $Closed {
            deposit(amount: int) {
                // Closed accounts ignore deposits.
            }
            withdraw(amount: int): bool { @@:(false) }
            balance(): int { @@:(this.bal) }
            owner_name(): str { @@:(this.who) }
        }

    domain:
        bal = initial_balance
        who = owner
}

const a = @@Account("Alice", 100);
if (a.owner_name() !== "Alice") { console.log("FAIL: owner"); process.exit(1); }
if (a.balance() !== 100) { console.log("FAIL: balance"); process.exit(1); }

a.deposit(50);
if (a.balance() !== 150) { console.log("FAIL: deposit"); process.exit(1); }

if (a.withdraw(60) !== true) { console.log("FAIL: withdraw ok"); process.exit(1); }
if (a.balance() !== 90) { console.log("FAIL: balance after withdraw"); process.exit(1); }

if (a.withdraw(200) !== false) { console.log("FAIL: withdraw insufficient"); process.exit(1); }
if (a.balance() !== 90) { console.log("FAIL: balance unchanged"); process.exit(1); }

a.close();
if (a.withdraw(10) !== false) { console.log("FAIL: closed withdraw"); process.exit(1); }
if (a.balance() !== 90) { console.log("FAIL: closed balance"); process.exit(1); }

const b = @@Account("Bob");
if (b.owner_name() !== "Bob") { console.log("FAIL: bob owner"); process.exit(1); }
if (b.balance() !== 0) { console.log("FAIL: bob balance"); process.exit(1); }
b.deposit(25);
if (b.balance() !== 25) { console.log("FAIL: bob deposit"); process.exit(1); }

console.log("ok 1 - 21_bank_account");

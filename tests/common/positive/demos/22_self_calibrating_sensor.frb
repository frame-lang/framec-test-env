# Self-Calibrating Sensor — @@:self demo (Ruby)

@@system Sensor {
    interface:
        calibrate(): str
        reading(): float
        trigger_shutdown()
        attempt_post_shutdown(): str
        status(): str

    machine:
        $Active {
            calibrate(): str {
                baseline = @@:self.reading()
                self.offset = baseline * -1
                @@:("calibrated: offset=#{self.offset}")
            }

            reading(): float {
                @@:(self.raw_value + self.offset)
            }

            trigger_shutdown() {
                -> $Shutdown
            }

            attempt_post_shutdown(): str {
                self.trace = "before"
                @@:self.trigger_shutdown()
                self.trace = "after"
                @@:(self.trace)
            }

            status(): str { @@:(@@:system.state) }
        }

        $Shutdown {
            status(): str { @@:(@@:system.state) }
        }

    domain:
        raw_value = 42.0
        offset = 0.0
        trace = ""
}

sensor = @@Sensor()
failures = 0

r1 = sensor.reading()
if (r1 - 42.0).abs > 1e-9
    puts "FAIL: reading() expected 42.0, got #{r1}"
    failures += 1
end

cal = sensor.calibrate()
unless cal.include?("calibrated")
    puts "FAIL: calibrate() expected 'calibrated', got '#{cal}'"
    failures += 1
end

r2 = sensor.reading()
if r2.abs > 1e-9
    puts "FAIL: reading() after calibrate expected 0.0, got #{r2}"
    failures += 1
end

sensor.attempt_post_shutdown()
if sensor.trace != "before"
    puts "FAIL: trace expected 'before' (guard suppressed 'after'), got '#{sensor.trace}'"
    failures += 1
end

st = sensor.status()
if st != "Shutdown"
    puts "FAIL: status() expected 'Shutdown', got '#{st}'"
    failures += 1
end

if failures > 0
    puts "FAIL: self_calibrating_sensor (#{failures} failures)"
    raise "Test failed"
end
puts "PASS: self_calibrating_sensor"

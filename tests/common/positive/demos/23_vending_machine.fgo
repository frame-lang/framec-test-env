@@[target("go")]

package main

import (
	"fmt"
	"os"
)

@@system VendingMachine(stock: int = 0) {
    operations:
        GetBalance(): int { return s.balance }
        GetStock(): int { return s.stock }

    interface:
        InsertCoin(amount: int)
        Select(): string
        Cancel(): int

    machine:
        $Idle {
            InsertCoin(amount: int) {
                s.balance = amount
                -> $HasCredit
            }
            Select(): string { @@:("insert coin first") }
            Cancel(): int { @@:(0) }
        }
        $HasCredit {
            InsertCoin(amount: int) { s.balance = s.balance + amount }
            Select(): string {
                if s.balance < s.price {
                    @@:("need more")
                } else if s.stock <= 0 {
                    @@:("sold out")
                } else {
                    s.stock = s.stock - 1
                    s.balance = s.balance - s.price
                    @@:("dispensing")
                    -> $Dispensing
                }
            }
            Cancel(): int {
                refund := s.balance
                s.balance = 0
                @@:(refund)
                -> $Idle
            }
        }
        $Dispensing {
            $>() {
                change := s.balance
                s.balance = 0
                if change > 0 {
                    fmt.Printf("Change: %d\n", change)
                }
                -> $Idle
            }
        }

    domain:
        balance : int = 0
        stock : int = 0
        price : int = 100
}

func main() {
	vm := @@VendingMachine(3)
	failures := 0

	if vm.GetStock() != 3 { fmt.Println("FAIL: stock"); failures++ }
	if vm.Select() != "insert coin first" { fmt.Println("FAIL: select"); failures++ }
	vm.InsertCoin(100)
	if vm.Select() != "dispensing" { fmt.Println("FAIL: dispensing"); failures++ }
	if vm.GetStock() != 2 { fmt.Println("FAIL: stock after"); failures++ }

	if failures > 0 { fmt.Printf("FAIL: vending_machine (%d)\n", failures); os.Exit(1) }
	fmt.Println("PASS: vending_machine")
}

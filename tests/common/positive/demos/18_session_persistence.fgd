@@[target("gdscript")]

extends SceneTree

@@[persist]
@@system Session {
    interface:
        login(user: str)
        logout()
        who(): str

    machine:
        $LoggedOut {
            login(user: str) {
                self.user = user
                -> $LoggedIn
            }
            who(): str { @@:("nobody") }
        }
        $LoggedIn {
            logout() {
                self.user = ""
                -> $LoggedOut
            }
            who(): str { @@:(self.user) }
        }

    domain:
        user = ""
}

func _init():
    var s = @@Session()
    s.login("alice")
    assert(s.who() == "alice", "Expected 'alice'")
    var data = s.save_state()
    var s2 = Session.restore_state(data)
    assert(s2.who() == "alice", "Expected 'alice' after restore")
    print("PASS: session_persistence")
    quit()

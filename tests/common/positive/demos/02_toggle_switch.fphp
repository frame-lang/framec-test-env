@@[target("php")]

<?php

@@system ToggleSwitch {
    interface:
        toggle(): str
        status(): str

    machine:
        $Off {
            toggle(): str {
                @@:("on")
                -> $On
            }
            status(): str { @@:("off") }
        }
        $On {
            toggle(): str {
                @@:("off")
                -> $Off
            }
            status(): str { @@:("on") }
        }
}

$sw = @@ToggleSwitch();
if ($sw->status() !== "off") {
    echo "FAIL: expected 'off' from status\n";
    exit(1);
}
if ($sw->toggle() !== "on") {
    echo "FAIL: expected 'on' from toggle\n";
    exit(1);
}
if ($sw->toggle() !== "off") {
    echo "FAIL: expected 'off' from toggle\n";
    exit(1);
}
echo "PASS: toggle_switch\n";

@@target kotlin

@@system Agent {
    interface:
        tick()
        threat()
        safe()
        get_log(): String

    machine:
        $Exploring {
            tick() {
                this.action_log = this.action_log + "explore,"
            }
            threat() {
                this.action_log = this.action_log + "flee,"
                -> $Fleeing
            }
            get_log(): String { @@:(this.action_log) }
        }
        $Fleeing {
            tick() {
                this.action_log = this.action_log + "run,"
            }
            safe() {
                this.action_log = this.action_log + "resume,"
                -> $Exploring
            }
            get_log(): String { @@:(this.action_log) }
        }

    domain:
        action_log: String = ""
}

fun main() {
    val a = Agent()
    a.tick()
    a.tick()
    a.threat()
    a.tick()
    a.safe()
    val result = a.get_log() as String
    val expected = "explore,explore,flee,run,resume,"
    assert(result == expected) { "Expected '$expected', got '$result'" }
    println("PASS: ai_agent")
}

@@target gdscript

extends SceneTree

@@system Editor {
    interface:
        type_char(c: str)
        undo()
        get_buffer(): str

    machine:
        $Editing {
            $.buffer: str = ""

            type_char(c: str) {
                push$
                $.buffer = $.buffer + c
            }
            undo() {
                -> pop$
            }
            get_buffer(): str { @@:($.buffer) }
        }
}

func _init():
    var e = @@Editor()
    e.type_char("H")
    e.type_char("i")
    assert(e.get_buffer() == "Hi")
    e.undo()
    assert(e.get_buffer() == "Hi")
    e.undo()
    assert(e.get_buffer() == "Hi")
    print("PASS: undo_redo")
    quit()

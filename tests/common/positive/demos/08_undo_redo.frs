@@target rust

@@system Editor {
    interface:
        type_char(c: String)
        undo()
        get_buffer(): String

    machine:
        $Editing {
            $.buffer: String = String::new()

            type_char(c: String) {
                push$
                $.buffer = format!("{}{}", $.buffer, c)
            }
            undo() {
                -> pop$
            }
            get_buffer(): String { @@:($.buffer.clone()) }
        }
}

fn main() {
    let mut e = @@Editor();
    e.type_char("H".to_string());
    e.type_char("i".to_string());
    assert_eq!(e.get_buffer(), "Hi");
    e.undo();
    assert_eq!(e.get_buffer(), "H");
    e.undo();
    assert_eq!(e.get_buffer(), "");
    println!("PASS: undo_redo");
}

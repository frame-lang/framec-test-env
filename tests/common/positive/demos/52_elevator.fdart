@@[target("dart")]

@@system Elevator {
    interface:
        request(floor: int)
        tick()
        close_doors()
        current_floor(): int
        status(): String

    machine:
        $Idle {
            request(floor: int) {
                if (floor > this.floor) {
                    this.target = floor;
                    -> $MovingUp
                } else if (floor < this.floor) {
                    this.target = floor;
                    -> $MovingDown
                } else {
                    -> $DoorsOpen
                }
            }
            current_floor(): int { @@:(this.floor) }
            status(): String { @@:("idle") }
        }

        $MovingUp {
            tick() {
                this.floor = this.floor + 1;
                if (this.floor == this.target) {
                    -> $DoorsOpen
                }
            }
            current_floor(): int { @@:(this.floor) }
            status(): String { @@:("up") }
        }

        $MovingDown {
            tick() {
                this.floor = this.floor - 1;
                if (this.floor == this.target) {
                    -> $DoorsOpen
                }
            }
            current_floor(): int { @@:(this.floor) }
            status(): String { @@:("down") }
        }

        $DoorsOpen {
            close_doors() { -> $Idle }
            current_floor(): int { @@:(this.floor) }
            status(): String { @@:("doors_open") }
        }

    domain:
        floor: int = 1
        target: int = 1
}

void main() {
    final e = @@Elevator();
    if (e.status() != "idle") throw "expected idle";
    if (e.current_floor() != 1) throw "expected floor=1";
    e.request(5);
    if (e.status() != "up") throw "expected up";
    e.tick(); e.tick(); e.tick(); e.tick();
    if (e.current_floor() != 5) throw "expected floor=5";
    if (e.status() != "doors_open") throw "expected doors_open";
    e.close_doors();
    if (e.status() != "idle") throw "expected idle";
    e.request(2);
    if (e.status() != "down") throw "expected down";
    e.tick(); e.tick(); e.tick();
    if (e.current_floor() != 2) throw "expected floor=2";
    if (e.status() != "doors_open") throw "expected doors_open";
    e.close_doors();
    e.request(2);
    if (e.status() != "doors_open") throw "expected immediate";
    print("PASS: elevator");
}

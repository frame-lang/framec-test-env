@@target go

package main

import (
	"fmt"
	"os"
)

@@system VideoPlayer {
    interface:
        play()
        pause()
        stop()
        status(): string

    machine:
        $Stopped {
            play() { -> $Playing }
            status(): string { @@:("stopped") }
        }
        $Playing => $Active {
            pause() { -> $Paused }
            status(): string { @@:("playing") }
            => $^
        }
        $Paused => $Active {
            play() { -> $Playing }
            status(): string { @@:("paused") }
            => $^
        }
        $Active {
            stop() { -> $Stopped }
        }
}

func main() {
	vp := NewVideoPlayer()
	if vp.Status() != "stopped" { fmt.Println("FAIL"); os.Exit(1) }
	vp.Play()
	if vp.Status() != "playing" { fmt.Println("FAIL"); os.Exit(1) }
	vp.Pause()
	if vp.Status() != "paused" { fmt.Println("FAIL"); os.Exit(1) }
	vp.Stop()
	if vp.Status() != "stopped" { fmt.Println("FAIL"); os.Exit(1) }
	fmt.Println("PASS: video_player")
}

@@[target("typescript")]

@@system Worker {
    interface:
        assign(msg: str)
        finish()
        busy(): bool

    machine:
        $Idle {
            assign(msg: str) {
                this.current = msg;
                -> $Working
            }
            busy(): bool { @@:(false) }
        }
        $Working {
            $>() { console.log("worker[" + this.name + "] start: " + this.current); }
            finish() {
                console.log("worker[" + this.name + "] done");
                this.current = "";
                -> $Idle
            }
            busy(): bool { @@:(true) }
        }

    domain:
        name: str = ""
        current: str = ""
}

@@[main]
@@system Dispatcher {
    interface:
        submit(msg: str): str
        worker_a_free()
        worker_b_free()

    machine:
        $Running {
            submit(msg: str): str {
                if (!this.worker_a.busy()) {
                    this.worker_a.assign(msg);
                    @@:("dispatched to a")
                } else {
                    if (!this.worker_b.busy()) {
                        this.worker_b.assign(msg);
                        @@:("dispatched to b")
                    } else {
                        this.backlog = this.backlog + 1;
                        @@:("queued")
                    }
                }
            }
            worker_a_free() {
                if (this.backlog > 0) {
                    this.backlog = this.backlog - 1;
                    this.worker_a.assign("backlog-job");
                }
            }
            worker_b_free() {
                if (this.backlog > 0) {
                    this.backlog = this.backlog - 1;
                    this.worker_b.assign("backlog-job");
                }
            }
        }

    domain:
        worker_a = @@Worker()
        worker_b = @@Worker()
        backlog: int = 0
}

const d = @@Dispatcher();
d.worker_a.name = "A";
d.worker_b.name = "B";

if (d.submit("job-1") !== "dispatched to a") throw new Error("expected dispatched to a");
if (d.submit("job-2") !== "dispatched to b") throw new Error("expected dispatched to b");
if (d.submit("job-3") !== "queued")          throw new Error("expected queued");

d.worker_a.finish();
d.worker_a_free();
if (d.worker_a.busy() !== true) throw new Error("expected worker_a busy after backlog pickup");
if (d.backlog !== 0) throw new Error("expected backlog drained");

d.worker_b.finish();
d.worker_a.finish();
console.log("PASS: competing_consumers");

@@[target("gdscript")]

extends SceneTree

@@system Turnstile {
    interface:
        coin()
        push(): str

    machine:
        $Locked {
            coin() { -> $Unlocked }
            push(): str { @@:("locked - insert coin") }
        }
        $Unlocked {
            coin() { }
            push(): str {
                @@:("welcome")
                -> $Locked
            }
        }
}

func _init():
    var t = @@Turnstile()
    assert(t.push() == "locked - insert coin", "Expected 'locked - insert coin'")
    t.coin()
    assert(t.push() == "welcome", "Expected 'welcome'")
    assert(t.push() == "locked - insert coin", "Expected 'locked - insert coin'")
    print("PASS: turnstile")
    quit()

@@[target("ruby")]

@@system TrafficLight {
    interface:
        next(): str

    machine:
        $Green {
            next(): str {
                @@:("green")
                -> $Yellow
            }
        }
        $Yellow {
            next(): str {
                @@:("yellow")
                -> $Red
            }
        }
        $Red {
            next(): str {
                @@:("red")
                -> $Green
            }
        }
}

light = TrafficLight.new
results = []
6.times { results << light.next() }
expected = ["green", "yellow", "red", "green", "yellow", "red"]
raise "Expected #{expected} got #{results}" unless results == expected
puts "PASS: traffic_light"

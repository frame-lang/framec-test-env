@@[target("c")]

#include <stdio.h>
#include <stdlib.h>
#include <string.h>
#include <cjson/cJSON.h>

@@[persist]
@@system MessageStore {
    operations:
        @@[save]
        save_state(): char* {}

        @@[load]
        restore_state(data: char*) {}

    interface:
        record(topic: str, payload: str)
        count_for(topic: str): int
        total(): int

    machine:
        $Recording {
            record(topic: str, payload: str) {
                self->total_count = self->total_count + 1;
                if (strcmp(topic, "orders") == 0) {
                    self->orders_count = self->orders_count + 1;
                } else {
                    if (strcmp(topic, "refunds") == 0) {
                        self->refunds_count = self->refunds_count + 1;
                    }
                }
            }
            count_for(topic: str): int {
                if (strcmp(topic, "orders") == 0) {
                    @@:(self->orders_count)
                } else {
                    if (strcmp(topic, "refunds") == 0) {
                        @@:(self->refunds_count)
                    } else {
                        @@:(0)
                    }
                }
            }
            total(): int { @@:(self->total_count) }
        }

    domain:
        total_count: int = 0
        orders_count: int = 0
        refunds_count: int = 0
}

int main() {
    MessageStore* s = @@MessageStore();
    MessageStore_record(s, "orders", "O-1");
    MessageStore_record(s, "orders", "O-2");
    MessageStore_record(s, "refunds", "R-1");

    char* snap = MessageStore_save_state(s);
    MessageStore* s2 = @@MessageStore();
    MessageStore_restore_state(s2, snap);
    if (MessageStore_total(s2) != 3)              { printf("FAIL: total=3\n");  return 1; }
    if (MessageStore_count_for(s2, "orders") != 2) { printf("FAIL: orders=2\n"); return 1; }
    MessageStore_record(s2, "orders", "O-3");
    if (MessageStore_total(s2) != 4)              { printf("FAIL: total=4\n");  return 1; }
    if (MessageStore_count_for(s2, "orders") != 3) { printf("FAIL: orders=3\n"); return 1; }
    printf("PASS: message_store\n");
    free(snap);
    MessageStore_destroy(s);
    MessageStore_destroy(s2);
    return 0;
}

@@[target("typescript")]

@@system FixBuySideOrder {
    interface:
        send_new(cl_ord_id: str)
        exec_new(exec_id: str)
        exec_partial_fill(qty: float, px: float)
        exec_fill(qty: float, px: float)
        exec_canceled(exec_id: str)
        get_status(): str
        get_cum_qty(): float
        get_leaves_qty(): float

    machine:
        $Pending {
            send_new(cl_ord_id: str) {
                this.cl_ord_id = cl_ord_id;
                this.leaves_qty = this.order_qty;
                -> $PendingNew
            }
            get_status(): str { @@:("Pending") }
            get_cum_qty(): float { @@:(this.cum_qty) }
            get_leaves_qty(): float { @@:(this.leaves_qty) }
        }

        $PendingNew {
            exec_new(exec_id: str) { -> $New }
            get_status(): str { @@:("PendingNew") }
            get_cum_qty(): float { @@:(this.cum_qty) }
            get_leaves_qty(): float { @@:(this.leaves_qty) }
        }

        $New {
            exec_partial_fill(qty: float, px: float) {
                this.cum_qty = this.cum_qty + qty;
                this.leaves_qty = this.order_qty - this.cum_qty;
                -> $PartiallyFilled
            }
            exec_fill(qty: float, px: float) {
                this.cum_qty = this.cum_qty + qty;
                this.leaves_qty = 0.0;
                -> $Filled
            }
            exec_canceled(exec_id: str) { -> $Canceled }
            get_status(): str { @@:("New") }
            get_cum_qty(): float { @@:(this.cum_qty) }
            get_leaves_qty(): float { @@:(this.leaves_qty) }
        }

        $PartiallyFilled {
            exec_partial_fill(qty: float, px: float) {
                this.cum_qty = this.cum_qty + qty;
                this.leaves_qty = this.order_qty - this.cum_qty;
                -> $PartiallyFilled
            }
            exec_fill(qty: float, px: float) {
                this.cum_qty = this.cum_qty + qty;
                this.leaves_qty = 0.0;
                -> $Filled
            }
            exec_canceled(exec_id: str) { -> $Canceled }
            get_status(): str { @@:("PartiallyFilled") }
            get_cum_qty(): float { @@:(this.cum_qty) }
            get_leaves_qty(): float { @@:(this.leaves_qty) }
        }

        $Filled {
            get_status(): str { @@:("Filled") }
            get_cum_qty(): float { @@:(this.cum_qty) }
            get_leaves_qty(): float { @@:(this.leaves_qty) }
        }

        $Canceled {
            get_status(): str { @@:("Canceled") }
            get_cum_qty(): float { @@:(this.cum_qty) }
            get_leaves_qty(): float { @@:(this.leaves_qty) }
        }

    domain:
        cl_ord_id: str = ""
        order_qty: float = 100.0
        cum_qty: float = 0.0
        leaves_qty: float = 0.0
}

const o = @@FixBuySideOrder();
if (o.get_status() !== "Pending") throw new Error("expected Pending");

o.send_new("CL-1");
if (o.get_status() !== "PendingNew") throw new Error("expected PendingNew");
if (o.get_leaves_qty() !== 100.0) throw new Error("expected leaves=100");

o.exec_new("E-1");
if (o.get_status() !== "New") throw new Error("expected New");

o.exec_partial_fill(40.0, 100.5);
if (o.get_status() !== "PartiallyFilled") throw new Error("expected PartiallyFilled");
if (o.get_cum_qty() !== 40.0) throw new Error("expected cum=40");
if (o.get_leaves_qty() !== 60.0) throw new Error("expected leaves=60");

o.exec_partial_fill(30.0, 100.6);
if (o.get_cum_qty() !== 70.0) throw new Error("expected cum=70");
if (o.get_leaves_qty() !== 30.0) throw new Error("expected leaves=30");

o.exec_fill(30.0, 100.7);
if (o.get_status() !== "Filled") throw new Error("expected Filled");
if (o.get_cum_qty() !== 100.0) throw new Error("expected cum=100");
if (o.get_leaves_qty() !== 0.0) throw new Error("expected leaves=0");
console.log("PASS: fix_buy_side");

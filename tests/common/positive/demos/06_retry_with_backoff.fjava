@@target java

@@system Retrier {
    interface:
        start()
        status(): String

    machine:
        $Idle {
            start() {
                this.attempts = 0;
                -> $Trying
            }
        }
        $Trying {
            $>() {
                this.attempts = this.attempts + 1;
                if (this.attempts >= this.max_retries) {
                    -> $Failed
                } else {
                    -> $Trying
                }
            }
            status(): String { @@:("trying") }
        }
        $Succeeded {
            status(): String { @@:("succeeded") }
        }
        $Failed {
            status(): String { @@:("failed after max retries") }
        }

    domain:
        attempts: int = 0
        max_retries: int = 3
}

class Main {
    public static void main(String[] args) {
        var r = new Retrier();
        r.start();
        var result = (String) r.status();
        assert result.equals("failed after max retries") : "Got: " + result;
        assert r.attempts == 3 : "Expected 3 attempts, got " + r.attempts;
        System.out.println("PASS: retry_with_backoff");
    }
}

@@[target("csharp")]


@@system CircuitBreaker {
    interface:
        Call(): string
        Success()
        Failure()
        Tick()
        Status(): string

    machine:
        $Closed {
            $.failures: int = 0
            Call(): string { @@:("allowed") }
            Success() { $.failures = 0; }
            Failure() {
                $.failures = $.failures + 1;
                if ($.failures >= this.threshold) {
                    -> $Open
                }
            }
            Status(): string { @@:("closed") }
        }
        $Open {
            $.cooldown_remaining: int = 0
            $>() {
                $.cooldown_remaining = this.cooldown;
            }
            Call(): string { @@:("blocked") }
            Tick() {
                $.cooldown_remaining = $.cooldown_remaining - 1;
                if ($.cooldown_remaining <= 0) {
                    -> $HalfOpen
                }
            }
            Status(): string { @@:("open") }
        }
        $HalfOpen {
            Call(): string { @@:("testing") }
            Success() { -> $Closed }
            Failure() { -> $Open }
            Status(): string { @@:("half-open") }
        }

    domain:
        threshold : int = 3
        cooldown : int = 5
}

class Program {
    static void Main(string[] args) {
        var cb = @@CircuitBreaker();
        int failures = 0;

        cb.Failure(); cb.Failure(); cb.Failure();
        if ((string)cb.Call() != "blocked") { Console.WriteLine("FAIL: expected blocked"); failures++; }

        for (int i = 0; i < 5; i++) { cb.Tick(); }
        if ((string)cb.Call() != "testing") { Console.WriteLine("FAIL: expected testing"); failures++; }

        cb.Success();
        if ((string)cb.Status() != "closed") { Console.WriteLine("FAIL: expected closed, got " + cb.Status()); failures++; }

        if (failures > 0) { Console.WriteLine("FAIL: circuit_breaker (" + failures + ")"); Environment.Exit(1); }
        Console.WriteLine("PASS: circuit_breaker");
    }
}

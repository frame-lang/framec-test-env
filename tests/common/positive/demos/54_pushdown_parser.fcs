@@[target("csharp")]


@@system BracketParser {
    interface:
        open()
        close()
        depth_now(): int
        status(): String

    machine:
        $Flat {
            open() {
                this.depth = this.depth + 1;
                push$
                -> $Nested
            }
            depth_now(): int { @@:(this.depth) }
            status(): String { @@:("flat") }
        }

        $Nested {
            open() {
                this.depth = this.depth + 1;
                push$
                -> $Nested
            }
            close() {
                this.depth = this.depth - 1;
                -> pop$
            }
            depth_now(): int { @@:(this.depth) }
            status(): String { @@:("nested") }
        }

    domain:
        depth: int = 0
}

class Program {
    static void Main(string[] args) {
        var p = @@BracketParser();
        if ((string) p.status() != "flat") throw new Exception("expected flat");
        if ((int) p.depth_now() != 0) throw new Exception("expected 0");
        p.open();
        if ((string) p.status() != "nested") throw new Exception("expected nested");
        if ((int) p.depth_now() != 1) throw new Exception("expected 1");
        p.open();
        if ((int) p.depth_now() != 2) throw new Exception("expected 2");
        p.close();
        if ((int) p.depth_now() != 1) throw new Exception("expected 1 after");
        p.close();
        if ((string) p.status() != "flat") throw new Exception("expected flat after");
        if ((int) p.depth_now() != 0) throw new Exception("expected 0 after");
        p.open();
        p.close();
        if ((string) p.status() != "flat") throw new Exception("expected flat re-flat");
        Console.WriteLine("PASS: pushdown_parser");
    }
}

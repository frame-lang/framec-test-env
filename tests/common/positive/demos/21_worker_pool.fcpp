@@target cpp
@@skip -- C++ parameterized systems with list domain not yet supported

#include <iostream>

@@system WorkerPool($(max_retries: int), pool_size: int) {
    interface:
        submit()
        get_status()

    machine:
        $Idle(max_retries: int) {
            submit() { }
            get_status() { }
        }
}

int main() {
    std::cout << "SKIP: worker_pool -- C++ parameterized systems with list domain not yet supported" << std::endl;
    return 0;
}

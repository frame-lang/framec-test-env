@@[target("ruby")]
@@skip -- Ruby does not have native async/await

@@system AsyncWorker {
    interface:
        start()
        get_status(): str

    machine:
        $Idle {
            start() { -> $Working }
            get_status(): str { @@:("idle") }
        }
        $Working {
            get_status(): str { @@:("working") }
        }
}

puts "SKIP: async_http_client -- Ruby does not have native async/await"

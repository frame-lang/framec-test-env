@@target c

#include <stdio.h>
#include <stdlib.h>
#include <string.h>

@@system MealyDetector {
    interface:
        input(bit: int): str

    machine:
        $S0 {
            input(bit: int): str {
                if (bit == 1) {
                    @@:("0")
                    -> $S1
                } else {
                    @@:("0")
                }
            }
        }
        $S1 {
            input(bit: int): str {
                if (bit == 0) {
                    @@:("1")
                    -> $S0
                } else {
                    @@:("0")
                }
            }
        }
}

int main() {
    MealyDetector* m = @@MealyDetector();
    int bits[] = {1, 0, 1, 1, 0};
    const char* expected[] = {"0", "1", "0", "0", "1"};
    for (int i = 0; i < 5; i++) {
        const char* result = MealyDetector_input(m, bits[i]);
        if (strcmp(result, expected[i]) != 0) {
            printf("FAIL: bit=%d expected '%s', got '%s'\n", bits[i], expected[i], result);
            return 1;
        }
    }
    printf("PASS: mealy_machine\n");
    MealyDetector_destroy(m);
    return 0;
}

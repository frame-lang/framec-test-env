@@target lua

@@system TrafficLight {
    interface:
        next(): str

    machine:
        $Green {
            next(): str {
                @@:("green")
                -> $Yellow
            }
        }
        $Yellow {
            next(): str {
                @@:("yellow")
                -> $Red
            }
        }
        $Red {
            next(): str {
                @@:("red")
                -> $Green
            }
        }
}

local light = @@TrafficLight()
local results = {}
for i = 1, 6 do
    results[i] = light:next()
end
local expected = {"green", "yellow", "red", "green", "yellow", "red"}
for i = 1, 6 do
    assert(results[i] == expected[i], "Step " .. i .. ": expected " .. expected[i] .. " got " .. tostring(results[i]))
end
print("PASS: traffic_light")

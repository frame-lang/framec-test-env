@@[target("lua")]

@@system Logger {
    interface:
        log(msg: str)

    machine:
        $Active {
            log(msg: str) {
                print("[LOG] " .. msg)
            }
        }
}

@@[main]
@@system App {
    interface:
        start()
        stop()

    machine:
        $Idle {
            start() {
                self.logger:log("App starting")
                -> $Running
            }
        }
        $Running {
            $>() { self.logger:log("App running") }
            stop() {
                self.logger:log("App stopping")
                -> $Idle
            }
        }

    domain:
        logger = Logger:new()
}

local app = App:new()
app:start()
app:stop()
print("PASS: multi_system_composition")

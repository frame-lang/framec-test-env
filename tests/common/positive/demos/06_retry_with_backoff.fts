@@target typescript

@@system Retrier {
    interface:
        start()
        status(): str

    machine:
        $Idle {
            start() {
                this.attempts = 0;
                -> $Trying
            }
        }
        $Trying {
            $>() {
                this.attempts = this.attempts + 1;
                if (this.attempts >= this.max_retries) {
                    -> $Failed
                } else {
                    -> $Trying
                }
            }
            status(): str { @@:("trying") }
        }
        $Succeeded {
            status(): str { @@:("succeeded") }
        }
        $Failed {
            status(): str { @@:("failed after max retries") }
        }

    domain:
        attempts: number = 0
        max_retries: number = 3
}

const r = @@Retrier();
r.start();
const result = r.status();
if (result !== "failed after max retries") { console.log("FAIL: Got: " + result); process.exit(1); }
// Note: r.attempts is private in generated TS; skip direct field check.
// The status() assertion above validates the behavior.
console.log("PASS: retry_with_backoff");

@@[target("java")]

import java.util.*;

@@system TrafficLight {
    interface:
        next(): String

    machine:
        $Green {
            next(): String {
                @@:("green")
                -> $Yellow
            }
        }
        $Yellow {
            next(): String {
                @@:("yellow")
                -> $Red
            }
        }
        $Red {
            next(): String {
                @@:("red")
                -> $Green
            }
        }
}

class Main {
    public static void main(String[] args) {
        var light = @@TrafficLight();
        List<String> results = new ArrayList<>();
        for (int i = 0; i < 6; i++) {
            results.add((String) light.next());
        }
        List<String> expected = List.of("green", "yellow", "red", "green", "yellow", "red");
        if (!results.equals(expected)) {
            throw new RuntimeException("Expected " + expected + " got " + results);
        }
        System.out.println("PASS: traffic_light");
    }
}

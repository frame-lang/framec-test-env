@@[target("javascript")]

@@system BracketParser {
    interface:
        open()
        close()
        depth_now()
        status()

    machine:
        $Flat {
            open() {
                this.depth = this.depth + 1;
                push$
                -> $Nested
            }
            depth_now() { @@:(this.depth) }
            status() { @@:("flat") }
        }

        $Nested {
            open() {
                this.depth = this.depth + 1;
                push$
                -> $Nested
            }
            close() {
                this.depth = this.depth - 1;
                -> pop$
            }
            depth_now() { @@:(this.depth) }
            status() { @@:("nested") }
        }

    domain:
        depth = 0
}

const p = @@BracketParser();
if (p.status() !== "flat") throw new Error("expected flat");
if (p.depth_now() !== 0) throw new Error("expected 0");
p.open();
if (p.status() !== "nested") throw new Error("expected nested");
if (p.depth_now() !== 1) throw new Error("expected 1");
p.open();
if (p.depth_now() !== 2) throw new Error("expected 2");
p.close();
if (p.depth_now() !== 1) throw new Error("expected 1 after");
p.close();
if (p.status() !== "flat") throw new Error("expected flat after");
if (p.depth_now() !== 0) throw new Error("expected 0 after");
p.open();
p.close();
if (p.status() !== "flat") throw new Error("expected flat re-flat");
console.log("PASS: pushdown_parser");

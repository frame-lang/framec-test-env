@@target lua

@@system MooreParity {
    interface:
        input(bit: int)
        output(): str

    machine:
        $Even {
            input(bit: int) {
                if bit == 1 then
                    -> $Odd
                end
            }
            output(): str { @@:("even") }
        }
        $Odd {
            input(bit: int) {
                if bit == 1 then
                    -> $Even
                end
            }
            output(): str { @@:("odd") }
        }
}

local m = @@MooreParity()
local bits = {1, 0, 1, 1, 0}
local expected = {"odd", "odd", "even", "odd", "odd"}
for i = 1, 5 do
    m:input(bits[i])
    local result = m:output()
    assert(result == expected[i], "after bit " .. bits[i] .. " expected '" .. expected[i] .. "', got '" .. tostring(result) .. "'")
end
print("PASS: moore_machine")

@@[target("rust")]

use std::collections::HashSet;

@@system IdempotentReceiver {
    interface:
        deliver(msg_id: String, payload: String): String

    machine:
        $Ready {
            deliver(msg_id: String, payload: String): String {
                if self.seen.contains(&msg_id) {
                    @@:("duplicate".to_string())
                } else {
                    self.seen.insert(msg_id);
                    self.process(payload);
                    @@:("accepted".to_string())
                }
            }
        }

    actions:
        process(payload: String) {
            println!("processing: {}", payload);
        }

    domain:
        seen: HashSet<String> = HashSet::new()
}

fn main() {
    let mut r = @@IdempotentReceiver();
    assert_eq!(r.deliver("m1".to_string(), "hello".to_string()), "accepted");
    assert_eq!(r.deliver("m1".to_string(), "hello".to_string()), "duplicate");
    assert_eq!(r.deliver("m2".to_string(), "world".to_string()), "accepted");
    assert_eq!(r.deliver("m2".to_string(), "world".to_string()), "duplicate");
    println!("PASS: idempotent_receiver");
}

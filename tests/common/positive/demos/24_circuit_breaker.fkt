@@target kotlin

import kotlin.system.exitProcess

@@system CircuitBreaker {
    interface:
        call(): String = "error"
        success()
        failure()
        tick()
        status(): String = ""

    machine:
        $Closed {
            $.failures: Int = 0
            call(): String { @@:("allowed") }
            success() { $.failures = 0 }
            failure() {
                $.failures = $.failures + 1
                if ($.failures >= this.threshold) {
                    -> $Open
                }
            }
            status(): String { @@:("closed (${$.failures} failures)") }
        }
        $Open {
            $.cooldown_remaining: Int = 0
            $>() {
                $.cooldown_remaining = this.cooldown
            }
            call(): String { @@:("blocked") }
            tick() {
                $.cooldown_remaining = $.cooldown_remaining - 1
                if ($.cooldown_remaining <= 0) {
                    -> $HalfOpen
                }
            }
            status(): String { @@:("open (${$.cooldown_remaining} ticks left)") }
        }
        $HalfOpen {
            call(): String { @@:("testing") }
            success() { -> $Closed }
            failure() { -> $Open }
            status(): String { @@:("half-open") }
        }

    domain:
        threshold = 3
        cooldown = 5
}

fun main() {
    val cb = @@CircuitBreaker()
    var failures = 0

    cb.failure(); cb.failure(); cb.failure()
    if (cb.call() as String != "blocked") { println("FAIL: expected blocked"); failures++ }

    for (i in 1..5) { cb.tick() }
    if (cb.call() as String != "testing") { println("FAIL: expected testing"); failures++ }

    cb.success()
    if (cb.status() as String != "closed (0 failures)") { println("FAIL: expected reset, got ${cb.status()}"); failures++ }

    if (failures > 0) { println("FAIL: circuit_breaker ($failures)"); exitProcess(1) }
    println("PASS: circuit_breaker")
}

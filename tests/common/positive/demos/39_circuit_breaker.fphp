@@[target("php")]

<?php

@@system CircuitBreaker {
    interface:
        call(payload: str): str
        record_failure()
        record_success()
        probe()
        state_name(): str

    machine:
        $Closed {
            $>() {
                $this->failures = 0;
            }
            call(payload: str): str {
                @@:($this->invoke($payload))
            }
            record_failure() {
                $this->failures = $this->failures + 1;
                if ($this->failures >= $this->threshold) {
                    -> "trip" $Open
                }
            }
            record_success() {
                $this->failures = 0;
            }
            state_name(): str { @@:("closed") }
        }

        $Open {
            call(payload: str): str {
                @@:("rejected: circuit open")
            }
            probe() {
                -> $HalfOpen
            }
            state_name(): str { @@:("open") }
        }

        $HalfOpen {
            call(payload: str): str {
                @@:($this->invoke($payload))
            }
            record_success() {
                -> "recover" $Closed
            }
            record_failure() {
                -> "re-trip" $Open
            }
            state_name(): str { @@:("half_open") }
        }

    actions:
        invoke(payload) {
            return "ok:" . $payload;
        }

    domain:
        failures = 0
        threshold = 3
}

$cb = @@CircuitBreaker();
for ($i = 0; $i < 3; $i++) {
    $cb->call("x");
    $cb->record_failure();
}
assert($cb->state_name() === "open", "Expected open, got " . $cb->state_name());
assert($cb->call("x") === "rejected: circuit open");
$cb->probe();
assert($cb->state_name() === "half_open", "Expected half_open, got " . $cb->state_name());
$cb->call("x");
$cb->record_success();
assert($cb->state_name() === "closed", "Expected closed, got " . $cb->state_name());
echo "PASS: circuit_breaker\n";

@@target swift

@@system TrafficLight {
    interface:
        next(): String

    machine:
        $Green {
            next(): String {
                @@:("green")
                -> $Yellow
            }
        }
        $Yellow {
            next(): String {
                @@:("yellow")
                -> $Red
            }
        }
        $Red {
            next(): String {
                @@:("red")
                -> $Green
            }
        }
}

var light = @@TrafficLight()
var results: [String] = []
for _ in 0..<6 {
    results.append(light.next() as! String)
}
let expected = ["green", "yellow", "red", "green", "yellow", "red"]
if results != expected {
    fatalError("Expected \(expected) got \(results)")
}
print("PASS: traffic_light")

@@[target("ruby")]

require 'json'

@@[persist]
@@system Session {
    operations:
        @@[save]
        save_state(): String {}

        @@[load]
        restore_state(data: String) {}

    interface:
        login(user: str)
        logout()
        who(): str

    machine:
        $LoggedOut {
            login(user: str) {
                self.user = user
                -> $LoggedIn
            }
            who(): str { @@:("nobody") }
        }
        $LoggedIn {
            logout() {
                self.user = ""
                -> $LoggedOut
            }
            who(): str { @@:(self.user) }
        }

    domain:
        user = ""
}

s = Session.new
s.login("alice")
raise "Expected 'alice'" unless s.who == "alice"
data = s.save_state
s2 = Session.new
s2.restore_state(data)
raise "Expected 'alice' after restore" unless s2.who == "alice"
puts "PASS: session_persistence"

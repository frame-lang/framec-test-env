@@target dart

@@system MealyDetector {
    interface:
        input(bit: int): String

    machine:
        $S0 {
            input(bit: int): String {
                if (bit == 1) {
                    @@:("0")
                    -> $S1
                } else {
                    @@:("0")
                }
            }
        }
        $S1 {
            input(bit: int): String {
                if (bit == 0) {
                    @@:("1")
                    -> $S0
                } else {
                    @@:("0")
                }
            }
        }
}

void main() {
    final m = @@MealyDetector();
    final bits = [1, 0, 1, 1, 0];
    final expected = ["0", "1", "0", "0", "1"];
    for (int i = 0; i < 5; i++) {
        String result = m.input(bits[i]) as String;
        if (result != expected[i]) {
            throw Exception("FAIL: bit=${bits[i]} expected '${expected[i]}', got '$result'");
        }
    }
    print("PASS: mealy_machine");
}

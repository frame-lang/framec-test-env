@@[target("swift")]

@@system Logger {
    interface:
        log(msg: String)

    machine:
        $Active {
            log(msg: String) {
                print("[LOG] \(msg)")
            }
        }
}

@@[main]
@@system App {
    interface:
        start()
        stop()

    machine:
        $Idle {
            start() {
                self.logger.log("App starting")
                -> $Running
            }
        }
        $Running {
            $>() { self.logger.log("App running") }
            stop() {
                self.logger.log("App stopping")
                -> $Idle
            }
        }

    domain:
        logger: Logger = Logger()
}

var app = @@App()
app.start()
app.stop()
print("PASS: multi_system_composition")

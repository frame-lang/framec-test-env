@@[target("csharp")]

using System;

@@system FixSellSide {
    interface:
        new_order(cl_ord_id: String, qty: double, price: double)
        market_fill(qty: double, px: double)
        cancel_request(cancel_cl_ord_id: String)
        status(): String
        get_cum_qty(): double
        get_leaves_qty(): double

    machine:
        $NoOrder {
            new_order(cl_ord_id: String, qty: double, price: double) {
                this.cl_ord_id = cl_ord_id;
                this.order_qty = qty;
                this.leaves_qty = qty;
                this.price = price;
                -> $Working
            }
            status(): String { @@:("NoOrder") }
            get_cum_qty(): double { @@:(this.cum_qty) }
            get_leaves_qty(): double { @@:(this.leaves_qty) }
        }

        $Working {
            market_fill(qty: double, px: double) {
                this.cum_qty = this.cum_qty + qty;
                this.leaves_qty = this.order_qty - this.cum_qty;
                if (this.leaves_qty <= 0.0) {
                    -> $Filled
                }
            }
            cancel_request(cancel_cl_ord_id: String) { -> $Canceled }
            status(): String { @@:("Working") }
            get_cum_qty(): double { @@:(this.cum_qty) }
            get_leaves_qty(): double { @@:(this.leaves_qty) }
        }

        $Filled {
            status(): String { @@:("Filled") }
            get_cum_qty(): double { @@:(this.cum_qty) }
            get_leaves_qty(): double { @@:(this.leaves_qty) }
        }

        $Canceled {
            status(): String { @@:("Canceled") }
            get_cum_qty(): double { @@:(this.cum_qty) }
            get_leaves_qty(): double { @@:(this.leaves_qty) }
        }

    domain:
        cl_ord_id: String = ""
        order_qty: double = 0.0
        cum_qty: double = 0.0
        leaves_qty: double = 0.0
        price: double = 0.0
}

class Program {
    static void Main(string[] args) {
        var o = @@FixSellSide();
        if ((string) o.status() != "NoOrder") throw new Exception("expected NoOrder");
        o.new_order("CL-1", 200.0, 50.0);
        if ((string) o.status() != "Working") throw new Exception("expected Working");
        if ((double) o.get_leaves_qty() != 200.0) throw new Exception("expected leaves=200");
        o.market_fill(80.0, 50.05);
        if ((double) o.get_cum_qty() != 80.0) throw new Exception("expected cum=80");
        o.market_fill(120.0, 50.10);
        if ((string) o.status() != "Filled") throw new Exception("expected Filled");

        var o2 = @@FixSellSide();
        o2.new_order("CL-2", 100.0, 49.0);
        o2.market_fill(30.0, 49.10);
        o2.cancel_request("CXL-2");
        if ((string) o2.status() != "Canceled") throw new Exception("expected Canceled");
        Console.WriteLine("PASS: fix_sell_side");
    }
}

@@target javascript

@@system Thermostat {
    interface:
        set_temp(target)
        tick()
        status(): str = "unknown"

    machine:
        $Off {
            set_temp(target) {
                this.target = target
                -> $LowHeat
            }
            status(): str { @@:("off") }
        }
        $LowHeat => $On {
            $>() { this.heat_rate = 1 }
            status(): str { @@:(`low heat (${this.current} -> ${this.target})`) }
            => $^
        }
        $HighHeat => $On {
            $>() { this.heat_rate = 2 }
            status(): str { @@:(`high heat (${this.current} -> ${this.target})`) }
            => $^
        }
        $On {
            tick() {
                this.current = this.current + this.heat_rate
                if (this.current >= this.target) {
                    this.current = this.target
                    -> $Cooling
                } else if (this.target - this.current > 5) {
                    if (this.heat_rate < 2) {
                        -> $HighHeat
                    }
                } else if (this.target - this.current <= 3) {
                    if (this.heat_rate > 1) {
                        -> $LowHeat
                    }
                }
            }
            set_temp(target) { this.target = target }
        }
        $Cooling {
            $>() { this.heat_rate = 0 }
            tick() {
                this.current = this.current - 1
                if (this.current <= this.target) {
                    -> $Off
                }
            }
            status(): str { @@:(`cooling (${this.current} -> ${this.target})`) }
        }

    domain:
        current = 65
        target = 65
        heat_rate = 0
}

const t = @@Thermostat()
let failures = 0

if (t.status() !== "off") { console.log("FAIL: initial status"); failures++ }

t.set_temp(75)
let cooled = false
for (let i = 0; i < 20; i++) {
    t.tick()
    const s = t.status()
    if (s.includes("cooling") || s === "off") { cooled = true }
}
if (!cooled) { console.log("FAIL: never cooled"); failures++ }

if (failures > 0) { console.log("FAIL: thermostat (" + failures + ")"); process.exit(1) }
console.log("PASS: thermostat")

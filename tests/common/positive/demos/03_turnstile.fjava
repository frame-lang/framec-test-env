@@[target("java")]

@@system Turnstile {
    interface:
        coin()
        push(): String

    machine:
        $Locked {
            coin() { -> $Unlocked }
            push(): String { @@:("locked - insert coin") }
        }
        $Unlocked {
            coin() { }
            push(): String {
                @@:("welcome")
                -> $Locked
            }
        }
}

class Main {
    public static void main(String[] args) {
        var t = @@Turnstile();
        if (!"locked - insert coin".equals((String) t.push())) {
            throw new RuntimeException("Expected 'locked - insert coin'");
        }
        t.coin();
        if (!"welcome".equals((String) t.push())) {
            throw new RuntimeException("Expected 'welcome'");
        }
        if (!"locked - insert coin".equals((String) t.push())) {
            throw new RuntimeException("Expected 'locked - insert coin'");
        }
        System.out.println("PASS: turnstile");
    }
}

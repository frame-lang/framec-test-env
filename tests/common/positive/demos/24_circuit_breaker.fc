@@[target("c")]

#include <stdio.h>
#include <stdlib.h>
#include <string.h>

@@system CircuitBreaker {
    interface:
        call(): char*
        success()
        failure()
        tick()
        status(): char*

    machine:
        $Closed {
            $.failures: int = 0
            call(): char* { @@:("allowed") }
            success() { $.failures = 0; }
            failure() {
                $.failures = $.failures + 1;
                if ($.failures >= self->threshold) {
                    -> $Open
                }
            }
            status(): char* { @@:("closed") }
        }
        $Open {
            $.cooldown_remaining: int = 0
            $>() {
                $.cooldown_remaining = self->cooldown;
            }
            call(): char* { @@:("blocked") }
            tick() {
                $.cooldown_remaining = $.cooldown_remaining - 1;
                if ($.cooldown_remaining <= 0) {
                    -> $HalfOpen
                }
            }
            status(): char* { @@:("open") }
        }
        $HalfOpen {
            call(): char* { @@:("testing") }
            success() { -> $Closed }
            failure() { -> $Open }
            status(): char* { @@:("half-open") }
        }

    domain:
        threshold : int = 3
        cooldown : int = 5
}

int main() {
    CircuitBreaker* cb = @@CircuitBreaker();
    int failures = 0;

    CircuitBreaker_failure(cb);
    CircuitBreaker_failure(cb);
    CircuitBreaker_failure(cb);
    if (strcmp(CircuitBreaker_call(cb), "blocked") != 0) {
        printf("FAIL: expected blocked\n");
        failures++;
    }

    for (int i = 0; i < 5; i++) { CircuitBreaker_tick(cb); }
    if (strcmp(CircuitBreaker_call(cb), "testing") != 0) {
        printf("FAIL: expected testing\n");
        failures++;
    }

    CircuitBreaker_success(cb);
    if (strcmp(CircuitBreaker_status(cb), "closed") != 0) {
        printf("FAIL: expected closed after success\n");
        failures++;
    }

    if (failures > 0) {
        printf("FAIL: circuit_breaker (%d failures)\n", failures);
        return 1;
    }
    printf("PASS: circuit_breaker\n");
    return 0;
}

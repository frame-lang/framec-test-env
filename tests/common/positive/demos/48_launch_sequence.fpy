@@[target("python_3")]

# Smoke-test variant of cookbook recipe 48 (Launch Sequence
# Controller). Single-system simplification: phases progress
# sequentially (Idle -> Countdown -> Boost -> Sustain -> Orbit)
# with an abort path that produces different outcomes depending
# on the phase reached. The cookbook's 3-system topology
# (FlightComputer + PropulsionController + RangeOfficer) is
# documented there; matrix test validates the abort-from-any-phase
# pattern.

@@system LaunchController {
    interface:
        countdown_start()
        ignite()
        max_q_passed()
        meco()
        seco()
        abort()
        phase(): str
        outcome(): str

    machine:
        $Idle {
            countdown_start() { -> $Countdown }
            phase(): str { @@:("Idle") }
            outcome(): str { @@:("none") }
        }

        $Countdown {
            ignite() { -> $Boost }
            abort() {
                self.outcome_str = "scrubbed"
                -> $Aborted
            }
            phase(): str { @@:("Countdown") }
            outcome(): str { @@:("none") }
        }

        $Boost {
            max_q_passed() { -> $Sustain }
            abort() {
                self.outcome_str = "RTLS"
                -> $Aborted
            }
            phase(): str { @@:("Boost") }
            outcome(): str { @@:("none") }
        }

        $Sustain {
            meco() { -> $Coast }
            abort() {
                self.outcome_str = "ATO"
                -> $Aborted
            }
            phase(): str { @@:("Sustain") }
            outcome(): str { @@:("none") }
        }

        $Coast {
            seco() { -> $Orbit }
            abort() {
                self.outcome_str = "TAL"
                -> $Aborted
            }
            phase(): str { @@:("Coast") }
            outcome(): str { @@:("none") }
        }

        $Orbit {
            phase(): str { @@:("Orbit") }
            outcome(): str { @@:("nominal") }
        }

        $Aborted {
            phase(): str { @@:("Aborted") }
            outcome(): str { @@:(self.outcome_str) }
        }

    domain:
        outcome_str: str = ""
}

if __name__ == '__main__':
    # Nominal flight to orbit
    lc = @@LaunchController()
    lc.countdown_start()
    lc.ignite()
    lc.max_q_passed()
    lc.meco()
    lc.seco()
    assert lc.phase() == "Orbit"
    assert lc.outcome() == "nominal"

    # Abort during boost -> RTLS
    lc2 = @@LaunchController()
    lc2.countdown_start()
    lc2.ignite()
    lc2.abort()
    assert lc2.phase() == "Aborted"
    assert lc2.outcome() == "RTLS"

    # Abort during sustain -> ATO
    lc3 = @@LaunchController()
    lc3.countdown_start()
    lc3.ignite()
    lc3.max_q_passed()
    lc3.abort()
    assert lc3.outcome() == "ATO"

    # Abort during countdown -> scrubbed
    lc4 = @@LaunchController()
    lc4.countdown_start()
    lc4.abort()
    assert lc4.outcome() == "scrubbed"

    print("PASS: launch_sequence")

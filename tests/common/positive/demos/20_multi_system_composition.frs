@@target rust

@@system Logger {
    interface:
        log(msg: String)

    machine:
        $Active {
            log(msg: String) {
                println!("[LOG] {}", msg)
            }
        }
}

@@system App {
    interface:
        start()
        stop()

    machine:
        $Idle {
            start() {
                self.logger.log("App starting".to_string());
                -> $Running
            }
        }
        $Running {
            $>() { self.logger.log("App running".to_string()); }
            stop() {
                self.logger.log("App stopping".to_string());
                -> $Idle
            }
        }

    domain:
        logger: Logger = Logger::new()
}

fn main() {
    let mut app = @@App();
    app.start();
    app.stop();
    println!("PASS: multi_system_composition");
}

@@[target("go")]

package main

import (
	"encoding/json"
	"fmt"
	"os"
)

@@[persist(string)]
@@[save(SaveState)]
@@[load(LoadState)]
@@system MessageStore {
    interface:
        record(topic: string, payload: string)
        count_for(topic: string): int
        total(): int

    machine:
        $Recording {
            record(topic: string, payload: string) {
                s.total_count = s.total_count + 1
                if topic == "orders" {
                    s.orders_count = s.orders_count + 1
                } else {
                    if topic == "refunds" {
                        s.refunds_count = s.refunds_count + 1
                    }
                }
            }
            count_for(topic: string): int {
                if topic == "orders" {
                    @@:(s.orders_count)
                } else {
                    if topic == "refunds" {
                        @@:(s.refunds_count)
                    } else {
                        @@:(0)
                    }
                }
            }
            total(): int { @@:(s.total_count) }
        }

    domain:
        total_count: int = 0
        orders_count: int = 0
        refunds_count: int = 0
}

func main() {
    s := @@MessageStore()
    s.Record("orders", "O-1")
    s.Record("orders", "O-2")
    s.Record("refunds", "R-1")

    snap := s.SaveState()
    s2 := @@MessageStore()
    s2.LoadState(snap)
    if s2.Total() != 3                { fmt.Println("FAIL: total=3"); os.Exit(1) }
    if s2.Count_for("orders") != 2    { fmt.Println("FAIL: orders=2"); os.Exit(1) }
    s2.Record("orders", "O-3")
    if s2.Total() != 4                { fmt.Println("FAIL: total=4"); os.Exit(1) }
    if s2.Count_for("orders") != 3    { fmt.Println("FAIL: orders=3"); os.Exit(1) }
    _ = json.Marshal
    fmt.Println("PASS: message_store")
}

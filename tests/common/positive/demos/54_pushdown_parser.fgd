@@[target("gdscript")]

extends SceneTree

@@system BracketParser {
    interface:
        open()
        close()
        depth_now(): int
        status(): String

    machine:
        $Flat {
            open() {
                self.depth = self.depth + 1
                push$
                -> $Nested
            }
            depth_now(): int { @@:(self.depth) }
            status(): String { @@:("flat") }
        }

        $Nested {
            open() {
                self.depth = self.depth + 1
                push$
                -> $Nested
            }
            close() {
                self.depth = self.depth - 1
                -> pop$
            }
            depth_now(): int { @@:(self.depth) }
            status(): String { @@:("nested") }
        }

    domain:
        depth = 0
}

func main():
    var p = @@BracketParser()
    var failures = 0
    if p.status() != "flat": print("FAIL: flat"); failures += 1
    if p.depth_now() != 0: print("FAIL: 0"); failures += 1
    p.open()
    if p.status() != "nested": print("FAIL: nested"); failures += 1
    if p.depth_now() != 1: print("FAIL: 1"); failures += 1
    p.open()
    if p.depth_now() != 2: print("FAIL: 2"); failures += 1
    p.close()
    if p.depth_now() != 1: print("FAIL: 1 after"); failures += 1
    p.close()
    if p.status() != "flat": print("FAIL: flat after"); failures += 1
    if p.depth_now() != 0: print("FAIL: 0 after"); failures += 1
    p.open()
    p.close()
    if p.status() != "flat": print("FAIL: flat re-flat"); failures += 1

    if failures > 0:
        print("FAIL: pushdown_parser (" + str(failures) + " failures)")
        quit(1)
    print("PASS: pushdown_parser")

func _init():
    main()
    quit()

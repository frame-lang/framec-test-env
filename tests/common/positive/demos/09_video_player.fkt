@@[target("kotlin")]

@@system VideoPlayer {
    interface:
        play()
        pause()
        stop()
        status(): String

    machine:
        $Stopped {
            play() { -> $Playing }
            status(): String { @@:("stopped") }
        }
        $Playing => $Active {
            pause() { -> $Paused }
            status(): String { @@:("playing") }
            => $^
        }
        $Paused => $Active {
            play() { -> $Playing }
            status(): String { @@:("paused") }
            => $^
        }
        $Active {
            stop() { -> $Stopped }
        }
}

fun main() {
    val vp = @@VideoPlayer()
    assert(vp.status() as String == "stopped")
    vp.play()
    assert(vp.status() as String == "playing")
    vp.pause()
    assert(vp.status() as String == "paused")
    vp.stop()
    assert(vp.status() as String == "stopped")
    println("PASS: video_player")
}

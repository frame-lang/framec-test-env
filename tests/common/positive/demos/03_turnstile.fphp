@@target php

<?php

@@system Turnstile {
    interface:
        coin()
        push(): str

    machine:
        $Locked {
            coin() { -> $Unlocked }
            push(): str { @@:("locked - insert coin") }
        }
        $Unlocked {
            coin() { }
            push(): str {
                @@:("welcome")
                -> $Locked
            }
        }
}

$t = @@Turnstile();
if ($t->push() !== "locked - insert coin") {
    echo "FAIL: expected 'locked - insert coin'\n";
    exit(1);
}
$t->coin();
if ($t->push() !== "welcome") {
    echo "FAIL: expected 'welcome'\n";
    exit(1);
}
if ($t->push() !== "locked - insert coin") {
    echo "FAIL: expected 'locked - insert coin'\n";
    exit(1);
}
echo "PASS: turnstile\n";

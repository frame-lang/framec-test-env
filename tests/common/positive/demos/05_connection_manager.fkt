@@[target("kotlin")]

@@system Connection {
    interface:
        connect(host: String)
        send(data: String): String
        disconnect()

    machine:
        $Disconnected {
            connect(host: String) {
                this.host = host
                -> $Connecting
            }
        }
        $Connecting {
            $>() {
                println("Connecting to ${this.host}...")
                -> $Connected
            }
        }
        $Connected {
            $>() { println("Connected to ${this.host}") }
            <$() { println("Disconnecting from ${this.host}") }

            send(data: String): String {
                @@:("sent '${data}' to ${this.host}")
            }
            disconnect() { -> $Disconnected }
        }

    domain:
        host: String = ""
}

fun main() {
    val c = Connection()
    c.connect("example.com")
    val result = c.send("hello") as String
    assert(result == "sent 'hello' to example.com") { "Got: $result" }
    c.disconnect()
    println("PASS: connection_manager")
}

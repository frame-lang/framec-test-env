@@[target("kotlin")]

@@system TrafficLight {
    interface:
        next(): String

    machine:
        $Green {
            next(): String {
                @@:("green")
                -> $Yellow
            }
        }
        $Yellow {
            next(): String {
                @@:("yellow")
                -> $Red
            }
        }
        $Red {
            next(): String {
                @@:("red")
                -> $Green
            }
        }
}

fun main() {
    val light = TrafficLight()
    val results = mutableListOf<String>()
    for (i in 0 until 6) {
        results.add(light.next() as String)
    }
    val expected = listOf("green", "yellow", "red", "green", "yellow", "red")
    if (results != expected) {
        throw RuntimeException("Expected $expected got $results")
    }
    println("PASS: traffic_light")
}

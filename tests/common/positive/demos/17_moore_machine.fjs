@@target javascript

@@system MooreParity {
    interface:
        input(bit: int)
        output(): str

    machine:
        $Even {
            input(bit: int) {
                if (bit == 1) {
                    -> $Odd
                }
            }
            output(): str { @@:("even") }
        }
        $Odd {
            input(bit: int) {
                if (bit == 1) {
                    -> $Even
                }
            }
            output(): str { @@:("odd") }
        }
}

const m = @@MooreParity();
const bits = [1, 0, 1, 1, 0];
const expected = ["odd", "odd", "even", "odd", "odd"];
for (let i = 0; i < 5; i++) {
    m.input(bits[i]);
    const result = m.output();
    if (result !== expected[i]) {
        console.log("FAIL: after bit " + bits[i] + " expected '" + expected[i] + "', got '" + result + "'");
        process.exit(1);
    }
}
console.log("PASS: moore_machine");

@@target rust

@@system DialogManager {
    interface:
        open(name: String)
        close(): String
        current(): String

    machine:
        $Main {
            open(name: String) {
                push$
                -> (name) $Dialog
            }
            current(): String { @@:("main".to_string()) }
        }
        $Dialog {
            $.name: String = String::new()

            $>(name: String) { $.name = name }

            open(name: String) {
                push$
                -> (name) $Dialog
            }
            close(): String {
                @@:($.name)
                -> pop$
            }
            current(): String { @@:($.name) }
        }
}

fn main() {
    let mut dm = @@DialogManager();
    assert_eq!(dm.current(), "main");
    dm.open("Settings".to_string());
    assert_eq!(dm.current(), "Settings");
    dm.open("Confirm".to_string());
    assert_eq!(dm.current(), "Confirm");
    let closed = dm.close();
    assert_eq!(closed, "Confirm");
    assert_eq!(dm.current(), "Settings");
    let closed = dm.close();
    assert_eq!(closed, "Settings");
    assert_eq!(dm.current(), "main");
    println!("PASS: modal_dialog_stack");
}

@@[target("cpp_17")]

#include <iostream>
#include <memory>
#include <string>

@@system Worker {
    interface:
        assign(msg: str)
        finish()
        busy(): bool

    machine:
        $Idle {
            assign(msg: str) {
                this->current = msg;
                -> $Working
            }
            busy(): bool { @@:(false) }
        }
        $Working {
            $>() { std::cout << "worker[" << this->name << "] start: " << this->current << std::endl; }
            finish() {
                std::cout << "worker[" << this->name << "] done" << std::endl;
                this->current = "";
                -> $Idle
            }
            busy(): bool { @@:(true) }
        }

    domain:
        name: std::string = ""
        current: std::string = ""
}

@@[main]
@@system Dispatcher {
    interface:
        submit(msg: str): str
        worker_a_free()
        worker_b_free()

    machine:
        $Running {
            submit(msg: str): str {
                if (!std::any_cast<bool>(this->worker_a->busy())) {
                    this->worker_a->assign(msg);
                    @@:(std::string("dispatched to a"))
                } else {
                    if (!std::any_cast<bool>(this->worker_b->busy())) {
                        this->worker_b->assign(msg);
                        @@:(std::string("dispatched to b"))
                    } else {
                        this->backlog = this->backlog + 1;
                        @@:(std::string("queued"))
                    }
                }
            }
            worker_a_free() {
                if (this->backlog > 0) {
                    this->backlog = this->backlog - 1;
                    this->worker_a->assign("backlog-job");
                }
            }
            worker_b_free() {
                if (this->backlog > 0) {
                    this->backlog = this->backlog - 1;
                    this->worker_b->assign("backlog-job");
                }
            }
        }

    domain:
        worker_a: std::shared_ptr<Worker> = std::make_shared<Worker>()
        worker_b: std::shared_ptr<Worker> = std::make_shared<Worker>()
        backlog: int = 0
}

int main() {
    auto d = @@Dispatcher();
    d.worker_a->name = "A";
    d.worker_b->name = "B";

    if (std::any_cast<std::string>(d.submit("job-1")) != "dispatched to a") { printf("FAIL: dispatched a\n"); return 1; }
    if (std::any_cast<std::string>(d.submit("job-2")) != "dispatched to b") { printf("FAIL: dispatched b\n"); return 1; }
    if (std::any_cast<std::string>(d.submit("job-3")) != "queued")          { printf("FAIL: queued\n");      return 1; }

    d.worker_a->finish();
    d.worker_a_free();
    if (!std::any_cast<bool>(d.worker_a->busy())) { printf("FAIL: expected worker_a busy\n"); return 1; }
    if (d.backlog != 0)                            { printf("FAIL: expected backlog drained\n"); return 1; }

    d.worker_b->finish();
    d.worker_a->finish();
    std::cout << "PASS: competing_consumers" << std::endl;
    return 0;
}

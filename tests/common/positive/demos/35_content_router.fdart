@@[target("dart")]

@@system ContentBasedRouter {
    interface:
        route(kind: String, payload: String): String

    machine:
        $Routing {
            route(kind: String, payload: String): String {
                if (kind == "order") {
                    this.to_orders(payload);
                    @@:("orders")
                } else {
                    if (kind == "refund") {
                        this.to_refunds(payload);
                        @@:("refunds")
                    } else {
                        this.to_dlq(payload);
                        @@:("dlq")
                    }
                }
            }
        }

    actions:
        to_orders(p: String): void  { print("-> orders:  " + p); }
        to_refunds(p: String): void { print("-> refunds: " + p); }
        to_dlq(p: String): void     { print("-> dlq:     " + p); }
}

void main() {
    var r = @@ContentBasedRouter();
    if ((r.route("order",   "SKU-1") as String) != "orders")  throw "Expected orders";
    if ((r.route("refund",  "INV-7") as String) != "refunds") throw "Expected refunds";
    if ((r.route("unknown", "???") as String)    != "dlq")     throw "Expected dlq";
    print("PASS: content_router");
}

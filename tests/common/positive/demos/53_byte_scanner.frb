@@[target("ruby")]

@@system Scanner {
    interface:
        feed_letter()
        feed_punct()
        eof()
        token_count(): int
        status(): str

    machine:
        $Start {
            feed_letter() { -> $InIdent }
            feed_punct() {
                @count = @count + 1
            }
            eof() {
                @count = @count + 1
            }
            token_count(): int { @@:(@count) }
            status(): str { @@:("start") }
        }

        $InIdent {
            feed_letter() {}
            feed_punct() {
                @count = @count + 2
                -> $Start
            }
            eof() {
                @count = @count + 2
            }
            token_count(): int { @@:(@count) }
            status(): str { @@:("in_ident") }
        }

    domain:
        count = 0
}

s = Scanner.new
raise "expected start" unless s.status == "start"
raise "expected count=0" unless s.token_count == 0
s.feed_letter
raise "expected in_ident" unless s.status == "in_ident"
s.feed_letter
s.feed_punct
raise "expected start after" unless s.status == "start"
raise "expected count=2" unless s.token_count == 2
s.feed_punct
raise "expected count=3" unless s.token_count == 3
s.eof
raise "expected count=4" unless s.token_count == 4

s2 = Scanner.new
s2.feed_letter
s2.feed_letter
s2.eof
raise "expected count=2 eof" unless s2.token_count == 2
puts "PASS: byte_scanner"

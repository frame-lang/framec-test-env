@@target kotlin

@@system LoginManager {
    interface:
        login(user: String, pass: String): String
        logout()
        status(): String

    machine:
        $LoggedOut {
            login(user: String, pass: String): String {
                if (pass == "secret") {
                    this.current_user = user
                    -> $LoggedIn
                    @@:("ok")
                } else {
                    @@:("denied")
                }
            }
            status(): String { @@:("logged_out") }
        }
        $LoggedIn {
            logout() {
                this.current_user = ""
                -> $LoggedOut
            }
            status(): String { @@:("logged_in") }
        }

    domain:
        current_user: String = ""
}

@@system App {
    interface:
        authenticate(user: String, pass: String): String
        get_status(): String

    machine:
        $Running {
            authenticate(user: String, pass: String): String {
                val result = this.auth.login(user, pass) as String
                @@:(result)
            }
            get_status(): String {
                @@:(this.auth.status() as String)
            }
        }

    domain:
        auth: LoginManager = LoginManager()
}

fun main() {
    val app = App()
    var failures = 0

    if (app.get_status() as String != "logged_out") {
        println("FAIL: expected logged_out")
        failures++
    }

    val r1 = app.authenticate("alice", "wrong") as String
    if (r1 != "denied") {
        println("FAIL: expected denied, got $r1")
        failures++
    }

    val r2 = app.authenticate("alice", "secret") as String
    if (r2 != "ok") {
        println("FAIL: expected ok, got $r2")
        failures++
    }

    if (app.get_status() as String != "logged_in") {
        println("FAIL: expected logged_in")
        failures++
    }

    if (failures > 0) {
        println("FAIL: auth_flow ($failures failures)")
        kotlin.system.exitProcess(1)
    }
    println("PASS: auth_flow")
}

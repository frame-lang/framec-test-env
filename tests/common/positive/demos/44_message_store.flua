@@[target("lua")]

@@[persist(string)]
@@[save(save_state)]
@@[load(restore_state)]
@@system MessageStore {
    interface:
        record(topic: str, payload: str)
        count_for(topic: str): int
        total(): int

    machine:
        $Recording {
            record(topic: str, payload: str) {
                self.total_count = self.total_count + 1
                if topic == "orders" then
                    self.orders_count = self.orders_count + 1
                else
                    if topic == "refunds" then
                        self.refunds_count = self.refunds_count + 1
                    end
                end
            }
            count_for(topic: str): int {
                if topic == "orders" then
                    @@:(self.orders_count)
                else
                    if topic == "refunds" then
                        @@:(self.refunds_count)
                    else
                        @@:(0)
                    end
                end
            }
            total(): int { @@:(self.total_count) }
        }

    domain:
        total_count: int = 0
        orders_count: int = 0
        refunds_count: int = 0
}

local s = @@MessageStore()
s:record("orders", "O-1")
s:record("orders", "O-2")
s:record("refunds", "R-1")

local snap = s:save_state()
local s2 = @@MessageStore()
s2:restore_state(snap)
assert(s2:total() == 3,             "expected total=3")
assert(s2:count_for("orders") == 2, "expected orders=2")
s2:record("orders", "O-3")
assert(s2:total() == 4,             "expected total=4")
assert(s2:count_for("orders") == 3, "expected orders=3")
print("PASS: message_store")

@@target ruby

@@system MealyDetector {
    interface:
        input(bit: int): str

    machine:
        $S0 {
            input(bit: int): str {
                if bit == 1
                    @@:("0")
                    -> $S1
                else
                    @@:("0")
                end
            }
        }
        $S1 {
            input(bit: int): str {
                if bit == 0
                    @@:("1")
                    -> $S0
                else
                    @@:("0")
                end
            }
        }
}

m = MealyDetector.new
bits = [1, 0, 1, 1, 0]
expected = ["0", "1", "0", "0", "1"]
bits.each_with_index do |bit, i|
    result = m.input(bit)
    raise "FAIL: bit=#{bit} expected '#{expected[i]}', got '#{result}'" unless result == expected[i]
end
puts "PASS: mealy_machine"

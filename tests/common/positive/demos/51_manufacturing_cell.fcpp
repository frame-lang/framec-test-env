@@[target("cpp_17")]

#include <iostream>
#include <cassert>

@@system ManufacturingCell {
    interface:
        work_order(order_id: str)
        phase_done()
        emergency_stop()
        reset()
        parts_produced(): int
        status(): str

    machine:
        $Idle => $Active {
            work_order(order_id: str) { -> $Setup }
            status(): str { @@:(std::string("idle")) }
            => $^
        }

        $Setup => $Active {
            phase_done() { -> $Machining }
            status(): str { @@:(std::string("setup")) }
            => $^
        }

        $Machining => $Active {
            phase_done() { -> $Teardown }
            status(): str { @@:(std::string("machining")) }
            => $^
        }

        $Teardown => $Active {
            phase_done() {
                this->parts = this->parts + 1;
                -> $Idle
            }
            status(): str { @@:(std::string("teardown")) }
            => $^
        }

        $Active {
            emergency_stop() { -> $EStopped }
            parts_produced(): int { @@:(this->parts) }
            status(): str { @@:(std::string("active")) }
        }

        $EStopped {
            reset() { -> $Idle }
            parts_produced(): int { @@:(this->parts) }
            status(): str { @@:(std::string("estopped")) }
        }

    domain:
        parts: int = 0
}

int main() {
    auto c = @@ManufacturingCell();
    assert(std::any_cast<std::string>(c.status()) == "idle");
    assert(std::any_cast<int>(c.parts_produced()) == 0);
    c.work_order("WO-001");
    assert(std::any_cast<std::string>(c.status()) == "setup");
    c.phase_done();
    assert(std::any_cast<std::string>(c.status()) == "machining");
    c.phase_done();
    assert(std::any_cast<std::string>(c.status()) == "teardown");
    c.phase_done();
    assert(std::any_cast<std::string>(c.status()) == "idle");
    assert(std::any_cast<int>(c.parts_produced()) == 1);
    c.work_order("WO-002");
    c.phase_done();
    c.emergency_stop();
    assert(std::any_cast<std::string>(c.status()) == "estopped");
    c.reset();
    assert(std::any_cast<std::string>(c.status()) == "idle");
    std::cout << "PASS: manufacturing_cell" << std::endl;
    return 0;
}

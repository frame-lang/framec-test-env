@@target csharp

using System;

@@system Agent {
    interface:
        tick()
        threat()
        safe()
        get_log(): String

    machine:
        $Exploring {
            tick() {
                this.action_log = this.action_log + "explore,";
            }
            threat() {
                this.action_log = this.action_log + "flee,";
                -> $Fleeing
            }
            get_log(): String { @@:(this.action_log) }
        }
        $Fleeing {
            tick() {
                this.action_log = this.action_log + "run,";
            }
            safe() {
                this.action_log = this.action_log + "resume,";
                -> $Exploring
            }
            get_log(): String { @@:(this.action_log) }
        }

    domain:
        action_log: String = ""
}

class Program {
    static void Main(string[] args) {
        var a = new Agent();
        a.tick();
        a.tick();
        a.threat();
        a.tick();
        a.safe();
        var result = (string) a.get_log();
        var expected = "explore,explore,flee,run,resume,";
        if (result != expected) throw new Exception("Expected '" + expected + "', got '" + result + "'");
        Console.WriteLine("PASS: ai_agent");
    }
}

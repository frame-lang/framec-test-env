@@target java

@@system LoginFlow {
    interface:
        submit(value: String): String

    machine:
        $EnterUsername {
            submit(value: String): String {
                this.username = value;
                @@:("enter password")
                -> $EnterPassword
            }
        }
        $EnterPassword {
            submit(value: String): String {
                if (this.username.equals("admin") && value.equals("secret")) {
                    @@:("welcome")
                    -> $LoggedIn
                } else {
                    @@:("invalid - try again")
                    -> $EnterUsername
                }
            }
        }
        $LoggedIn {
            submit(value: String): String { @@:("already logged in") }
        }

    domain:
        username: String = ""
}

class Main {
    public static void main(String[] args) {
        var login = @@LoginFlow();
        var r1 = (String) login.submit("admin");
        assert r1.equals("enter password") : "Expected 'enter password', got '" + r1 + "'";
        var r2 = (String) login.submit("wrong");
        assert r2.equals("invalid - try again") : "Expected 'invalid - try again', got '" + r2 + "'";
        var r3 = (String) login.submit("admin");
        assert r3.equals("enter password") : "Expected 'enter password', got '" + r3 + "'";
        var r4 = (String) login.submit("secret");
        assert r4.equals("welcome") : "Expected 'welcome', got '" + r4 + "'";
        System.out.println("PASS: login_flow");
    }
}

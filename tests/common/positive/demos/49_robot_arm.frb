@@[target("ruby")]

@@system RobotArm {
    interface:
        set_manual()
        set_auto()
        e_stop()
        reset_e_stop()
        status(): str

    machine:
        $Manual => $Operational {
            set_auto() { -> $Auto }
            status(): str { @@:("Manual") }
            => $^
        }

        $Auto => $Operational {
            set_manual() { -> $Manual }
            status(): str { @@:("Auto") }
            => $^
        }

        $Operational {
            e_stop() { -> $EStop }
            status(): str { @@:("Operational") }
        }

        $EStop {
            reset_e_stop() { -> $Manual }
            status(): str { @@:("EStop") }
        }

    domain:
}

arm = @@RobotArm()
raise "expected Manual" unless arm.status == "Manual"
arm.e_stop
raise "expected EStop" unless arm.status == "EStop"
arm.reset_e_stop
raise "expected Manual2" unless arm.status == "Manual"
arm.set_auto
raise "expected Auto" unless arm.status == "Auto"
arm.e_stop
raise "expected EStop from Auto" unless arm.status == "EStop"
puts "PASS: robot_arm"

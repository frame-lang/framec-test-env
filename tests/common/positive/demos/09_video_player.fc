@@[target("c")]

#include <stdio.h>
#include <stdlib.h>
#include <string.h>

@@system VideoPlayer {
    interface:
        play()
        pause()
        stop()
        status(): str

    machine:
        $Stopped {
            play() { -> $Playing }
            status(): str { @@:("stopped") }
        }
        $Playing => $Active {
            pause() { -> $Paused }
            status(): str { @@:("playing") }
            => $^
        }
        $Paused => $Active {
            play() { -> $Playing }
            status(): str { @@:("paused") }
            => $^
        }
        $Active {
            stop() { -> $Stopped }
        }
}

int main() {
    VideoPlayer* vp = @@VideoPlayer();
    if (strcmp(VideoPlayer_status(vp), "stopped") != 0) { printf("FAIL\n"); return 1; }
    VideoPlayer_play(vp);
    if (strcmp(VideoPlayer_status(vp), "playing") != 0) { printf("FAIL\n"); return 1; }
    VideoPlayer_pause(vp);
    if (strcmp(VideoPlayer_status(vp), "paused") != 0) { printf("FAIL\n"); return 1; }
    VideoPlayer_stop(vp);
    if (strcmp(VideoPlayer_status(vp), "stopped") != 0) { printf("FAIL\n"); return 1; }
    printf("PASS: video_player\n");
    VideoPlayer_destroy(vp);
    return 0;
}

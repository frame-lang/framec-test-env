@@[target("go")]

package main

import (
	"fmt"
	"os"
)

@@system RobotArm {
    interface:
        set_manual()
        set_auto()
        e_stop()
        reset_e_stop()
        status(): string

    machine:
        $Manual => $Operational {
            set_auto() { -> $Auto }
            status(): string { @@:("Manual") }
            => $^
        }

        $Auto => $Operational {
            set_manual() { -> $Manual }
            status(): string { @@:("Auto") }
            => $^
        }

        $Operational {
            e_stop() { -> $EStop }
            status(): string { @@:("Operational") }
        }

        $EStop {
            reset_e_stop() { -> $Manual }
            status(): string { @@:("EStop") }
        }

    domain:
}

func main() {
    arm := @@RobotArm()
    if arm.Status() != "Manual" { fmt.Println("FAIL: Manual"); os.Exit(1) }
    arm.E_stop()
    if arm.Status() != "EStop" { fmt.Println("FAIL: EStop"); os.Exit(1) }
    arm.Reset_e_stop()
    if arm.Status() != "Manual" { fmt.Println("FAIL: Manual2"); os.Exit(1) }
    arm.Set_auto()
    if arm.Status() != "Auto" { fmt.Println("FAIL: Auto"); os.Exit(1) }
    arm.E_stop()
    if arm.Status() != "EStop" { fmt.Println("FAIL: EStop from Auto"); os.Exit(1) }
    fmt.Println("PASS: robot_arm")
}

@@[target("gdscript")]

extends SceneTree

@@[persist]
@@system MessageStore {
    operations:
        @@[save]
        save_state(): String {}

        @@[load]
        restore_state(data: String) {}

    interface:
        record(topic: str, payload: str)
        count_for(topic: str): int
        total(): int

    machine:
        $Recording {
            record(topic: str, payload: str) {
                self.total_count = self.total_count + 1
                if topic == "orders":
                    self.orders_count = self.orders_count + 1
                else:
                    if topic == "refunds":
                        self.refunds_count = self.refunds_count + 1
            }
            count_for(topic: str): int {
                if topic == "orders":
                    @@:(self.orders_count)
                else:
                    if topic == "refunds":
                        @@:(self.refunds_count)
                    else:
                        @@:(0)
            }
            total(): int { @@:(self.total_count) }
        }

    domain:
        total_count = 0
        orders_count = 0
        refunds_count = 0
}

func main():
    var s = @@MessageStore()
    s.record("orders", "O-1")
    s.record("orders", "O-2")
    s.record("refunds", "R-1")

    var snap = s.save_state()
    var s2 = MessageStore.new()
    s2.restore_state(snap)
    var failures = 0
    if s2.total() != 3:               print("FAIL: total=3");  failures += 1
    if s2.count_for("orders") != 2:   print("FAIL: orders=2"); failures += 1
    s2.record("orders", "O-3")
    if s2.total() != 4:               print("FAIL: total=4");  failures += 1
    if s2.count_for("orders") != 3:   print("FAIL: orders=3"); failures += 1

    if failures > 0:
        print("FAIL: message_store (" + str(failures) + " failures)")
        quit(1)
    print("PASS: message_store")

func _init():
    main()
    quit()

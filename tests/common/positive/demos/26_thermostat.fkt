@@[target("kotlin")]

@@system Thermostat {
    interface:
        set_target(temp: Int)
        tick(): String
        status(): String

    machine:
        $Off {
            set_target(temp: Int) {
                this.target = temp
                -> $Heating
            }
            status(): String { @@:("off") }
        }
        $Heating => $Active {
            tick(): String {
                this.current = this.current + this.heat_rate
                if (this.current >= this.target) {
                    -> $Cooling
                }
                @@:("heating")
            }
            status(): String { @@:("heating") }
            => $^
        }
        $Cooling => $Active {
            tick(): String {
                this.current = this.current - 1
                if (this.current <= this.target - 2) {
                    -> $Heating
                }
                @@:("cooling")
            }
            status(): String { @@:("cooling") }
            => $^
        }
        $Active {
            set_target(temp: Int) {
                this.target = temp
            }
        }

    domain:
        current: Int = 60
        target: Int = 72
        heat_rate: Int = 2
}

fun main() {
    val t = Thermostat()
    var failures = 0

    if (t.status() as String != "off") {
        println("FAIL: expected off")
        failures++
    }

    t.set_target(64)
    if (t.status() as String != "heating") {
        println("FAIL: expected heating")
        failures++
    }

    var r = t.tick() as String
    if (r != "heating") {
        println("FAIL: expected heating tick, got $r")
        failures++
    }

    r = t.tick() as String
    if (t.status() as String != "cooling") {
        println("FAIL: expected cooling after reaching target")
        failures++
    }

    t.set_target(66)
    if (t.status() as String != "cooling") {
        println("FAIL: expected still cooling after set_target (HSM parent)")
        failures++
    }

    if (failures > 0) {
        println("FAIL: thermostat ($failures failures)")
        kotlin.system.exitProcess(1)
    }
    println("PASS: thermostat")
}

@@target ruby

@@system S {
    machine:
        $A => $P {
            e() {
                d = {"k" => 1}
                d["k"] = 2
                => $^
                d["k"]
            }
        }
        $P { }
}

puts("TAP version 14")
puts("1..1")
begin
    s = S.new
    if s.respond_to?(:e)
        s.e()
    end
    puts("ok 1 - dict_ops")
rescue => ex
    puts("not ok 1 - dict_ops # #{ex}")
end

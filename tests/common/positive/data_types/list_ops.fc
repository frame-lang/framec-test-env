@@target c

#include <stdio.h>
#include <stdlib.h>
#include <string.h>

@@system S {
    machine:
        $A => $P {
            e() {
                // C doesn't have dynamic lists like Python
                // Using a simple array instead
                int a[10];
                int a_len = 2;
                a[0] = 1;
                a[1] = 2;
                // append(3)
                a[a_len++] = 3;
                => $^
                // len(a) would be a_len
                int len = a_len;
            }
        }
        $P { }
}

// TAP test harness
int main() {
    printf("TAP version 14\n");
    printf("1..1\n");

    S* s = @@S();
    if (s != NULL) {
        S_e(s);
        printf("ok 1 - list_ops\n");
        S_destroy(s);
    } else {
        printf("not ok 1 - list_ops # failed to create system\n");
        return 1;
    }

    return 0;
}

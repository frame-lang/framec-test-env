@@target c
// @@visitor-map-golden: origins=frame; min=1

#include <stdio.h>
#include <stdlib.h>
#include <string.h>

@@system S {
    machine:
        $A {
            e() {
                int x = 1;
                -> $B()
            }
        }
        $B {
            e() {
                // pass - empty handler
            }
        }
}

// TAP test harness
int main() {
    printf("TAP version 14\n");
    printf("1..1\n");

    S* s = @@S();
    if (s != NULL) {
        S_e(s);
        printf("ok 1 - module_visitor_map_basic\n");
        S_destroy(s);
    } else {
        printf("not ok 1 - module_visitor_map_basic # failed to create system\n");
        return 1;
    }

    return 0;
}

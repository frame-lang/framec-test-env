@@[target("gdscript")]
extends SceneTree


@@system MixedBodyStringsComments {
    machine:
        $Init {
            start() {
                # Native Python with Frame-statement-like tokens in strings and comments
                var text = "This mentions -> $Next and pop$ inside a string."
                # A comment that mentions => $^ and -> $Other should not be parsed as Frame
                print(text)
                -> $Done
            }
        }
        $Done {}
}

# Stub functions for placeholder calls
func native(): pass
func x(): pass

# TAP test harness
func _init():
    print("TAP version 14")
    print("1..1")
    var s = @@MixedBodyStringsComments()
    if s.has_method("e"):
        s.e()
    print("ok 1 - test_mixed_body_strings_comments")
    quit()

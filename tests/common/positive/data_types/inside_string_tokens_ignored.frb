@@[target("ruby")]

@@system S {
    machine:
        $A {
            e() {
                s = "-> $B() and => $^ ignored"
                a()
            }
        }
}

def a; end

puts("TAP version 14")
puts("1..1")
begin
    s = @@S()
    if s.respond_to?(:e)
        s.e()
    end
    puts("ok 1 - inside_string_tokens_ignored")
rescue => ex
    puts("not ok 1 - inside_string_tokens_ignored # #{ex}")
end

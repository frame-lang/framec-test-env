@@target c

#include <stdio.h>
#include <stdlib.h>
#include <string.h>
#include <ctype.h>

@@system S {
    machine:
        $A => $P {
            e() {
                int n = 42;
                char* s = "hello";
                => $^
                // C doesn't have s.upper() - would need manual implementation
                // Just using the string as-is for this test
                char upper[100];
                int i = 0;
                while (s[i]) {
                    upper[i] = toupper(s[i]);
                    i++;
                }
                upper[i] = '\0';
            }
        }
        $P { }
}

// TAP test harness
int main() {
    printf("TAP version 14\n");
    printf("1..1\n");

    S* s = S_new();
    if (s != NULL) {
        S_e(s);
        printf("ok 1 - ints_strings\n");
        S_destroy(s);
    } else {
        printf("not ok 1 - ints_strings # failed to create system\n");
        return 1;
    }

    return 0;
}

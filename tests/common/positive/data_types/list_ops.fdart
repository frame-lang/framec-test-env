@@[target("dart")]
@@system S {
    machine:
        $A => $P {
            e() {
                var a = [1, 2];
                a.add(3);
                => $^
                a.length;
            }
        }
        $P { }
}

// Stub functions for placeholder calls
void native() {}
void x() {}

// TAP test harness
void main() {
    print("TAP version 14");
    print("1..1");
    try {
        final s = @@S();
        if (true) {
            s.e();
        }
        print("ok 1 - list_ops");
    } catch (ex) {
        print("not ok 1 - list_ops # ${ex}");
    }
}

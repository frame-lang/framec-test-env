@@[target("ruby")]

@@system MixedBodyStringsComments {
    machine:
        $Init {
            start() {
                # Native Ruby with Frame-statement-like tokens in strings and comments
                text = "This mentions -> $Next and pop$ inside a string."
                # A comment that mentions => $^ and -> $Other should not be parsed as Frame
                puts(text)
                -> $Done
            }
        }
        $Done {}
}

puts("TAP version 14")
puts("1..1")
begin
    s = MixedBodyStringsComments.new
    if s.respond_to?(:e)
        s.e()
    end
    puts("ok 1 - test_mixed_body_strings_comments")
rescue => ex
    puts("not ok 1 - test_mixed_body_strings_comments # #{ex}")
end

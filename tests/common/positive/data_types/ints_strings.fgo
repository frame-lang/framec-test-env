@@[target("go")]

package main

import (
	"fmt"
	"strings"
)

@@system S {
    machine:
        $A => $P {
            E() {
                n := 42
                str := "hello"
                _ = n
                => $^
                _ = strings.ToUpper(str)
            }
        }
        $P { }
}

func main() {
	fmt.Println("TAP version 14")
	fmt.Println("1..1")
	s := NewS()
	s.E()
	fmt.Println("ok 1 - ints_strings")
}

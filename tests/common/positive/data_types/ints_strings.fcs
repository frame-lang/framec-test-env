@@[target("csharp")]


@@system S {
    machine:
        $A => $P {
            e() {
                int n = 42;
                string s = "hello";
                => $^
                s.ToUpper();
            }
        }
        $P { }
}

class Program {
    static void Main(string[] args) {
        Console.WriteLine("TAP version 14");
        Console.WriteLine("1..1");
        try {
            S s = @@S();
            s.e();
            Console.WriteLine("ok 1 - ints_strings");
        } catch (Exception ex) {
            Console.WriteLine("not ok 1 - ints_strings # " + ex);
        }
    }
}

@@target c

#include <stdio.h>
#include <stdlib.h>
#include <string.h>

@@system S {
    machine:
        $A => $P {
            e() {
                // C doesn't have dicts - using a simple struct-like approach
                // For this test, just demonstrate basic variable assignment
                int k_value = 1;
                k_value = 2;
                => $^
                // d.get("k") would return k_value
                int result = k_value;
            }
        }
        $P { }
}

// TAP test harness
int main() {
    printf("TAP version 14\n");
    printf("1..1\n");

    S* s = @@S();
    if (s != NULL) {
        S_e(s);
        printf("ok 1 - dict_ops\n");
        S_destroy(s);
    } else {
        printf("not ok 1 - dict_ops # failed to create system\n");
        return 1;
    }

    return 0;
}

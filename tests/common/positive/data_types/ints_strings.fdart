@@target dart

@@system S {
    machine:
        $A => $P {
            e() {
                n = 42
                s = "hello"
                => $^
                s.upper()
            }
        }
        $P { }
}

// Stub functions for placeholder calls

// TAP test harness
void main() {
    print("TAP version 14");
    print("1..1");
    try:
        var s = @@S();
        if // hasattr check: 'e'):
            s.e();
        print("ok 1 - ints_strings");
    except Exception as ex:
        print("not ok 1 - ints_strings // {ex}");

}

@@target dart

@@system S {
    machine:
        $A => $P {
            e() {
                var n = 42;
                var s = "hello";
                => $^
                s.toUpperCase();
            }
        }
        $P { }
}

void main() {
    print("TAP version 14");
    print("1..1");
    try {
        var s = @@S();
        s.e();
        print("ok 1 - ints_strings");
    } catch (ex) {
        print("not ok 1 - ints_strings # $ex");
    }
}
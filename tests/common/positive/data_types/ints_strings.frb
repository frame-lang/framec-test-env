@@target ruby

@@system S {
    machine:
        $A => $P {
            e() {
                n = 42
                s = "hello"
                => $^
                s.upcase
            }
        }
        $P { }
}

puts("TAP version 14")
puts("1..1")
begin
    s = S.new
    if s.respond_to?(:e)
        s.e()
    end
    puts("ok 1 - ints_strings")
rescue => ex
    puts("not ok 1 - ints_strings # #{ex}")
end

@@[target("php")]

@@system S {
    machine:
        $A => $P {
            e() {
                $n = 42;
                $s = "hello";
                => $^
                strtoupper($s);
            }
        }
        $P { }
}

function native() {}
function x() {}

echo "TAP version 14" . "\n";
echo "1..1" . "\n";
try {
    $s = @@S();
    if (method_exists($s, 'e')) { $s->e(); }
    echo "ok 1 - ints_strings" . "\n";
} catch (\Exception $ex) {
    echo "not ok 1 - ints_strings # " . $ex->getMessage() . "\n";
}

@@[target("c")]

#include <stdio.h>
#include <stdlib.h>
#include <string.h>

@@system MixedBodyStringsComments {
    machine:
        $Init {
            start() {
                // Native C with Frame-statement-like tokens in strings and comments
                char* text = "This mentions -> $Next and pop$ inside a string.";
                // A comment that mentions => $^ and -> $Other should not be parsed as Frame
                printf("%s\n", text);
                -> $Done
            }
        }
        $Done {}
}

// TAP test harness
int main() {
    printf("TAP version 14\n");
    printf("1..1\n");

    MixedBodyStringsComments* s = @@MixedBodyStringsComments();
    if (s != NULL) {
        MixedBodyStringsComments_start(s);
        printf("ok 1 - test_mixed_body_strings_comments\n");
        MixedBodyStringsComments_destroy(s);
    } else {
        printf("not ok 1 - test_mixed_body_strings_comments # failed to create system\n");
        return 1;
    }

    return 0;
}

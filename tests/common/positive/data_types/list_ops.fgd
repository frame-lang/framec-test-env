@@target gdscript

@@system S {
    machine:
        $A => $P {
            e() {
                a = [1,2]
                a.append(3)
                => $^
                len(a)
            }
        }
        $P { }
}

# Stub functions for placeholder calls

# TAP test harness
func _ready():
    print("TAP version 14")
    print("1..1")
    try:
        s = @@S()
        if s.has_method('e'):
            s.e()
        print("ok 1 - list_ops")
    except Exception as ex:
        print("not ok 1 - list_ops # {ex}")

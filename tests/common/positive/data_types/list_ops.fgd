@@[target("gdscript")]
extends SceneTree

@@system S {
    machine:
        $A => $P {
            e() {
                var a = [1,2]
                a.append(3)
                => $^
                a.size()
            }
        }
        $P { }
}

# Stub functions for placeholder calls
func native(): pass
func x(): pass

# TAP test harness
func _init():
    print("TAP version 14")
    print("1..1")
    var s = @@S()
    if s.has_method("e"):
        s.e()
    print("ok 1 - list_ops")
    quit()

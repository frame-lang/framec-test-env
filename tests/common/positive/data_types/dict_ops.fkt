@@target kotlin

import kotlin.system.exitProcess

@@system S {
    machine:
        $A => $P {
            e() {
                val d = mutableMapOf<String, Int>()
                d["k"] = 1
                d["k"] = 2
                => $^
                d["k"]
            }
        }
        $P { }
}

fun main() {
    println("TAP version 14")
    println("1..1")
    try {
        val s = S()
        s.e()
        println("ok 1 - dict_ops")
    } catch (ex: Exception) {
        println("not ok 1 - dict_ops # $ex")
    }
}

@@[target("php")]

@@system MixedBodyStringsComments {
    machine:
        $Init {
            start() {
                # Native PHP with Frame-statement-like tokens in strings and comments
                $text = "This mentions -> \$Next and pop\$ inside a string.";
                # A comment that mentions => $^ and -> $Other should not be parsed as Frame
                echo $text . "\n";
                -> $Done
            }
        }
        $Done {}
}

function native() {}
function x() {}

echo "TAP version 14" . "\n";
echo "1..1" . "\n";
try {
    $s = @@MixedBodyStringsComments();
    if (method_exists($s, 'e')) { $s->e(); }
    echo "ok 1 - test_mixed_body_strings_comments" . "\n";
} catch (\Exception $ex) {
    echo "not ok 1 - test_mixed_body_strings_comments # " . $ex->getMessage() . "\n";
}

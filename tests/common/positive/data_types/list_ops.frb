@@[target("ruby")]

@@system S {
    machine:
        $A => $P {
            e() {
                a = [1,2]
                a.push(3)
                => $^
                a.length
            }
        }
        $P { }
}

puts("TAP version 14")
puts("1..1")
begin
    s = @@S()
    if s.respond_to?(:e)
        s.e()
    end
    puts("ok 1 - list_ops")
rescue => ex
    puts("not ok 1 - list_ops # #{ex}")
end

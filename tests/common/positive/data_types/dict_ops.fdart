@@target dart

@@system S {
    machine:
        $A => $P {
            e() {
                var d = {"k": 1};
                d["k"] = 2;
                => $^
                d["k"];
            }
        }
        $P { }
}

void main() {
    print("TAP version 14");
    print("1..1");
    try {
        var s = @@S();
        s.e();
        print("ok 1 - dict_ops");
    } catch (ex) {
        print("not ok 1 - dict_ops # $ex");
    }
}
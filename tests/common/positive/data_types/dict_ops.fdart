@@target dart

@@system S {
    machine:
        $A => $P {
            e() {
                d = {"k": 1}
                d["k"] = 2
                => $^
                d.get("k")
            }
        }
        $P { }
}

// Stub functions for placeholder calls

// TAP test harness
void main() {
    print("TAP version 14");
    print("1..1");
    try:
        var s = @@S();
        if // hasattr check: 'e'):
            s.e();
        print("ok 1 - dict_ops");
    except Exception as ex:
        print("not ok 1 - dict_ops // {ex}");

}

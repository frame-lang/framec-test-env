@@target kotlin

import kotlin.system.exitProcess

@@system MixedBodyStringsComments {
    machine:
        $Init {
            start() {
                // Native Kotlin with Frame-statement-like tokens in strings and comments
                val text = "This mentions -> \$Next and pop\$ inside a string."
                // A comment that mentions => $^ and -> $Other should not be parsed as Frame
                println(text)
                -> $Done
            }
        }
        $Done {}
}

fun main() {
    println("TAP version 14")
    println("1..1")
    try {
        val s = MixedBodyStringsComments()
        println("ok 1 - test_mixed_body_strings_comments")
    } catch (ex: Exception) {
        println("not ok 1 - test_mixed_body_strings_comments # $ex")
    }
}

@@[target("ruby")]
@@visitor-map-golden: origins=frame; min=1

@@system S {
    machine:
        $A {
            e() {
                x = 1
                -> $B()
            }
        }
        $B { e() { } }
}

puts("TAP version 14")
puts("1..1")
begin
    s = @@S()
    if s.respond_to?(:e)
        s.e()
    end
    puts("ok 1 - module_visitor_map_basic")
rescue => ex
    puts("not ok 1 - module_visitor_map_basic # #{ex}")
end

@@[target("kotlin")]

import kotlin.system.exitProcess

@@system S {
    machine:
        $A => $P {
            e() {
                val a = mutableListOf(1, 2)
                a.add(3)
                => $^
                a.size
            }
        }
        $P { }
}

fun main() {
    println("TAP version 14")
    println("1..1")
    try {
        val s = S()
        s.e()
        println("ok 1 - list_ops")
    } catch (ex: Exception) {
        println("not ok 1 - list_ops # $ex")
    }
}

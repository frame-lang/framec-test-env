@@target cpp_17

#include <iostream>
#include <string>
#include <unordered_map>
#include <cassert>

@@system S {
    machine:
        $A => $P {
            e() {
                std::unordered_map<std::string, int> d = {{"k", 1}};
                d["k"] = 2;
                => $^
                d.count("k");
            }
        }
        $P { }
}

// Stub functions for placeholder calls
void native() {}
void x() {}

// TAP test harness
int main() {
    printf("TAP version 14\n");
    printf("1..1\n");
    try {
        S s;
        s.e();
        printf("ok 1 - dict_ops\n");
    } catch (...) {
        printf("not ok 1 - dict_ops\n");
    }
    return 0;
}

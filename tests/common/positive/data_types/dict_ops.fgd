@@target gdscript

@@system S {
    machine:
        $A => $P {
            e() {
                d = {"k": 1}
                d["k"] = 2
                => $^
                d.get("k")
            }
        }
        $P { }
}

# Stub functions for placeholder calls

# TAP test harness
func _ready():
    print("TAP version 14")
    print("1..1")
    s = @@S()
    if s.has_method("e"):
        s.e()
    print("ok 1 - dict_ops")
@@[target("python")]


@@system MixedBodyStringsComments {
    machine:
        $Init {
            start() {
                # Native Python with Frame-statement-like tokens in strings and comments
                text = "This mentions -> $Next and pop$ inside a string."
                # A comment that mentions => $^ and -> $Other should not be parsed as Frame
                print(text)
                -> $Done
            }
        }
        $Done {}
}

# Stub functions for placeholder calls
def native(): pass
def x(): pass

# TAP test harness
if __name__ == "__main__":
    print("TAP version 14")
    print("1..1")
    try:
        s = @@MixedBodyStringsComments()
        if hasattr(s, 'e'):
            s.e()
        print("ok 1 - test_mixed_body_strings_comments")
    except Exception as ex:
        print(f"not ok 1 - test_mixed_body_strings_comments # {ex}")

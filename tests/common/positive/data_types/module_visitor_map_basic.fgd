@@target gdscript
@@visitor-map-golden: origins=frame; min=1

@@system S {
    machine:
        $A {
            e() {
                x = 1
                -> $B()
            }
        }
        $B {
            e() {
                pass
            }
        }
}

# Stub functions for placeholder calls

# TAP test harness
func _ready():
    print("TAP version 14")
    print("1..1")
    try:
        s = @@S()
        if s.has_method('e'):
            s.e()
        print("ok 1 - module_visitor_map_basic")
    except Exception as ex:
        print("not ok 1 - module_visitor_map_basic # {ex}")

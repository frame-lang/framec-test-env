@@target gdscript
extends SceneTree
@@visitor-map-golden: origins=frame; min=1

@@system S {
    machine:
        $A {
            e() {
                var x = 1
                -> $B()
            }
        }
        $B {
            e() {
                pass
            }
        }
}

# Stub functions for placeholder calls
func native(): pass
func x(): pass

# TAP test harness
func _init():
    print("TAP version 14")
    print("1..1")
    var s = @@S()
    if s.has_method("e"):
        s.e()
    print("ok 1 - module_visitor_map_basic")
    quit()

@@[target("cpp_17")]

#include <iostream>
#include <string>
#include <algorithm>
#include <cassert>

@@system S {
    machine:
        $A => $P {
            e() {
                int n = 42;
                std::string s = "hello";
                => $^
                std::transform(s.begin(), s.end(), s.begin(), ::toupper);
            }
        }
        $P { }
}

// Stub functions for placeholder calls
void native() {}
void x() {}

// TAP test harness
int main() {
    printf("TAP version 14\n");
    printf("1..1\n");
    try {
        auto s = @@S();
        s.e();
        printf("ok 1 - ints_strings\n");
    } catch (...) {
        printf("not ok 1 - ints_strings\n");
    }
    return 0;
}

@@[target("cpp_17")]

// USB Device Enumeration — multi-stage pipeline with compensation (saga).

#include <iostream>
#include <sstream>
#include <cassert>
#include <cstdlib>

@@system UsbEnumerator {
    interface:
        plug_in(port: int)
        reset_done(success: bool)
        address_set(success: bool, addr: int)
        descriptors_read(success: bool, product: str)
        driver_bound(success: bool)
        unplug()
        status(): str

    machine:
        $Detached {
            plug_in(port: int) {
                this->port = port;
                this->reset_attempts = 0;
                -> $Resetting
            }
            status(): str { @@:(std::string("detached")) }
        }

        $Resetting => $Enumerating {
            $>() {
                this->reset_attempts = this->reset_attempts + 1;
                this->issue_port_reset(this->port);
            }

            reset_done(success: bool) {
                if (success) {
                    -> $Addressing
                } else {
                    if (this->reset_attempts < this->max_reset_attempts) {
                        -> $Resetting
                    } else {
                        -> $Failed
                    }
                }
            }
            status(): str { @@:(std::string("resetting")) }
            => $^
        }

        $Addressing => $Enumerating {
            $>() {
                this->assign_address();
            }

            address_set(success: bool, addr: int) {
                if (success) {
                    this->address = addr;
                    -> $ReadingDescriptors
                } else {
                    -> $UndoReset
                }
            }
            status(): str { @@:(std::string("addressing")) }
            => $^
        }

        $ReadingDescriptors => $Enumerating {
            $>() {
                this->read_descriptors(this->address);
            }

            descriptors_read(success: bool, product: str) {
                if (success) {
                    this->product = product;
                    -> $BindingDriver
                } else {
                    -> $UndoAddress
                }
            }
            status(): str { @@:(std::string("reading descriptors")) }
            => $^
        }

        $BindingDriver => $Enumerating {
            $>() {
                this->bind_driver(this->product);
            }

            driver_bound(success: bool) {
                if (success) {
                    -> $Configured
                } else {
                    -> $UndoAddress
                }
            }
            status(): str { @@:(std::string("binding driver")) }
            => $^
        }

        $Enumerating {
            unplug() {
                -> $Detached
            }
        }

        $UndoAddress {
            $>() {
                this->release_address(this->address);
                -> $UndoReset
            }
        }

        $UndoReset {
            $>() {
                this->disable_port(this->port);
                -> $Failed
            }
        }

        $Configured {
            unplug() {
                this->unbind_driver();
                this->release_address(this->address);
                this->disable_port(this->port);
                -> $Detached
            }
            status(): str { @@:(std::string("configured")) }
        }

        $Failed {
            plug_in(port: int) {
                this->port = port;
                this->reset_attempts = 0;
                -> $Resetting
            }
            status(): str { @@:(std::string("failed")) }
        }

    actions:
        issue_port_reset(port: int) {}
        assign_address() {}
        read_descriptors(addr: int) {}
        bind_driver(product: str) {}
        release_address(addr: int) {}
        disable_port(port: int) {}
        unbind_driver() {}

    domain:
        port: int = 0
        address: int = 0
        product: std::string = std::string("")
        reset_attempts: int = 0
        max_reset_attempts: int = 3
}


void check(const std::string& label, const std::string& actual, const std::string& expected) {
    if (actual != expected) {
        std::cout << "FAIL: " << label << " — expected '" << expected << "', got '" << actual << "'" << std::endl;
        std::exit(1);
    }
}

void test_happy_path() {
    auto usb = @@UsbEnumerator();
    check("initial detached", std::any_cast<std::string>(usb.status()), "detached");
    usb.plug_in(1);
    check("after plug_in", std::any_cast<std::string>(usb.status()), "resetting");
    usb.reset_done(true);
    check("reset ok -> addressing", std::any_cast<std::string>(usb.status()), "addressing");
    usb.address_set(true, 7);
    check("address ok -> reading", std::any_cast<std::string>(usb.status()), "reading descriptors");
    usb.descriptors_read(true, std::string("USB Keyboard"));
    check("descriptors ok -> binding", std::any_cast<std::string>(usb.status()), "binding driver");
    usb.driver_bound(true);
    check("driver bound -> configured", std::any_cast<std::string>(usb.status()), "configured");
    std::cout << "PASS: happy path enumeration" << std::endl;
}

void test_descriptor_failure_compensates() {
    auto usb = @@UsbEnumerator();
    usb.plug_in(2);
    usb.reset_done(true);
    usb.address_set(true, 8);
    usb.descriptors_read(false, std::string(""));
    check("compensated to failed", std::any_cast<std::string>(usb.status()), "failed");
    std::cout << "PASS: descriptor failure compensation" << std::endl;
}

void test_driver_bind_failure_compensates() {
    auto usb = @@UsbEnumerator();
    usb.plug_in(3);
    usb.reset_done(true);
    usb.address_set(true, 9);
    usb.descriptors_read(true, std::string("Mouse"));
    usb.driver_bound(false);
    check("bind fail compensated to failed", std::any_cast<std::string>(usb.status()), "failed");
    std::cout << "PASS: driver bind failure compensation" << std::endl;
}

void test_unplug_during_enumeration() {
    auto usb = @@UsbEnumerator();
    usb.plug_in(4);
    check("in resetting", std::any_cast<std::string>(usb.status()), "resetting");
    usb.unplug();
    check("unplug -> detached", std::any_cast<std::string>(usb.status()), "detached");
    std::cout << "PASS: unplug during enumeration forwards via HSM" << std::endl;
}

void test_reset_retry_then_exhaust() {
    auto usb = @@UsbEnumerator();
    usb.plug_in(5);
    usb.reset_done(false);
    check("retry 1", std::any_cast<std::string>(usb.status()), "resetting");
    usb.reset_done(false);
    check("retry 2", std::any_cast<std::string>(usb.status()), "resetting");
    usb.reset_done(false);
    check("exhausted -> failed", std::any_cast<std::string>(usb.status()), "failed");
    std::cout << "PASS: reset retry exhaustion" << std::endl;
}

void test_replug_from_failed() {
    auto usb = @@UsbEnumerator();
    usb.plug_in(6);
    usb.reset_done(false);
    usb.reset_done(false);
    usb.reset_done(false);
    check("failed state", std::any_cast<std::string>(usb.status()), "failed");
    usb.plug_in(6);
    check("re-plug restarts enumeration", std::any_cast<std::string>(usb.status()), "resetting");
    std::cout << "PASS: re-plug from failed state" << std::endl;
}

int main() {
    test_happy_path();
    test_descriptor_failure_compensates();
    test_driver_bind_failure_compensates();
    test_unplug_during_enumeration();
    test_reset_retry_then_exhaust();
    test_replug_from_failed();
    std::cout << "PASS: all USB enumeration tests passed" << std::endl;
    return 0;
}

@@target cpp_17

// OOM Killer — kernel mm/oom_kill.c semantics. Safety-critical: while $Killing,
// concurrent oom_detected_again() events are silently dropped because no handler
// exists for them in that state.

#include <iostream>
#include <string>
#include <cstdlib>

@@system OomKiller {
    interface:
        oom_detected(gfp_flags: int): str
        victim_exited(pid: int, freed_kb: int): str
        oom_detected_again(gfp_flags: int): str
        status(): str

    machine:
        $Normal {
            oom_detected(gfp_flags: int): str {
                @@:(std::string("selecting victim"))
                -> $Selecting
            }
            status(): str { @@:(std::string("normal")) }
        }

        $Selecting {
            $>() {
                this->victim_pid = this->select_victim();
                if (this->victim_pid < 0) {
                    -> $Panic
                } else {
                    -> $Killing
                }
            }
            status(): str { @@:(std::string("selecting")) }
        }

        $Killing {
            $>() {
                this->send_sigkill(this->victim_pid);
                this->start_reaper_timer();
            }
            <$() {
                this->cancel_reaper_timer();
            }

            victim_exited(pid: int, freed_kb: int): str {
                if (pid == this->victim_pid) {
                    this->total_freed_kb = this->total_freed_kb + freed_kb;
                    @@:(std::string("reclaimed"))
                    -> $Normal
                } else {
                    @@:(std::string("wrong pid, still waiting"))
                }
            }

            // oom_detected_again NOT handled -- structural safety property.
            status(): str { @@:(std::string("killing")) }
        }

        $Panic {
            status(): str { @@:(std::string("panic")) }
        }

    actions:
        select_victim(): int {
            this->victim_score = 850;
            return 4242;
        }
        send_sigkill(pid: int) {}
        start_reaper_timer() {}
        cancel_reaper_timer() {}

    domain:
        victim_pid: int = -1
        victim_score: int = 0
        total_freed_kb: int = 0
}


void check(const std::string& label, const std::string& actual, const std::string& expected) {
    if (actual != expected) {
        std::cout << "FAIL: " << label << " — expected '" << expected << "', got '" << actual << "'" << std::endl;
        std::exit(1);
    }
}

void test_normal_oom_flow() {
    auto oom = @@OomKiller();
    check("initial normal", std::any_cast<std::string>(oom.status()), "normal");
    check("oom_detected -> selecting", std::any_cast<std::string>(oom.oom_detected(0)), "selecting victim");
    check("arrived in killing", std::any_cast<std::string>(oom.status()), "killing");
    check("victim exits", std::any_cast<std::string>(oom.victim_exited(4242, 51200)), "reclaimed");
    check("back to normal", std::any_cast<std::string>(oom.status()), "normal");
    std::cout << "PASS: normal OOM flow" << std::endl;
}

void test_concurrent_oom_silently_dropped() {
    auto oom = @@OomKiller();
    oom.oom_detected(0);
    check("in killing", std::any_cast<std::string>(oom.status()), "killing");
    oom.oom_detected_again(0);
    check("still killing (event dropped)", std::any_cast<std::string>(oom.status()), "killing");
    oom.victim_exited(4242, 8192);
    check("back to normal after reclaim", std::any_cast<std::string>(oom.status()), "normal");
    std::cout << "PASS: concurrent OOM events dropped in $Killing (safety)" << std::endl;
}

void test_wrong_pid_exit_ignored() {
    auto oom = @@OomKiller();
    oom.oom_detected(0);
    check("waiting for victim", std::any_cast<std::string>(oom.victim_exited(9999, 1024)), "wrong pid, still waiting");
    check("still killing", std::any_cast<std::string>(oom.status()), "killing");
    oom.victim_exited(4242, 2048);
    check("correct pid -> normal", std::any_cast<std::string>(oom.status()), "normal");
    std::cout << "PASS: wrong-pid exit ignored in $Killing" << std::endl;
}

void test_oom_detected_ignored_in_selecting() {
    auto oom = @@OomKiller();
    check("first oom", std::any_cast<std::string>(oom.oom_detected(0)), "selecting victim");
    oom.oom_detected(0);
    check("second oom dropped", std::any_cast<std::string>(oom.status()), "killing");
    std::cout << "PASS: oom_detected ignored while killing" << std::endl;
}

int main() {
    test_normal_oom_flow();
    test_concurrent_oom_silently_dropped();
    test_wrong_pid_exit_ignored();
    test_oom_detected_ignored_in_selecting();
    std::cout << "PASS: all OOM killer tests passed" << std::endl;
    return 0;
}

@@[target("rust")]

// DHCP Client -- RFC 2131 Figure 5 state machine.

@@system DhcpClient {
    interface:
        start()
        offer_received(server_ip: String, offered_ip: String, lease_sec: i32)
        ack_received(ip: String, lease_sec: i32)
        nak_received()
        t1_expired()
        t2_expired()
        lease_expired()
        release()
        status(): String

    machine:
        $Init {
            $>() {
                self.attempts = 0;
            }

            start() {
                -> $Selecting
            }
            status(): String { @@:("init".to_string()) }
        }

        $Selecting {
            $>() {
                self.attempts = self.attempts + 1;
                self.broadcast_discover();
            }

            offer_received(server_ip: String, offered_ip: String, lease_sec: i32) {
                self.server = server_ip;
                self.offered = offered_ip;
                self.lease_sec = lease_sec;
                -> $Requesting
            }
            status(): String { @@:("selecting".to_string()) }
        }

        $Requesting {
            $>() {
                self.send_request();
            }

            ack_received(ip: String, lease_sec: i32) {
                self.bound = ip;
                self.lease_sec = lease_sec;
                -> $Bound
            }
            nak_received() {
                -> $Init
            }
            status(): String { @@:("requesting".to_string()) }
        }

        $Bound {
            $>() {
                self.arm_timers();
            }

            t1_expired() {
                -> $Renewing
            }
            release() {
                self.cancel_all_timers();
                self.send_release();
                -> $Init
            }
            status(): String { @@:("bound".to_string()) }
        }

        $Renewing {
            $>() {
                self.send_renew();
            }

            ack_received(ip: String, lease_sec: i32) {
                self.lease_sec = lease_sec;
                -> $Bound
            }
            nak_received() {
                self.cancel_all_timers();
                -> $Init
            }
            t2_expired() {
                -> $Rebinding
            }
            lease_expired() {
                self.cancel_all_timers();
                -> $Init
            }
            release() {
                self.cancel_all_timers();
                -> $Init
            }
            status(): String { @@:("renewing".to_string()) }
        }

        $Rebinding {
            $>() {
                self.broadcast_renew();
            }

            ack_received(ip: String, lease_sec: i32) {
                self.lease_sec = lease_sec;
                -> $Bound
            }
            nak_received() {
                self.cancel_all_timers();
                -> $Init
            }
            lease_expired() {
                self.cancel_all_timers();
                self.bound = "".to_string();
                -> $Init
            }
            release() {
                self.cancel_all_timers();
                -> $Init
            }
            status(): String { @@:("rebinding".to_string()) }
        }

    actions:
        broadcast_discover()    {}
        send_request()          {}
        send_renew()            {}
        broadcast_renew()       {}
        send_release()          {}
        arm_timers()            {}
        cancel_all_timers()     {}

    domain:
        server: String = "".to_string()
        offered: String = "".to_string()
        bound: String = "".to_string()
        lease_sec: i32 = 0
        attempts: i32 = 0
}


fn check(label: &str, actual: &str, expected: &str) {
    if actual != expected {
        println!("FAIL: {} -- expected '{}', got '{}'", label, expected, actual);
        std::process::exit(1);
    }
}

fn test_full_lease_acquisition() {
    let mut dhcp = @@DhcpClient();
    check("initial init", &dhcp.status(), "init");
    dhcp.start();
    check("selecting", &dhcp.status(), "selecting");
    dhcp.offer_received("192.168.1.1".to_string(), "192.168.1.100".to_string(), 3600);
    check("requesting after offer", &dhcp.status(), "requesting");
    dhcp.ack_received("192.168.1.100".to_string(), 3600);
    check("bound", &dhcp.status(), "bound");
    println!("PASS: full lease acquisition Init->Selecting->Requesting->Bound");
}

fn test_t1_triggers_renewal() {
    let mut dhcp = @@DhcpClient();
    dhcp.start();
    dhcp.offer_received("10.0.0.1".to_string(), "10.0.0.100".to_string(), 7200);
    dhcp.ack_received("10.0.0.100".to_string(), 7200);
    dhcp.t1_expired();
    check("renewing after t1", &dhcp.status(), "renewing");
    dhcp.ack_received("10.0.0.100".to_string(), 7200);
    check("back to bound after renew ack", &dhcp.status(), "bound");
    println!("PASS: T1 triggers renewal, ACK returns to bound");
}

fn test_t2_triggers_rebind() {
    let mut dhcp = @@DhcpClient();
    dhcp.start();
    dhcp.offer_received("10.0.0.1".to_string(), "10.0.0.100".to_string(), 7200);
    dhcp.ack_received("10.0.0.100".to_string(), 7200);
    dhcp.t1_expired();
    check("renewing", &dhcp.status(), "renewing");
    dhcp.t2_expired();
    check("rebinding after t2", &dhcp.status(), "rebinding");
    dhcp.ack_received("10.0.0.100".to_string(), 7200);
    check("rebind ACK -> bound", &dhcp.status(), "bound");
    println!("PASS: T2 triggers rebind, ACK returns to bound");
}

fn test_nak_during_requesting_restarts() {
    let mut dhcp = @@DhcpClient();
    dhcp.start();
    dhcp.offer_received("10.0.0.1".to_string(), "10.0.0.100".to_string(), 7200);
    dhcp.nak_received();
    check("NAK in Requesting -> Init", &dhcp.status(), "init");
    println!("PASS: NAK in Requesting restarts");
}

fn test_lease_expired_in_rebinding() {
    let mut dhcp = @@DhcpClient();
    dhcp.start();
    dhcp.offer_received("10.0.0.1".to_string(), "10.0.0.100".to_string(), 7200);
    dhcp.ack_received("10.0.0.100".to_string(), 7200);
    dhcp.t1_expired();
    dhcp.t2_expired();
    dhcp.lease_expired();
    check("lease_expired in Rebinding -> Init", &dhcp.status(), "init");
    println!("PASS: lease expiry in rebinding clears state");
}

fn test_release_from_bound() {
    let mut dhcp = @@DhcpClient();
    dhcp.start();
    dhcp.offer_received("10.0.0.1".to_string(), "10.0.0.100".to_string(), 7200);
    dhcp.ack_received("10.0.0.100".to_string(), 7200);
    dhcp.release();
    check("release -> init", &dhcp.status(), "init");
    println!("PASS: release from bound");
}

fn main() {
    test_full_lease_acquisition();
    test_t1_triggers_renewal();
    test_t2_triggers_rebind();
    test_nak_during_requesting_restarts();
    test_lease_expired_in_rebinding();
    test_release_from_bound();
    println!("PASS: all DHCP client tests passed");
}

@@target swift

// PPP Link Control Protocol -- RFC 1661 Section 4 state table direct transcription.

import Foundation

@@system PppLcp {
    interface:
        up()
        down()
        open()
        close()
        receive_configure_request(acceptable: Bool)
        receive_configure_ack()
        receive_configure_nak()
        receive_terminate_request()
        receive_terminate_ack()
        timeout_positive()
        timeout_negative()
        status(): String

    machine:
        $Initial {
            up() { -> $Closed }
            open() { -> $Starting }
            status(): String { @@:("initial") }
        }

        $Starting {
            up() {
                self.init_restart_count()
                self.send_configure_request()
                -> $ReqSent
            }
            close() { -> $Initial }
            status(): String { @@:("starting") }
        }

        $Closed {
            open() {
                self.init_restart_count()
                self.send_configure_request()
                -> $ReqSent
            }
            down() { -> $Initial }
            receive_configure_request(acceptable: Bool) {
                self.send_terminate_ack()
            }
            status(): String { @@:("closed") }
        }

        $Stopped {
            open() { -> $Stopped }
            down() { -> $Starting }
            receive_configure_request(acceptable: Bool) {
                self.init_restart_count()
                if acceptable {
                    self.send_configure_ack()
                    self.send_configure_request()
                    -> $AckSent
                } else {
                    self.send_configure_nak()
                    self.send_configure_request()
                    -> $ReqSent
                }
            }
            status(): String { @@:("stopped") }
        }

        $Closing {
            timeout_positive() {
                self.send_terminate_request()
            }
            timeout_negative() {
                -> $Closed
            }
            receive_terminate_ack() {
                -> $Closed
            }
            down() { -> $Initial }
            status(): String { @@:("closing") }
        }

        $Stopping {
            timeout_positive() {
                self.send_terminate_request()
            }
            timeout_negative() {
                -> $Stopped
            }
            receive_terminate_ack() {
                -> $Stopped
            }
            down() { -> $Starting }
            status(): String { @@:("stopping") }
        }

        $ReqSent {
            timeout_positive() {
                self.send_configure_request()
            }
            timeout_negative() {
                -> $Stopped
            }
            receive_configure_request(acceptable: Bool) {
                if acceptable {
                    self.send_configure_ack()
                    -> $AckSent
                } else {
                    self.send_configure_nak()
                }
            }
            receive_configure_ack() {
                self.init_restart_count()
                -> $AckRcvd
            }
            receive_configure_nak() {
                self.init_restart_count()
                self.send_configure_request()
            }
            receive_terminate_request() {
                self.send_terminate_ack()
                -> $ReqSent
            }
            close() {
                self.init_restart_count()
                self.send_terminate_request()
                -> $Closing
            }
            down() { -> $Starting }
            status(): String { @@:("req-sent") }
        }

        $AckRcvd {
            receive_configure_request(acceptable: Bool) {
                if acceptable {
                    self.send_configure_ack()
                    self.tlu()
                    -> $Opened
                } else {
                    self.send_configure_nak()
                }
            }
            timeout_positive() {
                self.send_configure_request()
                -> $ReqSent
            }
            timeout_negative() { -> $Stopped }
            receive_configure_ack() {
                self.send_configure_request()
                -> $ReqSent
            }
            close() {
                self.init_restart_count()
                self.send_terminate_request()
                -> $Closing
            }
            down() { -> $Starting }
            status(): String { @@:("ack-rcvd") }
        }

        $AckSent {
            receive_configure_ack() {
                self.init_restart_count()
                self.tlu()
                -> $Opened
            }
            timeout_positive() {
                self.send_configure_request()
            }
            timeout_negative() { -> $Stopped }
            receive_configure_request(acceptable: Bool) {
                if acceptable {
                    self.send_configure_ack()
                } else {
                    self.send_configure_nak()
                    -> $ReqSent
                }
            }
            receive_configure_nak() {
                self.init_restart_count()
                self.send_configure_request()
                -> $ReqSent
            }
            close() {
                self.init_restart_count()
                self.send_terminate_request()
                -> $Closing
            }
            down() { -> $Starting }
            status(): String { @@:("ack-sent") }
        }

        $Opened {
            <$() {
                self.tld()
            }

            receive_configure_request(acceptable: Bool) {
                self.send_configure_request()
                if acceptable {
                    self.send_configure_ack()
                    -> $AckSent
                } else {
                    self.send_configure_nak()
                    -> $ReqSent
                }
            }
            receive_terminate_request() {
                self.send_terminate_ack()
                self.zero_restart_count()
                -> $Stopping
            }
            close() {
                self.init_restart_count()
                self.send_terminate_request()
                -> $Closing
            }
            down() {
                -> $Starting
            }
            status(): String { @@:("opened") }
        }

    actions:
        send_configure_request() {}
        send_configure_ack()     {}
        send_configure_nak()     {}
        send_terminate_request() {}
        send_terminate_ack()     {}
        init_restart_count() {
            self.restart_count = self.max_restart
        }
        zero_restart_count() {
            self.restart_count = 0
        }
        tlu() {}
        tld() {}

    domain:
        restart_count: Int = 0
        max_restart: Int = 10
}


func check(_ label: String, _ actual: String, _ expected: String) {
    if actual != expected {
        print("FAIL: \(label) -- expected '\(expected)', got '\(actual)'")
        exit(1)
    }
}

func test_normal_open() {
    var ppp = @@PppLcp()
    check("initial", ppp.status() as! String, "initial")
    _ = ppp.open()
    check("starting", ppp.status() as! String, "starting")
    _ = ppp.up()
    check("req-sent", ppp.status() as! String, "req-sent")
    _ = ppp.receive_configure_ack()
    check("ack-rcvd", ppp.status() as! String, "ack-rcvd")
    _ = ppp.receive_configure_request(true)
    check("opened", ppp.status() as! String, "opened")
    print("PASS: normal open sequence")
}

func test_peer_renegotiation() {
    var ppp = @@PppLcp()
    _ = ppp.open()
    _ = ppp.up()
    _ = ppp.receive_configure_ack()
    _ = ppp.receive_configure_request(true)
    check("opened first time", ppp.status() as! String, "opened")
    _ = ppp.receive_configure_request(true)
    check("renegotiation -> AckSent", ppp.status() as! String, "ack-sent")
    _ = ppp.receive_configure_ack()
    check("back to opened", ppp.status() as! String, "opened")
    print("PASS: peer-initiated renegotiation from opened")
}

func test_clean_shutdown() {
    var ppp = @@PppLcp()
    _ = ppp.open()
    _ = ppp.up()
    _ = ppp.receive_configure_ack()
    _ = ppp.receive_configure_request(true)
    _ = ppp.close()
    check("closing", ppp.status() as! String, "closing")
    _ = ppp.receive_terminate_ack()
    check("closed", ppp.status() as! String, "closed")
    print("PASS: clean shutdown via close()")
}

func test_peer_terminate() {
    var ppp = @@PppLcp()
    _ = ppp.open()
    _ = ppp.up()
    _ = ppp.receive_configure_ack()
    _ = ppp.receive_configure_request(true)
    _ = ppp.receive_terminate_request()
    check("stopping on peer-terminate", ppp.status() as! String, "stopping")
    _ = ppp.receive_terminate_ack()
    check("stopped", ppp.status() as! String, "stopped")
    print("PASS: peer-initiated terminate")
}

func test_timeout_negative_from_closing() {
    var ppp = @@PppLcp()
    _ = ppp.open()
    _ = ppp.up()
    _ = ppp.receive_configure_ack()
    _ = ppp.receive_configure_request(true)
    _ = ppp.close()
    check("closing", ppp.status() as! String, "closing")
    _ = ppp.timeout_negative()
    check("closing exhausts to closed", ppp.status() as! String, "closed")
    print("PASS: timeout_negative in closing -> closed")
}

func test_down_from_opened() {
    var ppp = @@PppLcp()
    _ = ppp.open()
    _ = ppp.up()
    _ = ppp.receive_configure_ack()
    _ = ppp.receive_configure_request(true)
    _ = ppp.down()
    check("down from opened -> starting", ppp.status() as! String, "starting")
    print("PASS: down from opened")
}

test_normal_open()
test_peer_renegotiation()
test_clean_shutdown()
test_peer_terminate()
test_timeout_negative_from_closing()
test_down_from_opened()
print("PASS: all PPP LCP tests passed")

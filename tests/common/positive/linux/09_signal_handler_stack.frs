@@target rust

// Signal Handler Stack — textbook push$/pop$ use case.
// When a signal arrives, push the current compartment, enter $SignalHandler
// with the signal name as an enter arg. -> pop$ on handler return restores.
// State variables are preserved across pop$ (unlike -> $State which resets).

@@system SignalContext {
    interface:
        enter_user_code()
        signal_arrives(sig: String)
        handler_returns()
        current_mode(): String
        depth(): i32
        current_signum(): String

    machine:
        $Kernel {
            enter_user_code() {
                -> $UserMode
            }
            current_mode(): String { @@:("kernel".to_string()) }
            depth(): i32 { @@:(self.nesting) }
            current_signum(): String { @@:("".to_string()) }
        }

        $UserMode {
            $.saved_regs: str = ""

            $>() {
                $.saved_regs = self.snapshot_registers();
            }

            signal_arrives(sig: String) {
                self.nesting = self.nesting + 1;
                push$
                -> (sig) $SignalHandler
            }
            current_mode(): String { @@:("user".to_string()) }
            depth(): i32 { @@:(self.nesting) }
            current_signum(): String { @@:("".to_string()) }
        }

        $SignalHandler {
            $.signum: str = ""

            $>(sig: String) {
                $.signum = sig;
            }

            signal_arrives(sig: String) {
                self.nesting = self.nesting + 1;
                push$
                -> (sig) $SignalHandler
            }

            handler_returns() {
                self.nesting = self.nesting - 1;
                -> pop$
            }

            current_mode(): String { @@:("handler".to_string()) }
            depth(): i32 { @@:(self.nesting) }
            current_signum(): String { @@:($.signum.clone()) }
        }

    actions:
        snapshot_registers(): String {
            return "regs_snapshot".to_string();
        }

    domain:
        nesting: i32 = 0
}


fn check_str(label: &str, actual: &str, expected: &str) {
    if actual != expected {
        println!("FAIL: {} -- expected '{}', got '{}'", label, expected, actual);
        std::process::exit(1);
    }
}

fn check_int(label: &str, actual: i32, expected: i32) {
    if actual != expected {
        println!("FAIL: {} -- expected {}, got {}", label, expected, actual);
        std::process::exit(1);
    }
}

fn test_enter_user_mode() {
    let mut cpu = @@SignalContext();
    check_str("initial kernel", &cpu.current_mode(), "kernel");
    cpu.enter_user_code();
    check_str("in user mode", &cpu.current_mode(), "user");
    check_int("depth 0", cpu.depth(), 0);
    println!("PASS: enter user mode");
}

fn test_single_signal_handler() {
    let mut cpu = @@SignalContext();
    cpu.enter_user_code();
    cpu.signal_arrives("SIGUSR1".to_string());
    check_str("in handler", &cpu.current_mode(), "handler");
    check_str("signum SIGUSR1", &cpu.current_signum(), "SIGUSR1");
    check_int("depth 1", cpu.depth(), 1);
    cpu.handler_returns();
    check_str("back to user", &cpu.current_mode(), "user");
    check_int("depth 0", cpu.depth(), 0);
    println!("PASS: single signal handler + return");
}

fn test_nested_signals() {
    let mut cpu = @@SignalContext();
    cpu.enter_user_code();
    cpu.signal_arrives("SIGUSR1".to_string());
    check_str("outer handler signum", &cpu.current_signum(), "SIGUSR1");
    cpu.signal_arrives("SIGALRM".to_string());
    check_str("inner handler signum", &cpu.current_signum(), "SIGALRM");
    check_int("nested depth 2", cpu.depth(), 2);
    cpu.handler_returns();
    check_str("popped to outer handler", &cpu.current_mode(), "handler");
    check_str("outer signum preserved across pop", &cpu.current_signum(), "SIGUSR1");
    check_int("depth 1", cpu.depth(), 1);
    cpu.handler_returns();
    check_str("back to user", &cpu.current_mode(), "user");
    check_int("depth 0", cpu.depth(), 0);
    println!("PASS: nested signals (push$/pop$ preserves state vars)");
}

fn test_deeply_nested_signals() {
    let mut cpu = @@SignalContext();
    cpu.enter_user_code();
    cpu.signal_arrives("SIG1".to_string());
    cpu.signal_arrives("SIG2".to_string());
    cpu.signal_arrives("SIG3".to_string());
    cpu.signal_arrives("SIG4".to_string());
    check_int("depth 4", cpu.depth(), 4);
    check_str("top signum", &cpu.current_signum(), "SIG4");
    cpu.handler_returns();
    check_str("after pop 1: SIG3", &cpu.current_signum(), "SIG3");
    cpu.handler_returns();
    check_str("after pop 2: SIG2", &cpu.current_signum(), "SIG2");
    cpu.handler_returns();
    check_str("after pop 3: SIG1", &cpu.current_signum(), "SIG1");
    cpu.handler_returns();
    check_str("back to user", &cpu.current_mode(), "user");
    println!("PASS: 4-deep nested signal stack");
}

fn main() {
    test_enter_user_mode();
    test_single_signal_handler();
    test_nested_signals();
    test_deeply_nested_signals();
    println!("PASS: all signal handler stack tests passed");
}

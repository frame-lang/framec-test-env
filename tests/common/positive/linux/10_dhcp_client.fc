@@[target("c")]

// DHCP Client -- RFC 2131 Figure 5 state machine.

#include <stdio.h>
#include <stdlib.h>
#include <string.h>

@@system DhcpClient {
    interface:
        start()
        offer_received(server_ip: str, offered_ip: str, lease_sec: int)
        ack_received(ip: str, lease_sec: int)
        nak_received()
        t1_expired()
        t2_expired()
        lease_expired()
        release()
        status(): str

    machine:
        $Init {
            $>() {
                self->attempts = 0;
            }

            start() {
                -> $Selecting
            }
            status(): str { @@:("init") }
        }

        $Selecting {
            $>() {
                self->attempts = self->attempts + 1;
                DhcpClient_broadcast_discover(self);
            }

            offer_received(server_ip: str, offered_ip: str, lease_sec: int) {
                self->server = server_ip;
                self->offered = offered_ip;
                self->lease_sec = lease_sec;
                -> $Requesting
            }
            status(): str { @@:("selecting") }
        }

        $Requesting {
            $>() {
                DhcpClient_send_request(self);
            }

            ack_received(ip: str, lease_sec: int) {
                self->bound = ip;
                self->lease_sec = lease_sec;
                -> $Bound
            }
            nak_received() {
                -> $Init
            }
            status(): str { @@:("requesting") }
        }

        $Bound {
            $>() {
                DhcpClient_arm_timers(self);
            }

            t1_expired() {
                -> $Renewing
            }
            release() {
                DhcpClient_cancel_all_timers(self);
                DhcpClient_send_release(self);
                -> $Init
            }
            status(): str { @@:("bound") }
        }

        $Renewing {
            $>() {
                DhcpClient_send_renew(self);
            }

            ack_received(ip: str, lease_sec: int) {
                self->lease_sec = lease_sec;
                -> $Bound
            }
            nak_received() {
                DhcpClient_cancel_all_timers(self);
                -> $Init
            }
            t2_expired() {
                -> $Rebinding
            }
            lease_expired() {
                DhcpClient_cancel_all_timers(self);
                -> $Init
            }
            release() {
                DhcpClient_cancel_all_timers(self);
                -> $Init
            }
            status(): str { @@:("renewing") }
        }

        $Rebinding {
            $>() {
                DhcpClient_broadcast_renew(self);
            }

            ack_received(ip: str, lease_sec: int) {
                self->lease_sec = lease_sec;
                -> $Bound
            }
            nak_received() {
                DhcpClient_cancel_all_timers(self);
                -> $Init
            }
            lease_expired() {
                DhcpClient_cancel_all_timers(self);
                self->bound = "";
                -> $Init
            }
            release() {
                DhcpClient_cancel_all_timers(self);
                -> $Init
            }
            status(): str { @@:("rebinding") }
        }

    actions:
        broadcast_discover()    {}
        send_request()          {}
        send_renew()            {}
        broadcast_renew()       {}
        send_release()          {}
        arm_timers()            {}
        cancel_all_timers()     {}

    domain:
        server: str = ""
        offered: str = ""
        bound: str = ""
        lease_sec: int = 0
        attempts: int = 0
}


void check(const char* label, const char* actual, const char* expected) {
    if (strcmp(actual, expected) != 0) {
        printf("FAIL: %s -- expected '%s', got '%s'\n", label, expected, actual);
        exit(1);
    }
}

void test_full_lease_acquisition(void) {
    DhcpClient* dhcp = @@DhcpClient();
    check("initial init", (const char*)DhcpClient_status(dhcp), "init");
    DhcpClient_start(dhcp);
    check("selecting", (const char*)DhcpClient_status(dhcp), "selecting");
    DhcpClient_offer_received(dhcp, "192.168.1.1", "192.168.1.100", 3600);
    check("requesting after offer", (const char*)DhcpClient_status(dhcp), "requesting");
    DhcpClient_ack_received(dhcp, "192.168.1.100", 3600);
    check("bound", (const char*)DhcpClient_status(dhcp), "bound");
    printf("PASS: full lease acquisition Init->Selecting->Requesting->Bound\n");
    DhcpClient_destroy(dhcp);
}

void test_t1_triggers_renewal(void) {
    DhcpClient* dhcp = @@DhcpClient();
    DhcpClient_start(dhcp);
    DhcpClient_offer_received(dhcp, "10.0.0.1", "10.0.0.100", 7200);
    DhcpClient_ack_received(dhcp, "10.0.0.100", 7200);
    DhcpClient_t1_expired(dhcp);
    check("renewing after t1", (const char*)DhcpClient_status(dhcp), "renewing");
    DhcpClient_ack_received(dhcp, "10.0.0.100", 7200);
    check("back to bound after renew ack", (const char*)DhcpClient_status(dhcp), "bound");
    printf("PASS: T1 triggers renewal, ACK returns to bound\n");
    DhcpClient_destroy(dhcp);
}

void test_t2_triggers_rebind(void) {
    DhcpClient* dhcp = @@DhcpClient();
    DhcpClient_start(dhcp);
    DhcpClient_offer_received(dhcp, "10.0.0.1", "10.0.0.100", 7200);
    DhcpClient_ack_received(dhcp, "10.0.0.100", 7200);
    DhcpClient_t1_expired(dhcp);
    check("renewing", (const char*)DhcpClient_status(dhcp), "renewing");
    DhcpClient_t2_expired(dhcp);
    check("rebinding after t2", (const char*)DhcpClient_status(dhcp), "rebinding");
    DhcpClient_ack_received(dhcp, "10.0.0.100", 7200);
    check("rebind ACK -> bound", (const char*)DhcpClient_status(dhcp), "bound");
    printf("PASS: T2 triggers rebind, ACK returns to bound\n");
    DhcpClient_destroy(dhcp);
}

void test_nak_during_requesting_restarts(void) {
    DhcpClient* dhcp = @@DhcpClient();
    DhcpClient_start(dhcp);
    DhcpClient_offer_received(dhcp, "10.0.0.1", "10.0.0.100", 7200);
    DhcpClient_nak_received(dhcp);
    check("NAK in Requesting -> Init", (const char*)DhcpClient_status(dhcp), "init");
    printf("PASS: NAK in Requesting restarts\n");
    DhcpClient_destroy(dhcp);
}

void test_lease_expired_in_rebinding(void) {
    DhcpClient* dhcp = @@DhcpClient();
    DhcpClient_start(dhcp);
    DhcpClient_offer_received(dhcp, "10.0.0.1", "10.0.0.100", 7200);
    DhcpClient_ack_received(dhcp, "10.0.0.100", 7200);
    DhcpClient_t1_expired(dhcp);
    DhcpClient_t2_expired(dhcp);
    DhcpClient_lease_expired(dhcp);
    check("lease_expired in Rebinding -> Init", (const char*)DhcpClient_status(dhcp), "init");
    printf("PASS: lease expiry in rebinding clears state\n");
    DhcpClient_destroy(dhcp);
}

void test_release_from_bound(void) {
    DhcpClient* dhcp = @@DhcpClient();
    DhcpClient_start(dhcp);
    DhcpClient_offer_received(dhcp, "10.0.0.1", "10.0.0.100", 7200);
    DhcpClient_ack_received(dhcp, "10.0.0.100", 7200);
    DhcpClient_release(dhcp);
    check("release -> init", (const char*)DhcpClient_status(dhcp), "init");
    printf("PASS: release from bound\n");
    DhcpClient_destroy(dhcp);
}

int main(void) {
    test_full_lease_acquisition();
    test_t1_triggers_renewal();
    test_t2_triggers_rebind();
    test_nak_during_requesting_restarts();
    test_lease_expired_in_rebinding();
    test_release_from_bound();
    printf("PASS: all DHCP client tests passed\n");
    return 0;
}

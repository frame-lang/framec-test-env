@@[target("swift")]

// Filesystem Freeze — VFS fs/super.c semantics. 3-level HSM:
//   $Active => $Readable => $Mounted
//   $Frozen => $Readable => $Mounted
// $Mounted provides read/sync/unmount for all mounted sub-states.
// $Active adds write/freeze. $Frozen overrides write to block and adds thaw.
// $Freezing is transient, bypasses $Readable (state in flux during flush).


@@system Filesystem {
    interface:
        mount(device: String): String
        unmount(): String
        freeze(): String
        thaw(): String
        write(data: String): String
        read(): String
        sync(): String
        status(): String
        read_count(): Int
        write_count(): Int

    machine:
        $Unmounted {
            mount(device: String): String {
                self.device = device
                @@:("mounted")
                -> $Active
            }
            status(): String { @@:("unmounted") }
            read_count(): Int { @@:(self.reads) }
            write_count(): Int { @@:(self.writes) }
        }

        $Active => $Readable {
            write(data: String): String {
                self.writes = self.writes + 1
                @@:("wrote")
            }
            freeze(): String {
                @@:("freezing")
                -> $Freezing
            }
            status(): String { @@:("active") }
            => $^
        }

        $Freezing => $Mounted {
            $>() {
                self.flush_pending_writes()
                -> $Frozen
            }
            status(): String { @@:("freezing") }
            => $^
        }

        $Frozen => $Readable {
            write(data: String): String {
                @@:("BLOCKED")
            }
            thaw(): String {
                @@:("thawed")
                -> $Active
            }
            status(): String { @@:("frozen") }
            => $^
        }

        $Readable => $Mounted {
            => $^
        }

        $Mounted {
            read(): String {
                self.reads = self.reads + 1
                @@:("read")
            }
            sync(): String {
                @@:("synced")
            }
            unmount(): String {
                @@:("unmounting")
                -> $Unmounting
            }
            read_count(): Int { @@:(self.reads) }
            write_count(): Int { @@:(self.writes) }
        }

        $Unmounting {
            $>() {
                self.flush_pending_writes()
                self.release_resources()
                -> $Unmounted
            }
        }

    actions:
        flush_pending_writes() {}
        release_resources() {}

    domain:
        device: String = ""
        writes: Int = 0
        reads: Int = 0
}


func check_str(_ label: String, _ actual: String, _ expected: String) {
    if actual != expected {
        print("FAIL: \(label) — expected '\(expected)', got '\(actual)'")
        exit(1)
    }
}

func check_int(_ label: String, _ actual: Int, _ expected: Int) {
    if actual != expected {
        print("FAIL: \(label) — expected \(expected), got \(actual)")
        exit(1)
    }
}

func test_mount_write_read() {
    var fs = @@Filesystem()
    check_str("initial unmounted", fs.status() as! String, "unmounted")
    check_str("mount", fs.mount("/dev/sda1") as! String, "mounted")
    check_str("active state", fs.status() as! String, "active")
    check_str("write 1", fs.write("hello") as! String, "wrote")
    check_str("read 1", fs.read() as! String, "read")
    check_str("sync via HSM", fs.sync() as! String, "synced")
    check_int("read count incremented", fs.read_count() as! Int, 1)
    check_int("write count incremented", fs.write_count() as! Int, 1)
    print("PASS: mount + write + read + sync")
}

func test_freeze_blocks_writes_allows_reads() {
    var fs = @@Filesystem()
    _ = fs.mount("/dev/sda1")
    _ = fs.write("before freeze")
    _ = fs.freeze()
    check_str("in frozen state", fs.status() as! String, "frozen")
    check_str("write blocked", fs.write("nope") as! String, "BLOCKED")
    check_str("read still works", fs.read() as! String, "read")
    check_int("read count 1", fs.read_count() as! Int, 1)
    check_int("write count unchanged", fs.write_count() as! Int, 1)
    print("PASS: freeze blocks writes, allows reads (3-level HSM)")
}

func test_thaw_restores_write() {
    var fs = @@Filesystem()
    _ = fs.mount("/dev/sda1")
    _ = fs.freeze()
    check_str("thaw", fs.thaw() as! String, "thawed")
    check_str("back to active", fs.status() as! String, "active")
    check_str("write works again", fs.write("post-thaw") as! String, "wrote")
    print("PASS: thaw restores write capability")
}

func test_unmount_forwards_via_hsm() {
    var fs = @@Filesystem()
    _ = fs.mount("/dev/sda1")
    check_str("unmount from Active", fs.unmount() as! String, "unmounting")
    check_str("eventually unmounted", fs.status() as! String, "unmounted")
    print("PASS: unmount forwards from Active via $Readable to $Mounted")
}

func test_freeze_impossible_when_unmounted() {
    let fs = @@Filesystem()
    // framec returns empty String default when no handler exists.
    let ret = fs.freeze() as! String
    if !ret.isEmpty {
        print("FAIL: freeze unmounted expected empty, got '\(ret)'")
        exit(1)
    }
    check_str("still unmounted", fs.status() as! String, "unmounted")
    print("PASS: freeze on unmounted fs is no-op")
}

func test_read_count_accumulates_across_states() {
    var fs = @@Filesystem()
    _ = fs.mount("/dev/sda1")
    _ = fs.read()
    _ = fs.read()
    _ = fs.freeze()
    _ = fs.read()
    _ = fs.thaw()
    _ = fs.read()
    check_int("reads across Active/Frozen/Active", fs.read_count() as! Int, 4)
    print("PASS: read count spans states (domain var)")
}

test_mount_write_read()
test_freeze_blocks_writes_allows_reads()
test_thaw_restores_write()
test_unmount_forwards_via_hsm()
test_freeze_impossible_when_unmounted()
test_read_count_accumulates_across_states()
print("PASS: all filesystem freeze tests passed")

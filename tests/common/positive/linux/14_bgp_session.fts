@@[target("typescript")]

// BGP Finite State Machine -- RFC 4271 Section 8 direct transcription.
// @@persist models bgpd graceful-restart: session state survives daemon restart.
// 6 states: Idle -> Connect -> OpenSent -> OpenConfirm -> Established
//                  -> Active (TCP passive alternative)

@@[persist]
@@system BgpSession {
    operations:
        @@[save]
        saveState(): string {}

        @@[load]
        restoreState(data: string) {}

    interface:
        manual_start()
        manual_stop()
        tcp_connection_confirmed()
        tcp_connection_fails()
        open_received(asn: number, hold_time: number)
        keepalive_received()
        notification_received(code: number, subcode: number)
        hold_timer_expired()
        keepalive_timer_expired()
        connect_retry_timer_expired()
        status(): string

    machine:
        $Idle {
            manual_start() {
                this.connect_retry_count = 0;
                this.start_connect_retry_timer();
                this.initiate_tcp_connection();
                -> $Connect
            }
            status(): string { @@:("idle") }
        }

        $Connect {
            tcp_connection_confirmed() {
                this.cancel_connect_retry_timer();
                this.send_open();
                -> $OpenSent
            }
            tcp_connection_fails() {
                -> $Active
            }
            connect_retry_timer_expired() {
                this.initiate_tcp_connection();
                this.start_connect_retry_timer();
            }
            manual_stop() {
                -> $Idle
            }
            status(): string { @@:("connect") }
        }

        $Active {
            tcp_connection_confirmed() {
                this.cancel_connect_retry_timer();
                this.send_open();
                -> $OpenSent
            }
            connect_retry_timer_expired() {
                this.connect_retry_count = this.connect_retry_count + 1;
                this.initiate_tcp_connection();
                this.start_connect_retry_timer();
                -> $Connect
            }
            manual_stop() {
                -> $Idle
            }
            status(): string { @@:("active") }
        }

        $OpenSent {
            open_received(asn: number, hold_time: number) {
                this.peer_asn = asn;
                this.negotiated_hold = hold_time;
                this.cancel_hold_timer();
                this.send_keepalive();
                -> $OpenConfirm
            }
            tcp_connection_fails() {
                this.cancel_hold_timer();
                -> $Active
            }
            notification_received(code: number, subcode: number) {
                -> $Idle
            }
            hold_timer_expired() {
                this.send_notification();
                -> $Idle
            }
            manual_stop() {
                this.send_notification();
                -> $Idle
            }
            status(): string { @@:("open sent") }
        }

        $OpenConfirm {
            keepalive_received() {
                -> $Established
            }
            notification_received(code: number, subcode: number) {
                -> $Idle
            }
            hold_timer_expired() {
                this.send_notification();
                -> $Idle
            }
            keepalive_timer_expired() {
                this.send_keepalive();
            }
            manual_stop() {
                this.send_notification();
                -> $Idle
            }
            status(): string { @@:("open confirm") }
        }

        $Established {
            keepalive_received() {
                this.reset_hold_timer();
            }
            keepalive_timer_expired() {
                this.send_keepalive();
            }
            notification_received(code: number, subcode: number) {
                -> $Idle
            }
            hold_timer_expired() {
                this.send_notification();
                -> $Idle
            }
            manual_stop() {
                this.send_notification();
                -> $Idle
            }
            status(): string { @@:("established") }
        }

    actions:
        initiate_tcp_connection()   {}
        send_open()                 {}
        send_keepalive()            {}
        send_notification()         {}
        start_connect_retry_timer() {}
        cancel_connect_retry_timer(){}
        cancel_hold_timer()         {}
        reset_hold_timer()          {}

    domain:
        local_asn: number = 65001
        peer_asn: number = 0
        negotiated_hold: number = 0
        connect_retry_count: number = 0
}


function check(label: string, actual: string, expected: string): void {
    if (actual !== expected) {
        console.log(`FAIL: ${label} -- expected '${expected}', got '${actual}'`);
        throw new Error(`assertion failed: ${label}`);
    }
}

function test_full_session_establishment(): void {
    const bgp = @@BgpSession();
    check("initial idle", bgp.status() as string, "idle");
    bgp.manual_start();
    check("connect", bgp.status() as string, "connect");
    bgp.tcp_connection_confirmed();
    check("open sent", bgp.status() as string, "open sent");
    bgp.open_received(65002, 60);
    check("open confirm", bgp.status() as string, "open confirm");
    bgp.keepalive_received();
    check("established", bgp.status() as string, "established");
    console.log("PASS: full BGP session establishment");
}

function test_persist_across_restart(): void {
    const bgp = @@BgpSession();
    bgp.manual_start();
    bgp.tcp_connection_confirmed();
    bgp.open_received(65002, 60);
    bgp.keepalive_received();
    check("established", bgp.status() as string, "established");
    const snap = bgp.saveState();
    const bgp2 = @@BgpSession();

    bgp2.restoreState(snap);
    check("established survived restart", bgp2.status() as string, "established");
    bgp2.keepalive_timer_expired();
    bgp2.keepalive_received();
    check("still established", bgp2.status() as string, "established");
    console.log("PASS: @@persist -- BGP session survives daemon restart");
}

function test_hold_timer_teardown(): void {
    const bgp = @@BgpSession();
    bgp.manual_start();
    bgp.tcp_connection_confirmed();
    bgp.open_received(65002, 60);
    bgp.keepalive_received();
    bgp.hold_timer_expired();
    check("hold expiry tears down", bgp.status() as string, "idle");
    console.log("PASS: hold timer expiry returns to idle");
}

function test_tcp_failure_goes_active(): void {
    const bgp = @@BgpSession();
    bgp.manual_start();
    bgp.tcp_connection_fails();
    check("active after TCP fail", bgp.status() as string, "active");
    bgp.connect_retry_timer_expired();
    check("retry transitions back to connect", bgp.status() as string, "connect");
    console.log("PASS: TCP failure path Active -> Connect");
}

function test_notification_in_established_teardown(): void {
    const bgp = @@BgpSession();
    bgp.manual_start();
    bgp.tcp_connection_confirmed();
    bgp.open_received(65002, 60);
    bgp.keepalive_received();
    bgp.notification_received(6, 0);
    check("notification tears down", bgp.status() as string, "idle");
    console.log("PASS: notification in Established -> idle");
}

function test_manual_stop_from_established(): void {
    const bgp = @@BgpSession();
    bgp.manual_start();
    bgp.tcp_connection_confirmed();
    bgp.open_received(65002, 60);
    bgp.keepalive_received();
    bgp.manual_stop();
    check("manual stop", bgp.status() as string, "idle");
    console.log("PASS: manual_stop from established");
}

test_full_session_establishment();
test_persist_across_restart();
test_hold_timer_teardown();
test_tcp_failure_goes_active();
test_notification_in_established_teardown();
test_manual_stop_from_established();
console.log("PASS: all BGP session tests passed");

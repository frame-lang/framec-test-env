@@[target("rust")]

// Process Lifecycle — Linux task states (kernel/sched/core.c semantics)
// Three-level HSM: $Interruptible, $Uninterruptible => $Blocked => $Alive.
// Explicit upward forwarding via `=> $^` encodes per-state signal policy.

@@system TaskLifecycle {
    interface:
        fork(): String
        schedule(): String
        block_on_io(): String
        io_complete(): String
        block_uninterruptible(): String
        send_signal(sig: String): String
        wait_by_parent(): String
        status(): String

    machine:
        $New {
            fork(): String {
                self.pid = self.next_pid();
                @@:("forked".to_string())
                -> $Ready
            }
            status(): String { @@:("new".to_string()) }
        }

        $Ready => $Alive {
            schedule(): String {
                @@:("running".to_string())
                -> $Running
            }
            status(): String { @@:("ready".to_string()) }
            => $^
        }

        $Running => $Alive {
            schedule(): String {
                @@:("preempted".to_string())
                -> $Ready
            }
            block_on_io(): String {
                @@:("blocked".to_string())
                -> $Interruptible
            }
            block_uninterruptible(): String {
                @@:("blocked (D)".to_string())
                -> $Uninterruptible
            }
            status(): String { @@:("running".to_string()) }
            => $^
        }

        $Interruptible => $Blocked {
            io_complete(): String {
                @@:("woke".to_string())
                -> $Ready
            }
            send_signal(sig: String): String {
                if sig == "SIGKILL" || sig == "SIGTERM" || sig == "SIGSTOP" {
                    => $^
                } else {
                    @@:("interrupted".to_string())
                    -> $Ready
                }
            }
            status(): String { @@:("interruptible".to_string()) }
            => $^
        }

        $Uninterruptible => $Blocked {
            io_complete(): String {
                @@:("woke".to_string())
                -> $Ready
            }
            send_signal(sig: String): String {
                if sig == "SIGKILL" {
                    => $^
                } else {
                    @@:("signal held pending (D-state)".to_string())
                }
            }
            status(): String { @@:("uninterruptible".to_string()) }
            => $^
        }

        $Blocked => $Alive {
            status(): String { @@:("blocked".to_string()) }
            => $^
        }

        $Alive {
            send_signal(sig: String): String {
                if sig == "SIGKILL" || sig == "SIGTERM" {
                    @@:("exiting".to_string())
                    -> $Zombie
                } else if sig == "SIGSTOP" {
                    @@:("stopped".to_string())
                    -> $Stopped
                } else {
                    @@:("signal delivered".to_string())
                }
            }
        }

        $Stopped {
            send_signal(sig: String): String {
                if sig == "SIGCONT" {
                    @@:("continued".to_string())
                    -> $Ready
                } else if sig == "SIGKILL" {
                    @@:("killed while stopped".to_string())
                    -> $Zombie
                } else {
                    @@:("signal ignored".to_string())
                }
            }
            status(): String { @@:("stopped".to_string()) }
        }

        $Zombie {
            wait_by_parent(): String {
                @@:("reaped".to_string())
                -> $Dead
            }
            status(): String { @@:("zombie".to_string()) }
        }

        $Dead {
            status(): String { @@:("dead".to_string()) }
        }

    actions:
        next_pid(): i32 {
            self.pid_counter = self.pid_counter + 1;
            return self.pid_counter;
        }

    domain:
        pid: i32 = 0
        pid_counter: i32 = 100
}


fn check(label: &str, actual: &str, expected: &str) {
    if actual != expected {
        println!("FAIL: {} — expected '{}', got '{}'", label, expected, actual);
        std::process::exit(1);
    }
}

fn test_happy_path() {
    let mut t = @@TaskLifecycle();
    check("initial status", &t.status(), "new");
    check("fork",           &t.fork(),     "forked");
    check("after fork",     &t.status(),   "ready");
    check("schedule",       &t.schedule(), "running");
    check("after schedule", &t.status(),   "running");
    check("preempt",        &t.schedule(), "preempted");
    check("after preempt",  &t.status(),   "ready");
    println!("PASS: happy path");
}

fn test_interruptible_wake_by_signal() {
    let mut t = @@TaskLifecycle();
    t.fork();
    t.schedule();
    check("block_on_io", &t.block_on_io(), "blocked");
    check("interruptible status", &t.status(), "interruptible");
    check("SIGUSR1 wakes interruptible",
          &t.send_signal("SIGUSR1".to_string()), "interrupted");
    check("woke to ready", &t.status(), "ready");
    println!("PASS: interruptible wake by signal");
}

fn test_uninterruptible_holds_signal() {
    let mut t = @@TaskLifecycle();
    t.fork();
    t.schedule();
    check("block_uninterruptible",
          &t.block_uninterruptible(), "blocked (D)");
    check("D state", &t.status(), "uninterruptible");
    check("SIGUSR1 held pending in D",
          &t.send_signal("SIGUSR1".to_string()), "signal held pending (D-state)");
    check("still in D", &t.status(), "uninterruptible");
    println!("PASS: uninterruptible holds non-fatal signal");
}

fn test_sigkill_reaches_d_state() {
    let mut t = @@TaskLifecycle();
    t.fork();
    t.schedule();
    t.block_uninterruptible();
    check("SIGKILL forwarded from D through $Alive",
          &t.send_signal("SIGKILL".to_string()), "exiting");
    check("now zombie", &t.status(), "zombie");
    check("reap", &t.wait_by_parent(), "reaped");
    check("dead", &t.status(), "dead");
    println!("PASS: SIGKILL reaches D state via $Alive forwarding");
}

fn test_sigstop_sigcont() {
    let mut t = @@TaskLifecycle();
    t.fork();
    t.schedule();
    check("SIGSTOP from running",
          &t.send_signal("SIGSTOP".to_string()), "stopped");
    check("stopped status", &t.status(), "stopped");
    check("SIGCONT resumes", &t.send_signal("SIGCONT".to_string()), "continued");
    check("back to ready", &t.status(), "ready");
    println!("PASS: SIGSTOP/SIGCONT");
}

fn main() {
    test_happy_path();
    test_interruptible_wake_by_signal();
    test_uninterruptible_holds_signal();
    test_sigkill_reaches_d_state();
    test_sigstop_sigcont();
    println!("PASS: all process lifecycle tests passed");
}

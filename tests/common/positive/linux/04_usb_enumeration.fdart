@@target dart

// USB Device Enumeration — multi-stage pipeline with compensation (saga).

import 'dart:io';

@@system UsbEnumerator {
    interface:
        plug_in(port: int)
        reset_done(success: bool)
        address_set(success: bool, addr: int)
        descriptors_read(success: bool, product: String)
        driver_bound(success: bool)
        unplug()
        status(): String

    machine:
        $Detached {
            plug_in(port: int) {
                this.port = port;
                this.reset_attempts = 0;
                -> $Resetting
            }
            status(): String { @@:("detached") }
        }

        $Resetting => $Enumerating {
            $>() {
                this.reset_attempts = this.reset_attempts + 1;
                this.issue_port_reset(this.port);
            }

            reset_done(success: bool) {
                if (success) {
                    -> $Addressing
                } else {
                    if (this.reset_attempts < this.max_reset_attempts) {
                        -> $Resetting
                    } else {
                        -> $Failed
                    }
                }
            }
            status(): String { @@:("resetting") }
            => $^
        }

        $Addressing => $Enumerating {
            $>() {
                this.assign_address();
            }

            address_set(success: bool, addr: int) {
                if (success) {
                    this.address = addr;
                    -> $ReadingDescriptors
                } else {
                    -> $UndoReset
                }
            }
            status(): String { @@:("addressing") }
            => $^
        }

        $ReadingDescriptors => $Enumerating {
            $>() {
                this.read_descriptors(this.address);
            }

            descriptors_read(success: bool, product: String) {
                if (success) {
                    this.product = product;
                    -> $BindingDriver
                } else {
                    -> $UndoAddress
                }
            }
            status(): String { @@:("reading descriptors") }
            => $^
        }

        $BindingDriver => $Enumerating {
            $>() {
                this.bind_driver(this.product);
            }

            driver_bound(success: bool) {
                if (success) {
                    -> $Configured
                } else {
                    -> $UndoAddress
                }
            }
            status(): String { @@:("binding driver") }
            => $^
        }

        $Enumerating {
            unplug() {
                -> $Detached
            }
        }

        $UndoAddress {
            $>() {
                this.release_address(this.address);
                -> $UndoReset
            }
        }

        $UndoReset {
            $>() {
                this.disable_port(this.port);
                -> $Failed
            }
        }

        $Configured {
            unplug() {
                this.unbind_driver();
                this.release_address(this.address);
                this.disable_port(this.port);
                -> $Detached
            }
            status(): String { @@:("configured") }
        }

        $Failed {
            plug_in(port: int) {
                this.port = port;
                this.reset_attempts = 0;
                -> $Resetting
            }
            status(): String { @@:("failed") }
        }

    actions:
        issue_port_reset(port: int) {}
        assign_address() {}
        read_descriptors(addr: int) {}
        bind_driver(product: String) {}
        release_address(addr: int) {}
        disable_port(port: int) {}
        unbind_driver() {}

    domain:
        port: int = 0
        address: int = 0
        product: String = ""
        reset_attempts: int = 0
        max_reset_attempts: int = 3
}


void check(String label, String actual, String expected) {
    if (actual != expected) {
        print("FAIL: $label — expected '$expected', got '$actual'");
        exit(1);
    }
}

void test_happy_path() {
    final usb = @@UsbEnumerator();
    check("initial detached", usb.status() as String, "detached");
    usb.plug_in(1);
    check("after plug_in", usb.status() as String, "resetting");
    usb.reset_done(true);
    check("reset ok -> addressing", usb.status() as String, "addressing");
    usb.address_set(true, 7);
    check("address ok -> reading", usb.status() as String, "reading descriptors");
    usb.descriptors_read(true, "USB Keyboard");
    check("descriptors ok -> binding", usb.status() as String, "binding driver");
    usb.driver_bound(true);
    check("driver bound -> configured", usb.status() as String, "configured");
    print("PASS: happy path enumeration");
}

void test_descriptor_failure_compensates() {
    final usb = @@UsbEnumerator();
    usb.plug_in(2);
    usb.reset_done(true);
    usb.address_set(true, 8);
    usb.descriptors_read(false, "");
    check("compensated to failed", usb.status() as String, "failed");
    print("PASS: descriptor failure compensation");
}

void test_driver_bind_failure_compensates() {
    final usb = @@UsbEnumerator();
    usb.plug_in(3);
    usb.reset_done(true);
    usb.address_set(true, 9);
    usb.descriptors_read(true, "Mouse");
    usb.driver_bound(false);
    check("bind fail compensated to failed", usb.status() as String, "failed");
    print("PASS: driver bind failure compensation");
}

void test_unplug_during_enumeration() {
    final usb = @@UsbEnumerator();
    usb.plug_in(4);
    check("in resetting", usb.status() as String, "resetting");
    usb.unplug();
    check("unplug -> detached", usb.status() as String, "detached");
    print("PASS: unplug during enumeration forwards via HSM");
}

void test_reset_retry_then_exhaust() {
    final usb = @@UsbEnumerator();
    usb.plug_in(5);
    usb.reset_done(false);
    check("retry 1", usb.status() as String, "resetting");
    usb.reset_done(false);
    check("retry 2", usb.status() as String, "resetting");
    usb.reset_done(false);
    check("exhausted -> failed", usb.status() as String, "failed");
    print("PASS: reset retry exhaustion");
}

void test_replug_from_failed() {
    final usb = @@UsbEnumerator();
    usb.plug_in(6);
    usb.reset_done(false);
    usb.reset_done(false);
    usb.reset_done(false);
    check("failed state", usb.status() as String, "failed");
    usb.plug_in(6);
    check("re-plug restarts enumeration", usb.status() as String, "resetting");
    print("PASS: re-plug from failed state");
}

void main() {
    test_happy_path();
    test_descriptor_failure_compensates();
    test_driver_bind_failure_compensates();
    test_unplug_during_enumeration();
    test_reset_retry_then_exhaust();
    test_replug_from_failed();
    print("PASS: all USB enumeration tests passed");
}

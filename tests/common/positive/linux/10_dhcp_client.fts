@@target typescript

// DHCP Client — RFC 2131 Figure 5 state machine.
// Lease lifecycle: Init -> Selecting -> Requesting -> Bound
//                                                   <- Renewing (t1_expired)
//                                                   <- Rebinding (t2_expired from Renewing)
// Timers (T1/T2/lease) are armed once in $Bound and not cancelled on state
// transition -- they're absolute deadlines. Only release/nak/lease_expired
// cancel them explicitly.

@@system DhcpClient {
    interface:
        start()
        offer_received(server_ip: string, offered_ip: string, lease_sec: number)
        ack_received(ip: string, lease_sec: number)
        nak_received()
        t1_expired()
        t2_expired()
        lease_expired()
        release()
        status(): string

    machine:
        $Init {
            $>() {
                this.attempts = 0;
            }

            start() {
                -> $Selecting
            }
            status(): string { @@:("init") }
        }

        $Selecting {
            $>() {
                this.attempts = this.attempts + 1;
                this.broadcast_discover();
            }

            offer_received(server_ip: string, offered_ip: string, lease_sec: number) {
                this.server = server_ip;
                this.offered = offered_ip;
                this.lease_sec = lease_sec;
                -> $Requesting
            }
            status(): string { @@:("selecting") }
        }

        $Requesting {
            $>() {
                this.send_request();
            }

            ack_received(ip: string, lease_sec: number) {
                this.bound = ip;
                this.lease_sec = lease_sec;
                -> $Bound
            }
            nak_received() {
                -> $Init
            }
            status(): string { @@:("requesting") }
        }

        $Bound {
            $>() {
                this.arm_timers();
            }

            t1_expired() {
                -> $Renewing
            }
            release() {
                this.cancel_all_timers();
                this.send_release();
                -> $Init
            }
            status(): string { @@:("bound") }
        }

        $Renewing {
            $>() {
                this.send_renew();
            }

            ack_received(ip: string, lease_sec: number) {
                this.lease_sec = lease_sec;
                -> $Bound
            }
            nak_received() {
                this.cancel_all_timers();
                -> $Init
            }
            t2_expired() {
                -> $Rebinding
            }
            lease_expired() {
                this.cancel_all_timers();
                -> $Init
            }
            release() {
                this.cancel_all_timers();
                -> $Init
            }
            status(): string { @@:("renewing") }
        }

        $Rebinding {
            $>() {
                this.broadcast_renew();
            }

            ack_received(ip: string, lease_sec: number) {
                this.lease_sec = lease_sec;
                -> $Bound
            }
            nak_received() {
                this.cancel_all_timers();
                -> $Init
            }
            lease_expired() {
                this.cancel_all_timers();
                this.bound = "";
                -> $Init
            }
            release() {
                this.cancel_all_timers();
                -> $Init
            }
            status(): string { @@:("rebinding") }
        }

    actions:
        broadcast_discover()    {}
        send_request()          {}
        send_renew()            {}
        broadcast_renew()       {}
        send_release()          {}
        arm_timers()            {}
        cancel_all_timers()     {}

    domain:
        server: string = ""
        offered: string = ""
        bound: string = ""
        lease_sec: number = 0
        attempts: number = 0
}


function check(label: string, actual: string, expected: string): void {
    if (actual !== expected) {
        console.log(`FAIL: ${label} -- expected '${expected}', got '${actual}'`);
        throw new Error(`assertion failed: ${label}`);
    }
}

function test_full_lease_acquisition(): void {
    const dhcp = @@DhcpClient();
    check("initial init", dhcp.status(), "init");
    dhcp.start();
    check("selecting", dhcp.status(), "selecting");
    dhcp.offer_received("192.168.1.1", "192.168.1.100", 3600);
    check("requesting after offer", dhcp.status(), "requesting");
    dhcp.ack_received("192.168.1.100", 3600);
    check("bound", dhcp.status(), "bound");
    console.log("PASS: full lease acquisition Init->Selecting->Requesting->Bound");
}

function test_t1_triggers_renewal(): void {
    const dhcp = @@DhcpClient();
    dhcp.start();
    dhcp.offer_received("10.0.0.1", "10.0.0.100", 7200);
    dhcp.ack_received("10.0.0.100", 7200);
    dhcp.t1_expired();
    check("renewing after t1", dhcp.status(), "renewing");
    dhcp.ack_received("10.0.0.100", 7200);
    check("back to bound after renew ack", dhcp.status(), "bound");
    console.log("PASS: T1 triggers renewal, ACK returns to bound");
}

function test_t2_triggers_rebind(): void {
    const dhcp = @@DhcpClient();
    dhcp.start();
    dhcp.offer_received("10.0.0.1", "10.0.0.100", 7200);
    dhcp.ack_received("10.0.0.100", 7200);
    dhcp.t1_expired();
    check("renewing", dhcp.status(), "renewing");
    dhcp.t2_expired();
    check("rebinding after t2", dhcp.status(), "rebinding");
    dhcp.ack_received("10.0.0.100", 7200);
    check("rebind ACK -> bound", dhcp.status(), "bound");
    console.log("PASS: T2 triggers rebind, ACK returns to bound");
}

function test_nak_during_requesting_restarts(): void {
    const dhcp = @@DhcpClient();
    dhcp.start();
    dhcp.offer_received("10.0.0.1", "10.0.0.100", 7200);
    dhcp.nak_received();
    check("NAK in Requesting -> Init", dhcp.status(), "init");
    console.log("PASS: NAK in Requesting restarts");
}

function test_lease_expired_in_rebinding(): void {
    const dhcp = @@DhcpClient();
    dhcp.start();
    dhcp.offer_received("10.0.0.1", "10.0.0.100", 7200);
    dhcp.ack_received("10.0.0.100", 7200);
    dhcp.t1_expired();
    dhcp.t2_expired();
    dhcp.lease_expired();
    check("lease_expired in Rebinding -> Init", dhcp.status(), "init");
    console.log("PASS: lease expiry in rebinding clears state");
}

function test_release_from_bound(): void {
    const dhcp = @@DhcpClient();
    dhcp.start();
    dhcp.offer_received("10.0.0.1", "10.0.0.100", 7200);
    dhcp.ack_received("10.0.0.100", 7200);
    dhcp.release();
    check("release -> init", dhcp.status(), "init");
    console.log("PASS: release from bound");
}

test_full_lease_acquisition();
test_t1_triggers_renewal();
test_t2_triggers_rebind();
test_nak_during_requesting_restarts();
test_lease_expired_in_rebinding();
test_release_from_bound();
console.log("PASS: all DHCP client tests passed");

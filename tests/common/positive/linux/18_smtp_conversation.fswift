@@[target("swift")]

// SMTP Conversation -- RFC 5321 client state machine.

import Foundation

@@system SmtpClient {
    interface:
        tcp_connected()
        greeting_received(code: Int)
        ehlo_response(code: Int, supports_starttls: Bool)
        starttls()
        starttls_response(code: Int)
        tls_handshake_complete()
        mail_from(sender: String)
        mail_response(code: Int)
        rcpt_to(recipient: String)
        rcpt_response(code: Int)
        data()
        data_response(code: Int)
        data_body(body: String)
        data_final_response(code: Int)
        quit()
        quit_response(code: Int)
        status(): String
        recipient_count(): Int
        tls_on(): Bool

    machine:
        $Disconnected {
            tcp_connected() { -> $AwaitGreeting }
            status(): String { @@:("disconnected") }
            recipient_count(): Int { @@:(self.rcpt_count) }
            tls_on(): Bool { @@:(self.tls_active) }
        }

        $AwaitGreeting => $Connected {
            greeting_received(code: Int) {
                if code == 220 {
                    self.send_ehlo()
                    -> $AwaitEhlo
                } else {
                    -> $Disconnected
                }
            }
            status(): String { @@:("await greeting") }
            => $^
        }

        $AwaitEhlo => $Connected {
            ehlo_response(code: Int, supports_starttls: Bool) {
                if code == 250 {
                    self.server_supports_starttls = supports_starttls
                    -> $Ready
                } else {
                    -> $Disconnected
                }
            }
            status(): String { @@:("await ehlo") }
            => $^
        }

        $Ready => $Connected {
            starttls() {
                if self.server_supports_starttls {
                    if self.tls_active == false {
                        self.send_starttls()
                        -> $AwaitStartTlsResponse
                    }
                }
            }
            mail_from(sender: String) {
                self.sender = sender
                self.send_mail_from()
                -> $AwaitMailResponse
            }
            quit() {
                self.send_quit()
                -> $AwaitQuitResponse
            }
            status(): String { @@:("ready") }
            => $^
        }

        $AwaitStartTlsResponse => $Connected {
            starttls_response(code: Int) {
                if code == 220 {
                    -> $TlsHandshake
                } else {
                    -> $Ready
                }
            }
            status(): String { @@:("await starttls response") }
            => $^
        }

        $TlsHandshake => $Connected {
            tls_handshake_complete() {
                self.tls_active = true
                self.send_ehlo()
                -> $AwaitEhlo
            }
            status(): String { @@:("tls handshake") }
            => $^
        }

        $AwaitMailResponse => $Connected {
            mail_response(code: Int) {
                if code == 250 {
                    -> $AwaitRcpt
                } else {
                    -> $Ready
                }
            }
            status(): String { @@:("await mail response") }
            => $^
        }

        $AwaitRcpt => $Connected {
            rcpt_to(recipient: String) {
                self.rcpt_count = self.rcpt_count + 1
                self.send_rcpt_to()
                -> $AwaitRcptResponse
            }
            data() {
                if self.rcpt_count > 0 {
                    self.send_data()
                    -> $AwaitDataResponse
                }
            }
            status(): String { @@:("await rcpt") }
            => $^
        }

        $AwaitRcptResponse => $Connected {
            rcpt_response(code: Int) {
                -> $AwaitRcpt
            }
            status(): String { @@:("await rcpt response") }
            => $^
        }

        $AwaitDataResponse => $Connected {
            data_response(code: Int) {
                if code == 354 {
                    -> $SendingBody
                } else {
                    -> $Ready
                }
            }
            status(): String { @@:("await data response") }
            => $^
        }

        $SendingBody => $Connected {
            data_body(body: String) {
                self.send_body()
                self.send_body_terminator()
                -> $AwaitFinalResponse
            }
            status(): String { @@:("sending body") }
            => $^
        }

        $AwaitFinalResponse => $Connected {
            data_final_response(code: Int) {
                self.rcpt_count = 0
                -> $Ready
            }
            status(): String { @@:("await final response") }
            => $^
        }

        $AwaitQuitResponse => $Connected {
            quit_response(code: Int) {
                -> $Disconnected
            }
            status(): String { @@:("await quit response") }
            => $^
        }

        $Connected {
            recipient_count(): Int { @@:(self.rcpt_count) }
            tls_on(): Bool { @@:(self.tls_active) }
        }

    actions:
        send_ehlo()             {}
        send_starttls()         {}
        send_mail_from()        {}
        send_rcpt_to()          {}
        send_data()             {}
        send_body()             {}
        send_body_terminator()  {}
        send_quit()             {}

    domain:
        server_supports_starttls: Bool = false
        tls_active: Bool = false
        sender: String = ""
        rcpt_count: Int = 0
}


func check_str(_ label: String, _ actual: String, _ expected: String) {
    if actual != expected {
        print("FAIL: \(label) -- expected '\(expected)', got '\(actual)'")
        exit(1)
    }
}

func check_int(_ label: String, _ actual: Int, _ expected: Int) {
    if actual != expected {
        print("FAIL: \(label) -- expected \(expected), got \(actual)")
        exit(1)
    }
}

func check_bool(_ label: String, _ actual: Bool, _ expected: Bool) {
    if actual != expected {
        print("FAIL: \(label) -- expected \(expected), got \(actual)")
        exit(1)
    }
}

func test_basic_exchange_no_tls() {
    var smtp = @@SmtpClient()
    check_str("initial disconnected", smtp.status() as! String, "disconnected")
    _ = smtp.tcp_connected()
    check_str("await greeting", smtp.status() as! String, "await greeting")
    _ = smtp.greeting_received(220)
    check_str("await ehlo", smtp.status() as! String, "await ehlo")
    _ = smtp.ehlo_response(250, false)
    check_str("ready", smtp.status() as! String, "ready")
    check_bool("tls off", smtp.tls_on() as! Bool, false)
    print("PASS: basic TCP connect + EHLO")
}

func test_starttls_upgrade() {
    var smtp = @@SmtpClient()
    _ = smtp.tcp_connected()
    _ = smtp.greeting_received(220)
    _ = smtp.ehlo_response(250, true)
    _ = smtp.starttls()
    check_str("await starttls response", smtp.status() as! String, "await starttls response")
    _ = smtp.starttls_response(220)
    check_str("tls handshake", smtp.status() as! String, "tls handshake")
    _ = smtp.tls_handshake_complete()
    check_str("await ehlo after TLS", smtp.status() as! String, "await ehlo")
    _ = smtp.ehlo_response(250, true)
    check_str("back to ready", smtp.status() as! String, "ready")
    check_bool("tls on", smtp.tls_on() as! Bool, true)
    print("PASS: STARTTLS upgrade cycles through $AwaitEhlo")
}

func test_send_message_three_recipients() {
    var smtp = @@SmtpClient()
    _ = smtp.tcp_connected()
    _ = smtp.greeting_received(220)
    _ = smtp.ehlo_response(250, false)
    _ = smtp.mail_from("alice@example.com")
    check_str("await mail", smtp.status() as! String, "await mail response")
    _ = smtp.mail_response(250)
    _ = smtp.rcpt_to("bob@example.com")
    _ = smtp.rcpt_response(250)
    _ = smtp.rcpt_to("carol@example.com")
    _ = smtp.rcpt_response(250)
    _ = smtp.rcpt_to("dan@example.com")
    _ = smtp.rcpt_response(250)
    check_int("3 recipients", smtp.recipient_count() as! Int, 3)
    _ = smtp.data()
    check_str("await data response", smtp.status() as! String, "await data response")
    _ = smtp.data_response(354)
    _ = smtp.data_body("Subject: hi\r\n\r\nhello")
    _ = smtp.data_final_response(250)
    check_str("ready again", smtp.status() as! String, "ready")
    check_int("recipient count reset", smtp.recipient_count() as! Int, 0)
    print("PASS: send message with three recipients")
}

func test_quit() {
    var smtp = @@SmtpClient()
    _ = smtp.tcp_connected()
    _ = smtp.greeting_received(220)
    _ = smtp.ehlo_response(250, false)
    _ = smtp.quit()
    _ = smtp.quit_response(221)
    check_str("disconnected after QUIT", smtp.status() as! String, "disconnected")
    print("PASS: clean QUIT shutdown")
}

func test_greeting_reject() {
    var smtp = @@SmtpClient()
    _ = smtp.tcp_connected()
    _ = smtp.greeting_received(500)
    check_str("bad greeting -> disconnected", smtp.status() as! String, "disconnected")
    print("PASS: bad greeting drops connection")
}

func test_starttls_refused_if_not_supported() {
    var smtp = @@SmtpClient()
    _ = smtp.tcp_connected()
    _ = smtp.greeting_received(220)
    _ = smtp.ehlo_response(250, false)
    _ = smtp.starttls()
    check_str("still ready (starttls refused)", smtp.status() as! String, "ready")
    check_bool("tls still off", smtp.tls_on() as! Bool, false)
    print("PASS: starttls no-op when server doesn't support it")
}

func test_mail_rejection_returns_to_ready() {
    var smtp = @@SmtpClient()
    _ = smtp.tcp_connected()
    _ = smtp.greeting_received(220)
    _ = smtp.ehlo_response(250, false)
    _ = smtp.mail_from("bad@user")
    _ = smtp.mail_response(550)
    check_str("mail rejected -> ready", smtp.status() as! String, "ready")
    print("PASS: mail rejection returns to ready")
}

test_basic_exchange_no_tls()
test_starttls_upgrade()
test_send_message_three_recipients()
test_quit()
test_greeting_reject()
test_starttls_refused_if_not_supported()
test_mail_rejection_returns_to_ready()
print("PASS: all SMTP conversation tests passed")

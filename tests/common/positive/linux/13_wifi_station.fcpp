@@[target("cpp_17")]

// Wi-Fi Station Management -- IEEE 802.11 station state machine.

#include <iostream>
#include <cassert>
#include <cstdlib>

@@system WifiStation {
    interface:
        scan_done(bssid: std::string, ssid: std::string)
        auth_response(success: bool)
        assoc_response(success: bool, aid: int)
        eapol_key_msg(msg_num: int)
        deauth(reason: std::string)
        disassoc(reason: std::string)
        disconnect()
        status(): std::string
        key_step(): int

    machine:
        $Disconnected {
            scan_done(bssid: std::string, ssid: std::string) {
                this->bssid = bssid;
                this->ssid = ssid;
                -> $Authenticating
            }
            status(): std::string { @@:(std::string("disconnected")) }
            key_step(): int { @@:(0) }
        }

        $Authenticating => $Associated {
            $>() {
                this->send_auth_request();
            }

            auth_response(success: bool) {
                if (success) {
                    -> $Associating
                } else {
                    -> $Disconnected
                }
            }
            status(): std::string { @@:(std::string("authenticating")) }
            key_step(): int { @@:(0) }
            => $^
        }

        $Associating => $Associated {
            $>() {
                this->send_assoc_request();
            }

            assoc_response(success: bool, aid: int) {
                if (success) {
                    this->aid = aid;
                    -> $KeyNegotiation
                } else {
                    -> $Disconnected
                }
            }
            disassoc(reason: std::string) {
                -> $Authenticating
            }
            status(): std::string { @@:(std::string("associating")) }
            key_step(): int { @@:(0) }
            => $^
        }

        $KeyNegotiation => $Associated {
            $.step: int = 0

            eapol_key_msg(msg_num: int) {
                $.step = msg_num;
                if (msg_num == 4) {
                    -> $Connected
                }
            }
            disassoc(reason: std::string) {
                -> $Authenticating
            }
            status(): std::string { @@:(std::string("key negotiation")) }
            key_step(): int { @@:($.step) }
            => $^
        }

        $Associated {
            deauth(reason: std::string) {
                -> $Disconnected
            }
            disconnect() {
                this->send_deauth();
                -> $Disconnected
            }
        }

        $Connected {
            disassoc(reason: std::string) {
                -> $Authenticating
            }
            deauth(reason: std::string) {
                -> $Disconnected
            }
            disconnect() {
                this->send_deauth();
                -> $Disconnected
            }
            status(): std::string { @@:(std::string("connected")) }
            key_step(): int { @@:(4) }
        }

    actions:
        send_auth_request() {}
        send_assoc_request() {}
        send_deauth() {}

    domain:
        bssid: std::string = std::string("")
        ssid: std::string = std::string("")
        aid: int = 0
}


void check_str(const std::string& label, const std::string& actual, const std::string& expected) {
    if (actual != expected) {
        std::cout << "FAIL: " << label << " -- expected '" << expected << "', got '" << actual << "'" << std::endl;
        std::exit(1);
    }
}

void check_int(const std::string& label, int actual, int expected) {
    if (actual != expected) {
        std::cout << "FAIL: " << label << " -- expected " << expected << ", got " << actual << std::endl;
        std::exit(1);
    }
}

void test_happy_connect() {
    auto sta = @@WifiStation();
    check_str("initial disconnected", std::any_cast<std::string>(sta.status()), "disconnected");
    sta.scan_done(std::string("AA:BB:CC:DD:EE:FF"), std::string("MyNet"));
    check_str("authenticating", std::any_cast<std::string>(sta.status()), "authenticating");
    sta.auth_response(true);
    check_str("associating", std::any_cast<std::string>(sta.status()), "associating");
    sta.assoc_response(true, 1);
    check_str("key negotiation", std::any_cast<std::string>(sta.status()), "key negotiation");
    sta.eapol_key_msg(1);
    check_int("step 1", std::any_cast<int>(sta.key_step()), 1);
    sta.eapol_key_msg(2);
    check_int("step 2", std::any_cast<int>(sta.key_step()), 2);
    sta.eapol_key_msg(3);
    check_int("step 3", std::any_cast<int>(sta.key_step()), 3);
    sta.eapol_key_msg(4);
    check_str("connected", std::any_cast<std::string>(sta.status()), "connected");
    std::cout << "PASS: happy connect through 4-way handshake" << std::endl;
}

void test_auth_rejection() {
    auto sta = @@WifiStation();
    sta.scan_done(std::string("aa"), std::string("net"));
    sta.auth_response(false);
    check_str("auth rejected -> disconnected", std::any_cast<std::string>(sta.status()), "disconnected");
    std::cout << "PASS: auth rejection returns to disconnected" << std::endl;
}

void test_deauth_from_keynegotiation_via_hsm() {
    auto sta = @@WifiStation();
    sta.scan_done(std::string("aa"), std::string("net"));
    sta.auth_response(true);
    sta.assoc_response(true, 5);
    sta.eapol_key_msg(2);
    check_str("in key negotiation", std::any_cast<std::string>(sta.status()), "key negotiation");
    sta.deauth(std::string("AP restart"));
    check_str("deauth forwarded via HSM -> disconnected", std::any_cast<std::string>(sta.status()), "disconnected");
    std::cout << "PASS: deauth forwards via HSM parent from key negotiation" << std::endl;
}

void test_disassoc_drops_to_authenticating() {
    auto sta = @@WifiStation();
    sta.scan_done(std::string("aa"), std::string("net"));
    sta.auth_response(true);
    sta.assoc_response(true, 7);
    sta.eapol_key_msg(2);
    sta.disassoc(std::string("reason"));
    check_str("disassoc -> authenticating", std::any_cast<std::string>(sta.status()), "authenticating");
    sta.assoc_response(true, 7);
    check_int("step resets on reentry", std::any_cast<int>(sta.key_step()), 0);
    std::cout << "PASS: disassoc drops to authenticating (state var resets)" << std::endl;
}

void test_deauth_from_connected() {
    auto sta = @@WifiStation();
    sta.scan_done(std::string("aa"), std::string("net"));
    sta.auth_response(true);
    sta.assoc_response(true, 3);
    sta.eapol_key_msg(4);
    check_str("connected", std::any_cast<std::string>(sta.status()), "connected");
    sta.deauth(std::string("inactivity"));
    check_str("deauth from connected", std::any_cast<std::string>(sta.status()), "disconnected");
    std::cout << "PASS: deauth from connected returns to disconnected" << std::endl;
}

void test_disconnect_from_connected() {
    auto sta = @@WifiStation();
    sta.scan_done(std::string("aa"), std::string("net"));
    sta.auth_response(true);
    sta.assoc_response(true, 3);
    sta.eapol_key_msg(4);
    sta.disconnect();
    check_str("disconnect from connected", std::any_cast<std::string>(sta.status()), "disconnected");
    std::cout << "PASS: explicit disconnect from connected" << std::endl;
}

int main() {
    test_happy_connect();
    test_auth_rejection();
    test_deauth_from_keynegotiation_via_hsm();
    test_disassoc_drops_to_authenticating();
    test_deauth_from_connected();
    test_disconnect_from_connected();
    std::cout << "PASS: all Wi-Fi station tests passed" << std::endl;
    return 0;
}

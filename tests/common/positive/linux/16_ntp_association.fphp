@@[target("php")]

<?php

// NTP Client Association -- RFC 5905.

@@system NtpAssociation {
    operations:
        get_offset(): int { return $this->last_offset; }
        is_reachable(): bool { return $this->reach_register > 0; }

    interface:
        poll_tick()
        response_received(offset_ms: int, delay_ms: int)
        poll_timeout()
        status(): str
        poll_interval(): int
        reach(): int

    machine:
        $Unsynced {
            $>() {
                $this->poll_interval_v = $this->min_poll;
            }

            poll_tick() {
            }
            response_received(offset_ms: int, delay_ms: int) {
                $this->shift_reach_register(1);
                $this->last_offset = $offset_ms;
                $this->last_delay = $delay_ms;
                $this->good_responses = $this->good_responses + 1;
                if ($this->good_responses >= $this->sync_threshold) {
                    -> $Synced
                }
            }
            poll_timeout() {
                $this->shift_reach_register(0);
            }
            status(): str { @@:("unsynced") }
            poll_interval(): int { @@:($this->poll_interval_v) }
            reach(): int { @@:($this->reach_register) }
        }

        $Synced {
            poll_tick() {
            }
            response_received(offset_ms: int, delay_ms: int) {
                $this->shift_reach_register(1);
                $this->last_offset = $offset_ms;
                $this->last_delay = $delay_ms;
                if ($this->poll_interval_v < $this->max_poll) {
                    $this->poll_interval_v = $this->poll_interval_v * 2;
                }
            }
            poll_timeout() {
                $this->shift_reach_register(0);
                $this->consecutive_timeouts = $this->consecutive_timeouts + 1;
                if ($this->consecutive_timeouts >= 3) {
                    $this->consecutive_timeouts = 0;
                    $this->good_responses = 0;
                    -> $Unsynced
                }
                if ($this->poll_interval_v > $this->min_poll) {
                    $this->poll_interval_v = $this->poll_interval_v >> 1;
                }
            }
            status(): str { @@:("synced") }
            poll_interval(): int { @@:($this->poll_interval_v) }
            reach(): int { @@:($this->reach_register) }
        }

    actions:
        shift_reach_register(bit: int) {
            $this->reach_register = (($this->reach_register << 1) | $bit) & 0xFF;
            if ($bit != 0) {
                $this->consecutive_timeouts = 0;
            }
        }

    domain:
        poll_interval_v = 64
        min_poll = 64
        max_poll = 1024
        reach_register = 0
        last_offset = 0
        last_delay = 0
        good_responses = 0
        sync_threshold = 3
        consecutive_timeouts = 0
}


function check_value($label, $actual, $expected) {
    if ($actual !== $expected) {
        echo "FAIL: $label -- expected '" . var_export($expected, true) . "', got '" . var_export($actual, true) . "'\n";
        exit(1);
    }
}

function test_builds_to_sync() {
    $ntp = @@NtpAssociation();
    check_value("initial unsynced", $ntp->status(), "unsynced");
    $ntp->poll_tick();
    $ntp->response_received(12, 3);
    $ntp->poll_tick();
    $ntp->response_received(11, 2);
    check_value("not yet synced (2 good)", $ntp->status(), "unsynced");
    $ntp->poll_tick();
    $ntp->response_received(12, 3);
    check_value("synced after 3 good responses", $ntp->status(), "synced");
    echo "PASS: sync threshold reached after 3 good responses\n";
}

function test_poll_interval_backs_off() {
    $ntp = @@NtpAssociation();
    $ntp->poll_tick(); $ntp->response_received(10, 2);
    $ntp->poll_tick(); $ntp->response_received(10, 2);
    $ntp->poll_tick(); $ntp->response_received(10, 2);
    check_value("synced", $ntp->status(), "synced");
    check_value("interval at min (64)", $ntp->poll_interval(), 64);
    $ntp->poll_tick(); $ntp->response_received(10, 2);
    check_value("128 after 1 good in synced", $ntp->poll_interval(), 128);
    $ntp->poll_tick(); $ntp->response_received(10, 2);
    check_value("256 after 2 good", $ntp->poll_interval(), 256);
    echo "PASS: poll interval doubles on success in synced\n";
}

function test_timeout_shrinks_interval() {
    $ntp = @@NtpAssociation();
    $ntp->poll_tick(); $ntp->response_received(10, 2);
    $ntp->poll_tick(); $ntp->response_received(10, 2);
    $ntp->poll_tick(); $ntp->response_received(10, 2);
    $ntp->poll_tick(); $ntp->response_received(10, 2);
    check_value("interval 128", $ntp->poll_interval(), 128);
    $ntp->poll_tick(); $ntp->poll_timeout();
    check_value("timeout halves -> 64", $ntp->poll_interval(), 64);
    echo "PASS: timeout halves poll interval in synced\n";
}

function test_three_timeouts_drops_to_unsync() {
    $ntp = @@NtpAssociation();
    $ntp->poll_tick(); $ntp->response_received(10, 2);
    $ntp->poll_tick(); $ntp->response_received(10, 2);
    $ntp->poll_tick(); $ntp->response_received(10, 2);
    check_value("synced", $ntp->status(), "synced");
    $ntp->poll_tick(); $ntp->poll_timeout();
    $ntp->poll_tick(); $ntp->poll_timeout();
    check_value("still synced after 2 timeouts", $ntp->status(), "synced");
    $ntp->poll_tick(); $ntp->poll_timeout();
    check_value("3rd timeout drops to unsync", $ntp->status(), "unsynced");
    echo "PASS: three consecutive timeouts drop to unsync\n";
}

function test_reach_register_shifts() {
    $ntp = @@NtpAssociation();
    check_value("reach starts 0", $ntp->reach(), 0);
    $ntp->poll_tick();
    $ntp->response_received(10, 2);
    check_value("reach 0b00000001 = 1", $ntp->reach(), 1);
    $ntp->poll_tick();
    $ntp->response_received(10, 2);
    check_value("reach 0b00000011 = 3", $ntp->reach(), 3);
    $ntp->poll_tick();
    $ntp->poll_timeout();
    check_value("reach 0b00000110 = 6", $ntp->reach(), 6);
    echo "PASS: reach register shifts correctly\n";
}

function test_is_reachable_operation() {
    $ntp = @@NtpAssociation();
    check_value("initial not reachable", $ntp->is_reachable(), false);
    $ntp->poll_tick();
    $ntp->response_received(10, 2);
    check_value("after good response reachable", $ntp->is_reachable(), true);
    echo "PASS: is_reachable() operation query\n";
}

test_builds_to_sync();
test_poll_interval_backs_off();
test_timeout_shrinks_interval();
test_three_timeouts_drops_to_unsync();
test_reach_register_shifts();
test_is_reachable_operation();
echo "PASS: all NTP association tests passed\n";

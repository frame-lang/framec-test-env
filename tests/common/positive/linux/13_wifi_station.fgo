@@target go

// Wi-Fi Station Management -- IEEE 802.11 station state machine.

package main

import (
	"fmt"
	"os"
)

@@system WifiStation {
    interface:
        ScanDone(bssid: string, ssid: string)
        AuthResponse(success: bool)
        AssocResponse(success: bool, aid: int)
        EapolKeyMsg(msg_num: int)
        Deauth(reason: string)
        Disassoc(reason: string)
        Disconnect()
        Status(): string
        KeyStep(): int

    machine:
        $Disconnected {
            ScanDone(bssid: string, ssid: string) {
                s.bssid = bssid
                s.ssid = ssid
                -> $Authenticating
            }
            Status(): string { @@:("disconnected") }
            KeyStep(): int { @@:(0) }
        }

        $Authenticating => $Associated {
            $>() {
                s.send_auth_request()
            }

            AuthResponse(success: bool) {
                if success {
                    -> $Associating
                } else {
                    -> $Disconnected
                }
            }
            Status(): string { @@:("authenticating") }
            KeyStep(): int { @@:(0) }
            => $^
        }

        $Associating => $Associated {
            $>() {
                s.send_assoc_request()
            }

            AssocResponse(success: bool, aid: int) {
                if success {
                    s.aid = aid
                    -> $KeyNegotiation
                } else {
                    -> $Disconnected
                }
            }
            Disassoc(reason: string) {
                -> $Authenticating
            }
            Status(): string { @@:("associating") }
            KeyStep(): int { @@:(0) }
            => $^
        }

        $KeyNegotiation => $Associated {
            $.step: int = 0

            EapolKeyMsg(msg_num: int) {
                $.step = msg_num
                if msg_num == 4 {
                    -> $Connected
                }
            }
            Disassoc(reason: string) {
                -> $Authenticating
            }
            Status(): string { @@:("key negotiation") }
            KeyStep(): int { @@:($.step) }
            => $^
        }

        $Associated {
            Deauth(reason: string) {
                -> $Disconnected
            }
            Disconnect() {
                s.send_deauth()
                -> $Disconnected
            }
        }

        $Connected {
            Disassoc(reason: string) {
                -> $Authenticating
            }
            Deauth(reason: string) {
                -> $Disconnected
            }
            Disconnect() {
                s.send_deauth()
                -> $Disconnected
            }
            Status(): string { @@:("connected") }
            KeyStep(): int { @@:(4) }
        }

    actions:
        send_auth_request() {}
        send_assoc_request() {}
        send_deauth() {}

    domain:
        bssid: string = ""
        ssid: string = ""
        aid: int = 0
}


func check_str(label, actual, expected string) {
	if actual != expected {
		fmt.Printf("FAIL: %s -- expected '%s', got '%s'\n", label, expected, actual)
		os.Exit(1)
	}
}

func check_int(label string, actual, expected int) {
	if actual != expected {
		fmt.Printf("FAIL: %s -- expected %d, got %d\n", label, expected, actual)
		os.Exit(1)
	}
}

func test_happy_connect() {
	sta := NewWifiStation()
	check_str("initial disconnected", sta.Status(), "disconnected")
	sta.ScanDone("AA:BB:CC:DD:EE:FF", "MyNet")
	check_str("authenticating", sta.Status(), "authenticating")
	sta.AuthResponse(true)
	check_str("associating", sta.Status(), "associating")
	sta.AssocResponse(true, 1)
	check_str("key negotiation", sta.Status(), "key negotiation")
	sta.EapolKeyMsg(1)
	check_int("step 1", sta.KeyStep(), 1)
	sta.EapolKeyMsg(2)
	check_int("step 2", sta.KeyStep(), 2)
	sta.EapolKeyMsg(3)
	check_int("step 3", sta.KeyStep(), 3)
	sta.EapolKeyMsg(4)
	check_str("connected", sta.Status(), "connected")
	fmt.Println("PASS: happy connect through 4-way handshake")
}

func test_auth_rejection() {
	sta := NewWifiStation()
	sta.ScanDone("aa", "net")
	sta.AuthResponse(false)
	check_str("auth rejected -> disconnected", sta.Status(), "disconnected")
	fmt.Println("PASS: auth rejection returns to disconnected")
}

func test_deauth_from_keynegotiation_via_hsm() {
	sta := NewWifiStation()
	sta.ScanDone("aa", "net")
	sta.AuthResponse(true)
	sta.AssocResponse(true, 5)
	sta.EapolKeyMsg(2)
	check_str("in key negotiation", sta.Status(), "key negotiation")
	sta.Deauth("AP restart")
	check_str("deauth forwarded via HSM -> disconnected", sta.Status(), "disconnected")
	fmt.Println("PASS: deauth forwards via HSM parent from key negotiation")
}

func test_disassoc_drops_to_authenticating() {
	sta := NewWifiStation()
	sta.ScanDone("aa", "net")
	sta.AuthResponse(true)
	sta.AssocResponse(true, 7)
	sta.EapolKeyMsg(2)
	sta.Disassoc("reason")
	check_str("disassoc -> authenticating", sta.Status(), "authenticating")
	sta.AssocResponse(true, 7)
	check_int("step resets on reentry", sta.KeyStep(), 0)
	fmt.Println("PASS: disassoc drops to authenticating (state var resets)")
}

func test_deauth_from_connected() {
	sta := NewWifiStation()
	sta.ScanDone("aa", "net")
	sta.AuthResponse(true)
	sta.AssocResponse(true, 3)
	sta.EapolKeyMsg(4)
	check_str("connected", sta.Status(), "connected")
	sta.Deauth("inactivity")
	check_str("deauth from connected", sta.Status(), "disconnected")
	fmt.Println("PASS: deauth from connected returns to disconnected")
}

func test_disconnect_from_connected() {
	sta := NewWifiStation()
	sta.ScanDone("aa", "net")
	sta.AuthResponse(true)
	sta.AssocResponse(true, 3)
	sta.EapolKeyMsg(4)
	sta.Disconnect()
	check_str("disconnect from connected", sta.Status(), "disconnected")
	fmt.Println("PASS: explicit disconnect from connected")
}

func main() {
	test_happy_connect()
	test_auth_rejection()
	test_deauth_from_keynegotiation_via_hsm()
	test_disassoc_drops_to_authenticating()
	test_deauth_from_connected()
	test_disconnect_from_connected()
	fmt.Println("PASS: all Wi-Fi station tests passed")
}

@@[target("c")]

// Signal Handler Stack — textbook push$/pop$ use case.

#include <stdio.h>
#include <stdlib.h>
#include <string.h>

@@system SignalContext {
    interface:
        enter_user_code()
        signal_arrives(sig: str)
        handler_returns()
        current_mode(): str
        depth(): int
        current_signum(): str

    machine:
        $Kernel {
            enter_user_code() {
                -> $UserMode
            }
            current_mode(): str { @@:("kernel") }
            depth(): int { @@:(self->nesting) }
            current_signum(): str { @@:("") }
        }

        $UserMode {
            $.saved_regs: str = ""

            $>() {
                $.saved_regs = SignalContext_snapshot_registers(self);
            }

            signal_arrives(sig: str) {
                self->nesting = self->nesting + 1;
                push$
                -> (sig) $SignalHandler
            }
            current_mode(): str { @@:("user") }
            depth(): int { @@:(self->nesting) }
            current_signum(): str { @@:("") }
        }

        $SignalHandler {
            $.signum: str = ""

            $>(sig: str) {
                $.signum = sig;
            }

            signal_arrives(sig: str) {
                self->nesting = self->nesting + 1;
                push$
                -> (sig) $SignalHandler
            }

            handler_returns() {
                self->nesting = self->nesting - 1;
                -> pop$
            }

            current_mode(): str { @@:("handler") }
            depth(): int { @@:(self->nesting) }
            current_signum(): str { @@:($.signum) }
        }

    actions:
        snapshot_registers(): str {
            return "regs_snapshot";
        }

    domain:
        nesting: int = 0
}


void check_str(const char* label, const char* actual, const char* expected) {
    if (strcmp(actual, expected) != 0) {
        printf("FAIL: %s -- expected '%s', got '%s'\n", label, expected, actual);
        exit(1);
    }
}

void check_int(const char* label, int actual, int expected) {
    if (actual != expected) {
        printf("FAIL: %s -- expected %d, got %d\n", label, expected, actual);
        exit(1);
    }
}

void test_enter_user_mode(void) {
    SignalContext* cpu = @@SignalContext();
    check_str("initial kernel", (const char*)SignalContext_current_mode(cpu), "kernel");
    SignalContext_enter_user_code(cpu);
    check_str("in user mode", (const char*)SignalContext_current_mode(cpu), "user");
    check_int("depth 0", SignalContext_depth(cpu), 0);
    printf("PASS: enter user mode\n");
    SignalContext_destroy(cpu);
}

void test_single_signal_handler(void) {
    SignalContext* cpu = @@SignalContext();
    SignalContext_enter_user_code(cpu);
    SignalContext_signal_arrives(cpu, "SIGUSR1");
    check_str("in handler", (const char*)SignalContext_current_mode(cpu), "handler");
    check_str("signum SIGUSR1", (const char*)SignalContext_current_signum(cpu), "SIGUSR1");
    check_int("depth 1", SignalContext_depth(cpu), 1);
    SignalContext_handler_returns(cpu);
    check_str("back to user", (const char*)SignalContext_current_mode(cpu), "user");
    check_int("depth 0", SignalContext_depth(cpu), 0);
    printf("PASS: single signal handler + return\n");
    SignalContext_destroy(cpu);
}

void test_nested_signals(void) {
    SignalContext* cpu = @@SignalContext();
    SignalContext_enter_user_code(cpu);
    SignalContext_signal_arrives(cpu, "SIGUSR1");
    check_str("outer handler signum", (const char*)SignalContext_current_signum(cpu), "SIGUSR1");
    SignalContext_signal_arrives(cpu, "SIGALRM");
    check_str("inner handler signum", (const char*)SignalContext_current_signum(cpu), "SIGALRM");
    check_int("nested depth 2", SignalContext_depth(cpu), 2);
    SignalContext_handler_returns(cpu);
    check_str("popped to outer handler", (const char*)SignalContext_current_mode(cpu), "handler");
    check_str("outer signum preserved across pop", (const char*)SignalContext_current_signum(cpu), "SIGUSR1");
    check_int("depth 1", SignalContext_depth(cpu), 1);
    SignalContext_handler_returns(cpu);
    check_str("back to user", (const char*)SignalContext_current_mode(cpu), "user");
    check_int("depth 0", SignalContext_depth(cpu), 0);
    printf("PASS: nested signals (push$/pop$ preserves state vars)\n");
    SignalContext_destroy(cpu);
}

void test_deeply_nested_signals(void) {
    SignalContext* cpu = @@SignalContext();
    SignalContext_enter_user_code(cpu);
    SignalContext_signal_arrives(cpu, "SIG1");
    SignalContext_signal_arrives(cpu, "SIG2");
    SignalContext_signal_arrives(cpu, "SIG3");
    SignalContext_signal_arrives(cpu, "SIG4");
    check_int("depth 4", SignalContext_depth(cpu), 4);
    check_str("top signum", (const char*)SignalContext_current_signum(cpu), "SIG4");
    SignalContext_handler_returns(cpu);
    check_str("after pop 1: SIG3", (const char*)SignalContext_current_signum(cpu), "SIG3");
    SignalContext_handler_returns(cpu);
    check_str("after pop 2: SIG2", (const char*)SignalContext_current_signum(cpu), "SIG2");
    SignalContext_handler_returns(cpu);
    check_str("after pop 3: SIG1", (const char*)SignalContext_current_signum(cpu), "SIG1");
    SignalContext_handler_returns(cpu);
    check_str("back to user", (const char*)SignalContext_current_mode(cpu), "user");
    printf("PASS: 4-deep nested signal stack\n");
    SignalContext_destroy(cpu);
}

int main(void) {
    test_enter_user_mode();
    test_single_signal_handler();
    test_nested_signals();
    test_deeply_nested_signals();
    printf("PASS: all signal handler stack tests passed\n");
    return 0;
}

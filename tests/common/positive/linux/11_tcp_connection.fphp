@@[target("php")]

<?php

// TCP Connection -- RFC 793 Figure 6 FSM with @@persist for TIME_WAIT.

@@[persist(string)]
@@[save(save_state)]
@@[load(restore_state)]
@@system TcpConnection {
    interface:
        passive_open()
        active_open()
        recv_syn()
        recv_syn_ack()
        recv_ack()
        recv_fin()
        app_close()
        app_send(bytes_n: int)
        timeout_2msl()
        abort()
        state_name(): str

    machine:
        $Closed {
            passive_open() { -> $Listen }
            active_open() {
                $this->send_syn();
                -> $SynSent
            }
            state_name(): str { @@:("CLOSED") }
        }

        $Listen {
            recv_syn() {
                $this->send_syn_ack();
                -> $SynReceived
            }
            app_close() { -> $Closed }
            state_name(): str { @@:("LISTEN") }
        }

        $SynSent {
            recv_syn_ack() {
                $this->send_ack();
                -> $Established
            }
            recv_syn() {
                $this->send_syn_ack();
                -> $SynReceived
            }
            app_close() { -> $Closed }
            state_name(): str { @@:("SYN_SENT") }
        }

        $SynReceived {
            recv_ack() { -> $Established }
            app_close() {
                $this->send_fin();
                -> $FinWait1
            }
            state_name(): str { @@:("SYN_RECEIVED") }
        }

        $Established {
            app_send(bytes_n: int) {
                $this->bytes_sent = $this->bytes_sent + $bytes_n;
            }
            app_close() {
                $this->send_fin();
                -> $FinWait1
            }
            recv_fin() {
                $this->send_ack();
                -> $CloseWait
            }
            abort() {
                $this->send_rst();
                -> $Closed
            }
            state_name(): str { @@:("ESTABLISHED") }
        }

        $FinWait1 {
            recv_ack() { -> $FinWait2 }
            recv_fin() {
                $this->send_ack();
                -> $Closing
            }
            state_name(): str { @@:("FIN_WAIT_1") }
        }

        $FinWait2 {
            recv_fin() {
                $this->send_ack();
                -> $TimeWait
            }
            state_name(): str { @@:("FIN_WAIT_2") }
        }

        $Closing {
            recv_ack() { -> $TimeWait }
            state_name(): str { @@:("CLOSING") }
        }

        $TimeWait {
            $>() {
                $this->start_2msl_timer();
            }
            timeout_2msl() { -> $Closed }
            state_name(): str { @@:("TIME_WAIT") }
        }

        $CloseWait {
            app_close() {
                $this->send_fin();
                -> $LastAck
            }
            state_name(): str { @@:("CLOSE_WAIT") }
        }

        $LastAck {
            recv_ack() { -> $Closed }
            state_name(): str { @@:("LAST_ACK") }
        }

    actions:
        send_syn()         {}
        send_syn_ack()     {}
        send_ack()         {}
        send_fin()         {}
        send_rst()         {}
        start_2msl_timer() {}

    domain:
        local_port = 0
        remote_port = 0
        bytes_sent = 0
}


function check_value($label, $actual, $expected) {
    if ($actual !== $expected) {
        echo "FAIL: $label -- expected '$expected', got '$actual'\n";
        exit(1);
    }
}

function test_active_open_full_cycle() {
    $c = @@TcpConnection();
    check_value("initial CLOSED", $c->state_name(), "CLOSED");
    $c->active_open();
    check_value("SYN_SENT", $c->state_name(), "SYN_SENT");
    $c->recv_syn_ack();
    check_value("ESTABLISHED", $c->state_name(), "ESTABLISHED");
    $c->app_send(1024);
    $c->app_close();
    check_value("FIN_WAIT_1", $c->state_name(), "FIN_WAIT_1");
    $c->recv_ack();
    check_value("FIN_WAIT_2", $c->state_name(), "FIN_WAIT_2");
    $c->recv_fin();
    check_value("TIME_WAIT", $c->state_name(), "TIME_WAIT");
    $c->timeout_2msl();
    check_value("back to CLOSED", $c->state_name(), "CLOSED");
    echo "PASS: active open, full cycle to TIME_WAIT\n";
}

function test_passive_open_full_cycle() {
    $c = @@TcpConnection();
    $c->passive_open();
    check_value("LISTEN", $c->state_name(), "LISTEN");
    $c->recv_syn();
    check_value("SYN_RECEIVED", $c->state_name(), "SYN_RECEIVED");
    $c->recv_ack();
    check_value("ESTABLISHED", $c->state_name(), "ESTABLISHED");
    $c->recv_fin();
    check_value("CLOSE_WAIT", $c->state_name(), "CLOSE_WAIT");
    $c->app_close();
    check_value("LAST_ACK", $c->state_name(), "LAST_ACK");
    $c->recv_ack();
    check_value("CLOSED", $c->state_name(), "CLOSED");
    echo "PASS: passive open, peer-initiated close\n";
}

function test_simultaneous_close() {
    $c = @@TcpConnection();
    $c->active_open();
    $c->recv_syn_ack();
    $c->app_close();
    check_value("in FIN_WAIT_1", $c->state_name(), "FIN_WAIT_1");
    $c->recv_fin();
    check_value("CLOSING (simultaneous)", $c->state_name(), "CLOSING");
    $c->recv_ack();
    check_value("TIME_WAIT after CLOSING ACK", $c->state_name(), "TIME_WAIT");
    echo "PASS: simultaneous close -> CLOSING -> TIME_WAIT\n";
}

function test_abort_from_established() {
    $c = @@TcpConnection();
    $c->active_open();
    $c->recv_syn_ack();
    $c->abort();
    check_value("RST drops to CLOSED", $c->state_name(), "CLOSED");
    echo "PASS: abort sends RST and returns to CLOSED\n";
}

function test_persist_across_restart() {
    $c = @@TcpConnection();
    $c->active_open();
    $c->recv_syn_ack();
    $c->app_send(2048);
    $c->app_close();
    $c->recv_ack();
    $c->recv_fin();
    check_value("TIME_WAIT before persist", $c->state_name(), "TIME_WAIT");
    $snap = $c->save_state();
    $c2 = new TcpConnection();

    $c2->restore_state($snap);
    check_value("TIME_WAIT restored", $c2->state_name(), "TIME_WAIT");
    $c2->timeout_2msl();
    check_value("CLOSED after 2MSL", $c2->state_name(), "CLOSED");
    echo "PASS: @@persist survives simulated restart in TIME_WAIT\n";
}

test_active_open_full_cycle();
test_passive_open_full_cycle();
test_simultaneous_close();
test_abort_from_established();
test_persist_across_restart();
echo "PASS: all TCP connection tests passed\n";

@@target typescript

// Filesystem Freeze — VFS fs/super.c semantics. 3-level HSM:
//   $Active => $Readable => $Mounted
//   $Frozen => $Readable => $Mounted
// $Mounted provides read/sync/unmount for all mounted sub-states.
// $Active adds write/freeze. $Frozen overrides write to block and adds thaw.
// $Freezing is transient, bypasses $Readable (state in flux during flush).

@@system Filesystem {
    interface:
        mount(device: string): string
        unmount(): string
        freeze(): string
        thaw(): string
        write(data: string): string
        read(): string
        sync(): string
        status(): string
        read_count(): number
        write_count(): number

    machine:
        $Unmounted {
            mount(device: string): string {
                this.device = device;
                @@:("mounted")
                -> $Active
            }
            status(): string { @@:("unmounted") }
            read_count(): number { @@:(this.reads) }
            write_count(): number { @@:(this.writes) }
        }

        $Active => $Readable {
            write(data: string): string {
                this.writes = this.writes + 1;
                @@:("wrote")
            }
            freeze(): string {
                @@:("freezing")
                -> $Freezing
            }
            status(): string { @@:("active") }
            => $^
        }

        $Freezing => $Mounted {
            $>() {
                this.flush_pending_writes();
                -> $Frozen
            }
            status(): string { @@:("freezing") }
            => $^
        }

        $Frozen => $Readable {
            write(data: string): string {
                @@:("BLOCKED")
            }
            thaw(): string {
                @@:("thawed")
                -> $Active
            }
            status(): string { @@:("frozen") }
            => $^
        }

        $Readable => $Mounted {
            => $^
        }

        $Mounted {
            read(): string {
                this.reads = this.reads + 1;
                @@:("read")
            }
            sync(): string {
                @@:("synced")
            }
            unmount(): string {
                @@:("unmounting")
                -> $Unmounting
            }
            read_count(): number { @@:(this.reads) }
            write_count(): number { @@:(this.writes) }
        }

        $Unmounting {
            $>() {
                this.flush_pending_writes();
                this.release_resources();
                -> $Unmounted
            }
        }

    actions:
        flush_pending_writes() {}
        release_resources() {}

    domain:
        device: string = ""
        writes: number = 0
        reads: number = 0
}


function check(label: string, actual: any, expected: any): void {
    if (actual !== expected) {
        console.log(`FAIL: ${label} — expected '${expected}', got '${actual}'`);
        throw new Error(`assertion failed: ${label}`);
    }
}

function test_mount_write_read(): void {
    const fs = @@Filesystem();
    check("initial unmounted", fs.status(), "unmounted");
    check("mount", fs.mount("/dev/sda1"), "mounted");
    check("active state", fs.status(), "active");
    check("write 1", fs.write("hello"), "wrote");
    check("read 1", fs.read(), "read");
    check("sync via HSM", fs.sync(), "synced");
    check("read count incremented", fs.read_count(), 1);
    check("write count incremented", fs.write_count(), 1);
    console.log("PASS: mount + write + read + sync");
}

function test_freeze_blocks_writes_allows_reads(): void {
    const fs = @@Filesystem();
    fs.mount("/dev/sda1");
    fs.write("before freeze");
    fs.freeze();
    check("in frozen state", fs.status(), "frozen");
    check("write blocked", fs.write("nope"), "BLOCKED");
    check("read still works", fs.read(), "read");
    check("read count 1", fs.read_count(), 1);
    check("write count unchanged", fs.write_count(), 1);
    console.log("PASS: freeze blocks writes, allows reads (3-level HSM)");
}

function test_thaw_restores_write(): void {
    const fs = @@Filesystem();
    fs.mount("/dev/sda1");
    fs.freeze();
    check("thaw", fs.thaw(), "thawed");
    check("back to active", fs.status(), "active");
    check("write works again", fs.write("post-thaw"), "wrote");
    console.log("PASS: thaw restores write capability");
}

function test_unmount_forwards_via_hsm(): void {
    const fs = @@Filesystem();
    fs.mount("/dev/sda1");
    check("unmount from Active", fs.unmount(), "unmounting");
    check("eventually unmounted", fs.status(), "unmounted");
    console.log("PASS: unmount forwards from Active via $Readable to $Mounted");
}

function test_freeze_impossible_when_unmounted(): void {
    const fs = @@Filesystem();
    check("freeze unmounted = no-op (no handler)",
          fs.freeze(), null);
    check("still unmounted", fs.status(), "unmounted");
    console.log("PASS: freeze on unmounted fs is no-op");
}

function test_read_count_accumulates_across_states(): void {
    const fs = @@Filesystem();
    fs.mount("/dev/sda1");
    fs.read();
    fs.read();
    fs.freeze();
    fs.read();
    fs.thaw();
    fs.read();
    check("reads across Active/Frozen/Active",
          fs.read_count(), 4);
    console.log("PASS: read count spans states (domain var)");
}

test_mount_write_read();
test_freeze_blocks_writes_allows_reads();
test_thaw_restores_write();
test_unmount_forwards_via_hsm();
test_freeze_impossible_when_unmounted();
test_read_count_accumulates_across_states();
console.log("PASS: all filesystem freeze tests passed");

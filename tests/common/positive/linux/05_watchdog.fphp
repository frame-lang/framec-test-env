@@target php

<?php

// Watchdog Timer — kernel drivers/watchdog/watchdog_dev.c magic-close semantics.

@@system WatchdogDevice {
    interface:
        open(): str
        write(data: str): str
        ping(): str
        close(): str
        timeout_expired(): str
        status(): str

    machine:
        $Inactive {
            open(): str {
                @@:("opened")
                -> $Armed
            }
            status(): str { @@:("inactive") }
        }

        $Armed {
            $>() {
                $this->magic_seen = false;
                $this->start_hw_timer();
            }

            ping(): str {
                $this->reset_hw_timer();
                @@:("pinged")
            }
            write(data: str): str {
                if (str_contains($data, "V")) {
                    $this->magic_seen = true;
                    @@:("magic character received")
                } else {
                    @@:("data written")
                }
                $this->reset_hw_timer();
            }
            close(): str {
                if ($this->magic_seen) {
                    $this->stop_hw_timer();
                    @@:("disarmed")
                    -> $Inactive
                } else {
                    @@:("close ignored -- no magic char")
                }
            }
            timeout_expired(): str {
                @@:("SYSTEM RESET")
                -> $Triggered
            }
            status(): str {
                if ($this->magic_seen) {
                    @@:("armed (magic seen, close will disarm)")
                } else {
                    @@:("armed")
                }
            }
        }

        $Triggered {
            status(): str { @@:("triggered -- system reset") }
        }

    actions:
        start_hw_timer() {}
        reset_hw_timer() {}
        stop_hw_timer() {}

    domain:
        timeout_sec = 60
        magic_seen = false
}


function check_value($label, $actual, $expected) {
    if ($actual !== $expected) {
        echo "FAIL: $label — expected '$expected', got '$actual'\n";
        exit(1);
    }
}

function test_open_and_ping() {
    $wd = @@WatchdogDevice();
    check_value("initial inactive", $wd->status(), "inactive");
    check_value("open returns opened", $wd->open(), "opened");
    check_value("armed after open", $wd->status(), "armed");
    check_value("ping", $wd->ping(), "pinged");
    check_value("still armed after ping", $wd->status(), "armed");
    echo "PASS: open and ping\n";
}

function test_close_without_magic_is_ignored() {
    $wd = @@WatchdogDevice();
    $wd->open();
    check_value("close without magic", $wd->close(), "close ignored -- no magic char");
    check_value("still armed after bad close", $wd->status(), "armed");
    echo "PASS: close without magic ignored (safety property)\n";
}

function test_magic_char_then_close_disarms() {
    $wd = @@WatchdogDevice();
    $wd->open();
    check_value("write with V sets magic", $wd->write("goodbye V"), "magic character received");
    check_value("status shows magic seen", $wd->status(), "armed (magic seen, close will disarm)");
    check_value("close after magic disarms", $wd->close(), "disarmed");
    check_value("back to inactive", $wd->status(), "inactive");
    echo "PASS: magic char then close disarms\n";
}

function test_write_without_magic_is_plain_data() {
    $wd = @@WatchdogDevice();
    $wd->open();
    check_value("write without V", $wd->write("abcdef"), "data written");
    check_value("still armed with no magic", $wd->status(), "armed");
    echo "PASS: write without magic is plain data\n";
}

function test_timeout_triggers_reset() {
    $wd = @@WatchdogDevice();
    $wd->open();
    check_value("timeout fires", $wd->timeout_expired(), "SYSTEM RESET");
    check_value("terminal triggered state", $wd->status(), "triggered -- system reset");
    echo "PASS: timeout triggers system reset\n";
}

function test_reopen_resets_magic_seen() {
    $wd = @@WatchdogDevice();
    $wd->open();
    $wd->write("set V please");
    $wd->close();
    $wd->open();
    check_value("magic_seen reset on reopen", $wd->close(), "close ignored -- no magic char");
    echo "PASS: reopen resets magic_seen via enter handler\n";
}

test_open_and_ping();
test_close_without_magic_is_ignored();
test_magic_char_then_close_disarms();
test_write_without_magic_is_plain_data();
test_timeout_triggers_reset();
test_reopen_resets_magic_seen();
echo "PASS: all watchdog tests passed\n";

@@target lua

-- USB Device Enumeration — multi-stage pipeline with compensation (saga).

@@system UsbEnumerator {
    interface:
        plug_in(port: int)
        reset_done(success: bool)
        address_set(success: bool, addr: int)
        descriptors_read(success: bool, product: str)
        driver_bound(success: bool)
        unplug()
        status(): str

    machine:
        $Detached {
            plug_in(port: int) {
                self.port = port
                self.reset_attempts = 0
                -> $Resetting
            }
            status(): str { @@:("detached") }
        }

        $Resetting => $Enumerating {
            $>() {
                self.reset_attempts = self.reset_attempts + 1
                self:issue_port_reset(self.port)
            }

            reset_done(success: bool) {
                if success then
                    -> $Addressing
                else
                    if self.reset_attempts < self.max_reset_attempts then
                        -> $Resetting
                    else
                        -> $Failed
                    end
                end
            }
            status(): str { @@:("resetting") }
            => $^
        }

        $Addressing => $Enumerating {
            $>() {
                self:assign_address()
            }

            address_set(success: bool, addr: int) {
                if success then
                    self.address = addr
                    -> $ReadingDescriptors
                else
                    -> $UndoReset
                end
            }
            status(): str { @@:("addressing") }
            => $^
        }

        $ReadingDescriptors => $Enumerating {
            $>() {
                self:read_descriptors(self.address)
            }

            descriptors_read(success: bool, product: str) {
                if success then
                    self.product = product
                    -> $BindingDriver
                else
                    -> $UndoAddress
                end
            }
            status(): str { @@:("reading descriptors") }
            => $^
        }

        $BindingDriver => $Enumerating {
            $>() {
                self:bind_driver(self.product)
            }

            driver_bound(success: bool) {
                if success then
                    -> $Configured
                else
                    -> $UndoAddress
                end
            }
            status(): str { @@:("binding driver") }
            => $^
        }

        $Enumerating {
            unplug() {
                -> $Detached
            }
        }

        $UndoAddress {
            $>() {
                self:release_address(self.address)
                -> $UndoReset
            }
        }

        $UndoReset {
            $>() {
                self:disable_port(self.port)
                -> $Failed
            }
        }

        $Configured {
            unplug() {
                self:unbind_driver()
                self:release_address(self.address)
                self:disable_port(self.port)
                -> $Detached
            }
            status(): str { @@:("configured") }
        }

        $Failed {
            plug_in(port: int) {
                self.port = port
                self.reset_attempts = 0
                -> $Resetting
            }
            status(): str { @@:("failed") }
        }

    actions:
        issue_port_reset(port) {}
        assign_address() {}
        read_descriptors(addr) {}
        bind_driver(product) {}
        release_address(addr) {}
        disable_port(port) {}
        unbind_driver() {}

    domain:
        port: int = 0
        address: int = 0
        product: str = ""
        reset_attempts: int = 0
        max_reset_attempts: int = 3
}


local function check(label, actual, expected)
    if actual ~= expected then
        print("FAIL: " .. label .. " — expected '" .. tostring(expected) .. "', got '" .. tostring(actual) .. "'")
        os.exit(1)
    end
end

local function test_happy_path()
    local usb = @@UsbEnumerator()
    check("initial detached", usb:status(), "detached")
    usb:plug_in(1)
    check("after plug_in", usb:status(), "resetting")
    usb:reset_done(true)
    check("reset ok -> addressing", usb:status(), "addressing")
    usb:address_set(true, 7)
    check("address ok -> reading", usb:status(), "reading descriptors")
    usb:descriptors_read(true, "USB Keyboard")
    check("descriptors ok -> binding", usb:status(), "binding driver")
    usb:driver_bound(true)
    check("driver bound -> configured", usb:status(), "configured")
    print("PASS: happy path enumeration")
end

local function test_descriptor_failure_compensates()
    local usb = @@UsbEnumerator()
    usb:plug_in(2)
    usb:reset_done(true)
    usb:address_set(true, 8)
    usb:descriptors_read(false, "")
    check("compensated to failed", usb:status(), "failed")
    print("PASS: descriptor failure compensation")
end

local function test_driver_bind_failure_compensates()
    local usb = @@UsbEnumerator()
    usb:plug_in(3)
    usb:reset_done(true)
    usb:address_set(true, 9)
    usb:descriptors_read(true, "Mouse")
    usb:driver_bound(false)
    check("bind fail compensated to failed", usb:status(), "failed")
    print("PASS: driver bind failure compensation")
end

local function test_unplug_during_enumeration()
    local usb = @@UsbEnumerator()
    usb:plug_in(4)
    check("in resetting", usb:status(), "resetting")
    usb:unplug()
    check("unplug -> detached", usb:status(), "detached")
    print("PASS: unplug during enumeration forwards via HSM")
end

local function test_reset_retry_then_exhaust()
    local usb = @@UsbEnumerator()
    usb:plug_in(5)
    usb:reset_done(false)
    check("retry 1", usb:status(), "resetting")
    usb:reset_done(false)
    check("retry 2", usb:status(), "resetting")
    usb:reset_done(false)
    check("exhausted -> failed", usb:status(), "failed")
    print("PASS: reset retry exhaustion")
end

local function test_replug_from_failed()
    local usb = @@UsbEnumerator()
    usb:plug_in(6)
    usb:reset_done(false)
    usb:reset_done(false)
    usb:reset_done(false)
    check("failed state", usb:status(), "failed")
    usb:plug_in(6)
    check("re-plug restarts enumeration", usb:status(), "resetting")
    print("PASS: re-plug from failed state")
end

test_happy_path()
test_descriptor_failure_compensates()
test_driver_bind_failure_compensates()
test_unplug_during_enumeration()
test_reset_retry_then_exhaust()
test_replug_from_failed()
print("PASS: all USB enumeration tests passed")

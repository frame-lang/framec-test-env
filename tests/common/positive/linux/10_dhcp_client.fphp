@@[target("php")]


// DHCP Client -- RFC 2131 Figure 5 state machine.

@@system DhcpClient {
    interface:
        start()
        offer_received(server_ip: str, offered_ip: str, lease_sec: int)
        ack_received(ip: str, lease_sec: int)
        nak_received()
        t1_expired()
        t2_expired()
        lease_expired()
        release()
        status(): str

    machine:
        $Init {
            $>() {
                $this->attempts = 0;
            }

            start() {
                -> $Selecting
            }
            status(): str { @@:("init") }
        }

        $Selecting {
            $>() {
                $this->attempts = $this->attempts + 1;
                $this->broadcast_discover();
            }

            offer_received(server_ip: str, offered_ip: str, lease_sec: int) {
                $this->server = $server_ip;
                $this->offered = $offered_ip;
                $this->lease_sec = $lease_sec;
                -> $Requesting
            }
            status(): str { @@:("selecting") }
        }

        $Requesting {
            $>() {
                $this->send_request();
            }

            ack_received(ip: str, lease_sec: int) {
                $this->bound = $ip;
                $this->lease_sec = $lease_sec;
                -> $Bound
            }
            nak_received() {
                -> $Init
            }
            status(): str { @@:("requesting") }
        }

        $Bound {
            $>() {
                $this->arm_timers();
            }

            t1_expired() {
                -> $Renewing
            }
            release() {
                $this->cancel_all_timers();
                $this->send_release();
                -> $Init
            }
            status(): str { @@:("bound") }
        }

        $Renewing {
            $>() {
                $this->send_renew();
            }

            ack_received(ip: str, lease_sec: int) {
                $this->lease_sec = $lease_sec;
                -> $Bound
            }
            nak_received() {
                $this->cancel_all_timers();
                -> $Init
            }
            t2_expired() {
                -> $Rebinding
            }
            lease_expired() {
                $this->cancel_all_timers();
                -> $Init
            }
            release() {
                $this->cancel_all_timers();
                -> $Init
            }
            status(): str { @@:("renewing") }
        }

        $Rebinding {
            $>() {
                $this->broadcast_renew();
            }

            ack_received(ip: str, lease_sec: int) {
                $this->lease_sec = $lease_sec;
                -> $Bound
            }
            nak_received() {
                $this->cancel_all_timers();
                -> $Init
            }
            lease_expired() {
                $this->cancel_all_timers();
                $this->bound = "";
                -> $Init
            }
            release() {
                $this->cancel_all_timers();
                -> $Init
            }
            status(): str { @@:("rebinding") }
        }

    actions:
        broadcast_discover()    {}
        send_request()          {}
        send_renew()            {}
        broadcast_renew()       {}
        send_release()          {}
        arm_timers()            {}
        cancel_all_timers()     {}

    domain:
        server = ""
        offered = ""
        bound = ""
        lease_sec = 0
        attempts = 0
}


function check_value($label, $actual, $expected) {
    if ($actual !== $expected) {
        echo "FAIL: $label -- expected '$expected', got '$actual'\n";
        exit(1);
    }
}

function test_full_lease_acquisition() {
    $dhcp = @@DhcpClient();
    check_value("initial init", $dhcp->status(), "init");
    $dhcp->start();
    check_value("selecting", $dhcp->status(), "selecting");
    $dhcp->offer_received("192.168.1.1", "192.168.1.100", 3600);
    check_value("requesting after offer", $dhcp->status(), "requesting");
    $dhcp->ack_received("192.168.1.100", 3600);
    check_value("bound", $dhcp->status(), "bound");
    echo "PASS: full lease acquisition Init->Selecting->Requesting->Bound\n";
}

function test_t1_triggers_renewal() {
    $dhcp = @@DhcpClient();
    $dhcp->start();
    $dhcp->offer_received("10.0.0.1", "10.0.0.100", 7200);
    $dhcp->ack_received("10.0.0.100", 7200);
    $dhcp->t1_expired();
    check_value("renewing after t1", $dhcp->status(), "renewing");
    $dhcp->ack_received("10.0.0.100", 7200);
    check_value("back to bound after renew ack", $dhcp->status(), "bound");
    echo "PASS: T1 triggers renewal, ACK returns to bound\n";
}

function test_t2_triggers_rebind() {
    $dhcp = @@DhcpClient();
    $dhcp->start();
    $dhcp->offer_received("10.0.0.1", "10.0.0.100", 7200);
    $dhcp->ack_received("10.0.0.100", 7200);
    $dhcp->t1_expired();
    check_value("renewing", $dhcp->status(), "renewing");
    $dhcp->t2_expired();
    check_value("rebinding after t2", $dhcp->status(), "rebinding");
    $dhcp->ack_received("10.0.0.100", 7200);
    check_value("rebind ACK -> bound", $dhcp->status(), "bound");
    echo "PASS: T2 triggers rebind, ACK returns to bound\n";
}

function test_nak_during_requesting_restarts() {
    $dhcp = @@DhcpClient();
    $dhcp->start();
    $dhcp->offer_received("10.0.0.1", "10.0.0.100", 7200);
    $dhcp->nak_received();
    check_value("NAK in Requesting -> Init", $dhcp->status(), "init");
    echo "PASS: NAK in Requesting restarts\n";
}

function test_lease_expired_in_rebinding() {
    $dhcp = @@DhcpClient();
    $dhcp->start();
    $dhcp->offer_received("10.0.0.1", "10.0.0.100", 7200);
    $dhcp->ack_received("10.0.0.100", 7200);
    $dhcp->t1_expired();
    $dhcp->t2_expired();
    $dhcp->lease_expired();
    check_value("lease_expired in Rebinding -> Init", $dhcp->status(), "init");
    echo "PASS: lease expiry in rebinding clears state\n";
}

function test_release_from_bound() {
    $dhcp = @@DhcpClient();
    $dhcp->start();
    $dhcp->offer_received("10.0.0.1", "10.0.0.100", 7200);
    $dhcp->ack_received("10.0.0.100", 7200);
    $dhcp->release();
    check_value("release -> init", $dhcp->status(), "init");
    echo "PASS: release from bound\n";
}

test_full_lease_acquisition();
test_t1_triggers_renewal();
test_t2_triggers_rebind();
test_nak_during_requesting_restarts();
test_lease_expired_in_rebinding();
test_release_from_bound();
echo "PASS: all DHCP client tests passed\n";

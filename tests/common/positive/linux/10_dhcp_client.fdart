@@[target("dart")]

// DHCP Client -- RFC 2131 Figure 5 state machine.

import 'dart:io';

@@system DhcpClient {
    interface:
        start()
        offer_received(server_ip: String, offered_ip: String, lease_sec: int)
        ack_received(ip: String, lease_sec: int)
        nak_received()
        t1_expired()
        t2_expired()
        lease_expired()
        release()
        status(): String

    machine:
        $Init {
            $>() {
                this.attempts = 0;
            }

            start() {
                -> $Selecting
            }
            status(): String { @@:("init") }
        }

        $Selecting {
            $>() {
                this.attempts = this.attempts + 1;
                this.broadcast_discover();
            }

            offer_received(server_ip: String, offered_ip: String, lease_sec: int) {
                this.server = server_ip;
                this.offered = offered_ip;
                this.lease_sec = lease_sec;
                -> $Requesting
            }
            status(): String { @@:("selecting") }
        }

        $Requesting {
            $>() {
                this.send_request();
            }

            ack_received(ip: String, lease_sec: int) {
                this.bound = ip;
                this.lease_sec = lease_sec;
                -> $Bound
            }
            nak_received() {
                -> $Init
            }
            status(): String { @@:("requesting") }
        }

        $Bound {
            $>() {
                this.arm_timers();
            }

            t1_expired() {
                -> $Renewing
            }
            release() {
                this.cancel_all_timers();
                this.send_release();
                -> $Init
            }
            status(): String { @@:("bound") }
        }

        $Renewing {
            $>() {
                this.send_renew();
            }

            ack_received(ip: String, lease_sec: int) {
                this.lease_sec = lease_sec;
                -> $Bound
            }
            nak_received() {
                this.cancel_all_timers();
                -> $Init
            }
            t2_expired() {
                -> $Rebinding
            }
            lease_expired() {
                this.cancel_all_timers();
                -> $Init
            }
            release() {
                this.cancel_all_timers();
                -> $Init
            }
            status(): String { @@:("renewing") }
        }

        $Rebinding {
            $>() {
                this.broadcast_renew();
            }

            ack_received(ip: String, lease_sec: int) {
                this.lease_sec = lease_sec;
                -> $Bound
            }
            nak_received() {
                this.cancel_all_timers();
                -> $Init
            }
            lease_expired() {
                this.cancel_all_timers();
                this.bound = "";
                -> $Init
            }
            release() {
                this.cancel_all_timers();
                -> $Init
            }
            status(): String { @@:("rebinding") }
        }

    actions:
        broadcast_discover()    {}
        send_request()          {}
        send_renew()            {}
        broadcast_renew()       {}
        send_release()          {}
        arm_timers()            {}
        cancel_all_timers()     {}

    domain:
        server: String = ""
        offered: String = ""
        bound: String = ""
        lease_sec: int = 0
        attempts: int = 0
}


void check(String label, String actual, String expected) {
    if (actual != expected) {
        print("FAIL: $label -- expected '$expected', got '$actual'");
        exit(1);
    }
}

void test_full_lease_acquisition() {
    final dhcp = @@DhcpClient();
    check("initial init", dhcp.status() as String, "init");
    dhcp.start();
    check("selecting", dhcp.status() as String, "selecting");
    dhcp.offer_received("192.168.1.1", "192.168.1.100", 3600);
    check("requesting after offer", dhcp.status() as String, "requesting");
    dhcp.ack_received("192.168.1.100", 3600);
    check("bound", dhcp.status() as String, "bound");
    print("PASS: full lease acquisition Init->Selecting->Requesting->Bound");
}

void test_t1_triggers_renewal() {
    final dhcp = @@DhcpClient();
    dhcp.start();
    dhcp.offer_received("10.0.0.1", "10.0.0.100", 7200);
    dhcp.ack_received("10.0.0.100", 7200);
    dhcp.t1_expired();
    check("renewing after t1", dhcp.status() as String, "renewing");
    dhcp.ack_received("10.0.0.100", 7200);
    check("back to bound after renew ack", dhcp.status() as String, "bound");
    print("PASS: T1 triggers renewal, ACK returns to bound");
}

void test_t2_triggers_rebind() {
    final dhcp = @@DhcpClient();
    dhcp.start();
    dhcp.offer_received("10.0.0.1", "10.0.0.100", 7200);
    dhcp.ack_received("10.0.0.100", 7200);
    dhcp.t1_expired();
    check("renewing", dhcp.status() as String, "renewing");
    dhcp.t2_expired();
    check("rebinding after t2", dhcp.status() as String, "rebinding");
    dhcp.ack_received("10.0.0.100", 7200);
    check("rebind ACK -> bound", dhcp.status() as String, "bound");
    print("PASS: T2 triggers rebind, ACK returns to bound");
}

void test_nak_during_requesting_restarts() {
    final dhcp = @@DhcpClient();
    dhcp.start();
    dhcp.offer_received("10.0.0.1", "10.0.0.100", 7200);
    dhcp.nak_received();
    check("NAK in Requesting -> Init", dhcp.status() as String, "init");
    print("PASS: NAK in Requesting restarts");
}

void test_lease_expired_in_rebinding() {
    final dhcp = @@DhcpClient();
    dhcp.start();
    dhcp.offer_received("10.0.0.1", "10.0.0.100", 7200);
    dhcp.ack_received("10.0.0.100", 7200);
    dhcp.t1_expired();
    dhcp.t2_expired();
    dhcp.lease_expired();
    check("lease_expired in Rebinding -> Init", dhcp.status() as String, "init");
    print("PASS: lease expiry in rebinding clears state");
}

void test_release_from_bound() {
    final dhcp = @@DhcpClient();
    dhcp.start();
    dhcp.offer_received("10.0.0.1", "10.0.0.100", 7200);
    dhcp.ack_received("10.0.0.100", 7200);
    dhcp.release();
    check("release -> init", dhcp.status() as String, "init");
    print("PASS: release from bound");
}

void main() {
    test_full_lease_acquisition();
    test_t1_triggers_renewal();
    test_t2_triggers_rebind();
    test_nak_during_requesting_restarts();
    test_lease_expired_in_rebinding();
    test_release_from_bound();
    print("PASS: all DHCP client tests passed");
}

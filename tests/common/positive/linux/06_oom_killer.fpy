@@target python_3

# OOM Killer — kernel mm/oom_kill.c semantics. Safety-critical: while $Killing,
# concurrent oom_detected_again() events are silently dropped because no handler
# exists for them in that state. This is safety by structural absence —
# no oom_lock needed, no flag check, just "no dispatch path."

@@system OomKiller {
    interface:
        oom_detected(gfp_flags: int): str
        victim_exited(pid: int, freed_kb: int): str
        oom_detected_again(gfp_flags: int): str
        status(): str

    machine:
        $Normal {
            oom_detected(gfp_flags: int): str {
                @@:("selecting victim")
                -> $Selecting
            }
            status(): str { @@:("normal") }
        }

        $Selecting {
            $>() {
                self.victim_pid = self.select_victim()
                if self.victim_pid < 0:
                    -> $Panic
                else:
                    -> $Killing
            }
            status(): str { @@:("selecting") }
        }

        $Killing {
            $>() {
                self.send_sigkill(self.victim_pid)
                self.start_reaper_timer()
            }
            <$() {
                self.cancel_reaper_timer()
            }

            victim_exited(pid: int, freed_kb: int): str {
                if pid == self.victim_pid:
                    self.total_freed_kb = self.total_freed_kb + freed_kb
                    @@:("reclaimed")
                    -> $Normal
                else:
                    @@:("wrong pid, still waiting")
            }

            # oom_detected_again NOT handled — structural safety property.
            status(): str { @@:("killing") }
        }

        $Panic {
            status(): str { @@:("panic") }
        }

    actions:
        select_victim() {
            self.victim_score = 850
            return 4242
        }
        send_sigkill(pid) { pass }
        start_reaper_timer() { pass }
        cancel_reaper_timer() { pass }

    domain:
        victim_pid: int = -1
        victim_score: int = 0
        total_freed_kb: int = 0
}


def check(label, actual, expected):
    if actual != expected:
        print(f"FAIL: {label} — expected {expected!r}, got {actual!r}")
        raise SystemExit(1)

def test_normal_oom_flow():
    oom = @@OomKiller()
    check("initial normal", oom.status(), "normal")
    check("oom_detected -> selecting", oom.oom_detected(0), "selecting victim")
    # $Selecting is transient — enter handler already moved us to $Killing
    check("arrived in killing", oom.status(), "killing")
    check("victim exits",
          oom.victim_exited(4242, 51200), "reclaimed")
    check("back to normal", oom.status(), "normal")
    print("PASS: normal OOM flow")

def test_concurrent_oom_silently_dropped():
    # SAFETY PROPERTY: while $Killing, oom_detected_again() is dropped.
    oom = @@OomKiller()
    oom.oom_detected(0)
    check("in killing", oom.status(), "killing")
    # Second OOM event — should be dropped (no handler in $Killing)
    oom.oom_detected_again(0)
    check("still killing (event dropped)", oom.status(), "killing")
    # Finish the kill
    oom.victim_exited(4242, 8192)
    check("back to normal after reclaim", oom.status(), "normal")
    print("PASS: concurrent OOM events dropped in $Killing (safety)")

def test_wrong_pid_exit_ignored():
    # If a random process exits with the wrong PID, we stay in $Killing
    oom = @@OomKiller()
    oom.oom_detected(0)
    check("waiting for victim",
          oom.victim_exited(9999, 1024), "wrong pid, still waiting")
    check("still killing", oom.status(), "killing")
    # Now the right victim exits
    oom.victim_exited(4242, 2048)
    check("correct pid -> normal", oom.status(), "normal")
    print("PASS: wrong-pid exit ignored in $Killing")

def test_oom_detected_ignored_in_selecting():
    # oom_detected in $Killing: no handler, dropped
    # oom_detected in $Normal: valid, starts the cycle
    oom = @@OomKiller()
    check("first oom", oom.oom_detected(0), "selecting victim")
    # We're in $Killing now (transient $Selecting resolved)
    # Another oom_detected in $Killing — no handler, ignored
    oom.oom_detected(0)
    check("second oom dropped", oom.status(), "killing")
    print("PASS: oom_detected ignored while killing")

if __name__ == '__main__':
    test_normal_oom_flow()
    test_concurrent_oom_silently_dropped()
    test_wrong_pid_exit_ignored()
    test_oom_detected_ignored_in_selecting()
    print("PASS: all OOM killer tests passed")

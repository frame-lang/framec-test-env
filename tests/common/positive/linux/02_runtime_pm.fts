@@target typescript

// Runtime Power Management — kernel drivers/base/power/runtime.c semantics.
// Device transitions through Active/Idle/Suspending/Suspended/Resuming
// driven by usage count (get/put) and autosuspend timers (enter/exit).

@@system RuntimePM {
    interface:
        get(): string
        put(): string
        autosuspend_expired(): string
        resume_complete(): string
        suspend_complete(success: boolean): string
        status(): string

    machine:
        $Active {
            $>() {
                this.cancel_timer();
            }

            get(): string {
                this.usage_count = this.usage_count + 1;
                @@:(`get: usage=${this.usage_count}`)
            }
            put(): string {
                this.usage_count = this.usage_count - 1;
                @@:(`put: usage=${this.usage_count}`)
                if (this.usage_count <= 0) {
                    -> $Idle
                }
            }
            status(): string { @@:("active") }
        }

        $Idle {
            $>() {
                this.start_autosuspend_timer();
            }
            <$() {
                this.cancel_timer();
            }

            get(): string {
                this.usage_count = this.usage_count + 1;
                @@:(`get: usage=${this.usage_count}`)
                -> $Active
            }
            autosuspend_expired(): string {
                @@:("suspending")
                -> $Suspending
            }
            status(): string { @@:("idle") }
        }

        $Suspending {
            $>() {
                this.call_suspend_callback();
            }

            suspend_complete(success: boolean): string {
                if (success) {
                    @@:("suspended")
                    -> $Suspended
                } else {
                    @@:("suspend failed")
                    -> $Active
                }
            }
            get(): string {
                this.usage_count = this.usage_count + 1;
                @@:("resume requested during suspend")
                -> $Resuming
            }
            status(): string { @@:("suspending") }
        }

        $Suspended {
            get(): string {
                this.usage_count = this.usage_count + 1;
                @@:("waking")
                -> $Resuming
            }
            status(): string { @@:("suspended") }
        }

        $Resuming {
            $>() {
                this.call_resume_callback();
            }

            resume_complete(): string {
                @@:("resumed")
                -> $Active
            }
            status(): string { @@:("resuming") }
        }

    actions:
        start_autosuspend_timer() {}
        cancel_timer() {}
        call_suspend_callback() {}
        call_resume_callback() {}

    domain:
        usage_count: number = 1
        autosuspend_delay_ms: number = 500
}


function check(label: string, actual: string, expected: string): void {
    if (actual !== expected) {
        console.log(`FAIL: ${label} — expected '${expected}', got '${actual}'`);
        throw new Error(`assertion failed: ${label}`);
    }
}

function test_happy_idle_suspend_resume(): void {
    const dev = @@RuntimePM();
    check("initial active", dev.status(), "active");
    check("put drops to 0", dev.put(), "put: usage=0");
    check("idle after drain", dev.status(), "idle");
    check("autosuspend fires", dev.autosuspend_expired(), "suspending");
    check("suspend_complete true", dev.suspend_complete(true), "suspended");
    check("get wakes", dev.get(), "waking");
    check("resuming status", dev.status(), "resuming");
    check("resume_complete", dev.resume_complete(), "resumed");
    check("back to active", dev.status(), "active");
    console.log("PASS: happy path (active -> idle -> suspended -> resumed)");
}

function test_suspend_failure_returns_to_active(): void {
    const dev = @@RuntimePM();
    dev.put();
    dev.autosuspend_expired();
    check("suspend failed", dev.suspend_complete(false), "suspend failed");
    check("reverted to active", dev.status(), "active");
    console.log("PASS: suspend failure -> active");
}

function test_get_during_suspending_redirects_to_resuming(): void {
    const dev = @@RuntimePM();
    dev.put();
    dev.autosuspend_expired();
    check("suspending state", dev.status(), "suspending");
    check("get during suspend", dev.get(), "resume requested during suspend");
    check("redirected to resuming", dev.status(), "resuming");
    console.log("PASS: get during suspending redirects to resuming");
}

function test_usage_count_mgmt(): void {
    const dev = @@RuntimePM();
    check("get +1", dev.get(), "get: usage=2");
    check("get +1 again", dev.get(), "get: usage=3");
    check("put -1", dev.put(), "put: usage=2");
    check("put -1", dev.put(), "put: usage=1");
    check("put to 0 -> idle", dev.put(), "put: usage=0");
    check("idle", dev.status(), "idle");
    console.log("PASS: usage count tracking");
}

test_happy_idle_suspend_resume();
test_suspend_failure_returns_to_active();
test_get_during_suspending_redirects_to_resuming();
test_usage_count_mgmt();
console.log("PASS: all runtime PM tests passed");

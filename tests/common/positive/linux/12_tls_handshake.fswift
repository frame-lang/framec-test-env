@@target swift

// TLS Handshake (server side) — RFC 5246 Section 7.3.

import Foundation

@@system TlsServerHandshake {
    interface:
        client_hello(version: String, cipher: String)
        client_key_exchange(key_data: String)
        client_change_cipher_spec()
        client_finished(verify: String)
        alert(level: String, desc: String)
        status(): String

    machine:
        $Idle {
            client_hello(version: String, cipher: String) {
                self.client_version = version
                if cipher == "TLS_ECDHE_RSA_WITH_AES_128_GCM_SHA256" {
                    self.selected_cipher = cipher
                    -> $ServerHello
                } else {
                    if cipher == "TLS_RSA_WITH_AES_128_CBC_SHA" {
                        self.selected_cipher = cipher
                        -> $ServerHello
                    } else {
                        self.send_alert()
                        -> $Closed
                    }
                }
            }
            status(): String { @@:("idle") }
        }

        $ServerHello => $Handshaking {
            $>() {
                self.send_server_hello()
                self.send_certificate()
                self.send_server_hello_done()
                -> $AwaitClientKeyExchange
            }
            status(): String { @@:("server hello") }
            => $^
        }

        $AwaitClientKeyExchange => $Handshaking {
            client_key_exchange(key_data: String) {
                self.premaster = key_data
                self.derive_keys()
                -> $AwaitChangeCipherSpec
            }
            status(): String { @@:("await key exchange") }
            => $^
        }

        $AwaitChangeCipherSpec => $Handshaking {
            client_change_cipher_spec() {
                self.client_encrypted = true
                -> $AwaitClientFinished
            }
            status(): String { @@:("await change cipher spec") }
            => $^
        }

        $AwaitClientFinished => $Handshaking {
            client_finished(verify: String) {
                if verify == "valid" {
                    self.send_change_cipher_spec()
                    self.send_finished()
                    -> $Established
                } else {
                    self.send_alert()
                    -> $Closed
                }
            }
            status(): String { @@:("await client finished") }
            => $^
        }

        $Handshaking {
            alert(level: String, desc: String) {
                if level == "fatal" {
                    -> $Closed
                }
            }
        }

        $Established {
            alert(level: String, desc: String) {
                if level == "fatal" {
                    -> $Closed
                }
            }
            status(): String { @@:("established") }
        }

        $Closed {
            status(): String { @@:("closed") }
        }

    actions:
        send_server_hello() {}
        send_certificate() {}
        send_server_hello_done() {}
        derive_keys() {}
        send_change_cipher_spec() {}
        send_finished() {}
        send_alert() {}

    domain:
        client_version: String = ""
        selected_cipher: String = ""
        premaster: String = ""
        client_encrypted: Bool = false
}


func check(_ label: String, _ actual: String, _ expected: String) {
    if actual != expected {
        print("FAIL: \(label) — expected '\(expected)', got '\(actual)'")
        exit(1)
    }
}

func test_happy_handshake() {
    var tls = @@TlsServerHandshake()
    check("initial idle", tls.status() as! String, "idle")
    _ = tls.client_hello("TLS 1.2", "TLS_RSA_WITH_AES_128_CBC_SHA")
    check("after client_hello -> through ServerHello to await", tls.status() as! String, "await key exchange")
    _ = tls.client_key_exchange("premaster_data")
    check("after key exchange", tls.status() as! String, "await change cipher spec")
    _ = tls.client_change_cipher_spec()
    check("after CCS", tls.status() as! String, "await client finished")
    _ = tls.client_finished("valid")
    check("established", tls.status() as! String, "established")
    print("PASS: happy TLS handshake")
}

func test_unsupported_cipher_closes() {
    var tls = @@TlsServerHandshake()
    _ = tls.client_hello("TLS 1.2", "TLS_NULL_WITH_NULL_NULL")
    check("no matching cipher -> closed", tls.status() as! String, "closed")
    print("PASS: unsupported cipher closes handshake")
}

func test_fatal_alert_during_handshake() {
    var tls = @@TlsServerHandshake()
    _ = tls.client_hello("TLS 1.2", "TLS_RSA_WITH_AES_128_CBC_SHA")
    _ = tls.alert("fatal", "unexpected_message")
    check("fatal alert -> closed (via HSM parent)", tls.status() as! String, "closed")
    print("PASS: fatal alert forwards via HSM parent to $Closed")
}

func test_warning_alert_ignored() {
    var tls = @@TlsServerHandshake()
    _ = tls.client_hello("TLS 1.2", "TLS_RSA_WITH_AES_128_CBC_SHA")
    _ = tls.alert("warning", "close_notify_soon")
    check("warning alert doesn't close", tls.status() as! String, "await key exchange")
    print("PASS: warning alert doesn't close handshake")
}

func test_invalid_finished_closes() {
    var tls = @@TlsServerHandshake()
    _ = tls.client_hello("TLS 1.2", "TLS_RSA_WITH_AES_128_CBC_SHA")
    _ = tls.client_key_exchange("bogus")
    _ = tls.client_change_cipher_spec()
    _ = tls.client_finished("invalid")
    check("bad verify -> closed", tls.status() as! String, "closed")
    print("PASS: invalid client_finished closes")
}

func test_fatal_alert_in_established() {
    var tls = @@TlsServerHandshake()
    _ = tls.client_hello("TLS 1.2", "TLS_RSA_WITH_AES_128_CBC_SHA")
    _ = tls.client_key_exchange("pm")
    _ = tls.client_change_cipher_spec()
    _ = tls.client_finished("valid")
    check("established", tls.status() as! String, "established")
    _ = tls.alert("fatal", "bad_record_mac")
    check("fatal in $Established -> closed", tls.status() as! String, "closed")
    print("PASS: fatal alert in established closes")
}

test_happy_handshake()
test_unsupported_cipher_closes()
test_fatal_alert_during_handshake()
test_warning_alert_ignored()
test_invalid_finished_closes()
test_fatal_alert_in_established()
print("PASS: all TLS handshake tests passed")

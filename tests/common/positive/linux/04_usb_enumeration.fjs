@@target javascript

// USB Device Enumeration — multi-stage pipeline with compensation (saga).

@@system UsbEnumerator {
    interface:
        plug_in(port: number)
        reset_done(success: boolean)
        address_set(success: boolean, addr: number)
        descriptors_read(success: boolean, product: string)
        driver_bound(success: boolean)
        unplug()
        status(): string

    machine:
        $Detached {
            plug_in(port: number) {
                this.port = port;
                this.reset_attempts = 0;
                -> $Resetting
            }
            status(): string { @@:("detached") }
        }

        $Resetting => $Enumerating {
            $>() {
                this.reset_attempts = this.reset_attempts + 1;
                this.issue_port_reset(this.port);
            }

            reset_done(success: boolean) {
                if (success) {
                    -> $Addressing
                } else {
                    if (this.reset_attempts < this.max_reset_attempts) {
                        -> $Resetting
                    } else {
                        -> $Failed
                    }
                }
            }
            status(): string { @@:("resetting") }
            => $^
        }

        $Addressing => $Enumerating {
            $>() {
                this.assign_address();
            }

            address_set(success: boolean, addr: number) {
                if (success) {
                    this.address = addr;
                    -> $ReadingDescriptors
                } else {
                    -> $UndoReset
                }
            }
            status(): string { @@:("addressing") }
            => $^
        }

        $ReadingDescriptors => $Enumerating {
            $>() {
                this.read_descriptors(this.address);
            }

            descriptors_read(success: boolean, product: string) {
                if (success) {
                    this.product = product;
                    -> $BindingDriver
                } else {
                    -> $UndoAddress
                }
            }
            status(): string { @@:("reading descriptors") }
            => $^
        }

        $BindingDriver => $Enumerating {
            $>() {
                this.bind_driver(this.product);
            }

            driver_bound(success: boolean) {
                if (success) {
                    -> $Configured
                } else {
                    -> $UndoAddress
                }
            }
            status(): string { @@:("binding driver") }
            => $^
        }

        $Enumerating {
            unplug() {
                -> $Detached
            }
        }

        $UndoAddress {
            $>() {
                this.release_address(this.address);
                -> $UndoReset
            }
        }

        $UndoReset {
            $>() {
                this.disable_port(this.port);
                -> $Failed
            }
        }

        $Configured {
            unplug() {
                this.unbind_driver();
                this.release_address(this.address);
                this.disable_port(this.port);
                -> $Detached
            }
            status(): string { @@:("configured") }
        }

        $Failed {
            plug_in(port: number) {
                this.port = port;
                this.reset_attempts = 0;
                -> $Resetting
            }
            status(): string { @@:("failed") }
        }

    actions:
        issue_port_reset(port) {}
        assign_address() {}
        read_descriptors(addr) {}
        bind_driver(product) {}
        release_address(addr) {}
        disable_port(port) {}
        unbind_driver() {}

    domain:
        port = 0
        address = 0
        product = ""
        reset_attempts = 0
        max_reset_attempts = 3
}


function check(label, actual, expected) {
    if (actual !== expected) {
        console.log(`FAIL: ${label} — expected '${expected}', got '${actual}'`);
        throw new Error(`assertion failed: ${label}`);
    }
}

function test_happy_path() {
    const usb = @@UsbEnumerator();
    check("initial detached", usb.status(), "detached");
    usb.plug_in(1);
    check("after plug_in", usb.status(), "resetting");
    usb.reset_done(true);
    check("reset ok -> addressing", usb.status(), "addressing");
    usb.address_set(true, 7);
    check("address ok -> reading", usb.status(), "reading descriptors");
    usb.descriptors_read(true, "USB Keyboard");
    check("descriptors ok -> binding", usb.status(), "binding driver");
    usb.driver_bound(true);
    check("driver bound -> configured", usb.status(), "configured");
    console.log("PASS: happy path enumeration");
}

function test_descriptor_failure_compensates() {
    const usb = @@UsbEnumerator();
    usb.plug_in(2);
    usb.reset_done(true);
    usb.address_set(true, 8);
    usb.descriptors_read(false, "");
    check("compensated to failed", usb.status(), "failed");
    console.log("PASS: descriptor failure compensation");
}

function test_driver_bind_failure_compensates() {
    const usb = @@UsbEnumerator();
    usb.plug_in(3);
    usb.reset_done(true);
    usb.address_set(true, 9);
    usb.descriptors_read(true, "Mouse");
    usb.driver_bound(false);
    check("bind fail compensated to failed", usb.status(), "failed");
    console.log("PASS: driver bind failure compensation");
}

function test_unplug_during_enumeration() {
    const usb = @@UsbEnumerator();
    usb.plug_in(4);
    check("in resetting", usb.status(), "resetting");
    usb.unplug();
    check("unplug -> detached", usb.status(), "detached");
    console.log("PASS: unplug during enumeration forwards via HSM");
}

function test_reset_retry_then_exhaust() {
    const usb = @@UsbEnumerator();
    usb.plug_in(5);
    usb.reset_done(false);
    check("retry 1", usb.status(), "resetting");
    usb.reset_done(false);
    check("retry 2", usb.status(), "resetting");
    usb.reset_done(false);
    check("exhausted -> failed", usb.status(), "failed");
    console.log("PASS: reset retry exhaustion");
}

function test_replug_from_failed() {
    const usb = @@UsbEnumerator();
    usb.plug_in(6);
    usb.reset_done(false);
    usb.reset_done(false);
    usb.reset_done(false);
    check("failed state", usb.status(), "failed");
    usb.plug_in(6);
    check("re-plug restarts enumeration", usb.status(), "resetting");
    console.log("PASS: re-plug from failed state");
}

test_happy_path();
test_descriptor_failure_compensates();
test_driver_bind_failure_compensates();
test_unplug_during_enumeration();
test_reset_retry_then_exhaust();
test_replug_from_failed();
console.log("PASS: all USB enumeration tests passed");

@@target ruby

# BGP Finite State Machine -- RFC 4271 Section 8 direct transcription.

require 'json'

@@persist
@@system BgpSession {
    interface:
        manual_start()
        manual_stop()
        tcp_connection_confirmed()
        tcp_connection_fails()
        open_received(asn: int, hold_time: int)
        keepalive_received()
        notification_received(code: int, subcode: int)
        hold_timer_expired()
        keepalive_timer_expired()
        connect_retry_timer_expired()
        status(): str

    machine:
        $Idle {
            manual_start() {
                @connect_retry_count = 0
                start_connect_retry_timer()
                initiate_tcp_connection()
                -> $Connect
            }
            status(): str { @@:("idle") }
        }

        $Connect {
            tcp_connection_confirmed() {
                cancel_connect_retry_timer()
                send_open()
                -> $OpenSent
            }
            tcp_connection_fails() {
                -> $Active
            }
            connect_retry_timer_expired() {
                initiate_tcp_connection()
                start_connect_retry_timer()
            }
            manual_stop() {
                -> $Idle
            }
            status(): str { @@:("connect") }
        }

        $Active {
            tcp_connection_confirmed() {
                cancel_connect_retry_timer()
                send_open()
                -> $OpenSent
            }
            connect_retry_timer_expired() {
                @connect_retry_count = @connect_retry_count + 1
                initiate_tcp_connection()
                start_connect_retry_timer()
                -> $Connect
            }
            manual_stop() {
                -> $Idle
            }
            status(): str { @@:("active") }
        }

        $OpenSent {
            open_received(asn: int, hold_time: int) {
                @peer_asn = asn
                @negotiated_hold = hold_time
                cancel_hold_timer()
                send_keepalive()
                -> $OpenConfirm
            }
            tcp_connection_fails() {
                cancel_hold_timer()
                -> $Active
            }
            notification_received(code: int, subcode: int) {
                -> $Idle
            }
            hold_timer_expired() {
                send_notification()
                -> $Idle
            }
            manual_stop() {
                send_notification()
                -> $Idle
            }
            status(): str { @@:("open sent") }
        }

        $OpenConfirm {
            keepalive_received() {
                -> $Established
            }
            notification_received(code: int, subcode: int) {
                -> $Idle
            }
            hold_timer_expired() {
                send_notification()
                -> $Idle
            }
            keepalive_timer_expired() {
                send_keepalive()
            }
            manual_stop() {
                send_notification()
                -> $Idle
            }
            status(): str { @@:("open confirm") }
        }

        $Established {
            keepalive_received() {
                reset_hold_timer()
            }
            keepalive_timer_expired() {
                send_keepalive()
            }
            notification_received(code: int, subcode: int) {
                -> $Idle
            }
            hold_timer_expired() {
                send_notification()
                -> $Idle
            }
            manual_stop() {
                send_notification()
                -> $Idle
            }
            status(): str { @@:("established") }
        }

    actions:
        initiate_tcp_connection()   {}
        send_open()                 {}
        send_keepalive()            {}
        send_notification()         {}
        start_connect_retry_timer() {}
        cancel_connect_retry_timer(){}
        cancel_hold_timer()         {}
        reset_hold_timer()          {}

    domain:
        local_asn: int = 65001
        peer_asn: int = 0
        negotiated_hold: int = 0
        connect_retry_count: int = 0
}


def check(label, actual, expected)
    if actual != expected
        puts "FAIL: #{label} -- expected '#{expected}', got '#{actual}'"
        exit 1
    end
end

def test_full_session_establishment
    bgp = BgpSession.new
    check("initial idle", bgp.status, "idle")
    bgp.manual_start
    check("connect", bgp.status, "connect")
    bgp.tcp_connection_confirmed
    check("open sent", bgp.status, "open sent")
    bgp.open_received(65002, 60)
    check("open confirm", bgp.status, "open confirm")
    bgp.keepalive_received
    check("established", bgp.status, "established")
    puts "PASS: full BGP session establishment"
end

def test_persist_across_restart
    bgp = BgpSession.new
    bgp.manual_start
    bgp.tcp_connection_confirmed
    bgp.open_received(65002, 60)
    bgp.keepalive_received
    check("established", bgp.status, "established")
    snap = bgp.save_state
    bgp2 = BgpSession.restore_state(snap)
    check("established survived restart", bgp2.status, "established")
    bgp2.keepalive_timer_expired
    bgp2.keepalive_received
    check("still established", bgp2.status, "established")
    puts "PASS: @@persist -- BGP session survives daemon restart"
end

def test_hold_timer_teardown
    bgp = BgpSession.new
    bgp.manual_start
    bgp.tcp_connection_confirmed
    bgp.open_received(65002, 60)
    bgp.keepalive_received
    bgp.hold_timer_expired
    check("hold expiry tears down", bgp.status, "idle")
    puts "PASS: hold timer expiry returns to idle"
end

def test_tcp_failure_goes_active
    bgp = BgpSession.new
    bgp.manual_start
    bgp.tcp_connection_fails
    check("active after TCP fail", bgp.status, "active")
    bgp.connect_retry_timer_expired
    check("retry transitions back to connect", bgp.status, "connect")
    puts "PASS: TCP failure path Active -> Connect"
end

def test_notification_in_established_teardown
    bgp = BgpSession.new
    bgp.manual_start
    bgp.tcp_connection_confirmed
    bgp.open_received(65002, 60)
    bgp.keepalive_received
    bgp.notification_received(6, 0)
    check("notification tears down", bgp.status, "idle")
    puts "PASS: notification in Established -> idle"
end

def test_manual_stop_from_established
    bgp = BgpSession.new
    bgp.manual_start
    bgp.tcp_connection_confirmed
    bgp.open_received(65002, 60)
    bgp.keepalive_received
    bgp.manual_stop
    check("manual stop", bgp.status, "idle")
    puts "PASS: manual_stop from established"
end

test_full_session_establishment
test_persist_across_restart
test_hold_timer_teardown
test_tcp_failure_goes_active
test_notification_in_established_teardown
test_manual_stop_from_established
puts "PASS: all BGP session tests passed"

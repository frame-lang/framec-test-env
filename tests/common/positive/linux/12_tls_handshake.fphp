@@target php

<?php

// TLS Handshake (server side) — RFC 5246 Section 7.3.

@@system TlsServerHandshake {
    interface:
        client_hello(version: str, cipher: str)
        client_key_exchange(key_data: str)
        client_change_cipher_spec()
        client_finished(verify: str)
        alert(level: str, desc: str)
        status(): str

    machine:
        $Idle {
            client_hello(version: str, cipher: str) {
                $this->client_version = $version;
                if ($cipher === "TLS_ECDHE_RSA_WITH_AES_128_GCM_SHA256") {
                    $this->selected_cipher = $cipher;
                    -> $ServerHello
                } else {
                    if ($cipher === "TLS_RSA_WITH_AES_128_CBC_SHA") {
                        $this->selected_cipher = $cipher;
                        -> $ServerHello
                    } else {
                        $this->send_alert();
                        -> $Closed
                    }
                }
            }
            status(): str { @@:("idle") }
        }

        $ServerHello => $Handshaking {
            $>() {
                $this->send_server_hello();
                $this->send_certificate();
                $this->send_server_hello_done();
                -> $AwaitClientKeyExchange
            }
            status(): str { @@:("server hello") }
            => $^
        }

        $AwaitClientKeyExchange => $Handshaking {
            client_key_exchange(key_data: str) {
                $this->premaster = $key_data;
                $this->derive_keys();
                -> $AwaitChangeCipherSpec
            }
            status(): str { @@:("await key exchange") }
            => $^
        }

        $AwaitChangeCipherSpec => $Handshaking {
            client_change_cipher_spec() {
                $this->client_encrypted = true;
                -> $AwaitClientFinished
            }
            status(): str { @@:("await change cipher spec") }
            => $^
        }

        $AwaitClientFinished => $Handshaking {
            client_finished(verify: str) {
                if ($verify === "valid") {
                    $this->send_change_cipher_spec();
                    $this->send_finished();
                    -> $Established
                } else {
                    $this->send_alert();
                    -> $Closed
                }
            }
            status(): str { @@:("await client finished") }
            => $^
        }

        $Handshaking {
            alert(level: str, desc: str) {
                if ($level === "fatal") {
                    -> $Closed
                }
            }
        }

        $Established {
            alert(level: str, desc: str) {
                if ($level === "fatal") {
                    -> $Closed
                }
            }
            status(): str { @@:("established") }
        }

        $Closed {
            status(): str { @@:("closed") }
        }

    actions:
        send_server_hello() {}
        send_certificate() {}
        send_server_hello_done() {}
        derive_keys() {}
        send_change_cipher_spec() {}
        send_finished() {}
        send_alert() {}

    domain:
        client_version = ""
        selected_cipher = ""
        premaster = ""
        client_encrypted = false
}


function check_value($label, $actual, $expected) {
    if ($actual !== $expected) {
        echo "FAIL: $label — expected '$expected', got '$actual'\n";
        exit(1);
    }
}

function test_happy_handshake() {
    $tls = @@TlsServerHandshake();
    check_value("initial idle", $tls->status(), "idle");
    $tls->client_hello("TLS 1.2", "TLS_RSA_WITH_AES_128_CBC_SHA");
    check_value("after client_hello -> through ServerHello to await", $tls->status(), "await key exchange");
    $tls->client_key_exchange("premaster_data");
    check_value("after key exchange", $tls->status(), "await change cipher spec");
    $tls->client_change_cipher_spec();
    check_value("after CCS", $tls->status(), "await client finished");
    $tls->client_finished("valid");
    check_value("established", $tls->status(), "established");
    echo "PASS: happy TLS handshake\n";
}

function test_unsupported_cipher_closes() {
    $tls = @@TlsServerHandshake();
    $tls->client_hello("TLS 1.2", "TLS_NULL_WITH_NULL_NULL");
    check_value("no matching cipher -> closed", $tls->status(), "closed");
    echo "PASS: unsupported cipher closes handshake\n";
}

function test_fatal_alert_during_handshake() {
    $tls = @@TlsServerHandshake();
    $tls->client_hello("TLS 1.2", "TLS_RSA_WITH_AES_128_CBC_SHA");
    $tls->alert("fatal", "unexpected_message");
    check_value("fatal alert -> closed (via HSM parent)", $tls->status(), "closed");
    echo "PASS: fatal alert forwards via HSM parent to \$Closed\n";
}

function test_warning_alert_ignored() {
    $tls = @@TlsServerHandshake();
    $tls->client_hello("TLS 1.2", "TLS_RSA_WITH_AES_128_CBC_SHA");
    $tls->alert("warning", "close_notify_soon");
    check_value("warning alert doesn't close", $tls->status(), "await key exchange");
    echo "PASS: warning alert doesn't close handshake\n";
}

function test_invalid_finished_closes() {
    $tls = @@TlsServerHandshake();
    $tls->client_hello("TLS 1.2", "TLS_RSA_WITH_AES_128_CBC_SHA");
    $tls->client_key_exchange("bogus");
    $tls->client_change_cipher_spec();
    $tls->client_finished("invalid");
    check_value("bad verify -> closed", $tls->status(), "closed");
    echo "PASS: invalid client_finished closes\n";
}

function test_fatal_alert_in_established() {
    $tls = @@TlsServerHandshake();
    $tls->client_hello("TLS 1.2", "TLS_RSA_WITH_AES_128_CBC_SHA");
    $tls->client_key_exchange("pm");
    $tls->client_change_cipher_spec();
    $tls->client_finished("valid");
    check_value("established", $tls->status(), "established");
    $tls->alert("fatal", "bad_record_mac");
    check_value("fatal in \$Established -> closed", $tls->status(), "closed");
    echo "PASS: fatal alert in established closes\n";
}

test_happy_handshake();
test_unsupported_cipher_closes();
test_fatal_alert_during_handshake();
test_warning_alert_ignored();
test_invalid_finished_closes();
test_fatal_alert_in_established();
echo "PASS: all TLS handshake tests passed\n";

@@[target("csharp")]

// Signal Handler Stack — textbook push$/pop$ use case.

using System;

@@system SignalContext {
    interface:
        enter_user_code()
        signal_arrives(sig: String)
        handler_returns()
        current_mode(): String
        depth(): int
        current_signum(): String

    machine:
        $Kernel {
            enter_user_code() {
                -> $UserMode
            }
            current_mode(): String { @@:("kernel") }
            depth(): int { @@:(this.nesting) }
            current_signum(): String { @@:("") }
        }

        $UserMode {
            $.saved_regs: String = ""

            $>() {
                $.saved_regs = this.snapshot_registers();
            }

            signal_arrives(sig: String) {
                this.nesting = this.nesting + 1;
                push$
                -> (sig) $SignalHandler
            }
            current_mode(): String { @@:("user") }
            depth(): int { @@:(this.nesting) }
            current_signum(): String { @@:("") }
        }

        $SignalHandler {
            $.signum: String = ""

            $>(sig: String) {
                $.signum = sig;
            }

            signal_arrives(sig: String) {
                this.nesting = this.nesting + 1;
                push$
                -> (sig) $SignalHandler
            }

            handler_returns() {
                this.nesting = this.nesting - 1;
                -> pop$
            }

            current_mode(): String { @@:("handler") }
            depth(): int { @@:(this.nesting) }
            current_signum(): String { @@:($.signum) }
        }

    actions:
        snapshot_registers(): String {
            return "regs_snapshot";
        }

    domain:
        nesting: int = 0
}


class Program {
    static void check_str(string label, string actual, string expected) {
        if (actual != expected) {
            Console.WriteLine($"FAIL: {label} -- expected '{expected}', got '{actual}'");
            Environment.Exit(1);
        }
    }

    static void check_int(string label, int actual, int expected) {
        if (actual != expected) {
            Console.WriteLine($"FAIL: {label} -- expected {expected}, got {actual}");
            Environment.Exit(1);
        }
    }

    static void test_enter_user_mode() {
        var cpu = @@SignalContext();
        check_str("initial kernel", (string) cpu.current_mode(), "kernel");
        cpu.enter_user_code();
        check_str("in user mode", (string) cpu.current_mode(), "user");
        check_int("depth 0", (int) cpu.depth(), 0);
        Console.WriteLine("PASS: enter user mode");
    }

    static void test_single_signal_handler() {
        var cpu = @@SignalContext();
        cpu.enter_user_code();
        cpu.signal_arrives("SIGUSR1");
        check_str("in handler", (string) cpu.current_mode(), "handler");
        check_str("signum SIGUSR1", (string) cpu.current_signum(), "SIGUSR1");
        check_int("depth 1", (int) cpu.depth(), 1);
        cpu.handler_returns();
        check_str("back to user", (string) cpu.current_mode(), "user");
        check_int("depth 0", (int) cpu.depth(), 0);
        Console.WriteLine("PASS: single signal handler + return");
    }

    static void test_nested_signals() {
        var cpu = @@SignalContext();
        cpu.enter_user_code();
        cpu.signal_arrives("SIGUSR1");
        check_str("outer handler signum", (string) cpu.current_signum(), "SIGUSR1");
        cpu.signal_arrives("SIGALRM");
        check_str("inner handler signum", (string) cpu.current_signum(), "SIGALRM");
        check_int("nested depth 2", (int) cpu.depth(), 2);
        cpu.handler_returns();
        check_str("popped to outer handler", (string) cpu.current_mode(), "handler");
        check_str("outer signum preserved across pop", (string) cpu.current_signum(), "SIGUSR1");
        check_int("depth 1", (int) cpu.depth(), 1);
        cpu.handler_returns();
        check_str("back to user", (string) cpu.current_mode(), "user");
        check_int("depth 0", (int) cpu.depth(), 0);
        Console.WriteLine("PASS: nested signals (push$/pop$ preserves state vars)");
    }

    static void test_deeply_nested_signals() {
        var cpu = @@SignalContext();
        cpu.enter_user_code();
        cpu.signal_arrives("SIG1");
        cpu.signal_arrives("SIG2");
        cpu.signal_arrives("SIG3");
        cpu.signal_arrives("SIG4");
        check_int("depth 4", (int) cpu.depth(), 4);
        check_str("top signum", (string) cpu.current_signum(), "SIG4");
        cpu.handler_returns();
        check_str("after pop 1: SIG3", (string) cpu.current_signum(), "SIG3");
        cpu.handler_returns();
        check_str("after pop 2: SIG2", (string) cpu.current_signum(), "SIG2");
        cpu.handler_returns();
        check_str("after pop 3: SIG1", (string) cpu.current_signum(), "SIG1");
        cpu.handler_returns();
        check_str("back to user", (string) cpu.current_mode(), "user");
        Console.WriteLine("PASS: 4-deep nested signal stack");
    }

    static void Main(string[] args) {
        test_enter_user_mode();
        test_single_signal_handler();
        test_nested_signals();
        test_deeply_nested_signals();
        Console.WriteLine("PASS: all signal handler stack tests passed");
    }
}

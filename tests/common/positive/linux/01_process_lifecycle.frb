@@[target("ruby")]

# Process Lifecycle — Linux task states (kernel/sched/core.c semantics)
# Three-level HSM with explicit upward forwarding as per-state signal policy.

@@system TaskLifecycle {
    interface:
        fork(): str
        schedule(): str
        block_on_io(): str
        io_complete(): str
        block_uninterruptible(): str
        send_signal(sig: str): str
        wait_by_parent(): str
        status(): str

    machine:
        $New {
            fork(): str {
                @pid = next_pid()
                @@:("forked")
                -> $Ready
            }
            status(): str { @@:("new") }
        }

        $Ready => $Alive {
            schedule(): str {
                @@:("running")
                -> $Running
            }
            status(): str { @@:("ready") }
            => $^
        }

        $Running => $Alive {
            schedule(): str {
                @@:("preempted")
                -> $Ready
            }
            block_on_io(): str {
                @@:("blocked")
                -> $Interruptible
            }
            block_uninterruptible(): str {
                @@:("blocked (D)")
                -> $Uninterruptible
            }
            status(): str { @@:("running") }
            => $^
        }

        $Interruptible => $Blocked {
            io_complete(): str {
                @@:("woke")
                -> $Ready
            }
            send_signal(sig: str): str {
                if sig == "SIGKILL" || sig == "SIGTERM" || sig == "SIGSTOP"
                    => $^
                else
                    @@:("interrupted")
                    -> $Ready
                end
            }
            status(): str { @@:("interruptible") }
            => $^
        }

        $Uninterruptible => $Blocked {
            io_complete(): str {
                @@:("woke")
                -> $Ready
            }
            send_signal(sig: str): str {
                if sig == "SIGKILL"
                    => $^
                else
                    @@:("signal held pending (D-state)")
                end
            }
            status(): str { @@:("uninterruptible") }
            => $^
        }

        $Blocked => $Alive {
            status(): str { @@:("blocked") }
            => $^
        }

        $Alive {
            send_signal(sig: str): str {
                if sig == "SIGKILL" || sig == "SIGTERM"
                    @@:("exiting")
                    -> $Zombie
                elsif sig == "SIGSTOP"
                    @@:("stopped")
                    -> $Stopped
                else
                    @@:("signal delivered")
                end
            }
        }

        $Stopped {
            send_signal(sig: str): str {
                if sig == "SIGCONT"
                    @@:("continued")
                    -> $Ready
                elsif sig == "SIGKILL"
                    @@:("killed while stopped")
                    -> $Zombie
                else
                    @@:("signal ignored")
                end
            }
            status(): str { @@:("stopped") }
        }

        $Zombie {
            wait_by_parent(): str {
                @@:("reaped")
                -> $Dead
            }
            status(): str { @@:("zombie") }
        }

        $Dead {
            status(): str { @@:("dead") }
        }

    actions:
        next_pid() {
            @pid_counter = @pid_counter + 1
            @pid_counter
        }

    domain:
        pid: int = 0
        pid_counter: int = 100
}


def check(label, actual, expected)
    if actual != expected
        puts "FAIL: #{label} — expected '#{expected}', got '#{actual}'"
        exit 1
    end
end

def test_happy_path
    t = TaskLifecycle.new
    check("initial status", t.status, "new")
    check("fork",           t.fork,   "forked")
    check("after fork",     t.status, "ready")
    check("schedule",       t.schedule, "running")
    check("after schedule", t.status, "running")
    check("preempt",        t.schedule, "preempted")
    check("after preempt",  t.status, "ready")
    puts "PASS: happy path"
end

def test_interruptible_wake_by_signal
    t = TaskLifecycle.new
    t.fork
    t.schedule
    check("block_on_io", t.block_on_io, "blocked")
    check("interruptible status", t.status, "interruptible")
    check("SIGUSR1 wakes interruptible",
          t.send_signal("SIGUSR1"), "interrupted")
    check("woke to ready", t.status, "ready")
    puts "PASS: interruptible wake by signal"
end

def test_uninterruptible_holds_signal
    t = TaskLifecycle.new
    t.fork
    t.schedule
    check("block_uninterruptible",
          t.block_uninterruptible, "blocked (D)")
    check("D state", t.status, "uninterruptible")
    check("SIGUSR1 held pending in D",
          t.send_signal("SIGUSR1"), "signal held pending (D-state)")
    check("still in D", t.status, "uninterruptible")
    puts "PASS: uninterruptible holds non-fatal signal"
end

def test_sigkill_reaches_d_state
    t = TaskLifecycle.new
    t.fork
    t.schedule
    t.block_uninterruptible
    check("SIGKILL forwarded from D through $Alive",
          t.send_signal("SIGKILL"), "exiting")
    check("now zombie", t.status, "zombie")
    check("reap", t.wait_by_parent, "reaped")
    check("dead", t.status, "dead")
    puts "PASS: SIGKILL reaches D state via $Alive forwarding"
end

def test_sigstop_sigcont
    t = TaskLifecycle.new
    t.fork
    t.schedule
    check("SIGSTOP from running",
          t.send_signal("SIGSTOP"), "stopped")
    check("stopped status", t.status, "stopped")
    check("SIGCONT resumes", t.send_signal("SIGCONT"), "continued")
    check("back to ready", t.status, "ready")
    puts "PASS: SIGSTOP/SIGCONT"
end

test_happy_path
test_interruptible_wake_by_signal
test_uninterruptible_holds_signal
test_sigkill_reaches_d_state
test_sigstop_sigcont
puts "PASS: all process lifecycle tests passed"

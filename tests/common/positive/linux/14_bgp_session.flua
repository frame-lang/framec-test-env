@@[target("lua")]

-- BGP Finite State Machine -- RFC 4271 Section 8 direct transcription.

@@[persist]
@@system BgpSession {
    interface:
        manual_start()
        manual_stop()
        tcp_connection_confirmed()
        tcp_connection_fails()
        open_received(asn: int, hold_time: int)
        keepalive_received()
        notification_received(code: int, subcode: int)
        hold_timer_expired()
        keepalive_timer_expired()
        connect_retry_timer_expired()
        status(): str

    machine:
        $Idle {
            manual_start() {
                self.connect_retry_count = 0
                self:start_connect_retry_timer()
                self:initiate_tcp_connection()
                -> $Connect
            }
            status(): str { @@:("idle") }
        }

        $Connect {
            tcp_connection_confirmed() {
                self:cancel_connect_retry_timer()
                self:send_open()
                -> $OpenSent
            }
            tcp_connection_fails() {
                -> $Active
            }
            connect_retry_timer_expired() {
                self:initiate_tcp_connection()
                self:start_connect_retry_timer()
            }
            manual_stop() {
                -> $Idle
            }
            status(): str { @@:("connect") }
        }

        $Active {
            tcp_connection_confirmed() {
                self:cancel_connect_retry_timer()
                self:send_open()
                -> $OpenSent
            }
            connect_retry_timer_expired() {
                self.connect_retry_count = self.connect_retry_count + 1
                self:initiate_tcp_connection()
                self:start_connect_retry_timer()
                -> $Connect
            }
            manual_stop() {
                -> $Idle
            }
            status(): str { @@:("active") }
        }

        $OpenSent {
            open_received(asn: int, hold_time: int) {
                self.peer_asn = asn
                self.negotiated_hold = hold_time
                self:cancel_hold_timer()
                self:send_keepalive()
                -> $OpenConfirm
            }
            tcp_connection_fails() {
                self:cancel_hold_timer()
                -> $Active
            }
            notification_received(code: int, subcode: int) {
                -> $Idle
            }
            hold_timer_expired() {
                self:send_notification()
                -> $Idle
            }
            manual_stop() {
                self:send_notification()
                -> $Idle
            }
            status(): str { @@:("open sent") }
        }

        $OpenConfirm {
            keepalive_received() {
                -> $Established
            }
            notification_received(code: int, subcode: int) {
                -> $Idle
            }
            hold_timer_expired() {
                self:send_notification()
                -> $Idle
            }
            keepalive_timer_expired() {
                self:send_keepalive()
            }
            manual_stop() {
                self:send_notification()
                -> $Idle
            }
            status(): str { @@:("open confirm") }
        }

        $Established {
            keepalive_received() {
                self:reset_hold_timer()
            }
            keepalive_timer_expired() {
                self:send_keepalive()
            }
            notification_received(code: int, subcode: int) {
                -> $Idle
            }
            hold_timer_expired() {
                self:send_notification()
                -> $Idle
            }
            manual_stop() {
                self:send_notification()
                -> $Idle
            }
            status(): str { @@:("established") }
        }

    actions:
        initiate_tcp_connection()   {}
        send_open()                 {}
        send_keepalive()            {}
        send_notification()         {}
        start_connect_retry_timer() {}
        cancel_connect_retry_timer(){}
        cancel_hold_timer()         {}
        reset_hold_timer()          {}

    domain:
        local_asn: int = 65001
        peer_asn: int = 0
        negotiated_hold: int = 0
        connect_retry_count: int = 0
}


local function check(label, actual, expected)
    if actual ~= expected then
        print("FAIL: " .. label .. " -- expected '" .. tostring(expected) .. "', got '" .. tostring(actual) .. "'")
        os.exit(1)
    end
end

local function test_full_session_establishment()
    local bgp = @@BgpSession()
    check("initial idle", bgp:status(), "idle")
    bgp:manual_start()
    check("connect", bgp:status(), "connect")
    bgp:tcp_connection_confirmed()
    check("open sent", bgp:status(), "open sent")
    bgp:open_received(65002, 60)
    check("open confirm", bgp:status(), "open confirm")
    bgp:keepalive_received()
    check("established", bgp:status(), "established")
    print("PASS: full BGP session establishment")
end

local function test_persist_across_restart()
    local bgp = @@BgpSession()
    bgp:manual_start()
    bgp:tcp_connection_confirmed()
    bgp:open_received(65002, 60)
    bgp:keepalive_received()
    check("established", bgp:status(), "established")
    local snap = bgp:save_state()
    local bgp2 = BgpSession.restore_state(snap)
    check("established survived restart", bgp2:status(), "established")
    bgp2:keepalive_timer_expired()
    bgp2:keepalive_received()
    check("still established", bgp2:status(), "established")
    print("PASS: @@persist -- BGP session survives daemon restart")
end

local function test_hold_timer_teardown()
    local bgp = @@BgpSession()
    bgp:manual_start()
    bgp:tcp_connection_confirmed()
    bgp:open_received(65002, 60)
    bgp:keepalive_received()
    bgp:hold_timer_expired()
    check("hold expiry tears down", bgp:status(), "idle")
    print("PASS: hold timer expiry returns to idle")
end

local function test_tcp_failure_goes_active()
    local bgp = @@BgpSession()
    bgp:manual_start()
    bgp:tcp_connection_fails()
    check("active after TCP fail", bgp:status(), "active")
    bgp:connect_retry_timer_expired()
    check("retry transitions back to connect", bgp:status(), "connect")
    print("PASS: TCP failure path Active -> Connect")
end

local function test_notification_in_established_teardown()
    local bgp = @@BgpSession()
    bgp:manual_start()
    bgp:tcp_connection_confirmed()
    bgp:open_received(65002, 60)
    bgp:keepalive_received()
    bgp:notification_received(6, 0)
    check("notification tears down", bgp:status(), "idle")
    print("PASS: notification in Established -> idle")
end

local function test_manual_stop_from_established()
    local bgp = @@BgpSession()
    bgp:manual_start()
    bgp:tcp_connection_confirmed()
    bgp:open_received(65002, 60)
    bgp:keepalive_received()
    bgp:manual_stop()
    check("manual stop", bgp:status(), "idle")
    print("PASS: manual_stop from established")
end

test_full_session_establishment()
test_persist_across_restart()
test_hold_timer_teardown()
test_tcp_failure_goes_active()
test_notification_in_established_teardown()
test_manual_stop_from_established()
print("PASS: all BGP session tests passed")

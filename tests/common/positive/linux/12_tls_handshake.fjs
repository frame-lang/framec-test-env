@@target javascript

// TLS Handshake (server side) — RFC 5246 Section 7.3.

@@system TlsServerHandshake {
    interface:
        client_hello(version: string, cipher: string)
        client_key_exchange(key_data: string)
        client_change_cipher_spec()
        client_finished(verify: string)
        alert(level: string, desc: string)
        status(): string

    machine:
        $Idle {
            client_hello(version: string, cipher: string) {
                this.client_version = version;
                if (cipher === "TLS_ECDHE_RSA_WITH_AES_128_GCM_SHA256") {
                    this.selected_cipher = cipher;
                    -> $ServerHello
                } else {
                    if (cipher === "TLS_RSA_WITH_AES_128_CBC_SHA") {
                        this.selected_cipher = cipher;
                        -> $ServerHello
                    } else {
                        this.send_alert();
                        -> $Closed
                    }
                }
            }
            status(): string { @@:("idle") }
        }

        $ServerHello => $Handshaking {
            $>() {
                this.send_server_hello();
                this.send_certificate();
                this.send_server_hello_done();
                -> $AwaitClientKeyExchange
            }
            status(): string { @@:("server hello") }
            => $^
        }

        $AwaitClientKeyExchange => $Handshaking {
            client_key_exchange(key_data: string) {
                this.premaster = key_data;
                this.derive_keys();
                -> $AwaitChangeCipherSpec
            }
            status(): string { @@:("await key exchange") }
            => $^
        }

        $AwaitChangeCipherSpec => $Handshaking {
            client_change_cipher_spec() {
                this.client_encrypted = true;
                -> $AwaitClientFinished
            }
            status(): string { @@:("await change cipher spec") }
            => $^
        }

        $AwaitClientFinished => $Handshaking {
            client_finished(verify: string) {
                if (verify === "valid") {
                    this.send_change_cipher_spec();
                    this.send_finished();
                    -> $Established
                } else {
                    this.send_alert();
                    -> $Closed
                }
            }
            status(): string { @@:("await client finished") }
            => $^
        }

        $Handshaking {
            alert(level: string, desc: string) {
                if (level === "fatal") {
                    -> $Closed
                }
            }
        }

        $Established {
            alert(level: string, desc: string) {
                if (level === "fatal") {
                    -> $Closed
                }
            }
            status(): string { @@:("established") }
        }

        $Closed {
            status(): string { @@:("closed") }
        }

    actions:
        send_server_hello() {}
        send_certificate() {}
        send_server_hello_done() {}
        derive_keys() {}
        send_change_cipher_spec() {}
        send_finished() {}
        send_alert() {}

    domain:
        client_version = ""
        selected_cipher = ""
        premaster = ""
        client_encrypted = false
}


function check(label, actual, expected) {
    if (actual !== expected) {
        console.log(`FAIL: ${label} — expected '${expected}', got '${actual}'`);
        throw new Error(`assertion failed: ${label}`);
    }
}

function test_happy_handshake() {
    const tls = @@TlsServerHandshake();
    check("initial idle", tls.status(), "idle");
    tls.client_hello("TLS 1.2", "TLS_RSA_WITH_AES_128_CBC_SHA");
    check("after client_hello -> through ServerHello to await", tls.status(), "await key exchange");
    tls.client_key_exchange("premaster_data");
    check("after key exchange", tls.status(), "await change cipher spec");
    tls.client_change_cipher_spec();
    check("after CCS", tls.status(), "await client finished");
    tls.client_finished("valid");
    check("established", tls.status(), "established");
    console.log("PASS: happy TLS handshake");
}

function test_unsupported_cipher_closes() {
    const tls = @@TlsServerHandshake();
    tls.client_hello("TLS 1.2", "TLS_NULL_WITH_NULL_NULL");
    check("no matching cipher -> closed", tls.status(), "closed");
    console.log("PASS: unsupported cipher closes handshake");
}

function test_fatal_alert_during_handshake() {
    const tls = @@TlsServerHandshake();
    tls.client_hello("TLS 1.2", "TLS_RSA_WITH_AES_128_CBC_SHA");
    tls.alert("fatal", "unexpected_message");
    check("fatal alert -> closed (via HSM parent)", tls.status(), "closed");
    console.log("PASS: fatal alert forwards via HSM parent to $Closed");
}

function test_warning_alert_ignored() {
    const tls = @@TlsServerHandshake();
    tls.client_hello("TLS 1.2", "TLS_RSA_WITH_AES_128_CBC_SHA");
    tls.alert("warning", "close_notify_soon");
    check("warning alert doesn't close", tls.status(), "await key exchange");
    console.log("PASS: warning alert doesn't close handshake");
}

function test_invalid_finished_closes() {
    const tls = @@TlsServerHandshake();
    tls.client_hello("TLS 1.2", "TLS_RSA_WITH_AES_128_CBC_SHA");
    tls.client_key_exchange("bogus");
    tls.client_change_cipher_spec();
    tls.client_finished("invalid");
    check("bad verify -> closed", tls.status(), "closed");
    console.log("PASS: invalid client_finished closes");
}

function test_fatal_alert_in_established() {
    const tls = @@TlsServerHandshake();
    tls.client_hello("TLS 1.2", "TLS_RSA_WITH_AES_128_CBC_SHA");
    tls.client_key_exchange("pm");
    tls.client_change_cipher_spec();
    tls.client_finished("valid");
    check("established", tls.status(), "established");
    tls.alert("fatal", "bad_record_mac");
    check("fatal in $Established -> closed", tls.status(), "closed");
    console.log("PASS: fatal alert in established closes");
}

test_happy_handshake();
test_unsupported_cipher_closes();
test_fatal_alert_during_handshake();
test_warning_alert_ignored();
test_invalid_finished_closes();
test_fatal_alert_in_established();
console.log("PASS: all TLS handshake tests passed");

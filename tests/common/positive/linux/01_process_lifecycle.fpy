@@target python_3

# Process Lifecycle — Linux task states (kernel/sched/core.c semantics)
# Three-level HSM: $Interruptible, $Uninterruptible => $Blocked => $Alive.
# Explicit upward forwarding via `=> $^` encodes per-state signal policy:
# - $Interruptible forwards fatal/stop signals to $Alive, wakes otherwise.
# - $Uninterruptible forwards only SIGKILL (TASK_WAKEKILL), holds others.

@@system TaskLifecycle {
    interface:
        fork(): str
        schedule(): str
        block_on_io(): str
        io_complete(): str
        block_uninterruptible(): str
        send_signal(sig: str): str
        wait_by_parent(): str
        status(): str

    machine:
        $New {
            fork(): str {
                self.pid = self.next_pid()
                @@:("forked")
                -> $Ready
            }
            status(): str { @@:("new") }
        }

        $Ready => $Alive {
            schedule(): str {
                @@:("running")
                -> $Running
            }
            status(): str { @@:("ready") }
            => $^
        }

        $Running => $Alive {
            schedule(): str {
                @@:("preempted")
                -> $Ready
            }
            block_on_io(): str {
                @@:("blocked")
                -> $Interruptible
            }
            block_uninterruptible(): str {
                @@:("blocked (D)")
                -> $Uninterruptible
            }
            status(): str { @@:("running") }
            => $^
        }

        $Interruptible => $Blocked {
            io_complete(): str {
                @@:("woke")
                -> $Ready
            }
            send_signal(sig: str): str {
                if sig == "SIGKILL" or sig == "SIGTERM" or sig == "SIGSTOP":
                    # Fatal and stop signals take precedence over wakeup —
                    # let $Alive handle them.
                    => $^
                else:
                    @@:("interrupted")
                    -> $Ready
            }
            status(): str { @@:("interruptible") }
            => $^
        }

        $Uninterruptible => $Blocked {
            io_complete(): str {
                @@:("woke")
                -> $Ready
            }
            # send_signal NOT handled here — all signals forward via => $^
            # through $Blocked to $Alive. Non-fatal signals hit the "ignored"
            # branch there, matching the kernel's D-state behavior.
            # SIGKILL still gets through, matching TASK_KILLABLE.
            status(): str { @@:("uninterruptible") }
            => $^
        }

        $Blocked => $Alive {
            status(): str { @@:("blocked") }
            => $^
        }

        $Alive {
            send_signal(sig: str): str {
                if sig == "SIGKILL" or sig == "SIGTERM":
                    @@:("exiting")
                    -> $Zombie
                elif sig == "SIGSTOP":
                    @@:("stopped")
                    -> $Stopped
                else:
                    @@:("signal ignored")
            }
        }

        $Stopped {
            send_signal(sig: str): str {
                if sig == "SIGCONT":
                    @@:("continued")
                    -> $Ready
                elif sig == "SIGKILL":
                    @@:("killed while stopped")
                    -> $Zombie
                else:
                    @@:("signal ignored")
            }
            status(): str { @@:("stopped") }
        }

        $Zombie {
            wait_by_parent(): str {
                @@:("reaped")
                -> $Dead
            }
            status(): str { @@:("zombie") }
        }

        $Dead {
            status(): str { @@:("dead") }
        }

    actions:
        next_pid() {
            self.pid_counter = self.pid_counter + 1
            return self.pid_counter
        }

    domain:
        pid: int = 0
        pid_counter: int = 100
}


# ============================================================
# Test Harness
# ============================================================

def check(label, actual, expected):
    if actual != expected:
        print(f"FAIL: {label} — expected {expected!r}, got {actual!r}")
        raise SystemExit(1)

def test_happy_path():
    t = @@TaskLifecycle()
    check("initial status", t.status(), "new")
    check("fork",           t.fork(),     "forked")
    check("after fork",     t.status(),   "ready")
    check("schedule",       t.schedule(), "running")
    check("after schedule", t.status(),   "running")
    check("preempt",        t.schedule(), "preempted")
    check("after preempt",  t.status(),   "ready")
    print("PASS: happy path")

def test_interruptible_wake_by_signal():
    t = @@TaskLifecycle()
    t.fork()
    t.schedule()
    check("block_on_io", t.block_on_io(), "blocked")
    check("interruptible status", t.status(), "interruptible")
    check("SIGUSR1 wakes interruptible",
          t.send_signal("SIGUSR1"), "interrupted")
    check("woke to ready", t.status(), "ready")
    print("PASS: interruptible wake by signal")

def test_uninterruptible_holds_signal():
    t = @@TaskLifecycle()
    t.fork()
    t.schedule()
    check("block_uninterruptible",
          t.block_uninterruptible(), "blocked (D)")
    check("D state", t.status(), "uninterruptible")
    check("SIGUSR1 ignored in D (forwarded to $Alive)",
          t.send_signal("SIGUSR1"), "signal ignored")
    check("still in D", t.status(), "uninterruptible")
    print("PASS: uninterruptible ignores non-fatal signal via $Alive")

def test_sigkill_reaches_d_state():
    t = @@TaskLifecycle()
    t.fork()
    t.schedule()
    t.block_uninterruptible()
    check("SIGKILL forwarded from D through $Alive",
          t.send_signal("SIGKILL"), "exiting")
    check("now zombie", t.status(), "zombie")
    check("reap", t.wait_by_parent(), "reaped")
    check("dead", t.status(), "dead")
    print("PASS: SIGKILL reaches D state via $Alive forwarding")

def test_sigstop_sigcont():
    t = @@TaskLifecycle()
    t.fork()
    t.schedule()
    check("SIGSTOP from running",
          t.send_signal("SIGSTOP"), "stopped")
    check("stopped status", t.status(), "stopped")
    check("SIGCONT resumes", t.send_signal("SIGCONT"), "continued")
    check("back to ready", t.status(), "ready")
    print("PASS: SIGSTOP/SIGCONT")

if __name__ == '__main__':
    test_happy_path()
    test_interruptible_wake_by_signal()
    test_uninterruptible_holds_signal()
    test_sigkill_reaches_d_state()
    test_sigstop_sigcont()
    print("PASS: all process lifecycle tests passed")

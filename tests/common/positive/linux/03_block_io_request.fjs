@@[target("javascript")]

// Block I/O Request — kernel blk-mq layer semantics.

@@system BlockRequest {
    interface:
        submit(sector: number, size: number): string
        dispatch(): string
        complete(success: boolean): string
        timeout(): string
        status(): string

    machine:
        $Idle {
            submit(sector: number, size: number): string {
                this.sector = sector;
                this.size = size;
                this.attempts = 0;
                @@:("queued")
                -> $Queued
            }
            status(): string { @@:("idle") }
        }

        $Queued {
            dispatch(): string {
                @@:("dispatched")
                -> $InFlight
            }
            status(): string { @@:("queued") }
        }

        $InFlight {
            $>() {
                this.attempts = this.attempts + 1;
                this.start_timeout();
            }
            <$() {
                this.cancel_timeout();
            }

            complete(success: boolean): string {
                if (success) {
                    @@:("done")
                    -> $Done
                } else {
                    if (this.attempts < this.max_retries) {
                        @@:("requeued")
                        -> $Queued
                    } else {
                        @@:("io error")
                        -> $Error
                    }
                }
            }
            timeout(): string {
                if (this.attempts < this.max_retries) {
                    @@:("timeout, retrying")
                    -> $Queued
                } else {
                    @@:("timeout, giving up")
                    -> $Error
                }
            }
            status(): string { @@:("in-flight") }
        }

        $Done {
            status(): string { @@:("done") }
        }

        $Error {
            status(): string { @@:("error") }
        }

    actions:
        start_timeout() {}
        cancel_timeout() {}

    domain:
        sector = 0
        size = 0
        attempts = 0
        max_retries = 3
        timeout_ms = 30000
}


function check(label, actual, expected) {
    if (actual !== expected) {
        console.log(`FAIL: ${label} — expected '${expected}', got '${actual}'`);
        throw new Error(`assertion failed: ${label}`);
    }
}

function test_happy_path() {
    const req = @@BlockRequest();
    check("initial idle",   req.status(),           "idle");
    check("submit",         req.submit(1024, 8),    "queued");
    check("dispatch",       req.dispatch(),         "dispatched");
    check("complete ok",    req.complete(true),     "done");
    check("terminal done",  req.status(),           "done");
    console.log("PASS: happy path");
}

function test_timeout_retry_then_complete() {
    const req = @@BlockRequest();
    req.submit(2048, 4);
    req.dispatch();
    check("first timeout -> retry", req.timeout(), "timeout, retrying");
    check("back to queued after timeout", req.status(), "queued");
    req.dispatch();
    check("complete after retry", req.complete(true), "done");
    console.log("PASS: timeout then retry success");
}

function test_failure_requeue_then_success() {
    const req = @@BlockRequest();
    req.submit(4096, 2);
    req.dispatch();
    check("complete(false) -> requeued", req.complete(false), "requeued");
    req.dispatch();
    check("complete(true) -> done", req.complete(true), "done");
    console.log("PASS: failure requeue then success");
}

function test_retry_exhaustion() {
    const req = @@BlockRequest();
    req.submit(8192, 1);
    req.dispatch();
    check("req 1 failure requeued", req.complete(false), "requeued");
    req.dispatch();
    check("req 2 failure requeued", req.complete(false), "requeued");
    req.dispatch();
    check("req 3 failure -> io error", req.complete(false), "io error");
    check("terminal error state", req.status(), "error");
    console.log("PASS: retry exhaustion -> error");
}

function test_timeout_exhaustion() {
    const req = @@BlockRequest();
    req.submit(16384, 1);
    req.dispatch();
    check("to 1 retry", req.timeout(), "timeout, retrying");
    req.dispatch();
    check("to 2 retry", req.timeout(), "timeout, retrying");
    req.dispatch();
    check("to 3 giving up", req.timeout(), "timeout, giving up");
    check("error terminal", req.status(), "error");
    console.log("PASS: timeout exhaustion -> error");
}

test_happy_path();
test_timeout_retry_then_complete();
test_failure_requeue_then_success();
test_retry_exhaustion();
test_timeout_exhaustion();
console.log("PASS: all block I/O request tests passed");

@@[target("php")]


// Signal Handler Stack — textbook push$/pop$ use case.

@@system SignalContext {
    interface:
        enter_user_code()
        signal_arrives(sig: str)
        handler_returns()
        current_mode(): str
        depth(): int
        current_signum(): str

    machine:
        $Kernel {
            enter_user_code() {
                -> $UserMode
            }
            current_mode(): str { @@:("kernel") }
            depth(): int { @@:($this->nesting) }
            current_signum(): str { @@:("") }
        }

        $UserMode {
            $.saved_regs = ""

            $>() {
                $.saved_regs = $this->snapshot_registers();
            }

            signal_arrives(sig: str) {
                $this->nesting = $this->nesting + 1;
                push$
                -> (sig) $SignalHandler
            }
            current_mode(): str { @@:("user") }
            depth(): int { @@:($this->nesting) }
            current_signum(): str { @@:("") }
        }

        $SignalHandler {
            $.signum = ""

            $>(sig: str) {
                $.signum = sig;
            }

            signal_arrives(sig: str) {
                $this->nesting = $this->nesting + 1;
                push$
                -> (sig) $SignalHandler
            }

            handler_returns() {
                $this->nesting = $this->nesting - 1;
                -> pop$
            }

            current_mode(): str { @@:("handler") }
            depth(): int { @@:($this->nesting) }
            current_signum(): str { @@:($.signum) }
        }

    actions:
        snapshot_registers() {
            return "regs_snapshot";
        }

    domain:
        nesting = 0
}


function check_value($label, $actual, $expected) {
    if ($actual !== $expected) {
        echo "FAIL: $label -- expected '$expected', got '$actual'\n";
        exit(1);
    }
}

function test_enter_user_mode() {
    $cpu = @@SignalContext();
    check_value("initial kernel", $cpu->current_mode(), "kernel");
    $cpu->enter_user_code();
    check_value("in user mode", $cpu->current_mode(), "user");
    check_value("depth 0", $cpu->depth(), 0);
    echo "PASS: enter user mode\n";
}

function test_single_signal_handler() {
    $cpu = @@SignalContext();
    $cpu->enter_user_code();
    $cpu->signal_arrives("SIGUSR1");
    check_value("in handler", $cpu->current_mode(), "handler");
    check_value("signum SIGUSR1", $cpu->current_signum(), "SIGUSR1");
    check_value("depth 1", $cpu->depth(), 1);
    $cpu->handler_returns();
    check_value("back to user", $cpu->current_mode(), "user");
    check_value("depth 0", $cpu->depth(), 0);
    echo "PASS: single signal handler + return\n";
}

function test_nested_signals() {
    $cpu = @@SignalContext();
    $cpu->enter_user_code();
    $cpu->signal_arrives("SIGUSR1");
    check_value("outer handler signum", $cpu->current_signum(), "SIGUSR1");
    $cpu->signal_arrives("SIGALRM");
    check_value("inner handler signum", $cpu->current_signum(), "SIGALRM");
    check_value("nested depth 2", $cpu->depth(), 2);
    $cpu->handler_returns();
    check_value("popped to outer handler", $cpu->current_mode(), "handler");
    check_value("outer signum preserved across pop", $cpu->current_signum(), "SIGUSR1");
    check_value("depth 1", $cpu->depth(), 1);
    $cpu->handler_returns();
    check_value("back to user", $cpu->current_mode(), "user");
    check_value("depth 0", $cpu->depth(), 0);
    echo "PASS: nested signals (push\$/pop\$ preserves state vars)\n";
}

function test_deeply_nested_signals() {
    $cpu = @@SignalContext();
    $cpu->enter_user_code();
    $cpu->signal_arrives("SIG1");
    $cpu->signal_arrives("SIG2");
    $cpu->signal_arrives("SIG3");
    $cpu->signal_arrives("SIG4");
    check_value("depth 4", $cpu->depth(), 4);
    check_value("top signum", $cpu->current_signum(), "SIG4");
    $cpu->handler_returns();
    check_value("after pop 1: SIG3", $cpu->current_signum(), "SIG3");
    $cpu->handler_returns();
    check_value("after pop 2: SIG2", $cpu->current_signum(), "SIG2");
    $cpu->handler_returns();
    check_value("after pop 3: SIG1", $cpu->current_signum(), "SIG1");
    $cpu->handler_returns();
    check_value("back to user", $cpu->current_mode(), "user");
    echo "PASS: 4-deep nested signal stack\n";
}

test_enter_user_mode();
test_single_signal_handler();
test_nested_signals();
test_deeply_nested_signals();
echo "PASS: all signal handler stack tests passed\n";

@@[target("php")]

<?php

// Wi-Fi Station Management -- IEEE 802.11 station state machine.

@@system WifiStation {
    interface:
        scan_done(bssid: str, ssid: str)
        auth_response(success: bool)
        assoc_response(success: bool, aid: int)
        eapol_key_msg(msg_num: int)
        deauth(reason: str)
        disassoc(reason: str)
        disconnect()
        status(): str
        key_step(): int

    machine:
        $Disconnected {
            scan_done(bssid: str, ssid: str) {
                $this->bssid = $bssid;
                $this->ssid = $ssid;
                -> $Authenticating
            }
            status(): str { @@:("disconnected") }
            key_step(): int { @@:(0) }
        }

        $Authenticating => $Associated {
            $>() {
                $this->send_auth_request();
            }

            auth_response(success: bool) {
                if ($success) {
                    -> $Associating
                } else {
                    -> $Disconnected
                }
            }
            status(): str { @@:("authenticating") }
            key_step(): int { @@:(0) }
            => $^
        }

        $Associating => $Associated {
            $>() {
                $this->send_assoc_request();
            }

            assoc_response(success: bool, aid: int) {
                if ($success) {
                    $this->aid = $aid;
                    -> $KeyNegotiation
                } else {
                    -> $Disconnected
                }
            }
            disassoc(reason: str) {
                -> $Authenticating
            }
            status(): str { @@:("associating") }
            key_step(): int { @@:(0) }
            => $^
        }

        $KeyNegotiation => $Associated {
            $.step = 0

            eapol_key_msg(msg_num: int) {
                $.step = $msg_num;
                if ($msg_num === 4) {
                    -> $Connected
                }
            }
            disassoc(reason: str) {
                -> $Authenticating
            }
            status(): str { @@:("key negotiation") }
            key_step(): int { @@:($.step) }
            => $^
        }

        $Associated {
            deauth(reason: str) {
                -> $Disconnected
            }
            disconnect() {
                $this->send_deauth();
                -> $Disconnected
            }
        }

        $Connected {
            disassoc(reason: str) {
                -> $Authenticating
            }
            deauth(reason: str) {
                -> $Disconnected
            }
            disconnect() {
                $this->send_deauth();
                -> $Disconnected
            }
            status(): str { @@:("connected") }
            key_step(): int { @@:(4) }
        }

    actions:
        send_auth_request() {}
        send_assoc_request() {}
        send_deauth() {}

    domain:
        bssid = ""
        ssid = ""
        aid = 0
}


function check_value($label, $actual, $expected) {
    if ($actual !== $expected) {
        echo "FAIL: $label -- expected '$expected', got '$actual'\n";
        exit(1);
    }
}

function test_happy_connect() {
    $sta = @@WifiStation();
    check_value("initial disconnected", $sta->status(), "disconnected");
    $sta->scan_done("AA:BB:CC:DD:EE:FF", "MyNet");
    check_value("authenticating", $sta->status(), "authenticating");
    $sta->auth_response(true);
    check_value("associating", $sta->status(), "associating");
    $sta->assoc_response(true, 1);
    check_value("key negotiation", $sta->status(), "key negotiation");
    $sta->eapol_key_msg(1);
    check_value("step 1", $sta->key_step(), 1);
    $sta->eapol_key_msg(2);
    check_value("step 2", $sta->key_step(), 2);
    $sta->eapol_key_msg(3);
    check_value("step 3", $sta->key_step(), 3);
    $sta->eapol_key_msg(4);
    check_value("connected", $sta->status(), "connected");
    echo "PASS: happy connect through 4-way handshake\n";
}

function test_auth_rejection() {
    $sta = @@WifiStation();
    $sta->scan_done("aa", "net");
    $sta->auth_response(false);
    check_value("auth rejected -> disconnected", $sta->status(), "disconnected");
    echo "PASS: auth rejection returns to disconnected\n";
}

function test_deauth_from_keynegotiation_via_hsm() {
    $sta = @@WifiStation();
    $sta->scan_done("aa", "net");
    $sta->auth_response(true);
    $sta->assoc_response(true, 5);
    $sta->eapol_key_msg(2);
    check_value("in key negotiation", $sta->status(), "key negotiation");
    $sta->deauth("AP restart");
    check_value("deauth forwarded via HSM -> disconnected", $sta->status(), "disconnected");
    echo "PASS: deauth forwards via HSM parent from key negotiation\n";
}

function test_disassoc_drops_to_authenticating() {
    $sta = @@WifiStation();
    $sta->scan_done("aa", "net");
    $sta->auth_response(true);
    $sta->assoc_response(true, 7);
    $sta->eapol_key_msg(2);
    $sta->disassoc("reason");
    check_value("disassoc -> authenticating", $sta->status(), "authenticating");
    $sta->assoc_response(true, 7);
    check_value("step resets on reentry", $sta->key_step(), 0);
    echo "PASS: disassoc drops to authenticating (state var resets)\n";
}

function test_deauth_from_connected() {
    $sta = @@WifiStation();
    $sta->scan_done("aa", "net");
    $sta->auth_response(true);
    $sta->assoc_response(true, 3);
    $sta->eapol_key_msg(4);
    check_value("connected", $sta->status(), "connected");
    $sta->deauth("inactivity");
    check_value("deauth from connected", $sta->status(), "disconnected");
    echo "PASS: deauth from connected returns to disconnected\n";
}

function test_disconnect_from_connected() {
    $sta = @@WifiStation();
    $sta->scan_done("aa", "net");
    $sta->auth_response(true);
    $sta->assoc_response(true, 3);
    $sta->eapol_key_msg(4);
    $sta->disconnect();
    check_value("disconnect from connected", $sta->status(), "disconnected");
    echo "PASS: explicit disconnect from connected\n";
}

test_happy_connect();
test_auth_rejection();
test_deauth_from_keynegotiation_via_hsm();
test_disassoc_drops_to_authenticating();
test_deauth_from_connected();
test_disconnect_from_connected();
echo "PASS: all Wi-Fi station tests passed\n";

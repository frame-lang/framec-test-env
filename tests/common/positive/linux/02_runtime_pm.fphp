@@[target("php")]

<?php

// Runtime Power Management — kernel drivers/base/power/runtime.c semantics.

@@system RuntimePM {
    interface:
        get(): str
        put(): str
        autosuspend_expired(): str
        resume_complete(): str
        suspend_complete(success: bool): str
        status(): str

    machine:
        $Active {
            $>() {
                $this->cancel_timer();
            }

            get(): str {
                $this->usage_count = $this->usage_count + 1;
                @@:("get: usage=" . $this->usage_count)
            }
            put(): str {
                $this->usage_count = $this->usage_count - 1;
                @@:("put: usage=" . $this->usage_count)
                if ($this->usage_count <= 0) {
                    -> $Idle
                }
            }
            status(): str { @@:("active") }
        }

        $Idle {
            $>() {
                $this->start_autosuspend_timer();
            }
            <$() {
                $this->cancel_timer();
            }

            get(): str {
                $this->usage_count = $this->usage_count + 1;
                @@:("get: usage=" . $this->usage_count)
                -> $Active
            }
            autosuspend_expired(): str {
                @@:("suspending")
                -> $Suspending
            }
            status(): str { @@:("idle") }
        }

        $Suspending {
            $>() {
                $this->call_suspend_callback();
            }

            suspend_complete(success: bool): str {
                if ($success) {
                    @@:("suspended")
                    -> $Suspended
                } else {
                    @@:("suspend failed")
                    -> $Active
                }
            }
            get(): str {
                $this->usage_count = $this->usage_count + 1;
                @@:("resume requested during suspend")
                -> $Resuming
            }
            status(): str { @@:("suspending") }
        }

        $Suspended {
            get(): str {
                $this->usage_count = $this->usage_count + 1;
                @@:("waking")
                -> $Resuming
            }
            status(): str { @@:("suspended") }
        }

        $Resuming {
            $>() {
                $this->call_resume_callback();
            }

            resume_complete(): str {
                @@:("resumed")
                -> $Active
            }
            status(): str { @@:("resuming") }
        }

    actions:
        start_autosuspend_timer() {}
        cancel_timer() {}
        call_suspend_callback() {}
        call_resume_callback() {}

    domain:
        usage_count = 1
        autosuspend_delay_ms = 500
}


function check_value($label, $actual, $expected) {
    if ($actual !== $expected) {
        echo "FAIL: $label — expected '$expected', got '$actual'\n";
        exit(1);
    }
}

function test_happy_idle_suspend_resume() {
    $dev = @@RuntimePM();
    check_value("initial active", $dev->status(), "active");
    check_value("put drops to 0", $dev->put(), "put: usage=0");
    check_value("idle after drain", $dev->status(), "idle");
    check_value("autosuspend fires", $dev->autosuspend_expired(), "suspending");
    check_value("suspend_complete true", $dev->suspend_complete(true), "suspended");
    check_value("get wakes", $dev->get(), "waking");
    check_value("resuming status", $dev->status(), "resuming");
    check_value("resume_complete", $dev->resume_complete(), "resumed");
    check_value("back to active", $dev->status(), "active");
    echo "PASS: happy path (active -> idle -> suspended -> resumed)\n";
}

function test_suspend_failure_returns_to_active() {
    $dev = @@RuntimePM();
    $dev->put();
    $dev->autosuspend_expired();
    check_value("suspend failed", $dev->suspend_complete(false), "suspend failed");
    check_value("reverted to active", $dev->status(), "active");
    echo "PASS: suspend failure -> active\n";
}

function test_get_during_suspending_redirects_to_resuming() {
    $dev = @@RuntimePM();
    $dev->put();
    $dev->autosuspend_expired();
    check_value("suspending state", $dev->status(), "suspending");
    check_value("get during suspend", $dev->get(), "resume requested during suspend");
    check_value("redirected to resuming", $dev->status(), "resuming");
    echo "PASS: get during suspending redirects to resuming\n";
}

function test_usage_count_mgmt() {
    $dev = @@RuntimePM();
    check_value("get +1", $dev->get(), "get: usage=2");
    check_value("get +1 again", $dev->get(), "get: usage=3");
    check_value("put -1", $dev->put(), "put: usage=2");
    check_value("put -1", $dev->put(), "put: usage=1");
    check_value("put to 0 -> idle", $dev->put(), "put: usage=0");
    check_value("idle", $dev->status(), "idle");
    echo "PASS: usage count tracking\n";
}

test_happy_idle_suspend_resume();
test_suspend_failure_returns_to_active();
test_get_during_suspending_redirects_to_resuming();
test_usage_count_mgmt();
echo "PASS: all runtime PM tests passed\n";

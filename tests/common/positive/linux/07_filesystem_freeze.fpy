@@[target("python_3")]

# Filesystem Freeze — VFS fs/super.c semantics. 3-level HSM:
#   $Active => $Readable => $Mounted
#   $Frozen => $Readable => $Mounted
# $Mounted provides read/sync/unmount for all mounted sub-states.
# $Active adds write/freeze. $Frozen overrides write to block and adds thaw.
# $Freezing is transient, bypasses $Readable (state in flux during flush).

@@system Filesystem {
    interface:
        mount(device: str): str
        unmount(): str
        freeze(): str
        thaw(): str
        write(data: str): str
        read(): str
        sync(): str
        status(): str
        read_count(): int
        write_count(): int

    machine:
        $Unmounted {
            mount(device: str): str {
                self.device = device
                @@:("mounted")
                -> $Active
            }
            status(): str { @@:("unmounted") }
            read_count(): int { @@:(self.reads) }
            write_count(): int { @@:(self.writes) }
        }

        $Active => $Readable {
            write(data: str): str {
                self.writes = self.writes + 1
                @@:("wrote")
            }
            freeze(): str {
                @@:("freezing")
                -> $Freezing
            }
            status(): str { @@:("active") }
            => $^
        }

        $Freezing => $Mounted {
            $>() {
                self.flush_pending_writes()
                -> $Frozen
            }
            status(): str { @@:("freezing") }
            => $^
        }

        $Frozen => $Readable {
            write(data: str): str {
                @@:("BLOCKED")
            }
            thaw(): str {
                @@:("thawed")
                -> $Active
            }
            status(): str { @@:("frozen") }
            => $^
        }

        $Readable => $Mounted {
            => $^
        }

        $Mounted {
            read(): str {
                self.reads = self.reads + 1
                @@:("read")
            }
            sync(): str {
                @@:("synced")
            }
            unmount(): str {
                @@:("unmounting")
                -> $Unmounting
            }
            read_count(): int { @@:(self.reads) }
            write_count(): int { @@:(self.writes) }
        }

        $Unmounting {
            $>() {
                self.flush_pending_writes()
                self.release_resources()
                -> $Unmounted
            }
        }

    actions:
        flush_pending_writes()  { pass }
        release_resources()     { pass }

    domain:
        device: str = ""
        writes: int = 0
        reads: int = 0
}


def check(label, actual, expected):
    if actual != expected:
        print(f"FAIL: {label} — expected {expected!r}, got {actual!r}")
        raise SystemExit(1)

def test_mount_write_read():
    fs = @@Filesystem()
    check("initial unmounted", fs.status(), "unmounted")
    check("mount", fs.mount("/dev/sda1"), "mounted")
    check("active state", fs.status(), "active")
    check("write 1", fs.write("hello"), "wrote")
    check("read 1", fs.read(), "read")
    check("sync via HSM", fs.sync(), "synced")
    check("read count incremented", fs.read_count(), 1)
    check("write count incremented", fs.write_count(), 1)
    print("PASS: mount + write + read + sync")

def test_freeze_blocks_writes_allows_reads():
    fs = @@Filesystem()
    fs.mount("/dev/sda1")
    fs.write("before freeze")
    fs.freeze()
    # After freeze(), enter handler of $Freezing transitions to $Frozen
    check("in frozen state", fs.status(), "frozen")
    # Writes blocked in $Frozen
    check("write blocked", fs.write("nope"), "BLOCKED")
    # But reads still work via HSM parent $Mounted
    check("read still works", fs.read(), "read")
    check("read count 1", fs.read_count(), 1)
    # Writes counter didn't increment on blocked write
    check("write count unchanged", fs.write_count(), 1)
    print("PASS: freeze blocks writes, allows reads (3-level HSM)")

def test_thaw_restores_write():
    fs = @@Filesystem()
    fs.mount("/dev/sda1")
    fs.freeze()
    check("thaw", fs.thaw(), "thawed")
    check("back to active", fs.status(), "active")
    check("write works again", fs.write("post-thaw"), "wrote")
    print("PASS: thaw restores write capability")

def test_unmount_forwards_via_hsm():
    # unmount() is defined on $Mounted. When called from $Active
    # (a grandchild two levels deep), forwards up via => $^.
    fs = @@Filesystem()
    fs.mount("/dev/sda1")
    check("unmount from Active", fs.unmount(), "unmounting")
    check("eventually unmounted", fs.status(), "unmounted")
    print("PASS: unmount forwards from Active via $Readable to $Mounted")

def test_freeze_impossible_when_unmounted():
    # freeze() is only defined on $Active. In $Unmounted, there's no
    # handler and no upward chain that handles it → no-op.
    fs = @@Filesystem()
    check("freeze unmounted = no-op (no handler)",
          fs.freeze(), None)
    check("still unmounted", fs.status(), "unmounted")
    print("PASS: freeze on unmounted fs is no-op")

def test_read_count_accumulates_across_states():
    fs = @@Filesystem()
    fs.mount("/dev/sda1")
    fs.read()
    fs.read()
    fs.freeze()
    fs.read()   # in $Frozen
    fs.thaw()
    fs.read()   # back in $Active
    check("reads across Active/Frozen/Active",
          fs.read_count(), 4)
    print("PASS: read count spans states (domain var)")

if __name__ == '__main__':
    test_mount_write_read()
    test_freeze_blocks_writes_allows_reads()
    test_thaw_restores_write()
    test_unmount_forwards_via_hsm()
    test_freeze_impossible_when_unmounted()
    test_read_count_accumulates_across_states()
    print("PASS: all filesystem freeze tests passed")

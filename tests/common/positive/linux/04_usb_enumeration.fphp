@@target php

<?php

// USB Device Enumeration — multi-stage pipeline with compensation (saga).

@@system UsbEnumerator {
    interface:
        plug_in(port: int)
        reset_done(success: bool)
        address_set(success: bool, addr: int)
        descriptors_read(success: bool, product: str)
        driver_bound(success: bool)
        unplug()
        status(): str

    machine:
        $Detached {
            plug_in(port: int) {
                $this->port = $port;
                $this->reset_attempts = 0;
                -> $Resetting
            }
            status(): str { @@:("detached") }
        }

        $Resetting => $Enumerating {
            $>() {
                $this->reset_attempts = $this->reset_attempts + 1;
                $this->issue_port_reset($this->port);
            }

            reset_done(success: bool) {
                if ($success) {
                    -> $Addressing
                } else {
                    if ($this->reset_attempts < $this->max_reset_attempts) {
                        -> $Resetting
                    } else {
                        -> $Failed
                    }
                }
            }
            status(): str { @@:("resetting") }
            => $^
        }

        $Addressing => $Enumerating {
            $>() {
                $this->assign_address();
            }

            address_set(success: bool, addr: int) {
                if ($success) {
                    $this->address = $addr;
                    -> $ReadingDescriptors
                } else {
                    -> $UndoReset
                }
            }
            status(): str { @@:("addressing") }
            => $^
        }

        $ReadingDescriptors => $Enumerating {
            $>() {
                $this->read_descriptors($this->address);
            }

            descriptors_read(success: bool, product: str) {
                if ($success) {
                    $this->product = $product;
                    -> $BindingDriver
                } else {
                    -> $UndoAddress
                }
            }
            status(): str { @@:("reading descriptors") }
            => $^
        }

        $BindingDriver => $Enumerating {
            $>() {
                $this->bind_driver($this->product);
            }

            driver_bound(success: bool) {
                if ($success) {
                    -> $Configured
                } else {
                    -> $UndoAddress
                }
            }
            status(): str { @@:("binding driver") }
            => $^
        }

        $Enumerating {
            unplug() {
                -> $Detached
            }
        }

        $UndoAddress {
            $>() {
                $this->release_address($this->address);
                -> $UndoReset
            }
        }

        $UndoReset {
            $>() {
                $this->disable_port($this->port);
                -> $Failed
            }
        }

        $Configured {
            unplug() {
                $this->unbind_driver();
                $this->release_address($this->address);
                $this->disable_port($this->port);
                -> $Detached
            }
            status(): str { @@:("configured") }
        }

        $Failed {
            plug_in(port: int) {
                $this->port = $port;
                $this->reset_attempts = 0;
                -> $Resetting
            }
            status(): str { @@:("failed") }
        }

    actions:
        issue_port_reset(port) {}
        assign_address() {}
        read_descriptors(addr) {}
        bind_driver(product) {}
        release_address(addr) {}
        disable_port(port) {}
        unbind_driver() {}

    domain:
        port = 0
        address = 0
        product = ""
        reset_attempts = 0
        max_reset_attempts = 3
}


function check_value($label, $actual, $expected) {
    if ($actual !== $expected) {
        echo "FAIL: $label — expected '$expected', got '$actual'\n";
        exit(1);
    }
}

function test_happy_path() {
    $usb = @@UsbEnumerator();
    check_value("initial detached", $usb->status(), "detached");
    $usb->plug_in(1);
    check_value("after plug_in", $usb->status(), "resetting");
    $usb->reset_done(true);
    check_value("reset ok -> addressing", $usb->status(), "addressing");
    $usb->address_set(true, 7);
    check_value("address ok -> reading", $usb->status(), "reading descriptors");
    $usb->descriptors_read(true, "USB Keyboard");
    check_value("descriptors ok -> binding", $usb->status(), "binding driver");
    $usb->driver_bound(true);
    check_value("driver bound -> configured", $usb->status(), "configured");
    echo "PASS: happy path enumeration\n";
}

function test_descriptor_failure_compensates() {
    $usb = @@UsbEnumerator();
    $usb->plug_in(2);
    $usb->reset_done(true);
    $usb->address_set(true, 8);
    $usb->descriptors_read(false, "");
    check_value("compensated to failed", $usb->status(), "failed");
    echo "PASS: descriptor failure compensation\n";
}

function test_driver_bind_failure_compensates() {
    $usb = @@UsbEnumerator();
    $usb->plug_in(3);
    $usb->reset_done(true);
    $usb->address_set(true, 9);
    $usb->descriptors_read(true, "Mouse");
    $usb->driver_bound(false);
    check_value("bind fail compensated to failed", $usb->status(), "failed");
    echo "PASS: driver bind failure compensation\n";
}

function test_unplug_during_enumeration() {
    $usb = @@UsbEnumerator();
    $usb->plug_in(4);
    check_value("in resetting", $usb->status(), "resetting");
    $usb->unplug();
    check_value("unplug -> detached", $usb->status(), "detached");
    echo "PASS: unplug during enumeration forwards via HSM\n";
}

function test_reset_retry_then_exhaust() {
    $usb = @@UsbEnumerator();
    $usb->plug_in(5);
    $usb->reset_done(false);
    check_value("retry 1", $usb->status(), "resetting");
    $usb->reset_done(false);
    check_value("retry 2", $usb->status(), "resetting");
    $usb->reset_done(false);
    check_value("exhausted -> failed", $usb->status(), "failed");
    echo "PASS: reset retry exhaustion\n";
}

function test_replug_from_failed() {
    $usb = @@UsbEnumerator();
    $usb->plug_in(6);
    $usb->reset_done(false);
    $usb->reset_done(false);
    $usb->reset_done(false);
    check_value("failed state", $usb->status(), "failed");
    $usb->plug_in(6);
    check_value("re-plug restarts enumeration", $usb->status(), "resetting");
    echo "PASS: re-plug from failed state\n";
}

test_happy_path();
test_descriptor_failure_compensates();
test_driver_bind_failure_compensates();
test_unplug_during_enumeration();
test_reset_retry_then_exhaust();
test_replug_from_failed();
echo "PASS: all USB enumeration tests passed\n";

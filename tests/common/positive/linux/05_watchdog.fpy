@@target python_3

# Watchdog Timer — kernel drivers/watchdog/watchdog_dev.c magic-close semantics.
# The device stays armed unless close() follows a write containing 'V'
# (the magic character). Safety-by-construction: the only path from
# $Armed to $Inactive requires self.magic_seen == True.

@@system WatchdogDevice {
    interface:
        open(): str
        write(data: str): str
        ping(): str
        close(): str
        timeout_expired(): str
        status(): str

    machine:
        $Inactive {
            open(): str {
                @@:("opened")
                -> $Armed
            }
            status(): str { @@:("inactive") }
        }

        $Armed {
            $>() {
                self.magic_seen = False
                self.start_hw_timer()
            }

            ping(): str {
                self.reset_hw_timer()
                @@:("pinged")
            }
            write(data: str): str {
                if "V" in data:
                    self.magic_seen = True
                    @@:("magic character received")
                else:
                    @@:("data written")
                self.reset_hw_timer()
            }
            close(): str {
                if self.magic_seen:
                    self.stop_hw_timer()
                    @@:("disarmed")
                    -> $Inactive
                else:
                    @@:("close ignored -- no magic char")
            }
            timeout_expired(): str {
                @@:("SYSTEM RESET")
                -> $Triggered
            }
            status(): str {
                if self.magic_seen:
                    @@:("armed (magic seen, close will disarm)")
                else:
                    @@:("armed")
            }
        }

        $Triggered {
            status(): str { @@:("triggered -- system reset") }
        }

    actions:
        start_hw_timer()  { pass }
        reset_hw_timer()  { pass }
        stop_hw_timer()   { pass }

    domain:
        timeout_sec: int = 60
        magic_seen: bool = False
}


def check(label, actual, expected):
    if actual != expected:
        print(f"FAIL: {label} — expected {expected!r}, got {actual!r}")
        raise SystemExit(1)

def test_open_and_ping():
    wd = @@WatchdogDevice()
    check("initial inactive", wd.status(), "inactive")
    check("open returns opened", wd.open(), "opened")
    check("armed after open", wd.status(), "armed")
    check("ping", wd.ping(), "pinged")
    check("still armed after ping", wd.status(), "armed")
    print("PASS: open and ping")

def test_close_without_magic_is_ignored():
    wd = @@WatchdogDevice()
    wd.open()
    check("close without magic",
          wd.close(), "close ignored -- no magic char")
    check("still armed after bad close", wd.status(), "armed")
    print("PASS: close without magic ignored (safety property)")

def test_magic_char_then_close_disarms():
    wd = @@WatchdogDevice()
    wd.open()
    check("write with V sets magic",
          wd.write("goodbye V"), "magic character received")
    check("status shows magic seen",
          wd.status(), "armed (magic seen, close will disarm)")
    check("close after magic disarms", wd.close(), "disarmed")
    check("back to inactive", wd.status(), "inactive")
    print("PASS: magic char then close disarms")

def test_write_without_magic_is_plain_data():
    wd = @@WatchdogDevice()
    wd.open()
    check("write without V",
          wd.write("abcdef"), "data written")
    check("still armed with no magic",
          wd.status(), "armed")
    print("PASS: write without magic is plain data")

def test_timeout_triggers_reset():
    wd = @@WatchdogDevice()
    wd.open()
    check("timeout fires", wd.timeout_expired(), "SYSTEM RESET")
    check("terminal triggered state",
          wd.status(), "triggered -- system reset")
    print("PASS: timeout triggers system reset")

def test_reopen_resets_magic_seen():
    # After a proper disarm, reopen: magic_seen must reset to False
    # (enforced by $>() on $Armed re-entry)
    wd = @@WatchdogDevice()
    wd.open()
    wd.write("set V please")
    wd.close()  # disarms
    wd.open()   # re-enters $Armed
    check("magic_seen reset on reopen",
          wd.close(), "close ignored -- no magic char")
    print("PASS: reopen resets magic_seen via enter handler")

if __name__ == '__main__':
    test_open_and_ping()
    test_close_without_magic_is_ignored()
    test_magic_char_then_close_disarms()
    test_write_without_magic_is_plain_data()
    test_timeout_triggers_reset()
    test_reopen_resets_magic_seen()
    print("PASS: all watchdog tests passed")

@@[target("ruby")]

# DHCP Client -- RFC 2131 Figure 5 state machine.

@@system DhcpClient {
    interface:
        start()
        offer_received(server_ip: str, offered_ip: str, lease_sec: int)
        ack_received(ip: str, lease_sec: int)
        nak_received()
        t1_expired()
        t2_expired()
        lease_expired()
        release()
        status(): str

    machine:
        $Init {
            $>() {
                @attempts = 0
            }

            start() {
                -> $Selecting
            }
            status(): str { @@:("init") }
        }

        $Selecting {
            $>() {
                @attempts = @attempts + 1
                broadcast_discover()
            }

            offer_received(server_ip: str, offered_ip: str, lease_sec: int) {
                @server = server_ip
                @offered = offered_ip
                @lease_sec = lease_sec
                -> $Requesting
            }
            status(): str { @@:("selecting") }
        }

        $Requesting {
            $>() {
                send_request()
            }

            ack_received(ip: str, lease_sec: int) {
                @bound = ip
                @lease_sec = lease_sec
                -> $Bound
            }
            nak_received() {
                -> $Init
            }
            status(): str { @@:("requesting") }
        }

        $Bound {
            $>() {
                arm_timers()
            }

            t1_expired() {
                -> $Renewing
            }
            release() {
                cancel_all_timers()
                send_release()
                -> $Init
            }
            status(): str { @@:("bound") }
        }

        $Renewing {
            $>() {
                send_renew()
            }

            ack_received(ip: str, lease_sec: int) {
                @lease_sec = lease_sec
                -> $Bound
            }
            nak_received() {
                cancel_all_timers()
                -> $Init
            }
            t2_expired() {
                -> $Rebinding
            }
            lease_expired() {
                cancel_all_timers()
                -> $Init
            }
            release() {
                cancel_all_timers()
                -> $Init
            }
            status(): str { @@:("renewing") }
        }

        $Rebinding {
            $>() {
                broadcast_renew()
            }

            ack_received(ip: str, lease_sec: int) {
                @lease_sec = lease_sec
                -> $Bound
            }
            nak_received() {
                cancel_all_timers()
                -> $Init
            }
            lease_expired() {
                cancel_all_timers()
                @bound = ""
                -> $Init
            }
            release() {
                cancel_all_timers()
                -> $Init
            }
            status(): str { @@:("rebinding") }
        }

    actions:
        broadcast_discover()    {}
        send_request()          {}
        send_renew()            {}
        broadcast_renew()       {}
        send_release()          {}
        arm_timers()            {}
        cancel_all_timers()     {}

    domain:
        server: str = ""
        offered: str = ""
        bound: str = ""
        lease_sec: int = 0
        attempts: int = 0
}


def check(label, actual, expected)
    if actual != expected
        puts "FAIL: #{label} -- expected '#{expected}', got '#{actual}'"
        exit 1
    end
end

def test_full_lease_acquisition
    dhcp = @@DhcpClient()
    check("initial init", dhcp.status, "init")
    dhcp.start
    check("selecting", dhcp.status, "selecting")
    dhcp.offer_received("192.168.1.1", "192.168.1.100", 3600)
    check("requesting after offer", dhcp.status, "requesting")
    dhcp.ack_received("192.168.1.100", 3600)
    check("bound", dhcp.status, "bound")
    puts "PASS: full lease acquisition Init->Selecting->Requesting->Bound"
end

def test_t1_triggers_renewal
    dhcp = @@DhcpClient()
    dhcp.start
    dhcp.offer_received("10.0.0.1", "10.0.0.100", 7200)
    dhcp.ack_received("10.0.0.100", 7200)
    dhcp.t1_expired
    check("renewing after t1", dhcp.status, "renewing")
    dhcp.ack_received("10.0.0.100", 7200)
    check("back to bound after renew ack", dhcp.status, "bound")
    puts "PASS: T1 triggers renewal, ACK returns to bound"
end

def test_t2_triggers_rebind
    dhcp = @@DhcpClient()
    dhcp.start
    dhcp.offer_received("10.0.0.1", "10.0.0.100", 7200)
    dhcp.ack_received("10.0.0.100", 7200)
    dhcp.t1_expired
    check("renewing", dhcp.status, "renewing")
    dhcp.t2_expired
    check("rebinding after t2", dhcp.status, "rebinding")
    dhcp.ack_received("10.0.0.100", 7200)
    check("rebind ACK -> bound", dhcp.status, "bound")
    puts "PASS: T2 triggers rebind, ACK returns to bound"
end

def test_nak_during_requesting_restarts
    dhcp = @@DhcpClient()
    dhcp.start
    dhcp.offer_received("10.0.0.1", "10.0.0.100", 7200)
    dhcp.nak_received
    check("NAK in Requesting -> Init", dhcp.status, "init")
    puts "PASS: NAK in Requesting restarts"
end

def test_lease_expired_in_rebinding
    dhcp = @@DhcpClient()
    dhcp.start
    dhcp.offer_received("10.0.0.1", "10.0.0.100", 7200)
    dhcp.ack_received("10.0.0.100", 7200)
    dhcp.t1_expired
    dhcp.t2_expired
    dhcp.lease_expired
    check("lease_expired in Rebinding -> Init", dhcp.status, "init")
    puts "PASS: lease expiry in rebinding clears state"
end

def test_release_from_bound
    dhcp = @@DhcpClient()
    dhcp.start
    dhcp.offer_received("10.0.0.1", "10.0.0.100", 7200)
    dhcp.ack_received("10.0.0.100", 7200)
    dhcp.release
    check("release -> init", dhcp.status, "init")
    puts "PASS: release from bound"
end

test_full_lease_acquisition
test_t1_triggers_renewal
test_t2_triggers_rebind
test_nak_during_requesting_restarts
test_lease_expired_in_rebinding
test_release_from_bound
puts "PASS: all DHCP client tests passed"

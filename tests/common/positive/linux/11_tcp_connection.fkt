@@target kotlin

// TCP Connection -- RFC 793 Figure 6 FSM with @@persist for TIME_WAIT.

@@[persist]
@@system TcpConnection {
    interface:
        passive_open()
        active_open()
        recv_syn()
        recv_syn_ack()
        recv_ack()
        recv_fin()
        app_close()
        app_send(bytes_n: Int)
        timeout_2msl()
        abort()
        state_name(): String

    machine:
        $Closed {
            passive_open() { -> $Listen }
            active_open() {
                this.send_syn()
                -> $SynSent
            }
            state_name(): String { @@:("CLOSED") }
        }

        $Listen {
            recv_syn() {
                this.send_syn_ack()
                -> $SynReceived
            }
            app_close() { -> $Closed }
            state_name(): String { @@:("LISTEN") }
        }

        $SynSent {
            recv_syn_ack() {
                this.send_ack()
                -> $Established
            }
            recv_syn() {
                this.send_syn_ack()
                -> $SynReceived
            }
            app_close() { -> $Closed }
            state_name(): String { @@:("SYN_SENT") }
        }

        $SynReceived {
            recv_ack() { -> $Established }
            app_close() {
                this.send_fin()
                -> $FinWait1
            }
            state_name(): String { @@:("SYN_RECEIVED") }
        }

        $Established {
            app_send(bytes_n: Int) {
                this.bytes_sent = this.bytes_sent + bytes_n
            }
            app_close() {
                this.send_fin()
                -> $FinWait1
            }
            recv_fin() {
                this.send_ack()
                -> $CloseWait
            }
            abort() {
                this.send_rst()
                -> $Closed
            }
            state_name(): String { @@:("ESTABLISHED") }
        }

        $FinWait1 {
            recv_ack() { -> $FinWait2 }
            recv_fin() {
                this.send_ack()
                -> $Closing
            }
            state_name(): String { @@:("FIN_WAIT_1") }
        }

        $FinWait2 {
            recv_fin() {
                this.send_ack()
                -> $TimeWait
            }
            state_name(): String { @@:("FIN_WAIT_2") }
        }

        $Closing {
            recv_ack() { -> $TimeWait }
            state_name(): String { @@:("CLOSING") }
        }

        $TimeWait {
            $>() {
                this.start_2msl_timer()
            }
            timeout_2msl() { -> $Closed }
            state_name(): String { @@:("TIME_WAIT") }
        }

        $CloseWait {
            app_close() {
                this.send_fin()
                -> $LastAck
            }
            state_name(): String { @@:("CLOSE_WAIT") }
        }

        $LastAck {
            recv_ack() { -> $Closed }
            state_name(): String { @@:("LAST_ACK") }
        }

    actions:
        send_syn()         {}
        send_syn_ack()     {}
        send_ack()         {}
        send_fin()         {}
        send_rst()         {}
        start_2msl_timer() {}

    domain:
        local_port: Int = 0
        remote_port: Int = 0
        bytes_sent: Int = 0
}


fun check(label: String, actual: String, expected: String) {
    if (actual != expected) {
        println("FAIL: $label -- expected '$expected', got '$actual'")
        kotlin.system.exitProcess(1)
    }
}

fun test_active_open_full_cycle() {
    val c = TcpConnection()
    check("initial CLOSED", c.state_name() as String, "CLOSED")
    c.active_open()
    check("SYN_SENT", c.state_name() as String, "SYN_SENT")
    c.recv_syn_ack()
    check("ESTABLISHED", c.state_name() as String, "ESTABLISHED")
    c.app_send(1024)
    c.app_close()
    check("FIN_WAIT_1", c.state_name() as String, "FIN_WAIT_1")
    c.recv_ack()
    check("FIN_WAIT_2", c.state_name() as String, "FIN_WAIT_2")
    c.recv_fin()
    check("TIME_WAIT", c.state_name() as String, "TIME_WAIT")
    c.timeout_2msl()
    check("back to CLOSED", c.state_name() as String, "CLOSED")
    println("PASS: active open, full cycle to TIME_WAIT")
}

fun test_passive_open_full_cycle() {
    val c = TcpConnection()
    c.passive_open()
    check("LISTEN", c.state_name() as String, "LISTEN")
    c.recv_syn()
    check("SYN_RECEIVED", c.state_name() as String, "SYN_RECEIVED")
    c.recv_ack()
    check("ESTABLISHED", c.state_name() as String, "ESTABLISHED")
    c.recv_fin()
    check("CLOSE_WAIT", c.state_name() as String, "CLOSE_WAIT")
    c.app_close()
    check("LAST_ACK", c.state_name() as String, "LAST_ACK")
    c.recv_ack()
    check("CLOSED", c.state_name() as String, "CLOSED")
    println("PASS: passive open, peer-initiated close")
}

fun test_simultaneous_close() {
    val c = TcpConnection()
    c.active_open()
    c.recv_syn_ack()
    c.app_close()
    check("in FIN_WAIT_1", c.state_name() as String, "FIN_WAIT_1")
    c.recv_fin()
    check("CLOSING (simultaneous)", c.state_name() as String, "CLOSING")
    c.recv_ack()
    check("TIME_WAIT after CLOSING ACK", c.state_name() as String, "TIME_WAIT")
    println("PASS: simultaneous close -> CLOSING -> TIME_WAIT")
}

fun test_abort_from_established() {
    val c = TcpConnection()
    c.active_open()
    c.recv_syn_ack()
    c.abort()
    check("RST drops to CLOSED", c.state_name() as String, "CLOSED")
    println("PASS: abort sends RST and returns to CLOSED")
}

fun test_persist_across_restart() {
    val c = TcpConnection()
    c.active_open()
    c.recv_syn_ack()
    c.app_send(2048)
    c.app_close()
    c.recv_ack()
    c.recv_fin()
    check("TIME_WAIT before persist", c.state_name() as String, "TIME_WAIT")
    val snap = c.save_state()
    val c2 = TcpConnection.restore_state(snap)
    check("TIME_WAIT restored", c2.state_name() as String, "TIME_WAIT")
    c2.timeout_2msl()
    check("CLOSED after 2MSL", c2.state_name() as String, "CLOSED")
    println("PASS: @@persist survives simulated restart in TIME_WAIT")
}

fun main() {
    test_active_open_full_cycle()
    test_passive_open_full_cycle()
    test_simultaneous_close()
    test_abort_from_established()
    test_persist_across_restart()
    println("PASS: all TCP connection tests passed")
}

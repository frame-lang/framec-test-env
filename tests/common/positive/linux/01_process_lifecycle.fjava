@@[target("java")]

// Process Lifecycle — Linux task states (kernel/sched/core.c semantics)
// Three-level HSM with explicit upward forwarding as per-state signal policy.

@@system TaskLifecycle {
    interface:
        fork(): String
        schedule(): String
        block_on_io(): String
        io_complete(): String
        block_uninterruptible(): String
        send_signal(sig: String): String
        wait_by_parent(): String
        status(): String

    machine:
        $New {
            fork(): String {
                this.pid = this.next_pid();
                @@:("forked")
                -> $Ready
            }
            status(): String { @@:("new") }
        }

        $Ready => $Alive {
            schedule(): String {
                @@:("running")
                -> $Running
            }
            status(): String { @@:("ready") }
            => $^
        }

        $Running => $Alive {
            schedule(): String {
                @@:("preempted")
                -> $Ready
            }
            block_on_io(): String {
                @@:("blocked")
                -> $Interruptible
            }
            block_uninterruptible(): String {
                @@:("blocked (D)")
                -> $Uninterruptible
            }
            status(): String { @@:("running") }
            => $^
        }

        $Interruptible => $Blocked {
            io_complete(): String {
                @@:("woke")
                -> $Ready
            }
            send_signal(sig: String): String {
                if (sig.equals("SIGKILL") || sig.equals("SIGTERM") || sig.equals("SIGSTOP")) {
                    => $^
                } else {
                    @@:("interrupted")
                    -> $Ready
                }
            }
            status(): String { @@:("interruptible") }
            => $^
        }

        $Uninterruptible => $Blocked {
            io_complete(): String {
                @@:("woke")
                -> $Ready
            }
            send_signal(sig: String): String {
                if (sig.equals("SIGKILL")) {
                    => $^
                } else {
                    @@:("signal held pending (D-state)")
                }
            }
            status(): String { @@:("uninterruptible") }
            => $^
        }

        $Blocked => $Alive {
            status(): String { @@:("blocked") }
            => $^
        }

        $Alive {
            send_signal(sig: String): String {
                if (sig.equals("SIGKILL") || sig.equals("SIGTERM")) {
                    @@:("exiting")
                    -> $Zombie
                } else if (sig.equals("SIGSTOP")) {
                    @@:("stopped")
                    -> $Stopped
                } else {
                    @@:("signal delivered")
                }
            }
        }

        $Stopped {
            send_signal(sig: String): String {
                if (sig.equals("SIGCONT")) {
                    @@:("continued")
                    -> $Ready
                } else if (sig.equals("SIGKILL")) {
                    @@:("killed while stopped")
                    -> $Zombie
                } else {
                    @@:("signal ignored")
                }
            }
            status(): String { @@:("stopped") }
        }

        $Zombie {
            wait_by_parent(): String {
                @@:("reaped")
                -> $Dead
            }
            status(): String { @@:("zombie") }
        }

        $Dead {
            status(): String { @@:("dead") }
        }

    actions:
        next_pid(): int {
            this.pid_counter = this.pid_counter + 1;
            return this.pid_counter;
        }

    domain:
        pid: int = 0
        pid_counter: int = 100
}


class Main {
    static void check(String label, String actual, String expected) {
        if (!actual.equals(expected)) {
            System.out.println("FAIL: " + label + " — expected '" + expected + "', got '" + actual + "'");
            System.exit(1);
        }
    }

    static void test_happy_path() {
        var t = @@TaskLifecycle();
        check("initial status", (String) t.status(), "new");
        check("fork",           (String) t.fork(),   "forked");
        check("after fork",     (String) t.status(), "ready");
        check("schedule",       (String) t.schedule(), "running");
        check("after schedule", (String) t.status(), "running");
        check("preempt",        (String) t.schedule(), "preempted");
        check("after preempt",  (String) t.status(), "ready");
        System.out.println("PASS: happy path");
    }

    static void test_interruptible_wake_by_signal() {
        var t = @@TaskLifecycle();
        t.fork();
        t.schedule();
        check("block_on_io", (String) t.block_on_io(), "blocked");
        check("interruptible status", (String) t.status(), "interruptible");
        check("SIGUSR1 wakes interruptible",
              (String) t.send_signal("SIGUSR1"), "interrupted");
        check("woke to ready", (String) t.status(), "ready");
        System.out.println("PASS: interruptible wake by signal");
    }

    static void test_uninterruptible_holds_signal() {
        var t = @@TaskLifecycle();
        t.fork();
        t.schedule();
        check("block_uninterruptible",
              (String) t.block_uninterruptible(), "blocked (D)");
        check("D state", (String) t.status(), "uninterruptible");
        check("SIGUSR1 held pending in D",
              (String) t.send_signal("SIGUSR1"), "signal held pending (D-state)");
        check("still in D", (String) t.status(), "uninterruptible");
        System.out.println("PASS: uninterruptible holds non-fatal signal");
    }

    static void test_sigkill_reaches_d_state() {
        var t = @@TaskLifecycle();
        t.fork();
        t.schedule();
        t.block_uninterruptible();
        check("SIGKILL forwarded from D through $Alive",
              (String) t.send_signal("SIGKILL"), "exiting");
        check("now zombie", (String) t.status(), "zombie");
        check("reap", (String) t.wait_by_parent(), "reaped");
        check("dead", (String) t.status(), "dead");
        System.out.println("PASS: SIGKILL reaches D state via $Alive forwarding");
    }

    static void test_sigstop_sigcont() {
        var t = @@TaskLifecycle();
        t.fork();
        t.schedule();
        check("SIGSTOP from running",
              (String) t.send_signal("SIGSTOP"), "stopped");
        check("stopped status", (String) t.status(), "stopped");
        check("SIGCONT resumes", (String) t.send_signal("SIGCONT"), "continued");
        check("back to ready", (String) t.status(), "ready");
        System.out.println("PASS: SIGSTOP/SIGCONT");
    }

    public static void main(String[] args) {
        test_happy_path();
        test_interruptible_wake_by_signal();
        test_uninterruptible_holds_signal();
        test_sigkill_reaches_d_state();
        test_sigstop_sigcont();
        System.out.println("PASS: all process lifecycle tests passed");
    }
}

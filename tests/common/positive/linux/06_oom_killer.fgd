@@[target("gdscript")]

# OOM Killer — kernel mm/oom_kill.c semantics.

extends SceneTree

@@system OomKiller {
    interface:
        oom_detected(gfp_flags: int): str
        victim_exited(pid: int, freed_kb: int): str
        oom_detected_again(gfp_flags: int): str
        status(): str

    machine:
        $Normal {
            oom_detected(gfp_flags: int): str {
                @@:("selecting victim")
                -> $Selecting
            }
            status(): str { @@:("normal") }
        }

        $Selecting {
            $>() {
                self.victim_pid = self.select_victim()
                if self.victim_pid < 0:
                    -> $Panic
                else:
                    -> $Killing
            }
            status(): str { @@:("selecting") }
        }

        $Killing {
            $>() {
                self.send_sigkill(self.victim_pid)
                self.start_reaper_timer()
            }
            <$() {
                self.cancel_reaper_timer()
            }

            victim_exited(pid: int, freed_kb: int): str {
                if pid == self.victim_pid:
                    self.total_freed_kb = self.total_freed_kb + freed_kb
                    @@:("reclaimed")
                    -> $Normal
                else:
                    @@:("wrong pid, still waiting")
            }

            status(): str { @@:("killing") }
        }

        $Panic {
            status(): str { @@:("panic") }
        }

    actions:
        select_victim() {
            self.victim_score = 850
            return 4242
        }
        send_sigkill(pid) {}
        start_reaper_timer() {}
        cancel_reaper_timer() {}

    domain:
        victim_pid: int = -1
        victim_score: int = 0
        total_freed_kb: int = 0
}


func check(label, actual, expected):
    if actual != expected:
        print("FAIL: " + label + " — expected '" + str(expected) + "', got '" + str(actual) + "'")
        quit(1)

func test_normal_oom_flow():
    var oom = @@OomKiller()
    check("initial normal", oom.status(), "normal")
    check("oom_detected -> selecting", oom.oom_detected(0), "selecting victim")
    check("arrived in killing", oom.status(), "killing")
    check("victim exits", oom.victim_exited(4242, 51200), "reclaimed")
    check("back to normal", oom.status(), "normal")
    print("PASS: normal OOM flow")

func test_concurrent_oom_silently_dropped():
    var oom = @@OomKiller()
    oom.oom_detected(0)
    check("in killing", oom.status(), "killing")
    oom.oom_detected_again(0)
    check("still killing (event dropped)", oom.status(), "killing")
    oom.victim_exited(4242, 8192)
    check("back to normal after reclaim", oom.status(), "normal")
    print("PASS: concurrent OOM events dropped in $Killing (safety)")

func test_wrong_pid_exit_ignored():
    var oom = @@OomKiller()
    oom.oom_detected(0)
    check("waiting for victim", oom.victim_exited(9999, 1024), "wrong pid, still waiting")
    check("still killing", oom.status(), "killing")
    oom.victim_exited(4242, 2048)
    check("correct pid -> normal", oom.status(), "normal")
    print("PASS: wrong-pid exit ignored in $Killing")

func test_oom_detected_ignored_in_selecting():
    var oom = @@OomKiller()
    check("first oom", oom.oom_detected(0), "selecting victim")
    oom.oom_detected(0)
    check("second oom dropped", oom.status(), "killing")
    print("PASS: oom_detected ignored while killing")

func _init():
    test_normal_oom_flow()
    test_concurrent_oom_silently_dropped()
    test_wrong_pid_exit_ignored()
    test_oom_detected_ignored_in_selecting()
    print("PASS: all OOM killer tests passed")
    quit()

@@target python_3

# SMTP Conversation — RFC 5321 client state machine.
# Every state except $Disconnected is a child of $Connected (sentinel parent
# for "connection up"). STARTTLS upgrade cycles back to $AwaitEhlo.
#
# Simplified from the cookbook: recipients tracked via int counter rather
# than a list, for cross-language portability (no list native ops).

@@system SmtpClient {
    interface:
        tcp_connected()
        greeting_received(code: int)
        ehlo_response(code: int, supports_starttls: bool)
        starttls()
        starttls_response(code: int)
        tls_handshake_complete()
        mail_from(sender: str)
        mail_response(code: int)
        rcpt_to(recipient: str)
        rcpt_response(code: int)
        data()
        data_response(code: int)
        data_body(body: str)
        data_final_response(code: int)
        quit()
        quit_response(code: int)
        status(): str
        recipient_count(): int
        tls_on(): bool

    machine:
        $Disconnected {
            tcp_connected() { -> $AwaitGreeting }
            status(): str { @@:("disconnected") }
            recipient_count(): int { @@:(self.rcpt_count) }
            tls_on(): bool { @@:(self.tls_active) }
        }

        $AwaitGreeting => $Connected {
            greeting_received(code: int) {
                if code == 220:
                    self.send_ehlo()
                    -> $AwaitEhlo
                else:
                    -> $Disconnected
            }
            status(): str { @@:("await greeting") }
            => $^
        }

        $AwaitEhlo => $Connected {
            ehlo_response(code: int, supports_starttls: bool) {
                if code == 250:
                    self.server_supports_starttls = supports_starttls
                    -> $Ready
                else:
                    -> $Disconnected
            }
            status(): str { @@:("await ehlo") }
            => $^
        }

        $Ready => $Connected {
            starttls() {
                if self.server_supports_starttls:
                    if self.tls_active == False:
                        self.send_starttls()
                        -> $AwaitStartTlsResponse
            }
            mail_from(sender: str) {
                self.sender = sender
                self.send_mail_from()
                -> $AwaitMailResponse
            }
            quit() {
                self.send_quit()
                -> $AwaitQuitResponse
            }
            status(): str { @@:("ready") }
            => $^
        }

        $AwaitStartTlsResponse => $Connected {
            starttls_response(code: int) {
                if code == 220:
                    -> $TlsHandshake
                else:
                    -> $Ready
            }
            status(): str { @@:("await starttls response") }
            => $^
        }

        $TlsHandshake => $Connected {
            tls_handshake_complete() {
                self.tls_active = True
                self.send_ehlo()
                -> $AwaitEhlo
            }
            status(): str { @@:("tls handshake") }
            => $^
        }

        $AwaitMailResponse => $Connected {
            mail_response(code: int) {
                if code == 250:
                    -> $AwaitRcpt
                else:
                    -> $Ready
            }
            status(): str { @@:("await mail response") }
            => $^
        }

        $AwaitRcpt => $Connected {
            rcpt_to(recipient: str) {
                self.rcpt_count = self.rcpt_count + 1
                self.send_rcpt_to()
                -> $AwaitRcptResponse
            }
            data() {
                if self.rcpt_count > 0:
                    self.send_data()
                    -> $AwaitDataResponse
            }
            status(): str { @@:("await rcpt") }
            => $^
        }

        $AwaitRcptResponse => $Connected {
            rcpt_response(code: int) {
                -> $AwaitRcpt
            }
            status(): str { @@:("await rcpt response") }
            => $^
        }

        $AwaitDataResponse => $Connected {
            data_response(code: int) {
                if code == 354:
                    -> $SendingBody
                else:
                    -> $Ready
            }
            status(): str { @@:("await data response") }
            => $^
        }

        $SendingBody => $Connected {
            data_body(body: str) {
                self.send_body()
                self.send_body_terminator()
                -> $AwaitFinalResponse
            }
            status(): str { @@:("sending body") }
            => $^
        }

        $AwaitFinalResponse => $Connected {
            data_final_response(code: int) {
                self.rcpt_count = 0
                -> $Ready
            }
            status(): str { @@:("await final response") }
            => $^
        }

        $AwaitQuitResponse => $Connected {
            quit_response(code: int) {
                -> $Disconnected
            }
            status(): str { @@:("await quit response") }
            => $^
        }

        $Connected {
            recipient_count(): int { @@:(self.rcpt_count) }
            tls_on(): bool { @@:(self.tls_active) }
        }

    actions:
        send_ehlo()             { pass }
        send_starttls()         { pass }
        send_mail_from()        { pass }
        send_rcpt_to()          { pass }
        send_data()             { pass }
        send_body()             { pass }
        send_body_terminator()  { pass }
        send_quit()             { pass }

    domain:
        server_supports_starttls: bool = False
        tls_active: bool = False
        sender: str = ""
        rcpt_count: int = 0
}


def check(label, actual, expected):
    if actual != expected:
        print(f"FAIL: {label} — expected {expected!r}, got {actual!r}")
        raise SystemExit(1)

def test_basic_exchange_no_tls():
    smtp = @@SmtpClient()
    check("initial disconnected", smtp.status(), "disconnected")
    smtp.tcp_connected()
    check("await greeting", smtp.status(), "await greeting")
    smtp.greeting_received(220)
    check("await ehlo", smtp.status(), "await ehlo")
    smtp.ehlo_response(250, False)
    check("ready", smtp.status(), "ready")
    check("tls off", smtp.tls_on(), False)
    print("PASS: basic TCP connect + EHLO")

def test_starttls_upgrade():
    smtp = @@SmtpClient()
    smtp.tcp_connected()
    smtp.greeting_received(220)
    smtp.ehlo_response(250, True)
    smtp.starttls()
    check("await starttls response",
          smtp.status(), "await starttls response")
    smtp.starttls_response(220)
    check("tls handshake", smtp.status(), "tls handshake")
    smtp.tls_handshake_complete()
    check("await ehlo after TLS", smtp.status(), "await ehlo")
    smtp.ehlo_response(250, True)
    check("back to ready", smtp.status(), "ready")
    check("tls on", smtp.tls_on(), True)
    print("PASS: STARTTLS upgrade cycles through $AwaitEhlo")

def test_send_message_three_recipients():
    smtp = @@SmtpClient()
    smtp.tcp_connected()
    smtp.greeting_received(220)
    smtp.ehlo_response(250, False)
    smtp.mail_from("alice@example.com")
    check("await mail", smtp.status(), "await mail response")
    smtp.mail_response(250)
    smtp.rcpt_to("bob@example.com")
    smtp.rcpt_response(250)
    smtp.rcpt_to("carol@example.com")
    smtp.rcpt_response(250)
    smtp.rcpt_to("dan@example.com")
    smtp.rcpt_response(250)
    check("3 recipients", smtp.recipient_count(), 3)
    smtp.data()
    check("await data response", smtp.status(), "await data response")
    smtp.data_response(354)
    smtp.data_body("Subject: hi\r\n\r\nhello")
    smtp.data_final_response(250)
    check("ready again", smtp.status(), "ready")
    check("recipient count reset", smtp.recipient_count(), 0)
    print("PASS: send message with three recipients")

def test_quit():
    smtp = @@SmtpClient()
    smtp.tcp_connected()
    smtp.greeting_received(220)
    smtp.ehlo_response(250, False)
    smtp.quit()
    smtp.quit_response(221)
    check("disconnected after QUIT", smtp.status(), "disconnected")
    print("PASS: clean QUIT shutdown")

def test_greeting_reject():
    smtp = @@SmtpClient()
    smtp.tcp_connected()
    smtp.greeting_received(500)
    check("bad greeting -> disconnected", smtp.status(), "disconnected")
    print("PASS: bad greeting drops connection")

def test_starttls_refused_if_not_supported():
    smtp = @@SmtpClient()
    smtp.tcp_connected()
    smtp.greeting_received(220)
    smtp.ehlo_response(250, False)  # server doesn't advertise STARTTLS
    smtp.starttls()
    # Nothing happened (handler had no effect) — still in $Ready
    check("still ready (starttls refused)",
          smtp.status(), "ready")
    check("tls still off", smtp.tls_on(), False)
    print("PASS: starttls no-op when server doesn't support it")

def test_mail_rejection_returns_to_ready():
    smtp = @@SmtpClient()
    smtp.tcp_connected()
    smtp.greeting_received(220)
    smtp.ehlo_response(250, False)
    smtp.mail_from("bad@user")
    smtp.mail_response(550)
    check("mail rejected -> ready", smtp.status(), "ready")
    print("PASS: mail rejection returns to ready")

if __name__ == '__main__':
    test_basic_exchange_no_tls()
    test_starttls_upgrade()
    test_send_message_three_recipients()
    test_quit()
    test_greeting_reject()
    test_starttls_refused_if_not_supported()
    test_mail_rejection_returns_to_ready()
    print("PASS: all SMTP conversation tests passed")

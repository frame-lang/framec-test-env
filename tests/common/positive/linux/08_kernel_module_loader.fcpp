@@[target("cpp_17")]

// Kernel Module Loader — pipeline with compensation (saga pattern).

#include <iostream>
#include <cstdlib>

@@system ModuleLoader {
    interface:
        load(name: str)
        unload(): str
        acquire(): str
        release(): str
        resolve_done(success: bool, reason: str)
        alloc_done(success: bool, reason: str)
        relocate_done(success: bool, reason: str)
        init_done(success: bool, reason: str)
        status(): str
        refcount(): int
        failure_reason(): str

    machine:
        $Idle {
            load(name: str) {
                this->name = name;
                this->failure = std::string("");
                -> $ResolvingSymbols
            }
            status(): str { @@:(std::string("idle")) }
        }

        $ResolvingSymbols {
            $>() {
                this->do_resolve(this->name);
            }
            resolve_done(success: bool, reason: str) {
                if (success) {
                    -> $AllocatingMemory
                } else {
                    this->failure = reason;
                    -> $Failed
                }
            }
            status(): str { @@:(std::string("resolving")) }
        }

        $AllocatingMemory {
            $>() {
                this->do_alloc(this->name);
            }
            alloc_done(success: bool, reason: str) {
                if (success) {
                    -> $Relocating
                } else {
                    this->failure = reason;
                    -> $Failed
                }
            }
            status(): str { @@:(std::string("allocating")) }
        }

        $Relocating {
            $>() {
                this->do_relocate(this->name);
            }
            relocate_done(success: bool, reason: str) {
                if (success) {
                    -> $Initializing
                } else {
                    this->failure = reason;
                    -> $UndoAlloc
                }
            }
            status(): str { @@:(std::string("relocating")) }
        }

        $Initializing {
            $>() {
                this->do_init(this->name);
            }
            init_done(success: bool, reason: str) {
                if (success) {
                    -> $Live
                } else {
                    this->failure = reason;
                    -> $UndoRelocate
                }
            }
            status(): str { @@:(std::string("initializing")) }
        }

        $UndoRelocate {
            $>() {
                this->do_undo_relocate(this->name);
                -> $UndoAlloc
            }
        }

        $UndoAlloc {
            $>() {
                this->do_free(this->name);
                -> $Failed
            }
        }

        $Live {
            $>() {
                this->refs = 0;
            }

            acquire(): str {
                this->refs = this->refs + 1;
                @@:(std::string("acquired"))
            }
            release(): str {
                this->refs = this->refs - 1;
                @@:(std::string("released"))
            }
            unload(): str {
                if (this->refs > 0) {
                    @@:(std::string("busy"))
                } else {
                    @@:(std::string("unloading"))
                    -> $Unloading
                }
            }
            status(): str { @@:(std::string("live")) }
            refcount(): int { @@:(this->refs) }
        }

        $Unloading {
            $>() {
                this->do_exit(this->name);
                this->do_free(this->name);
                -> $Idle
            }
        }

        $Failed {
            load(name: str) {
                this->name = name;
                this->failure = std::string("");
                -> $ResolvingSymbols
            }
            status(): str { @@:(std::string("failed")) }
            failure_reason(): str { @@:(this->failure) }
        }

    actions:
        do_resolve(name: str) {}
        do_alloc(name: str) {}
        do_relocate(name: str) {}
        do_init(name: str) {}
        do_undo_relocate(name: str) {}
        do_free(name: str) {}
        do_exit(name: str) {}

    domain:
        name: std::string = std::string("")
        failure: std::string = std::string("")
        refs: int = 0
}


void check_str(const std::string& label, const std::string& actual, const std::string& expected) {
    if (actual != expected) {
        std::cout << "FAIL: " << label << " — expected '" << expected << "', got '" << actual << "'" << std::endl;
        std::exit(1);
    }
}

void check_int(const std::string& label, int actual, int expected) {
    if (actual != expected) {
        std::cout << "FAIL: " << label << " — expected " << expected << ", got " << actual << std::endl;
        std::exit(1);
    }
}

void test_happy_load_unload() {
    auto loader = @@ModuleLoader();
    check_str("initial idle", std::any_cast<std::string>(loader.status()), "idle");
    loader.load(std::string("ext4"));
    check_str("resolving", std::any_cast<std::string>(loader.status()), "resolving");
    loader.resolve_done(true, std::string(""));
    check_str("allocating", std::any_cast<std::string>(loader.status()), "allocating");
    loader.alloc_done(true, std::string(""));
    check_str("relocating", std::any_cast<std::string>(loader.status()), "relocating");
    loader.relocate_done(true, std::string(""));
    check_str("initializing", std::any_cast<std::string>(loader.status()), "initializing");
    loader.init_done(true, std::string(""));
    check_str("live", std::any_cast<std::string>(loader.status()), "live");
    check_int("refcount 0", std::any_cast<int>(loader.refcount()), 0);
    check_str("unload empty module", std::any_cast<std::string>(loader.unload()), "unloading");
    check_str("back to idle", std::any_cast<std::string>(loader.status()), "idle");
    std::cout << "PASS: happy load/unload pipeline" << std::endl;
}

void test_init_failure_compensates() {
    auto loader = @@ModuleLoader();
    loader.load(std::string("buggy"));
    loader.resolve_done(true, std::string(""));
    loader.alloc_done(true, std::string(""));
    loader.relocate_done(true, std::string(""));
    loader.init_done(false, std::string("ENOMEM"));
    check_str("failed state", std::any_cast<std::string>(loader.status()), "failed");
    check_str("failure captured", std::any_cast<std::string>(loader.failure_reason()), "ENOMEM");
    std::cout << "PASS: init failure compensation" << std::endl;
}

void test_relocate_failure_compensates() {
    auto loader = @@ModuleLoader();
    loader.load(std::string("symbol_err"));
    loader.resolve_done(true, std::string(""));
    loader.alloc_done(true, std::string(""));
    loader.relocate_done(false, std::string("undefined symbol"));
    check_str("failed from relocate", std::any_cast<std::string>(loader.status()), "failed");
    check_str("reason captured", std::any_cast<std::string>(loader.failure_reason()), "undefined symbol");
    std::cout << "PASS: relocate failure compensation" << std::endl;
}

void test_early_failure_no_compensation_needed() {
    auto loader = @@ModuleLoader();
    loader.load(std::string("no_such_sym"));
    loader.resolve_done(false, std::string("symbol not found"));
    check_str("direct fail from resolve", std::any_cast<std::string>(loader.status()), "failed");
    check_str("resolve reason", std::any_cast<std::string>(loader.failure_reason()), "symbol not found");
    std::cout << "PASS: early failure without compensation" << std::endl;
}

void test_refcount_blocks_unload() {
    auto loader = @@ModuleLoader();
    loader.load(std::string("shared_lib"));
    loader.resolve_done(true, std::string(""));
    loader.alloc_done(true, std::string(""));
    loader.relocate_done(true, std::string(""));
    loader.init_done(true, std::string(""));
    check_str("acquire returns 'acquired'", std::any_cast<std::string>(loader.acquire()), "acquired");
    check_int("refcount 1", std::any_cast<int>(loader.refcount()), 1);
    check_str("acquire again", std::any_cast<std::string>(loader.acquire()), "acquired");
    check_int("refcount 2", std::any_cast<int>(loader.refcount()), 2);
    check_str("unload blocked by refs", std::any_cast<std::string>(loader.unload()), "busy");
    check_str("still live", std::any_cast<std::string>(loader.status()), "live");
    loader.release();
    check_int("refcount after release", std::any_cast<int>(loader.refcount()), 1);
    check_str("still busy", std::any_cast<std::string>(loader.unload()), "busy");
    loader.release();
    check_int("refcount 0", std::any_cast<int>(loader.refcount()), 0);
    check_str("now unloads", std::any_cast<std::string>(loader.unload()), "unloading");
    check_str("idle again", std::any_cast<std::string>(loader.status()), "idle");
    std::cout << "PASS: refcount blocks unload" << std::endl;
}

void test_reload_from_failed() {
    auto loader = @@ModuleLoader();
    loader.load(std::string("badmod"));
    loader.resolve_done(false, std::string("initial fail"));
    check_str("failed", std::any_cast<std::string>(loader.status()), "failed");
    loader.load(std::string("goodmod"));
    check_str("restarted in resolving", std::any_cast<std::string>(loader.status()), "resolving");
    loader.resolve_done(true, std::string(""));
    loader.alloc_done(true, std::string(""));
    loader.relocate_done(true, std::string(""));
    loader.init_done(true, std::string(""));
    check_str("recovered to live", std::any_cast<std::string>(loader.status()), "live");
    std::cout << "PASS: reload from failed" << std::endl;
}

int main() {
    test_happy_load_unload();
    test_init_failure_compensates();
    test_relocate_failure_compensates();
    test_early_failure_no_compensation_needed();
    test_refcount_blocks_unload();
    test_reload_from_failed();
    std::cout << "PASS: all kernel module loader tests passed" << std::endl;
    return 0;
}

@@[target("kotlin")]

// PPP Link Control Protocol -- RFC 1661 Section 4 state table direct transcription.

@@system PppLcp {
    interface:
        up()
        down()
        open()
        close()
        receive_configure_request(acceptable: Boolean)
        receive_configure_ack()
        receive_configure_nak()
        receive_terminate_request()
        receive_terminate_ack()
        timeout_positive()
        timeout_negative()
        status(): String

    machine:
        $Initial {
            up() { -> $Closed }
            open() { -> $Starting }
            status(): String { @@:("initial") }
        }

        $Starting {
            up() {
                this.init_restart_count()
                this.send_configure_request()
                -> $ReqSent
            }
            close() { -> $Initial }
            status(): String { @@:("starting") }
        }

        $Closed {
            open() {
                this.init_restart_count()
                this.send_configure_request()
                -> $ReqSent
            }
            down() { -> $Initial }
            receive_configure_request(acceptable: Boolean) {
                this.send_terminate_ack()
            }
            status(): String { @@:("closed") }
        }

        $Stopped {
            open() { -> $Stopped }
            down() { -> $Starting }
            receive_configure_request(acceptable: Boolean) {
                this.init_restart_count()
                if (acceptable) {
                    this.send_configure_ack()
                    this.send_configure_request()
                    -> $AckSent
                } else {
                    this.send_configure_nak()
                    this.send_configure_request()
                    -> $ReqSent
                }
            }
            status(): String { @@:("stopped") }
        }

        $Closing {
            timeout_positive() {
                this.send_terminate_request()
            }
            timeout_negative() {
                -> $Closed
            }
            receive_terminate_ack() {
                -> $Closed
            }
            down() { -> $Initial }
            status(): String { @@:("closing") }
        }

        $Stopping {
            timeout_positive() {
                this.send_terminate_request()
            }
            timeout_negative() {
                -> $Stopped
            }
            receive_terminate_ack() {
                -> $Stopped
            }
            down() { -> $Starting }
            status(): String { @@:("stopping") }
        }

        $ReqSent {
            timeout_positive() {
                this.send_configure_request()
            }
            timeout_negative() {
                -> $Stopped
            }
            receive_configure_request(acceptable: Boolean) {
                if (acceptable) {
                    this.send_configure_ack()
                    -> $AckSent
                } else {
                    this.send_configure_nak()
                }
            }
            receive_configure_ack() {
                this.init_restart_count()
                -> $AckRcvd
            }
            receive_configure_nak() {
                this.init_restart_count()
                this.send_configure_request()
            }
            receive_terminate_request() {
                this.send_terminate_ack()
                -> $ReqSent
            }
            close() {
                this.init_restart_count()
                this.send_terminate_request()
                -> $Closing
            }
            down() { -> $Starting }
            status(): String { @@:("req-sent") }
        }

        $AckRcvd {
            receive_configure_request(acceptable: Boolean) {
                if (acceptable) {
                    this.send_configure_ack()
                    this.tlu()
                    -> $Opened
                } else {
                    this.send_configure_nak()
                }
            }
            timeout_positive() {
                this.send_configure_request()
                -> $ReqSent
            }
            timeout_negative() { -> $Stopped }
            receive_configure_ack() {
                this.send_configure_request()
                -> $ReqSent
            }
            close() {
                this.init_restart_count()
                this.send_terminate_request()
                -> $Closing
            }
            down() { -> $Starting }
            status(): String { @@:("ack-rcvd") }
        }

        $AckSent {
            receive_configure_ack() {
                this.init_restart_count()
                this.tlu()
                -> $Opened
            }
            timeout_positive() {
                this.send_configure_request()
            }
            timeout_negative() { -> $Stopped }
            receive_configure_request(acceptable: Boolean) {
                if (acceptable) {
                    this.send_configure_ack()
                } else {
                    this.send_configure_nak()
                    -> $ReqSent
                }
            }
            receive_configure_nak() {
                this.init_restart_count()
                this.send_configure_request()
                -> $ReqSent
            }
            close() {
                this.init_restart_count()
                this.send_terminate_request()
                -> $Closing
            }
            down() { -> $Starting }
            status(): String { @@:("ack-sent") }
        }

        $Opened {
            <$() {
                this.tld()
            }

            receive_configure_request(acceptable: Boolean) {
                this.send_configure_request()
                if (acceptable) {
                    this.send_configure_ack()
                    -> $AckSent
                } else {
                    this.send_configure_nak()
                    -> $ReqSent
                }
            }
            receive_terminate_request() {
                this.send_terminate_ack()
                this.zero_restart_count()
                -> $Stopping
            }
            close() {
                this.init_restart_count()
                this.send_terminate_request()
                -> $Closing
            }
            down() {
                -> $Starting
            }
            status(): String { @@:("opened") }
        }

    actions:
        send_configure_request() {}
        send_configure_ack()     {}
        send_configure_nak()     {}
        send_terminate_request() {}
        send_terminate_ack()     {}
        init_restart_count() {
            this.restart_count = this.max_restart
        }
        zero_restart_count() {
            this.restart_count = 0
        }
        tlu() {}
        tld() {}

    domain:
        restart_count: Int = 0
        max_restart: Int = 10
}


fun check(label: String, actual: String, expected: String) {
    if (actual != expected) {
        println("FAIL: $label -- expected '$expected', got '$actual'")
        kotlin.system.exitProcess(1)
    }
}

fun test_normal_open() {
    val ppp = PppLcp()
    check("initial", ppp.status() as String, "initial")
    ppp.open()
    check("starting", ppp.status() as String, "starting")
    ppp.up()
    check("req-sent", ppp.status() as String, "req-sent")
    ppp.receive_configure_ack()
    check("ack-rcvd", ppp.status() as String, "ack-rcvd")
    ppp.receive_configure_request(true)
    check("opened", ppp.status() as String, "opened")
    println("PASS: normal open sequence")
}

fun test_peer_renegotiation() {
    val ppp = PppLcp()
    ppp.open()
    ppp.up()
    ppp.receive_configure_ack()
    ppp.receive_configure_request(true)
    check("opened first time", ppp.status() as String, "opened")
    ppp.receive_configure_request(true)
    check("renegotiation -> AckSent", ppp.status() as String, "ack-sent")
    ppp.receive_configure_ack()
    check("back to opened", ppp.status() as String, "opened")
    println("PASS: peer-initiated renegotiation from opened")
}

fun test_clean_shutdown() {
    val ppp = PppLcp()
    ppp.open()
    ppp.up()
    ppp.receive_configure_ack()
    ppp.receive_configure_request(true)
    ppp.close()
    check("closing", ppp.status() as String, "closing")
    ppp.receive_terminate_ack()
    check("closed", ppp.status() as String, "closed")
    println("PASS: clean shutdown via close()")
}

fun test_peer_terminate() {
    val ppp = PppLcp()
    ppp.open()
    ppp.up()
    ppp.receive_configure_ack()
    ppp.receive_configure_request(true)
    ppp.receive_terminate_request()
    check("stopping on peer-terminate", ppp.status() as String, "stopping")
    ppp.receive_terminate_ack()
    check("stopped", ppp.status() as String, "stopped")
    println("PASS: peer-initiated terminate")
}

fun test_timeout_negative_from_closing() {
    val ppp = PppLcp()
    ppp.open()
    ppp.up()
    ppp.receive_configure_ack()
    ppp.receive_configure_request(true)
    ppp.close()
    check("closing", ppp.status() as String, "closing")
    ppp.timeout_negative()
    check("closing exhausts to closed", ppp.status() as String, "closed")
    println("PASS: timeout_negative in closing -> closed")
}

fun test_down_from_opened() {
    val ppp = PppLcp()
    ppp.open()
    ppp.up()
    ppp.receive_configure_ack()
    ppp.receive_configure_request(true)
    ppp.down()
    check("down from opened -> starting", ppp.status() as String, "starting")
    println("PASS: down from opened")
}

fun main() {
    test_normal_open()
    test_peer_renegotiation()
    test_clean_shutdown()
    test_peer_terminate()
    test_timeout_negative_from_closing()
    test_down_from_opened()
    println("PASS: all PPP LCP tests passed")
}

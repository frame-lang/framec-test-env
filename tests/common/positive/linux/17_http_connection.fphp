@@[target("php")]

<?php

// HTTP/1.1 Connection -- keep-alive lifecycle with HSM for cross-cutting errors.

@@system HttpConnection {
    interface:
        connect(host: str, port: int)
        send_request(method: str, path: str)
        headers_received(status_code: int, keep_alive: bool, content_length: int)
        body_chunk_received(chunk: str)
        body_complete()
        keep_alive_timeout()
        connection_error(reason: str)
        close()
        status(): str
        request_count(): int

    machine:
        $Disconnected {
            connect(host: str, port: int) {
                $this->host = $host;
                $this->port = $port;
                -> $Connecting
            }
            status(): str { @@:("disconnected") }
            request_count(): int { @@:($this->requests) }
        }

        $Connecting {
            $>() {
                $this->tcp_connect();
                -> $Idle
            }
        }

        $Idle => $Open {
            $>() {
                $this->start_keep_alive_timer();
            }
            <$() {
                $this->cancel_keep_alive_timer();
            }

            send_request(method: str, path: str) {
                $this->current_method = $method;
                $this->current_path = $path;
                $this->emit_request();
                -> $AwaitingResponse
            }
            keep_alive_timeout() {
                -> $Closing
            }
            status(): str { @@:("idle") }
            request_count(): int { @@:($this->requests) }
            => $^
        }

        $AwaitingResponse => $Open {
            headers_received(status_code: int, keep_alive: bool, content_length: int) {
                $this->response_status = $status_code;
                $this->ka = $keep_alive;
                $this->content_length = $content_length;
                if ($content_length === 0) {
                    -> $ResponseComplete
                } else {
                    -> $ReceivingBody
                }
            }
            status(): str { @@:("awaiting response") }
            request_count(): int { @@:($this->requests) }
            => $^
        }

        $ReceivingBody => $Open {
            body_chunk_received(chunk: str) {
                $this->bytes_received = $this->bytes_received + $this->content_length;
            }
            body_complete() {
                -> $ResponseComplete
            }
            status(): str { @@:("receiving body") }
            request_count(): int { @@:($this->requests) }
            => $^
        }

        $ResponseComplete => $Open {
            $>() {
                $this->requests = $this->requests + 1;
                if ($this->ka) {
                    -> $Idle
                } else {
                    -> $Closing
                }
            }
            => $^
        }

        $Open {
            connection_error(reason: str) {
                -> $Disconnected
            }
            close() {
                -> $Closing
            }
        }

        $Closing {
            $>() {
                $this->tcp_close();
                -> $Disconnected
            }
        }

    actions:
        tcp_connect() {}
        tcp_close() {}
        emit_request() {}
        start_keep_alive_timer() {}
        cancel_keep_alive_timer() {}

    domain:
        host = ""
        port = 80
        current_method = ""
        current_path = ""
        response_status = 0
        content_length = 0
        bytes_received = 0
        ka = true
        requests = 0
}


function check_value($label, $actual, $expected) {
    if ($actual !== $expected) {
        echo "FAIL: $label -- expected '$expected', got '$actual'\n";
        exit(1);
    }
}

function test_first_request_keepalive() {
    $conn = @@HttpConnection();
    check_value("disconnected", $conn->status(), "disconnected");
    $conn->connect("example.com", 80);
    check_value("idle after connect", $conn->status(), "idle");
    $conn->send_request("GET", "/index.html");
    check_value("awaiting response", $conn->status(), "awaiting response");
    $conn->headers_received(200, true, 5);
    check_value("receiving body", $conn->status(), "receiving body");
    $conn->body_complete();
    check_value("back to idle (keep-alive)", $conn->status(), "idle");
    check_value("request count 1", $conn->request_count(), 1);
    echo "PASS: first request, keep-alive cycles back to idle\n";
}

function test_empty_body_skips_receiving() {
    $conn = @@HttpConnection();
    $conn->connect("example.com", 80);
    $conn->send_request("GET", "/about");
    $conn->headers_received(200, true, 0);
    check_value("idle after empty body", $conn->status(), "idle");
    echo "PASS: empty body skips ReceivingBody\n";
}

function test_connection_close_header() {
    $conn = @@HttpConnection();
    $conn->connect("example.com", 80);
    $conn->send_request("POST", "/api");
    $conn->headers_received(201, false, 0);
    check_value("disconnected after Connection: close", $conn->status(), "disconnected");
    echo "PASS: Connection: close response path\n";
}

function test_keep_alive_timeout() {
    $conn = @@HttpConnection();
    $conn->connect("example.com", 80);
    check_value("idle", $conn->status(), "idle");
    $conn->keep_alive_timeout();
    check_value("disconnected after timeout", $conn->status(), "disconnected");
    echo "PASS: keep-alive timeout tears down connection\n";
}

function test_connection_error_during_receive() {
    $conn = @@HttpConnection();
    $conn->connect("example.com", 80);
    $conn->send_request("GET", "/large");
    $conn->headers_received(200, true, 1000);
    check_value("receiving body", $conn->status(), "receiving body");
    $conn->connection_error("peer reset");
    check_value("disconnected after error", $conn->status(), "disconnected");
    echo "PASS: connection_error from receiving body forwards via HSM\n";
}

function test_explicit_close_during_idle() {
    $conn = @@HttpConnection();
    $conn->connect("example.com", 80);
    $conn->close();
    check_value("close from idle", $conn->status(), "disconnected");
    echo "PASS: explicit close from idle via HSM parent\n";
}

function test_multiple_request_reuse() {
    $conn = @@HttpConnection();
    $conn->connect("example.com", 80);
    $conn->send_request("GET", "/one");
    $conn->headers_received(200, true, 0);
    $conn->send_request("GET", "/two");
    $conn->headers_received(200, true, 0);
    $conn->send_request("GET", "/three");
    $conn->headers_received(200, true, 0);
    check_value("3 requests on same connection", $conn->request_count(), 3);
    check_value("still idle", $conn->status(), "idle");
    echo "PASS: connection reused across multiple requests\n";
}

test_first_request_keepalive();
test_empty_body_skips_receiving();
test_connection_close_header();
test_keep_alive_timeout();
test_connection_error_during_receive();
test_explicit_close_during_idle();
test_multiple_request_reuse();
echo "PASS: all HTTP connection tests passed\n";

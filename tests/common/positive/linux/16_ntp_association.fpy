@@[target("python_3")]

# NTP Client Association — RFC 5905.
# Polling interval adapts: doubles on success (up to max_poll), halves on
# timeout (down to min_poll). Three consecutive timeouts drops sync.
# Reachability register is 8-bit shift register; bit per poll attempt.
# Uses operations (read-only queries) for get_offset/is_reachable.

@@system NtpAssociation {
    operations:
        get_offset(): int {
            return self.last_offset
        }
        is_reachable(): bool {
            return self.reach_register > 0
        }

    interface:
        poll_tick()
        response_received(offset_ms: int, delay_ms: int)
        poll_timeout()
        status(): str
        poll_interval(): int
        reach(): int

    machine:
        $Unsynced {
            $>() {
                self.poll_interval_v = self.min_poll
            }

            poll_tick() {
                # Send the request; bit gets shifted when we see the outcome.
                pass
            }
            response_received(offset_ms: int, delay_ms: int) {
                self.shift_reach_register(1)
                self.last_offset = offset_ms
                self.last_delay = delay_ms
                self.good_responses = self.good_responses + 1
                if self.good_responses >= self.sync_threshold:
                    -> $Synced
            }
            poll_timeout() {
                self.shift_reach_register(0)
            }
            status(): str { @@:("unsynced") }
            poll_interval(): int { @@:(self.poll_interval_v) }
            reach(): int { @@:(self.reach_register) }
        }

        $Synced {
            poll_tick() {
                # Request sent; outcome determines the shifted bit.
                pass
            }
            response_received(offset_ms: int, delay_ms: int) {
                self.shift_reach_register(1)
                self.last_offset = offset_ms
                self.last_delay = delay_ms
                if self.poll_interval_v < self.max_poll:
                    self.poll_interval_v = self.poll_interval_v * 2
            }
            poll_timeout() {
                self.shift_reach_register(0)
                self.consecutive_timeouts = self.consecutive_timeouts + 1
                if self.consecutive_timeouts >= 3:
                    self.consecutive_timeouts = 0
                    self.good_responses = 0
                    -> $Unsynced
                if self.poll_interval_v > self.min_poll:
                    self.poll_interval_v = self.poll_interval_v // 2
            }
            status(): str { @@:("synced") }
            poll_interval(): int { @@:(self.poll_interval_v) }
            reach(): int { @@:(self.reach_register) }
        }

    actions:
        shift_reach_register(bit: int) {
            self.reach_register = ((self.reach_register << 1) | bit) & 0xFF
            if bit:
                self.consecutive_timeouts = 0
        }

    domain:
        poll_interval_v: int = 64
        min_poll: int = 64
        max_poll: int = 1024
        reach_register: int = 0
        last_offset: int = 0
        last_delay: int = 0
        good_responses: int = 0
        sync_threshold: int = 3
        consecutive_timeouts: int = 0
}


def check(label, actual, expected):
    if actual != expected:
        print(f"FAIL: {label} — expected {expected!r}, got {actual!r}")
        raise SystemExit(1)

def test_builds_to_sync():
    ntp = @@NtpAssociation()
    check("initial unsynced", ntp.status(), "unsynced")
    ntp.poll_tick()
    ntp.response_received(12, 3)
    ntp.poll_tick()
    ntp.response_received(11, 2)
    check("not yet synced (2 good)", ntp.status(), "unsynced")
    ntp.poll_tick()
    ntp.response_received(12, 3)
    check("synced after 3 good responses", ntp.status(), "synced")
    print("PASS: sync threshold reached after 3 good responses")

def test_poll_interval_backs_off():
    ntp = @@NtpAssociation()
    ntp.poll_tick(); ntp.response_received(10, 2)
    ntp.poll_tick(); ntp.response_received(10, 2)
    ntp.poll_tick(); ntp.response_received(10, 2)
    check("synced", ntp.status(), "synced")
    check("interval at min (64)", ntp.poll_interval(), 64)
    ntp.poll_tick(); ntp.response_received(10, 2)
    check("128 after 1 good in synced", ntp.poll_interval(), 128)
    ntp.poll_tick(); ntp.response_received(10, 2)
    check("256 after 2 good", ntp.poll_interval(), 256)
    print("PASS: poll interval doubles on success in synced")

def test_timeout_shrinks_interval():
    ntp = @@NtpAssociation()
    ntp.poll_tick(); ntp.response_received(10, 2)
    ntp.poll_tick(); ntp.response_received(10, 2)
    ntp.poll_tick(); ntp.response_received(10, 2)
    ntp.poll_tick(); ntp.response_received(10, 2)  # -> 128
    check("interval 128", ntp.poll_interval(), 128)
    ntp.poll_tick(); ntp.poll_timeout()
    check("timeout halves -> 64", ntp.poll_interval(), 64)
    print("PASS: timeout halves poll interval in synced")

def test_three_timeouts_drops_to_unsync():
    ntp = @@NtpAssociation()
    ntp.poll_tick(); ntp.response_received(10, 2)
    ntp.poll_tick(); ntp.response_received(10, 2)
    ntp.poll_tick(); ntp.response_received(10, 2)
    check("synced", ntp.status(), "synced")
    ntp.poll_tick(); ntp.poll_timeout()
    ntp.poll_tick(); ntp.poll_timeout()
    check("still synced after 2 timeouts", ntp.status(), "synced")
    ntp.poll_tick(); ntp.poll_timeout()
    check("3rd timeout drops to unsync", ntp.status(), "unsynced")
    print("PASS: three consecutive timeouts drop to unsync")

def test_reach_register_shifts():
    ntp = @@NtpAssociation()
    check("reach starts 0", ntp.reach(), 0)
    # One poll that gets a response -> shifts in 1
    ntp.poll_tick()
    ntp.response_received(10, 2)
    check("reach 0b00000001 = 1", ntp.reach(), 1)
    # Another response -> shifts in another 1 -> 0b00000011
    ntp.poll_tick()
    ntp.response_received(10, 2)
    check("reach 0b00000011 = 3", ntp.reach(), 3)
    # A timeout -> shifts in 0 -> 0b00000110
    ntp.poll_tick()
    ntp.poll_timeout()
    check("reach 0b00000110 = 6", ntp.reach(), 6)
    print("PASS: reach register shifts correctly")

def test_is_reachable_operation():
    ntp = @@NtpAssociation()
    # Using the operation (read-only query)
    if ntp.is_reachable():
        print(f"FAIL: not yet reachable, expected False, got True")
        raise SystemExit(1)
    ntp.poll_tick()
    ntp.response_received(10, 2)
    if not ntp.is_reachable():
        print(f"FAIL: after good response, expected reachable")
        raise SystemExit(1)
    print("PASS: is_reachable() operation query")

if __name__ == '__main__':
    test_builds_to_sync()
    test_poll_interval_backs_off()
    test_timeout_shrinks_interval()
    test_three_timeouts_drops_to_unsync()
    test_reach_register_shifts()
    test_is_reachable_operation()
    print("PASS: all NTP association tests passed")

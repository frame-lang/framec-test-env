@@[target("java")]

// TLS Handshake (server side) — RFC 5246 Section 7.3.

@@system TlsServerHandshake {
    interface:
        client_hello(version: String, cipher: String)
        client_key_exchange(key_data: String)
        client_change_cipher_spec()
        client_finished(verify: String)
        alert(level: String, desc: String)
        status(): String

    machine:
        $Idle {
            client_hello(version: String, cipher: String) {
                this.client_version = version;
                if (cipher.equals("TLS_ECDHE_RSA_WITH_AES_128_GCM_SHA256")) {
                    this.selected_cipher = cipher;
                    -> $ServerHello
                } else {
                    if (cipher.equals("TLS_RSA_WITH_AES_128_CBC_SHA")) {
                        this.selected_cipher = cipher;
                        -> $ServerHello
                    } else {
                        this.send_alert();
                        -> $Closed
                    }
                }
            }
            status(): String { @@:("idle") }
        }

        $ServerHello => $Handshaking {
            $>() {
                this.send_server_hello();
                this.send_certificate();
                this.send_server_hello_done();
                -> $AwaitClientKeyExchange
            }
            status(): String { @@:("server hello") }
            => $^
        }

        $AwaitClientKeyExchange => $Handshaking {
            client_key_exchange(key_data: String) {
                this.premaster = key_data;
                this.derive_keys();
                -> $AwaitChangeCipherSpec
            }
            status(): String { @@:("await key exchange") }
            => $^
        }

        $AwaitChangeCipherSpec => $Handshaking {
            client_change_cipher_spec() {
                this.client_encrypted = true;
                -> $AwaitClientFinished
            }
            status(): String { @@:("await change cipher spec") }
            => $^
        }

        $AwaitClientFinished => $Handshaking {
            client_finished(verify: String) {
                if (verify.equals("valid")) {
                    this.send_change_cipher_spec();
                    this.send_finished();
                    -> $Established
                } else {
                    this.send_alert();
                    -> $Closed
                }
            }
            status(): String { @@:("await client finished") }
            => $^
        }

        $Handshaking {
            alert(level: String, desc: String) {
                if (level.equals("fatal")) {
                    -> $Closed
                }
            }
        }

        $Established {
            alert(level: String, desc: String) {
                if (level.equals("fatal")) {
                    -> $Closed
                }
            }
            status(): String { @@:("established") }
        }

        $Closed {
            status(): String { @@:("closed") }
        }

    actions:
        send_server_hello() {}
        send_certificate() {}
        send_server_hello_done() {}
        derive_keys() {}
        send_change_cipher_spec() {}
        send_finished() {}
        send_alert() {}

    domain:
        client_version: String = ""
        selected_cipher: String = ""
        premaster: String = ""
        client_encrypted: boolean = false
}


class Main {
    static void check(String label, String actual, String expected) {
        if (!actual.equals(expected)) {
            System.out.println("FAIL: " + label + " — expected '" + expected + "', got '" + actual + "'");
            System.exit(1);
        }
    }

    static void test_happy_handshake() {
        var tls = @@TlsServerHandshake();
        check("initial idle", (String) tls.status(), "idle");
        tls.client_hello("TLS 1.2", "TLS_RSA_WITH_AES_128_CBC_SHA");
        check("after client_hello -> through ServerHello to await", (String) tls.status(), "await key exchange");
        tls.client_key_exchange("premaster_data");
        check("after key exchange", (String) tls.status(), "await change cipher spec");
        tls.client_change_cipher_spec();
        check("after CCS", (String) tls.status(), "await client finished");
        tls.client_finished("valid");
        check("established", (String) tls.status(), "established");
        System.out.println("PASS: happy TLS handshake");
    }

    static void test_unsupported_cipher_closes() {
        var tls = @@TlsServerHandshake();
        tls.client_hello("TLS 1.2", "TLS_NULL_WITH_NULL_NULL");
        check("no matching cipher -> closed", (String) tls.status(), "closed");
        System.out.println("PASS: unsupported cipher closes handshake");
    }

    static void test_fatal_alert_during_handshake() {
        var tls = @@TlsServerHandshake();
        tls.client_hello("TLS 1.2", "TLS_RSA_WITH_AES_128_CBC_SHA");
        tls.alert("fatal", "unexpected_message");
        check("fatal alert -> closed (via HSM parent)", (String) tls.status(), "closed");
        System.out.println("PASS: fatal alert forwards via HSM parent to $Closed");
    }

    static void test_warning_alert_ignored() {
        var tls = @@TlsServerHandshake();
        tls.client_hello("TLS 1.2", "TLS_RSA_WITH_AES_128_CBC_SHA");
        tls.alert("warning", "close_notify_soon");
        check("warning alert doesn't close", (String) tls.status(), "await key exchange");
        System.out.println("PASS: warning alert doesn't close handshake");
    }

    static void test_invalid_finished_closes() {
        var tls = @@TlsServerHandshake();
        tls.client_hello("TLS 1.2", "TLS_RSA_WITH_AES_128_CBC_SHA");
        tls.client_key_exchange("bogus");
        tls.client_change_cipher_spec();
        tls.client_finished("invalid");
        check("bad verify -> closed", (String) tls.status(), "closed");
        System.out.println("PASS: invalid client_finished closes");
    }

    static void test_fatal_alert_in_established() {
        var tls = @@TlsServerHandshake();
        tls.client_hello("TLS 1.2", "TLS_RSA_WITH_AES_128_CBC_SHA");
        tls.client_key_exchange("pm");
        tls.client_change_cipher_spec();
        tls.client_finished("valid");
        check("established", (String) tls.status(), "established");
        tls.alert("fatal", "bad_record_mac");
        check("fatal in $Established -> closed", (String) tls.status(), "closed");
        System.out.println("PASS: fatal alert in established closes");
    }

    public static void main(String[] args) {
        test_happy_handshake();
        test_unsupported_cipher_closes();
        test_fatal_alert_during_handshake();
        test_warning_alert_ignored();
        test_invalid_finished_closes();
        test_fatal_alert_in_established();
        System.out.println("PASS: all TLS handshake tests passed");
    }
}

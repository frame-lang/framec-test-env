@@[target("kotlin")]

// OOM Killer — kernel mm/oom_kill.c semantics.

@@system OomKiller {
    interface:
        oom_detected(gfp_flags: Int): String
        victim_exited(pid: Int, freed_kb: Int): String
        oom_detected_again(gfp_flags: Int): String
        status(): String

    machine:
        $Normal {
            oom_detected(gfp_flags: Int): String {
                @@:("selecting victim")
                -> $Selecting
            }
            status(): String { @@:("normal") }
        }

        $Selecting {
            $>() {
                this.victim_pid = this.select_victim()
                if (this.victim_pid < 0) {
                    -> $Panic
                } else {
                    -> $Killing
                }
            }
            status(): String { @@:("selecting") }
        }

        $Killing {
            $>() {
                this.send_sigkill(this.victim_pid)
                this.start_reaper_timer()
            }
            <$() {
                this.cancel_reaper_timer()
            }

            victim_exited(pid: Int, freed_kb: Int): String {
                if (pid == this.victim_pid) {
                    this.total_freed_kb = this.total_freed_kb + freed_kb
                    @@:("reclaimed")
                    -> $Normal
                } else {
                    @@:("wrong pid, still waiting")
                }
            }

            status(): String { @@:("killing") }
        }

        $Panic {
            status(): String { @@:("panic") }
        }

    actions:
        select_victim(): Int {
            this.victim_score = 850
            return 4242
        }
        send_sigkill(pid: Int) {}
        start_reaper_timer() {}
        cancel_reaper_timer() {}

    domain:
        victim_pid: Int = -1
        victim_score: Int = 0
        total_freed_kb: Int = 0
}


fun check(label: String, actual: String, expected: String) {
    if (actual != expected) {
        println("FAIL: $label — expected '$expected', got '$actual'")
        kotlin.system.exitProcess(1)
    }
}

fun test_normal_oom_flow() {
    val oom = @@OomKiller()
    check("initial normal", oom.status() as String, "normal")
    check("oom_detected -> selecting", oom.oom_detected(0) as String, "selecting victim")
    check("arrived in killing", oom.status() as String, "killing")
    check("victim exits", oom.victim_exited(4242, 51200) as String, "reclaimed")
    check("back to normal", oom.status() as String, "normal")
    println("PASS: normal OOM flow")
}

fun test_concurrent_oom_silently_dropped() {
    val oom = @@OomKiller()
    oom.oom_detected(0)
    check("in killing", oom.status() as String, "killing")
    oom.oom_detected_again(0)
    check("still killing (event dropped)", oom.status() as String, "killing")
    oom.victim_exited(4242, 8192)
    check("back to normal after reclaim", oom.status() as String, "normal")
    println("PASS: concurrent OOM events dropped in \$Killing (safety)")
}

fun test_wrong_pid_exit_ignored() {
    val oom = @@OomKiller()
    oom.oom_detected(0)
    check("waiting for victim", oom.victim_exited(9999, 1024) as String, "wrong pid, still waiting")
    check("still killing", oom.status() as String, "killing")
    oom.victim_exited(4242, 2048)
    check("correct pid -> normal", oom.status() as String, "normal")
    println("PASS: wrong-pid exit ignored in \$Killing")
}

fun test_oom_detected_ignored_in_selecting() {
    val oom = @@OomKiller()
    check("first oom", oom.oom_detected(0) as String, "selecting victim")
    oom.oom_detected(0)
    check("second oom dropped", oom.status() as String, "killing")
    println("PASS: oom_detected ignored while killing")
}

fun main() {
    test_normal_oom_flow()
    test_concurrent_oom_silently_dropped()
    test_wrong_pid_exit_ignored()
    test_oom_detected_ignored_in_selecting()
    println("PASS: all OOM killer tests passed")
}

@@[target("python_3")]

# TCP Connection — RFC 793 Figure 6 FSM with @@persist for TIME_WAIT.
# 11 states. Active-close path: FIN_WAIT_1 -> FIN_WAIT_2 -> TIME_WAIT.
# Passive-close path: CLOSE_WAIT -> LAST_ACK. Simultaneous close via $Closing.
# abort() sends RST and drops to Closed from Established.

@@[persist(bytes)]
@@[save(save_state)]
@@[load(restore_state)]
@@system TcpConnection {
    interface:
        passive_open()
        active_open()
        recv_syn()
        recv_syn_ack()
        recv_ack()
        recv_fin()
        app_close()
        app_send(bytes_n: int)
        timeout_2msl()
        abort()
        state_name(): str

    machine:
        $Closed {
            passive_open() { -> $Listen }
            active_open() {
                self.send_syn()
                -> $SynSent
            }
            state_name(): str { @@:("CLOSED") }
        }

        $Listen {
            recv_syn() {
                self.send_syn_ack()
                -> $SynReceived
            }
            app_close() { -> $Closed }
            state_name(): str { @@:("LISTEN") }
        }

        $SynSent {
            recv_syn_ack() {
                self.send_ack()
                -> $Established
            }
            recv_syn() {
                self.send_syn_ack()
                -> $SynReceived
            }
            app_close() { -> $Closed }
            state_name(): str { @@:("SYN_SENT") }
        }

        $SynReceived {
            recv_ack() { -> $Established }
            app_close() {
                self.send_fin()
                -> $FinWait1
            }
            state_name(): str { @@:("SYN_RECEIVED") }
        }

        $Established {
            app_send(bytes_n: int) {
                self.bytes_sent = self.bytes_sent + bytes_n
            }
            app_close() {
                self.send_fin()
                -> $FinWait1
            }
            recv_fin() {
                self.send_ack()
                -> $CloseWait
            }
            abort() {
                self.send_rst()
                -> $Closed
            }
            state_name(): str { @@:("ESTABLISHED") }
        }

        $FinWait1 {
            recv_ack() { -> $FinWait2 }
            recv_fin() {
                self.send_ack()
                -> $Closing
            }
            state_name(): str { @@:("FIN_WAIT_1") }
        }

        $FinWait2 {
            recv_fin() {
                self.send_ack()
                -> $TimeWait
            }
            state_name(): str { @@:("FIN_WAIT_2") }
        }

        $Closing {
            recv_ack() { -> $TimeWait }
            state_name(): str { @@:("CLOSING") }
        }

        $TimeWait {
            $>() {
                self.start_2msl_timer()
            }
            timeout_2msl() { -> $Closed }
            state_name(): str { @@:("TIME_WAIT") }
        }

        $CloseWait {
            app_close() {
                self.send_fin()
                -> $LastAck
            }
            state_name(): str { @@:("CLOSE_WAIT") }
        }

        $LastAck {
            recv_ack() { -> $Closed }
            state_name(): str { @@:("LAST_ACK") }
        }

    actions:
        send_syn()         { pass }
        send_syn_ack()     { pass }
        send_ack()         { pass }
        send_fin()         { pass }
        send_rst()         { pass }
        start_2msl_timer() { pass }

    domain:
        local_port: int = 0
        remote_port: int = 0
        bytes_sent: int = 0
}


def check(label, actual, expected):
    if actual != expected:
        print(f"FAIL: {label} — expected {expected!r}, got {actual!r}")
        raise SystemExit(1)

def test_active_open_full_cycle():
    c = @@TcpConnection()
    check("initial CLOSED", c.state_name(), "CLOSED")
    c.active_open()
    check("SYN_SENT", c.state_name(), "SYN_SENT")
    c.recv_syn_ack()
    check("ESTABLISHED", c.state_name(), "ESTABLISHED")
    c.app_send(1024)
    c.app_close()
    check("FIN_WAIT_1", c.state_name(), "FIN_WAIT_1")
    c.recv_ack()
    check("FIN_WAIT_2", c.state_name(), "FIN_WAIT_2")
    c.recv_fin()
    check("TIME_WAIT", c.state_name(), "TIME_WAIT")
    c.timeout_2msl()
    check("back to CLOSED", c.state_name(), "CLOSED")
    print("PASS: active open, full cycle to TIME_WAIT")

def test_passive_open_full_cycle():
    c = @@TcpConnection()
    c.passive_open()
    check("LISTEN", c.state_name(), "LISTEN")
    c.recv_syn()
    check("SYN_RECEIVED", c.state_name(), "SYN_RECEIVED")
    c.recv_ack()
    check("ESTABLISHED", c.state_name(), "ESTABLISHED")
    c.recv_fin()
    check("CLOSE_WAIT", c.state_name(), "CLOSE_WAIT")
    c.app_close()
    check("LAST_ACK", c.state_name(), "LAST_ACK")
    c.recv_ack()
    check("CLOSED", c.state_name(), "CLOSED")
    print("PASS: passive open, peer-initiated close")

def test_simultaneous_close():
    c = @@TcpConnection()
    c.active_open()
    c.recv_syn_ack()
    c.app_close()
    check("in FIN_WAIT_1", c.state_name(), "FIN_WAIT_1")
    c.recv_fin()
    check("CLOSING (simultaneous)", c.state_name(), "CLOSING")
    c.recv_ack()
    check("TIME_WAIT after CLOSING ACK", c.state_name(), "TIME_WAIT")
    print("PASS: simultaneous close -> CLOSING -> TIME_WAIT")

def test_abort_from_established():
    c = @@TcpConnection()
    c.active_open()
    c.recv_syn_ack()
    c.abort()
    check("RST drops to CLOSED", c.state_name(), "CLOSED")
    print("PASS: abort sends RST and returns to CLOSED")

def test_persist_across_restart():
    c = @@TcpConnection()
    c.active_open()
    c.recv_syn_ack()
    c.app_send(2048)
    c.app_close()
    c.recv_ack()
    c.recv_fin()
    check("TIME_WAIT before persist", c.state_name(), "TIME_WAIT")
    # Simulate process death + restart: save, destroy, restore.
    snap = c.save_state()
    c2 = @@TcpConnection()

    c2.restore_state(snap)
    check("TIME_WAIT restored", c2.state_name(), "TIME_WAIT")
    c2.timeout_2msl()
    check("CLOSED after 2MSL", c2.state_name(), "CLOSED")
    print("PASS: @@persist survives simulated restart in TIME_WAIT")

if __name__ == '__main__':
    test_active_open_full_cycle()
    test_passive_open_full_cycle()
    test_simultaneous_close()
    test_abort_from_established()
    test_persist_across_restart()
    print("PASS: all TCP connection tests passed")

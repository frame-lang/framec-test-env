@@[target("c")]

// PPP Link Control Protocol -- RFC 1661 Section 4 state table direct transcription.

#include <stdio.h>
#include <stdlib.h>
#include <string.h>

@@system PppLcp {
    interface:
        up()
        down()
        open()
        close()
        receive_configure_request(acceptable: bool)
        receive_configure_ack()
        receive_configure_nak()
        receive_terminate_request()
        receive_terminate_ack()
        timeout_positive()
        timeout_negative()
        status(): str

    machine:
        $Initial {
            up() { -> $Closed }
            open() { -> $Starting }
            status(): str { @@:("initial") }
        }

        $Starting {
            up() {
                PppLcp_init_restart_count(self);
                PppLcp_send_configure_request(self);
                -> $ReqSent
            }
            close() { -> $Initial }
            status(): str { @@:("starting") }
        }

        $Closed {
            open() {
                PppLcp_init_restart_count(self);
                PppLcp_send_configure_request(self);
                -> $ReqSent
            }
            down() { -> $Initial }
            receive_configure_request(acceptable: bool) {
                PppLcp_send_terminate_ack(self);
            }
            status(): str { @@:("closed") }
        }

        $Stopped {
            open() { -> $Stopped }
            down() { -> $Starting }
            receive_configure_request(acceptable: bool) {
                PppLcp_init_restart_count(self);
                if (acceptable) {
                    PppLcp_send_configure_ack(self);
                    PppLcp_send_configure_request(self);
                    -> $AckSent
                } else {
                    PppLcp_send_configure_nak(self);
                    PppLcp_send_configure_request(self);
                    -> $ReqSent
                }
            }
            status(): str { @@:("stopped") }
        }

        $Closing {
            timeout_positive() {
                PppLcp_send_terminate_request(self);
            }
            timeout_negative() {
                -> $Closed
            }
            receive_terminate_ack() {
                -> $Closed
            }
            down() { -> $Initial }
            status(): str { @@:("closing") }
        }

        $Stopping {
            timeout_positive() {
                PppLcp_send_terminate_request(self);
            }
            timeout_negative() {
                -> $Stopped
            }
            receive_terminate_ack() {
                -> $Stopped
            }
            down() { -> $Starting }
            status(): str { @@:("stopping") }
        }

        $ReqSent {
            timeout_positive() {
                PppLcp_send_configure_request(self);
            }
            timeout_negative() {
                -> $Stopped
            }
            receive_configure_request(acceptable: bool) {
                if (acceptable) {
                    PppLcp_send_configure_ack(self);
                    -> $AckSent
                } else {
                    PppLcp_send_configure_nak(self);
                }
            }
            receive_configure_ack() {
                PppLcp_init_restart_count(self);
                -> $AckRcvd
            }
            receive_configure_nak() {
                PppLcp_init_restart_count(self);
                PppLcp_send_configure_request(self);
            }
            receive_terminate_request() {
                PppLcp_send_terminate_ack(self);
                -> $ReqSent
            }
            close() {
                PppLcp_init_restart_count(self);
                PppLcp_send_terminate_request(self);
                -> $Closing
            }
            down() { -> $Starting }
            status(): str { @@:("req-sent") }
        }

        $AckRcvd {
            receive_configure_request(acceptable: bool) {
                if (acceptable) {
                    PppLcp_send_configure_ack(self);
                    PppLcp_tlu(self);
                    -> $Opened
                } else {
                    PppLcp_send_configure_nak(self);
                }
            }
            timeout_positive() {
                PppLcp_send_configure_request(self);
                -> $ReqSent
            }
            timeout_negative() { -> $Stopped }
            receive_configure_ack() {
                PppLcp_send_configure_request(self);
                -> $ReqSent
            }
            close() {
                PppLcp_init_restart_count(self);
                PppLcp_send_terminate_request(self);
                -> $Closing
            }
            down() { -> $Starting }
            status(): str { @@:("ack-rcvd") }
        }

        $AckSent {
            receive_configure_ack() {
                PppLcp_init_restart_count(self);
                PppLcp_tlu(self);
                -> $Opened
            }
            timeout_positive() {
                PppLcp_send_configure_request(self);
            }
            timeout_negative() { -> $Stopped }
            receive_configure_request(acceptable: bool) {
                if (acceptable) {
                    PppLcp_send_configure_ack(self);
                } else {
                    PppLcp_send_configure_nak(self);
                    -> $ReqSent
                }
            }
            receive_configure_nak() {
                PppLcp_init_restart_count(self);
                PppLcp_send_configure_request(self);
                -> $ReqSent
            }
            close() {
                PppLcp_init_restart_count(self);
                PppLcp_send_terminate_request(self);
                -> $Closing
            }
            down() { -> $Starting }
            status(): str { @@:("ack-sent") }
        }

        $Opened {
            <$() {
                PppLcp_tld(self);
            }

            receive_configure_request(acceptable: bool) {
                PppLcp_send_configure_request(self);
                if (acceptable) {
                    PppLcp_send_configure_ack(self);
                    -> $AckSent
                } else {
                    PppLcp_send_configure_nak(self);
                    -> $ReqSent
                }
            }
            receive_terminate_request() {
                PppLcp_send_terminate_ack(self);
                PppLcp_zero_restart_count(self);
                -> $Stopping
            }
            close() {
                PppLcp_init_restart_count(self);
                PppLcp_send_terminate_request(self);
                -> $Closing
            }
            down() {
                -> $Starting
            }
            status(): str { @@:("opened") }
        }

    actions:
        send_configure_request() {}
        send_configure_ack()     {}
        send_configure_nak()     {}
        send_terminate_request() {}
        send_terminate_ack()     {}
        init_restart_count() {
            self->restart_count = self->max_restart;
        }
        zero_restart_count() {
            self->restart_count = 0;
        }
        tlu() {}
        tld() {}

    domain:
        restart_count: int = 0
        max_restart: int = 10
}


void check(const char* label, const char* actual, const char* expected) {
    if (strcmp(actual, expected) != 0) {
        printf("FAIL: %s -- expected '%s', got '%s'\n", label, expected, actual);
        exit(1);
    }
}

void test_normal_open(void) {
    PppLcp* ppp = @@PppLcp();
    check("initial", (const char*)PppLcp_status(ppp), "initial");
    PppLcp_open(ppp);
    check("starting", (const char*)PppLcp_status(ppp), "starting");
    PppLcp_up(ppp);
    check("req-sent", (const char*)PppLcp_status(ppp), "req-sent");
    PppLcp_receive_configure_ack(ppp);
    check("ack-rcvd", (const char*)PppLcp_status(ppp), "ack-rcvd");
    PppLcp_receive_configure_request(ppp, 1);
    check("opened", (const char*)PppLcp_status(ppp), "opened");
    printf("PASS: normal open sequence\n");
    PppLcp_destroy(ppp);
}

void test_peer_renegotiation(void) {
    PppLcp* ppp = @@PppLcp();
    PppLcp_open(ppp);
    PppLcp_up(ppp);
    PppLcp_receive_configure_ack(ppp);
    PppLcp_receive_configure_request(ppp, 1);
    check("opened first time", (const char*)PppLcp_status(ppp), "opened");
    PppLcp_receive_configure_request(ppp, 1);
    check("renegotiation -> AckSent", (const char*)PppLcp_status(ppp), "ack-sent");
    PppLcp_receive_configure_ack(ppp);
    check("back to opened", (const char*)PppLcp_status(ppp), "opened");
    printf("PASS: peer-initiated renegotiation from opened\n");
    PppLcp_destroy(ppp);
}

void test_clean_shutdown(void) {
    PppLcp* ppp = @@PppLcp();
    PppLcp_open(ppp);
    PppLcp_up(ppp);
    PppLcp_receive_configure_ack(ppp);
    PppLcp_receive_configure_request(ppp, 1);
    PppLcp_close(ppp);
    check("closing", (const char*)PppLcp_status(ppp), "closing");
    PppLcp_receive_terminate_ack(ppp);
    check("closed", (const char*)PppLcp_status(ppp), "closed");
    printf("PASS: clean shutdown via close()\n");
    PppLcp_destroy(ppp);
}

void test_peer_terminate(void) {
    PppLcp* ppp = @@PppLcp();
    PppLcp_open(ppp);
    PppLcp_up(ppp);
    PppLcp_receive_configure_ack(ppp);
    PppLcp_receive_configure_request(ppp, 1);
    PppLcp_receive_terminate_request(ppp);
    check("stopping on peer-terminate", (const char*)PppLcp_status(ppp), "stopping");
    PppLcp_receive_terminate_ack(ppp);
    check("stopped", (const char*)PppLcp_status(ppp), "stopped");
    printf("PASS: peer-initiated terminate\n");
    PppLcp_destroy(ppp);
}

void test_timeout_negative_from_closing(void) {
    PppLcp* ppp = @@PppLcp();
    PppLcp_open(ppp);
    PppLcp_up(ppp);
    PppLcp_receive_configure_ack(ppp);
    PppLcp_receive_configure_request(ppp, 1);
    PppLcp_close(ppp);
    check("closing", (const char*)PppLcp_status(ppp), "closing");
    PppLcp_timeout_negative(ppp);
    check("closing exhausts to closed", (const char*)PppLcp_status(ppp), "closed");
    printf("PASS: timeout_negative in closing -> closed\n");
    PppLcp_destroy(ppp);
}

void test_down_from_opened(void) {
    PppLcp* ppp = @@PppLcp();
    PppLcp_open(ppp);
    PppLcp_up(ppp);
    PppLcp_receive_configure_ack(ppp);
    PppLcp_receive_configure_request(ppp, 1);
    PppLcp_down(ppp);
    check("down from opened -> starting", (const char*)PppLcp_status(ppp), "starting");
    printf("PASS: down from opened\n");
    PppLcp_destroy(ppp);
}

int main(void) {
    test_normal_open();
    test_peer_renegotiation();
    test_clean_shutdown();
    test_peer_terminate();
    test_timeout_negative_from_closing();
    test_down_from_opened();
    printf("PASS: all PPP LCP tests passed\n");
    return 0;
}

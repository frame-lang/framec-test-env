@@target dart

// Signal Handler Stack — textbook push$/pop$ use case.

import 'dart:io';

@@system SignalContext {
    interface:
        enter_user_code()
        signal_arrives(sig: String)
        handler_returns()
        current_mode(): String
        depth(): int
        current_signum(): String

    machine:
        $Kernel {
            enter_user_code() {
                -> $UserMode
            }
            current_mode(): String { @@:("kernel") }
            depth(): int { @@:(this.nesting) }
            current_signum(): String { @@:("") }
        }

        $UserMode {
            $.saved_regs: String = ""

            $>() {
                $.saved_regs = this.snapshot_registers();
            }

            signal_arrives(sig: String) {
                this.nesting = this.nesting + 1;
                push$
                -> (sig) $SignalHandler
            }
            current_mode(): String { @@:("user") }
            depth(): int { @@:(this.nesting) }
            current_signum(): String { @@:("") }
        }

        $SignalHandler {
            $.signum: String = ""

            $>(sig: String) {
                $.signum = sig;
            }

            signal_arrives(sig: String) {
                this.nesting = this.nesting + 1;
                push$
                -> (sig) $SignalHandler
            }

            handler_returns() {
                this.nesting = this.nesting - 1;
                -> pop$
            }

            current_mode(): String { @@:("handler") }
            depth(): int { @@:(this.nesting) }
            current_signum(): String { @@:($.signum) }
        }

    actions:
        snapshot_registers(): String {
            return "regs_snapshot";
        }

    domain:
        nesting: int = 0
}


void check_str(String label, String actual, String expected) {
    if (actual != expected) {
        print("FAIL: $label -- expected '$expected', got '$actual'");
        exit(1);
    }
}

void check_int(String label, int actual, int expected) {
    if (actual != expected) {
        print("FAIL: $label -- expected $expected, got $actual");
        exit(1);
    }
}

void test_enter_user_mode() {
    final cpu = @@SignalContext();
    check_str("initial kernel", cpu.current_mode() as String, "kernel");
    cpu.enter_user_code();
    check_str("in user mode", cpu.current_mode() as String, "user");
    check_int("depth 0", cpu.depth() as int, 0);
    print("PASS: enter user mode");
}

void test_single_signal_handler() {
    final cpu = @@SignalContext();
    cpu.enter_user_code();
    cpu.signal_arrives("SIGUSR1");
    check_str("in handler", cpu.current_mode() as String, "handler");
    check_str("signum SIGUSR1", cpu.current_signum() as String, "SIGUSR1");
    check_int("depth 1", cpu.depth() as int, 1);
    cpu.handler_returns();
    check_str("back to user", cpu.current_mode() as String, "user");
    check_int("depth 0", cpu.depth() as int, 0);
    print("PASS: single signal handler + return");
}

void test_nested_signals() {
    final cpu = @@SignalContext();
    cpu.enter_user_code();
    cpu.signal_arrives("SIGUSR1");
    check_str("outer handler signum", cpu.current_signum() as String, "SIGUSR1");
    cpu.signal_arrives("SIGALRM");
    check_str("inner handler signum", cpu.current_signum() as String, "SIGALRM");
    check_int("nested depth 2", cpu.depth() as int, 2);
    cpu.handler_returns();
    check_str("popped to outer handler", cpu.current_mode() as String, "handler");
    check_str("outer signum preserved across pop", cpu.current_signum() as String, "SIGUSR1");
    check_int("depth 1", cpu.depth() as int, 1);
    cpu.handler_returns();
    check_str("back to user", cpu.current_mode() as String, "user");
    check_int("depth 0", cpu.depth() as int, 0);
    print("PASS: nested signals (push\$/pop\$ preserves state vars)");
}

void test_deeply_nested_signals() {
    final cpu = @@SignalContext();
    cpu.enter_user_code();
    cpu.signal_arrives("SIG1");
    cpu.signal_arrives("SIG2");
    cpu.signal_arrives("SIG3");
    cpu.signal_arrives("SIG4");
    check_int("depth 4", cpu.depth() as int, 4);
    check_str("top signum", cpu.current_signum() as String, "SIG4");
    cpu.handler_returns();
    check_str("after pop 1: SIG3", cpu.current_signum() as String, "SIG3");
    cpu.handler_returns();
    check_str("after pop 2: SIG2", cpu.current_signum() as String, "SIG2");
    cpu.handler_returns();
    check_str("after pop 3: SIG1", cpu.current_signum() as String, "SIG1");
    cpu.handler_returns();
    check_str("back to user", cpu.current_mode() as String, "user");
    print("PASS: 4-deep nested signal stack");
}

void main() {
    test_enter_user_mode();
    test_single_signal_handler();
    test_nested_signals();
    test_deeply_nested_signals();
    print("PASS: all signal handler stack tests passed");
}

@@target dart

// Block I/O Request — kernel blk-mq layer semantics.

import 'dart:io';

@@system BlockRequest {
    interface:
        submit(sector: int, size: int): String
        dispatch(): String
        complete(success: bool): String
        timeout(): String
        status(): String

    machine:
        $Idle {
            submit(sector: int, size: int): String {
                this.sector = sector;
                this.size = size;
                this.attempts = 0;
                @@:("queued")
                -> $Queued
            }
            status(): String { @@:("idle") }
        }

        $Queued {
            dispatch(): String {
                @@:("dispatched")
                -> $InFlight
            }
            status(): String { @@:("queued") }
        }

        $InFlight {
            $>() {
                this.attempts = this.attempts + 1;
                this.start_timeout();
            }
            <$() {
                this.cancel_timeout();
            }

            complete(success: bool): String {
                if (success) {
                    @@:("done")
                    -> $Done
                } else {
                    if (this.attempts < this.max_retries) {
                        @@:("requeued")
                        -> $Queued
                    } else {
                        @@:("io error")
                        -> $Error
                    }
                }
            }
            timeout(): String {
                if (this.attempts < this.max_retries) {
                    @@:("timeout, retrying")
                    -> $Queued
                } else {
                    @@:("timeout, giving up")
                    -> $Error
                }
            }
            status(): String { @@:("in-flight") }
        }

        $Done {
            status(): String { @@:("done") }
        }

        $Error {
            status(): String { @@:("error") }
        }

    actions:
        start_timeout() {}
        cancel_timeout() {}

    domain:
        sector: int = 0
        size: int = 0
        attempts: int = 0
        max_retries: int = 3
        timeout_ms: int = 30000
}


void check(String label, String actual, String expected) {
    if (actual != expected) {
        print("FAIL: $label — expected '$expected', got '$actual'");
        exit(1);
    }
}

void test_happy_path() {
    final req = @@BlockRequest();
    check("initial idle", req.status() as String, "idle");
    check("submit", req.submit(1024, 8) as String, "queued");
    check("dispatch", req.dispatch() as String, "dispatched");
    check("complete ok", req.complete(true) as String, "done");
    check("terminal done", req.status() as String, "done");
    print("PASS: happy path");
}

void test_timeout_retry_then_complete() {
    final req = @@BlockRequest();
    req.submit(2048, 4);
    req.dispatch();
    check("first timeout -> retry", req.timeout() as String, "timeout, retrying");
    check("back to queued after timeout", req.status() as String, "queued");
    req.dispatch();
    check("complete after retry", req.complete(true) as String, "done");
    print("PASS: timeout then retry success");
}

void test_failure_requeue_then_success() {
    final req = @@BlockRequest();
    req.submit(4096, 2);
    req.dispatch();
    check("complete(false) -> requeued", req.complete(false) as String, "requeued");
    req.dispatch();
    check("complete(true) -> done", req.complete(true) as String, "done");
    print("PASS: failure requeue then success");
}

void test_retry_exhaustion() {
    final req = @@BlockRequest();
    req.submit(8192, 1);
    req.dispatch();
    check("req 1 failure requeued", req.complete(false) as String, "requeued");
    req.dispatch();
    check("req 2 failure requeued", req.complete(false) as String, "requeued");
    req.dispatch();
    check("req 3 failure -> io error", req.complete(false) as String, "io error");
    check("terminal error state", req.status() as String, "error");
    print("PASS: retry exhaustion -> error");
}

void test_timeout_exhaustion() {
    final req = @@BlockRequest();
    req.submit(16384, 1);
    req.dispatch();
    check("to 1 retry", req.timeout() as String, "timeout, retrying");
    req.dispatch();
    check("to 2 retry", req.timeout() as String, "timeout, retrying");
    req.dispatch();
    check("to 3 giving up", req.timeout() as String, "timeout, giving up");
    check("error terminal", req.status() as String, "error");
    print("PASS: timeout exhaustion -> error");
}

void main() {
    test_happy_path();
    test_timeout_retry_then_complete();
    test_failure_requeue_then_success();
    test_retry_exhaustion();
    test_timeout_exhaustion();
    print("PASS: all block I/O request tests passed");
}

@@target csharp

// USB Device Enumeration — multi-stage pipeline with compensation (saga).

using System;

@@system UsbEnumerator {
    interface:
        plug_in(port: int)
        reset_done(success: bool)
        address_set(success: bool, addr: int)
        descriptors_read(success: bool, product: String)
        driver_bound(success: bool)
        unplug()
        status(): String

    machine:
        $Detached {
            plug_in(port: int) {
                this.port = port;
                this.reset_attempts = 0;
                -> $Resetting
            }
            status(): String { @@:("detached") }
        }

        $Resetting => $Enumerating {
            $>() {
                this.reset_attempts = this.reset_attempts + 1;
                this.issue_port_reset(this.port);
            }

            reset_done(success: bool) {
                if (success) {
                    -> $Addressing
                } else {
                    if (this.reset_attempts < this.max_reset_attempts) {
                        -> $Resetting
                    } else {
                        -> $Failed
                    }
                }
            }
            status(): String { @@:("resetting") }
            => $^
        }

        $Addressing => $Enumerating {
            $>() {
                this.assign_address();
            }

            address_set(success: bool, addr: int) {
                if (success) {
                    this.address = addr;
                    -> $ReadingDescriptors
                } else {
                    -> $UndoReset
                }
            }
            status(): String { @@:("addressing") }
            => $^
        }

        $ReadingDescriptors => $Enumerating {
            $>() {
                this.read_descriptors(this.address);
            }

            descriptors_read(success: bool, product: String) {
                if (success) {
                    this.product = product;
                    -> $BindingDriver
                } else {
                    -> $UndoAddress
                }
            }
            status(): String { @@:("reading descriptors") }
            => $^
        }

        $BindingDriver => $Enumerating {
            $>() {
                this.bind_driver(this.product);
            }

            driver_bound(success: bool) {
                if (success) {
                    -> $Configured
                } else {
                    -> $UndoAddress
                }
            }
            status(): String { @@:("binding driver") }
            => $^
        }

        $Enumerating {
            unplug() {
                -> $Detached
            }
        }

        $UndoAddress {
            $>() {
                this.release_address(this.address);
                -> $UndoReset
            }
        }

        $UndoReset {
            $>() {
                this.disable_port(this.port);
                -> $Failed
            }
        }

        $Configured {
            unplug() {
                this.unbind_driver();
                this.release_address(this.address);
                this.disable_port(this.port);
                -> $Detached
            }
            status(): String { @@:("configured") }
        }

        $Failed {
            plug_in(port: int) {
                this.port = port;
                this.reset_attempts = 0;
                -> $Resetting
            }
            status(): String { @@:("failed") }
        }

    actions:
        issue_port_reset(port: int) {}
        assign_address() {}
        read_descriptors(addr: int) {}
        bind_driver(product: String) {}
        release_address(addr: int) {}
        disable_port(port: int) {}
        unbind_driver() {}

    domain:
        port: int = 0
        address: int = 0
        product: String = ""
        reset_attempts: int = 0
        max_reset_attempts: int = 3
}


class Program {
    static void check(string label, string actual, string expected) {
        if (actual != expected) {
            Console.WriteLine($"FAIL: {label} — expected '{expected}', got '{actual}'");
            Environment.Exit(1);
        }
    }

    static void test_happy_path() {
        var usb = @@UsbEnumerator();
        check("initial detached", (string) usb.status(), "detached");
        usb.plug_in(1);
        check("after plug_in", (string) usb.status(), "resetting");
        usb.reset_done(true);
        check("reset ok -> addressing", (string) usb.status(), "addressing");
        usb.address_set(true, 7);
        check("address ok -> reading", (string) usb.status(), "reading descriptors");
        usb.descriptors_read(true, "USB Keyboard");
        check("descriptors ok -> binding", (string) usb.status(), "binding driver");
        usb.driver_bound(true);
        check("driver bound -> configured", (string) usb.status(), "configured");
        Console.WriteLine("PASS: happy path enumeration");
    }

    static void test_descriptor_failure_compensates() {
        var usb = @@UsbEnumerator();
        usb.plug_in(2);
        usb.reset_done(true);
        usb.address_set(true, 8);
        usb.descriptors_read(false, "");
        check("compensated to failed", (string) usb.status(), "failed");
        Console.WriteLine("PASS: descriptor failure compensation");
    }

    static void test_driver_bind_failure_compensates() {
        var usb = @@UsbEnumerator();
        usb.plug_in(3);
        usb.reset_done(true);
        usb.address_set(true, 9);
        usb.descriptors_read(true, "Mouse");
        usb.driver_bound(false);
        check("bind fail compensated to failed", (string) usb.status(), "failed");
        Console.WriteLine("PASS: driver bind failure compensation");
    }

    static void test_unplug_during_enumeration() {
        var usb = @@UsbEnumerator();
        usb.plug_in(4);
        check("in resetting", (string) usb.status(), "resetting");
        usb.unplug();
        check("unplug -> detached", (string) usb.status(), "detached");
        Console.WriteLine("PASS: unplug during enumeration forwards via HSM");
    }

    static void test_reset_retry_then_exhaust() {
        var usb = @@UsbEnumerator();
        usb.plug_in(5);
        usb.reset_done(false);
        check("retry 1", (string) usb.status(), "resetting");
        usb.reset_done(false);
        check("retry 2", (string) usb.status(), "resetting");
        usb.reset_done(false);
        check("exhausted -> failed", (string) usb.status(), "failed");
        Console.WriteLine("PASS: reset retry exhaustion");
    }

    static void test_replug_from_failed() {
        var usb = @@UsbEnumerator();
        usb.plug_in(6);
        usb.reset_done(false);
        usb.reset_done(false);
        usb.reset_done(false);
        check("failed state", (string) usb.status(), "failed");
        usb.plug_in(6);
        check("re-plug restarts enumeration", (string) usb.status(), "resetting");
        Console.WriteLine("PASS: re-plug from failed state");
    }

    static void Main(string[] args) {
        test_happy_path();
        test_descriptor_failure_compensates();
        test_driver_bind_failure_compensates();
        test_unplug_during_enumeration();
        test_reset_retry_then_exhaust();
        test_replug_from_failed();
        Console.WriteLine("PASS: all USB enumeration tests passed");
    }
}

@@target lua

-- PPP Link Control Protocol -- RFC 1661 Section 4 state table direct transcription.

@@system PppLcp {
    interface:
        up()
        down()
        open()
        close()
        receive_configure_request(acceptable: bool)
        receive_configure_ack()
        receive_configure_nak()
        receive_terminate_request()
        receive_terminate_ack()
        timeout_positive()
        timeout_negative()
        status(): str

    machine:
        $Initial {
            up() { -> $Closed }
            open() { -> $Starting }
            status(): str { @@:("initial") }
        }

        $Starting {
            up() {
                self:init_restart_count()
                self:send_configure_request()
                -> $ReqSent
            }
            close() { -> $Initial }
            status(): str { @@:("starting") }
        }

        $Closed {
            open() {
                self:init_restart_count()
                self:send_configure_request()
                -> $ReqSent
            }
            down() { -> $Initial }
            receive_configure_request(acceptable: bool) {
                self:send_terminate_ack()
            }
            status(): str { @@:("closed") }
        }

        $Stopped {
            open() { -> $Stopped }
            down() { -> $Starting }
            receive_configure_request(acceptable: bool) {
                self:init_restart_count()
                if acceptable then
                    self:send_configure_ack()
                    self:send_configure_request()
                    -> $AckSent
                else
                    self:send_configure_nak()
                    self:send_configure_request()
                    -> $ReqSent
                end
            }
            status(): str { @@:("stopped") }
        }

        $Closing {
            timeout_positive() {
                self:send_terminate_request()
            }
            timeout_negative() {
                -> $Closed
            }
            receive_terminate_ack() {
                -> $Closed
            }
            down() { -> $Initial }
            status(): str { @@:("closing") }
        }

        $Stopping {
            timeout_positive() {
                self:send_terminate_request()
            }
            timeout_negative() {
                -> $Stopped
            }
            receive_terminate_ack() {
                -> $Stopped
            }
            down() { -> $Starting }
            status(): str { @@:("stopping") }
        }

        $ReqSent {
            timeout_positive() {
                self:send_configure_request()
            }
            timeout_negative() {
                -> $Stopped
            }
            receive_configure_request(acceptable: bool) {
                if acceptable then
                    self:send_configure_ack()
                    -> $AckSent
                else
                    self:send_configure_nak()
                end
            }
            receive_configure_ack() {
                self:init_restart_count()
                -> $AckRcvd
            }
            receive_configure_nak() {
                self:init_restart_count()
                self:send_configure_request()
            }
            receive_terminate_request() {
                self:send_terminate_ack()
                -> $ReqSent
            }
            close() {
                self:init_restart_count()
                self:send_terminate_request()
                -> $Closing
            }
            down() { -> $Starting }
            status(): str { @@:("req-sent") }
        }

        $AckRcvd {
            receive_configure_request(acceptable: bool) {
                if acceptable then
                    self:send_configure_ack()
                    self:tlu()
                    -> $Opened
                else
                    self:send_configure_nak()
                end
            }
            timeout_positive() {
                self:send_configure_request()
                -> $ReqSent
            }
            timeout_negative() { -> $Stopped }
            receive_configure_ack() {
                self:send_configure_request()
                -> $ReqSent
            }
            close() {
                self:init_restart_count()
                self:send_terminate_request()
                -> $Closing
            }
            down() { -> $Starting }
            status(): str { @@:("ack-rcvd") }
        }

        $AckSent {
            receive_configure_ack() {
                self:init_restart_count()
                self:tlu()
                -> $Opened
            }
            timeout_positive() {
                self:send_configure_request()
            }
            timeout_negative() { -> $Stopped }
            receive_configure_request(acceptable: bool) {
                if acceptable then
                    self:send_configure_ack()
                else
                    self:send_configure_nak()
                    -> $ReqSent
                end
            }
            receive_configure_nak() {
                self:init_restart_count()
                self:send_configure_request()
                -> $ReqSent
            }
            close() {
                self:init_restart_count()
                self:send_terminate_request()
                -> $Closing
            }
            down() { -> $Starting }
            status(): str { @@:("ack-sent") }
        }

        $Opened {
            <$() {
                self:tld()
            }

            receive_configure_request(acceptable: bool) {
                self:send_configure_request()
                if acceptable then
                    self:send_configure_ack()
                    -> $AckSent
                else
                    self:send_configure_nak()
                    -> $ReqSent
                end
            }
            receive_terminate_request() {
                self:send_terminate_ack()
                self:zero_restart_count()
                -> $Stopping
            }
            close() {
                self:init_restart_count()
                self:send_terminate_request()
                -> $Closing
            }
            down() {
                -> $Starting
            }
            status(): str { @@:("opened") }
        }

    actions:
        send_configure_request() {}
        send_configure_ack()     {}
        send_configure_nak()     {}
        send_terminate_request() {}
        send_terminate_ack()     {}
        init_restart_count() {
            self.restart_count = self.max_restart
        }
        zero_restart_count() {
            self.restart_count = 0
        }
        tlu() {}
        tld() {}

    domain:
        restart_count: int = 0
        max_restart: int = 10
}


local function check(label, actual, expected)
    if actual ~= expected then
        print("FAIL: " .. label .. " -- expected '" .. tostring(expected) .. "', got '" .. tostring(actual) .. "'")
        os.exit(1)
    end
end

local function test_normal_open()
    local ppp = @@PppLcp()
    check("initial", ppp:status(), "initial")
    ppp:open()
    check("starting", ppp:status(), "starting")
    ppp:up()
    check("req-sent", ppp:status(), "req-sent")
    ppp:receive_configure_ack()
    check("ack-rcvd", ppp:status(), "ack-rcvd")
    ppp:receive_configure_request(true)
    check("opened", ppp:status(), "opened")
    print("PASS: normal open sequence")
end

local function test_peer_renegotiation()
    local ppp = @@PppLcp()
    ppp:open()
    ppp:up()
    ppp:receive_configure_ack()
    ppp:receive_configure_request(true)
    check("opened first time", ppp:status(), "opened")
    ppp:receive_configure_request(true)
    check("renegotiation -> AckSent", ppp:status(), "ack-sent")
    ppp:receive_configure_ack()
    check("back to opened", ppp:status(), "opened")
    print("PASS: peer-initiated renegotiation from opened")
end

local function test_clean_shutdown()
    local ppp = @@PppLcp()
    ppp:open()
    ppp:up()
    ppp:receive_configure_ack()
    ppp:receive_configure_request(true)
    ppp:close()
    check("closing", ppp:status(), "closing")
    ppp:receive_terminate_ack()
    check("closed", ppp:status(), "closed")
    print("PASS: clean shutdown via close()")
end

local function test_peer_terminate()
    local ppp = @@PppLcp()
    ppp:open()
    ppp:up()
    ppp:receive_configure_ack()
    ppp:receive_configure_request(true)
    ppp:receive_terminate_request()
    check("stopping on peer-terminate", ppp:status(), "stopping")
    ppp:receive_terminate_ack()
    check("stopped", ppp:status(), "stopped")
    print("PASS: peer-initiated terminate")
end

local function test_timeout_negative_from_closing()
    local ppp = @@PppLcp()
    ppp:open()
    ppp:up()
    ppp:receive_configure_ack()
    ppp:receive_configure_request(true)
    ppp:close()
    check("closing", ppp:status(), "closing")
    ppp:timeout_negative()
    check("closing exhausts to closed", ppp:status(), "closed")
    print("PASS: timeout_negative in closing -> closed")
end

local function test_down_from_opened()
    local ppp = @@PppLcp()
    ppp:open()
    ppp:up()
    ppp:receive_configure_ack()
    ppp:receive_configure_request(true)
    ppp:down()
    check("down from opened -> starting", ppp:status(), "starting")
    print("PASS: down from opened")
end

test_normal_open()
test_peer_renegotiation()
test_clean_shutdown()
test_peer_terminate()
test_timeout_negative_from_closing()
test_down_from_opened()
print("PASS: all PPP LCP tests passed")

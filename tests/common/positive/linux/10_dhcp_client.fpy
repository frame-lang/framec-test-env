@@[target("python_3")]

# DHCP Client — RFC 2131 Figure 5 state machine.
# Lease lifecycle: Init -> Selecting -> Requesting -> Bound
#                                                   <- Renewing (t1_expired)
#                                                   <- Rebinding (t2_expired from Renewing)
# Timers (T1/T2/lease) are armed once in $Bound and not cancelled on state
# transition — they're absolute deadlines. Only release/nak/lease_expired
# cancel them explicitly.

@@system DhcpClient {
    interface:
        start()
        offer_received(server_ip: str, offered_ip: str, lease_sec: int)
        ack_received(ip: str, lease_sec: int)
        nak_received()
        t1_expired()
        t2_expired()
        lease_expired()
        release()
        status(): str

    machine:
        $Init {
            $>() {
                self.attempts = 0
            }

            start() {
                -> $Selecting
            }
            status(): str { @@:("init") }
        }

        $Selecting {
            $>() {
                self.attempts = self.attempts + 1
                self.broadcast_discover()
            }

            offer_received(server_ip: str, offered_ip: str, lease_sec: int) {
                self.server = server_ip
                self.offered = offered_ip
                self.lease_sec = lease_sec
                -> $Requesting
            }
            status(): str { @@:("selecting") }
        }

        $Requesting {
            $>() {
                self.send_request()
            }

            ack_received(ip: str, lease_sec: int) {
                self.bound = ip
                self.lease_sec = lease_sec
                -> $Bound
            }
            nak_received() {
                -> $Init
            }
            status(): str { @@:("requesting") }
        }

        $Bound {
            $>() {
                self.arm_timers()
            }

            t1_expired() {
                -> $Renewing
            }
            release() {
                self.cancel_all_timers()
                self.send_release()
                -> $Init
            }
            status(): str { @@:("bound") }
        }

        $Renewing {
            $>() {
                self.send_renew()
            }

            ack_received(ip: str, lease_sec: int) {
                self.lease_sec = lease_sec
                -> $Bound
            }
            nak_received() {
                self.cancel_all_timers()
                -> $Init
            }
            t2_expired() {
                -> $Rebinding
            }
            lease_expired() {
                self.cancel_all_timers()
                -> $Init
            }
            release() {
                self.cancel_all_timers()
                -> $Init
            }
            status(): str { @@:("renewing") }
        }

        $Rebinding {
            $>() {
                self.broadcast_renew()
            }

            ack_received(ip: str, lease_sec: int) {
                self.lease_sec = lease_sec
                -> $Bound
            }
            nak_received() {
                self.cancel_all_timers()
                -> $Init
            }
            lease_expired() {
                self.cancel_all_timers()
                self.bound = ""
                -> $Init
            }
            release() {
                self.cancel_all_timers()
                -> $Init
            }
            status(): str { @@:("rebinding") }
        }

    actions:
        broadcast_discover()    { pass }
        send_request()          { pass }
        send_renew()            { pass }
        broadcast_renew()       { pass }
        send_release()          { pass }
        arm_timers()            { pass }
        cancel_all_timers()     { pass }

    domain:
        server: str = ""
        offered: str = ""
        bound: str = ""
        lease_sec: int = 0
        attempts: int = 0
}


def check(label, actual, expected):
    if actual != expected:
        print(f"FAIL: {label} — expected {expected!r}, got {actual!r}")
        raise SystemExit(1)

def test_full_lease_acquisition():
    dhcp = @@DhcpClient()
    check("initial init", dhcp.status(), "init")
    dhcp.start()
    check("selecting", dhcp.status(), "selecting")
    dhcp.offer_received("192.168.1.1", "192.168.1.100", 3600)
    check("requesting after offer", dhcp.status(), "requesting")
    dhcp.ack_received("192.168.1.100", 3600)
    check("bound", dhcp.status(), "bound")
    print("PASS: full lease acquisition Init->Selecting->Requesting->Bound")

def test_t1_triggers_renewal():
    dhcp = @@DhcpClient()
    dhcp.start()
    dhcp.offer_received("10.0.0.1", "10.0.0.100", 7200)
    dhcp.ack_received("10.0.0.100", 7200)
    dhcp.t1_expired()
    check("renewing after t1", dhcp.status(), "renewing")
    dhcp.ack_received("10.0.0.100", 7200)
    check("back to bound after renew ack", dhcp.status(), "bound")
    print("PASS: T1 triggers renewal, ACK returns to bound")

def test_t2_triggers_rebind():
    dhcp = @@DhcpClient()
    dhcp.start()
    dhcp.offer_received("10.0.0.1", "10.0.0.100", 7200)
    dhcp.ack_received("10.0.0.100", 7200)
    dhcp.t1_expired()
    check("renewing", dhcp.status(), "renewing")
    dhcp.t2_expired()
    check("rebinding after t2", dhcp.status(), "rebinding")
    dhcp.ack_received("10.0.0.100", 7200)
    check("rebind ACK -> bound", dhcp.status(), "bound")
    print("PASS: T2 triggers rebind, ACK returns to bound")

def test_nak_during_requesting_restarts():
    dhcp = @@DhcpClient()
    dhcp.start()
    dhcp.offer_received("10.0.0.1", "10.0.0.100", 7200)
    dhcp.nak_received()
    check("NAK in Requesting -> Init", dhcp.status(), "init")
    print("PASS: NAK in Requesting restarts")

def test_lease_expired_in_rebinding():
    dhcp = @@DhcpClient()
    dhcp.start()
    dhcp.offer_received("10.0.0.1", "10.0.0.100", 7200)
    dhcp.ack_received("10.0.0.100", 7200)
    dhcp.t1_expired()
    dhcp.t2_expired()
    dhcp.lease_expired()
    check("lease_expired in Rebinding -> Init", dhcp.status(), "init")
    print("PASS: lease expiry in rebinding clears state")

def test_release_from_bound():
    dhcp = @@DhcpClient()
    dhcp.start()
    dhcp.offer_received("10.0.0.1", "10.0.0.100", 7200)
    dhcp.ack_received("10.0.0.100", 7200)
    dhcp.release()
    check("release -> init", dhcp.status(), "init")
    print("PASS: release from bound")

if __name__ == '__main__':
    test_full_lease_acquisition()
    test_t1_triggers_renewal()
    test_t2_triggers_rebind()
    test_nak_during_requesting_restarts()
    test_lease_expired_in_rebinding()
    test_release_from_bound()
    print("PASS: all DHCP client tests passed")

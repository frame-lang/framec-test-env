@@target cpp_17

// Signal Handler Stack — textbook push$/pop$ use case.

#include <iostream>
#include <string>
#include <cassert>
#include <cstdlib>

@@system SignalContext {
    interface:
        enter_user_code()
        signal_arrives(sig: str)
        handler_returns()
        current_mode(): str
        depth(): int
        current_signum(): str

    machine:
        $Kernel {
            enter_user_code() {
                -> $UserMode
            }
            current_mode(): str { @@:(std::string("kernel")) }
            depth(): int { @@:(this->nesting) }
            current_signum(): str { @@:(std::string("")) }
        }

        $UserMode {
            $.saved_regs: std::string = ""

            $>() {
                $.saved_regs = this->snapshot_registers();
            }

            signal_arrives(sig: str) {
                this->nesting = this->nesting + 1;
                push$
                -> (sig) $SignalHandler
            }
            current_mode(): str { @@:(std::string("user")) }
            depth(): int { @@:(this->nesting) }
            current_signum(): str { @@:(std::string("")) }
        }

        $SignalHandler {
            $.signum: std::string = ""

            $>(sig: str) {
                $.signum = sig;
            }

            signal_arrives(sig: str) {
                this->nesting = this->nesting + 1;
                push$
                -> (sig) $SignalHandler
            }

            handler_returns() {
                this->nesting = this->nesting - 1;
                -> pop$
            }

            current_mode(): str { @@:(std::string("handler")) }
            depth(): int { @@:(this->nesting) }
            current_signum(): str { @@:($.signum) }
        }

    actions:
        snapshot_registers(): std::string {
            return std::string("regs_snapshot");
        }

    domain:
        nesting: int = 0
}


void check_str(const std::string& label, const std::string& actual, const std::string& expected) {
    if (actual != expected) {
        std::cout << "FAIL: " << label << " -- expected '" << expected << "', got '" << actual << "'" << std::endl;
        std::exit(1);
    }
}

void check_int(const std::string& label, int actual, int expected) {
    if (actual != expected) {
        std::cout << "FAIL: " << label << " -- expected " << expected << ", got " << actual << std::endl;
        std::exit(1);
    }
}

void test_enter_user_mode() {
    auto cpu = @@SignalContext();
    check_str("initial kernel", std::any_cast<std::string>(cpu.current_mode()), "kernel");
    cpu.enter_user_code();
    check_str("in user mode", std::any_cast<std::string>(cpu.current_mode()), "user");
    check_int("depth 0", std::any_cast<int>(cpu.depth()), 0);
    std::cout << "PASS: enter user mode" << std::endl;
}

void test_single_signal_handler() {
    auto cpu = @@SignalContext();
    cpu.enter_user_code();
    cpu.signal_arrives(std::string("SIGUSR1"));
    check_str("in handler", std::any_cast<std::string>(cpu.current_mode()), "handler");
    check_str("signum SIGUSR1", std::any_cast<std::string>(cpu.current_signum()), "SIGUSR1");
    check_int("depth 1", std::any_cast<int>(cpu.depth()), 1);
    cpu.handler_returns();
    check_str("back to user", std::any_cast<std::string>(cpu.current_mode()), "user");
    check_int("depth 0", std::any_cast<int>(cpu.depth()), 0);
    std::cout << "PASS: single signal handler + return" << std::endl;
}

void test_nested_signals() {
    auto cpu = @@SignalContext();
    cpu.enter_user_code();
    cpu.signal_arrives(std::string("SIGUSR1"));
    check_str("outer handler signum", std::any_cast<std::string>(cpu.current_signum()), "SIGUSR1");
    cpu.signal_arrives(std::string("SIGALRM"));
    check_str("inner handler signum", std::any_cast<std::string>(cpu.current_signum()), "SIGALRM");
    check_int("nested depth 2", std::any_cast<int>(cpu.depth()), 2);
    cpu.handler_returns();
    check_str("popped to outer handler", std::any_cast<std::string>(cpu.current_mode()), "handler");
    check_str("outer signum preserved across pop", std::any_cast<std::string>(cpu.current_signum()), "SIGUSR1");
    check_int("depth 1", std::any_cast<int>(cpu.depth()), 1);
    cpu.handler_returns();
    check_str("back to user", std::any_cast<std::string>(cpu.current_mode()), "user");
    check_int("depth 0", std::any_cast<int>(cpu.depth()), 0);
    std::cout << "PASS: nested signals (push$/pop$ preserves state vars)" << std::endl;
}

void test_deeply_nested_signals() {
    auto cpu = @@SignalContext();
    cpu.enter_user_code();
    cpu.signal_arrives(std::string("SIG1"));
    cpu.signal_arrives(std::string("SIG2"));
    cpu.signal_arrives(std::string("SIG3"));
    cpu.signal_arrives(std::string("SIG4"));
    check_int("depth 4", std::any_cast<int>(cpu.depth()), 4);
    check_str("top signum", std::any_cast<std::string>(cpu.current_signum()), "SIG4");
    cpu.handler_returns();
    check_str("after pop 1: SIG3", std::any_cast<std::string>(cpu.current_signum()), "SIG3");
    cpu.handler_returns();
    check_str("after pop 2: SIG2", std::any_cast<std::string>(cpu.current_signum()), "SIG2");
    cpu.handler_returns();
    check_str("after pop 3: SIG1", std::any_cast<std::string>(cpu.current_signum()), "SIG1");
    cpu.handler_returns();
    check_str("back to user", std::any_cast<std::string>(cpu.current_mode()), "user");
    std::cout << "PASS: 4-deep nested signal stack" << std::endl;
}

int main() {
    test_enter_user_mode();
    test_single_signal_handler();
    test_nested_signals();
    test_deeply_nested_signals();
    std::cout << "PASS: all signal handler stack tests passed" << std::endl;
    return 0;
}

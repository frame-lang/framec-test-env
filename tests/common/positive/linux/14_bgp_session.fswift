@@[target("swift")]

// BGP Finite State Machine -- RFC 4271 Section 8 direct transcription.


@@[persist(String)]
@@[save(saveState)]
@@[load(restoreState)]
@@system BgpSession {
    interface:
        manual_start()
        manual_stop()
        tcp_connection_confirmed()
        tcp_connection_fails()
        open_received(asn: Int, hold_time: Int)
        keepalive_received()
        notification_received(code: Int, subcode: Int)
        hold_timer_expired()
        keepalive_timer_expired()
        connect_retry_timer_expired()
        status(): String

    machine:
        $Idle {
            manual_start() {
                self.connect_retry_count = 0
                self.start_connect_retry_timer()
                self.initiate_tcp_connection()
                -> $Connect
            }
            status(): String { @@:("idle") }
        }

        $Connect {
            tcp_connection_confirmed() {
                self.cancel_connect_retry_timer()
                self.send_open()
                -> $OpenSent
            }
            tcp_connection_fails() {
                -> $Active
            }
            connect_retry_timer_expired() {
                self.initiate_tcp_connection()
                self.start_connect_retry_timer()
            }
            manual_stop() {
                -> $Idle
            }
            status(): String { @@:("connect") }
        }

        $Active {
            tcp_connection_confirmed() {
                self.cancel_connect_retry_timer()
                self.send_open()
                -> $OpenSent
            }
            connect_retry_timer_expired() {
                self.connect_retry_count = self.connect_retry_count + 1
                self.initiate_tcp_connection()
                self.start_connect_retry_timer()
                -> $Connect
            }
            manual_stop() {
                -> $Idle
            }
            status(): String { @@:("active") }
        }

        $OpenSent {
            open_received(asn: Int, hold_time: Int) {
                self.peer_asn = asn
                self.negotiated_hold = hold_time
                self.cancel_hold_timer()
                self.send_keepalive()
                -> $OpenConfirm
            }
            tcp_connection_fails() {
                self.cancel_hold_timer()
                -> $Active
            }
            notification_received(code: Int, subcode: Int) {
                -> $Idle
            }
            hold_timer_expired() {
                self.send_notification()
                -> $Idle
            }
            manual_stop() {
                self.send_notification()
                -> $Idle
            }
            status(): String { @@:("open sent") }
        }

        $OpenConfirm {
            keepalive_received() {
                -> $Established
            }
            notification_received(code: Int, subcode: Int) {
                -> $Idle
            }
            hold_timer_expired() {
                self.send_notification()
                -> $Idle
            }
            keepalive_timer_expired() {
                self.send_keepalive()
            }
            manual_stop() {
                self.send_notification()
                -> $Idle
            }
            status(): String { @@:("open confirm") }
        }

        $Established {
            keepalive_received() {
                self.reset_hold_timer()
            }
            keepalive_timer_expired() {
                self.send_keepalive()
            }
            notification_received(code: Int, subcode: Int) {
                -> $Idle
            }
            hold_timer_expired() {
                self.send_notification()
                -> $Idle
            }
            manual_stop() {
                self.send_notification()
                -> $Idle
            }
            status(): String { @@:("established") }
        }

    actions:
        initiate_tcp_connection()   {}
        send_open()                 {}
        send_keepalive()            {}
        send_notification()         {}
        start_connect_retry_timer() {}
        cancel_connect_retry_timer(){}
        cancel_hold_timer()         {}
        reset_hold_timer()          {}

    domain:
        local_asn: Int = 65001
        peer_asn: Int = 0
        negotiated_hold: Int = 0
        connect_retry_count: Int = 0
}


func check(_ label: String, _ actual: String, _ expected: String) {
    if actual != expected {
        print("FAIL: \(label) -- expected '\(expected)', got '\(actual)'")
        exit(1)
    }
}

func test_full_session_establishment() {
    var bgp = @@BgpSession()
    check("initial idle", bgp.status() as! String, "idle")
    _ = bgp.manual_start()
    check("connect", bgp.status() as! String, "connect")
    _ = bgp.tcp_connection_confirmed()
    check("open sent", bgp.status() as! String, "open sent")
    _ = bgp.open_received(65002, 60)
    check("open confirm", bgp.status() as! String, "open confirm")
    _ = bgp.keepalive_received()
    check("established", bgp.status() as! String, "established")
    print("PASS: full BGP session establishment")
}

func test_persist_across_restart() {
    var bgp = @@BgpSession()
    _ = bgp.manual_start()
    _ = bgp.tcp_connection_confirmed()
    _ = bgp.open_received(65002, 60)
    _ = bgp.keepalive_received()
    check("established", bgp.status() as! String, "established")
    let snap = bgp.saveState()
    var bgp2 = @@BgpSession()
    bgp2.restoreState(snap)
    check("established survived restart", bgp2.status() as! String, "established")
    _ = bgp2.keepalive_timer_expired()
    _ = bgp2.keepalive_received()
    check("still established", bgp2.status() as! String, "established")
    print("PASS: @@persist -- BGP session survives daemon restart")
}

func test_hold_timer_teardown() {
    var bgp = @@BgpSession()
    _ = bgp.manual_start()
    _ = bgp.tcp_connection_confirmed()
    _ = bgp.open_received(65002, 60)
    _ = bgp.keepalive_received()
    _ = bgp.hold_timer_expired()
    check("hold expiry tears down", bgp.status() as! String, "idle")
    print("PASS: hold timer expiry returns to idle")
}

func test_tcp_failure_goes_active() {
    var bgp = @@BgpSession()
    _ = bgp.manual_start()
    _ = bgp.tcp_connection_fails()
    check("active after TCP fail", bgp.status() as! String, "active")
    _ = bgp.connect_retry_timer_expired()
    check("retry transitions back to connect", bgp.status() as! String, "connect")
    print("PASS: TCP failure path Active -> Connect")
}

func test_notification_in_established_teardown() {
    var bgp = @@BgpSession()
    _ = bgp.manual_start()
    _ = bgp.tcp_connection_confirmed()
    _ = bgp.open_received(65002, 60)
    _ = bgp.keepalive_received()
    _ = bgp.notification_received(6, 0)
    check("notification tears down", bgp.status() as! String, "idle")
    print("PASS: notification in Established -> idle")
}

func test_manual_stop_from_established() {
    var bgp = @@BgpSession()
    _ = bgp.manual_start()
    _ = bgp.tcp_connection_confirmed()
    _ = bgp.open_received(65002, 60)
    _ = bgp.keepalive_received()
    _ = bgp.manual_stop()
    check("manual stop", bgp.status() as! String, "idle")
    print("PASS: manual_stop from established")
}

test_full_session_establishment()
test_persist_across_restart()
test_hold_timer_teardown()
test_tcp_failure_goes_active()
test_notification_in_established_teardown()
test_manual_stop_from_established()
print("PASS: all BGP session tests passed")

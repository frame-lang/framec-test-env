@@[target("python_3")]

# BGP Finite State Machine — RFC 4271 §8 direct transcription.
# @@persist models bgpd graceful-restart: session state survives daemon restart.
# 6 states: Idle -> Connect -> OpenSent -> OpenConfirm -> Established
#                  -> Active (TCP passive alternative)

@@[persist]
@@system BgpSession {
    operations:
        @@[save]
        save_state(): bytes {}

        @@[load]
        restore_state(data: bytes) {}

    interface:
        manual_start()
        manual_stop()
        tcp_connection_confirmed()
        tcp_connection_fails()
        open_received(asn: int, hold_time: int)
        keepalive_received()
        notification_received(code: int, subcode: int)
        hold_timer_expired()
        keepalive_timer_expired()
        connect_retry_timer_expired()
        status(): str

    machine:
        $Idle {
            manual_start() {
                self.connect_retry_count = 0
                self.start_connect_retry_timer()
                self.initiate_tcp_connection()
                -> $Connect
            }
            status(): str { @@:("idle") }
        }

        $Connect {
            tcp_connection_confirmed() {
                self.cancel_connect_retry_timer()
                self.send_open()
                -> $OpenSent
            }
            tcp_connection_fails() {
                -> $Active
            }
            connect_retry_timer_expired() {
                self.initiate_tcp_connection()
                self.start_connect_retry_timer()
            }
            manual_stop() {
                -> $Idle
            }
            status(): str { @@:("connect") }
        }

        $Active {
            tcp_connection_confirmed() {
                self.cancel_connect_retry_timer()
                self.send_open()
                -> $OpenSent
            }
            connect_retry_timer_expired() {
                self.connect_retry_count = self.connect_retry_count + 1
                self.initiate_tcp_connection()
                self.start_connect_retry_timer()
                -> $Connect
            }
            manual_stop() {
                -> $Idle
            }
            status(): str { @@:("active") }
        }

        $OpenSent {
            open_received(asn: int, hold_time: int) {
                self.peer_asn = asn
                self.negotiated_hold = hold_time
                self.cancel_hold_timer()
                self.send_keepalive()
                -> $OpenConfirm
            }
            tcp_connection_fails() {
                self.cancel_hold_timer()
                -> $Active
            }
            notification_received(code: int, subcode: int) {
                -> $Idle
            }
            hold_timer_expired() {
                self.send_notification()
                -> $Idle
            }
            manual_stop() {
                self.send_notification()
                -> $Idle
            }
            status(): str { @@:("open sent") }
        }

        $OpenConfirm {
            keepalive_received() {
                -> $Established
            }
            notification_received(code: int, subcode: int) {
                -> $Idle
            }
            hold_timer_expired() {
                self.send_notification()
                -> $Idle
            }
            keepalive_timer_expired() {
                self.send_keepalive()
            }
            manual_stop() {
                self.send_notification()
                -> $Idle
            }
            status(): str { @@:("open confirm") }
        }

        $Established {
            keepalive_received() {
                self.reset_hold_timer()
            }
            keepalive_timer_expired() {
                self.send_keepalive()
            }
            notification_received(code: int, subcode: int) {
                -> $Idle
            }
            hold_timer_expired() {
                self.send_notification()
                -> $Idle
            }
            manual_stop() {
                self.send_notification()
                -> $Idle
            }
            status(): str { @@:("established") }
        }

    actions:
        initiate_tcp_connection()   { pass }
        send_open()                 { pass }
        send_keepalive()            { pass }
        send_notification()         { pass }
        start_connect_retry_timer() { pass }
        cancel_connect_retry_timer(){ pass }
        cancel_hold_timer()         { pass }
        reset_hold_timer()          { pass }

    domain:
        local_asn: int = 65001
        peer_asn: int = 0
        negotiated_hold: int = 0
        connect_retry_count: int = 0
}


def check(label, actual, expected):
    if actual != expected:
        print(f"FAIL: {label} — expected {expected!r}, got {actual!r}")
        raise SystemExit(1)

def test_full_session_establishment():
    bgp = @@BgpSession()
    check("initial idle", bgp.status(), "idle")
    bgp.manual_start()
    check("connect", bgp.status(), "connect")
    bgp.tcp_connection_confirmed()
    check("open sent", bgp.status(), "open sent")
    bgp.open_received(65002, 60)
    check("open confirm", bgp.status(), "open confirm")
    bgp.keepalive_received()
    check("established", bgp.status(), "established")
    print("PASS: full BGP session establishment")

def test_persist_across_restart():
    bgp = @@BgpSession()
    bgp.manual_start()
    bgp.tcp_connection_confirmed()
    bgp.open_received(65002, 60)
    bgp.keepalive_received()
    check("established", bgp.status(), "established")
    snap = bgp.save_state()
    bgp2 = BgpSession()

    bgp2.restore_state(snap)
    check("established survived restart", bgp2.status(), "established")
    # Continue operating
    bgp2.keepalive_timer_expired()
    bgp2.keepalive_received()
    check("still established", bgp2.status(), "established")
    print("PASS: @@persist — BGP session survives daemon restart")

def test_hold_timer_teardown():
    bgp = @@BgpSession()
    bgp.manual_start()
    bgp.tcp_connection_confirmed()
    bgp.open_received(65002, 60)
    bgp.keepalive_received()
    bgp.hold_timer_expired()
    check("hold expiry tears down", bgp.status(), "idle")
    print("PASS: hold timer expiry returns to idle")

def test_tcp_failure_goes_active():
    bgp = @@BgpSession()
    bgp.manual_start()
    bgp.tcp_connection_fails()
    check("active after TCP fail", bgp.status(), "active")
    bgp.connect_retry_timer_expired()
    check("retry transitions back to connect",
          bgp.status(), "connect")
    print("PASS: TCP failure path Active -> Connect")

def test_notification_in_established_teardown():
    bgp = @@BgpSession()
    bgp.manual_start()
    bgp.tcp_connection_confirmed()
    bgp.open_received(65002, 60)
    bgp.keepalive_received()
    bgp.notification_received(6, 0)
    check("notification tears down", bgp.status(), "idle")
    print("PASS: notification in Established -> idle")

def test_manual_stop_from_established():
    bgp = @@BgpSession()
    bgp.manual_start()
    bgp.tcp_connection_confirmed()
    bgp.open_received(65002, 60)
    bgp.keepalive_received()
    bgp.manual_stop()
    check("manual stop", bgp.status(), "idle")
    print("PASS: manual_stop from established")

if __name__ == '__main__':
    test_full_session_establishment()
    test_persist_across_restart()
    test_hold_timer_teardown()
    test_tcp_failure_goes_active()
    test_notification_in_established_teardown()
    test_manual_stop_from_established()
    print("PASS: all BGP session tests passed")

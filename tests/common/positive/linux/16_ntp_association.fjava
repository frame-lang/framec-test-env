@@target java

// NTP Client Association -- RFC 5905.

@@system NtpAssociation {
    operations:
        get_offset(): int { return this.last_offset; }
        is_reachable(): boolean { return this.reach_register > 0; }

    interface:
        poll_tick()
        response_received(offset_ms: int, delay_ms: int)
        poll_timeout()
        status(): String
        poll_interval(): int
        reach(): int

    machine:
        $Unsynced {
            $>() {
                this.poll_interval_v = this.min_poll;
            }

            poll_tick() {
            }
            response_received(offset_ms: int, delay_ms: int) {
                this.shift_reach_register(1);
                this.last_offset = offset_ms;
                this.last_delay = delay_ms;
                this.good_responses = this.good_responses + 1;
                if (this.good_responses >= this.sync_threshold) {
                    -> $Synced
                }
            }
            poll_timeout() {
                this.shift_reach_register(0);
            }
            status(): String { @@:("unsynced") }
            poll_interval(): int { @@:(this.poll_interval_v) }
            reach(): int { @@:(this.reach_register) }
        }

        $Synced {
            poll_tick() {
            }
            response_received(offset_ms: int, delay_ms: int) {
                this.shift_reach_register(1);
                this.last_offset = offset_ms;
                this.last_delay = delay_ms;
                if (this.poll_interval_v < this.max_poll) {
                    this.poll_interval_v = this.poll_interval_v * 2;
                }
            }
            poll_timeout() {
                this.shift_reach_register(0);
                this.consecutive_timeouts = this.consecutive_timeouts + 1;
                if (this.consecutive_timeouts >= 3) {
                    this.consecutive_timeouts = 0;
                    this.good_responses = 0;
                    -> $Unsynced
                }
                if (this.poll_interval_v > this.min_poll) {
                    this.poll_interval_v = this.poll_interval_v >> 1;
                }
            }
            status(): String { @@:("synced") }
            poll_interval(): int { @@:(this.poll_interval_v) }
            reach(): int { @@:(this.reach_register) }
        }

    actions:
        shift_reach_register(bit: int) {
            this.reach_register = ((this.reach_register << 1) | bit) & 0xFF;
            if (bit != 0) {
                this.consecutive_timeouts = 0;
            }
        }

    domain:
        poll_interval_v: int = 64
        min_poll: int = 64
        max_poll: int = 1024
        reach_register: int = 0
        last_offset: int = 0
        last_delay: int = 0
        good_responses: int = 0
        sync_threshold: int = 3
        consecutive_timeouts: int = 0
}


class Main {
    static void check_str(String label, String actual, String expected) {
        if (!actual.equals(expected)) {
            System.out.println("FAIL: " + label + " -- expected '" + expected + "', got '" + actual + "'");
            System.exit(1);
        }
    }

    static void check_int(String label, int actual, int expected) {
        if (actual != expected) {
            System.out.println("FAIL: " + label + " -- expected " + expected + ", got " + actual);
            System.exit(1);
        }
    }

    static void check_bool(String label, boolean actual, boolean expected) {
        if (actual != expected) {
            System.out.println("FAIL: " + label + " -- expected " + expected + ", got " + actual);
            System.exit(1);
        }
    }

    static void test_builds_to_sync() {
        var ntp = @@NtpAssociation();
        check_str("initial unsynced", (String) ntp.status(), "unsynced");
        ntp.poll_tick();
        ntp.response_received(12, 3);
        ntp.poll_tick();
        ntp.response_received(11, 2);
        check_str("not yet synced (2 good)", (String) ntp.status(), "unsynced");
        ntp.poll_tick();
        ntp.response_received(12, 3);
        check_str("synced after 3 good responses", (String) ntp.status(), "synced");
        System.out.println("PASS: sync threshold reached after 3 good responses");
    }

    static void test_poll_interval_backs_off() {
        var ntp = @@NtpAssociation();
        ntp.poll_tick(); ntp.response_received(10, 2);
        ntp.poll_tick(); ntp.response_received(10, 2);
        ntp.poll_tick(); ntp.response_received(10, 2);
        check_str("synced", (String) ntp.status(), "synced");
        check_int("interval at min (64)", (int) ntp.poll_interval(), 64);
        ntp.poll_tick(); ntp.response_received(10, 2);
        check_int("128 after 1 good in synced", (int) ntp.poll_interval(), 128);
        ntp.poll_tick(); ntp.response_received(10, 2);
        check_int("256 after 2 good", (int) ntp.poll_interval(), 256);
        System.out.println("PASS: poll interval doubles on success in synced");
    }

    static void test_timeout_shrinks_interval() {
        var ntp = @@NtpAssociation();
        ntp.poll_tick(); ntp.response_received(10, 2);
        ntp.poll_tick(); ntp.response_received(10, 2);
        ntp.poll_tick(); ntp.response_received(10, 2);
        ntp.poll_tick(); ntp.response_received(10, 2);
        check_int("interval 128", (int) ntp.poll_interval(), 128);
        ntp.poll_tick(); ntp.poll_timeout();
        check_int("timeout halves -> 64", (int) ntp.poll_interval(), 64);
        System.out.println("PASS: timeout halves poll interval in synced");
    }

    static void test_three_timeouts_drops_to_unsync() {
        var ntp = @@NtpAssociation();
        ntp.poll_tick(); ntp.response_received(10, 2);
        ntp.poll_tick(); ntp.response_received(10, 2);
        ntp.poll_tick(); ntp.response_received(10, 2);
        check_str("synced", (String) ntp.status(), "synced");
        ntp.poll_tick(); ntp.poll_timeout();
        ntp.poll_tick(); ntp.poll_timeout();
        check_str("still synced after 2 timeouts", (String) ntp.status(), "synced");
        ntp.poll_tick(); ntp.poll_timeout();
        check_str("3rd timeout drops to unsync", (String) ntp.status(), "unsynced");
        System.out.println("PASS: three consecutive timeouts drop to unsync");
    }

    static void test_reach_register_shifts() {
        var ntp = @@NtpAssociation();
        check_int("reach starts 0", (int) ntp.reach(), 0);
        ntp.poll_tick();
        ntp.response_received(10, 2);
        check_int("reach 0b00000001 = 1", (int) ntp.reach(), 1);
        ntp.poll_tick();
        ntp.response_received(10, 2);
        check_int("reach 0b00000011 = 3", (int) ntp.reach(), 3);
        ntp.poll_tick();
        ntp.poll_timeout();
        check_int("reach 0b00000110 = 6", (int) ntp.reach(), 6);
        System.out.println("PASS: reach register shifts correctly");
    }

    static void test_is_reachable_operation() {
        var ntp = @@NtpAssociation();
        check_bool("initial not reachable", (boolean) ntp.is_reachable(), false);
        ntp.poll_tick();
        ntp.response_received(10, 2);
        check_bool("after good response reachable", (boolean) ntp.is_reachable(), true);
        System.out.println("PASS: is_reachable() operation query");
    }

    public static void main(String[] args) {
        test_builds_to_sync();
        test_poll_interval_backs_off();
        test_timeout_shrinks_interval();
        test_three_timeouts_drops_to_unsync();
        test_reach_register_shifts();
        test_is_reachable_operation();
        System.out.println("PASS: all NTP association tests passed");
    }
}

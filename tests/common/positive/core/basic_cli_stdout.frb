@@target ruby

@@system S {
    machine:
        $A {
            e() {
                -> $B()
            }
        }
        $B { e() { } }
}

puts("TAP version 14")
puts("1..1")
begin
    s = S.new
    if s.respond_to?(:e)
        s.e()
    end
    puts("ok 1 - basic_cli_stdout")
rescue => ex
    puts("not ok 1 - basic_cli_stdout # #{ex}")
end

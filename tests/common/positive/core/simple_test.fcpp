@@target cpp_17

@@run-expect: SUCCESS
@@run-expect: Hello from Docker

#include <iostream>
#include <string>
#include <cassert>

@@system SimpleDocker {
    interface:
        run()

    machine:
        $Start {
            run() {
                printf("SUCCESS: Hello from Docker\n");
                -> $End
            }
        }

        $End {}
}

// Stub functions for placeholder calls
void native() {}
void x() {}

// TAP test harness
int main() {
    printf("TAP version 14\n");
    printf("1..1\n");
    try {
        SimpleDocker s;
        printf("ok 1 - simple_test\n");
    } catch (...) {
        printf("not ok 1 - simple_test\n");
    }
    return 0;
}

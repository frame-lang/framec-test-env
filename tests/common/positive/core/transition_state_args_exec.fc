@@[target("c")]

@@system S {
    interface:
        e(): void

    machine:
        $A {
            e() {
                -> $B(1, 2, 3)
            }
        }
        $B(x, y, k) {
            e() {
                // terminal state with args
            }
        }
}

int main() {
    printf("=== Test: transition_state_args_exec ===\n");
    S* s = @@S();

    // Call e() to trigger transition with state arguments
    S_e(s);

    printf("PASS: transition_state_args_exec\n");
    S_destroy(s);
    return 0;
}

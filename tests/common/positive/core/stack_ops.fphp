@@[target("php")]

@@system S {
    machine:
        $A {
            e() {
                push$
                pop$
            }
        }
}

function native() {}
function x() {}

echo "TAP version 14" . "\n";
echo "1..1" . "\n";
try {
    $s = @@S();
    if (method_exists($s, 'e')) { $s->e(); }
    echo "ok 1 - stack_ops" . "\n";
} catch (\Exception $ex) {
    echo "not ok 1 - stack_ops # " . $ex->getMessage() . "\n";
}

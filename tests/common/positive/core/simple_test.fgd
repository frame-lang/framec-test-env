@@[target("gdscript")]
extends SceneTree

@@run-expect: SUCCESS
@@run-expect: Hello from Docker

@@system SimpleDocker {
    interface:
        run()
    
    machine:
        $Start {
            run() {
                print("SUCCESS: Hello from Docker")
                -> $End
            }
        }
        
        $End {}
}

# Stub functions for placeholder calls
func native(): pass
func x(): pass

# TAP test harness
func _init():
    print("TAP version 14")
    print("1..1")
    var s = @@SimpleDocker()
    if s.has_method("e"):
        s.e()
    print("ok 1 - simple_test")
    quit()

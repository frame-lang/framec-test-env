@@target gdscript

@@run-expect: SUCCESS
@@run-expect: Hello from Docker

@@system SimpleDocker {
    interface:
        run()
    
    machine:
        $Start {
            run() {
                print("SUCCESS: Hello from Docker")
                -> $End
            }
        }
        
        $End {}
}

# Stub functions for placeholder calls

# TAP test harness
func _ready():
    print("TAP version 14")
    print("1..1")
    try:
        s = @@SimpleDocker()
        if s.has_method('e'):
            s.e()
        print("ok 1 - simple_test")
    except Exception as ex:
        print("not ok 1 - simple_test # {ex}")

@@target javascript

@@run-expect: SUCCESS
@@run-expect: Hello from Docker

@@system SimpleDocker {
    interface:
        run(): void

    machine:
        $Start {
            run() {
                console.log("SUCCESS: Hello from Docker")
                -> $End
            }
        }

        $End {}
}

function native() {}
function x() {}

function main() {
    console.log("TAP version 14");
    console.log("1..1");
    try {
        const s = @@SimpleDocker();
        if (typeof s.e === 'function') { s.e(); }
        console.log("ok 1 - simple_test");
    } catch (ex) {
        console.log(`not ok 1 - simple_test # ${ex}`);
    }
}
main();

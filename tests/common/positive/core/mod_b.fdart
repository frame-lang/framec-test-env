@@target dart

@@system S2 {
    machine:
        $A {
            e() { -> $A() }
        }
}

// Stub functions for placeholder calls
void native(): void {}
void x(): void {}

// TAP test harness
void main() {
    print("TAP version 14");
    print("1..1");
    try {
        final s = @@S2();
        if (typeof (s as any).e == 'function') {
            (s as any).e();
        }
        print("ok 1 - mod_b");
    } catch (ex) {
        print("not ok 1 - mod_b # ${ex}");
    }
}

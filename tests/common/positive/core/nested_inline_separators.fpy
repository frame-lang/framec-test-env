                if True:
                    x = 1; y = 2  # inline sep
                else:
                    y = 3; x = 4  # inline sep
                -> $B()
            }
        }
        $B { e() { pass } }
}

# Stub functions for placeholder calls
def native(): pass
def x(): pass

# TAP test harness
if __name__ == "__main__":

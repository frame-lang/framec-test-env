@@target c

@@system S {
    interface:
        e(): void

    machine:
        $A {
            e() {
                int x, y;
                if (1) {
                    x = 1; y = 2;  // inline sep
                } else {
                    y = 3; x = 4;  // inline sep
                }
                -> $B
            }
        }
        $B {
            e() {
                // pass
            }
        }
}

int main() {
    printf("=== Test: nested_inline_separators ===\n");
    S* s = @@S();

    // Call e() to trigger the handler with inline separators
    S_e(s);

    printf("PASS: nested_inline_separators\n");
    S_destroy(s);
    return 0;
}

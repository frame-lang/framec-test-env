@@target ruby
@@compile-expect: Compiled 1 module

@@system P {
    machine:
        $A {
            e() {
                -> $B()
            }
        }
        $B { e() { } }
}

puts("TAP version 14")
puts("1..1")
begin
    s = P.new
    if s.respond_to?(:e)
        s.e()
    end
    puts("ok 1 - basic_project")
rescue => ex
    puts("not ok 1 - basic_project # #{ex}")
end

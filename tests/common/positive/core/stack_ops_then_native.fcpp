@@[target("cpp_17")]

#include <iostream>
#include <string>
#include <cassert>

// Forward declarations for functions used in handlers
void x();
void y();

@@system S {
    machine:
        $A {
            e() {
                push$
                x();
                pop$
                y();
            }
        }
}

// Stub functions for placeholder calls
void native() {}
void x() {}
void y() {}

// TAP test harness
int main() {
    printf("TAP version 14\n");
    printf("1..1\n");
    try {
        S s;
        s.e();
        printf("ok 1 - stack_ops_then_native\n");
    } catch (...) {
        printf("not ok 1 - stack_ops_then_native\n");
    }
    return 0;
}

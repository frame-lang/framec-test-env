@@[target("ruby")]

@@run-expect: SUCCESS
@@run-expect: Hello from Docker

@@system SimpleDocker {
    interface:
        run()

    machine:
        $Start {
            run() {
                puts("SUCCESS: Hello from Docker")
                -> $End
            }
        }

        $End {}
}

puts("TAP version 14")
puts("1..1")
begin
    s = SimpleDocker.new
    if s.respond_to?(:e)
        s.e()
    end
    puts("ok 1 - simple_test")
rescue => ex
    puts("not ok 1 - simple_test # #{ex}")
end

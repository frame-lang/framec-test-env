@@target typescript
@@compile-expect: Compiled 1 module

@@system P {
    machine:
        $A {
            e() {
                -> $B()
            }
        }
        $B {
            e() {
                ;
            }
        }
}

// Stub functions for placeholder calls
function native(): void {}
function x(): void {}

// TAP test harness
function main() {
    console.log("TAP version 14");
    console.log("1..1");
    try {
        const s = new P();
        if (typeof (s as any).e === 'function') {
            (s as any).e();
        }
        console.log("ok 1 - basic_project");
    } catch (ex) {
        console.log(`not ok 1 - basic_project # ${ex}`);
    }
}
main();

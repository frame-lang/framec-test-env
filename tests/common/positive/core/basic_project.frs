@@target rust
@@compile-expect: Compiled 1 module

@@system P {
    machine:
        $A {
            e() {
                -> $B()
            }
        }
        $B {
            e() {
                {}
            }
        }
}


// Stub functions for placeholder calls
fn native() {}
fn x() {}


@@target java

import java.util.*;

class Stubs {
    static void native_stub() {}
}

@@system S {
    machine:
        $A {
            e(x, y, z) {
                Stubs.native_stub();
            }
        }
}

class Main {
    public static void main(String[] args) {
        System.out.println("TAP version 14");
        System.out.println("1..1");
        try {
            S s = new S();
            s.e("a", "b", "c");
            System.out.println("ok 1 - basic_snapshot");
        } catch (Exception ex) {
            System.out.println("not ok 1 - basic_snapshot # " + ex);
        }
    }
}

@@target gdscript

@@system S {
    machine:
        $A {
            e() {
                -> $B()
            }
        }
        $B { e() { pass } }
}

# Stub functions for placeholder calls

# TAP test harness
func _ready():
    print("TAP version 14")
    print("1..1")
    try:
        s = @@S()
        if s.has_method('e'):
            s.e()
        print("ok 1 - basic_cli_stdout")
    except Exception as ex:
        print("not ok 1 - basic_cli_stdout # {ex}")

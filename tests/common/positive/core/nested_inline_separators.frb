@@[target("ruby")]
@@visitor-map-golden: origins=frame; min=1

@@system S {
    machine:
        $A {
            e() {
                if true
                    x = 1; y = 2  # inline sep
                else
                    y = 3; x = 4  # inline sep
                end
                -> $B()
            }
        }
        $B { e() { } }
}

puts("TAP version 14")
puts("1..1")
begin
    s = @@S()
    if s.respond_to?(:e)
        s.e()
    end
    puts("ok 1 - nested_inline_separators")
rescue => ex
    puts("not ok 1 - nested_inline_separators # #{ex}")
end

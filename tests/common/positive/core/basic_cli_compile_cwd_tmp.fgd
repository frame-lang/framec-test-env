@@target gdscript
@@compile-expect: class S
@@cwd: tmp

@@system S {
    machine:
        $A {
            e() {
                -> $B()
            }
        }
        $B { e() { } }
}

# Stub functions for placeholder calls

# TAP test harness
func _ready():
    print("TAP version 14")
    print("1..1")
    try:
        s = @@S()
        if s.has_method('e'):
            s.e()
        print("ok 1 - basic_cli_compile_cwd_tmp")
    except Exception as ex:
        print("not ok 1 - basic_cli_compile_cwd_tmp # {ex}")

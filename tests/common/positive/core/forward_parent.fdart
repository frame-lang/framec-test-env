@@target dart

@@system S {
    machine:
        $A => $P {
            e() {
                => $^
                x();
            }
        }
        $P { }
}

// Stub functions for placeholder calls
void native(): void {}
void x(): void {}

// TAP test harness
void main() {
    print("TAP version 14");
    print("1..1");
    try {
        final s = @@S();
        if (typeof (s as any).e == 'function') {
            (s as any).e();
        }
        print("ok 1 - forward_parent");
    } catch (ex) {
        print("not ok 1 - forward_parent # ${ex}");
    }
}

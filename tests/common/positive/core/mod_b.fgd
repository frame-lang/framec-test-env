@@target gdscript

@@system S2 {
    machine:
        $A {
            e() { -> $A() }
        }
}

# Stub functions for placeholder calls

# TAP test harness
func _ready():
    print("TAP version 14")
    print("1..1")
    try:
        s = @@S2()
        if s.has_method('e'):
            s.e()
        print("ok 1 - mod_b")
    except Exception as ex:
        print("not ok 1 - mod_b # {ex}")

@@[target("kotlin")]

import kotlin.system.exitProcess

@@system SimpleDocker {
    interface:
        run()

    machine:
        $Start {
            run() {
                println("SUCCESS: Hello from Docker")
                -> $End
            }
        }

        $End {}
}

fun main() {
    println("TAP version 14")
    println("1..1")
    try {
        val s = @@SimpleDocker()
        println("ok 1 - simple_test")
    } catch (ex: Exception) {
        println("not ok 1 - simple_test # $ex")
    }
}

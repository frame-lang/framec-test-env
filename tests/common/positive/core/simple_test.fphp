@@[target("php")]

@@run-expect: SUCCESS
@@run-expect: Hello from Docker

@@system SimpleDocker {
    interface:
        run()

    machine:
        $Start {
            run() {
                echo "SUCCESS: Hello from Docker\n";
                -> $End
            }
        }

        $End {}
}

function native() {}
function x() {}

echo "TAP version 14" . "\n";
echo "1..1" . "\n";
try {
    $s = @@SimpleDocker();
    if (method_exists($s, 'e')) { $s->e(); }
    echo "ok 1 - simple_test" . "\n";
} catch (\Exception $ex) {
    echo "not ok 1 - simple_test # " . $ex->getMessage() . "\n";
}

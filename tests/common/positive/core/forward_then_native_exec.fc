@@target c

// Forward declaration for stub function
void native(void);

@@system S {
    machine:
        $A => $P {
            e() {
                => $^; native();
            }
        }
        $P { }
}

// Stub function implementation
void native(void) {
    printf("native() called\n");
}

int main() {
    printf("=== Test: forward_then_native_exec ===\n");
    S* s = @@S();

    // Test that system forwards event then executes native code
    S_e(s);

    printf("PASS: forward_then_native_exec\n");
    S_destroy(s);
    return 0;
}

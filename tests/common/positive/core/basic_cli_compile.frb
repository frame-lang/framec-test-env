@@[target("ruby")]
@@compile-expect: class S
@@import-call: class=S; method=e
@@py-compile

@@system S {
    machine:
        $A {
            e() {
                -> $B()
            }
        }
        $B { e() { } }
}

# TAP test harness
puts("TAP version 14")
puts("1..1")
begin
    s = S.new
    if s.respond_to?(:e)
        s.e()
    end
    puts("ok 1 - basic_cli_compile")
rescue => ex
    puts("not ok 1 - basic_cli_compile # #{ex}")
end

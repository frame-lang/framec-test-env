@@[target("c")]

@@system S {
    interface:
        e(): void

    machine:
        $A {
            e() {
                // native prelude
                int x = 42;
                push$
            }
        }
}

int main() {
    printf("=== Test: terminal_last_stack_ops ===\n");
    S* s = @@S();

    // Call e() which has native code followed by terminal push$
    S_e(s);

    printf("PASS: terminal_last_stack_ops\n");
    S_destroy(s);
    return 0;
}

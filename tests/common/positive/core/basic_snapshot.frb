@@[target("ruby")]

@@system S {
    machine:
        $A {
            e(x, y, z) {
                native()
            }
        }
}

def native; end

puts("TAP version 14")
puts("1..1")
begin
    s = S.new
    if s.respond_to?(:e)
        s.e(1, 2, 3)
    end
    puts("ok 1 - basic_snapshot")
rescue => ex
    puts("not ok 1 - basic_snapshot # #{ex}")
end

    machine:
        $A {
            e() {
                if (true) {
                    $x = 1; $y = 2;  // inline sep
                } else {
                    $y = 3; $x = 4;  // inline sep
                }
                -> $B()
            }
        }
        $B { e() { } }
}

function native() {}
function x() {}

echo "TAP version 14" . "\n";
echo "1..1" . "\n";

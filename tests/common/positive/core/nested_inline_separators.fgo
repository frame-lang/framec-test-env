@@[target("go")]

package main

import "fmt"

@@system S {
    machine:
        $A {
            E() {
                if true {
                    x := 1; y := 2  // inline sep
                    _ = x; _ = y
                } else {
                    y := 3; x := 4  // inline sep
                    _ = y; _ = x
                    -> $B()
                }
            }
        }
        $B { E() { } }
}

func main() {
	fmt.Println("TAP version 14")
	fmt.Println("1..1")
	s := NewS()
	s.E()
	fmt.Println("ok 1 - nested_inline_separators")
}

@@target swift

@@run-expect: SUCCESS
@@run-expect: Hello from Docker

@@system SimpleDocker {
    interface:
        run(): void

    machine:
        $Start {
            run() {
                print("SUCCESS: Hello from Docker")
                -> $End
            }
        }

        $End {}
}


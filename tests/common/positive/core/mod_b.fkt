@@[target("kotlin")]

import kotlin.system.exitProcess

@@system S2 {
    machine:
        $A {
            e() { -> $A() }
        }
}

fun main() {
    println("TAP version 14")
    println("1..1")
    try {
        val s = S2()
        s.e()
        println("ok 1 - mod_b")
    } catch (ex: Exception) {
        println("not ok 1 - mod_b # $ex")
    }
}

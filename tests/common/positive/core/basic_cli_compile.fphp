<?php
@@[target("php")]
@@compile-expect: class S
@@import-call: class=S; method=e
@@py-compile

@@system S {
    machine:
        $A {
            e() { -> $B() }
        }
        $B { e() { } }
}

function native() {}
function x() {}

echo "TAP version 14" . "\n";
echo "1..1" . "\n";
try {
    $s = new S();
    if (method_exists($s, 'e')) { $s->e(); }
    echo "ok 1 - basic_cli_compile" . "\n";
} catch (\Exception $ex) {
    echo "not ok 1 - basic_cli_compile # " . $ex->getMessage() . "\n";
}

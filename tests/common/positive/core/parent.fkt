@@target kotlin

import kotlin.system.exitProcess

@@system S {
    machine:
        $P { }
}

fun main() {
    println("TAP version 14")
    println("1..1")
    try {
        val s = S()
        println("ok 1 - parent")
    } catch (ex: Exception) {
        println("not ok 1 - parent # $ex")
    }
}

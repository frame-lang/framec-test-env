@@[target("dart")]
@@run-expect: SUCCESS
@@run-expect: Hello from Docker

@@system SimpleDocker {
    interface:
        run(): void
    
    machine:
        $Start {
            run() {
                print("SUCCESS: Hello from Docker");
                -> $End
            }
        }
        
        $End {}
}

// Stub functions for placeholder calls
void native() {}
void x() {}

// TAP test harness
void main() {
    print("TAP version 14");
    print("1..1");
    try {
        final s = @@SimpleDocker();
        s.run();
        print("ok 1 - simple_test");
    } catch (ex) {
        print("not ok 1 - simple_test # ${ex}");
    }
}

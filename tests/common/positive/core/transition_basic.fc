@@[target("c")]

@@system S {
    interface:
        e(): void

    machine:
        $A {
            e() {
                -> $B
            }
        }
        $B {
            e() {
                // terminal state
            }
        }
}

int main() {
    printf("=== Test: transition_basic ===\n");
    S* s = @@S();

    // Call e() to trigger transition from A to B
    S_e(s);

    printf("PASS: transition_basic\n");
    S_destroy(s);
    return 0;
}

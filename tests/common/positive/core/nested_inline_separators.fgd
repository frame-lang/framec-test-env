@@target gdscript
@@visitor-map-golden: origins=frame; min=1

@@system S {
    machine:
        $A {
            e() {
                if true:
                    x = 1; y = 2  # inline sep
                else:
                    y = 3; x = 4  # inline sep
                -> $B()
            }
        }
        $B { e() { pass } }
}

# Stub functions for placeholder calls

# TAP test harness
func _ready():
    print("TAP version 14")
    print("1..1")
    try:
        s = @@S()
        if s.has_method('e'):
            s.e()
        print("ok 1 - nested_inline_separators")
    except Exception as ex:
        print("not ok 1 - nested_inline_separators # {ex}")

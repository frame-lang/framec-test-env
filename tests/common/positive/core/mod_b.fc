@@target c

@@system S2 {
    machine:
        $A {
            e() { -> $A() }
        }
}

int main() {
    printf("=== Test: mod_b ===\n");
    S2* s = @@S2();

    // Test that system instantiates and handles self-transition
    S2_e(s);

    printf("PASS: mod_b\n");
    S2_destroy(s);
    return 0;
}

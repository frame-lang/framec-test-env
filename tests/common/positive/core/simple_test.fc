@@[target("c")]

@@system SimpleDocker {
    interface:
        run(): void

    machine:
        $Start {
            run() {
                printf("SUCCESS: Hello from Docker\n");
                -> $End
            }
        }

        $End {
            run() {
                // terminal state
            }
        }
}

int main() {
    printf("=== Test: simple_test ===\n");
    SimpleDocker* s = @@SimpleDocker();

    // Run should print SUCCESS and transition to End
    SimpleDocker_run(s);

    printf("PASS: simple_test\n");
    SimpleDocker_destroy(s);
    return 0;
}

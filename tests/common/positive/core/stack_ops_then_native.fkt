@@[target("kotlin")]

import kotlin.system.exitProcess

fun x() {}
fun y() {}
@@system S {
    machine:
        $A {
            e() {
                push$
                x()
                pop$
                y()
            }
        }
}

fun main() {
    println("TAP version 14")
    println("1..1")
    try {
        val s = S()
        s.e()
        println("ok 1 - stack_ops_then_native")
    } catch (ex: Exception) {
        println("not ok 1 - stack_ops_then_native # $ex")
    }
}

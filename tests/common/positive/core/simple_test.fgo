@@target go

package main

import "fmt"

@@system SimpleDocker {
    interface:
        Run()

    machine:
        $Start {
            Run() {
                fmt.Println("SUCCESS: Hello from Docker")
                -> $End
            }
        }

        $End {}
}

func main() {
	fmt.Println("TAP version 14")
	fmt.Println("1..1")
	_ = NewSimpleDocker()
	fmt.Println("ok 1 - simple_test")
}

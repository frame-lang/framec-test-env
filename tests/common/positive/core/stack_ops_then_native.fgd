@@target gdscript
extends SceneTree

@@system S {
    machine:
        $A {
            e() {
                push$
                x()
                pop$
                y()
            }
        }
}

# Stub functions for placeholder calls

# TAP test harness
func _init():
    print("TAP version 14")
    print("1..1")
    var s = @@S()
    if s.has_method("e"):
        s.e()
    print("ok 1 - stack_ops_then_native")
    quit()

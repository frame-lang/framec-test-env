@@target gdscript
@@compile-expect: class S:
@@import-call: class=S; method=e
@@py-compile

@@system S {
    machine:
        $A {
            e() {
                -> $B()
            }
        }
        $B { e() { pass } }
}

# Stub functions for placeholder calls

# TAP test harness
func _ready():
    print("TAP version 14")
    print("1..1")
    s = @@S()
    if s.has_method("e"):
        s.e()
    print("ok 1 - basic_cli_compile")
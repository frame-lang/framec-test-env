@@[target("dart")]
@@system S {
    machine:
        $A {
            e() {
                -> $B()
            }
        }
        $B { e() { } }
}

// Stub functions for placeholder calls
void native() {}
void x() {}

// TAP test harness
void main() {
    print("TAP version 14");
    print("1..1");
    try {
        final s = @@S();
        if (true) {
            s.e();
        }
        print("ok 1 - basic_cli_stdout");
    } catch (ex) {
        print("not ok 1 - basic_cli_stdout # ${ex}");
    }
}

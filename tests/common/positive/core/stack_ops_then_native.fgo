@@target go

package main

import "fmt"

func x() {}
func y() {}
@@system S {
    machine:
        $A {
            E() {
                push$
                x()
                pop$
                y()
            }
        }
}

func main() {
	fmt.Println("TAP version 14")
	fmt.Println("1..1")
	s := NewS()
	s.E()
	fmt.Println("ok 1 - stack_ops_then_native")
}

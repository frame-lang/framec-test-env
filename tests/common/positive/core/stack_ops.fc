@@[target("c")]

#include <stdio.h>
#include <stdlib.h>

@@system S {
    interface:
        e(): void

    machine:
        $A {
            e() {
                push$
                pop$
            }
        }
}

int main() {
    printf("=== Test: stack_ops ===\n");
    S* s = @@S();

    // Call e() to trigger push$ and pop$
    S_e(s);

    printf("PASS: stack_ops\n");
    S_destroy(s);
    return 0;
}

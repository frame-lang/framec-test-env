@@[target("ruby")]

@@system S {
    machine:
        $A {
            e() {
                push$
                x()
                pop$
                y()
            }
        }
}

def x; end
def y; end

puts("TAP version 14")
puts("1..1")
begin
    s = S.new
    if s.respond_to?(:e)
        s.e()
    end
    puts("ok 1 - stack_ops_then_native")
rescue => ex
    puts("not ok 1 - stack_ops_then_native # #{ex}")
end

@@[target("cpp_17")]
@@compile-expect: class S \{

#include <iostream>
#include <cassert>

@@system S {
    machine:
        $A {
            e() {
                -> $B()
            }
        }
        $B { e() { } }
}

// Stub functions for placeholder calls
void native() {}
void x() {}

// TAP test harness
int main() {
    printf("TAP version 14\n");
    printf("1..1\n");
    try {
        auto s = @@S();
        s.e();
        printf("ok 1 - basic_cli_compile\n");
    } catch (...) {
        printf("not ok 1 - basic_cli_compile\n");
    }
    return 0;
}

@@target gdscript
@@compile-expect: Compiled 1 module

@@system P {
    machine:
        $A {
            e() {
                -> $B()
            }
        }
        $B {
            e() {
                pass
            }
        }
}

# Stub functions for placeholder calls

# TAP test harness
func _ready():
    print("TAP version 14")
    print("1..1")
    try:
        s = @@P()
        if s.has_method('e'):
            s.e()
        print("ok 1 - basic_project")
    except Exception as ex:
        print("not ok 1 - basic_project # {ex}")

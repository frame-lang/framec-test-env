@@target kotlin

import kotlin.system.exitProcess

@@system S {
    machine:
        $A {
            e() {
                -> $B()
            }
        }
        $B { e() { } }
}

fun main() {
    println("TAP version 14")
    println("1..1")
    try {
        val s = S()
        s.e()
        println("ok 1 - basic_cli_stdout")
    } catch (ex: Exception) {
        println("not ok 1 - basic_cli_stdout # $ex")
    }
}

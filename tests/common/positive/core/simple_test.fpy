@@target python_3

@@run-expect: SUCCESS
@@run-expect: Hello from Docker

@@system SimpleDocker {
    interface:
        run()
    
    machine:
        $Start {
            run() {
                print("SUCCESS: Hello from Docker")
                -> $End
            }
        }
        
        $End {}
}

# Stub functions for placeholder calls
def native(): pass
def x(): pass

# TAP test harness
if __name__ == "__main__":
    print("TAP version 14")
    print("1..1")
    try:
        s = @@SimpleDocker()
        if hasattr(s, 'e'):
            s.e()
        print("ok 1 - simple_test")
    except Exception as ex:
        print(f"not ok 1 - simple_test # {ex}")

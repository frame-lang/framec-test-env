@@target c

@@system S {
    machine:
        $A {
            e() {
                push$
                -> $B()
            }
        }
        $B { e() { } }
}

int main() {
    printf("=== Test: mixed_ops ===\n");
    S* s = S_new();

    // Test that system handles push then transition
    S_e(s);

    printf("PASS: mixed_ops\n");
    S_destroy(s);
    return 0;
}

@@target gdscript

@@system S {
    machine:
        $A {
            e(x, y, z) {
                native()
            }
        }
}

# Stub functions for placeholder calls

# TAP test harness
func _ready():
    print("TAP version 14")
    print("1..1")
    try:
        s = @@S()
        if s.has_method('e'):
            s.e(1, 2, 3)  # e(x, y, z) requires three parameters
        print("ok 1 - basic_snapshot")
    except Exception as ex:
        print("not ok 1 - basic_snapshot # {ex}")

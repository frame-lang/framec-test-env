@@target dart
@@visitor-map-golden: origins=frame; min=1

@@system S {
    machine:
        $A {
            e() {
                if (true) {
                    var x = 1; var y = 2  // inline sep
                } else {
                    var y = 3; var x = 4  // inline sep
                    -> $B()
                }
            }
        }
        $B { e() { } }
}

// Stub functions for placeholder calls
void native(): void {}
void x(): void {}

// TAP test harness
void main() {
    print("TAP version 14");
    print("1..1");
    try {
        final s = @@S();
        if (typeof (s as any).e == 'function') {
            (s as any).e();
        }
        print("ok 1 - nested_inline_separators");
    } catch (ex) {
        print("not ok 1 - nested_inline_separators # ${ex}");
    }
}

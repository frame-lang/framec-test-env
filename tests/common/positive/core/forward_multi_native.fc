@@target c

// Forward declarations for stub functions
void a(void);
void b(void);

@@system S {
    machine:
        $A => $P {
            e() {
                => $^
                a();
                b();
            }
        }
        $P { }
}

// Stub function implementations
void a(void) {
    printf("a() called\n");
}

void b(void) {
    printf("b() called\n");
}

int main() {
    printf("=== Test: forward_multi_native ===\n");
    S* s = @@S();

    // Test that system instantiates and forwards event to parent
    S_e(s);

    printf("PASS: forward_multi_native\n");
    S_destroy(s);
    return 0;
}

@@[target("ruby")]
@@compile-expect: class S
@@cwd: tmp

@@system S {
    machine:
        $A {
            e() {
                -> $B()
            }
        }
        $B { e() { } }
}

# TAP test harness
puts("TAP version 14")
puts("1..1")
begin
    s = @@S()
    if s.respond_to?(:e)
        s.e()
    end
    puts("ok 1 - basic_cli_compile_cwd_tmp")
rescue => ex
    puts("not ok 1 - basic_cli_compile_cwd_tmp # #{ex}")
end

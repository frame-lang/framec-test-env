@@target python
@@compile-expect: class S:
@@import-call: class=S; method=e
@@py-compile

@@system S {
    machine:
        $A {
            e() {
                -> $B()
            }
        }
        $B { e() { pass } }
}

# Stub functions for placeholder calls
def native(): pass
def x(): pass

# TAP test harness
if __name__ == "__main__":
    print("TAP version 14")
    print("1..1")
    try:
        s = S()
        if hasattr(s, 'e'):
            s.e()
        print("ok 1 - basic_cli_compile")
    except Exception as ex:
        print(f"not ok 1 - basic_cli_compile # {ex}")

@@[target("c")]

@@system S {
    interface:
        ev(): void

    machine:
        $A => $P {
            ev() {
                => $^
            }
        }
        $P {
            ev() {
                // parent handler
            }
        }
}

int main() {
    printf("=== Test: simple_interface ===\n");
    S* s = @@S();

    // Call ev() to trigger forward to parent
    S_ev(s);

    printf("PASS: simple_interface\n");
    S_destroy(s);
    return 0;
}

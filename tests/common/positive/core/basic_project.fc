@@target c

@@system P {
    machine:
        $A {
            e() {
                -> $B()
            }
        }
        $B {
            e() {
            }
        }
}

int main() {
    printf("=== Test: basic_project ===\n");
    P* s = @@P();

    // Test that system instantiates and responds to event
    P_e(s);

    printf("PASS: basic_project\n");
    P_destroy(s);
    return 0;
}

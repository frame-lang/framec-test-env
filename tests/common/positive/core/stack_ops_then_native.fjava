@@target java

import java.util.*;

@@system S {
    machine:
        $A {
            e() {
                push$
                x();
                pop$
                y();
            }
        }
}

class Main {
    static void x() {}
    static void y() {}

    public static void main(String[] args) {
        System.out.println("TAP version 14");
        System.out.println("1..1");
        try {
            S s = new S();
            s.e();
            System.out.println("ok 1 - stack_ops_then_native");
        } catch (Exception ex) {
            System.out.println("not ok 1 - stack_ops_then_native # " + ex);
        }
    }
}

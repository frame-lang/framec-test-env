@@target csharp

using System;
using System.Collections.Generic;

@@system S {
    machine:
        $A {
            e() {
                if (true) {
                    int x = 1; int y = 2;  // inline sep
                } else {
                    int y = 3; int x = 4;  // inline sep
                    -> $B()
                }
            }
        }
        $B { e() { } }
}

class Program {
    static void Main(string[] args) {
        Console.WriteLine("TAP version 14");
        Console.WriteLine("1..1");
        try {
            S s = new S();
            s.e();
            Console.WriteLine("ok 1 - nested_inline_separators");
        } catch (Exception ex) {
            Console.WriteLine("not ok 1 - nested_inline_separators # " + ex);
        }
    }
}

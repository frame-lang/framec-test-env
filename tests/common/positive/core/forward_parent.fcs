@@[target("csharp")]


class Stubs {
    public static void x() {}
}

@@system S {
    machine:
        $A => $P {
            e() {
                => $^
                Stubs.x();
            }
        }
        $P { }
}

class Program {
    static void Main(string[] args) {
        Console.WriteLine("TAP version 14");
        Console.WriteLine("1..1");
        try {
            S s = @@S();
            s.e();
            Console.WriteLine("ok 1 - forward_parent");
        } catch (Exception ex) {
            Console.WriteLine("not ok 1 - forward_parent # " + ex);
        }
    }
}

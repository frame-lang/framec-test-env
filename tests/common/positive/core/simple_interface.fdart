@@target dart
@@system S {
    machine:
        $A => $P {
            ev() {
                => $^
            }
        }
        $P { }
}

// Stub functions for placeholder calls
void native() {}
void x() {}

// TAP test harness
void main() {
    print("TAP version 14");
    print("1..1");
    try {
        final s = @@S();
        s.ev();
        print("ok 1 - simple_interface");
    } catch (ex) {
        print("not ok 1 - simple_interface # ${ex}");
    }
}

@@target erlang
@@system MooreMachine {
    interface:
        i0()
        i1()
        getOutput(): int
    machine:
        $Q0 {
            $>() { self.setOutput(0) }
            i0() { -> $Q1 }
            i1() { -> $Q2 }
            getOutput(): int {
                @@:(self.current_output)
            }
        }
        $Q1 {
            $>() { self.setOutput(1) }
            i0() { -> $Q0 }
            i1() { -> $Q2 }
            getOutput(): int {
                @@:(self.current_output)
            }
        }
        $Q2 {
            $>() { self.setOutput(2) }
            i0() { -> $Q0 }
            i1() { -> $Q1 }
            getOutput(): int {
                @@:(self.current_output)
            }
        }
    actions:
        setOutput(val: int) { self.current_output = val }
    domain:
        current_output = 0
}
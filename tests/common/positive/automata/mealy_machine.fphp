@@[target("php")]

# Mealy Machine - output depends on state AND input (output on transitions)

@@system MealyMachine {
    operations:
        get_last_output(): int {
            return $this->last_output;
        }

    interface:
        i_0()
        i_1()

    machine:
        $Q0 {
            i_0() {
                $this->emit_output(0);
                -> $Q1
            }
            i_1() {
                $this->emit_output(0);
                -> $Q2
            }
        }
        $Q1 {
            i_0() {
                $this->emit_output(0);
                -> $Q1
            }
            i_1() {
                $this->emit_output(1);
                -> $Q2
            }
        }
        $Q2 {
            i_0() {
                $this->emit_output(1);
                -> $Q1
            }
            i_1() {
                $this->emit_output(0);
                -> $Q2
            }
        }

    actions:
        emit_output(value: int) {
            $this->last_output = $value;
        }

    domain:
        last_output = -1
}

echo "TAP version 14" . "\n";
echo "1..4" . "\n";

$m = @@MealyMachine();

$m->i_0();
if ($m->get_last_output() === 0) { echo "ok 1 - mealy i_0 from Q0 outputs 0" . "\n"; }
else { echo "not ok 1 - mealy i_0 from Q0 outputs 0 # got " . $m->get_last_output() . "\n"; }

$m->i_0();
if ($m->get_last_output() === 0) { echo "ok 2 - mealy i_0 from Q1 outputs 0" . "\n"; }
else { echo "not ok 2 # got " . $m->get_last_output() . "\n"; }

$m->i_1();
if ($m->get_last_output() === 1) { echo "ok 3 - mealy i_1 from Q1 outputs 1" . "\n"; }
else { echo "not ok 3 # got " . $m->get_last_output() . "\n"; }

$m->i_0();
if ($m->get_last_output() === 1) { echo "ok 4 - mealy i_0 from Q2 outputs 1" . "\n"; }
else { echo "not ok 4 # got " . $m->get_last_output() . "\n"; }

echo "# PASS - Mealy machine outputs depend on state AND input" . "\n";

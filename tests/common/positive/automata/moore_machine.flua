@@[target("lua")]
@@system MooreMachine {
    operations:
        get_output(): int {
            return self.current_output
        }

    interface:
        i_0()
        i_1()

    machine:
        $Q0 {
            $>() {
                self.set_output(0)
            }
            i_0() {
                -> $Q1
            }
            i_1() {
                -> $Q2
            }
        }

        $Q1 {
            $>() {
                self.set_output(0)
            }
            i_0() {
                -> $Q1
            }
            i_1() {
                -> $Q3
            }
        }

        $Q2 {
            $>() {
                self.set_output(0)
            }
            i_0() {
                -> $Q4
            }
            i_1() {
                -> $Q2
            }
        }

        $Q3 {
            $>() {
                self.set_output(1)
            }
            i_0() {
                -> $Q4
            }
            i_1() {
                -> $Q2
            }
        }

        $Q4 {
            $>() {
                self.set_output(1)
            }
            i_0() {
                -> $Q1
            }
            i_1() {
                -> $Q3
            }
        }

    actions:
        set_output(value: int) {
            self.current_output = value
        }

    domain:
        current_output: int = 0

}

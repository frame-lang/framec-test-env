@@target ruby

# Mealy Machine - output depends on state AND input (output on transitions)

@@system MealyMachine {
    operations:
        get_last_output(): int {
            return self.last_output
        }

    interface:
        i_0()
        i_1()

    machine:
        $Q0 {
            i_0() { self.emit_output(0); -> $Q1 }
            i_1() { self.emit_output(0); -> $Q2 }
        }
        $Q1 {
            i_0() { self.emit_output(0); -> $Q1 }
            i_1() { self.emit_output(1); -> $Q2 }
        }
        $Q2 {
            i_0() { self.emit_output(1); -> $Q1 }
            i_1() { self.emit_output(0); -> $Q2 }
        }

    actions:
        emit_output(value: int) {
            self.last_output = value
        }

    domain:
        last_output: int = -1
}

puts("TAP version 14")
puts("1..4")

m = MealyMachine.new

m.i_0()
if m.get_last_output() == 0
    puts("ok 1 - mealy i_0 from Q0 outputs 0")
else
    puts("not ok 1 - mealy i_0 from Q0 outputs 0 # got #{m.get_last_output()}")
end

m.i_0()
if m.get_last_output() == 0
    puts("ok 2 - mealy i_0 from Q1 outputs 0")
else
    puts("not ok 2 - mealy i_0 from Q1 outputs 0 # got #{m.get_last_output()}")
end

m.i_1()
if m.get_last_output() == 1
    puts("ok 3 - mealy i_1 from Q1 outputs 1")
else
    puts("not ok 3 - mealy i_1 from Q1 outputs 1 # got #{m.get_last_output()}")
end

m.i_0()
if m.get_last_output() == 1
    puts("ok 4 - mealy i_0 from Q2 outputs 1")
else
    puts("not ok 4 - mealy i_0 from Q2 outputs 1 # got #{m.get_last_output()}")
end

puts("# PASS - Mealy machine outputs depend on state AND input")

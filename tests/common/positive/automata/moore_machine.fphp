<?php
@@target php

# Moore Machine - output depends ONLY on state (output on entry)

@@system MooreMachine {
    operations:
        get_output(): int {
            return $this->current_output;
        }

    interface:
        i_0()
        i_1()

    machine:
        $Q0 {
            $>() {
                $this->set_output(0);
            }
            i_0() {
                -> $Q1
            }
            i_1() {
                -> $Q2
            }
        }
        $Q1 {
            $>() {
                $this->set_output(0);
            }
            i_0() {
                -> $Q1
            }
            i_1() {
                -> $Q3
            }
        }
        $Q2 {
            $>() {
                $this->set_output(0);
            }
            i_0() {
                -> $Q4
            }
            i_1() {
                -> $Q2
            }
        }
        $Q3 {
            $>() {
                $this->set_output(1);
            }
            i_0() {
                -> $Q4
            }
            i_1() {
                -> $Q2
            }
        }
        $Q4 {
            $>() {
                $this->set_output(1);
            }
            i_0() {
                -> $Q1
            }
            i_1() {
                -> $Q3
            }
        }

    actions:
        set_output(value: int) {
            $this->current_output = $value;
        }

    domain:
        current_output = 0
}

echo "TAP version 14" . "\n";
echo "1..5" . "\n";

$m = new MooreMachine();

if ($m->get_output() === 0) { echo "ok 1 - moore initial state Q0 has output 0" . "\n"; }
else { echo "not ok 1 # got " . $m->get_output() . "\n"; }

$m->i_0();
if ($m->get_output() === 0) { echo "ok 2 - moore Q1 has output 0" . "\n"; }
else { echo "not ok 2 # got " . $m->get_output() . "\n"; }

$m->i_1();
if ($m->get_output() === 1) { echo "ok 3 - moore Q3 has output 1" . "\n"; }
else { echo "not ok 3 # got " . $m->get_output() . "\n"; }

$m->i_0();
if ($m->get_output() === 1) { echo "ok 4 - moore Q4 has output 1" . "\n"; }
else { echo "not ok 4 # got " . $m->get_output() . "\n"; }

$m->i_0();
if ($m->get_output() === 0) { echo "ok 5 - moore Q1 has output 0 again" . "\n"; }
else { echo "not ok 5 # got " . $m->get_output() . "\n"; }

echo "# PASS - Moore machine outputs depend ONLY on state" . "\n";

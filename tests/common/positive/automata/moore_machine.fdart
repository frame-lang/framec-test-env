@@[target("dart")]
// Moore Machine - output depends ONLY on state (output on entry)
// See: https://www.geeksforgeeks.org/mealy-and-moore-machines-in-toc/

@@system MooreMachine {
    operations:
        get_output(): num {
            return this.current_output;
        }
    interface:
        i_0()
        i_1()

    machine:
        $Q0 {
            $>() {
                this.set_output(0);
            }
            i_0() {
                -> $Q1
            }
            i_1() {
                -> $Q2
            }
        }

        $Q1 {
            $>() {
                this.set_output(0);
            }
            i_0() {
                -> $Q1
            }
            i_1() {
                -> $Q3
            }
        }

        $Q2 {
            $>() {
                this.set_output(0);
            }
            i_0() {
                -> $Q4
            }
            i_1() {
                -> $Q2
            }
        }

        $Q3 {
            $>() {
                this.set_output(1);
            }
            i_0() {
                -> $Q4
            }
            i_1() {
                -> $Q2
            }
        }

        $Q4 {
            $>() {
                this.set_output(1);
            }
            i_0() {
                -> $Q1
            }
            i_1() {
                -> $Q3
            }
        }

    actions:
        set_output(value: num) {
            this.current_output = value;
        }

    domain:
        current_output : num = 0

}

void main() {
    print("TAP version 14");
    print("1..5");

    final m = @@MooreMachine();

    // Initial state Q0 has output 0
    if (m.get_output() == 0) {
        print("ok 1 - moore initial state Q0 has output 0");
    } else {
        print("not ok 1 - moore initial state Q0 has output 0 # got ${m.get_output()}");
    }

    // i_0: Q0 -> Q1 (output 0)
    m.i_0();
    if (m.get_output() == 0) {
        print("ok 2 - moore Q1 has output 0");
    } else {
        print("not ok 2 - moore Q1 has output 0 # got ${m.get_output()}");
    }

    // i_1: Q1 -> Q3 (output 1)
    m.i_1();
    if (m.get_output() == 1) {
        print("ok 3 - moore Q3 has output 1");
    } else {
        print("not ok 3 - moore Q3 has output 1 # got ${m.get_output()}");
    }

    // i_0: Q3 -> Q4 (output 1)
    m.i_0();
    if (m.get_output() == 1) {
        print("ok 4 - moore Q4 has output 1");
    } else {
        print("not ok 4 - moore Q4 has output 1 # got ${m.get_output()}");
    }

    // i_0: Q4 -> Q1 (output 0)
    m.i_0();
    if (m.get_output() == 0) {
        print("ok 5 - moore Q1 has output 0 again");
    } else {
        print("not ok 5 - moore Q1 has output 0 again # got ${m.get_output()}");
    }

    print("# PASS - Moore machine outputs depend ONLY on state");
}


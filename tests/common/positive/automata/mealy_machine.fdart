@@target dart
// Mealy Machine - output depends on state AND input (output on transitions)
// See: https://www.geeksforgeeks.org/mealy-and-moore-machines-in-toc/

@@system MealyMachine {
    operations:
        get_last_output(): num {
            return this.last_output;
        }
    interface:
        i_0()
        i_1()

    machine:
        $Q0 {
            i_0() {
                this.emit_output(0);
                -> $Q1
            }
            i_1() {
                this.emit_output(0);
                -> $Q2
            }
        }

        $Q1 {
            i_0() {
                this.emit_output(0);
                -> $Q1
            }
            i_1() {
                this.emit_output(1);
                -> $Q2
            }
        }

        $Q2 {
            i_0() {
                this.emit_output(1);
                -> $Q1
            }
            i_1() {
                this.emit_output(0);
                -> $Q2
            }
        }

    actions:
        emit_output(value: num) {
            this.last_output = value;
        }

    domain:
        last_output : num = -1

}

void main() {
    print("TAP version 14");
    print("1..4");

    final m = @@MealyMachine();

    m.i_0();  // Q0 -> Q1, output 0
    if (m.get_last_output() == 0) {
        print("ok 1 - mealy i_0 from Q0 outputs 0");
    } else {
        print("not ok 1 - mealy i_0 from Q0 outputs 0 # got ${m.get_last_output()}");
    }

    m.i_0();  // Q1 -> Q1, output 0
    if (m.get_last_output() == 0) {
        print("ok 2 - mealy i_0 from Q1 outputs 0");
    } else {
        print("not ok 2 - mealy i_0 from Q1 outputs 0 # got ${m.get_last_output()}");
    }

    m.i_1();  // Q1 -> Q2, output 1
    if (m.get_last_output() == 1) {
        print("ok 3 - mealy i_1 from Q1 outputs 1");
    } else {
        print("not ok 3 - mealy i_1 from Q1 outputs 1 # got ${m.get_last_output()}");
    }

    m.i_0();  // Q2 -> Q1, output 1
    if (m.get_last_output() == 1) {
        print("ok 4 - mealy i_0 from Q2 outputs 1");
    } else {
        print("not ok 4 - mealy i_0 from Q2 outputs 1 # got ${m.get_last_output()}");
    }

    print("# PASS - Mealy machine outputs depend on state AND input");
}


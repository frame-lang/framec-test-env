@@target erlang
@@system MealyMachine {
    interface:
        i0()
        i1()
        getLastOutput(): int
    machine:
        $Q0 {
            i0() {
                self.emitOutput(0)
                -> $Q1
            }
            i1() {
                self.emitOutput(0)
                -> $Q2
            }
            getLastOutput(): int { return self.last_output }
        }
        $Q1 {
            i0() {
                self.emitOutput(1)
                -> $Q0
            }
            i1() {
                self.emitOutput(1)
                -> $Q2
            }
            getLastOutput(): int { return self.last_output }
        }
        $Q2 {
            i0() {
                self.emitOutput(0)
                -> $Q0
            }
            i1() {
                self.emitOutput(0)
                -> $Q1
            }
            getLastOutput(): int { return self.last_output }
        }
    actions:
        emitOutput(val: int) { self.last_output = val }
    domain:
        last_output = 0
}
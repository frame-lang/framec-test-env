@@[target("ruby")]

# Moore Machine - output depends ONLY on state (output on entry)

@@system MooreMachine {
    operations:
        get_output(): int {
            return self.current_output
        }

    interface:
        i_0()
        i_1()

    machine:
        $Q0 {
            $>() { self.set_output(0) }
            i_0() { -> $Q1 }
            i_1() { -> $Q2 }
        }
        $Q1 {
            $>() { self.set_output(0) }
            i_0() { -> $Q1 }
            i_1() { -> $Q3 }
        }
        $Q2 {
            $>() { self.set_output(0) }
            i_0() { -> $Q4 }
            i_1() { -> $Q2 }
        }
        $Q3 {
            $>() { self.set_output(1) }
            i_0() { -> $Q4 }
            i_1() { -> $Q2 }
        }
        $Q4 {
            $>() { self.set_output(1) }
            i_0() { -> $Q1 }
            i_1() { -> $Q3 }
        }

    actions:
        set_output(value: int) {
            self.current_output = value
        }

    domain:
        current_output: int = 0
}

puts("TAP version 14")
puts("1..5")

m = MooreMachine.new

if m.get_output() == 0
    puts("ok 1 - moore initial state Q0 has output 0")
else
    puts("not ok 1 - moore initial state Q0 has output 0 # got #{m.get_output()}")
end

m.i_0()
if m.get_output() == 0
    puts("ok 2 - moore Q1 has output 0")
else
    puts("not ok 2 - moore Q1 has output 0 # got #{m.get_output()}")
end

m.i_1()
if m.get_output() == 1
    puts("ok 3 - moore Q3 has output 1")
else
    puts("not ok 3 - moore Q3 has output 1 # got #{m.get_output()}")
end

m.i_0()
if m.get_output() == 1
    puts("ok 4 - moore Q4 has output 1")
else
    puts("not ok 4 - moore Q4 has output 1 # got #{m.get_output()}")
end

m.i_0()
if m.get_output() == 0
    puts("ok 5 - moore Q1 has output 0 again")
else
    puts("not ok 5 - moore Q1 has output 0 again # got #{m.get_output()}")
end

puts("# PASS - Moore machine outputs depend ONLY on state")

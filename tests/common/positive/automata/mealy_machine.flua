@@target lua
@@system MealyMachine {
    operations:
        get_last_output(): int {
            return self.last_output
        }

    interface:
        i_0()
        i_1()

    machine:
        $Q0 {
            i_0() {
                self.emit_output(0)
                -> $Q1
            }
            i_1() {
                self.emit_output(0)
                -> $Q2
            }
        }

        $Q1 {
            i_0() {
                self.emit_output(0)
                -> $Q1
            }
            i_1() {
                self.emit_output(1)
                -> $Q2
            }
        }

        $Q2 {
            i_0() {
                self.emit_output(1)
                -> $Q1
            }
            i_1() {
                self.emit_output(0)
                -> $Q2
            }
        }

    actions:
        emit_output(value: int) {
            self.last_output = value
        }

    domain:
        last_output: int = -1

}

@@[target("gdscript")]
extends SceneTree

@@system S {
    machine:
        $A {
            e() {
                # native prelude
                push$
            }
        }
}

# Stub functions for placeholder calls
func native(): pass
func x(): pass

# TAP test harness
func _init():
    print("TAP version 14")
    print("1..1")
    var s = @@S()
    if s.has_method("e"):
        s.e()
    print("ok 1 - terminal_last_stack_ops")
    quit()

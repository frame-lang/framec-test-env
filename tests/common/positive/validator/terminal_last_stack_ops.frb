@@target ruby

@@system S {
    machine:
        $A {
            e() {
                # native prelude
                push$
            }
        }
}

puts("TAP version 14")
puts("1..1")
begin
    s = S.new
    if s.respond_to?(:e)
        s.e()
    end
    puts("ok 1 - terminal_last_stack_ops")
rescue => ex
    puts("not ok 1 - terminal_last_stack_ops # #{ex}")
end

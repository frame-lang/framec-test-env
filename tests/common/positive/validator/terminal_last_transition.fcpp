@@target cpp_17

#include <iostream>
#include <string>
#include <cassert>

@@system S {
    machine:
        $A {
            e() {
                // native prelude
                -> $B()
            }
        }
        $B {
        }
}

// TAP test harness
int main() {
    std::cout << "TAP version 14" << std::endl;
    std::cout << "1..1" << std::endl;
    S s;
    s.e();
    std::cout << "ok 1 - terminal_last_transition" << std::endl;
    return 0;
}

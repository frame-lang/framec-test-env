@@[target("ruby")]

@@system S {
    machine:
        $A => $P {
            ev(n:int) {
                => $^
                n.to_s
            }
        }
        $P { }
}

puts("TAP version 14")
puts("1..1")
begin
    s = S.new
    if s.respond_to?(:e)
        s.e()
    end
    puts("ok 1 - interface_with_param")
rescue => ex
    puts("not ok 1 - interface_with_param # #{ex}")
end

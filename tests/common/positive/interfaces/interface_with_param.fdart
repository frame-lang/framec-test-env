@@[target("dart")]
@@system S {
    machine:
        $A => $P {
            ev(n: num) {
                => $^
                n.toString();
            }
        }
        $P { }
}

// Stub functions for placeholder calls
void native() {}
void x() {}

// TAP test harness
void main() {
    print("TAP version 14");
    print("1..1");
    try {
        final s = @@S();
        s.ev(42);
        print("ok 1 - interface_with_param");
    } catch (ex) {
        print("not ok 1 - interface_with_param # ${ex}");
    }
}

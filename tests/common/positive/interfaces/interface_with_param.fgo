@@target go

package main

import (
	"fmt"
	"strconv"
)

@@system S {
    machine:
        $A => $P {
            Ev(n: int) {
                => $^
                _ = strconv.Itoa(n)
            }
        }
        $P { }
}

func main() {
	fmt.Println("TAP version 14")
	fmt.Println("1..1")
	_ = NewS()
	fmt.Println("ok 1 - interface_with_param")
}

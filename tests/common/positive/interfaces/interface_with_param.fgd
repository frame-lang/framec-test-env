@@target gdscript
extends SceneTree

@@system S {
    machine:
        $A => $P {
            ev(n:int) {
                => $^
                str(n)
            }
        }
        $P { }
}

# Stub functions for placeholder calls

# TAP test harness
func _init():
    print("TAP version 14")
    print("1..1")
    var s = @@S()
    if s.has_method("e"):
        s.e()
    print("ok 1 - interface_with_param")
    quit()

<?php
@@[target("php")]

// Tests the cross-target return contract for dynamic targets:
// PHP's interface wrapper always exposes the FrameContext's return
// slot, regardless of whether the source declared a return type.
// See docs/frame_runtime.md § "Return values across target languages".

@@system ReturnNoType {
    interface:
        get_value()    // no `: type` declared
        peek()         // also no type, no @@:return in handler

    machine:
        $S {
            get_value() {
                @@:(42)
            }
            peek() {
                // body intentionally empty — no @@:return called
            }
        }
}

$s = new ReturnNoType();

$v = $s->get_value();
if ($v !== 42) { echo "FAIL: Expected 42, got " . var_export($v, true) . "\n"; exit(1); }

$p = $s->peek();
if ($p !== null) { echo "FAIL: Expected null default, got " . var_export($p, true) . "\n"; exit(1); }

echo "ok 1 - return_no_type_annotation\n";

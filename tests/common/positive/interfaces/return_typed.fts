@@target typescript

// Tests the cross-target return contract for strongly-typed targets:
// TypeScript's interface wrapper emits `return` only when the source
// declares a return type. `void` methods compile without a return.
// See docs/frame_runtime.md § "Return values across target languages".

@@system ReturnTyped {
    interface:
        get_value(): number
        do_thing()

    machine:
        $S {
            get_value(): number {
                @@:(42)
            }
            do_thing() {
                // void method — body runs, no @@:return
            }
        }
}

const s = @@ReturnTyped();

// Typed method — wrapper returns the FrameContext's return slot.
const v: number = s.get_value();
if (v !== 42) throw new Error(`Expected 42, got ${v}`);

// Void method — wrapper compiles without `return`. The call must
// complete cleanly; we don't read a value.
s.do_thing();

console.log("ok 1 - return_typed");

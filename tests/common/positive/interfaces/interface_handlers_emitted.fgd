@@target gdscript
extends SceneTree
@@compile-expect: def e\(
@@compile-expect: def _action_doThing\(
@@py-compile

@@system S {
    interface:
        e()
    machine:
        $A {
            e() { pass }
        }
    actions:
        doThing() { pass }
}

# Stub functions for placeholder calls
func native(): pass
func x(): pass

# TAP test harness
func _init():
    print("TAP version 14")
    print("1..1")
    var s = @@S()
    if s.has_method("e"):
        s.e()
    print("ok 1 - interface_handlers_emitted")
    quit()

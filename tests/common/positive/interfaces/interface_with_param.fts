@@target typescript

@@system S {
    machine:
        $A => $P {
            ev(n: number) {
                => $^
                String(n)
            }
        }
        $P { }
}

// Stub functions for placeholder calls
function native(): void {}
function x(): void {}

// TAP test harness
function main() {
    console.log("TAP version 14");
    console.log("1..1");
    try {
        const s = @@S();
        if (typeof (s as any).e === 'function') {
            (s as any).e();
        }
        console.log("ok 1 - interface_with_param");
    } catch (ex) {
        console.log(`not ok 1 - interface_with_param # ${ex}`);
    }
}
main();

@@target cpp_17
@@compile-expect: void S::e\(
@@compile-expect: void S::_action_doThing\(

#include <iostream>
#include <string>
#include <cassert>

@@system S {
    interface:
        e()
    machine:
        $A {
            e() { }
        }
    actions:
        doThing() { }
}

int main() {
    std::cout << "=== Test: Interface Handlers Emitted ===" << std::endl;
    S s;

    // Test that interface method e() is callable
    s.e();
    std::cout << "Called s.e()" << std::endl;

    std::cout << "PASS: Interface handlers emitted correctly" << std::endl;
    return 0;
}

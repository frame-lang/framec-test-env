@@[target("c")]

@@system S {
    machine:
        $A => $P {
            ev(n: int) {
                => $^
                // str(n) would be converted but we just verify forwarding works
            }
        }
        $P { }
}

int main() {
    printf("=== Test: Interface With Param ===\n");
    S* s = @@S();

    // The test mainly verifies the system compiles with HSM forwarding
    // and parameter handling
    printf("System created with HSM forwarding and params\n");

    printf("PASS: Interface with param compiles correctly\n");
    S_destroy(s);
    return 0;
}

@@[target("javascript")]

// Tests the cross-target return contract for dynamic targets:
// JavaScript's interface wrapper always exposes the FrameContext's
// return slot, regardless of whether the source declared a return type.
// See docs/frame_runtime.md § "Return values across target languages".

@@system ReturnNoType {
    interface:
        get_value()    // no `: type` declared
        peek()          // also no type, no @@:return in handler

    machine:
        $S {
            get_value() {
                @@:(42)
            }
            peek() {
                // body intentionally empty — no @@:return called
            }
        }
}

const s = @@ReturnNoType();

// @@:(42) sets the FrameContext's return slot. The wrapper
// always returns it for dynamic targets.
const v = s.get_value();
if (v !== 42) throw new Error(`Expected 42, got ${v}`);

// No @@:return called — slot still holds the default (null).
const p = s.peek();
if (p !== null) throw new Error(`Expected null default, got ${p}`);

console.log("ok 1 - return_no_type_annotation");

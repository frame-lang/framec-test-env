@@[target("ruby")]
@@compile-expect: def e\(
@@compile-expect: def _action_doThing\(
@@py-compile

@@system S {
    interface:
        e()
    machine:
        $A {
            e() { }
        }
    actions:
        doThing() { }
}

puts("TAP version 14")
puts("1..1")
begin
    s = S.new
    if s.respond_to?(:e)
        s.e()
    end
    puts("ok 1 - interface_handlers_emitted")
rescue => ex
    puts("not ok 1 - interface_handlers_emitted # #{ex}")
end

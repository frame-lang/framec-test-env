@@target python_3

# Tests the cross-target return contract for dynamic targets:
# Python's interface wrapper always exposes the FrameContext's return
# slot, regardless of whether the source declared a return type.
# See docs/frame_runtime.md § "Return values across target languages".

@@system ReturnNoType {
    interface:
        get_value()    # no `: type` declared
        peek()          # also no type, no @@:return in handler

    machine:
        $S {
            get_value() {
                @@:(42)
            }
            peek() {
                # body intentionally empty — no @@:return called
            }
        }
}

if __name__ == '__main__':
    s = @@ReturnNoType()

    # @@:(42) sets the FrameContext's return slot. The wrapper
    # always returns it for dynamic targets.
    v = s.get_value()
    assert v == 42, f"Expected 42, got {v!r}"

    # No @@:return called — slot still holds the default (None).
    p = s.peek()
    assert p is None, f"Expected None default, got {p!r}"

    print("ok 1 - return_no_type_annotation")

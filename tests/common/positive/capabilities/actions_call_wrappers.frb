@@[target("ruby")]
@@compile-expect: def _action_log\(
@@compile-expect: def log\(
@@compile-expect: def _action_handle\(
@@compile-expect: def handle\(
@@py-compile

@@system CallMismatch {
    machine:
        $S {
            e() { self.handle() }
        }
    actions:
        log(message) {
            self.last = message
        }
        handle() {
            self.log("hello")
        }
    domain:
        last = ""
}

# TAP test harness
puts("TAP version 14")
puts("1..1")
begin
    s = @@CallMismatch()
    if s.respond_to?(:e)
        s.e()
    end
    puts("ok 1 - actions_call_wrappers")
rescue => ex
    puts("not ok 1 - actions_call_wrappers # #{ex}")
end

// @skip Header defaults require InterfaceMethod.return_init support in C codegen
@@target c

// capability: system.return header defaults and handler returns (C).
//
// This fixture exercises:
// - Interface header defaults: a1(): int = 10, a2(a): int = a,
//   a3(a): int = self.x + a
// - Handler bodies that use:
//   - bare `return` (leave system.return at the header default)
//   - `return expr` sugar (override system.return)

#include <stdio.h>
#include <stdlib.h>
#include <stdint.h>

@@system SystemReturnHeaderDefaultsC {

    interface:
        a1(): int = 10
        a2(a: int): int = a
        a3(a: int): int = self->x + a

    machine:
        $Idle {
            a1() {
                if (self->x < 5) {
                    return;
                } else {
                    return 0;
                }
            }

            a2(a: int) {
                return;
            }

            a3(a: int) {
                return a;
            }
        }

    actions:
        bump_x(delta: int) {
            self->x = self->x + delta;
        }

    domain:
        var x: int = 3
}

// TAP test harness
int main() {
    printf("TAP version 14\n");
    printf("1..1\n");

    SystemReturnHeaderDefaultsC* s = SystemReturnHeaderDefaultsC_new();

    // Test a1() - x < 5, so should return default 10
    int r1 = SystemReturnHeaderDefaultsC_a1(s);
    if (r1 != 10) {
        printf("not ok 1 - system_return_header_defaults # a1() expected 10, got %d\n", r1);
        SystemReturnHeaderDefaultsC_destroy(s);
        return 1;
    }

    // Test a2(5) - should return default which is 'a' (5)
    int r2 = SystemReturnHeaderDefaultsC_a2(s, 5);
    if (r2 != 5) {
        printf("not ok 1 - system_return_header_defaults # a2(5) expected 5, got %d\n", r2);
        SystemReturnHeaderDefaultsC_destroy(s);
        return 1;
    }

    // Test a3(7) - returns a (7), not the default self->x + a
    int r3 = SystemReturnHeaderDefaultsC_a3(s, 7);
    if (r3 != 7) {
        printf("not ok 1 - system_return_header_defaults # a3(7) expected 7, got %d\n", r3);
        SystemReturnHeaderDefaultsC_destroy(s);
        return 1;
    }

    printf("ok 1 - system_return_header_defaults\n");

    SystemReturnHeaderDefaultsC_destroy(s);
    return 0;
}

@@[target("cpp_17")]
@@compile-expect: void _action_log\(
@@compile-expect: void log\(
@@compile-expect: void _action_handle\(
@@compile-expect: void handle\(

#include <iostream>
#include <cassert>

@@system CallMismatch {
    machine:
        $S {
            e() { this->handle(); }
        }
    actions:
        log(message: std::string) {
            // log sink
            this->last = message;
        }
        handle() {
            // Calls 'log' without _action_ prefix; wrappers should preserve FRM names
            this->log(std::string("hello"));
        }
    domain:
        last : std::string = ""
}

// Stub functions for placeholder calls
void native() {}
void x() {}

// TAP test harness
int main() {
    printf("TAP version 14\n");
    printf("1..1\n");
    try {
        auto s = @@CallMismatch();
        s.e();
        printf("ok 1 - actions_call_wrappers\n");
    } catch (...) {
        printf("not ok 1 - actions_call_wrappers\n");
    }
    return 0;
}

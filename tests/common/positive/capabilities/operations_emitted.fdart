@@target dart
@@system S {
    operations:
        calc(x, y) { return x + y; }
    machine:
        $A {
            e() {
                this.calc(1, 2);
            }
        }
}

// Stub functions for placeholder calls
void native() {}
void x() {}

// TAP test harness
void main() {
    print("TAP version 14");
    print("1..1");
    try {
        final s = @@S();
        if (true) {
            s.e();
        }
        print("ok 1 - operations_emitted");
    } catch (ex) {
        print("not ok 1 - operations_emitted # ${ex}");
    }
}

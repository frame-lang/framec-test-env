@@[target("dart")]

// capability: @@:return header defaults and handler returns (Dart).
//
// This fixture exercises:
// - Interface header defaults: a1(): num = 10, a2(a): num = a,
//   a3(a): num = this.x + a
// - Handler bodies that use:
//   - bare `return` (leave @@:return at the header default)
//   - `return expr` sugar (override @@:return)

@@system SystemReturnHeaderDefaultsDart {
    interface:
        a1(): num = 10
        a2(a): num = a
        a3(a): num = this.x + a

    machine:
        $Idle {
            a1() {
                if (this.x < 5) {
                    return;
                } else {
                    @@:(0)
                    return;
                }
            }

            a2(a) {
                return;
            }

            a3(a) {
                @@:(a)
                return;
            }
        }

    actions:
        bump_x(delta) {
            this.x = this.x + delta;
        }

    domain:
        x : num = 3
}

void main() {
    print("TAP version 14");
    print("1..1");
    try {
        var s = @@SystemReturnHeaderDefaultsDart();
        print("ok 1 - system_return_header_defaults");
    } catch (ex) {
        print("not ok 1 - system_return_header_defaults # $ex");
    }
}
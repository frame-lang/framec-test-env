@@[target("javascript")]

@@system S {
    machine:
        $A {
            e() {
                this.helper()
            }
        }
    actions:
        helper() { }
}

// Stub functions for placeholder calls
function native() {}
function x() {}
function helper() {}

// TAP test harness
function main() {
    console.log("TAP version 14");
    console.log("1..1");
    try {
        const s = @@S();
        if (typeof s.e === 'function') {
            s.e();
        }
        console.log("ok 1 - actions_emitted");
    } catch (ex) {
        console.log(`not ok 1 - actions_emitted # ${ex}`);
    }
}
main();

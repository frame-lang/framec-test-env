@@target dart
@@compile-expect: def _action_log\(
@@compile-expect: def log\(
@@compile-expect: def _action_handle\(
@@compile-expect: def handle\(
@@py-compile

@@system CallMismatch {
    machine:
        $S {
            e() { self.handle() }
        }
    actions:
        log(message) {
            # log sink
            self.last = message
        }
        handle() {
            # Calls 'log' without _action_ prefix; wrappers should preserve FRM names
            self.log("hello")
        }
    domain:
        last = ""
}

// Stub functions for placeholder calls

// TAP test harness
void main() {
    print("TAP version 14");
    print("1..1");
    try:
        var s = @@CallMismatch();
        if // hasattr check: 'e'):
            s.e();
        print("ok 1 - actions_call_wrappers");
    except Exception as ex:
        print("not ok 1 - actions_call_wrappers // {ex}");

}

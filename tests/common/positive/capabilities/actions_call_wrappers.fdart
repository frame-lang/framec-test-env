@@[target("dart")]
@@compile-expect: void _action_log\(
@@compile-expect: void log\(
@@compile-expect: void _action_handle\(
@@compile-expect: void handle\(

@@system CallMismatch {
    machine:
        $S {
            e() { this.handle(); }
        }
    actions:
        log(message) {
            // log sink
            this.last = message;
        }
        handle() {
            // Calls 'log' without _action_ prefix; wrappers should preserve FRM names
            this.log("hello");
        }
    domain:
        last : String = ""
}

void main() {
    print("TAP version 14");
    print("1..1");
    try {
        var s = @@CallMismatch();
        s.e();
        print("ok 1 - actions_call_wrappers");
    } catch (ex) {
        print("not ok 1 - actions_call_wrappers # $ex");
    }
}
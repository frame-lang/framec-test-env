@@target c
@@exec-ok

#include <stdio.h>
#include <stdlib.h>
#include <stdint.h>

// Note: C doesn't support nested functions in standard C.
// GCC has an extension for nested functions, but for portability
// we'll restructure to use static helper functions.

static int inner_func(int v) {
    return v + 1;
}

static int outer_func(void) {
    int v = 1;
    return inner_func(v);
}

@@system S {
    machine:
        $A => $P {
            e() {
                => $^
                outer_func();
            }
        }
        $P { }
}

// TAP test harness
int main() {
    printf("TAP version 14\n");
    printf("1..1\n");

    S* s = @@S();
    S_e(s);

    printf("ok 1 - nested_functions\n");

    S_destroy(s);
    return 0;
}

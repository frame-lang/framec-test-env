@@target ruby

@@system S {
    operations:
        calc(x, y) { return x + y }

    machine:
        $A {
            e() {
                self.calc(1, 2)
            }
        }
}

# TAP test harness
puts("TAP version 14")
puts("1..1")
begin
    s = S.new
    if s.respond_to?(:e)
        s.e()
    end
    puts("ok 1 - operations_emitted")
rescue => ex
    puts("not ok 1 - operations_emitted # #{ex}")
end

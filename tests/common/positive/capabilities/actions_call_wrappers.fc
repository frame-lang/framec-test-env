@@[target("c")]
@@compile-expect: void _action_log\(
@@compile-expect: void log\(
@@compile-expect: void _action_handle\(
@@compile-expect: void handle\(
@@c-compile

#include <stdio.h>
#include <stdlib.h>
#include <string.h>
#include <stdint.h>

@@system CallMismatch {
    machine:
        $S {
            e() { CallMismatch_handle(self); }
        }
    actions:
        log(message: str) {
            // log sink
            self->last = message;
        }
        handle() {
            // Calls 'log' without _action_ prefix; wrappers should preserve FRM names
            CallMismatch_log(self, "hello");
        }
    domain:
        last : char*
}

// TAP test harness
int main() {
    printf("TAP version 14\n");
    printf("1..1\n");

    CallMismatch* s = @@CallMismatch();
    CallMismatch_e(s);

    printf("ok 1 - actions_call_wrappers\n");

    CallMismatch_destroy(s);
    return 0;
}

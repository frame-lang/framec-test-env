@@[target("erlang")]
@@system SystemReturnHeaderDefaultsPy {
    interface:
        a1(): int = 10
        a2(a): int = a
        a3(a): int = self.x + a

    machine:
        $Idle {
            a1() {
                if self.x < 5 {
                    ok
                } else {
                    @@:(0)
                }
            }

            a2(a) {
            }

            a3(a) {
                @@:(a)
            }
        }

    actions:
        bump_x(delta) {
            self.x = self.x + delta
        }

    domain:
        x = 3
}

@@[target("php")]
@@compile-expect: function _action_log\(
@@compile-expect: function log\(
@@compile-expect: function _action_handle\(
@@compile-expect: function handle\(
@@py-compile

@@system CallMismatch {
    machine:
        $S {
            e() { $this->handle(); }
        }
    actions:
        log(message) {
            # log sink
            $this->last = $message;
        }
        handle() {
            $this->log("hello");
        }
    domain:
        last = ""
}

echo "TAP version 14" . "\n";
echo "1..1" . "\n";
try {
    $s = @@CallMismatch();
    if (method_exists($s, 'e')) {
        $s->e();
    }
    echo "ok 1 - actions_call_wrappers" . "\n";
} catch (\Exception $ex) {
    echo "not ok 1 - actions_call_wrappers # " . $ex->getMessage() . "\n";
}

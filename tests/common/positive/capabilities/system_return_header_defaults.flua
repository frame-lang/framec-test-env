@@target lua
@@system SystemReturnHeaderDefaultsPy {
    interface:
        a1(): int = 10
        a2(a): int = a
        a3(a): int = self.x + a

    machine:
        $Idle {
            a1() {
                if self.x < 5 {
                    return
                } else {
                    return 0
                }
            }

            a2(a) {
                return
            }

            a3(a) {
                return a
            }
        }

    actions:
        bump_x(delta) {
            self.x = self.x + delta
        }

    domain:
        x = 3
}

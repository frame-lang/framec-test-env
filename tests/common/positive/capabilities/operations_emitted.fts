@@target typescript

@@system S {
    machine:
        $A {
            e() {
                this.calc(1, 2)
            }
        }
    operations:
        calc(x, y) { return x + y }
}

// Stub functions for placeholder calls
function native(): void {}
function x(): void {}

// TAP test harness
function main() {
    console.log("TAP version 14");
    console.log("1..1");
    try {
        const s = new S();
        if (typeof (s as any).e === 'function') {
            (s as any).e();
        }
        console.log("ok 1 - operations_emitted");
    } catch (ex) {
        console.log(`not ok 1 - operations_emitted # ${ex}`);
    }
}
main();

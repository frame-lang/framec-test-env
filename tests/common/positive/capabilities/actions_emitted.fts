@@target typescript

@@system S {
    machine:
        $A {
            e() {
                this.helper()
            }
        }
    actions:
        helper() { }
}

// Stub functions for placeholder calls
function native(): void {}
function x(): void {}
function helper(): void {}

// TAP test harness
function main() {
    console.log("TAP version 14");
    console.log("1..1");
    try {
        const s = @@S();
        if (typeof (s as any).e === 'function') {
            (s as any).e();
        }
        console.log("ok 1 - actions_emitted");
    } catch (ex) {
        console.log(`not ok 1 - actions_emitted # ${ex}`);
    }
}
main();

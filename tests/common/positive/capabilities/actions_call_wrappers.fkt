@@target kotlin

import kotlin.system.exitProcess

@@system CallMismatch {
    machine:
        $S {
            e() { this.handle() }
        }
    actions:
        log(message: String) {
            // log sink
            this.last = message
        }
        handle() {
            // Calls 'log' without _action_ prefix; wrappers should preserve FRM names
            this.log("hello")
        }
    domain:
        last = ""
}

fun main() {
    println("TAP version 14")
    println("1..1")
    try {
        val s = CallMismatch()
        s.e()
        println("ok 1 - actions_call_wrappers")
    } catch (ex: Exception) {
        println("not ok 1 - actions_call_wrappers # $ex")
    }
}

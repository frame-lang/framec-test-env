@@target kotlin

import kotlin.system.exitProcess

@@system S {
    operations:
        calc(x: Int, y: Int): Int { return x + y }
    machine:
        $A {
            e() {
                this.calc(1, 2)
            }
        }
}

fun main() {
    println("TAP version 14")
    println("1..1")
    try {
        val s = S()
        s.e()
        println("ok 1 - operations_emitted")
    } catch (ex: Exception) {
        println("not ok 1 - operations_emitted # $ex")
    }
}

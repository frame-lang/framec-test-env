@@[target("go")]

package main

import "fmt"

@@system S {
    operations:
        Calc(x: int, y: int): int { return x + y }
    machine:
        $A {
            E() {
                s.Calc(1, 2)
            }
        }
}

func main() {
	fmt.Println("TAP version 14")
	fmt.Println("1..1")
	s := NewS()
	s.E()
	fmt.Println("ok 1 - operations_emitted")
}

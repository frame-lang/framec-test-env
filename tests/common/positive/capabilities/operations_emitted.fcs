@@[target("csharp")]

using System;
using System.Collections.Generic;

@@system S {
    operations:
        calc(x: int, y: int): int { return x + y; }
    machine:
        $A {
            e() {
                this.calc(1, 2);
            }
        }
}

class Program {
    static void Main(string[] args) {
        Console.WriteLine("TAP version 14");
        Console.WriteLine("1..1");
        try {
            S s = @@S();
            s.e();
            Console.WriteLine("ok 1 - operations_emitted");
        } catch (Exception ex) {
            Console.WriteLine("not ok 1 - operations_emitted # " + ex);
        }
    }
}

@@target ruby

@@system S {
    machine:
        $A {
            e() {
                self.helper()
            }
        }
    actions:
        helper() { }
}

# TAP test harness
puts("TAP version 14")
puts("1..1")
begin
    s = S.new
    if s.respond_to?(:e)
        s.e()
    end
    puts("ok 1 - actions_emitted")
rescue => ex
    puts("not ok 1 - actions_emitted # #{ex}")
end

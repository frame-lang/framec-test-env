@@target cpp_17

#include <iostream>
#include <string>
#include <cassert>

@@system S {
    operations:
        calc(x: int, y: int): int { return x + y; }
    machine:
        $A {
            e() {
                calc(1, 2);
            }
        }
}

// TAP test harness
int main() {
    std::cout << "TAP version 14" << std::endl;
    std::cout << "1..1" << std::endl;

    S s;
    s.e();

    // Verify operation works
    int result = s.calc(1, 2);
    if (result != 3) {
        std::cout << "not ok 1 - operations_emitted # calc(1,2) expected 3, got " << result << std::endl;
        return 1;
    }

    std::cout << "ok 1 - operations_emitted" << std::endl;

    return 0;
}

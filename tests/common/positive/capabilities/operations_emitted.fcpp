@@[target("cpp_17")]

#include <iostream>
#include <cassert>

@@system S {
    operations:
        calc(x: int, y: int): int { return x + y; }
    machine:
        $A {
            e() {
                this->calc(1, 2);
            }
        }
}

// Stub functions for placeholder calls
void native() {}
void x() {}

// TAP test harness
int main() {
    printf("TAP version 14\n");
    printf("1..1\n");
    try {
        auto s = @@S();
        s.e();
        printf("ok 1 - operations_emitted\n");
    } catch (...) {
        printf("not ok 1 - operations_emitted\n");
    }
    return 0;
}

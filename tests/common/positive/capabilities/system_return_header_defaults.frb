@@target ruby

@@system SystemReturnHeaderDefaultsRb {
    interface:
        a1(): int = 10
        a2(a): int = a
        a3(a): int = self.x + a

    machine:
        $Idle {
            a1() {
                if self.x < 5
                    return
                else
                    @@:(0)
                    return
                end
            }

            a2(a) {
                return
            }

            a3(a) {
                @@:(a)
                return
            }
        }

    actions:
        bump_x(delta) {
            self.x = self.x + delta
        }

    domain:
        x = 3
}

# TAP test harness
puts("TAP version 14")
puts("1..1")
begin
    s = SystemReturnHeaderDefaultsRb.new
    if s.respond_to?(:e)
        s.e()
    end
    puts("ok 1 - system_return_header_defaults")
rescue => ex
    puts("not ok 1 - system_return_header_defaults # #{ex}")
end

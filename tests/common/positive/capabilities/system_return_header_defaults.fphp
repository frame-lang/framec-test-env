<?php
@@target php

@@system SystemReturnHeaderDefaultsPy {
    interface:
        a1(): int = 10
        a2(a): int = a
        a3(a): int = self.x + a

    machine:
        $Idle {
            a1() {
                if ($this->x < 5) {
                    return;
                } else {
                    return 0;
                }
            }

            a2(a) {
                return;
            }

            a3(a) {
                return $a;
            }
        }

    actions:
        bump_x(delta) {
            $this->x = $this->x + $delta;
        }

    domain:
        x = 3
}

function native() {}
function x() {}

echo "TAP version 14" . "\n";
echo "1..1" . "\n";
try {
    $s = new SystemReturnHeaderDefaultsPy();
    if (method_exists($s, 'e')) {
        $s->e();
    }
    echo "ok 1 - system_return_header_defaults" . "\n";
} catch (\Exception $ex) {
    echo "not ok 1 - system_return_header_defaults # " . $ex->getMessage() . "\n";
}

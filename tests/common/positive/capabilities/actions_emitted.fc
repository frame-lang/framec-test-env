@@target c

#include <stdio.h>
#include <stdlib.h>
#include <stdint.h>

@@system S {
    machine:
        $A {
            e() {
                S_helper(self);
            }
        }
    actions:
        helper() { }
}

// TAP test harness
int main() {
    printf("TAP version 14\n");
    printf("1..1\n");

    S* s = @@S();
    S_e(s);

    printf("ok 1 - actions_emitted\n");

    S_destroy(s);
    return 0;
}

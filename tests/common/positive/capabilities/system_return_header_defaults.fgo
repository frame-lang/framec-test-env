@@[target("go")]

package main

import (
	"fmt"
	"os"
)

// capability: @@:return header defaults and handler returns (Go).

@@system SystemReturnHeaderDefaultsGo {
    interface:
        A1(): int = 10
        A2(a: int): int = a
        A3(a: int): int = s.x + a

    machine:
        $Idle {
            $>() {
                s.x = 3
            }
            A1() {
                if s.x < 5 {
                    return
                } else {
                    @@:(0)
                    return;
                }
            }

            A2(a: int) {
                return
            }

            A3(a: int) {
                @@:(a)
                return;
            }
        }

    actions:
        bumpX(delta: int) {
            s.x = s.x + delta
        }

    domain:
        x : int
}

func main() {
	fmt.Println("TAP version 14")
	fmt.Println("1..1")
	s := @@SystemReturnHeaderDefaultsGo()
	if s.A1() != 10 {
		fmt.Println("not ok 1 # a1 failed")
		os.Exit(1)
	}
	if s.A2(42) != 42 {
		fmt.Println("not ok 1 # a2 failed")
		os.Exit(1)
	}
	if s.A3(7) != 7 {
		fmt.Println("not ok 1 # a3 failed")
		os.Exit(1)
	}
	fmt.Println("ok 1 - system_return_header_defaults")
}

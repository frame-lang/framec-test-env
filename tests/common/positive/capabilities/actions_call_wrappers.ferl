@@[target("erlang")]
@@system CallMismatch {
    machine:
        $S {
            e() { self.handle() }
        }
    actions:
        log(message) {
            % log sink
            self.last = message
        }
        handle() {
            % Calls 'log' without _action_ prefix; wrappers should preserve FRM names
            self.log("hello")
        }
    domain:
        last = ""
}
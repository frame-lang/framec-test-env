@@target dart

@@system S {
    machine:
        $A {
            e() {
                this.helper()
            }
        }
    actions:
        helper() { }
}

// Stub functions for placeholder calls
void native(): void {}
void x(): void {}
void helper(): void {}

// TAP test harness
void main() {
    print("TAP version 14");
    print("1..1");
    try {
        final s = @@S();
        if (typeof (s as any).e == 'function') {
            (s as any).e();
        }
        print("ok 1 - actions_emitted");
    } catch (ex) {
        print("not ok 1 - actions_emitted # ${ex}");
    }
}

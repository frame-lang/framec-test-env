@@[target("kotlin")]

import kotlin.system.exitProcess

// capability: @@:return header defaults and handler returns (Kotlin).

@@system SystemReturnHeaderDefaultsKotlin {
    interface:
        a1(): Int = 10
        a2(a: Int): Int = a
        a3(a: Int): Int = x + a

    machine:
        $Idle {
            a1() {
                if (x < 5) {
                    return
                } else {
                    @@:(0)
                    return;
                }
            }

            a2(a: Int) {
                return
            }

            a3(a: Int) {
                @@:(a)
                return;
            }
        }

    actions:
        bump_x(delta: Int) {
            x = x + delta
        }

    domain:
        x = 3
}

fun main() {
    println("TAP version 14")
    println("1..1")
    try {
        val s = SystemReturnHeaderDefaultsKotlin()
        if ((s.a1() as Int) != 10) { println("not ok 1 # a1 failed"); return }
        if ((s.a2(42) as Int) != 42) { println("not ok 1 # a2 failed"); return }
        if ((s.a3(7) as Int) != 7) { println("not ok 1 # a3 failed"); return }
        println("ok 1 - system_return_header_defaults")
    } catch (ex: Exception) {
        println("not ok 1 - system_return_header_defaults # $ex")
    }
}

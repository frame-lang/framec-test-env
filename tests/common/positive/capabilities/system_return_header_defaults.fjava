@@target java

import java.util.*;

// capability: @@:return header defaults and handler returns (Java).

@@system SystemReturnHeaderDefaultsJava {
    interface:
        a1(): int = 10
        a2(a): int = a
        a3(a): int = this.x + a

    machine:
        $Idle {
            a1() {
                if (this.x < 5) {
                    return;
                } else {
                    return 0;
                }
            }

            a2(a) {
                return;
            }

            a3(a) {
                return a;
            }
        }

    actions:
        bump_x(delta) {
            this.x = this.x + delta;
        }

    domain:
        int x = 3
}

class Main {
    public static void main(String[] args) {
        System.out.println("TAP version 14");
        System.out.println("1..1");
        try {
            SystemReturnHeaderDefaultsJava s = new SystemReturnHeaderDefaultsJava();
            System.out.println("ok 1 - system_return_header_defaults");
        } catch (Exception ex) {
            System.out.println("not ok 1 - system_return_header_defaults # " + ex);
        }
    }
}

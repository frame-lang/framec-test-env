@@target go

package main

import "fmt"

@@system CallMismatch {
    machine:
        $S {
            E() { s.handle() }
        }
    actions:
        log(message: string) {
            // log sink
            s.last = message
        }
        handle() {
            // Calls 'log' without _action_ prefix; wrappers should preserve FRM names
            s.log("hello")
        }
    domain:
        last string
}

func main() {
	fmt.Println("TAP version 14")
	fmt.Println("1..1")
	s := NewCallMismatch()
	s.E()
	fmt.Println("ok 1 - actions_call_wrappers")
}

@@target c

#include <stdio.h>
#include <stdlib.h>
#include <stdint.h>

@@system S {
    machine:
        $A {
            e() {
                S_calc(self, 1, 2);
            }
        }
    operations:
        calc(x: int, y: int): int { return x + y; }
}

// TAP test harness
int main() {
    printf("TAP version 14\n");
    printf("1..1\n");

    S* s = @@S();
    S_e(s);

    // Verify operation works
    int result = S_calc(s, 1, 2);
    if (result != 3) {
        printf("not ok 1 - operations_emitted # calc(1,2) expected 3, got %d\n", result);
        S_destroy(s);
        return 1;
    }

    printf("ok 1 - operations_emitted\n");

    S_destroy(s);
    return 0;
}

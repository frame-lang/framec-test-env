#include <cassert>

@@system S {
    machine:
        $A {
            e() {
                this->helper();
            }
        }
    actions:
        helper() { }
}

// Stub functions for placeholder calls
void native() {}
void x() {}
void helper() {}

// TAP test harness
int main() {
    printf("TAP version 14\n");
    printf("1..1\n");
    try {
        auto s = @@S();
        s.e();
        printf("ok 1 - actions_emitted\n");
    } catch (...) {
        printf("not ok 1 - actions_emitted\n");
    }
    return 0;
}

@@target cpp_17

#include <iostream>
#include <string>
#include <cassert>

@@system S {
    machine:
        $A {
            e() {
                helper();
            }
        }
    actions:
        helper() { }
}

// TAP test harness
int main() {
    std::cout << "TAP version 14" << std::endl;
    std::cout << "1..1" << std::endl;

    S s;
    s.e();

    std::cout << "ok 1 - actions_emitted" << std::endl;

    return 0;
}

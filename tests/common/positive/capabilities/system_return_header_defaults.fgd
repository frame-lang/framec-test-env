@@target gdscript

# capability: @@:return header defaults and handler returns (Python).
#
# This fixture exercises:
# - Interface header defaults: a1(): int = 10, a2(a): int = a,
#   a3(a): int = self.x + a
# - Handler bodies that use:
#   - bare `return` (leave @@:return at the header default)
#   - `return expr` sugar (override @@:return)

@@system SystemReturnHeaderDefaultsPy {
    interface:
        a1(): int = 10
        a2(a): int = a
        a3(a): int = self.x + a

    machine:
        $Idle {
            a1() {
                if self.x < 5:
                    return
                else:
                    @@:(0)
                    return
            }

            a2(a) {
                return
            }

            a3(a) {
                @@:(a)
                return
            }
        }

    actions:
        bump_x(delta) {
            self.x = self.x + delta
        }

    domain:
        x = 3
}

# Stub functions for placeholder calls

# TAP test harness
func _ready():
    print("TAP version 14")
    print("1..1")
    try:
        s = @@SystemReturnHeaderDefaultsPy()
        if s.has_method('e'):
            s.e()
        print("ok 1 - system_return_header_defaults")
    except Exception as ex:
        print("not ok 1 - system_return_header_defaults # {ex}")

@@target gdscript

@@system S {
    operations:
        calc(x, y) { return x + y }

    machine:
        $A {
            e() {
                self.calc(1, 2)
            }
        }
}

# Stub functions for placeholder calls

# TAP test harness
func _ready():
    print("TAP version 14")
    print("1..1")
    try:
        s = @@S()
        if s.has_method('e'):
            s.e()
        print("ok 1 - operations_emitted")
    except Exception as ex:
        print("not ok 1 - operations_emitted # {ex}")

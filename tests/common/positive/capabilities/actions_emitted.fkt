@@target kotlin

import kotlin.system.exitProcess

@@system S {
    machine:
        $A {
            e() {
                this.helper()
            }
        }
    actions:
        helper() { }
}

fun main() {
    println("TAP version 14")
    println("1..1")
    try {
        val s = S()
        s.e()
        println("ok 1 - actions_emitted")
    } catch (ex: Exception) {
        println("not ok 1 - actions_emitted # $ex")
    }
}

@@target c

#include <stdio.h>
#include <stdlib.h>

@@system S {
    machine:
        $P { e() { } }
        $A => $P {
            e() {
                if (1) {
                    => $^
                } else {
                    -> $B()
                }
            }
        }
        $B { e() { } }
}

int main() {
    printf("TAP version 14\n");
    printf("1..1\n");

    S* s = @@S();
    if (s != NULL) {
        S_e(s);
        printf("ok 1 - if_forward_else_transition\n");
    } else {
        printf("not ok 1 - if_forward_else_transition # failed to create S\n");
    }

    if (s != NULL) {
        S_destroy(s);
    }

    return 0;
}

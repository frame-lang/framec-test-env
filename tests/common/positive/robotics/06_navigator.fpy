@@[target("python_3")]

# Cookbook 101: Go-To-Goal with Obstacle Avoidance
# Deliberative ($Planning) + reactive ($Driving, $Avoiding).
# After $Avoiding clears, the robot MUST re-plan — it cannot drop
# back into $Driving with a stale path. Plan failures counted by
# replan_count; exceed max_replans -> $Failed.

@@system Navigator {
    interface:
        navigate_to(goal_x: float, goal_y: float)
        tick(obstacle_distance: float, at_goal: int)
        plan_ready(path_len: int)
        plan_failed()
        abort()
        status(): str
        get_replans(): int
        get_path_index(): int

    machine:
        $Idle {
            navigate_to(goal_x: float, goal_y: float) {
                self.goal_x = goal_x
                self.goal_y = goal_y
                self.replan_count = 0
                -> $Planning
            }
            status(): str { @@:("idle") }
            get_replans(): int { @@:(self.replan_count) }
            get_path_index(): int { @@:(self.path_index) }
        }

        $Active {
            get_replans(): int { @@:(self.replan_count) }
            get_path_index(): int { @@:(self.path_index) }
        }

        $Mission => $Active {
            abort() { -> $Idle }
            => $^
        }

        $Planning => $Mission {
            plan_ready(path_len: int) {
                if path_len == 0:
                    @@:self.plan_failed()
                else:
                    self.path_len = path_len
                    self.path_index = 0
                    -> $Driving
            }
            plan_failed() {
                self.replan_count = self.replan_count + 1
                if self.replan_count >= self.max_replans:
                    -> $Failed
                else:
                    -> $Planning
            }
            status(): str { @@:("planning") }
            => $^
        }

        $Driving => $Mission {
            tick(obstacle_distance: float, at_goal: int) {
                if at_goal == 1:
                    -> $Arrived
                elif obstacle_distance < self.obstacle_threshold:
                    -> $Avoiding
                else:
                    self.path_index = self.path_index + 1
                    if self.path_index >= self.path_len:
                        -> $Planning
            }
            status(): str { @@:("driving") }
            => $^
        }

        $Avoiding => $Mission {
            $>() { self.avoid_ticks = 0 }
            tick(obstacle_distance: float, at_goal: int) {
                self.avoid_ticks = self.avoid_ticks + 1
                if obstacle_distance >= self.obstacle_threshold:
                    -> $Planning
                elif self.avoid_ticks > self.max_avoid_ticks:
                    -> $Failed
            }
            status(): str { @@:("avoiding") }
            => $^
        }

        $Arrived {
            navigate_to(goal_x: float, goal_y: float) {
                self.goal_x = goal_x
                self.goal_y = goal_y
                self.replan_count = 0
                -> $Planning
            }
            status(): str { @@:("arrived") }
            get_replans(): int { @@:(self.replan_count) }
            get_path_index(): int { @@:(self.path_index) }
        }

        $Failed {
            navigate_to(goal_x: float, goal_y: float) {
                self.goal_x = goal_x
                self.goal_y = goal_y
                self.replan_count = 0
                -> $Planning
            }
            status(): str { @@:("failed") }
            get_replans(): int { @@:(self.replan_count) }
            get_path_index(): int { @@:(self.path_index) }
        }

    domain:
        goal_x: float = 0.0
        goal_y: float = 0.0
        path_len: int = 0
        path_index: int = 0
        replan_count: int = 0
        max_replans: int = 3
        obstacle_threshold: float = 0.5
        avoid_ticks: int = 0
        max_avoid_ticks: int = 30
}


def check(label, actual, expected):
    if actual != expected:
        print(f"FAIL: {label} expected '{expected}', got '{actual}'")
        import sys
        sys.exit(1)


if __name__ == '__main__':
    # Happy path
    n = @@Navigator()
    check("idle", n.status(), "idle")

    n.navigate_to(5.0, 0.0)
    check("planning", n.status(), "planning")

    # Plan ready with 3 waypoints
    n.plan_ready(3)
    check("driving", n.status(), "driving")

    # Drive 2 segments clear of obstacles
    n.tick(10.0, 0)
    check("still driving 1", n.status(), "driving")
    n.tick(10.0, 0)
    check("still driving 2", n.status(), "driving")

    # Arrive at goal
    n.tick(10.0, 1)
    check("arrived", n.status(), "arrived")

    # Failed plan path
    n2 = @@Navigator()
    n2.navigate_to(5.0, 0.0)
    n2.plan_failed()   # attempt 1
    check("re-planning", n2.status(), "planning")
    check("1 replan", n2.get_replans(), 1)
    n2.plan_failed()   # attempt 2
    check("2 replans", n2.get_replans(), 2)
    n2.plan_failed()   # attempt 3 -> failed
    check("exceeded -> failed", n2.status(), "failed")

    # Plan-ready with empty path also counts as failure
    n3 = @@Navigator()
    n3.navigate_to(5.0, 0.0)
    n3.plan_ready(0)
    check("empty plan -> re-planning", n3.status(), "planning")
    check("empty counted as failure", n3.get_replans(), 1)

    # Obstacle avoidance: driving -> avoiding -> planning
    n4 = @@Navigator()
    n4.navigate_to(5.0, 0.0)
    n4.plan_ready(5)
    n4.tick(10.0, 0)    # driving
    n4.tick(0.3, 0)     # obstacle detected
    check("avoiding", n4.status(), "avoiding")

    # Obstacle cleared -> replan (NOT back to driving with stale path)
    n4.tick(10.0, 0)
    check("cleared -> planning (freshness)", n4.status(), "planning")

    # Trapped: avoid_ticks exceeds max -> failed
    n5 = @@Navigator()
    n5.navigate_to(5.0, 0.0)
    n5.plan_ready(5)
    n5.tick(0.3, 0)     # straight to avoiding (first tick obstacle)
    check("avoiding start", n5.status(), "avoiding")

    # 30 ticks of obstacle persistence -> failed
    i = 0
    while i < 35:
        n5.tick(0.3, 0)
        if n5.status() == "failed":
            break
        i = i + 1
    check("trapped -> failed", n5.status(), "failed")

    # Path exhausted without reaching goal triggers re-plan.
    n6 = @@Navigator()
    n6.navigate_to(5.0, 0.0)
    n6.plan_ready(2)    # short path
    n6.tick(10.0, 0)    # advance to path_index=1
    n6.tick(10.0, 0)    # advance to path_index=2 — exhausted
    check("exhausted -> replan", n6.status(), "planning")

    # Abort from any mission state
    n7 = @@Navigator()
    n7.navigate_to(5.0, 0.0)
    n7.plan_ready(3)
    n7.abort()
    check("aborted -> idle", n7.status(), "idle")

    # Abort from $Avoiding via HSM parent
    n8 = @@Navigator()
    n8.navigate_to(5.0, 0.0)
    n8.plan_ready(5)
    n8.tick(0.3, 0)
    n8.abort()
    check("abort from avoiding", n8.status(), "idle")

    # Re-navigate from Failed resets replan counter
    n2.navigate_to(10.0, 0.0)
    check("re-navigate from failed", n2.status(), "planning")
    check("replan counter reset", n2.get_replans(), 0)

    print("PASS: navigator")

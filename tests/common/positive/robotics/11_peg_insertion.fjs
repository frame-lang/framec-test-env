@@[target("javascript")]

// Cookbook 106: Force-Controlled Insertion — Peg-in-Hole

@@system PegInsertion {
    interface:
        start(target_depth)
        force_reading(fz)
        tick()
        abort()
        retracted()
        status()
        current_depth()
        get_retries()

    machine:
        $Idle {
            start(target_depth) {
                this.target_depth = target_depth;
                this.depth = 0.0;
                this.retry_count = 0;
                -> $Approaching
            }
            status() { @@:("idle") }
            current_depth() { @@:(this.depth) }
            get_retries() { @@:(this.retry_count) }
        }

        $Operation {
            abort() { -> $Retracting }
            current_depth() { @@:(this.depth) }
            get_retries() { @@:(this.retry_count) }
        }

        $Approaching => $Operation {
            force_reading(fz) {
                if (fz > this.contact_threshold) {
                    -> $Searching
                }
            }
            status() { @@:("approaching") }
            => $^
        }

        $Searching => $Operation {
            $>() { this.search_ticks = 0; }
            force_reading(fz) {
                if (fz < this.hole_threshold) {
                    -> $Inserting
                }
            }
            tick() {
                this.search_ticks = this.search_ticks + 1;
                if (this.search_ticks > this.search_timeout) {
                    -> $Retreating
                }
            }
            status() { @@:("searching") }
            => $^
        }

        $Inserting => $Operation {
            force_reading(fz) {
                if (fz > this.jam_threshold) {
                    -> $Jammed
                }
            }
            tick() {
                this.depth = this.depth + this.insert_velocity * 0.01;
                if (this.depth >= this.target_depth) {
                    -> $Seated
                }
            }
            status() { @@:("inserting") }
            => $^
        }

        $Jammed => $Operation {
            $>() { this.retry_count = this.retry_count + 1; }
            tick() {
                if (this.retry_count >= this.max_retries) {
                    -> $Failed
                } else {
                    -> $Retreating
                }
            }
            status() { @@:("jammed") }
            => $^
        }

        $Retreating => $Operation {
            tick() {
                -> $Searching
            }
            status() { @@:("retreating") }
            => $^
        }

        $Seated {
            status() { @@:("seated") }
            current_depth() { @@:(this.depth) }
            get_retries() { @@:(this.retry_count) }
        }

        $Retracting {
            retracted() { -> $Idle }
            status() { @@:("retracting") }
            current_depth() { @@:(this.depth) }
            get_retries() { @@:(this.retry_count) }
        }

        $Failed {
            start(target_depth) {
                this.target_depth = target_depth;
                this.depth = 0.0;
                this.retry_count = 0;
                -> $Approaching
            }
            status() { @@:("failed") }
            current_depth() { @@:(this.depth) }
            get_retries() { @@:(this.retry_count) }
        }

    domain:
        target_depth = 10.0
        depth = 0.0
        retry_count = 0
        max_retries = 2
        search_ticks = 0
        search_timeout = 30
        contact_threshold = 1.0
        hole_threshold = 0.2
        jam_threshold = 10.0
        insert_velocity = 5.0
}


function checkStr(label, actual, expected) {
    if (actual !== expected) {
        console.log("FAIL: " + label + " expected '" + expected + "', got '" + actual + "'");
        process.exit(1);
    }
}
function checkInt(label, actual, expected) {
    if (actual !== expected) {
        console.log("FAIL: " + label + " expected " + expected + ", got " + actual);
        process.exit(1);
    }
}

const p = @@PegInsertion();
checkStr("idle", p.status(), "idle");

p.start(10.0);
checkStr("approaching", p.status(), "approaching");

p.force_reading(2.0);
checkStr("searching", p.status(), "searching");

p.force_reading(0.05);
checkStr("inserting", p.status(), "inserting");

let i = 0;
while (i < 220) {
    p.tick();
    if (p.status() === "seated") break;
    i = i + 1;
}
checkStr("seated", p.status(), "seated");

const p2 = @@PegInsertion();
p2.start(10.0);
p2.force_reading(2.0);
p2.force_reading(0.05);
p2.force_reading(15.0);
checkStr("jammed", p2.status(), "jammed");
checkInt("retry counted", p2.get_retries(), 1);

p2.tick();
checkStr("retreating", p2.status(), "retreating");
p2.tick();
checkStr("back to searching", p2.status(), "searching");

p2.force_reading(0.05);
checkStr("re-inserting", p2.status(), "inserting");
p2.force_reading(15.0);
checkStr("jammed again", p2.status(), "jammed");
p2.tick();
checkStr("exhausted -> failed", p2.status(), "failed");

const p3 = @@PegInsertion();
p3.start(10.0);
p3.force_reading(2.0);
let j = 0;
while (j < 35) {
    p3.tick();
    if (p3.status() !== "searching") break;
    j = j + 1;
}
checkStr("search timeout -> retreating", p3.status(), "retreating");

const p4 = @@PegInsertion();
p4.start(10.0);
p4.force_reading(2.0);
p4.force_reading(0.05);
p4.abort();
checkStr("abort -> retracting", p4.status(), "retracting");
p4.retracted();
checkStr("retracted -> idle", p4.status(), "idle");

console.log("PASS: peg_insertion");

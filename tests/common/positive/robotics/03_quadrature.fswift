@@[target("swift")]


// Cookbook 98: Quadrature Encoder Decoder — Mealy Machine

@@system QuadratureDecoder {
    operations:
        count(): Int { return self.count_val }
        direction(): String { return self.last_dir }
        errors_count(): Int { return self.errors }
        reset() {
            self.count_val = 0
            self.errors = 0
            self.last_dir = "none"
        }

    interface:
        signal(a: Int, b: Int): Int

    machine:
        $S00 {
            signal(a: Int, b: Int): Int {
                if a == 0 && b == 0 {
                    @@:(0)
                } else if a == 1 && b == 0 {
                    self.count_val = self.count_val + 1
                    self.last_dir = "fwd"
                    @@:(1)
                    -> $S10
                } else if a == 0 && b == 1 {
                    self.count_val = self.count_val - 1
                    self.last_dir = "rev"
                    @@:(-1)
                    -> $S01
                } else {
                    self.errors = self.errors + 1
                    @@:(0)
                }
            }
        }

        $S10 {
            signal(a: Int, b: Int): Int {
                if a == 1 && b == 0 {
                    @@:(0)
                } else if a == 1 && b == 1 {
                    self.count_val = self.count_val + 1
                    self.last_dir = "fwd"
                    @@:(1)
                    -> $S11
                } else if a == 0 && b == 0 {
                    self.count_val = self.count_val - 1
                    self.last_dir = "rev"
                    @@:(-1)
                    -> $S00
                } else {
                    self.errors = self.errors + 1
                    @@:(0)
                }
            }
        }

        $S11 {
            signal(a: Int, b: Int): Int {
                if a == 1 && b == 1 {
                    @@:(0)
                } else if a == 0 && b == 1 {
                    self.count_val = self.count_val + 1
                    self.last_dir = "fwd"
                    @@:(1)
                    -> $S01
                } else if a == 1 && b == 0 {
                    self.count_val = self.count_val - 1
                    self.last_dir = "rev"
                    @@:(-1)
                    -> $S10
                } else {
                    self.errors = self.errors + 1
                    @@:(0)
                }
            }
        }

        $S01 {
            signal(a: Int, b: Int): Int {
                if a == 0 && b == 1 {
                    @@:(0)
                } else if a == 0 && b == 0 {
                    self.count_val = self.count_val + 1
                    self.last_dir = "fwd"
                    @@:(1)
                    -> $S00
                } else if a == 1 && b == 1 {
                    self.count_val = self.count_val - 1
                    self.last_dir = "rev"
                    @@:(-1)
                    -> $S11
                } else {
                    self.errors = self.errors + 1
                    @@:(0)
                }
            }
        }

    domain:
        count_val: Int = 0
        errors: Int = 0
        last_dir: String = "none"
}


func checkStr(_ label: String, _ actual: String, _ expected: String) {
    if actual != expected {
        print("FAIL: \(label) expected '\(expected)', got '\(actual)'")
        exit(1)
    }
}
func checkInt(_ label: String, _ actual: Int, _ expected: Int) {
    if actual != expected {
        print("FAIL: \(label) expected \(expected), got \(actual)")
        exit(1)
    }
}

let q = @@QuadratureDecoder()
checkInt("initial count 0", q.count(), 0)
checkStr("initial direction", q.direction(), "none")
checkInt("initial errors 0", q.errors_count(), 0)

checkInt("idle 00", q.signal(0, 0), 0)
checkInt("no count change on idle", q.count(), 0)

checkInt("00->10 fwd", q.signal(1, 0), 1)
checkInt("10->11 fwd", q.signal(1, 1), 1)
checkInt("11->01 fwd", q.signal(0, 1), 1)
checkInt("01->00 fwd", q.signal(0, 0), 1)

checkInt("four fwd ticks", q.count(), 4)
checkStr("direction fwd", q.direction(), "fwd")

checkInt("00->01 rev", q.signal(0, 1), -1)
checkInt("01->11 rev", q.signal(1, 1), -1)
checkInt("11->10 rev", q.signal(1, 0), -1)
checkInt("10->00 rev", q.signal(0, 0), -1)

checkInt("net count 0", q.count(), 0)
checkStr("direction rev", q.direction(), "rev")

checkInt("illegal 00->11", q.signal(1, 1), 0)
checkInt("error counted", q.errors_count(), 1)

checkInt("still at 00", q.signal(1, 0), 1)

q.reset()
checkInt("count reset", q.count(), 0)
checkStr("direction reset", q.direction(), "none")
checkInt("errors reset", q.errors_count(), 0)

q.signal(1, 0); q.signal(1, 1); q.signal(0, 1); q.signal(0, 0)
q.signal(1, 0); q.signal(1, 1); q.signal(0, 1); q.signal(0, 0)
checkInt("8 signals starting idle = 7 fwd edges", q.count(), 7)

print("PASS: quadrature")

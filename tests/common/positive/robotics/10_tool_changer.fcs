@@[target("csharp")]

// Cookbook 105: Tool Changer — Interlocked Coupling Sequence


@@system ToolChanger {
    interface:
        request_couple(tool_id: string)
        request_uncouple()
        lock_confirmed()
        lock_lost()
        tool_energized()
        tool_deenergized()
        abort()
        status(): string
        is_energized(): int
        attached_tool(): string

    machine:
        $NoTool {
            request_couple(tool_id: string) {
                this.tool_id = tool_id;
                -> $Approaching
            }
            request_uncouple() { }
            status(): string { @@:("no_tool") }
            is_energized(): int { @@:(this.energized) }
            attached_tool(): string { @@:(this.tool_id) }
        }

        $Transitioning {
            is_energized(): int { @@:(this.energized) }
            attached_tool(): string { @@:(this.tool_id) }
        }

        $Coupling => $Transitioning {
            lock_lost() {
                this.tool_id = "";
                -> $NoTool
            }
            => $^
        }

        $Approaching => $Coupling {
            lock_confirmed() { -> $Coupled }
            abort() {
                this.tool_id = "";
                -> $NoTool
            }
            status(): string { @@:("approaching") }
            => $^
        }

        $Coupled {
            tool_energized() {
                this.energized = 1;
                -> $Working
            }
            request_uncouple() { -> $Uncoupling }
            lock_lost() { -> $Fault }
            status(): string { @@:("coupled") }
            is_energized(): int { @@:(this.energized) }
            attached_tool(): string { @@:(this.tool_id) }
        }

        $Working {
            tool_deenergized() {
                this.energized = 0;
                -> $Coupled
            }
            lock_lost() {
                this.energized = 0;
                -> $Fault
            }
            status(): string { @@:("working") }
            is_energized(): int { @@:(this.energized) }
            attached_tool(): string { @@:(this.tool_id) }
        }

        $Uncoupling => $Transitioning {
            lock_lost() {
                this.tool_id = "";
                -> $NoTool
            }
            status(): string { @@:("uncoupling") }
            => $^
        }

        $Fault {
            abort() {
                this.tool_id = "";
                this.energized = 0;
                -> $NoTool
            }
            status(): string { @@:("fault") }
            is_energized(): int { @@:(this.energized) }
            attached_tool(): string { @@:(this.tool_id) }
        }

    domain:
        tool_id: string = ""
        energized: int = 0
}


class Program {
    static void check_str(string label, string actual, string expected) {
        if (actual != expected) {
            Console.WriteLine($"FAIL: {label} expected '{expected}', got '{actual}'");
            Environment.Exit(1);
        }
    }
    static void check_int(string label, int actual, int expected) {
        if (actual != expected) {
            Console.WriteLine($"FAIL: {label} expected {expected}, got {actual}");
            Environment.Exit(1);
        }
    }

    public static void Main(string[] args) {
        var tc = @@ToolChanger();
        check_str("no tool", (string) tc.status(), "no_tool");
        check_str("no tool stored", (string) tc.attached_tool(), "");
        check_int("not energized", (int) tc.is_energized(), 0);

        tc.request_couple("drill_8mm");
        check_str("approaching", (string) tc.status(), "approaching");
        check_str("tool captured", (string) tc.attached_tool(), "drill_8mm");

        tc.lock_confirmed();
        check_str("coupled", (string) tc.status(), "coupled");

        tc.tool_energized();
        check_str("working", (string) tc.status(), "working");
        check_int("energized", (int) tc.is_energized(), 1);

        tc.request_uncouple();
        check_str("working absorbs uncouple", (string) tc.status(), "working");
        check_str("still attached", (string) tc.attached_tool(), "drill_8mm");
        check_int("still energized", (int) tc.is_energized(), 1);

        tc.tool_deenergized();
        check_str("coupled de-energized", (string) tc.status(), "coupled");
        check_int("not energized", (int) tc.is_energized(), 0);

        tc.request_uncouple();
        check_str("uncoupling", (string) tc.status(), "uncoupling");

        tc.lock_lost();
        check_str("no tool again", (string) tc.status(), "no_tool");
        check_str("tool cleared", (string) tc.attached_tool(), "");

        var tc2 = @@ToolChanger();
        tc2.request_couple("router");
        tc2.lock_confirmed();
        tc2.lock_lost();
        check_str("lock_lost in coupled -> fault", (string) tc2.status(), "fault");

        var tc3 = @@ToolChanger();
        tc3.request_couple("saw");
        tc3.lock_confirmed();
        tc3.tool_energized();
        tc3.lock_lost();
        check_str("lock_lost in working -> fault", (string) tc3.status(), "fault");
        check_int("fault de-energizes", (int) tc3.is_energized(), 0);

        tc3.abort();
        check_str("abort clears fault", (string) tc3.status(), "no_tool");

        var tc4 = @@ToolChanger();
        tc4.request_couple("probe");
        tc4.abort();
        check_str("abort during approach", (string) tc4.status(), "no_tool");

        var tc5 = @@ToolChanger();
        tc5.request_couple("clamp");
        tc5.lock_lost();
        check_str("lock_lost in approaching -> no_tool", (string) tc5.status(), "no_tool");

        Console.WriteLine("PASS: tool_changer");
    }
}

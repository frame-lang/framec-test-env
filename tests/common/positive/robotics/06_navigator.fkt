@@[target("kotlin")]

// Cookbook 101: Go-To-Goal with Obstacle Avoidance

@@system Navigator {
    interface:
        navigate_to(goal_x: Double, goal_y: Double)
        tick(obstacle_distance: Double, at_goal: Int)
        plan_ready(path_len: Int)
        plan_failed()
        abort()
        status(): String
        get_replans(): Int
        get_path_index(): Int

    machine:
        $Idle {
            navigate_to(goal_x: Double, goal_y: Double) {
                this.goal_x = goal_x
                this.goal_y = goal_y
                this.replan_count = 0
                -> $Planning
            }
            status(): String { @@:("idle") }
            get_replans(): Int { @@:(this.replan_count) }
            get_path_index(): Int { @@:(this.path_index) }
        }

        $Active {
            get_replans(): Int { @@:(this.replan_count) }
            get_path_index(): Int { @@:(this.path_index) }
        }

        $Mission => $Active {
            abort() { -> $Idle }
            => $^
        }

        $Planning => $Mission {
            plan_ready(path_len: Int) {
                if (path_len == 0) {
                    @@:self.plan_failed()
                } else {
                    this.path_len = path_len
                    this.path_index = 0
                    -> $Driving
                }
            }
            plan_failed() {
                this.replan_count = this.replan_count + 1
                if (this.replan_count >= this.max_replans) {
                    -> $Failed
                } else {
                    -> $Planning
                }
            }
            status(): String { @@:("planning") }
            => $^
        }

        $Driving => $Mission {
            tick(obstacle_distance: Double, at_goal: Int) {
                if (at_goal == 1) {
                    -> $Arrived
                } else if (obstacle_distance < this.obstacle_threshold) {
                    -> $Avoiding
                } else {
                    this.path_index = this.path_index + 1
                    if (this.path_index >= this.path_len) {
                        -> $Planning
                    }
                }
            }
            status(): String { @@:("driving") }
            => $^
        }

        $Avoiding => $Mission {
            $>() { this.avoid_ticks = 0 }
            tick(obstacle_distance: Double, at_goal: Int) {
                this.avoid_ticks = this.avoid_ticks + 1
                if (obstacle_distance >= this.obstacle_threshold) {
                    -> $Planning
                } else if (this.avoid_ticks > this.max_avoid_ticks) {
                    -> $Failed
                }
            }
            status(): String { @@:("avoiding") }
            => $^
        }

        $Arrived {
            navigate_to(goal_x: Double, goal_y: Double) {
                this.goal_x = goal_x
                this.goal_y = goal_y
                this.replan_count = 0
                -> $Planning
            }
            status(): String { @@:("arrived") }
            get_replans(): Int { @@:(this.replan_count) }
            get_path_index(): Int { @@:(this.path_index) }
        }

        $Failed {
            navigate_to(goal_x: Double, goal_y: Double) {
                this.goal_x = goal_x
                this.goal_y = goal_y
                this.replan_count = 0
                -> $Planning
            }
            status(): String { @@:("failed") }
            get_replans(): Int { @@:(this.replan_count) }
            get_path_index(): Int { @@:(this.path_index) }
        }

    domain:
        goal_x: Double = 0.0
        goal_y: Double = 0.0
        path_len: Int = 0
        path_index: Int = 0
        replan_count: Int = 0
        max_replans: Int = 3
        obstacle_threshold: Double = 0.5
        avoid_ticks: Int = 0
        max_avoid_ticks: Int = 30
}

fun check(label: String, actual: String, expected: String) {
    if (actual != expected) {
        println("FAIL: $label expected '$expected', got '$actual'")
        kotlin.system.exitProcess(1)
    }
}
fun checkInt(label: String, actual: Int, expected: Int) {
    if (actual != expected) {
        println("FAIL: $label expected $expected, got $actual")
        kotlin.system.exitProcess(1)
    }
}

fun main() {
    val n = @@Navigator()
    check("idle", n.status() as String, "idle")
    n.navigate_to(5.0, 0.0)
    check("planning", n.status() as String, "planning")
    n.plan_ready(3)
    check("driving", n.status() as String, "driving")
    n.tick(10.0, 0)
    check("still driving 1", n.status() as String, "driving")
    n.tick(10.0, 0)
    check("still driving 2", n.status() as String, "driving")
    n.tick(10.0, 1)
    check("arrived", n.status() as String, "arrived")

    val n2 = @@Navigator()
    n2.navigate_to(5.0, 0.0)
    n2.plan_failed()
    check("re-planning", n2.status() as String, "planning")
    checkInt("1 replan", n2.get_replans() as Int, 1)
    n2.plan_failed()
    checkInt("2 replans", n2.get_replans() as Int, 2)
    n2.plan_failed()
    check("exceeded -> failed", n2.status() as String, "failed")

    val n3 = @@Navigator()
    n3.navigate_to(5.0, 0.0)
    n3.plan_ready(0)
    check("empty plan -> re-planning", n3.status() as String, "planning")
    checkInt("empty counted as failure", n3.get_replans() as Int, 1)

    val n4 = @@Navigator()
    n4.navigate_to(5.0, 0.0)
    n4.plan_ready(5)
    n4.tick(10.0, 0)
    n4.tick(0.3, 0)
    check("avoiding", n4.status() as String, "avoiding")
    n4.tick(10.0, 0)
    check("cleared -> planning (freshness)", n4.status() as String, "planning")

    val n5 = @@Navigator()
    n5.navigate_to(5.0, 0.0)
    n5.plan_ready(5)
    n5.tick(0.3, 0)
    check("avoiding start", n5.status() as String, "avoiding")
    var i = 0
    while (i < 35) {
        n5.tick(0.3, 0)
        if ((n5.status() as String) == "failed") break
        i = i + 1
    }
    check("trapped -> failed", n5.status() as String, "failed")

    val n6 = @@Navigator()
    n6.navigate_to(5.0, 0.0)
    n6.plan_ready(2)
    n6.tick(10.0, 0)
    n6.tick(10.0, 0)
    check("exhausted -> replan", n6.status() as String, "planning")

    val n7 = @@Navigator()
    n7.navigate_to(5.0, 0.0)
    n7.plan_ready(3)
    n7.abort()
    check("aborted -> idle", n7.status() as String, "idle")

    val n8 = @@Navigator()
    n8.navigate_to(5.0, 0.0)
    n8.plan_ready(5)
    n8.tick(0.3, 0)
    n8.abort()
    check("abort from avoiding", n8.status() as String, "idle")

    n2.navigate_to(10.0, 0.0)
    check("re-navigate from failed", n2.status() as String, "planning")
    checkInt("replan counter reset", n2.get_replans() as Int, 0)

    println("PASS: navigator")
}

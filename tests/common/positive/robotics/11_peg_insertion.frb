@@[target("ruby")]

# Cookbook 106: Force-Controlled Insertion — Peg-in-Hole

@@system PegInsertion {
    interface:
        start(target_depth: float)
        force_reading(fz: float)
        tick()
        abort()
        retracted()
        status(): str
        current_depth(): float
        get_retries(): int

    machine:
        $Idle {
            start(target_depth: float) {
                self.target_depth = target_depth
                self.depth = 0.0
                self.retry_count = 0
                -> $Approaching
            }
            status(): str { @@:("idle") }
            current_depth(): float { @@:(self.depth) }
            get_retries(): int { @@:(self.retry_count) }
        }

        $Operation {
            abort() { -> $Retracting }
            current_depth(): float { @@:(self.depth) }
            get_retries(): int { @@:(self.retry_count) }
        }

        $Approaching => $Operation {
            force_reading(fz: float) {
                if fz > self.contact_threshold
                    -> $Searching
                end
            }
            status(): str { @@:("approaching") }
            => $^
        }

        $Searching => $Operation {
            $>() { self.search_ticks = 0 }
            force_reading(fz: float) {
                if fz < self.hole_threshold
                    -> $Inserting
                end
            }
            tick() {
                self.search_ticks = self.search_ticks + 1
                if self.search_ticks > self.search_timeout
                    -> $Retreating
                end
            }
            status(): str { @@:("searching") }
            => $^
        }

        $Inserting => $Operation {
            force_reading(fz: float) {
                if fz > self.jam_threshold
                    -> $Jammed
                end
            }
            tick() {
                self.depth = self.depth + self.insert_velocity * 0.01
                if self.depth >= self.target_depth
                    -> $Seated
                end
            }
            status(): str { @@:("inserting") }
            => $^
        }

        $Jammed => $Operation {
            $>() { self.retry_count = self.retry_count + 1 }
            tick() {
                if self.retry_count >= self.max_retries
                    -> $Failed
                else
                    -> $Retreating
                end
            }
            status(): str { @@:("jammed") }
            => $^
        }

        $Retreating => $Operation {
            tick() {
                -> $Searching
            }
            status(): str { @@:("retreating") }
            => $^
        }

        $Seated {
            status(): str { @@:("seated") }
            current_depth(): float { @@:(self.depth) }
            get_retries(): int { @@:(self.retry_count) }
        }

        $Retracting {
            retracted() { -> $Idle }
            status(): str { @@:("retracting") }
            current_depth(): float { @@:(self.depth) }
            get_retries(): int { @@:(self.retry_count) }
        }

        $Failed {
            start(target_depth: float) {
                self.target_depth = target_depth
                self.depth = 0.0
                self.retry_count = 0
                -> $Approaching
            }
            status(): str { @@:("failed") }
            current_depth(): float { @@:(self.depth) }
            get_retries(): int { @@:(self.retry_count) }
        }

    domain:
        target_depth = 10.0
        depth = 0.0
        retry_count = 0
        max_retries = 2
        search_ticks = 0
        search_timeout = 30
        contact_threshold = 1.0
        hole_threshold = 0.2
        jam_threshold = 10.0
        insert_velocity = 5.0
}


def check_str(label, actual, expected)
  if actual != expected
    puts "FAIL: #{label} expected '#{expected}', got '#{actual}'"
    exit 1
  end
end
def check_int(label, actual, expected)
  if actual != expected
    puts "FAIL: #{label} expected #{expected}, got #{actual}"
    exit 1
  end
end

p_ = @@PegInsertion()
check_str("idle", p_.status, "idle")

p_.start(10.0)
check_str("approaching", p_.status, "approaching")

p_.force_reading(2.0)
check_str("searching", p_.status, "searching")

p_.force_reading(0.05)
check_str("inserting", p_.status, "inserting")

i = 0
while i < 220
  p_.tick
  break if p_.status == "seated"
  i = i + 1
end
check_str("seated", p_.status, "seated")

p2 = @@PegInsertion()
p2.start(10.0)
p2.force_reading(2.0)
p2.force_reading(0.05)
p2.force_reading(15.0)
check_str("jammed", p2.status, "jammed")
check_int("retry counted", p2.get_retries, 1)

p2.tick
check_str("retreating", p2.status, "retreating")
p2.tick
check_str("back to searching", p2.status, "searching")

p2.force_reading(0.05)
check_str("re-inserting", p2.status, "inserting")
p2.force_reading(15.0)
check_str("jammed again", p2.status, "jammed")
p2.tick
check_str("exhausted -> failed", p2.status, "failed")

p3 = @@PegInsertion()
p3.start(10.0)
p3.force_reading(2.0)
j = 0
while j < 35
  p3.tick
  break if p3.status != "searching"
  j = j + 1
end
check_str("search timeout -> retreating", p3.status, "retreating")

p4 = @@PegInsertion()
p4.start(10.0)
p4.force_reading(2.0)
p4.force_reading(0.05)
p4.abort
check_str("abort -> retracting", p4.status, "retracting")
p4.retracted
check_str("retracted -> idle", p4.status, "idle")

puts "PASS: peg_insertion"

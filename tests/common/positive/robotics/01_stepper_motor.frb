@@[target("ruby")]

# Cookbook 96: Stepper Motor Driver — Trapezoidal Motion Profile

@@system StepperDriver {
    interface:
        move_to(target_steps: int)
        tick()
        stop()
        stall_detected()
        status(): str
        get_position(): int
        get_velocity(): int

    machine:
        $Idle {
            move_to(target_steps: int) {
                self.target = target_steps
                self.position = 0
                self.velocity = 0
                self.accel_steps = 0
                -> $Accelerating
            }
            tick() { }
            status(): str { @@:("idle") }
            get_position(): int { @@:(self.position) }
            get_velocity(): int { @@:(self.velocity) }
        }

        $Active {
            get_position(): int { @@:(self.position) }
            get_velocity(): int { @@:(self.velocity) }
        }

        $Motion => $Active {
            stop() { -> $Decelerating }
            stall_detected() {
                self.velocity = 0
                -> $Stalled
            }
            => $^
        }

        $Accelerating => $Motion {
            tick() {
                self.velocity = self.velocity + self.accel_rate
                self.position = self.position + self.velocity
                self.accel_steps = self.accel_steps + self.velocity

                if self.velocity >= self.v_max
                    self.velocity = self.v_max
                    -> $Cruising
                end

                remaining = self.target - self.position
                if remaining <= self.accel_steps
                    -> $Decelerating
                end
            }
            status(): str { @@:("accelerating") }
            => $^
        }

        $Cruising => $Motion {
            tick() {
                self.position = self.position + self.velocity
                remaining = self.target - self.position
                if remaining <= self.accel_steps
                    -> $Decelerating
                end
            }
            status(): str { @@:("cruising") }
            => $^
        }

        $Decelerating => $Motion {
            tick() {
                self.velocity = self.velocity - self.accel_rate
                if self.velocity <= 0
                    self.velocity = 0
                    -> $Idle
                else
                    self.position = self.position + self.velocity
                end
            }
            status(): str { @@:("decelerating") }
            => $^
        }

        $Stalled {
            move_to(target_steps: int) {
                self.target = target_steps
                self.position = 0
                self.velocity = 0
                self.accel_steps = 0
                -> $Accelerating
            }
            status(): str { @@:("stalled") }
            get_position(): int { @@:(self.position) }
            get_velocity(): int { @@:(self.velocity) }
        }

    domain:
        target = 0
        position = 0
        velocity = 0
        accel_steps = 0
        v_max = 20
        accel_rate = 2
}


def check_str(label, actual, expected)
  if actual != expected
    puts "FAIL: #{label} expected '#{expected}', got '#{actual}'"
    exit 1
  end
end
def check_int(label, actual, expected)
  if actual != expected
    puts "FAIL: #{label} expected #{expected}, got #{actual}"
    exit 1
  end
end
def check_bool(label, actual, expected)
  if actual != expected
    puts "FAIL: #{label} expected #{expected}, got #{actual}"
    exit 1
  end
end

m = @@StepperDriver()
check_str("start idle", m.status, "idle")
check_int("start position 0", m.get_position, 0)

m.move_to(300)
check_str("accelerating", m.status, "accelerating")

saw_cruising = false
final_status = ""
40.times do
  m.tick
  s = m.status
  saw_cruising = true if s == "cruising"
  if s == "idle"
    final_status = s
    break
  end
end
check_bool("long move visited cruising", saw_cruising, true)
check_str("long move ended idle", final_status, "idle")
check_int("final velocity 0", m.get_velocity, 0)
check_bool("position advanced", m.get_position > 200, true)

m2 = @@StepperDriver()
m2.move_to(40)
saw_cruising2 = false
final_status2 = ""
20.times do
  m2.tick
  s = m2.status
  saw_cruising2 = true if s == "cruising"
  if s == "idle"
    final_status2 = s
    break
  end
end
check_bool("short move skips cruising", saw_cruising2, false)
check_str("short move ended idle", final_status2, "idle")

m3 = @@StepperDriver()
m3.move_to(1000)
15.times { m3.tick }
check_str("in cruise", m3.status, "cruising")

m3.stop
check_str("stopped to decel", m3.status, "decelerating")

15.times do
  m3.tick
  break if m3.status == "idle"
end
check_str("decel completes after stop", m3.status, "idle")
check_int("stopped velocity 0", m3.get_velocity, 0)

m4 = @@StepperDriver()
m4.move_to(1000)
3.times { m4.tick }
check_str("accel when stalled", m4.status, "accelerating")
m4.stall_detected
check_str("stalled", m4.status, "stalled")
check_int("velocity cleared on stall", m4.get_velocity, 0)

m4.move_to(50)
check_str("stall cleared", m4.status, "accelerating")

m5 = @@StepperDriver()
m5.stop
m5.stall_detected
check_str("idle absorbs stop", m5.status, "idle")

puts "PASS: stepper_motor"

@@[target("java")]

// Cookbook 106: Force-Controlled Insertion — Peg-in-Hole

@@system PegInsertion {
    interface:
        start(target_depth: double)
        force_reading(fz: double)
        tick()
        abort()
        retracted()
        status(): String
        current_depth(): double
        get_retries(): int

    machine:
        $Idle {
            start(target_depth: double) {
                this.target_depth = target_depth;
                this.depth = 0.0;
                this.retry_count = 0;
                -> $Approaching
            }
            status(): String { @@:("idle") }
            current_depth(): double { @@:(this.depth) }
            get_retries(): int { @@:(this.retry_count) }
        }

        $Operation {
            abort() { -> $Retracting }
            current_depth(): double { @@:(this.depth) }
            get_retries(): int { @@:(this.retry_count) }
        }

        $Approaching => $Operation {
            force_reading(fz: double) {
                if (fz > this.contact_threshold) {
                    -> $Searching
                }
            }
            status(): String { @@:("approaching") }
            => $^
        }

        $Searching => $Operation {
            $>() { this.search_ticks = 0; }
            force_reading(fz: double) {
                if (fz < this.hole_threshold) {
                    -> $Inserting
                }
            }
            tick() {
                this.search_ticks = this.search_ticks + 1;
                if (this.search_ticks > this.search_timeout) {
                    -> $Retreating
                }
            }
            status(): String { @@:("searching") }
            => $^
        }

        $Inserting => $Operation {
            force_reading(fz: double) {
                if (fz > this.jam_threshold) {
                    -> $Jammed
                }
            }
            tick() {
                this.depth = this.depth + this.insert_velocity * 0.01;
                if (this.depth >= this.target_depth) {
                    -> $Seated
                }
            }
            status(): String { @@:("inserting") }
            => $^
        }

        $Jammed => $Operation {
            $>() { this.retry_count = this.retry_count + 1; }
            tick() {
                if (this.retry_count >= this.max_retries) {
                    -> $Failed
                } else {
                    -> $Retreating
                }
            }
            status(): String { @@:("jammed") }
            => $^
        }

        $Retreating => $Operation {
            tick() {
                -> $Searching
            }
            status(): String { @@:("retreating") }
            => $^
        }

        $Seated {
            status(): String { @@:("seated") }
            current_depth(): double { @@:(this.depth) }
            get_retries(): int { @@:(this.retry_count) }
        }

        $Retracting {
            retracted() { -> $Idle }
            status(): String { @@:("retracting") }
            current_depth(): double { @@:(this.depth) }
            get_retries(): int { @@:(this.retry_count) }
        }

        $Failed {
            start(target_depth: double) {
                this.target_depth = target_depth;
                this.depth = 0.0;
                this.retry_count = 0;
                -> $Approaching
            }
            status(): String { @@:("failed") }
            current_depth(): double { @@:(this.depth) }
            get_retries(): int { @@:(this.retry_count) }
        }

    domain:
        target_depth: double = 10.0
        depth: double = 0.0
        retry_count: int = 0
        max_retries: int = 2
        search_ticks: int = 0
        search_timeout: int = 30
        contact_threshold: double = 1.0
        hole_threshold: double = 0.2
        jam_threshold: double = 10.0
        insert_velocity: double = 5.0
}


class Main {
    static void check_str(String label, String actual, String expected) {
        if (!actual.equals(expected)) {
            System.out.println("FAIL: " + label + " expected '" + expected + "', got '" + actual + "'");
            System.exit(1);
        }
    }
    static void check_int(String label, int actual, int expected) {
        if (actual != expected) {
            System.out.println("FAIL: " + label + " expected " + expected + ", got " + actual);
            System.exit(1);
        }
    }

    public static void main(String[] args) {
        PegInsertion p = @@PegInsertion();
        check_str("idle", p.status(), "idle");

        p.start(10.0);
        check_str("approaching", p.status(), "approaching");

        p.force_reading(2.0);
        check_str("searching", p.status(), "searching");

        p.force_reading(0.05);
        check_str("inserting", p.status(), "inserting");

        int i = 0;
        while (i < 220) {
            p.tick();
            if (((String) p.status()).equals("seated")) break;
            i = i + 1;
        }
        check_str("seated", p.status(), "seated");

        PegInsertion p2 = @@PegInsertion();
        p2.start(10.0);
        p2.force_reading(2.0);
        p2.force_reading(0.05);
        p2.force_reading(15.0);
        check_str("jammed", p2.status(), "jammed");
        check_int("retry counted", p2.get_retries(), 1);

        p2.tick();
        check_str("retreating", p2.status(), "retreating");
        p2.tick();
        check_str("back to searching", p2.status(), "searching");

        p2.force_reading(0.05);
        check_str("re-inserting", p2.status(), "inserting");
        p2.force_reading(15.0);
        check_str("jammed again", p2.status(), "jammed");
        p2.tick();
        check_str("exhausted -> failed", p2.status(), "failed");

        PegInsertion p3 = @@PegInsertion();
        p3.start(10.0);
        p3.force_reading(2.0);
        int j = 0;
        while (j < 35) {
            p3.tick();
            if (!((String) p3.status()).equals("searching")) break;
            j = j + 1;
        }
        check_str("search timeout -> retreating", p3.status(), "retreating");

        PegInsertion p4 = @@PegInsertion();
        p4.start(10.0);
        p4.force_reading(2.0);
        p4.force_reading(0.05);
        p4.abort();
        check_str("abort -> retracting", p4.status(), "retracting");
        p4.retracted();
        check_str("retracted -> idle", p4.status(), "idle");

        System.out.println("PASS: peg_insertion");
    }
}

@@[target("go")]

// Cookbook 100: Mobile Base — Teleop/Autonomy + Safety Bumper

package main

import (
    "fmt"
    "math"
    "os"
)

@@system MobileBase {
    interface:
        set_teleop()
        set_autonomous()
        drive(linear: float64, angular: float64)
        follow_waypoints(count: int)
        waypoint_reached()
        e_stop()
        clear_e_stop()
        bumper_hit(side: string)
        cliff_detected()
        clear_safety()
        tick()
        status(): string
        get_x(): float64
        get_v(): float64
        get_wp_index(): int

    machine:
        $TeleopIdle => $Teleop {
            drive(linear: float64, angular: float64) {
                s.v_linear = linear
                s.v_angular = angular
                -> $TeleopDriving
            }
            set_autonomous() { -> $AutoIdle }
            status(): string { @@:("teleop_idle") }
            => $^
        }

        $Safety {
            get_x(): float64 { @@:(s.pos_x) }
            get_v(): float64 { @@:(s.v_linear) }
            get_wp_index(): int { @@:(s.wp_index) }
        }

        $Operational => $Safety {
            e_stop() {
                s.v_linear = 0.0
                s.v_angular = 0.0
                -> $EStopped
            }
            bumper_hit(side: string) {
                s.v_linear = 0.0
                s.v_angular = 0.0
                s.safety_reason = "bumper"
                -> $ProtectiveStop
            }
            cliff_detected() {
                s.v_linear = 0.0
                s.v_angular = 0.0
                s.safety_reason = "cliff"
                -> $ProtectiveStop
            }
            => $^
        }

        $EStopped {
            clear_e_stop() { -> $TeleopIdle }
            status(): string { @@:("e_stop") }
            get_x(): float64 { @@:(s.pos_x) }
            get_v(): float64 { @@:(s.v_linear) }
            get_wp_index(): int { @@:(s.wp_index) }
        }

        $ProtectiveStop {
            clear_safety() {
                s.safety_reason = ""
                -> $TeleopIdle
            }
            status(): string { @@:("protective_stop") }
            get_x(): float64 { @@:(s.pos_x) }
            get_v(): float64 { @@:(s.v_linear) }
            get_wp_index(): int { @@:(s.wp_index) }
        }

        $Teleop => $Operational {
            follow_waypoints(count: int) { }
            => $^
        }

        $TeleopDriving => $Teleop {
            $>() {
                if s.v_linear > s.teleop_speed_limit {
                    s.v_linear = s.teleop_speed_limit
                }
            }
            drive(linear: float64, angular: float64) {
                if linear == 0.0 && angular == 0.0 {
                    s.v_linear = 0.0
                    s.v_angular = 0.0
                    -> $TeleopIdle
                } else {
                    s.v_linear = linear
                    s.v_angular = angular
                }
            }
            tick() {
                s.pos_x = s.pos_x + s.v_linear * 0.1
            }
            status(): string { @@:("teleop_driving") }
            => $^
        }

        $Auto => $Operational {
            drive(linear: float64, angular: float64) { }
            set_teleop() { -> $TeleopIdle }
            => $^
        }

        $AutoIdle => $Auto {
            follow_waypoints(count: int) {
                s.wp_count = count
                s.wp_index = 0
                -> $AutoDriving
            }
            status(): string { @@:("auto_idle") }
            => $^
        }

        $AutoDriving => $Auto {
            $>() {
                if s.wp_index >= s.wp_count {
                    -> $AutoIdle
                } else {
                    s.v_linear = s.auto_speed_limit
                }
            }
            tick() {
                s.pos_x = s.pos_x + s.v_linear * 0.1
                if s.pos_x >= float64(s.wp_index + 1) * 5.0 {
                    @@:self.waypoint_reached()
                }
            }
            waypoint_reached() {
                s.wp_index = s.wp_index + 1
                -> $AutoDriving
            }
            status(): string { @@:("auto_driving") }
            => $^
        }

    domain:
        pos_x: float64 = 0.0
        v_linear: float64 = 0.0
        v_angular: float64 = 0.0
        teleop_speed_limit: float64 = 0.5
        auto_speed_limit: float64 = 1.0
        wp_count: int = 0
        wp_index: int = 0
        safety_reason: string = ""
}

func check(label, actual, expected string) {
    if actual != expected {
        fmt.Printf("FAIL: %s expected '%s', got '%s'\n", label, expected, actual)
        os.Exit(1)
    }
}
func checkD(label string, actual, expected float64) {
    if math.Abs(actual-expected) > 1e-9 {
        fmt.Printf("FAIL: %s expected %f, got %f\n", label, expected, actual)
        os.Exit(1)
    }
}
func checkI(label string, actual, expected int) {
    if actual != expected {
        fmt.Printf("FAIL: %s expected %d, got %d\n", label, expected, actual)
        os.Exit(1)
    }
}

func main() {
    b := @@MobileBase()
    check("teleop_idle", b.status().(string), "teleop_idle")

    b.drive(0.3, 0.0)
    check("teleop_driving", b.status().(string), "teleop_driving")
    checkD("velocity set", b.get_v().(float64), 0.3)

    b.tick()
    b.tick()
    checkD("position advanced", b.get_x().(float64), 0.06)

    b.drive(0.0, 0.0)
    check("stopped -> idle", b.status().(string), "teleop_idle")

    b.drive(2.0, 0.0)
    checkD("speed limited on entry", b.get_v().(float64), 0.5)
    b.drive(0.0, 0.0)

    b.drive(0.3, 0.0)
    b.bumper_hit("front")
    check("bumper -> protective_stop", b.status().(string), "protective_stop")
    checkD("velocity zeroed on bump", b.get_v().(float64), 0.0)

    posBefore := b.get_x().(float64)
    b.tick()
    checkD("protective absorbs tick", b.get_x().(float64), posBefore)

    b.clear_safety()
    check("cleared to teleop_idle", b.status().(string), "teleop_idle")

    b.drive(0.3, 0.0)
    b.cliff_detected()
    check("cliff -> protective_stop", b.status().(string), "protective_stop")
    b.clear_safety()

    b.drive(0.3, 0.0)
    b.e_stop()
    check("e_stop", b.status().(string), "e_stop")
    b.clear_e_stop()
    check("cleared e_stop to teleop_idle", b.status().(string), "teleop_idle")

    b.set_autonomous()
    check("auto_idle", b.status().(string), "auto_idle")

    b.drive(0.3, 0.0)
    check("auto rejects drive", b.status().(string), "auto_idle")

    b.follow_waypoints(3)
    check("auto_driving", b.status().(string), "auto_driving")
    checkI("0 wp reached initially", b.get_wp_index().(int), 0)

    i := 0
    for i < 250 {
        b.tick()
        if b.status().(string) == "auto_idle" {
            break
        }
        i = i + 1
    }
    check("auto complete -> auto_idle", b.status().(string), "auto_idle")
    checkI("3 waypoints tracked", b.get_wp_index().(int), 3)

    b.set_teleop()
    check("back to teleop_idle", b.status().(string), "teleop_idle")
    wpBefore := b.get_wp_index().(int)
    b.follow_waypoints(5)
    check("teleop rejects follow", b.status().(string), "teleop_idle")
    checkI("wp_index unchanged", b.get_wp_index().(int), wpBefore)

    fmt.Println("PASS: mobile_base")
}

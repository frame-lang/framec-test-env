@@[target("typescript")]

// Cookbook 108: Drone Flight Modes — Failsafe from Any Phase

@@system DroneFlightMode {
    interface:
        arm(preflight_ok: number)
        takeoff(altitude: number)
        set_mission(waypoints_ok: number)
        return_to_home()
        land()
        disarm()
        takeoff_complete()
        mission_complete()
        home_reached()
        touchdown()
        battery_critical()
        gps_lost()
        rc_lost()
        geofence_breach()
        tick()
        status(): string
        altitude(): number
        failsafe_reason(): string

    machine:
        $Disarmed {
            arm(preflight_ok: number) {
                if (preflight_ok == 1) {
                    -> $Armed
                }
            }
            status(): string { @@:("disarmed") }
            altitude(): number { @@:(this.current_altitude) }
            failsafe_reason(): string { @@:(this.reason) }
        }

        $Armed {
            takeoff(altitude: number) {
                this.target_altitude = altitude;
                -> $TakingOff
            }
            disarm() { -> $Disarmed }
            status(): string { @@:("armed") }
            altitude(): number { @@:(this.current_altitude) }
            failsafe_reason(): string { @@:(this.reason) }
        }

        $Flying {
            altitude(): number { @@:(this.current_altitude) }
            failsafe_reason(): string { @@:(this.reason) }
        }

        $InFlight => $Flying {
            battery_critical() {
                this.reason = "battery";
                -> $EmergencyLand
            }
            rc_lost() {
                this.reason = "rc_lost";
                -> $ReturningHome
            }
            gps_lost() {
                this.reason = "gps_lost";
                -> $AltitudeHold
            }
            geofence_breach() {
                this.reason = "geofence";
                -> $ReturningHome
            }
            => $^
        }

        $TakingOff => $InFlight {
            $>() { this.current_altitude = 0.0; }
            tick() {
                this.current_altitude = this.current_altitude + 1.0;
                if (this.current_altitude >= this.target_altitude) {
                    @@:self.takeoff_complete();
                }
            }
            takeoff_complete() { -> $Hovering }
            status(): string { @@:("taking_off") }
            => $^
        }

        $Hovering => $InFlight {
            set_mission(waypoints_ok: number) {
                if (waypoints_ok == 1) {
                    -> $OnMission
                }
            }
            land() { -> $Landing }
            return_to_home() { -> $ReturningHome }
            status(): string { @@:("hovering") }
            => $^
        }

        $OnMission => $InFlight {
            mission_complete() { -> $Hovering }
            return_to_home() { -> $ReturningHome }
            status(): string { @@:("on_mission") }
            => $^
        }

        $ReturningHome => $InFlight {
            home_reached() { -> $Landing }
            status(): string { @@:("returning") }
            => $^
        }

        $AltitudeHold => $InFlight {
            status(): string { @@:("altitude_hold") }
            => $^
        }

        $Landing {
            touchdown() {
                this.current_altitude = 0.0;
                -> $Armed
            }
            status(): string { @@:("landing") }
            altitude(): number { @@:(this.current_altitude) }
            failsafe_reason(): string { @@:(this.reason) }
        }

        $EmergencyLand {
            touchdown() {
                this.current_altitude = 0.0;
                -> $Armed
            }
            status(): string { @@:("emergency_land") }
            altitude(): number { @@:(this.current_altitude) }
            failsafe_reason(): string { @@:(this.reason) }
        }

    domain:
        target_altitude: number = 0.0
        current_altitude: number = 0.0
        reason: string = ""
}

function check(label: string, actual: any, expected: any): void {
    if (actual !== expected) {
        console.log("FAIL: " + label + " expected '" + expected + "', got '" + actual + "'");
        process.exit(1);
    }
}
function checkAlt(label: string, actual: number, expected: number): void {
    if (Math.abs(actual - expected) > 1e-6) {
        console.log("FAIL: " + label + " expected " + expected + ", got " + actual);
        process.exit(1);
    }
}

const d = @@DroneFlightMode();
check("disarmed", d.status(), "disarmed");
d.arm(0);
check("preflight fail", d.status(), "disarmed");
d.arm(1);
check("armed", d.status(), "armed");
d.takeoff(5.0);
check("taking off", d.status(), "taking_off");

let i = 0;
while (i < 10) {
    d.tick();
    if (d.status() === "hovering") break;
    i = i + 1;
}
check("hovering", d.status(), "hovering");
checkAlt("at altitude", d.altitude(), 5.0);

d.set_mission(1);
check("on mission", d.status(), "on_mission");
d.mission_complete();
check("back to hovering", d.status(), "hovering");

d.land();
check("landing", d.status(), "landing");
d.touchdown();
check("back to armed", d.status(), "armed");

const d2 = @@DroneFlightMode();
d2.arm(1);
d2.takeoff(100.0);
d2.battery_critical();
check("battery -> emergency", d2.status(), "emergency_land");
check("battery reason", d2.failsafe_reason(), "battery");

const d3 = @@DroneFlightMode();
d3.arm(1);
d3.takeoff(5.0);
i = 0;
while (i < 10) {
    d3.tick();
    if (d3.status() === "hovering") break;
    i = i + 1;
}
d3.rc_lost();
check("rc lost -> returning", d3.status(), "returning");
d3.home_reached();
check("home reached -> landing", d3.status(), "landing");

const d4 = @@DroneFlightMode();
d4.arm(1);
d4.takeoff(5.0);
i = 0;
while (i < 10) {
    d4.tick();
    if (d4.status() === "hovering") break;
    i = i + 1;
}
d4.set_mission(1);
d4.gps_lost();
check("gps lost -> altitude hold", d4.status(), "altitude_hold");

const d5 = @@DroneFlightMode();
d5.arm(1);
d5.takeoff(5.0);
i = 0;
while (i < 10) {
    d5.tick();
    if (d5.status() === "hovering") break;
    i = i + 1;
}
d5.set_mission(1);
d5.geofence_breach();
check("geofence -> returning", d5.status(), "returning");
check("geofence reason", d5.failsafe_reason(), "geofence");

const d6 = @@DroneFlightMode();
d6.battery_critical();
d6.rc_lost();
d6.gps_lost();
d6.geofence_breach();
check("disarmed ignores failsafes", d6.status(), "disarmed");

console.log("PASS: drone_flight");

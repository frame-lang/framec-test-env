@@[target("cpp")]

// Cookbook 107: Mission Controller (BT-alternative)

@@system MissionController {
    interface:
        start_mission(mission_id: string, site_count: int)
        arrived_at_site()
        inspection_complete()
        inspection_failed()
        report_sent()
        docked()
        abort()
        tick()
        status(): string
        get_site(): int
        get_total(): int
        get_retries(): int

    machine:
        $Idle {
            start_mission(mission_id: string, site_count: int) {
                this->mission_id = mission_id;
                this->site_total = site_count;
                this->site_index = 0;
                this->findings_count = 0;
                this->inspection_retries = 0;
                -> $TravelingToSite
            }
            status(): string { @@:("idle") }
            get_site(): int { @@:(this->site_index) }
            get_total(): int { @@:(this->site_total) }
            get_retries(): int { @@:(this->inspection_retries) }
        }

        $Mission {
            abort() { -> $ReturningToDock }
            get_site(): int { @@:(this->site_index) }
            get_total(): int { @@:(this->site_total) }
            get_retries(): int { @@:(this->inspection_retries) }
        }

        $TravelingToSite => $Mission {
            $>() {
                if (this->site_index >= this->site_total) {
                    -> $ReturningToDock
                }
            }
            arrived_at_site() { -> $Inspecting }
            status(): string { @@:("traveling") }
            => $^
        }

        $Inspecting => $Mission {
            $>() { this->inspection_retries = this->inspection_retries + 1; }
            inspection_complete() {
                this->findings_count = this->findings_count + 1;
                this->inspection_retries = 0;
                this->site_index = this->site_index + 1;
                -> $TravelingToSite
            }
            inspection_failed() {
                if (this->inspection_retries >= this->max_inspection_retries) {
                    this->inspection_retries = 0;
                    this->site_index = this->site_index + 1;
                    -> $TravelingToSite
                } else {
                    -> $Inspecting
                }
            }
            status(): string { @@:("inspecting") }
            => $^
        }

        $ReturningToDock => $Mission {
            docked() { -> $SendingReport }
            status(): string { @@:("returning") }
            => $^
        }

        $SendingReport => $Mission {
            report_sent() { -> $Idle }
            status(): string { @@:("sending_report") }
            => $^
        }

    domain:
        mission_id: string = ""
        site_total: int = 0
        site_index: int = 0
        findings_count: int = 0
        inspection_retries: int = 0
        max_inspection_retries: int = 3
}

#include <iostream>
#include <cstdlib>

static void check_str(const std::string& label, const std::string& actual, const std::string& expected) {
    if (actual != expected) {
        std::cout << "FAIL: " << label << " expected '" << expected << "', got '" << actual << "'\n";
        std::exit(1);
    }
}
static void check_int(const std::string& label, int actual, int expected) {
    if (actual != expected) {
        std::cout << "FAIL: " << label << " expected " << expected << ", got " << actual << "\n";
        std::exit(1);
    }
}

int main() {
    auto m = @@MissionController();
    check_str("idle", m.status(), "idle");

    m.start_mission("M-1", 3);
    check_str("traveling", m.status(), "traveling");
    check_int("site 0", m.get_site(), 0);
    check_int("3 total", m.get_total(), 3);

    m.arrived_at_site();
    check_str("inspecting", m.status(), "inspecting");
    check_int("attempt 1", m.get_retries(), 1);
    m.inspection_complete();
    check_int("advancing", m.get_site(), 1);
    check_str("back to traveling", m.status(), "traveling");
    check_int("retries reset", m.get_retries(), 0);

    m.arrived_at_site();
    m.inspection_failed();
    check_str("retry same site", m.status(), "inspecting");
    check_int("still site 1", m.get_site(), 1);
    check_int("attempt 2", m.get_retries(), 2);
    m.inspection_complete();
    check_int("site 2 done", m.get_site(), 2);

    m.arrived_at_site();
    m.inspection_failed();
    m.inspection_failed();
    m.inspection_failed();
    check_int("skipped site after max retries", m.get_site(), 3);

    m.arrived_at_site();
    check_str("returning to dock", m.status(), "returning");

    m.docked();
    check_str("sending report", m.status(), "sending_report");

    m.report_sent();
    check_str("back to idle", m.status(), "idle");

    auto m2 = @@MissionController();
    m2.start_mission("M-2", 5);
    m2.arrived_at_site();
    m2.abort();
    check_str("abort -> returning", m2.status(), "returning");
    m2.docked();
    m2.report_sent();
    check_str("abort completes to idle", m2.status(), "idle");

    std::cout << "PASS: mission_controller\n";
    return 0;
}

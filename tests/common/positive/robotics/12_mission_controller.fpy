@@[target("python_3")]

# Cookbook 107: Mission Controller (BT-alternative)
# Simplified: site list modelled as a count (instead of list).
# Each site inspection has a retry budget. Full tour ends at
# ReturningToDock -> Idle.

@@system MissionController {
    interface:
        start_mission(mission_id: str, site_count: int)
        arrived_at_site()
        inspection_complete()
        inspection_failed()
        report_sent()
        docked()
        abort()
        tick()
        status(): str
        get_site(): int
        get_total(): int
        get_retries(): int

    machine:
        $Idle {
            start_mission(mission_id: str, site_count: int) {
                self.mission_id = mission_id
                self.site_total = site_count
                self.site_index = 0
                self.findings_count = 0
                self.inspection_retries = 0
                -> $TravelingToSite
            }
            status(): str { @@:("idle") }
            get_site(): int { @@:(self.site_index) }
            get_total(): int { @@:(self.site_total) }
            get_retries(): int { @@:(self.inspection_retries) }
        }

        $Mission {
            abort() { -> $ReturningToDock }
            get_site(): int { @@:(self.site_index) }
            get_total(): int { @@:(self.site_total) }
            get_retries(): int { @@:(self.inspection_retries) }
        }

        $TravelingToSite => $Mission {
            $>() {
                if self.site_index >= self.site_total:
                    -> $ReturningToDock
            }
            arrived_at_site() { -> $Inspecting }
            status(): str { @@:("traveling") }
            => $^
        }

        $Inspecting => $Mission {
            $>() { self.inspection_retries = self.inspection_retries + 1 }
            inspection_complete() {
                self.findings_count = self.findings_count + 1
                self.inspection_retries = 0
                self.site_index = self.site_index + 1
                -> $TravelingToSite
            }
            inspection_failed() {
                if self.inspection_retries >= self.max_inspection_retries:
                    self.inspection_retries = 0
                    self.site_index = self.site_index + 1
                    -> $TravelingToSite
                else:
                    -> $Inspecting
            }
            status(): str { @@:("inspecting") }
            => $^
        }

        $ReturningToDock => $Mission {
            docked() { -> $SendingReport }
            status(): str { @@:("returning") }
            => $^
        }

        $SendingReport => $Mission {
            report_sent() { -> $Idle }
            status(): str { @@:("sending_report") }
            => $^
        }

    domain:
        mission_id: str = ""
        site_total: int = 0
        site_index: int = 0
        findings_count: int = 0
        inspection_retries: int = 0
        max_inspection_retries: int = 3
}


def check(label, actual, expected):
    if actual != expected:
        print(f"FAIL: {label} expected '{expected}', got '{actual}'")
        import sys
        sys.exit(1)


if __name__ == '__main__':
    m = @@MissionController()
    check("idle", m.status(), "idle")

    # 3-site mission
    m.start_mission("M-1", 3)
    check("traveling", m.status(), "traveling")
    check("site 0", m.get_site(), 0)
    check("3 total", m.get_total(), 3)

    # Site 1 happy path
    m.arrived_at_site()
    check("inspecting", m.status(), "inspecting")
    check("attempt 1", m.get_retries(), 1)
    m.inspection_complete()
    check("advancing", m.get_site(), 1)
    check("back to traveling", m.status(), "traveling")
    check("retries reset", m.get_retries(), 0)

    # Site 2 with one failure then success
    m.arrived_at_site()
    m.inspection_failed()
    check("retry same site", m.status(), "inspecting")
    check("still site 1", m.get_site(), 1)
    check("attempt 2", m.get_retries(), 2)
    m.inspection_complete()
    check("site 2 done", m.get_site(), 2)

    # Site 3 with all failures -> skip site
    m.arrived_at_site()
    m.inspection_failed()
    m.inspection_failed()
    m.inspection_failed()  # hits max -> advance
    check("skipped site after max retries", m.get_site(), 3)

    # Next travel: site_index == total -> ReturningToDock
    m.arrived_at_site()   # but actually after exhaustion we're in traveling...
    # traveling's $>() checked if site_index >= total, transitioned to returning
    # Already in Returning state
    check("returning to dock", m.status(), "returning")

    m.docked()
    check("sending report", m.status(), "sending_report")

    m.report_sent()
    check("back to idle", m.status(), "idle")

    # Abort from any mission state
    m2 = @@MissionController()
    m2.start_mission("M-2", 5)
    m2.arrived_at_site()
    m2.abort()
    check("abort -> returning", m2.status(), "returning")
    m2.docked()
    m2.report_sent()
    check("abort completes to idle", m2.status(), "idle")

    print("PASS: mission_controller")

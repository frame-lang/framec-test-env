@@target python_3

# Cookbook 103: Multi-Floor Delivery Robot
# Simplified: just the DeliveryRobot state machine (the elevator it
# calls is tested in primary/52_elevator). Key structural property:
# Approaching -> Requesting -> Waiting -> Boarding -> Riding -> Exiting
# -> Traveling -> Dropping -> Idle. Each step only advances via its
# expected event.

@@system DeliveryRobot {
    interface:
        deliver(from_floor: int, to_floor: int)
        at_elevator()
        car_arrived()
        boarded()
        at_destination_floor()
        exited()
        dropped_off()
        status(): str
        pickup_floor(): int
        drop_floor(): int

    machine:
        $Idle {
            deliver(from_floor: int, to_floor: int) {
                self.pickup = from_floor
                self.dropoff = to_floor
                -> $Approaching
            }
            status(): str { @@:("idle") }
            pickup_floor(): int { @@:(self.pickup) }
            drop_floor(): int { @@:(self.dropoff) }
        }

        $Approaching {
            at_elevator() { -> $Boarding }
            status(): str { @@:("approaching") }
            pickup_floor(): int { @@:(self.pickup) }
            drop_floor(): int { @@:(self.dropoff) }
        }

        $Boarding {
            boarded() { -> $Riding }
            status(): str { @@:("boarding") }
            pickup_floor(): int { @@:(self.pickup) }
            drop_floor(): int { @@:(self.dropoff) }
        }

        $Riding {
            at_destination_floor() { -> $Exiting }
            status(): str { @@:("riding") }
            pickup_floor(): int { @@:(self.pickup) }
            drop_floor(): int { @@:(self.dropoff) }
        }

        $Exiting {
            exited() { -> $Dropping }
            status(): str { @@:("exiting") }
            pickup_floor(): int { @@:(self.pickup) }
            drop_floor(): int { @@:(self.dropoff) }
        }

        $Dropping {
            dropped_off() { -> $Idle }
            status(): str { @@:("dropping") }
            pickup_floor(): int { @@:(self.pickup) }
            drop_floor(): int { @@:(self.dropoff) }
        }

    domain:
        pickup: int = 0
        dropoff: int = 0
}


def check(label, actual, expected):
    if actual != expected:
        print(f"FAIL: {label} expected '{expected}', got '{actual}'")
        import sys
        sys.exit(1)


if __name__ == '__main__':
    r = @@DeliveryRobot()
    check("idle", r.status(), "idle")

    r.deliver(1, 5)
    check("approaching", r.status(), "approaching")
    check("pickup stored", r.pickup_floor(), 1)
    check("drop stored", r.drop_floor(), 5)

    # Strict event ordering — out-of-order events absorbed
    r.boarded()
    check("approaching absorbs boarded", r.status(), "approaching")
    r.exited()
    check("approaching absorbs exited", r.status(), "approaching")

    r.at_elevator()
    check("boarding", r.status(), "boarding")

    r.boarded()
    check("riding", r.status(), "riding")

    r.at_destination_floor()
    check("exiting", r.status(), "exiting")

    r.exited()
    check("dropping", r.status(), "dropping")

    r.dropped_off()
    check("idle again", r.status(), "idle")

    # Second delivery from the freshly idle robot
    r.deliver(5, 1)
    check("second pickup", r.pickup_floor(), 5)
    check("second drop", r.drop_floor(), 1)

    # Stray events in Idle absorbed
    r2 = @@DeliveryRobot()
    r2.at_elevator()
    r2.boarded()
    r2.dropped_off()
    check("idle absorbs all", r2.status(), "idle")

    print("PASS: delivery_robot")

@@[target("csharp")]

// Cookbook 103: Multi-Floor Delivery Robot

@@system DeliveryRobot {
    interface:
        deliver(from_floor: int, to_floor: int)
        at_elevator()
        car_arrived()
        boarded()
        at_destination_floor()
        exited()
        dropped_off()
        status(): string
        pickup_floor(): int
        drop_floor(): int

    machine:
        $Idle {
            deliver(from_floor: int, to_floor: int) {
                this.pickup = from_floor;
                this.dropoff = to_floor;
                -> $Approaching
            }
            status(): string { @@:("idle") }
            pickup_floor(): int { @@:(this.pickup) }
            drop_floor(): int { @@:(this.dropoff) }
        }
        $Approaching {
            at_elevator() { -> $Boarding }
            status(): string { @@:("approaching") }
            pickup_floor(): int { @@:(this.pickup) }
            drop_floor(): int { @@:(this.dropoff) }
        }
        $Boarding {
            boarded() { -> $Riding }
            status(): string { @@:("boarding") }
            pickup_floor(): int { @@:(this.pickup) }
            drop_floor(): int { @@:(this.dropoff) }
        }
        $Riding {
            at_destination_floor() { -> $Exiting }
            status(): string { @@:("riding") }
            pickup_floor(): int { @@:(this.pickup) }
            drop_floor(): int { @@:(this.dropoff) }
        }
        $Exiting {
            exited() { -> $Dropping }
            status(): string { @@:("exiting") }
            pickup_floor(): int { @@:(this.pickup) }
            drop_floor(): int { @@:(this.dropoff) }
        }
        $Dropping {
            dropped_off() { -> $Idle }
            status(): string { @@:("dropping") }
            pickup_floor(): int { @@:(this.pickup) }
            drop_floor(): int { @@:(this.dropoff) }
        }
    domain:
        pickup: int = 0
        dropoff: int = 0
}

class Program {
    static void CheckStr(string label, string actual, string expected) {
        if (actual != expected) {
            System.Console.WriteLine($"FAIL: {label} expected '{expected}', got '{actual}'");
            System.Environment.Exit(1);
        }
    }
    static void CheckInt(string label, int actual, int expected) {
        if (actual != expected) {
            System.Console.WriteLine($"FAIL: {label} expected {expected}, got {actual}");
            System.Environment.Exit(1);
        }
    }
    public static void Main(string[] args) {
        var r = @@DeliveryRobot();
        CheckStr("idle", r.status(), "idle");
        r.deliver(1, 5);
        CheckStr("approaching", r.status(), "approaching");
        CheckInt("pickup stored", r.pickup_floor(), 1);
        CheckInt("drop stored", r.drop_floor(), 5);
        r.boarded();
        CheckStr("approaching absorbs boarded", r.status(), "approaching");
        r.exited();
        CheckStr("approaching absorbs exited", r.status(), "approaching");
        r.at_elevator();
        CheckStr("boarding", r.status(), "boarding");
        r.boarded();
        CheckStr("riding", r.status(), "riding");
        r.at_destination_floor();
        CheckStr("exiting", r.status(), "exiting");
        r.exited();
        CheckStr("dropping", r.status(), "dropping");
        r.dropped_off();
        CheckStr("idle again", r.status(), "idle");
        r.deliver(5, 1);
        CheckInt("second pickup", r.pickup_floor(), 5);
        CheckInt("second drop", r.drop_floor(), 1);
        var r2 = @@DeliveryRobot();
        r2.at_elevator();
        r2.boarded();
        r2.dropped_off();
        CheckStr("idle absorbs all", r2.status(), "idle");
        System.Console.WriteLine("PASS: delivery_robot");
    }
}

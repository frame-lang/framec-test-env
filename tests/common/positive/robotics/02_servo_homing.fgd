@@[target("gdscript")]

# Cookbook 97: Servo Homing Sequence

@@system ServoHoming : RefCounted {
    interface:
        home()
        tick()
        limit_hit()
        index_pulse()
        fault(reason: String)
        status(): String
        get_attempts(): int

    machine:
        $Unhomed {
            home() {
                self.attempts = 0
                -> $SeekingLimit
            }
            status(): String { @@:("unhomed") }
            get_attempts(): int { @@:(self.attempts) }
        }

        $Active {
            get_attempts(): int { @@:(self.attempts) }
        }

        $Homing => $Active {
            fault(reason: String) {
                self.fault_reason = reason
                -> $Fault
            }
            => $^
        }

        $SeekingLimit => $Homing {
            $>() {
                self.attempts = self.attempts + 1
                self.travel = 0
            }

            tick() {
                self.travel = self.travel + self.seek_speed
                if self.travel > self.max_travel:
                    if self.attempts >= self.max_attempts:
                        @@:self.fault("limit not found")
                    else:
                        -> $SeekingLimit
            }

            limit_hit() { -> $BackingOff }

            status(): String { @@:("seeking limit") }
            => $^
        }

        $BackingOff => $Homing {
            $>() {
                self.backoff_remaining = self.backoff_distance
            }

            tick() {
                self.backoff_remaining = self.backoff_remaining - self.seek_speed
                if self.backoff_remaining <= 0:
                    -> $FindingIndex
            }

            status(): String { @@:("backing off") }
            => $^
        }

        $FindingIndex => $Homing {
            $>() { self.index_travel = 0 }

            tick() {
                self.index_travel = self.index_travel + self.index_speed
                if self.index_travel > self.index_window:
                    @@:self.fault("index pulse missing")
            }

            index_pulse() {
                self.position = 0
                -> $Homed
            }

            status(): String { @@:("finding index") }
            => $^
        }

        $Homed {
            home() {
                self.attempts = 0
                -> $SeekingLimit
            }
            status(): String { @@:("homed") }
            get_attempts(): int { @@:(self.attempts) }
        }

        $Fault {
            home() {
                self.attempts = 0
                self.fault_reason = ""
                -> $SeekingLimit
            }
            status(): String { @@:("fault") }
            get_attempts(): int { @@:(self.attempts) }
        }

    domain:
        attempts: int = 0
        max_attempts: int = 3
        travel: int = 0
        max_travel: int = 100
        backoff_remaining: int = 0
        backoff_distance: int = 10
        index_travel: int = 0
        index_window: int = 30
        seek_speed: int = 5
        index_speed: int = 1
        position: int = 0
        fault_reason: String = ""
}


func check_str(label: String, actual: String, expected: String) -> void:
    if actual != expected:
        print("FAIL: %s expected '%s', got '%s'" % [label, expected, actual])
        quit(1)
func check_int(label: String, actual: int, expected: int) -> void:
    if actual != expected:
        print("FAIL: %s expected %d, got %d" % [label, expected, actual])
        quit(1)

func _init() -> void:
    var s = @@ServoHoming()
    check_str("unhomed", s.status(), "unhomed")

    s.home()
    check_str("seeking limit", s.status(), "seeking limit")
    check_int("1 attempt", s.get_attempts(), 1)

    for i in range(3):
        s.tick()
    s.limit_hit()
    check_str("backing off", s.status(), "backing off")

    s.tick()
    s.tick()
    check_str("finding index", s.status(), "finding index")

    s.index_pulse()
    check_str("homed", s.status(), "homed")

    s.home()
    check_str("re-homing from homed", s.status(), "seeking limit")
    check_int("attempts reset on re-home", s.get_attempts(), 1)

    var s2 = @@ServoHoming()
    s2.home()
    for i in range(21):
        s2.tick()
    check_str("retry after overtravel", s2.status(), "seeking limit")
    check_int("retry attempt 2", s2.get_attempts(), 2)

    for i in range(21):
        s2.tick()
    check_int("retry 3", s2.get_attempts(), 3)

    for i in range(21):
        s2.tick()
    check_str("fault after max attempts", s2.status(), "fault")

    s2.home()
    check_str("fault cleared by home", s2.status(), "seeking limit")
    check_int("attempts reset on clear", s2.get_attempts(), 1)

    var s3 = @@ServoHoming()
    s3.home()
    s3.limit_hit()
    s3.tick(); s3.tick()
    check_str("in find index", s3.status(), "finding index")

    for i in range(31):
        s3.tick()
    check_str("index missing -> fault", s3.status(), "fault")

    var s4 = @@ServoHoming()
    s4.limit_hit()
    check_str("unhomed absorbs limit_hit", s4.status(), "unhomed")
    s4.index_pulse()
    check_str("unhomed absorbs index_pulse", s4.status(), "unhomed")

    print("PASS: servo_homing")
    quit()

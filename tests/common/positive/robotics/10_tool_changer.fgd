@@[target("gdscript")]

# Cookbook 105: Tool Changer — Interlocked Coupling Sequence

@@system ToolChanger : RefCounted {
    interface:
        request_couple(tool_id: String)
        request_uncouple()
        lock_confirmed()
        lock_lost()
        tool_energized()
        tool_deenergized()
        abort()
        status(): String
        is_energized(): int
        attached_tool(): String

    machine:
        $NoTool {
            request_couple(tool_id: String) {
                self.tool_id = tool_id
                -> $Approaching
            }
            request_uncouple() { }
            status(): String { @@:("no_tool") }
            is_energized(): int { @@:(self.energized) }
            attached_tool(): String { @@:(self.tool_id) }
        }

        $Transitioning {
            is_energized(): int { @@:(self.energized) }
            attached_tool(): String { @@:(self.tool_id) }
        }

        $Coupling => $Transitioning {
            lock_lost() {
                self.tool_id = ""
                -> $NoTool
            }
            => $^
        }

        $Approaching => $Coupling {
            lock_confirmed() { -> $Coupled }
            abort() {
                self.tool_id = ""
                -> $NoTool
            }
            status(): String { @@:("approaching") }
            => $^
        }

        $Coupled {
            tool_energized() {
                self.energized = 1
                -> $Working
            }
            request_uncouple() { -> $Uncoupling }
            lock_lost() { -> $Fault }
            status(): String { @@:("coupled") }
            is_energized(): int { @@:(self.energized) }
            attached_tool(): String { @@:(self.tool_id) }
        }

        $Working {
            tool_deenergized() {
                self.energized = 0
                -> $Coupled
            }
            lock_lost() {
                self.energized = 0
                -> $Fault
            }
            status(): String { @@:("working") }
            is_energized(): int { @@:(self.energized) }
            attached_tool(): String { @@:(self.tool_id) }
        }

        $Uncoupling => $Transitioning {
            lock_lost() {
                self.tool_id = ""
                -> $NoTool
            }
            status(): String { @@:("uncoupling") }
            => $^
        }

        $Fault {
            abort() {
                self.tool_id = ""
                self.energized = 0
                -> $NoTool
            }
            status(): String { @@:("fault") }
            is_energized(): int { @@:(self.energized) }
            attached_tool(): String { @@:(self.tool_id) }
        }

    domain:
        tool_id: String = ""
        energized: int = 0
}


func check_str(label: String, actual: String, expected: String) -> void:
    if actual != expected:
        print("FAIL: %s expected '%s', got '%s'" % [label, expected, actual])
        quit(1)
func check_int(label: String, actual: int, expected: int) -> void:
    if actual != expected:
        print("FAIL: %s expected %d, got %d" % [label, expected, actual])
        quit(1)

func _init() -> void:
    var tc = @@ToolChanger()
    check_str("no tool", tc.status(), "no_tool")
    check_str("no tool stored", tc.attached_tool(), "")
    check_int("not energized", tc.is_energized(), 0)

    tc.request_couple("drill_8mm")
    check_str("approaching", tc.status(), "approaching")
    check_str("tool captured", tc.attached_tool(), "drill_8mm")

    tc.lock_confirmed()
    check_str("coupled", tc.status(), "coupled")

    tc.tool_energized()
    check_str("working", tc.status(), "working")
    check_int("energized", tc.is_energized(), 1)

    tc.request_uncouple()
    check_str("working absorbs uncouple", tc.status(), "working")
    check_str("still attached", tc.attached_tool(), "drill_8mm")
    check_int("still energized", tc.is_energized(), 1)

    tc.tool_deenergized()
    check_str("coupled de-energized", tc.status(), "coupled")
    check_int("not energized", tc.is_energized(), 0)

    tc.request_uncouple()
    check_str("uncoupling", tc.status(), "uncoupling")

    tc.lock_lost()
    check_str("no tool again", tc.status(), "no_tool")
    check_str("tool cleared", tc.attached_tool(), "")

    var tc2 = @@ToolChanger()
    tc2.request_couple("router")
    tc2.lock_confirmed()
    tc2.lock_lost()
    check_str("lock_lost in coupled -> fault", tc2.status(), "fault")

    var tc3 = @@ToolChanger()
    tc3.request_couple("saw")
    tc3.lock_confirmed()
    tc3.tool_energized()
    tc3.lock_lost()
    check_str("lock_lost in working -> fault", tc3.status(), "fault")
    check_int("fault de-energizes", tc3.is_energized(), 0)

    tc3.abort()
    check_str("abort clears fault", tc3.status(), "no_tool")

    var tc4 = @@ToolChanger()
    tc4.request_couple("probe")
    tc4.abort()
    check_str("abort during approach", tc4.status(), "no_tool")

    var tc5 = @@ToolChanger()
    tc5.request_couple("clamp")
    tc5.lock_lost()
    check_str("lock_lost in approaching -> no_tool", tc5.status(), "no_tool")

    print("PASS: tool_changer")
    quit()

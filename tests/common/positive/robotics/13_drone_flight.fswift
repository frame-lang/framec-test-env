@@[target("swift")]

// Cookbook 108: Drone Flight Modes — Failsafe from Any Phase

import Foundation

@@system DroneFlightMode {
    interface:
        arm(preflight_ok: Int)
        takeoff(altitude: Double)
        set_mission(waypoints_ok: Int)
        return_to_home()
        land()
        disarm()
        takeoff_complete()
        mission_complete()
        home_reached()
        touchdown()
        battery_critical()
        gps_lost()
        rc_lost()
        geofence_breach()
        tick()
        status(): String
        altitude(): Double
        failsafe_reason(): String

    machine:
        $Disarmed {
            arm(preflight_ok: Int) {
                if preflight_ok == 1 {
                    -> $Armed
                }
            }
            status(): String { @@:("disarmed") }
            altitude(): Double { @@:(self.current_altitude) }
            failsafe_reason(): String { @@:(self.reason) }
        }

        $Armed {
            takeoff(altitude: Double) {
                self.target_altitude = altitude
                -> $TakingOff
            }
            disarm() { -> $Disarmed }
            status(): String { @@:("armed") }
            altitude(): Double { @@:(self.current_altitude) }
            failsafe_reason(): String { @@:(self.reason) }
        }

        $Flying {
            altitude(): Double { @@:(self.current_altitude) }
            failsafe_reason(): String { @@:(self.reason) }
        }

        $InFlight => $Flying {
            battery_critical() {
                self.reason = "battery"
                -> $EmergencyLand
            }
            rc_lost() {
                self.reason = "rc_lost"
                -> $ReturningHome
            }
            gps_lost() {
                self.reason = "gps_lost"
                -> $AltitudeHold
            }
            geofence_breach() {
                self.reason = "geofence"
                -> $ReturningHome
            }
            => $^
        }

        $TakingOff => $InFlight {
            $>() { self.current_altitude = 0.0 }
            tick() {
                self.current_altitude = self.current_altitude + 1.0
                if self.current_altitude >= self.target_altitude {
                    @@:self.takeoff_complete()
                }
            }
            takeoff_complete() { -> $Hovering }
            status(): String { @@:("taking_off") }
            => $^
        }

        $Hovering => $InFlight {
            set_mission(waypoints_ok: Int) {
                if waypoints_ok == 1 {
                    -> $OnMission
                }
            }
            land() { -> $Landing }
            return_to_home() { -> $ReturningHome }
            status(): String { @@:("hovering") }
            => $^
        }

        $OnMission => $InFlight {
            mission_complete() { -> $Hovering }
            return_to_home() { -> $ReturningHome }
            status(): String { @@:("on_mission") }
            => $^
        }

        $ReturningHome => $InFlight {
            home_reached() { -> $Landing }
            status(): String { @@:("returning") }
            => $^
        }

        $AltitudeHold => $InFlight {
            status(): String { @@:("altitude_hold") }
            => $^
        }

        $Landing {
            touchdown() {
                self.current_altitude = 0.0
                -> $Armed
            }
            status(): String { @@:("landing") }
            altitude(): Double { @@:(self.current_altitude) }
            failsafe_reason(): String { @@:(self.reason) }
        }

        $EmergencyLand {
            touchdown() {
                self.current_altitude = 0.0
                -> $Armed
            }
            status(): String { @@:("emergency_land") }
            altitude(): Double { @@:(self.current_altitude) }
            failsafe_reason(): String { @@:(self.reason) }
        }

    domain:
        target_altitude: Double = 0.0
        current_altitude: Double = 0.0
        reason: String = ""
}

func check(_ label: String, _ actual: String, _ expected: String) {
    if actual != expected {
        print("FAIL: \(label) expected '\(expected)', got '\(actual)'")
        exit(1)
    }
}
func checkDouble(_ label: String, _ actual: Double, _ expected: Double) {
    if abs(actual - expected) > 1e-6 {
        print("FAIL: \(label) expected \(expected), got \(actual)")
        exit(1)
    }
}

let d = @@DroneFlightMode()
check("disarmed", d.status() as! String, "disarmed")
d.arm(preflight_ok: 0)
check("preflight fail", d.status() as! String, "disarmed")
d.arm(preflight_ok: 1)
check("armed", d.status() as! String, "armed")
d.takeoff(altitude: 5.0)
check("taking off", d.status() as! String, "taking_off")

var i = 0
while i < 10 {
    d.tick()
    if (d.status() as! String) == "hovering" { break }
    i = i + 1
}
check("hovering", d.status() as! String, "hovering")
checkDouble("at altitude", d.altitude() as! Double, 5.0)

d.set_mission(waypoints_ok: 1)
check("on mission", d.status() as! String, "on_mission")
d.mission_complete()
check("back to hovering", d.status() as! String, "hovering")

d.land()
check("landing", d.status() as! String, "landing")
d.touchdown()
check("back to armed", d.status() as! String, "armed")

let d2 = @@DroneFlightMode()
d2.arm(preflight_ok: 1)
d2.takeoff(altitude: 100.0)
d2.battery_critical()
check("battery -> emergency", d2.status() as! String, "emergency_land")
check("battery reason", d2.failsafe_reason() as! String, "battery")

let d3 = @@DroneFlightMode()
d3.arm(preflight_ok: 1)
d3.takeoff(altitude: 5.0)
i = 0
while i < 10 {
    d3.tick()
    if (d3.status() as! String) == "hovering" { break }
    i = i + 1
}
d3.rc_lost()
check("rc lost -> returning", d3.status() as! String, "returning")
d3.home_reached()
check("home reached -> landing", d3.status() as! String, "landing")

let d4 = @@DroneFlightMode()
d4.arm(preflight_ok: 1)
d4.takeoff(altitude: 5.0)
i = 0
while i < 10 {
    d4.tick()
    if (d4.status() as! String) == "hovering" { break }
    i = i + 1
}
d4.set_mission(waypoints_ok: 1)
d4.gps_lost()
check("gps lost -> altitude hold", d4.status() as! String, "altitude_hold")

let d5 = @@DroneFlightMode()
d5.arm(preflight_ok: 1)
d5.takeoff(altitude: 5.0)
i = 0
while i < 10 {
    d5.tick()
    if (d5.status() as! String) == "hovering" { break }
    i = i + 1
}
d5.set_mission(waypoints_ok: 1)
d5.geofence_breach()
check("geofence -> returning", d5.status() as! String, "returning")
check("geofence reason", d5.failsafe_reason() as! String, "geofence")

let d6 = @@DroneFlightMode()
d6.battery_critical()
d6.rc_lost()
d6.gps_lost()
d6.geofence_breach()
check("disarmed ignores failsafes", d6.status() as! String, "disarmed")

print("PASS: drone_flight")

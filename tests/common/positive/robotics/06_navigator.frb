@@[target("ruby")]

# Cookbook 101: Go-To-Goal with Obstacle Avoidance

@@system Navigator {
    interface:
        navigate_to(goal_x, goal_y)
        tick(obstacle_distance, at_goal)
        plan_ready(path_len)
        plan_failed()
        abort()
        status()
        get_replans()
        get_path_index()

    machine:
        $Idle {
            navigate_to(goal_x, goal_y) {
                @goal_x = goal_x
                @goal_y = goal_y
                @replan_count = 0
                -> $Planning
            }
            status() { @@:("idle") }
            get_replans() { @@:(@replan_count) }
            get_path_index() { @@:(@path_index) }
        }

        $Active {
            get_replans() { @@:(@replan_count) }
            get_path_index() { @@:(@path_index) }
        }

        $Mission => $Active {
            abort() { -> $Idle }
            => $^
        }

        $Planning => $Mission {
            plan_ready(path_len) {
                if path_len == 0
                    @@:self.plan_failed()
                else
                    @path_len = path_len
                    @path_index = 0
                    -> $Driving
                end
            }
            plan_failed() {
                @replan_count = @replan_count + 1
                if @replan_count >= @max_replans
                    -> $Failed
                else
                    -> $Planning
                end
            }
            status() { @@:("planning") }
            => $^
        }

        $Driving => $Mission {
            tick(obstacle_distance, at_goal) {
                if at_goal == 1
                    -> $Arrived
                elsif obstacle_distance < @obstacle_threshold
                    -> $Avoiding
                else
                    @path_index = @path_index + 1
                    if @path_index >= @path_len
                        -> $Planning
                    end
                end
            }
            status() { @@:("driving") }
            => $^
        }

        $Avoiding => $Mission {
            $>() { @avoid_ticks = 0 }
            tick(obstacle_distance, at_goal) {
                @avoid_ticks = @avoid_ticks + 1
                if obstacle_distance >= @obstacle_threshold
                    -> $Planning
                elsif @avoid_ticks > @max_avoid_ticks
                    -> $Failed
                end
            }
            status() { @@:("avoiding") }
            => $^
        }

        $Arrived {
            navigate_to(goal_x, goal_y) {
                @goal_x = goal_x
                @goal_y = goal_y
                @replan_count = 0
                -> $Planning
            }
            status() { @@:("arrived") }
            get_replans() { @@:(@replan_count) }
            get_path_index() { @@:(@path_index) }
        }

        $Failed {
            navigate_to(goal_x, goal_y) {
                @goal_x = goal_x
                @goal_y = goal_y
                @replan_count = 0
                -> $Planning
            }
            status() { @@:("failed") }
            get_replans() { @@:(@replan_count) }
            get_path_index() { @@:(@path_index) }
        }

    domain:
        goal_x = 0.0
        goal_y = 0.0
        path_len = 0
        path_index = 0
        replan_count = 0
        max_replans = 3
        obstacle_threshold = 0.5
        avoid_ticks = 0
        max_avoid_ticks = 30
}

def check(label, actual, expected)
    if actual != expected
        puts "FAIL: #{label} expected '#{expected}', got '#{actual}'"
        exit(1)
    end
end

n = @@Navigator()
check("idle", n.status, "idle")
n.navigate_to(5.0, 0.0)
check("planning", n.status, "planning")
n.plan_ready(3)
check("driving", n.status, "driving")
n.tick(10.0, 0)
check("still driving 1", n.status, "driving")
n.tick(10.0, 0)
check("still driving 2", n.status, "driving")
n.tick(10.0, 1)
check("arrived", n.status, "arrived")

n2 = @@Navigator()
n2.navigate_to(5.0, 0.0)
n2.plan_failed
check("re-planning", n2.status, "planning")
check("1 replan", n2.get_replans, 1)
n2.plan_failed
check("2 replans", n2.get_replans, 2)
n2.plan_failed
check("exceeded -> failed", n2.status, "failed")

n3 = @@Navigator()
n3.navigate_to(5.0, 0.0)
n3.plan_ready(0)
check("empty plan -> re-planning", n3.status, "planning")
check("empty counted as failure", n3.get_replans, 1)

n4 = @@Navigator()
n4.navigate_to(5.0, 0.0)
n4.plan_ready(5)
n4.tick(10.0, 0)
n4.tick(0.3, 0)
check("avoiding", n4.status, "avoiding")
n4.tick(10.0, 0)
check("cleared -> planning (freshness)", n4.status, "planning")

n5 = @@Navigator()
n5.navigate_to(5.0, 0.0)
n5.plan_ready(5)
n5.tick(0.3, 0)
check("avoiding start", n5.status, "avoiding")
i = 0
while i < 35
    n5.tick(0.3, 0)
    break if n5.status == "failed"
    i = i + 1
end
check("trapped -> failed", n5.status, "failed")

n6 = @@Navigator()
n6.navigate_to(5.0, 0.0)
n6.plan_ready(2)
n6.tick(10.0, 0)
n6.tick(10.0, 0)
check("exhausted -> replan", n6.status, "planning")

n7 = @@Navigator()
n7.navigate_to(5.0, 0.0)
n7.plan_ready(3)
n7.abort
check("aborted -> idle", n7.status, "idle")

n8 = @@Navigator()
n8.navigate_to(5.0, 0.0)
n8.plan_ready(5)
n8.tick(0.3, 0)
n8.abort
check("abort from avoiding", n8.status, "idle")

n2.navigate_to(10.0, 0.0)
check("re-navigate from failed", n2.status, "planning")
check("replan counter reset", n2.get_replans, 0)

puts "PASS: navigator"

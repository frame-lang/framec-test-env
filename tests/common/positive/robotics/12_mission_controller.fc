@@[target("c")]

// Cookbook 107: Mission Controller (BT-alternative)

@@system MissionController {
    interface:
        start_mission(mission_id: string, site_count: int)
        arrived_at_site()
        inspection_complete()
        inspection_failed()
        report_sent()
        docked()
        abort()
        tick()
        status(): string
        get_site(): int
        get_total(): int
        get_retries(): int

    machine:
        $Idle {
            start_mission(mission_id: string, site_count: int) {
                self->mission_id = mission_id;
                self->site_total = site_count;
                self->site_index = 0;
                self->findings_count = 0;
                self->inspection_retries = 0;
                -> $TravelingToSite
            }
            status(): string { @@:("idle") }
            get_site(): int { @@:(self->site_index) }
            get_total(): int { @@:(self->site_total) }
            get_retries(): int { @@:(self->inspection_retries) }
        }

        $Mission {
            abort() { -> $ReturningToDock }
            get_site(): int { @@:(self->site_index) }
            get_total(): int { @@:(self->site_total) }
            get_retries(): int { @@:(self->inspection_retries) }
        }

        $TravelingToSite => $Mission {
            $>() {
                if (self->site_index >= self->site_total) {
                    -> $ReturningToDock
                }
            }
            arrived_at_site() { -> $Inspecting }
            status(): string { @@:("traveling") }
            => $^
        }

        $Inspecting => $Mission {
            $>() { self->inspection_retries = self->inspection_retries + 1; }
            inspection_complete() {
                self->findings_count = self->findings_count + 1;
                self->inspection_retries = 0;
                self->site_index = self->site_index + 1;
                -> $TravelingToSite
            }
            inspection_failed() {
                if (self->inspection_retries >= self->max_inspection_retries) {
                    self->inspection_retries = 0;
                    self->site_index = self->site_index + 1;
                    -> $TravelingToSite
                } else {
                    -> $Inspecting
                }
            }
            status(): string { @@:("inspecting") }
            => $^
        }

        $ReturningToDock => $Mission {
            docked() { -> $SendingReport }
            status(): string { @@:("returning") }
            => $^
        }

        $SendingReport => $Mission {
            report_sent() { -> $Idle }
            status(): string { @@:("sending_report") }
            => $^
        }

    domain:
        mission_id: string = ""
        site_total: int = 0
        site_index: int = 0
        findings_count: int = 0
        inspection_retries: int = 0
        max_inspection_retries: int = 3
}

#include <stdio.h>
#include <stdlib.h>
#include <string.h>

static void check_str(const char* label, const char* actual, const char* expected) {
    if (strcmp(actual, expected) != 0) {
        printf("FAIL: %s expected '%s', got '%s'\n", label, expected, actual);
        exit(1);
    }
}
static void check_int(const char* label, int actual, int expected) {
    if (actual != expected) {
        printf("FAIL: %s expected %d, got %d\n", label, expected, actual);
        exit(1);
    }
}

int main(void) {
    MissionController* m = @@MissionController();
    check_str("idle", MissionController_status(m), "idle");

    MissionController_start_mission(m, "M-1", 3);
    check_str("traveling", MissionController_status(m), "traveling");
    check_int("site 0", MissionController_get_site(m), 0);
    check_int("3 total", MissionController_get_total(m), 3);

    MissionController_arrived_at_site(m);
    check_str("inspecting", MissionController_status(m), "inspecting");
    check_int("attempt 1", MissionController_get_retries(m), 1);
    MissionController_inspection_complete(m);
    check_int("advancing", MissionController_get_site(m), 1);
    check_str("back to traveling", MissionController_status(m), "traveling");
    check_int("retries reset", MissionController_get_retries(m), 0);

    MissionController_arrived_at_site(m);
    MissionController_inspection_failed(m);
    check_str("retry same site", MissionController_status(m), "inspecting");
    check_int("still site 1", MissionController_get_site(m), 1);
    check_int("attempt 2", MissionController_get_retries(m), 2);
    MissionController_inspection_complete(m);
    check_int("site 2 done", MissionController_get_site(m), 2);

    MissionController_arrived_at_site(m);
    MissionController_inspection_failed(m);
    MissionController_inspection_failed(m);
    MissionController_inspection_failed(m);
    check_int("skipped site after max retries", MissionController_get_site(m), 3);

    MissionController_arrived_at_site(m);
    check_str("returning to dock", MissionController_status(m), "returning");

    MissionController_docked(m);
    check_str("sending report", MissionController_status(m), "sending_report");

    MissionController_report_sent(m);
    check_str("back to idle", MissionController_status(m), "idle");

    MissionController* m2 = @@MissionController();
    MissionController_start_mission(m2, "M-2", 5);
    MissionController_arrived_at_site(m2);
    MissionController_abort(m2);
    check_str("abort -> returning", MissionController_status(m2), "returning");
    MissionController_docked(m2);
    MissionController_report_sent(m2);
    check_str("abort completes to idle", MissionController_status(m2), "idle");

    printf("PASS: mission_controller\n");
    MissionController_destroy(m);
    MissionController_destroy(m2);
    return 0;
}

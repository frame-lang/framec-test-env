@@[target("kotlin")]

// Cookbook 108: Drone Flight Modes — Failsafe from Any Phase

@@system DroneFlightMode {
    interface:
        arm(preflight_ok: Int)
        takeoff(altitude: Double)
        set_mission(waypoints_ok: Int)
        return_to_home()
        land()
        disarm()
        takeoff_complete()
        mission_complete()
        home_reached()
        touchdown()
        battery_critical()
        gps_lost()
        rc_lost()
        geofence_breach()
        tick()
        status(): String
        altitude(): Double
        failsafe_reason(): String

    machine:
        $Disarmed {
            arm(preflight_ok: Int) {
                if (preflight_ok == 1) {
                    -> $Armed
                }
            }
            status(): String { @@:("disarmed") }
            altitude(): Double { @@:(this.current_altitude) }
            failsafe_reason(): String { @@:(this.reason) }
        }

        $Armed {
            takeoff(altitude: Double) {
                this.target_altitude = altitude
                -> $TakingOff
            }
            disarm() { -> $Disarmed }
            status(): String { @@:("armed") }
            altitude(): Double { @@:(this.current_altitude) }
            failsafe_reason(): String { @@:(this.reason) }
        }

        $Flying {
            altitude(): Double { @@:(this.current_altitude) }
            failsafe_reason(): String { @@:(this.reason) }
        }

        $InFlight => $Flying {
            battery_critical() {
                this.reason = "battery"
                -> $EmergencyLand
            }
            rc_lost() {
                this.reason = "rc_lost"
                -> $ReturningHome
            }
            gps_lost() {
                this.reason = "gps_lost"
                -> $AltitudeHold
            }
            geofence_breach() {
                this.reason = "geofence"
                -> $ReturningHome
            }
            => $^
        }

        $TakingOff => $InFlight {
            $>() { this.current_altitude = 0.0 }
            tick() {
                this.current_altitude = this.current_altitude + 1.0
                if (this.current_altitude >= this.target_altitude) {
                    @@:self.takeoff_complete()
                }
            }
            takeoff_complete() { -> $Hovering }
            status(): String { @@:("taking_off") }
            => $^
        }

        $Hovering => $InFlight {
            set_mission(waypoints_ok: Int) {
                if (waypoints_ok == 1) {
                    -> $OnMission
                }
            }
            land() { -> $Landing }
            return_to_home() { -> $ReturningHome }
            status(): String { @@:("hovering") }
            => $^
        }

        $OnMission => $InFlight {
            mission_complete() { -> $Hovering }
            return_to_home() { -> $ReturningHome }
            status(): String { @@:("on_mission") }
            => $^
        }

        $ReturningHome => $InFlight {
            home_reached() { -> $Landing }
            status(): String { @@:("returning") }
            => $^
        }

        $AltitudeHold => $InFlight {
            status(): String { @@:("altitude_hold") }
            => $^
        }

        $Landing {
            touchdown() {
                this.current_altitude = 0.0
                -> $Armed
            }
            status(): String { @@:("landing") }
            altitude(): Double { @@:(this.current_altitude) }
            failsafe_reason(): String { @@:(this.reason) }
        }

        $EmergencyLand {
            touchdown() {
                this.current_altitude = 0.0
                -> $Armed
            }
            status(): String { @@:("emergency_land") }
            altitude(): Double { @@:(this.current_altitude) }
            failsafe_reason(): String { @@:(this.reason) }
        }

    domain:
        target_altitude: Double = 0.0
        current_altitude: Double = 0.0
        reason: String = ""
}

fun check(label: String, actual: String, expected: String) {
    if (actual != expected) {
        println("FAIL: $label expected '$expected', got '$actual'")
        kotlin.system.exitProcess(1)
    }
}
fun checkDouble(label: String, actual: Double, expected: Double) {
    if (kotlin.math.abs(actual - expected) > 1e-6) {
        println("FAIL: $label expected $expected, got $actual")
        kotlin.system.exitProcess(1)
    }
}

fun main() {
    val d = @@DroneFlightMode()
    check("disarmed", d.status() as String, "disarmed")
    d.arm(0)
    check("preflight fail", d.status() as String, "disarmed")
    d.arm(1)
    check("armed", d.status() as String, "armed")
    d.takeoff(5.0)
    check("taking off", d.status() as String, "taking_off")

    var i = 0
    while (i < 10) {
        d.tick()
        if ((d.status() as String) == "hovering") break
        i = i + 1
    }
    check("hovering", d.status() as String, "hovering")
    checkDouble("at altitude", d.altitude() as Double, 5.0)

    d.set_mission(1)
    check("on mission", d.status() as String, "on_mission")
    d.mission_complete()
    check("back to hovering", d.status() as String, "hovering")

    d.land()
    check("landing", d.status() as String, "landing")
    d.touchdown()
    check("back to armed", d.status() as String, "armed")

    val d2 = @@DroneFlightMode()
    d2.arm(1)
    d2.takeoff(100.0)
    d2.battery_critical()
    check("battery -> emergency", d2.status() as String, "emergency_land")
    check("battery reason", d2.failsafe_reason() as String, "battery")

    val d3 = @@DroneFlightMode()
    d3.arm(1)
    d3.takeoff(5.0)
    i = 0
    while (i < 10) {
        d3.tick()
        if ((d3.status() as String) == "hovering") break
        i = i + 1
    }
    d3.rc_lost()
    check("rc lost -> returning", d3.status() as String, "returning")
    d3.home_reached()
    check("home reached -> landing", d3.status() as String, "landing")

    val d4 = @@DroneFlightMode()
    d4.arm(1)
    d4.takeoff(5.0)
    i = 0
    while (i < 10) {
        d4.tick()
        if ((d4.status() as String) == "hovering") break
        i = i + 1
    }
    d4.set_mission(1)
    d4.gps_lost()
    check("gps lost -> altitude hold", d4.status() as String, "altitude_hold")

    val d5 = @@DroneFlightMode()
    d5.arm(1)
    d5.takeoff(5.0)
    i = 0
    while (i < 10) {
        d5.tick()
        if ((d5.status() as String) == "hovering") break
        i = i + 1
    }
    d5.set_mission(1)
    d5.geofence_breach()
    check("geofence -> returning", d5.status() as String, "returning")
    check("geofence reason", d5.failsafe_reason() as String, "geofence")

    val d6 = @@DroneFlightMode()
    d6.battery_critical()
    d6.rc_lost()
    d6.gps_lost()
    d6.geofence_breach()
    check("disarmed ignores failsafes", d6.status() as String, "disarmed")

    println("PASS: drone_flight")
}

@@[target("java")]

// Cookbook 98: Quadrature Encoder Decoder — Mealy Machine

@@system QuadratureDecoder {
    operations:
        count(): int { return this.count_val; }
        direction(): String { return this.last_dir; }
        errors_count(): int { return this.errors; }
        reset() {
            this.count_val = 0;
            this.errors = 0;
            this.last_dir = "none";
        }

    interface:
        signal(a: int, b: int): int

    machine:
        $S00 {
            signal(a: int, b: int): int {
                if (a == 0 && b == 0) {
                    @@:(0)
                } else if (a == 1 && b == 0) {
                    this.count_val = this.count_val + 1;
                    this.last_dir = "fwd";
                    @@:(1)
                    -> $S10
                } else if (a == 0 && b == 1) {
                    this.count_val = this.count_val - 1;
                    this.last_dir = "rev";
                    @@:(-1)
                    -> $S01
                } else {
                    this.errors = this.errors + 1;
                    @@:(0)
                }
            }
        }

        $S10 {
            signal(a: int, b: int): int {
                if (a == 1 && b == 0) {
                    @@:(0)
                } else if (a == 1 && b == 1) {
                    this.count_val = this.count_val + 1;
                    this.last_dir = "fwd";
                    @@:(1)
                    -> $S11
                } else if (a == 0 && b == 0) {
                    this.count_val = this.count_val - 1;
                    this.last_dir = "rev";
                    @@:(-1)
                    -> $S00
                } else {
                    this.errors = this.errors + 1;
                    @@:(0)
                }
            }
        }

        $S11 {
            signal(a: int, b: int): int {
                if (a == 1 && b == 1) {
                    @@:(0)
                } else if (a == 0 && b == 1) {
                    this.count_val = this.count_val + 1;
                    this.last_dir = "fwd";
                    @@:(1)
                    -> $S01
                } else if (a == 1 && b == 0) {
                    this.count_val = this.count_val - 1;
                    this.last_dir = "rev";
                    @@:(-1)
                    -> $S10
                } else {
                    this.errors = this.errors + 1;
                    @@:(0)
                }
            }
        }

        $S01 {
            signal(a: int, b: int): int {
                if (a == 0 && b == 1) {
                    @@:(0)
                } else if (a == 0 && b == 0) {
                    this.count_val = this.count_val + 1;
                    this.last_dir = "fwd";
                    @@:(1)
                    -> $S00
                } else if (a == 1 && b == 1) {
                    this.count_val = this.count_val - 1;
                    this.last_dir = "rev";
                    @@:(-1)
                    -> $S11
                } else {
                    this.errors = this.errors + 1;
                    @@:(0)
                }
            }
        }

    domain:
        count_val: int = 0
        errors: int = 0
        last_dir: String = "none"
}


class Main {
    static void check_str(String label, String actual, String expected) {
        if (!actual.equals(expected)) {
            System.out.println("FAIL: " + label + " expected '" + expected + "', got '" + actual + "'");
            System.exit(1);
        }
    }
    static void check_int(String label, int actual, int expected) {
        if (actual != expected) {
            System.out.println("FAIL: " + label + " expected " + expected + ", got " + actual);
            System.exit(1);
        }
    }

    public static void main(String[] args) {
        QuadratureDecoder q = @@QuadratureDecoder();
        check_int("initial count 0", q.count(), 0);
        check_str("initial direction", q.direction(), "none");
        check_int("initial errors 0", q.errors_count(), 0);

        check_int("idle 00", (int) q.signal(0, 0), 0);
        check_int("no count change on idle", q.count(), 0);

        check_int("00->10 fwd", (int) q.signal(1, 0), 1);
        check_int("10->11 fwd", (int) q.signal(1, 1), 1);
        check_int("11->01 fwd", (int) q.signal(0, 1), 1);
        check_int("01->00 fwd", (int) q.signal(0, 0), 1);

        check_int("four fwd ticks", q.count(), 4);
        check_str("direction fwd", q.direction(), "fwd");

        check_int("00->01 rev", (int) q.signal(0, 1), -1);
        check_int("01->11 rev", (int) q.signal(1, 1), -1);
        check_int("11->10 rev", (int) q.signal(1, 0), -1);
        check_int("10->00 rev", (int) q.signal(0, 0), -1);

        check_int("net count 0", q.count(), 0);
        check_str("direction rev", q.direction(), "rev");

        check_int("illegal 00->11", (int) q.signal(1, 1), 0);
        check_int("error counted", q.errors_count(), 1);

        check_int("still at 00", (int) q.signal(1, 0), 1);

        q.reset();
        check_int("count reset", q.count(), 0);
        check_str("direction reset", q.direction(), "none");
        check_int("errors reset", q.errors_count(), 0);

        q.signal(1, 0); q.signal(1, 1); q.signal(0, 1); q.signal(0, 0);
        q.signal(1, 0); q.signal(1, 1); q.signal(0, 1); q.signal(0, 0);
        check_int("8 signals starting idle = 7 fwd edges", q.count(), 7);

        System.out.println("PASS: quadrature");
    }
}

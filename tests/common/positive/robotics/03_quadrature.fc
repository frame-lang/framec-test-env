@@[target("c")]

// Cookbook 98: Quadrature Encoder Decoder — Mealy Machine

@@system QuadratureDecoder {
    operations:
        count(): int { return self->count_val; }
        direction(): string { return self->last_dir; }
        errors_count(): int { return self->errors; }
        reset() {
            self->count_val = 0;
            self->errors = 0;
            self->last_dir = "none";
        }

    interface:
        signal(a: int, b: int): int

    machine:
        $S00 {
            signal(a: int, b: int): int {
                if (a == 0 && b == 0) {
                    @@:(0)
                } else if (a == 1 && b == 0) {
                    self->count_val = self->count_val + 1;
                    self->last_dir = "fwd";
                    @@:(1)
                    -> $S10
                } else if (a == 0 && b == 1) {
                    self->count_val = self->count_val - 1;
                    self->last_dir = "rev";
                    @@:(-1)
                    -> $S01
                } else {
                    self->errors = self->errors + 1;
                    @@:(0)
                }
            }
        }

        $S10 {
            signal(a: int, b: int): int {
                if (a == 1 && b == 0) {
                    @@:(0)
                } else if (a == 1 && b == 1) {
                    self->count_val = self->count_val + 1;
                    self->last_dir = "fwd";
                    @@:(1)
                    -> $S11
                } else if (a == 0 && b == 0) {
                    self->count_val = self->count_val - 1;
                    self->last_dir = "rev";
                    @@:(-1)
                    -> $S00
                } else {
                    self->errors = self->errors + 1;
                    @@:(0)
                }
            }
        }

        $S11 {
            signal(a: int, b: int): int {
                if (a == 1 && b == 1) {
                    @@:(0)
                } else if (a == 0 && b == 1) {
                    self->count_val = self->count_val + 1;
                    self->last_dir = "fwd";
                    @@:(1)
                    -> $S01
                } else if (a == 1 && b == 0) {
                    self->count_val = self->count_val - 1;
                    self->last_dir = "rev";
                    @@:(-1)
                    -> $S10
                } else {
                    self->errors = self->errors + 1;
                    @@:(0)
                }
            }
        }

        $S01 {
            signal(a: int, b: int): int {
                if (a == 0 && b == 1) {
                    @@:(0)
                } else if (a == 0 && b == 0) {
                    self->count_val = self->count_val + 1;
                    self->last_dir = "fwd";
                    @@:(1)
                    -> $S00
                } else if (a == 1 && b == 1) {
                    self->count_val = self->count_val - 1;
                    self->last_dir = "rev";
                    @@:(-1)
                    -> $S11
                } else {
                    self->errors = self->errors + 1;
                    @@:(0)
                }
            }
        }

    domain:
        count_val: int = 0
        errors: int = 0
        last_dir: string = "none"
}

#include <stdio.h>
#include <stdlib.h>
#include <string.h>

static void check_str(const char* label, const char* actual, const char* expected) {
    if (strcmp(actual, expected) != 0) {
        printf("FAIL: %s expected '%s', got '%s'\n", label, expected, actual);
        exit(1);
    }
}
static void check_int(const char* label, int actual, int expected) {
    if (actual != expected) {
        printf("FAIL: %s expected %d, got %d\n", label, expected, actual);
        exit(1);
    }
}

int main(void) {
    QuadratureDecoder* q = @@QuadratureDecoder();
    check_int("initial count 0", QuadratureDecoder_count(q), 0);
    check_str("initial direction", QuadratureDecoder_direction(q), "none");
    check_int("initial errors 0", QuadratureDecoder_errors_count(q), 0);

    check_int("idle 00", QuadratureDecoder_signal(q, 0, 0), 0);
    check_int("no count change on idle", QuadratureDecoder_count(q), 0);

    check_int("00->10 fwd", QuadratureDecoder_signal(q, 1, 0), 1);
    check_int("10->11 fwd", QuadratureDecoder_signal(q, 1, 1), 1);
    check_int("11->01 fwd", QuadratureDecoder_signal(q, 0, 1), 1);
    check_int("01->00 fwd", QuadratureDecoder_signal(q, 0, 0), 1);

    check_int("four fwd ticks", QuadratureDecoder_count(q), 4);
    check_str("direction fwd", QuadratureDecoder_direction(q), "fwd");

    check_int("00->01 rev", QuadratureDecoder_signal(q, 0, 1), -1);
    check_int("01->11 rev", QuadratureDecoder_signal(q, 1, 1), -1);
    check_int("11->10 rev", QuadratureDecoder_signal(q, 1, 0), -1);
    check_int("10->00 rev", QuadratureDecoder_signal(q, 0, 0), -1);

    check_int("net count 0", QuadratureDecoder_count(q), 0);
    check_str("direction rev", QuadratureDecoder_direction(q), "rev");

    check_int("illegal 00->11", QuadratureDecoder_signal(q, 1, 1), 0);
    check_int("error counted", QuadratureDecoder_errors_count(q), 1);

    check_int("still at 00", QuadratureDecoder_signal(q, 1, 0), 1);

    QuadratureDecoder_reset(q);
    check_int("count reset", QuadratureDecoder_count(q), 0);
    check_str("direction reset", QuadratureDecoder_direction(q), "none");
    check_int("errors reset", QuadratureDecoder_errors_count(q), 0);

    QuadratureDecoder_signal(q, 1, 0); QuadratureDecoder_signal(q, 1, 1);
    QuadratureDecoder_signal(q, 0, 1); QuadratureDecoder_signal(q, 0, 0);
    QuadratureDecoder_signal(q, 1, 0); QuadratureDecoder_signal(q, 1, 1);
    QuadratureDecoder_signal(q, 0, 1); QuadratureDecoder_signal(q, 0, 0);
    check_int("8 signals starting idle = 7 fwd edges", QuadratureDecoder_count(q), 7);

    printf("PASS: quadrature\n");
    QuadratureDecoder_destroy(q);
    return 0;
}

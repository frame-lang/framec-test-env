@@[target("gdscript")]

# Cookbook 102: Dock-and-Charge — Negotiated Resource Lifecycle

@@system DockController : RefCounted {
    interface:
        battery_low()
        dock_visible(range: float)
        dock_lost()
        contact_made()
        charging_started()
        charging_fault()
        fully_charged()
        undock_complete()
        tick()
        status(): String
        get_battery(): int

    machine:
        $Discharging {
            battery_low() {
                self.align_attempts = 0
                -> $SeekingDock
            }
            tick() { self.battery_pct = self.battery_pct - 1 }
            status(): String { @@:("discharging") }
            get_battery(): int { @@:(self.battery_pct) }
        }

        $DockingFlow {
            dock_lost() { -> $Discharging }
            get_battery(): int { @@:(self.battery_pct) }
        }

        $SeekingDock => $DockingFlow {
            dock_visible(range: float) {
                if range < 0.2:
                    -> $Aligning
            }
            status(): String { @@:("seeking") }
            => $^
        }

        $Aligning => $DockingFlow {
            $>() { self.align_attempts = self.align_attempts + 1 }
            tick() {
                if self.align_attempts >= self.max_align_attempts:
                    -> $Failed
            }
            dock_visible(range: float) {
                if range < 0.05:
                    -> $MakingContact
            }
            status(): String { @@:("aligning") }
            => $^
        }

        $MakingContact => $DockingFlow {
            contact_made() { -> $VerifyingCharge }
            status(): String { @@:("making_contact") }
            => $^
        }

        $VerifyingCharge => $DockingFlow {
            charging_started() { -> $Charging }
            charging_fault() { -> $Failed }
            status(): String { @@:("verifying_charge") }
            => $^
        }

        $Charging {
            tick() {
                self.battery_pct = self.battery_pct + 1
                if self.battery_pct >= 100:
                    -> $Undocking
            }
            fully_charged() { -> $Undocking }
            status(): String { @@:("charging") }
            get_battery(): int { @@:(self.battery_pct) }
        }

        $Undocking {
            undock_complete() { -> $Discharging }
            status(): String { @@:("undocking") }
            get_battery(): int { @@:(self.battery_pct) }
        }

        $Failed {
            battery_low() {
                self.align_attempts = 0
                -> $SeekingDock
            }
            status(): String { @@:("failed") }
            get_battery(): int { @@:(self.battery_pct) }
        }

    domain:
        battery_pct: int = 50
        align_attempts: int = 0
        max_align_attempts: int = 3
}


func check_str(label: String, actual: String, expected: String) -> void:
    if actual != expected:
        print("FAIL: %s expected '%s', got '%s'" % [label, expected, actual])
        quit(1)

func _init() -> void:
    var d = @@DockController()
    check_str("discharging", d.status(), "discharging")

    d.battery_low()
    check_str("seeking", d.status(), "seeking")

    d.dock_visible(0.1)
    check_str("aligning", d.status(), "aligning")

    d.dock_visible(0.01)
    check_str("contact", d.status(), "making_contact")

    d.contact_made()
    check_str("verifying", d.status(), "verifying_charge")

    d.charging_started()
    check_str("charging", d.status(), "charging")

    var i = 0
    while i < 100:
        d.tick()
        if d.status() == "undocking":
            break
        i = i + 1
    check_str("undocking", d.status(), "undocking")

    d.undock_complete()
    check_str("back to discharging", d.status(), "discharging")

    var d2 = @@DockController()
    d2.battery_low()
    d2.dock_visible(0.1)
    d2.dock_lost()
    check_str("dock lost -> discharging", d2.status(), "discharging")

    var d4 = @@DockController()
    d4.battery_low()
    d4.dock_visible(0.1)
    d4.dock_visible(0.01)
    d4.contact_made()
    d4.charging_fault()
    check_str("charge fault -> failed", d4.status(), "failed")
    d4.battery_low()
    check_str("failed re-seeks on battery_low", d4.status(), "seeking")

    print("PASS: dock_charge")
    quit()

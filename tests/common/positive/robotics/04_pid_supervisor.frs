@@[target("rust")]

// Cookbook 99: PID Loop Supervisor

@@system PidSupervisor {
    interface:
        enable()
        disable()
        set_setpoint(sp: f64)
        start_autotune()
        tune_step_done()
        tick(measurement: f64): f64
        saturate_detected()
        clear_saturation()
        status(): String
        integrator_val(): f64

    machine:
        $Disabled {
            enable() { -> $Holding }
            tick(measurement: f64): f64 { @@:(0.0) }
            status(): String { @@:(String::from("disabled")) }
            integrator_val(): f64 { @@:(self.integrator) }
        }

        $Enabled {
            disable() {
                self.integrator = 0.0;
                self.last_error = 0.0;
                -> $Disabled
            }
            saturate_detected() { -> $Saturated }
            integrator_val(): f64 { @@:(self.integrator) }
        }

        $Tuning => $Enabled {
            tick(measurement: f64): f64 { @@:(0.0) }
            tune_step_done() { -> $Holding }
            status(): String { @@:(String::from("tuning")) }
            => $^
        }

        $Holding => $Enabled {
            set_setpoint(sp: f64) { self.setpoint = sp; }
            start_autotune() { -> $Tuning }
            tick(measurement: f64): f64 {
                let error = self.setpoint - measurement;
                self.integrator = self.integrator + error;
                let derivative = error - self.last_error;
                self.last_error = error;
                @@:(self.kp * error + self.ki * self.integrator + self.kd * derivative)
            }
            status(): String { @@:(String::from("holding")) }
            => $^
        }

        $Saturated => $Enabled {
            tick(measurement: f64): f64 {
                let error = self.setpoint - measurement;
                let derivative = error - self.last_error;
                self.last_error = error;
                @@:(self.kp * error + self.kd * derivative)
            }
            clear_saturation() { -> $Holding }
            status(): String { @@:(String::from("saturated")) }
            => $^
        }

    domain:
        kp: f64 = 1.0
        ki: f64 = 0.1
        kd: f64 = 0.01
        setpoint: f64 = 0.0
        integrator: f64 = 0.0
        last_error: f64 = 0.0
}


fn check_str(label: &str, actual: &str, expected: &str) {
    if actual != expected {
        println!("FAIL: {} expected '{}', got '{}'", label, expected, actual);
        std::process::exit(1);
    }
}
fn check_float(label: &str, actual: f64, expected: f64) {
    if (actual - expected).abs() > 1e-9 {
        println!("FAIL: {} expected {}, got {}", label, expected, actual);
        std::process::exit(1);
    }
}

fn main() {
    let mut p = @@PidSupervisor();
    check_str("disabled initially", &p.status(), "disabled");

    check_float("disabled tick 0", p.tick(10.0), 0.0);

    p.set_setpoint(100.0);
    check_str("disabled absorbs setpoint", &p.status(), "disabled");

    p.enable();
    check_str("enabled -> holding", &p.status(), "holding");

    p.set_setpoint(10.0);
    let out1 = p.tick(0.0);
    check_float("first pid step", out1, 11.1);
    check_float("integrator accumulated", p.integrator_val(), 10.0);

    let out2 = p.tick(5.0);
    check_float("second pid step", out2, 6.45);
    check_float("integrator grew", p.integrator_val(), 15.0);

    p.saturate_detected();
    check_str("saturated", &p.status(), "saturated");
    let out3 = p.tick(6.0);
    check_float("saturated pid no-I", out3, 3.99);
    check_float("integrator frozen", p.integrator_val(), 15.0);

    p.clear_saturation();
    check_str("holding after clear", &p.status(), "holding");
    check_float("integrator survives", p.integrator_val(), 15.0);

    p.start_autotune();
    check_str("tuning", &p.status(), "tuning");
    p.set_setpoint(50.0);
    check_str("tuning absorbs setpoint", &p.status(), "tuning");

    p.tune_step_done();
    check_str("tuning done -> holding", &p.status(), "holding");

    p.disable();
    check_str("disabled", &p.status(), "disabled");
    check_float("integrator cleared on disable", p.integrator_val(), 0.0);

    let mut p2 = @@PidSupervisor();
    p2.enable();
    p2.saturate_detected();
    check_str("holding->saturated via HSM", &p2.status(), "saturated");

    let mut p3 = @@PidSupervisor();
    p3.enable();
    p3.start_autotune();
    p3.saturate_detected();
    check_str("tuning->saturated via HSM", &p3.status(), "saturated");

    println!("PASS: pid_supervisor");
}

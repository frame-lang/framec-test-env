@@[target("swift")]

import Foundation

// Cookbook 102: Dock-and-Charge — Negotiated Resource Lifecycle

@@system DockController {
    interface:
        battery_low()
        dock_visible(range: Double)
        dock_lost()
        contact_made()
        charging_started()
        charging_fault()
        fully_charged()
        undock_complete()
        tick()
        status(): String
        get_battery(): Int

    machine:
        $Discharging {
            battery_low() {
                self.align_attempts = 0
                -> $SeekingDock
            }
            tick() { self.battery_pct = self.battery_pct - 1 }
            status(): String { @@:("discharging") }
            get_battery(): Int { @@:(self.battery_pct) }
        }

        $DockingFlow {
            dock_lost() { -> $Discharging }
            get_battery(): Int { @@:(self.battery_pct) }
        }

        $SeekingDock => $DockingFlow {
            dock_visible(range: Double) {
                if range < 0.2 {
                    -> $Aligning
                }
            }
            status(): String { @@:("seeking") }
            => $^
        }

        $Aligning => $DockingFlow {
            $>() { self.align_attempts = self.align_attempts + 1 }
            tick() {
                if self.align_attempts >= self.max_align_attempts {
                    -> $Failed
                }
            }
            dock_visible(range: Double) {
                if range < 0.05 {
                    -> $MakingContact
                }
            }
            status(): String { @@:("aligning") }
            => $^
        }

        $MakingContact => $DockingFlow {
            contact_made() { -> $VerifyingCharge }
            status(): String { @@:("making_contact") }
            => $^
        }

        $VerifyingCharge => $DockingFlow {
            charging_started() { -> $Charging }
            charging_fault() { -> $Failed }
            status(): String { @@:("verifying_charge") }
            => $^
        }

        $Charging {
            tick() {
                self.battery_pct = self.battery_pct + 1
                if self.battery_pct >= 100 {
                    -> $Undocking
                }
            }
            fully_charged() { -> $Undocking }
            status(): String { @@:("charging") }
            get_battery(): Int { @@:(self.battery_pct) }
        }

        $Undocking {
            undock_complete() { -> $Discharging }
            status(): String { @@:("undocking") }
            get_battery(): Int { @@:(self.battery_pct) }
        }

        $Failed {
            battery_low() {
                self.align_attempts = 0
                -> $SeekingDock
            }
            status(): String { @@:("failed") }
            get_battery(): Int { @@:(self.battery_pct) }
        }

    domain:
        battery_pct: Int = 50
        align_attempts: Int = 0
        max_align_attempts: Int = 3
}


func checkStr(_ label: String, _ actual: String, _ expected: String) {
    if actual != expected {
        print("FAIL: \(label) expected '\(expected)', got '\(actual)'")
        exit(1)
    }
}

let d = @@DockController()
checkStr("discharging", d.status(), "discharging")

d.battery_low()
checkStr("seeking", d.status(), "seeking")

d.dock_visible(0.1)
checkStr("aligning", d.status(), "aligning")

d.dock_visible(0.01)
checkStr("contact", d.status(), "making_contact")

d.contact_made()
checkStr("verifying", d.status(), "verifying_charge")

d.charging_started()
checkStr("charging", d.status(), "charging")

var i = 0
while i < 100 {
    d.tick()
    if d.status() == "undocking" {
        break
    }
    i = i + 1
}
checkStr("undocking", d.status(), "undocking")

d.undock_complete()
checkStr("back to discharging", d.status(), "discharging")

let d2 = @@DockController()
d2.battery_low()
d2.dock_visible(0.1)
d2.dock_lost()
checkStr("dock lost -> discharging", d2.status(), "discharging")

let d4 = @@DockController()
d4.battery_low()
d4.dock_visible(0.1)
d4.dock_visible(0.01)
d4.contact_made()
d4.charging_fault()
checkStr("charge fault -> failed", d4.status(), "failed")
d4.battery_low()
checkStr("failed re-seeks on battery_low", d4.status(), "seeking")

print("PASS: dock_charge")

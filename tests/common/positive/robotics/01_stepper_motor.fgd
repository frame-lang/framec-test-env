@@[target("gdscript")]

# Cookbook 96: Stepper Motor Driver — Trapezoidal Motion Profile

@@system StepperDriver : RefCounted {
    interface:
        move_to(target_steps: int)
        tick()
        stop()
        stall_detected()
        status(): String
        get_position(): int
        get_velocity(): int

    machine:
        $Idle {
            move_to(target_steps: int) {
                self.target = target_steps
                self.position = 0
                self.velocity = 0
                self.accel_steps = 0
                -> $Accelerating
            }
            tick() { }
            status(): String { @@:("idle") }
            get_position(): int { @@:(self.position) }
            get_velocity(): int { @@:(self.velocity) }
        }

        $Active {
            get_position(): int { @@:(self.position) }
            get_velocity(): int { @@:(self.velocity) }
        }

        $Motion => $Active {
            stop() { -> $Decelerating }
            stall_detected() {
                self.velocity = 0
                -> $Stalled
            }
            => $^
        }

        $Accelerating => $Motion {
            tick() {
                self.velocity = self.velocity + self.accel_rate
                self.position = self.position + self.velocity
                self.accel_steps = self.accel_steps + self.velocity

                if self.velocity >= self.v_max:
                    self.velocity = self.v_max
                    -> $Cruising

                var remaining = self.target - self.position
                if remaining <= self.accel_steps:
                    -> $Decelerating
            }
            status(): String { @@:("accelerating") }
            => $^
        }

        $Cruising => $Motion {
            tick() {
                self.position = self.position + self.velocity
                var remaining = self.target - self.position
                if remaining <= self.accel_steps:
                    -> $Decelerating
            }
            status(): String { @@:("cruising") }
            => $^
        }

        $Decelerating => $Motion {
            tick() {
                self.velocity = self.velocity - self.accel_rate
                if self.velocity <= 0:
                    self.velocity = 0
                    -> $Idle
                else:
                    self.position = self.position + self.velocity
            }
            status(): String { @@:("decelerating") }
            => $^
        }

        $Stalled {
            move_to(target_steps: int) {
                self.target = target_steps
                self.position = 0
                self.velocity = 0
                self.accel_steps = 0
                -> $Accelerating
            }
            status(): String { @@:("stalled") }
            get_position(): int { @@:(self.position) }
            get_velocity(): int { @@:(self.velocity) }
        }

    domain:
        target: int = 0
        position: int = 0
        velocity: int = 0
        accel_steps: int = 0
        v_max: int = 20
        accel_rate: int = 2
}


func check_str(label: String, actual: String, expected: String) -> void:
    if actual != expected:
        print("FAIL: %s expected '%s', got '%s'" % [label, expected, actual])
        quit(1)
func check_int(label: String, actual: int, expected: int) -> void:
    if actual != expected:
        print("FAIL: %s expected %d, got %d" % [label, expected, actual])
        quit(1)
func check_bool(label: String, actual: bool, expected: bool) -> void:
    if actual != expected:
        print("FAIL: %s expected %s, got %s" % [label, str(expected), str(actual)])
        quit(1)

func _init() -> void:
    var m = @@StepperDriver()
    check_str("start idle", m.status(), "idle")
    check_int("start position 0", m.get_position(), 0)

    m.move_to(300)
    check_str("accelerating", m.status(), "accelerating")

    var saw_cruising = false
    var final_status = ""
    for i in range(40):
        m.tick()
        var s = m.status()
        if s == "cruising":
            saw_cruising = true
        if s == "idle":
            final_status = s
            break
    check_bool("long move visited cruising", saw_cruising, true)
    check_str("long move ended idle", final_status, "idle")
    check_int("final velocity 0", m.get_velocity(), 0)
    check_bool("position advanced", m.get_position() > 200, true)

    var m2 = @@StepperDriver()
    m2.move_to(40)
    var saw_cruising2 = false
    var final_status2 = ""
    for j in range(20):
        m2.tick()
        var s = m2.status()
        if s == "cruising":
            saw_cruising2 = true
        if s == "idle":
            final_status2 = s
            break
    check_bool("short move skips cruising", saw_cruising2, false)
    check_str("short move ended idle", final_status2, "idle")

    var m3 = @@StepperDriver()
    m3.move_to(1000)
    for k in range(15):
        m3.tick()
    check_str("in cruise", m3.status(), "cruising")

    m3.stop()
    check_str("stopped to decel", m3.status(), "decelerating")

    for n in range(15):
        m3.tick()
        if m3.status() == "idle":
            break
    check_str("decel completes after stop", m3.status(), "idle")
    check_int("stopped velocity 0", m3.get_velocity(), 0)

    var m4 = @@StepperDriver()
    m4.move_to(1000)
    for p in range(3):
        m4.tick()
    check_str("accel when stalled", m4.status(), "accelerating")
    m4.stall_detected()
    check_str("stalled", m4.status(), "stalled")
    check_int("velocity cleared on stall", m4.get_velocity(), 0)

    m4.move_to(50)
    check_str("stall cleared", m4.status(), "accelerating")

    var m5 = @@StepperDriver()
    m5.stop()
    m5.stall_detected()
    check_str("idle absorbs stop", m5.status(), "idle")

    print("PASS: stepper_motor")
    quit()

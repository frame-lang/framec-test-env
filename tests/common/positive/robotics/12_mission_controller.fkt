@@[target("kotlin")]

// Cookbook 107: Mission Controller (BT-alternative)

@@system MissionController {
    interface:
        start_mission(mission_id: String, site_count: Int)
        arrived_at_site()
        inspection_complete()
        inspection_failed()
        report_sent()
        docked()
        abort()
        tick()
        status(): String
        get_site(): Int
        get_total(): Int
        get_retries(): Int

    machine:
        $Idle {
            start_mission(mission_id: String, site_count: Int) {
                this.mission_id = mission_id
                this.site_total = site_count
                this.site_index = 0
                this.findings_count = 0
                this.inspection_retries = 0
                -> $TravelingToSite
            }
            status(): String { @@:("idle") }
            get_site(): Int { @@:(this.site_index) }
            get_total(): Int { @@:(this.site_total) }
            get_retries(): Int { @@:(this.inspection_retries) }
        }

        $Mission {
            abort() { -> $ReturningToDock }
            get_site(): Int { @@:(this.site_index) }
            get_total(): Int { @@:(this.site_total) }
            get_retries(): Int { @@:(this.inspection_retries) }
        }

        $TravelingToSite => $Mission {
            $>() {
                if (this.site_index >= this.site_total) {
                    -> $ReturningToDock
                }
            }
            arrived_at_site() { -> $Inspecting }
            status(): String { @@:("traveling") }
            => $^
        }

        $Inspecting => $Mission {
            $>() { this.inspection_retries = this.inspection_retries + 1 }
            inspection_complete() {
                this.findings_count = this.findings_count + 1
                this.inspection_retries = 0
                this.site_index = this.site_index + 1
                -> $TravelingToSite
            }
            inspection_failed() {
                if (this.inspection_retries >= this.max_inspection_retries) {
                    this.inspection_retries = 0
                    this.site_index = this.site_index + 1
                    -> $TravelingToSite
                } else {
                    -> $Inspecting
                }
            }
            status(): String { @@:("inspecting") }
            => $^
        }

        $ReturningToDock => $Mission {
            docked() { -> $SendingReport }
            status(): String { @@:("returning") }
            => $^
        }

        $SendingReport => $Mission {
            report_sent() { -> $Idle }
            status(): String { @@:("sending_report") }
            => $^
        }

    domain:
        mission_id: String = ""
        site_total: Int = 0
        site_index: Int = 0
        findings_count: Int = 0
        inspection_retries: Int = 0
        max_inspection_retries: Int = 3
}


fun check_str(label: String, actual: String, expected: String) {
    if (actual != expected) {
        println("FAIL: $label expected '$expected', got '$actual'")
        kotlin.system.exitProcess(1)
    }
}

fun check_int(label: String, actual: Int, expected: Int) {
    if (actual != expected) {
        println("FAIL: $label expected $expected, got $actual")
        kotlin.system.exitProcess(1)
    }
}

fun main() {
    val m = @@MissionController()
    check_str("idle", m.status() as String, "idle")

    m.start_mission("M-1", 3)
    check_str("traveling", m.status() as String, "traveling")
    check_int("site 0", m.get_site() as Int, 0)
    check_int("3 total", m.get_total() as Int, 3)

    m.arrived_at_site()
    check_str("inspecting", m.status() as String, "inspecting")
    check_int("attempt 1", m.get_retries() as Int, 1)
    m.inspection_complete()
    check_int("advancing", m.get_site() as Int, 1)
    check_str("back to traveling", m.status() as String, "traveling")
    check_int("retries reset", m.get_retries() as Int, 0)

    m.arrived_at_site()
    m.inspection_failed()
    check_str("retry same site", m.status() as String, "inspecting")
    check_int("still site 1", m.get_site() as Int, 1)
    check_int("attempt 2", m.get_retries() as Int, 2)
    m.inspection_complete()
    check_int("site 2 done", m.get_site() as Int, 2)

    m.arrived_at_site()
    m.inspection_failed()
    m.inspection_failed()
    m.inspection_failed()
    check_int("skipped site after max retries", m.get_site() as Int, 3)

    m.arrived_at_site()
    check_str("returning to dock", m.status() as String, "returning")

    m.docked()
    check_str("sending report", m.status() as String, "sending_report")

    m.report_sent()
    check_str("back to idle", m.status() as String, "idle")

    val m2 = @@MissionController()
    m2.start_mission("M-2", 5)
    m2.arrived_at_site()
    m2.abort()
    check_str("abort -> returning", m2.status() as String, "returning")
    m2.docked()
    m2.report_sent()
    check_str("abort completes to idle", m2.status() as String, "idle")

    println("PASS: mission_controller")
}

@@[target("javascript")]

// Cookbook 109: Fleet Robot (single-robot half of Fleet Dispatcher)

@@system FleetRobot(robot_id: string) {
    interface:
        assign_task(task_id: string)
        task_complete()
        task_failed()
        tick()
        state_name(): string
        current_task_id(): string
        id(): string

    machine:
        $Available {
            assign_task(task_id: string) {
                this.current_task = task_id;
                -> $Busy
            }
            state_name(): string { @@:("available") }
            current_task_id(): string { @@:(this.current_task) }
            id(): string { @@:(this.rid) }
        }

        $Busy {
            $>() { this.work_ticks = 0; }
            tick() {
                this.work_ticks = this.work_ticks + 1;
                if (this.work_ticks >= this.task_duration) {
                    @@:self.task_complete();
                }
            }
            task_complete() {
                this.completed_count = this.completed_count + 1;
                this.current_task = "";
                -> $Available
            }
            task_failed() {
                this.failed_count = this.failed_count + 1;
                this.current_task = "";
                -> $Available
            }
            state_name(): string { @@:("busy") }
            current_task_id(): string { @@:(this.current_task) }
            id(): string { @@:(this.rid) }
        }

    domain:
        rid: string = robot_id
        current_task: string = ""
        work_ticks: int = 0
        task_duration: int = 5
        completed_count: int = 0
        failed_count: int = 0
}

function check(label, actual, expected) {
    if (actual !== expected) {
        console.log("FAIL: " + label + " expected '" + expected + "', got '" + actual + "'");
        process.exit(1);
    }
}

const r = @@FleetRobot("bot-1");
check("available", r.state_name(), "available");
check("id preserved", r.id(), "bot-1");
check("no task", r.current_task_id(), "");

r.task_complete();
r.task_failed();
check("available absorbs completions", r.state_name(), "available");

r.assign_task("task-42");
check("busy", r.state_name(), "busy");
check("task captured", r.current_task_id(), "task-42");

r.assign_task("task-99");
check("busy absorbs new assign", r.state_name(), "busy");
check("task unchanged", r.current_task_id(), "task-42");

r.tick();
r.tick();
check("still busy after 2 ticks", r.state_name(), "busy");
r.tick();
r.tick();
r.tick();
check("auto-complete at 5 ticks", r.state_name(), "available");
check("task cleared", r.current_task_id(), "");

r.assign_task("task-43");
r.task_complete();
check("explicit complete -> available", r.state_name(), "available");

r.assign_task("task-44");
r.task_failed();
check("failed -> available", r.state_name(), "available");

const r2 = @@FleetRobot("bot-2");
check("bot-2 id", r2.id(), "bot-2");
check("bot-2 independent state", r2.state_name(), "available");

r.assign_task("t1"); r.task_complete();
r.assign_task("t2"); r.task_complete();
r.assign_task("t3"); r.task_complete();
check("available after 3 cycles", r.state_name(), "available");

console.log("PASS: fleet_robot");

@@[target("kotlin")]

// Cookbook 99: PID Loop Supervisor

@@system PidSupervisor {
    interface:
        enable()
        disable()
        set_setpoint(sp: Double)
        start_autotune()
        tune_step_done()
        tick(measurement: Double): Double
        saturate_detected()
        clear_saturation()
        status(): String
        integrator_val(): Double

    machine:
        $Disabled {
            enable() { -> $Holding }
            tick(measurement: Double): Double { @@:(0.0) }
            status(): String { @@:("disabled") }
            integrator_val(): Double { @@:(this.integrator) }
        }

        $Enabled {
            disable() {
                this.integrator = 0.0
                this.last_error = 0.0
                -> $Disabled
            }
            saturate_detected() { -> $Saturated }
            integrator_val(): Double { @@:(this.integrator) }
        }

        $Tuning => $Enabled {
            tick(measurement: Double): Double { @@:(0.0) }
            tune_step_done() { -> $Holding }
            status(): String { @@:("tuning") }
            => $^
        }

        $Holding => $Enabled {
            set_setpoint(sp: Double) { this.setpoint = sp }
            start_autotune() { -> $Tuning }
            tick(measurement: Double): Double {
                val error = this.setpoint - measurement
                this.integrator = this.integrator + error
                val derivative = error - this.last_error
                this.last_error = error
                @@:(this.kp * error + this.ki * this.integrator + this.kd * derivative)
            }
            status(): String { @@:("holding") }
            => $^
        }

        $Saturated => $Enabled {
            tick(measurement: Double): Double {
                val error = this.setpoint - measurement
                val derivative = error - this.last_error
                this.last_error = error
                @@:(this.kp * error + this.kd * derivative)
            }
            clear_saturation() { -> $Holding }
            status(): String { @@:("saturated") }
            => $^
        }

    domain:
        kp: Double = 1.0
        ki: Double = 0.1
        kd: Double = 0.01
        setpoint: Double = 0.0
        integrator: Double = 0.0
        last_error: Double = 0.0
}


fun check_str(label: String, actual: String, expected: String) {
    if (actual != expected) {
        println("FAIL: $label expected '$expected', got '$actual'")
        kotlin.system.exitProcess(1)
    }
}
fun check_float(label: String, actual: Double, expected: Double) {
    if (kotlin.math.abs(actual - expected) > 1e-9) {
        println("FAIL: $label expected $expected, got $actual")
        kotlin.system.exitProcess(1)
    }
}

fun main() {
    val p = @@PidSupervisor()
    check_str("disabled initially", p.status() as String, "disabled")

    check_float("disabled tick 0", p.tick(10.0) as Double, 0.0)
    p.set_setpoint(100.0)
    check_str("disabled absorbs setpoint", p.status() as String, "disabled")

    p.enable()
    check_str("enabled -> holding", p.status() as String, "holding")

    p.set_setpoint(10.0)
    val out1 = p.tick(0.0) as Double
    check_float("first pid step", out1, 11.1)
    check_float("integrator accumulated", p.integrator_val() as Double, 10.0)

    val out2 = p.tick(5.0) as Double
    check_float("second pid step", out2, 6.45)
    check_float("integrator grew", p.integrator_val() as Double, 15.0)

    p.saturate_detected()
    check_str("saturated", p.status() as String, "saturated")
    val out3 = p.tick(6.0) as Double
    check_float("saturated pid no-I", out3, 3.99)
    check_float("integrator frozen", p.integrator_val() as Double, 15.0)

    p.clear_saturation()
    check_str("holding after clear", p.status() as String, "holding")
    check_float("integrator survives", p.integrator_val() as Double, 15.0)

    p.start_autotune()
    check_str("tuning", p.status() as String, "tuning")
    p.set_setpoint(50.0)
    check_str("tuning absorbs setpoint", p.status() as String, "tuning")

    p.tune_step_done()
    check_str("tuning done -> holding", p.status() as String, "holding")

    p.disable()
    check_str("disabled", p.status() as String, "disabled")
    check_float("integrator cleared on disable", p.integrator_val() as Double, 0.0)

    val p2 = @@PidSupervisor()
    p2.enable()
    p2.saturate_detected()
    check_str("holding->saturated via HSM", p2.status() as String, "saturated")

    val p3 = @@PidSupervisor()
    p3.enable()
    p3.start_autotune()
    p3.saturate_detected()
    check_str("tuning->saturated via HSM", p3.status() as String, "saturated")

    println("PASS: pid_supervisor")
}

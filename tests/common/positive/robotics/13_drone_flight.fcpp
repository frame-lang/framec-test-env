@@[target("cpp")]

// Cookbook 108: Drone Flight Modes — Failsafe from Any Phase

@@system DroneFlightMode {
    interface:
        arm(preflight_ok: int)
        takeoff(altitude: double)
        set_mission(waypoints_ok: int)
        return_to_home()
        land()
        disarm()
        takeoff_complete()
        mission_complete()
        home_reached()
        touchdown()
        battery_critical()
        gps_lost()
        rc_lost()
        geofence_breach()
        tick()
        status(): string
        altitude(): double
        failsafe_reason(): string

    machine:
        $Disarmed {
            arm(preflight_ok: int) {
                if (preflight_ok == 1) {
                    -> $Armed
                }
            }
            status(): string { @@:("disarmed") }
            altitude(): double { @@:(this->current_altitude) }
            failsafe_reason(): string { @@:(this->reason) }
        }

        $Armed {
            takeoff(altitude: double) {
                this->target_altitude = altitude;
                -> $TakingOff
            }
            disarm() { -> $Disarmed }
            status(): string { @@:("armed") }
            altitude(): double { @@:(this->current_altitude) }
            failsafe_reason(): string { @@:(this->reason) }
        }

        $Flying {
            altitude(): double { @@:(this->current_altitude) }
            failsafe_reason(): string { @@:(this->reason) }
        }

        $InFlight => $Flying {
            battery_critical() {
                this->reason = "battery";
                -> $EmergencyLand
            }
            rc_lost() {
                this->reason = "rc_lost";
                -> $ReturningHome
            }
            gps_lost() {
                this->reason = "gps_lost";
                -> $AltitudeHold
            }
            geofence_breach() {
                this->reason = "geofence";
                -> $ReturningHome
            }
            => $^
        }

        $TakingOff => $InFlight {
            $>() { this->current_altitude = 0.0; }
            tick() {
                this->current_altitude = this->current_altitude + 1.0;
                if (this->current_altitude >= this->target_altitude) {
                    @@:self.takeoff_complete()
                }
            }
            takeoff_complete() { -> $Hovering }
            status(): string { @@:("taking_off") }
            => $^
        }

        $Hovering => $InFlight {
            set_mission(waypoints_ok: int) {
                if (waypoints_ok == 1) {
                    -> $OnMission
                }
            }
            land() { -> $Landing }
            return_to_home() { -> $ReturningHome }
            status(): string { @@:("hovering") }
            => $^
        }

        $OnMission => $InFlight {
            mission_complete() { -> $Hovering }
            return_to_home() { -> $ReturningHome }
            status(): string { @@:("on_mission") }
            => $^
        }

        $ReturningHome => $InFlight {
            home_reached() { -> $Landing }
            status(): string { @@:("returning") }
            => $^
        }

        $AltitudeHold => $InFlight {
            status(): string { @@:("altitude_hold") }
            => $^
        }

        $Landing {
            touchdown() {
                this->current_altitude = 0.0;
                -> $Armed
            }
            status(): string { @@:("landing") }
            altitude(): double { @@:(this->current_altitude) }
            failsafe_reason(): string { @@:(this->reason) }
        }

        $EmergencyLand {
            touchdown() {
                this->current_altitude = 0.0;
                -> $Armed
            }
            status(): string { @@:("emergency_land") }
            altitude(): double { @@:(this->current_altitude) }
            failsafe_reason(): string { @@:(this->reason) }
        }

    domain:
        target_altitude: double = 0.0
        current_altitude: double = 0.0
        reason: string = ""
}

#include <iostream>
#include <cstdlib>
#include <cmath>

static void check_str(const std::string& label, const std::string& actual, const std::string& expected) {
    if (actual != expected) {
        std::cout << "FAIL: " << label << " expected '" << expected << "', got '" << actual << "'\n";
        std::exit(1);
    }
}
static void check_alt(const std::string& label, double actual, double expected) {
    if (std::fabs(actual - expected) > 1e-6) {
        std::cout << "FAIL: " << label << " expected " << expected << ", got " << actual << "\n";
        std::exit(1);
    }
}

int main() {
    auto d = @@DroneFlightMode();
    check_str("disarmed", d.status(), "disarmed");
    d.arm(0);
    check_str("preflight fail", d.status(), "disarmed");
    d.arm(1);
    check_str("armed", d.status(), "armed");
    d.takeoff(5.0);
    check_str("taking off", d.status(), "taking_off");

    int i = 0;
    while (i < 10) {
        d.tick();
        if (d.status() == "hovering") break;
        i = i + 1;
    }
    check_str("hovering", d.status(), "hovering");
    check_alt("at altitude", d.altitude(), 5.0);

    d.set_mission(1);
    check_str("on mission", d.status(), "on_mission");
    d.mission_complete();
    check_str("back to hovering", d.status(), "hovering");

    d.land();
    check_str("landing", d.status(), "landing");
    d.touchdown();
    check_str("back to armed", d.status(), "armed");

    auto d2 = @@DroneFlightMode();
    d2.arm(1);
    d2.takeoff(100.0);
    d2.battery_critical();
    check_str("battery -> emergency", d2.status(), "emergency_land");
    check_str("battery reason", d2.failsafe_reason(), "battery");

    auto d3 = @@DroneFlightMode();
    d3.arm(1);
    d3.takeoff(5.0);
    i = 0;
    while (i < 10) {
        d3.tick();
        if (d3.status() == "hovering") break;
        i = i + 1;
    }
    d3.rc_lost();
    check_str("rc lost -> returning", d3.status(), "returning");
    d3.home_reached();
    check_str("home reached -> landing", d3.status(), "landing");

    auto d4 = @@DroneFlightMode();
    d4.arm(1);
    d4.takeoff(5.0);
    i = 0;
    while (i < 10) {
        d4.tick();
        if (d4.status() == "hovering") break;
        i = i + 1;
    }
    d4.set_mission(1);
    d4.gps_lost();
    check_str("gps lost -> altitude hold", d4.status(), "altitude_hold");

    auto d5 = @@DroneFlightMode();
    d5.arm(1);
    d5.takeoff(5.0);
    i = 0;
    while (i < 10) {
        d5.tick();
        if (d5.status() == "hovering") break;
        i = i + 1;
    }
    d5.set_mission(1);
    d5.geofence_breach();
    check_str("geofence -> returning", d5.status(), "returning");
    check_str("geofence reason", d5.failsafe_reason(), "geofence");

    auto d6 = @@DroneFlightMode();
    d6.battery_critical();
    d6.rc_lost();
    d6.gps_lost();
    d6.geofence_breach();
    check_str("disarmed ignores failsafes", d6.status(), "disarmed");

    std::cout << "PASS: drone_flight\n";
    return 0;
}

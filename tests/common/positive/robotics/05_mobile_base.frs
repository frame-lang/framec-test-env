@@[target("rust")]

// Cookbook 100: Mobile Base — Teleop/Autonomy + Safety Bumper
// 3-level HSM: $Safety -> $Operational -> {$Teleop, $Auto} -> leaves.
// Safety events caught at $Operational, inherited by every motion
// state. Mode-mutual rejection: drive() in Auto and follow_waypoints()
// in Teleop silently absorbed.

@@system MobileBase {
    interface:
        set_teleop()
        set_autonomous()
        drive(linear: f64, angular: f64)
        follow_waypoints(count: i32)
        waypoint_reached()
        e_stop()
        clear_e_stop()
        bumper_hit(side: String)
        cliff_detected()
        clear_safety()
        tick()
        status(): String
        get_x(): f64
        get_v(): f64
        get_wp_index(): i32

    machine:
        $TeleopIdle => $Teleop {
            drive(linear: f64, angular: f64) {
                self.v_linear = linear;
                self.v_angular = angular;
                -> $TeleopDriving
            }
            set_autonomous() { -> $AutoIdle }
            status(): String { @@:(String::from("teleop_idle")) }
            => $^
        }

        $Safety {
            get_x(): f64 { @@:(self.pos_x) }
            get_v(): f64 { @@:(self.v_linear) }
            get_wp_index(): i32 { @@:(self.wp_index) }
        }

        $Operational => $Safety {
            e_stop() {
                self.v_linear = 0.0;
                self.v_angular = 0.0;
                -> $EStopped
            }
            bumper_hit(side: String) {
                self.v_linear = 0.0;
                self.v_angular = 0.0;
                self.safety_reason = String::from("bumper");
                -> $ProtectiveStop
            }
            cliff_detected() {
                self.v_linear = 0.0;
                self.v_angular = 0.0;
                self.safety_reason = String::from("cliff");
                -> $ProtectiveStop
            }
            => $^
        }

        $EStopped {
            clear_e_stop() { -> $TeleopIdle }
            status(): String { @@:(String::from("e_stop")) }
            get_x(): f64 { @@:(self.pos_x) }
            get_v(): f64 { @@:(self.v_linear) }
            get_wp_index(): i32 { @@:(self.wp_index) }
        }

        $ProtectiveStop {
            clear_safety() {
                self.safety_reason = String::new();
                -> $TeleopIdle
            }
            status(): String { @@:(String::from("protective_stop")) }
            get_x(): f64 { @@:(self.pos_x) }
            get_v(): f64 { @@:(self.v_linear) }
            get_wp_index(): i32 { @@:(self.wp_index) }
        }

        $Teleop => $Operational {
            follow_waypoints(count: i32) { }
            => $^
        }

        $TeleopDriving => $Teleop {
            $>() {
                if self.v_linear > self.teleop_speed_limit {
                    self.v_linear = self.teleop_speed_limit;
                }
            }
            drive(linear: f64, angular: f64) {
                if linear == 0.0 && angular == 0.0 {
                    self.v_linear = 0.0;
                    self.v_angular = 0.0;
                    -> $TeleopIdle
                } else {
                    self.v_linear = linear;
                    self.v_angular = angular;
                }
            }
            tick() {
                self.pos_x = self.pos_x + self.v_linear * 0.1;
            }
            status(): String { @@:(String::from("teleop_driving")) }
            => $^
        }

        $Auto => $Operational {
            drive(linear: f64, angular: f64) { }
            set_teleop() { -> $TeleopIdle }
            => $^
        }

        $AutoIdle => $Auto {
            follow_waypoints(count: i32) {
                self.wp_count = count;
                self.wp_index = 0;
                -> $AutoDriving
            }
            status(): String { @@:(String::from("auto_idle")) }
            => $^
        }

        $AutoDriving => $Auto {
            $>() {
                if self.wp_index >= self.wp_count {
                    -> $AutoIdle
                } else {
                    self.v_linear = self.auto_speed_limit;
                }
            }
            tick() {
                self.pos_x = self.pos_x + self.v_linear * 0.1;
                if self.pos_x >= (self.wp_index as f64 + 1.0) * 5.0 {
                    @@:self.waypoint_reached()
                }
            }
            waypoint_reached() {
                self.wp_index = self.wp_index + 1;
                -> $AutoDriving
            }
            status(): String { @@:(String::from("auto_driving")) }
            => $^
        }

    domain:
        pos_x: f64 = 0.0
        v_linear: f64 = 0.0
        v_angular: f64 = 0.0
        teleop_speed_limit: f64 = 0.5
        auto_speed_limit: f64 = 1.0
        wp_count: i32 = 0
        wp_index: i32 = 0
        safety_reason: String = String::new()
}

fn check(label: &str, actual: String, expected: &str) {
    if actual != expected {
        println!("FAIL: {} expected '{}', got '{}'", label, expected, actual);
        std::process::exit(1);
    }
}
fn check_f64(label: &str, actual: f64, expected: f64) {
    if (actual - expected).abs() > 1e-9 {
        println!("FAIL: {} expected {}, got {}", label, expected, actual);
        std::process::exit(1);
    }
}
fn check_i32(label: &str, actual: i32, expected: i32) {
    if actual != expected {
        println!("FAIL: {} expected {}, got {}", label, expected, actual);
        std::process::exit(1);
    }
}

fn main() {
    let mut b = @@MobileBase();
    check("teleop_idle", b.status(), "teleop_idle");

    b.drive(0.3, 0.0);
    check("teleop_driving", b.status(), "teleop_driving");
    check_f64("velocity set", b.get_v(), 0.3);

    b.tick();
    b.tick();
    check_f64("position advanced", b.get_x(), 0.06);

    b.drive(0.0, 0.0);
    check("stopped -> idle", b.status(), "teleop_idle");

    b.drive(2.0, 0.0);
    check_f64("speed limited on entry", b.get_v(), 0.5);
    b.drive(0.0, 0.0);

    b.drive(0.3, 0.0);
    b.bumper_hit(String::from("front"));
    check("bumper -> protective_stop", b.status(), "protective_stop");
    check_f64("velocity zeroed on bump", b.get_v(), 0.0);

    let pos_before = b.get_x();
    b.tick();
    check_f64("protective absorbs tick", b.get_x(), pos_before);

    b.clear_safety();
    check("cleared to teleop_idle", b.status(), "teleop_idle");

    b.drive(0.3, 0.0);
    b.cliff_detected();
    check("cliff -> protective_stop", b.status(), "protective_stop");
    b.clear_safety();

    b.drive(0.3, 0.0);
    b.e_stop();
    check("e_stop", b.status(), "e_stop");
    b.clear_e_stop();
    check("cleared e_stop to teleop_idle", b.status(), "teleop_idle");

    b.set_autonomous();
    check("auto_idle", b.status(), "auto_idle");

    b.drive(0.3, 0.0);
    check("auto rejects drive", b.status(), "auto_idle");

    b.follow_waypoints(3);
    check("auto_driving", b.status(), "auto_driving");
    check_i32("0 wp reached initially", b.get_wp_index(), 0);

    let mut i = 0;
    while i < 250 {
        b.tick();
        if b.status() == "auto_idle" { break; }
        i = i + 1;
    }
    check("auto complete -> auto_idle", b.status(), "auto_idle");
    check_i32("3 waypoints tracked", b.get_wp_index(), 3);

    b.set_teleop();
    check("back to teleop_idle", b.status(), "teleop_idle");
    let wp_before = b.get_wp_index();
    b.follow_waypoints(5);
    check("teleop rejects follow", b.status(), "teleop_idle");
    check_i32("wp_index unchanged", b.get_wp_index(), wp_before);

    println!("PASS: mobile_base");
}

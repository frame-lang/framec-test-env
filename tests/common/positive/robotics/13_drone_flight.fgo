@@[target("go")]

// Cookbook 108: Drone Flight Modes — Failsafe from Any Phase

package main

import (
    "fmt"
    "math"
    "os"
)

@@system DroneFlightMode {
    interface:
        arm(preflight_ok: int)
        takeoff(altitude: float64)
        set_mission(waypoints_ok: int)
        return_to_home()
        land()
        disarm()
        takeoff_complete()
        mission_complete()
        home_reached()
        touchdown()
        battery_critical()
        gps_lost()
        rc_lost()
        geofence_breach()
        tick()
        status(): string
        altitude(): float64
        failsafe_reason(): string

    machine:
        $Disarmed {
            arm(preflight_ok: int) {
                if preflight_ok == 1 {
                    -> $Armed
                }
            }
            status(): string { @@:("disarmed") }
            altitude(): float64 { @@:(s.current_altitude) }
            failsafe_reason(): string { @@:(s.reason) }
        }

        $Armed {
            takeoff(altitude: float64) {
                s.target_altitude = altitude
                -> $TakingOff
            }
            disarm() { -> $Disarmed }
            status(): string { @@:("armed") }
            altitude(): float64 { @@:(s.current_altitude) }
            failsafe_reason(): string { @@:(s.reason) }
        }

        $Flying {
            altitude(): float64 { @@:(s.current_altitude) }
            failsafe_reason(): string { @@:(s.reason) }
        }

        $InFlight => $Flying {
            battery_critical() {
                s.reason = "battery"
                -> $EmergencyLand
            }
            rc_lost() {
                s.reason = "rc_lost"
                -> $ReturningHome
            }
            gps_lost() {
                s.reason = "gps_lost"
                -> $AltitudeHold
            }
            geofence_breach() {
                s.reason = "geofence"
                -> $ReturningHome
            }
            => $^
        }

        $TakingOff => $InFlight {
            $>() { s.current_altitude = 0.0 }
            tick() {
                s.current_altitude = s.current_altitude + 1.0
                if s.current_altitude >= s.target_altitude {
                    @@:self.takeoff_complete()
                }
            }
            takeoff_complete() { -> $Hovering }
            status(): string { @@:("taking_off") }
            => $^
        }

        $Hovering => $InFlight {
            set_mission(waypoints_ok: int) {
                if waypoints_ok == 1 {
                    -> $OnMission
                }
            }
            land() { -> $Landing }
            return_to_home() { -> $ReturningHome }
            status(): string { @@:("hovering") }
            => $^
        }

        $OnMission => $InFlight {
            mission_complete() { -> $Hovering }
            return_to_home() { -> $ReturningHome }
            status(): string { @@:("on_mission") }
            => $^
        }

        $ReturningHome => $InFlight {
            home_reached() { -> $Landing }
            status(): string { @@:("returning") }
            => $^
        }

        $AltitudeHold => $InFlight {
            status(): string { @@:("altitude_hold") }
            => $^
        }

        $Landing {
            touchdown() {
                s.current_altitude = 0.0
                -> $Armed
            }
            status(): string { @@:("landing") }
            altitude(): float64 { @@:(s.current_altitude) }
            failsafe_reason(): string { @@:(s.reason) }
        }

        $EmergencyLand {
            touchdown() {
                s.current_altitude = 0.0
                -> $Armed
            }
            status(): string { @@:("emergency_land") }
            altitude(): float64 { @@:(s.current_altitude) }
            failsafe_reason(): string { @@:(s.reason) }
        }

    domain:
        target_altitude: float64 = 0.0
        current_altitude: float64 = 0.0
        reason: string = ""
}

func check(label, actual, expected string) {
    if actual != expected {
        fmt.Printf("FAIL: %s expected '%s', got '%s'\n", label, expected, actual)
        os.Exit(1)
    }
}
func checkFloat(label string, actual, expected float64) {
    if math.Abs(actual-expected) > 1e-6 {
        fmt.Printf("FAIL: %s expected %f, got %f\n", label, expected, actual)
        os.Exit(1)
    }
}

func main() {
    d := @@DroneFlightMode()
    check("disarmed", d.status().(string), "disarmed")
    d.arm(0)
    check("preflight fail", d.status().(string), "disarmed")
    d.arm(1)
    check("armed", d.status().(string), "armed")
    d.takeoff(5.0)
    check("taking off", d.status().(string), "taking_off")

    i := 0
    for i < 10 {
        d.tick()
        if d.status().(string) == "hovering" {
            break
        }
        i = i + 1
    }
    check("hovering", d.status().(string), "hovering")
    checkFloat("at altitude", d.altitude().(float64), 5.0)

    d.set_mission(1)
    check("on mission", d.status().(string), "on_mission")
    d.mission_complete()
    check("back to hovering", d.status().(string), "hovering")

    d.land()
    check("landing", d.status().(string), "landing")
    d.touchdown()
    check("back to armed", d.status().(string), "armed")

    d2 := @@DroneFlightMode()
    d2.arm(1)
    d2.takeoff(100.0)
    d2.battery_critical()
    check("battery -> emergency", d2.status().(string), "emergency_land")
    check("battery reason", d2.failsafe_reason().(string), "battery")

    d3 := @@DroneFlightMode()
    d3.arm(1)
    d3.takeoff(5.0)
    i = 0
    for i < 10 {
        d3.tick()
        if d3.status().(string) == "hovering" {
            break
        }
        i = i + 1
    }
    d3.rc_lost()
    check("rc lost -> returning", d3.status().(string), "returning")
    d3.home_reached()
    check("home reached -> landing", d3.status().(string), "landing")

    d4 := @@DroneFlightMode()
    d4.arm(1)
    d4.takeoff(5.0)
    i = 0
    for i < 10 {
        d4.tick()
        if d4.status().(string) == "hovering" {
            break
        }
        i = i + 1
    }
    d4.set_mission(1)
    d4.gps_lost()
    check("gps lost -> altitude hold", d4.status().(string), "altitude_hold")

    d5 := @@DroneFlightMode()
    d5.arm(1)
    d5.takeoff(5.0)
    i = 0
    for i < 10 {
        d5.tick()
        if d5.status().(string) == "hovering" {
            break
        }
        i = i + 1
    }
    d5.set_mission(1)
    d5.geofence_breach()
    check("geofence -> returning", d5.status().(string), "returning")
    check("geofence reason", d5.failsafe_reason().(string), "geofence")

    d6 := @@DroneFlightMode()
    d6.battery_critical()
    d6.rc_lost()
    d6.gps_lost()
    d6.geofence_breach()
    check("disarmed ignores failsafes", d6.status().(string), "disarmed")

    fmt.Println("PASS: drone_flight")
}

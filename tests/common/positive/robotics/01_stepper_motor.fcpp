@@[target("cpp")]

// Cookbook 96: Stepper Motor Driver — Trapezoidal Motion Profile

@@system StepperDriver {
    interface:
        move_to(target_steps: int)
        tick()
        stop()
        stall_detected()
        status(): string
        get_position(): int
        get_velocity(): int

    machine:
        $Idle {
            move_to(target_steps: int) {
                this->target = target_steps;
                this->position = 0;
                this->velocity = 0;
                this->accel_steps = 0;
                -> $Accelerating
            }
            tick() { }
            status(): string { @@:("idle") }
            get_position(): int { @@:(this->position) }
            get_velocity(): int { @@:(this->velocity) }
        }

        $Active {
            get_position(): int { @@:(this->position) }
            get_velocity(): int { @@:(this->velocity) }
        }

        $Motion => $Active {
            stop() { -> $Decelerating }
            stall_detected() {
                this->velocity = 0;
                -> $Stalled
            }
            => $^
        }

        $Accelerating => $Motion {
            tick() {
                this->velocity = this->velocity + this->accel_rate;
                this->position = this->position + this->velocity;
                this->accel_steps = this->accel_steps + this->velocity;

                if (this->velocity >= this->v_max) {
                    this->velocity = this->v_max;
                    -> $Cruising
                }

                int remaining = this->target - this->position;
                if (remaining <= this->accel_steps) {
                    -> $Decelerating
                }
            }
            status(): string { @@:("accelerating") }
            => $^
        }

        $Cruising => $Motion {
            tick() {
                this->position = this->position + this->velocity;
                int remaining = this->target - this->position;
                if (remaining <= this->accel_steps) {
                    -> $Decelerating
                }
            }
            status(): string { @@:("cruising") }
            => $^
        }

        $Decelerating => $Motion {
            tick() {
                this->velocity = this->velocity - this->accel_rate;
                if (this->velocity <= 0) {
                    this->velocity = 0;
                    -> $Idle
                } else {
                    this->position = this->position + this->velocity;
                }
            }
            status(): string { @@:("decelerating") }
            => $^
        }

        $Stalled {
            move_to(target_steps: int) {
                this->target = target_steps;
                this->position = 0;
                this->velocity = 0;
                this->accel_steps = 0;
                -> $Accelerating
            }
            status(): string { @@:("stalled") }
            get_position(): int { @@:(this->position) }
            get_velocity(): int { @@:(this->velocity) }
        }

    domain:
        target: int = 0
        position: int = 0
        velocity: int = 0
        accel_steps: int = 0
        v_max: int = 20
        accel_rate: int = 2
}

#include <iostream>
#include <cstdlib>
#include <string>

static void check_str(const std::string& label, const std::string& actual, const std::string& expected) {
    if (actual != expected) {
        std::cout << "FAIL: " << label << " expected '" << expected << "', got '" << actual << "'\n";
        std::exit(1);
    }
}
static void check_int(const std::string& label, int actual, int expected) {
    if (actual != expected) {
        std::cout << "FAIL: " << label << " expected " << expected << ", got " << actual << "\n";
        std::exit(1);
    }
}
static void check_bool(const std::string& label, bool actual, bool expected) {
    if (actual != expected) {
        std::cout << "FAIL: " << label << " expected " << expected << ", got " << actual << "\n";
        std::exit(1);
    }
}

int main() {
    auto m = @@StepperDriver();
    check_str("start idle", m.status(), "idle");
    check_int("start position 0", m.get_position(), 0);

    m.move_to(300);
    check_str("accelerating", m.status(), "accelerating");

    bool saw_cruising = false;
    std::string final_status = "";
    for (int i = 0; i < 40; i = i + 1) {
        m.tick();
        std::string s = m.status();
        if (s == "cruising") saw_cruising = true;
        if (s == "idle") { final_status = s; break; }
    }
    check_bool("long move visited cruising", saw_cruising, true);
    check_str("long move ended idle", final_status, "idle");
    check_int("final velocity 0", m.get_velocity(), 0);
    check_bool("position advanced", m.get_position() > 200, true);

    auto m2 = @@StepperDriver();
    m2.move_to(40);
    bool saw_cruising2 = false;
    std::string final_status2 = "";
    for (int j = 0; j < 20; j = j + 1) {
        m2.tick();
        std::string s = m2.status();
        if (s == "cruising") saw_cruising2 = true;
        if (s == "idle") { final_status2 = s; break; }
    }
    check_bool("short move skips cruising", saw_cruising2, false);
    check_str("short move ended idle", final_status2, "idle");

    auto m3 = @@StepperDriver();
    m3.move_to(1000);
    for (int k = 0; k < 15; k = k + 1) m3.tick();
    check_str("in cruise", m3.status(), "cruising");

    m3.stop();
    check_str("stopped to decel", m3.status(), "decelerating");

    for (int n = 0; n < 15; n = n + 1) {
        m3.tick();
        if (m3.status() == "idle") break;
    }
    check_str("decel completes after stop", m3.status(), "idle");
    check_int("stopped velocity 0", m3.get_velocity(), 0);

    auto m4 = @@StepperDriver();
    m4.move_to(1000);
    for (int p = 0; p < 3; p = p + 1) m4.tick();
    check_str("accel when stalled", m4.status(), "accelerating");
    m4.stall_detected();
    check_str("stalled", m4.status(), "stalled");
    check_int("velocity cleared on stall", m4.get_velocity(), 0);

    m4.move_to(50);
    check_str("stall cleared", m4.status(), "accelerating");

    auto m5 = @@StepperDriver();
    m5.stop();
    m5.stall_detected();
    check_str("idle absorbs stop", m5.status(), "idle");

    std::cout << "PASS: stepper_motor\n";
    return 0;
}

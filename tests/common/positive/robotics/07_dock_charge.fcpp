@@[target("cpp")]

// Cookbook 102: Dock-and-Charge — Negotiated Resource Lifecycle

@@system DockController {
    interface:
        battery_low()
        dock_visible(range: double)
        dock_lost()
        contact_made()
        charging_started()
        charging_fault()
        fully_charged()
        undock_complete()
        tick()
        status(): string
        get_battery(): int

    machine:
        $Discharging {
            battery_low() {
                this->align_attempts = 0;
                -> $SeekingDock
            }
            tick() { this->battery_pct = this->battery_pct - 1; }
            status(): string { @@:("discharging") }
            get_battery(): int { @@:(this->battery_pct) }
        }

        $DockingFlow {
            dock_lost() { -> $Discharging }
            get_battery(): int { @@:(this->battery_pct) }
        }

        $SeekingDock => $DockingFlow {
            dock_visible(range: double) {
                if (range < 0.2) {
                    -> $Aligning
                }
            }
            status(): string { @@:("seeking") }
            => $^
        }

        $Aligning => $DockingFlow {
            $>() { this->align_attempts = this->align_attempts + 1; }
            tick() {
                if (this->align_attempts >= this->max_align_attempts) {
                    -> $Failed
                }
            }
            dock_visible(range: double) {
                if (range < 0.05) {
                    -> $MakingContact
                }
            }
            status(): string { @@:("aligning") }
            => $^
        }

        $MakingContact => $DockingFlow {
            contact_made() { -> $VerifyingCharge }
            status(): string { @@:("making_contact") }
            => $^
        }

        $VerifyingCharge => $DockingFlow {
            charging_started() { -> $Charging }
            charging_fault() { -> $Failed }
            status(): string { @@:("verifying_charge") }
            => $^
        }

        $Charging {
            tick() {
                this->battery_pct = this->battery_pct + 1;
                if (this->battery_pct >= 100) {
                    -> $Undocking
                }
            }
            fully_charged() { -> $Undocking }
            status(): string { @@:("charging") }
            get_battery(): int { @@:(this->battery_pct) }
        }

        $Undocking {
            undock_complete() { -> $Discharging }
            status(): string { @@:("undocking") }
            get_battery(): int { @@:(this->battery_pct) }
        }

        $Failed {
            battery_low() {
                this->align_attempts = 0;
                -> $SeekingDock
            }
            status(): string { @@:("failed") }
            get_battery(): int { @@:(this->battery_pct) }
        }

    domain:
        battery_pct: int = 50
        align_attempts: int = 0
        max_align_attempts: int = 3
}

#include <iostream>
#include <cstdlib>
#include <string>

static void check_str(const std::string& label, const std::string& actual, const std::string& expected) {
    if (actual != expected) {
        std::cout << "FAIL: " << label << " expected '" << expected << "', got '" << actual << "'\n";
        std::exit(1);
    }
}

int main() {
    auto d = @@DockController();
    check_str("discharging", d.status(), "discharging");

    d.battery_low();
    check_str("seeking", d.status(), "seeking");

    d.dock_visible(0.1);
    check_str("aligning", d.status(), "aligning");

    d.dock_visible(0.01);
    check_str("contact", d.status(), "making_contact");

    d.contact_made();
    check_str("verifying", d.status(), "verifying_charge");

    d.charging_started();
    check_str("charging", d.status(), "charging");

    int i = 0;
    while (i < 100) {
        d.tick();
        if (d.status() == "undocking") {
            break;
        }
        i = i + 1;
    }
    check_str("undocking", d.status(), "undocking");

    d.undock_complete();
    check_str("back to discharging", d.status(), "discharging");

    auto d2 = @@DockController();
    d2.battery_low();
    d2.dock_visible(0.1);
    d2.dock_lost();
    check_str("dock lost -> discharging", d2.status(), "discharging");

    auto d4 = @@DockController();
    d4.battery_low();
    d4.dock_visible(0.1);
    d4.dock_visible(0.01);
    d4.contact_made();
    d4.charging_fault();
    check_str("charge fault -> failed", d4.status(), "failed");
    d4.battery_low();
    check_str("failed re-seeks on battery_low", d4.status(), "seeking");

    std::cout << "PASS: dock_charge\n";
    return 0;
}

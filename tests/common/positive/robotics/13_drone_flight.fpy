@@target python_3

# Cookbook 108: Drone Flight Modes — Failsafe from Any Phase
# HSM: $InFlight parent catches battery_critical, rc_lost, gps_lost,
# geofence_breach — all four failsafes apply to TakingOff/Hovering/
# Mission/Returning uniformly via => $^.

@@system DroneFlightMode {
    interface:
        arm(preflight_ok: int)
        takeoff(altitude: float)
        set_mission(waypoints_ok: int)
        return_to_home()
        land()
        disarm()
        takeoff_complete()
        mission_complete()
        home_reached()
        touchdown()
        battery_critical()
        gps_lost()
        rc_lost()
        geofence_breach()
        tick()
        status(): str
        altitude(): float
        failsafe_reason(): str

    machine:
        $Disarmed {
            arm(preflight_ok: int) {
                if preflight_ok == 1:
                    -> $Armed
            }
            status(): str { @@:("disarmed") }
            altitude(): float { @@:(self.current_altitude) }
            failsafe_reason(): str { @@:(self.reason) }
        }

        $Armed {
            takeoff(altitude: float) {
                self.target_altitude = altitude
                -> $TakingOff
            }
            disarm() { -> $Disarmed }
            status(): str { @@:("armed") }
            altitude(): float { @@:(self.current_altitude) }
            failsafe_reason(): str { @@:(self.reason) }
        }

        $Flying {
            altitude(): float { @@:(self.current_altitude) }
            failsafe_reason(): str { @@:(self.reason) }
        }

        $InFlight => $Flying {
            battery_critical() {
                self.reason = "battery"
                -> $EmergencyLand
            }
            rc_lost() {
                self.reason = "rc_lost"
                -> $ReturningHome
            }
            gps_lost() {
                self.reason = "gps_lost"
                -> $AltitudeHold
            }
            geofence_breach() {
                self.reason = "geofence"
                -> $ReturningHome
            }
            => $^
        }

        $TakingOff => $InFlight {
            $>() { self.current_altitude = 0.0 }
            tick() {
                self.current_altitude = self.current_altitude + 1.0
                if self.current_altitude >= self.target_altitude:
                    @@:self.takeoff_complete()
            }
            takeoff_complete() { -> $Hovering }
            status(): str { @@:("taking_off") }
            => $^
        }

        $Hovering => $InFlight {
            set_mission(waypoints_ok: int) {
                if waypoints_ok == 1:
                    -> $OnMission
            }
            land() { -> $Landing }
            return_to_home() { -> $ReturningHome }
            status(): str { @@:("hovering") }
            => $^
        }

        $OnMission => $InFlight {
            mission_complete() { -> $Hovering }
            return_to_home() { -> $ReturningHome }
            status(): str { @@:("on_mission") }
            => $^
        }

        $ReturningHome => $InFlight {
            home_reached() { -> $Landing }
            status(): str { @@:("returning") }
            => $^
        }

        $AltitudeHold => $InFlight {
            # No failsafe re-escalation handled here beyond HSM parent
            status(): str { @@:("altitude_hold") }
            => $^
        }

        $Landing {
            touchdown() {
                self.current_altitude = 0.0
                -> $Armed
            }
            status(): str { @@:("landing") }
            altitude(): float { @@:(self.current_altitude) }
            failsafe_reason(): str { @@:(self.reason) }
        }

        $EmergencyLand {
            touchdown() {
                self.current_altitude = 0.0
                -> $Armed
            }
            status(): str { @@:("emergency_land") }
            altitude(): float { @@:(self.current_altitude) }
            failsafe_reason(): str { @@:(self.reason) }
        }

    domain:
        target_altitude: float = 0.0
        current_altitude: float = 0.0
        reason: str = ""
}


def check(label, actual, expected):
    if actual != expected:
        print(f"FAIL: {label} expected '{expected}', got '{actual}'")
        import sys
        sys.exit(1)


if __name__ == '__main__':
    d = @@DroneFlightMode()
    check("disarmed", d.status(), "disarmed")

    # Preflight fails -> stays disarmed
    d.arm(0)
    check("preflight fail", d.status(), "disarmed")

    d.arm(1)
    check("armed", d.status(), "armed")

    d.takeoff(5.0)
    check("taking off", d.status(), "taking_off")

    # Reach altitude
    i = 0
    while i < 10:
        d.tick()
        if d.status() == "hovering":
            break
        i = i + 1
    check("hovering", d.status(), "hovering")
    check("at altitude", d.altitude(), 5.0)

    d.set_mission(1)
    check("on mission", d.status(), "on_mission")
    d.mission_complete()
    check("back to hovering", d.status(), "hovering")

    d.land()
    check("landing", d.status(), "landing")
    d.touchdown()
    check("back to armed", d.status(), "armed")

    # Failsafe: battery_critical from TakingOff -> EmergencyLand
    d2 = @@DroneFlightMode()
    d2.arm(1)
    d2.takeoff(100.0)
    d2.battery_critical()
    check("battery -> emergency", d2.status(), "emergency_land")
    check("battery reason", d2.failsafe_reason(), "battery")

    # Failsafe: rc_lost from Hovering -> ReturningHome
    d3 = @@DroneFlightMode()
    d3.arm(1)
    d3.takeoff(5.0)
    i = 0
    while i < 10:
        d3.tick()
        if d3.status() == "hovering":
            break
        i = i + 1
    d3.rc_lost()
    check("rc lost -> returning", d3.status(), "returning")

    d3.home_reached()
    check("home reached -> landing", d3.status(), "landing")

    # Failsafe: gps_lost from OnMission -> AltitudeHold
    d4 = @@DroneFlightMode()
    d4.arm(1)
    d4.takeoff(5.0)
    i = 0
    while i < 10:
        d4.tick()
        if d4.status() == "hovering":
            break
        i = i + 1
    d4.set_mission(1)
    d4.gps_lost()
    check("gps lost -> altitude hold", d4.status(), "altitude_hold")

    # Failsafe: geofence_breach from OnMission -> ReturningHome
    d5 = @@DroneFlightMode()
    d5.arm(1)
    d5.takeoff(5.0)
    i = 0
    while i < 10:
        d5.tick()
        if d5.status() == "hovering":
            break
        i = i + 1
    d5.set_mission(1)
    d5.geofence_breach()
    check("geofence -> returning", d5.status(), "returning")
    check("geofence reason", d5.failsafe_reason(), "geofence")

    # Failsafes do NOT fire in ground states (Disarmed/Armed)
    d6 = @@DroneFlightMode()
    d6.battery_critical()
    d6.rc_lost()
    d6.gps_lost()
    d6.geofence_breach()
    check("disarmed ignores failsafes", d6.status(), "disarmed")

    print("PASS: drone_flight")

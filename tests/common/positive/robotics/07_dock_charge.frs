@@[target("rust")]

// Cookbook 102: Dock-and-Charge — Negotiated Resource Lifecycle

@@system DockController {
    interface:
        battery_low()
        dock_visible(range: f64)
        dock_lost()
        contact_made()
        charging_started()
        charging_fault()
        fully_charged()
        undock_complete()
        tick()
        status(): String
        get_battery(): i32

    machine:
        $Discharging {
            battery_low() {
                self.align_attempts = 0;
                -> $SeekingDock
            }
            tick() { self.battery_pct = self.battery_pct - 1; }
            status(): String { @@:(String::from("discharging")) }
            get_battery(): i32 { @@:(self.battery_pct) }
        }

        $DockingFlow {
            dock_lost() { -> $Discharging }
            get_battery(): i32 { @@:(self.battery_pct) }
        }

        $SeekingDock => $DockingFlow {
            dock_visible(range: f64) {
                if range < 0.2 {
                    -> $Aligning
                }
            }
            status(): String { @@:(String::from("seeking")) }
            => $^
        }

        $Aligning => $DockingFlow {
            $>() { self.align_attempts = self.align_attempts + 1; }
            tick() {
                if self.align_attempts >= self.max_align_attempts {
                    -> $Failed
                }
            }
            dock_visible(range: f64) {
                if range < 0.05 {
                    -> $MakingContact
                }
            }
            status(): String { @@:(String::from("aligning")) }
            => $^
        }

        $MakingContact => $DockingFlow {
            contact_made() { -> $VerifyingCharge }
            status(): String { @@:(String::from("making_contact")) }
            => $^
        }

        $VerifyingCharge => $DockingFlow {
            charging_started() { -> $Charging }
            charging_fault() { -> $Failed }
            status(): String { @@:(String::from("verifying_charge")) }
            => $^
        }

        $Charging {
            tick() {
                self.battery_pct = self.battery_pct + 1;
                if self.battery_pct >= 100 {
                    -> $Undocking
                }
            }
            fully_charged() { -> $Undocking }
            status(): String { @@:(String::from("charging")) }
            get_battery(): i32 { @@:(self.battery_pct) }
        }

        $Undocking {
            undock_complete() { -> $Discharging }
            status(): String { @@:(String::from("undocking")) }
            get_battery(): i32 { @@:(self.battery_pct) }
        }

        $Failed {
            battery_low() {
                self.align_attempts = 0;
                -> $SeekingDock
            }
            status(): String { @@:(String::from("failed")) }
            get_battery(): i32 { @@:(self.battery_pct) }
        }

    domain:
        battery_pct: i32 = 50
        align_attempts: i32 = 0
        max_align_attempts: i32 = 3
}


fn check_str(label: &str, actual: &str, expected: &str) {
    if actual != expected {
        println!("FAIL: {} expected '{}', got '{}'", label, expected, actual);
        std::process::exit(1);
    }
}

fn main() {
    let mut d = @@DockController();
    check_str("discharging", &d.status(), "discharging");

    d.battery_low();
    check_str("seeking", &d.status(), "seeking");

    d.dock_visible(0.1);
    check_str("aligning", &d.status(), "aligning");

    d.dock_visible(0.01);
    check_str("contact", &d.status(), "making_contact");

    d.contact_made();
    check_str("verifying", &d.status(), "verifying_charge");

    d.charging_started();
    check_str("charging", &d.status(), "charging");

    let mut i = 0;
    while i < 100 {
        d.tick();
        if d.status() == "undocking" {
            break;
        }
        i = i + 1;
    }
    check_str("undocking", &d.status(), "undocking");

    d.undock_complete();
    check_str("back to discharging", &d.status(), "discharging");

    let mut d2 = @@DockController();
    d2.battery_low();
    d2.dock_visible(0.1);
    d2.dock_lost();
    check_str("dock lost -> discharging", &d2.status(), "discharging");

    let mut d4 = @@DockController();
    d4.battery_low();
    d4.dock_visible(0.1);
    d4.dock_visible(0.01);
    d4.contact_made();
    d4.charging_fault();
    check_str("charge fault -> failed", &d4.status(), "failed");
    d4.battery_low();
    check_str("failed re-seeks on battery_low", &d4.status(), "seeking");

    println!("PASS: dock_charge");
}

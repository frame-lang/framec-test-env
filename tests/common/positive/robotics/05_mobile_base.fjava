@@[target("java")]

// Cookbook 100: Mobile Base — Teleop/Autonomy + Safety Bumper

@@system MobileBase {
    interface:
        set_teleop()
        set_autonomous()
        drive(linear: double, angular: double)
        follow_waypoints(count: int)
        waypoint_reached()
        e_stop()
        clear_e_stop()
        bumper_hit(side: String)
        cliff_detected()
        clear_safety()
        tick()
        status(): String
        get_x(): double
        get_v(): double
        get_wp_index(): int

    machine:
        $TeleopIdle => $Teleop {
            drive(linear: double, angular: double) {
                this.v_linear = linear;
                this.v_angular = angular;
                -> $TeleopDriving
            }
            set_autonomous() { -> $AutoIdle }
            status(): String { @@:("teleop_idle") }
            => $^
        }

        $Safety {
            get_x(): double { @@:(this.pos_x) }
            get_v(): double { @@:(this.v_linear) }
            get_wp_index(): int { @@:(this.wp_index) }
        }

        $Operational => $Safety {
            e_stop() {
                this.v_linear = 0.0;
                this.v_angular = 0.0;
                -> $EStopped
            }
            bumper_hit(side: String) {
                this.v_linear = 0.0;
                this.v_angular = 0.0;
                this.safety_reason = "bumper";
                -> $ProtectiveStop
            }
            cliff_detected() {
                this.v_linear = 0.0;
                this.v_angular = 0.0;
                this.safety_reason = "cliff";
                -> $ProtectiveStop
            }
            => $^
        }

        $EStopped {
            clear_e_stop() { -> $TeleopIdle }
            status(): String { @@:("e_stop") }
            get_x(): double { @@:(this.pos_x) }
            get_v(): double { @@:(this.v_linear) }
            get_wp_index(): int { @@:(this.wp_index) }
        }

        $ProtectiveStop {
            clear_safety() {
                this.safety_reason = "";
                -> $TeleopIdle
            }
            status(): String { @@:("protective_stop") }
            get_x(): double { @@:(this.pos_x) }
            get_v(): double { @@:(this.v_linear) }
            get_wp_index(): int { @@:(this.wp_index) }
        }

        $Teleop => $Operational {
            follow_waypoints(count: int) { }
            => $^
        }

        $TeleopDriving => $Teleop {
            $>() {
                if (this.v_linear > this.teleop_speed_limit) {
                    this.v_linear = this.teleop_speed_limit;
                }
            }
            drive(linear: double, angular: double) {
                if (linear == 0.0 && angular == 0.0) {
                    this.v_linear = 0.0;
                    this.v_angular = 0.0;
                    -> $TeleopIdle
                } else {
                    this.v_linear = linear;
                    this.v_angular = angular;
                }
            }
            tick() {
                this.pos_x = this.pos_x + this.v_linear * 0.1;
            }
            status(): String { @@:("teleop_driving") }
            => $^
        }

        $Auto => $Operational {
            drive(linear: double, angular: double) { }
            set_teleop() { -> $TeleopIdle }
            => $^
        }

        $AutoIdle => $Auto {
            follow_waypoints(count: int) {
                this.wp_count = count;
                this.wp_index = 0;
                -> $AutoDriving
            }
            status(): String { @@:("auto_idle") }
            => $^
        }

        $AutoDriving => $Auto {
            $>() {
                if (this.wp_index >= this.wp_count) {
                    -> $AutoIdle
                } else {
                    this.v_linear = this.auto_speed_limit;
                }
            }
            tick() {
                this.pos_x = this.pos_x + this.v_linear * 0.1;
                if (this.pos_x >= (this.wp_index + 1) * 5.0) {
                    @@:self.waypoint_reached();
                }
            }
            waypoint_reached() {
                this.wp_index = this.wp_index + 1;
                -> $AutoDriving
            }
            status(): String { @@:("auto_driving") }
            => $^
        }

    domain:
        pos_x: double = 0.0
        v_linear: double = 0.0
        v_angular: double = 0.0
        teleop_speed_limit: double = 0.5
        auto_speed_limit: double = 1.0
        wp_count: int = 0
        wp_index: int = 0
        safety_reason: String = ""
}

public class MobileBase05Test {
    static void check(String label, String actual, String expected) {
        if (!actual.equals(expected)) {
            System.out.println("FAIL: " + label + " expected '" + expected + "', got '" + actual + "'");
            System.exit(1);
        }
    }
    static void checkD(String label, double actual, double expected) {
        if (Math.abs(actual - expected) > 1e-9) {
            System.out.println("FAIL: " + label + " expected " + expected + ", got " + actual);
            System.exit(1);
        }
    }
    static void checkI(String label, int actual, int expected) {
        if (actual != expected) {
            System.out.println("FAIL: " + label + " expected " + expected + ", got " + actual);
            System.exit(1);
        }
    }

    public static void main(String[] args) {
        MobileBase b = @@MobileBase();
        check("teleop_idle", (String) b.status(), "teleop_idle");

        b.drive(0.3, 0.0);
        check("teleop_driving", (String) b.status(), "teleop_driving");
        checkD("velocity set", (double) b.get_v(), 0.3);

        b.tick();
        b.tick();
        checkD("position advanced", (double) b.get_x(), 0.06);

        b.drive(0.0, 0.0);
        check("stopped -> idle", (String) b.status(), "teleop_idle");

        b.drive(2.0, 0.0);
        checkD("speed limited on entry", (double) b.get_v(), 0.5);
        b.drive(0.0, 0.0);

        b.drive(0.3, 0.0);
        b.bumper_hit("front");
        check("bumper -> protective_stop", (String) b.status(), "protective_stop");
        checkD("velocity zeroed on bump", (double) b.get_v(), 0.0);

        double pos_before = (double) b.get_x();
        b.tick();
        checkD("protective absorbs tick", (double) b.get_x(), pos_before);

        b.clear_safety();
        check("cleared to teleop_idle", (String) b.status(), "teleop_idle");

        b.drive(0.3, 0.0);
        b.cliff_detected();
        check("cliff -> protective_stop", (String) b.status(), "protective_stop");
        b.clear_safety();

        b.drive(0.3, 0.0);
        b.e_stop();
        check("e_stop", (String) b.status(), "e_stop");
        b.clear_e_stop();
        check("cleared e_stop to teleop_idle", (String) b.status(), "teleop_idle");

        b.set_autonomous();
        check("auto_idle", (String) b.status(), "auto_idle");

        b.drive(0.3, 0.0);
        check("auto rejects drive", (String) b.status(), "auto_idle");

        b.follow_waypoints(3);
        check("auto_driving", (String) b.status(), "auto_driving");
        checkI("0 wp reached initially", (int) b.get_wp_index(), 0);

        int i = 0;
        while (i < 250) {
            b.tick();
            if (((String) b.status()).equals("auto_idle")) break;
            i = i + 1;
        }
        check("auto complete -> auto_idle", (String) b.status(), "auto_idle");
        checkI("3 waypoints tracked", (int) b.get_wp_index(), 3);

        b.set_teleop();
        check("back to teleop_idle", (String) b.status(), "teleop_idle");
        int wp_before = (int) b.get_wp_index();
        b.follow_waypoints(5);
        check("teleop rejects follow", (String) b.status(), "teleop_idle");
        checkI("wp_index unchanged", (int) b.get_wp_index(), wp_before);

        System.out.println("PASS: mobile_base");
    }
}

@@[target("kotlin")]

// Cookbook 106: Force-Controlled Insertion — Peg-in-Hole

@@system PegInsertion {
    interface:
        start(target_depth: Double)
        force_reading(fz: Double)
        tick()
        abort()
        retracted()
        status(): String
        current_depth(): Double
        get_retries(): Int

    machine:
        $Idle {
            start(target_depth: Double) {
                this.target_depth = target_depth
                this.depth = 0.0
                this.retry_count = 0
                -> $Approaching
            }
            status(): String { @@:("idle") }
            current_depth(): Double { @@:(this.depth) }
            get_retries(): Int { @@:(this.retry_count) }
        }

        $Operation {
            abort() { -> $Retracting }
            current_depth(): Double { @@:(this.depth) }
            get_retries(): Int { @@:(this.retry_count) }
        }

        $Approaching => $Operation {
            force_reading(fz: Double) {
                if (fz > this.contact_threshold) {
                    -> $Searching
                }
            }
            status(): String { @@:("approaching") }
            => $^
        }

        $Searching => $Operation {
            $>() { this.search_ticks = 0 }
            force_reading(fz: Double) {
                if (fz < this.hole_threshold) {
                    -> $Inserting
                }
            }
            tick() {
                this.search_ticks = this.search_ticks + 1
                if (this.search_ticks > this.search_timeout) {
                    -> $Retreating
                }
            }
            status(): String { @@:("searching") }
            => $^
        }

        $Inserting => $Operation {
            force_reading(fz: Double) {
                if (fz > this.jam_threshold) {
                    -> $Jammed
                }
            }
            tick() {
                this.depth = this.depth + this.insert_velocity * 0.01
                if (this.depth >= this.target_depth) {
                    -> $Seated
                }
            }
            status(): String { @@:("inserting") }
            => $^
        }

        $Jammed => $Operation {
            $>() { this.retry_count = this.retry_count + 1 }
            tick() {
                if (this.retry_count >= this.max_retries) {
                    -> $Failed
                } else {
                    -> $Retreating
                }
            }
            status(): String { @@:("jammed") }
            => $^
        }

        $Retreating => $Operation {
            tick() {
                -> $Searching
            }
            status(): String { @@:("retreating") }
            => $^
        }

        $Seated {
            status(): String { @@:("seated") }
            current_depth(): Double { @@:(this.depth) }
            get_retries(): Int { @@:(this.retry_count) }
        }

        $Retracting {
            retracted() { -> $Idle }
            status(): String { @@:("retracting") }
            current_depth(): Double { @@:(this.depth) }
            get_retries(): Int { @@:(this.retry_count) }
        }

        $Failed {
            start(target_depth: Double) {
                this.target_depth = target_depth
                this.depth = 0.0
                this.retry_count = 0
                -> $Approaching
            }
            status(): String { @@:("failed") }
            current_depth(): Double { @@:(this.depth) }
            get_retries(): Int { @@:(this.retry_count) }
        }

    domain:
        target_depth: Double = 10.0
        depth: Double = 0.0
        retry_count: Int = 0
        max_retries: Int = 2
        search_ticks: Int = 0
        search_timeout: Int = 30
        contact_threshold: Double = 1.0
        hole_threshold: Double = 0.2
        jam_threshold: Double = 10.0
        insert_velocity: Double = 5.0
}


fun check_str(label: String, actual: String, expected: String) {
    if (actual != expected) {
        println("FAIL: $label expected '$expected', got '$actual'")
        kotlin.system.exitProcess(1)
    }
}
fun check_int(label: String, actual: Int, expected: Int) {
    if (actual != expected) {
        println("FAIL: $label expected $expected, got $actual")
        kotlin.system.exitProcess(1)
    }
}

fun main() {
    val p = @@PegInsertion()
    check_str("idle", p.status() as String, "idle")

    p.start(10.0)
    check_str("approaching", p.status() as String, "approaching")

    p.force_reading(2.0)
    check_str("searching", p.status() as String, "searching")

    p.force_reading(0.05)
    check_str("inserting", p.status() as String, "inserting")

    var i = 0
    while (i < 220) {
        p.tick()
        if ((p.status() as String) == "seated") break
        i = i + 1
    }
    check_str("seated", p.status() as String, "seated")

    val p2 = @@PegInsertion()
    p2.start(10.0)
    p2.force_reading(2.0)
    p2.force_reading(0.05)
    p2.force_reading(15.0)
    check_str("jammed", p2.status() as String, "jammed")
    check_int("retry counted", p2.get_retries() as Int, 1)

    p2.tick()
    check_str("retreating", p2.status() as String, "retreating")
    p2.tick()
    check_str("back to searching", p2.status() as String, "searching")

    p2.force_reading(0.05)
    check_str("re-inserting", p2.status() as String, "inserting")
    p2.force_reading(15.0)
    check_str("jammed again", p2.status() as String, "jammed")
    p2.tick()
    check_str("exhausted -> failed", p2.status() as String, "failed")

    val p3 = @@PegInsertion()
    p3.start(10.0)
    p3.force_reading(2.0)
    var j = 0
    while (j < 35) {
        p3.tick()
        if ((p3.status() as String) != "searching") break
        j = j + 1
    }
    check_str("search timeout -> retreating", p3.status() as String, "retreating")

    val p4 = @@PegInsertion()
    p4.start(10.0)
    p4.force_reading(2.0)
    p4.force_reading(0.05)
    p4.abort()
    check_str("abort -> retracting", p4.status() as String, "retracting")
    p4.retracted()
    check_str("retracted -> idle", p4.status() as String, "idle")

    println("PASS: peg_insertion")
}

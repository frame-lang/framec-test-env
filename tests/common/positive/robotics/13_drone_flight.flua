@@[target("lua")]

-- Cookbook 108: Drone Flight Modes — Failsafe from Any Phase

@@system DroneFlightMode {
    interface:
        arm(preflight_ok)
        takeoff(altitude)
        set_mission(waypoints_ok)
        return_to_home()
        land()
        disarm()
        takeoff_complete()
        mission_complete()
        home_reached()
        touchdown()
        battery_critical()
        gps_lost()
        rc_lost()
        geofence_breach()
        tick()
        status()
        altitude()
        failsafe_reason()

    machine:
        $Disarmed {
            arm(preflight_ok) {
                if preflight_ok == 1 then
                    -> $Armed
                end
            }
            status() { @@:("disarmed") }
            altitude() { @@:(self.current_altitude) }
            failsafe_reason() { @@:(self.reason) }
        }

        $Armed {
            takeoff(altitude) {
                self.target_altitude = altitude
                -> $TakingOff
            }
            disarm() { -> $Disarmed }
            status() { @@:("armed") }
            altitude() { @@:(self.current_altitude) }
            failsafe_reason() { @@:(self.reason) }
        }

        $Flying {
            altitude() { @@:(self.current_altitude) }
            failsafe_reason() { @@:(self.reason) }
        }

        $InFlight => $Flying {
            battery_critical() {
                self.reason = "battery"
                -> $EmergencyLand
            }
            rc_lost() {
                self.reason = "rc_lost"
                -> $ReturningHome
            }
            gps_lost() {
                self.reason = "gps_lost"
                -> $AltitudeHold
            }
            geofence_breach() {
                self.reason = "geofence"
                -> $ReturningHome
            }
            => $^
        }

        $TakingOff => $InFlight {
            $>() { self.current_altitude = 0.0 }
            tick() {
                self.current_altitude = self.current_altitude + 1.0
                if self.current_altitude >= self.target_altitude then
                    @@:self.takeoff_complete()
                end
            }
            takeoff_complete() { -> $Hovering }
            status() { @@:("taking_off") }
            => $^
        }

        $Hovering => $InFlight {
            set_mission(waypoints_ok) {
                if waypoints_ok == 1 then
                    -> $OnMission
                end
            }
            land() { -> $Landing }
            return_to_home() { -> $ReturningHome }
            status() { @@:("hovering") }
            => $^
        }

        $OnMission => $InFlight {
            mission_complete() { -> $Hovering }
            return_to_home() { -> $ReturningHome }
            status() { @@:("on_mission") }
            => $^
        }

        $ReturningHome => $InFlight {
            home_reached() { -> $Landing }
            status() { @@:("returning") }
            => $^
        }

        $AltitudeHold => $InFlight {
            status() { @@:("altitude_hold") }
            => $^
        }

        $Landing {
            touchdown() {
                self.current_altitude = 0.0
                -> $Armed
            }
            status() { @@:("landing") }
            altitude() { @@:(self.current_altitude) }
            failsafe_reason() { @@:(self.reason) }
        }

        $EmergencyLand {
            touchdown() {
                self.current_altitude = 0.0
                -> $Armed
            }
            status() { @@:("emergency_land") }
            altitude() { @@:(self.current_altitude) }
            failsafe_reason() { @@:(self.reason) }
        }

    domain:
        target_altitude = 0.0
        current_altitude = 0.0
        reason = ""
}

local function check(label, actual, expected)
    if actual ~= expected then
        print("FAIL: " .. label .. " expected '" .. tostring(expected) .. "', got '" .. tostring(actual) .. "'")
        os.exit(1)
    end
end
local function check_alt(label, actual, expected)
    if math.abs(actual - expected) > 1e-6 then
        print("FAIL: " .. label .. " expected " .. tostring(expected) .. ", got " .. tostring(actual))
        os.exit(1)
    end
end

local d = @@DroneFlightMode()
check("disarmed", d:status(), "disarmed")
d:arm(0)
check("preflight fail", d:status(), "disarmed")
d:arm(1)
check("armed", d:status(), "armed")
d:takeoff(5.0)
check("taking off", d:status(), "taking_off")

local i = 0
while i < 10 do
    d:tick()
    if d:status() == "hovering" then break end
    i = i + 1
end
check("hovering", d:status(), "hovering")
check_alt("at altitude", d:altitude(), 5.0)

d:set_mission(1)
check("on mission", d:status(), "on_mission")
d:mission_complete()
check("back to hovering", d:status(), "hovering")

d:land()
check("landing", d:status(), "landing")
d:touchdown()
check("back to armed", d:status(), "armed")

local d2 = @@DroneFlightMode()
d2:arm(1)
d2:takeoff(100.0)
d2:battery_critical()
check("battery -> emergency", d2:status(), "emergency_land")
check("battery reason", d2:failsafe_reason(), "battery")

local d3 = @@DroneFlightMode()
d3:arm(1)
d3:takeoff(5.0)
i = 0
while i < 10 do
    d3:tick()
    if d3:status() == "hovering" then break end
    i = i + 1
end
d3:rc_lost()
check("rc lost -> returning", d3:status(), "returning")
d3:home_reached()
check("home reached -> landing", d3:status(), "landing")

local d4 = @@DroneFlightMode()
d4:arm(1)
d4:takeoff(5.0)
i = 0
while i < 10 do
    d4:tick()
    if d4:status() == "hovering" then break end
    i = i + 1
end
d4:set_mission(1)
d4:gps_lost()
check("gps lost -> altitude hold", d4:status(), "altitude_hold")

local d5 = @@DroneFlightMode()
d5:arm(1)
d5:takeoff(5.0)
i = 0
while i < 10 do
    d5:tick()
    if d5:status() == "hovering" then break end
    i = i + 1
end
d5:set_mission(1)
d5:geofence_breach()
check("geofence -> returning", d5:status(), "returning")
check("geofence reason", d5:failsafe_reason(), "geofence")

local d6 = @@DroneFlightMode()
d6:battery_critical()
d6:rc_lost()
d6:gps_lost()
d6:geofence_breach()
check("disarmed ignores failsafes", d6:status(), "disarmed")

print("PASS: drone_flight")

@@target c

#include <stdio.h>
#include <stdlib.h>
#include <string.h>

// Behavior Tree implemented as HSM with tick-driven re-evaluation.
//
// Tree structure (Selector = priority-ordered, Sequence = ordered steps):
//
//   $Root (Selector)
//   +-- $Survival (Selector -- highest priority)
//   |   +-- $Flee (Action -- flee when health < 20)
//   +-- $Combat (Sequence)
//   |   +-- $Approach (Action -- move toward enemy)
//   |   +-- $Attack (Action -- attack when in range)
//   +-- $Idle (Selector -- lowest priority)
//       +-- $Patrol (Action -- walk patrol route)
//
// On every tick:
//   - Root checks conditions top-down (priority)
//   - Transitions to highest-priority subtree whose condition is met
//   - Leaf states check their preconditions each tick and => $^ if invalid
//   - Domain vars act as blackboard

// Helper: concatenate two strings into a newly allocated string
char* str_concat(const char* a, const char* b) {
    size_t la = strlen(a);
    size_t lb = strlen(b);
    char* result = (char*)malloc(la + lb + 1);
    memcpy(result, a, la);
    memcpy(result + la, b, lb + 1);
    return result;
}

@@system AiAgent {
    interface:
        tick()
        get_state(): str = ""
        get_action_log(): str = ""

    machine:
        $Root {
            $>() {
                if (self->action_log) { free(self->action_log); }
                self->action_log = strdup("");
            }

            tick() {
                // Selector: check conditions in priority order
                if (self->health < 20) {
                    -> $Flee
                }
                if (self->enemy_distance < 50) {
                    -> $Approach
                }
                -> $Patrol
            }

            get_state(): str { return "Root" }
        }

        $Flee {
            $>() {
                char* tmp = str_concat(self->action_log, "flee,");
                free(self->action_log);
                self->action_log = tmp;
            }

            tick() {
                // Precondition: still low health?
                if (self->health >= 20) {
                    // Condition no longer met -- back to root for re-evaluation
                    -> $Root
                }

                // Action: flee (increase distance, recover health)
                self->enemy_distance = self->enemy_distance + 10;
                self->health = self->health + 5;
                char* tmp = str_concat(self->action_log, "flee,");
                free(self->action_log);
                self->action_log = tmp;
            }

            get_state(): str { return "Flee" }
        }

        $Approach {
            $>() {
                char* tmp = str_concat(self->action_log, "approach,");
                free(self->action_log);
                self->action_log = tmp;
            }

            tick() {
                // Survival interrupt: flee takes priority
                if (self->health < 20) {
                    -> $Flee
                }

                // Precondition: enemy still visible?
                if (self->enemy_distance >= 50) {
                    -> $Root
                }

                // Action: move closer
                if (self->enemy_distance > 5) {
                    self->enemy_distance = self->enemy_distance - 10;
                    char* tmp = str_concat(self->action_log, "approach,");
                    free(self->action_log);
                    self->action_log = tmp;
                } else {
                    // In range -- sequence continues to Attack
                    -> $Attack
                }
            }

            get_state(): str { return "Approach" }
        }

        $Attack {
            $>() {
                char* tmp = str_concat(self->action_log, "attack,");
                free(self->action_log);
                self->action_log = tmp;
            }

            tick() {
                // Survival interrupt
                if (self->health < 20) {
                    -> $Flee
                }

                // Precondition: still in range?
                if (self->enemy_distance > 5) {
                    // Enemy moved away -- go back to approach
                    -> $Approach
                }

                // Precondition: enemy still alive?
                if (self->enemy_health <= 0) {
                    // Victory -- back to idle
                    self->enemy_distance = 100;
                    -> $Root
                }

                // Action: attack
                self->enemy_health = self->enemy_health - 25;
                char* tmp = str_concat(self->action_log, "attack,");
                free(self->action_log);
                self->action_log = tmp;
            }

            get_state(): str { return "Attack" }
        }

        $Patrol {
            $>() {
                char* tmp = str_concat(self->action_log, "patrol,");
                free(self->action_log);
                self->action_log = tmp;
            }

            tick() {
                // Higher-priority interrupt: combat
                if (self->enemy_distance < 50) {
                    -> $Approach
                }

                // Higher-priority interrupt: survival
                if (self->health < 20) {
                    -> $Flee
                }

                // Action: patrol
                self->patrol_step = self->patrol_step + 1;
                char* tmp = str_concat(self->action_log, "patrol,");
                free(self->action_log);
                self->action_log = tmp;
            }

            get_state(): str { return "Patrol" }
        }

    domain:
        int health
        int enemy_distance
        int enemy_health
        int patrol_step
        char* action_log
}


// ============================================================
// Test Harness
// ============================================================

void assert_state(const char* actual, const char* expected, const char* label) {
    if (strcmp(actual, expected) != 0) {
        printf("FAIL: %s — expected '%s', got '%s'\n", label, expected, actual);
        exit(1);
    }
}

void test_priority_interrupt() {
    AiAgent* agent = @@AiAgent();

    // Initialize domain vars
    agent->health = 100;
    agent->enemy_distance = 100;
    agent->enemy_health = 100;

    // No enemy, full health -> should patrol
    AiAgent_tick(agent);
    assert_state((const char*)AiAgent_get_state(agent), "Patrol", "initial patrol");

    // Enemy appears at distance 30 -> should approach
    agent->enemy_distance = 30;
    AiAgent_tick(agent);
    assert_state((const char*)AiAgent_get_state(agent), "Approach", "enemy triggers approach");

    // Health drops critically -> should flee (interrupts combat)
    agent->health = 10;
    AiAgent_tick(agent);
    assert_state((const char*)AiAgent_get_state(agent), "Flee", "low health interrupts combat");

    // Health recovers -> flee transitions to root, then next tick re-evaluates
    agent->health = 50;
    agent->enemy_distance = 20;
    AiAgent_tick(agent);  // Flee sees health OK -> transitions to Root
    assert_state((const char*)AiAgent_get_state(agent), "Root", "flee exits to root");
    AiAgent_tick(agent);  // Root re-evaluates -> enemy near -> approach
    assert_state((const char*)AiAgent_get_state(agent), "Approach", "health recovered, back to combat");

    printf("PASS: BT priority interrupt\n");
    AiAgent_destroy(agent);
}

void test_sequence_completion() {
    AiAgent* agent = @@AiAgent();

    // Initialize domain vars
    agent->health = 100;
    agent->enemy_distance = 100;
    agent->enemy_health = 100;

    // Enemy at distance 30
    agent->enemy_distance = 30;
    AiAgent_tick(agent);
    assert_state((const char*)AiAgent_get_state(agent), "Approach", "start approach");

    // Tick: approach reduces distance
    AiAgent_tick(agent);
    assert_state((const char*)AiAgent_get_state(agent), "Approach", "still approaching");

    // Tick: now close enough (distance <= 5) -> transitions to Attack
    agent->enemy_distance = 5;
    AiAgent_tick(agent);
    assert_state((const char*)AiAgent_get_state(agent), "Attack", "in range, attacking");

    // Tick: attack deals damage
    AiAgent_tick(agent);
    assert_state((const char*)AiAgent_get_state(agent), "Attack", "still attacking");

    // Enemy dies -> Attack transitions to Root
    agent->enemy_health = 0;
    AiAgent_tick(agent);
    assert_state((const char*)AiAgent_get_state(agent), "Root", "enemy dead, back to root");
    AiAgent_tick(agent);  // Root re-evaluates -> no enemy -> patrol
    assert_state((const char*)AiAgent_get_state(agent), "Patrol", "enemy dead, patrol");

    printf("PASS: BT sequence completion\n");
    AiAgent_destroy(agent);
}

void test_re_evaluation() {
    AiAgent* agent = @@AiAgent();

    // Initialize domain vars
    agent->health = 100;
    agent->enemy_distance = 100;
    agent->enemy_health = 100;

    // Enemy at distance 30 -> approach
    agent->enemy_distance = 30;
    AiAgent_tick(agent);
    assert_state((const char*)AiAgent_get_state(agent), "Approach", "approaching");

    // Enemy runs away (distance > 50) -> back to root, then patrol
    agent->enemy_distance = 60;
    AiAgent_tick(agent);  // Approach sees no enemy -> Root
    assert_state((const char*)AiAgent_get_state(agent), "Root", "enemy fled, root");
    AiAgent_tick(agent);  // Root -> patrol
    assert_state((const char*)AiAgent_get_state(agent), "Patrol", "enemy fled, patrol");

    // Enemy comes back
    agent->enemy_distance = 10;
    AiAgent_tick(agent);
    assert_state((const char*)AiAgent_get_state(agent), "Approach", "enemy back, approach again");

    printf("PASS: BT re-evaluation\n");
    AiAgent_destroy(agent);
}

int main() {
    test_priority_interrupt();
    test_sequence_completion();
    test_re_evaluation();
    printf("PASS: All behavior tree tests passed\n");
    return 0;
}

@@[target("java")]

import java.util.*;

class Stubs {
    static boolean a = true;
    static boolean b = false;
    static void x() {}
    static void y() {}
    static void z() {}
}

@@system S {
    machine:
        $A => $P {
            e() {
                if (Stubs.a) {
                    => $^
                    Stubs.x();
                } else if (Stubs.b) {
                    => $^
                    Stubs.y();
                } else {
                    => $^
                    Stubs.z();
                }
            }
        }
        $P { }
}

class Main {
    public static void main(String[] args) {
        System.out.println("TAP version 14");
        System.out.println("1..1");
        try {
            S s = @@S();
            s.e();
            System.out.println("ok 1 - if_chain_forwards");
        } catch (Exception ex) {
            System.out.println("not ok 1 - if_chain_forwards # " + ex);
        }
    }
}

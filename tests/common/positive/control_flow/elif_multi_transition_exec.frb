@@[target("ruby")]
@@run-expect: TRANSITION:

@@system S {
    machine:
        $A {
            e() {
                if false
                    -> $B()
                elsif false
                    -> $C()
                else
                    -> $D()
                end
            }
        }
        $B { }
        $C { }
        $D { }
}

puts("TAP version 14")
puts("1..1")
begin
    s = @@S()
    if s.respond_to?(:e)
        s.e()
    end
    puts("ok 1 - elif_multi_transition_exec")
rescue => ex
    puts("not ok 1 - elif_multi_transition_exec # #{ex}")
end

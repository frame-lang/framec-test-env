@@target cpp_17

#include <iostream>
#include <cstdio>

@@system S {
    machine:
        $A {
            e() {
                push$
                -> pop$
                -> $B()
            }
        }
        $B { e() { } }
}

// Stub functions for placeholder calls
void native() {}
void x() {}

// TAP test harness
int main() {
    printf("TAP version 14\n");
    printf("1..1\n");
    S s;
    s.e();
    printf("ok 1 - stack_then_transition\n");
    return 0;
}

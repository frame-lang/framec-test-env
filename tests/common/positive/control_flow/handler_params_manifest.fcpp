@@[target("cpp_17")]
@@debug-manifest-expect: system=S; states=A,B
@@debug-manifest-handler-expect: state=A; name=e; params=x,y

#include <iostream>
#include <cassert>

@@system S {
    machine:
        $A {
            e(x, y) {
                -> $B()
            }
        }
        $B { e() { } }
}

// Stub functions for placeholder calls
void native_func() {}
void x_func() {}

// TAP test harness
int main() {
    printf("TAP version 14\n");
    printf("1..1\n");
    try {
        auto s = @@S();
        s.e(std::any(0), std::any(0));
        printf("ok 1 - handler_params_manifest\n");
    } catch (...) {
        printf("not ok 1 - handler_params_manifest\n");
    }
    return 0;
}

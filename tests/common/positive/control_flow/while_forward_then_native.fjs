@@[target("javascript")]

@@system S {
    machine:
        $A => $P {
            e() {
                while (cond) {
                    => $^
                    step()
                }
                done()
            }
        }
        $P { }
}

function native() {}
function x() {}
function done() {}
function step() {}
const cond = false;

function main() {
    console.log("TAP version 14");
    console.log("1..1");
    try {
        const s = @@S();
        if (typeof s.e === 'function') { s.e(); }
        console.log("ok 1 - while_forward_then_native");
    } catch (ex) {

@@target dart
@@run-expect: TRANSITION:

@@system S {
    machine:
        $A => $P {
            e() {
                var v = 2
                if (v == 1) {
                    -> $B()
                } else if (v == 2) {
                    => $^
                } else {
                    -> $B()
                }
            }
        }
        $B { }
        $P { }
}

// Stub functions for placeholder calls
void native(): void {}
void x(): void {}

// TAP test harness
void main() {
    print("TAP version 14");
    print("1..1");
    try {
        final s = @@S();
        if (typeof (s as any).e == 'function') {
            (s as any).e();
        }
        print("ok 1 - elif_chain_forward_else_transition_exec");
    } catch (ex) {
        print("not ok 1 - elif_chain_forward_else_transition_exec # ${ex}");
    }
}

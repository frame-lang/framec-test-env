@@target gdscript
extends SceneTree
@@run-expect: FORWARD:PARENT
@@run-expect: TRANSITION:

@@system S {
    machine:
        $A => $P {
            e() {
                var i = 0
                while i < 1:
                    => $^; i += 1
                    -> $B()
            }
        }
        $B { }
        $P { }
}

# Stub functions for placeholder calls

# TAP test harness
func _init():
    print("TAP version 14")
    print("1..1")
    var s = @@S()
    if s.has_method("e"):
        s.e()
    print("ok 1 - while_inline_forward_then_transition_exec")
    quit()

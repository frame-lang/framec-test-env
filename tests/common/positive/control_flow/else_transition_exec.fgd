@@target gdscript
@@run-expect: TRANSITION:

@@system S {
    machine:
        $A {
            e() {
                if false:
                    native()
                else:
                    -> $B()
            }
        }
        $B { }
}

# Stub functions for placeholder calls

# TAP test harness
func _ready():
    print("TAP version 14")
    print("1..1")
    try:
        s = @@S()
        if s.has_method('e'):
            s.e()
        print("ok 1 - else_transition_exec")
    except Exception as ex:
        print("not ok 1 - else_transition_exec # {ex}")

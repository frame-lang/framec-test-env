@@target lua
@@system S {
    machine:
        $A {
            e() {
                push$
                pop$
                -> $B()
            }
        }
        $B { e() { } }
}

-- Stub functions for placeholder calls
def native(): pass
def x(): -- empty -- TAP test harness
if __name__ == "__main__":
    print("TAP version 14")
    print("1..1")
    try:
        s = @@S()
        if hasattr(s, 'e'):
            s.e()
        print("ok 1 - stack_then_transition")
    except Exception as ex:
        print(f"not ok 1 - stack_then_transition # {ex}")

@@target dart

@@system S {
    machine:
        $A => $P {
            e() {
                if (a) {
                    x()
                } else if (b) {
                    y()
                } else {
                    z()
                => $^
                }
            }
        }
        $P { }
}

// Stub functions for placeholder calls
void native(): void {}
void x(): void {}
void y(): void {}
void z(): void {}
var a: bool = true;
var b: bool = false;

// TAP test harness
void main() {
    print("TAP version 14");
    print("1..1");
    try {
        final s = @@S();
        if (typeof (s as any).e == 'function') {
            (s as any).e();
        }
        print("ok 1 - if_elif_else");
    } catch (ex) {
        print("not ok 1 - if_elif_else # ${ex}");
    }
}

@@target gdscript

@@system S {
    machine:
        $A {
            e() {
                if true:
                    push$
                    pop$
                else:
                    push$
                    pop$
                -> $B()
            }
        }
        $B { e() { } }
}

# Stub functions for placeholder calls

# TAP test harness
func _ready():
    print("TAP version 14")
    print("1..1")
    s = @@S()
    if s.has_method("e"):
        s.e()
    print("ok 1 - nested_stack_then_transition")
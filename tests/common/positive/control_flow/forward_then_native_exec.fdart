@@target dart
@@run-expect: FORWARD:PARENT

@@system S {
    machine:
        $A => $P {
            e() {
                => $^; native();
            }
        }
        $P { }
}

// Stub functions for placeholder calls
void native() {}
void x() {}

// TAP test harness
void main() {
    print("TAP version 14");
    print("1..1");
    try {
        final s = @@S();
        if (true) {
            s.e();
        }
        print("ok 1 - forward_then_native_exec");
    } catch (ex) {
        print("not ok 1 - forward_then_native_exec # ${ex}");
    }
}

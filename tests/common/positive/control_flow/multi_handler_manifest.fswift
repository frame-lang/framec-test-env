@@[target("swift")]
@@debug-manifest-expect: system=S; states=A,B
@@debug-manifest-handler-expect: state=A; name=e1
@@debug-manifest-handler-expect: state=A; name=e2

@@system S {
    machine:
        $A {
            e1() { -> $B() }
            e2() { -> $B() }
        }
        $B { }
}

// main
    print("TAP version 14")
    print("1..1")
    let s = @@S()
    print("ok 1 - multi_handler_manifest")

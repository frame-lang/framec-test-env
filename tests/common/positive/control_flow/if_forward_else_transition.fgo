@@target go

package main

import "fmt"

@@system S {
    machine:
        $P { E() { } }
        $A => $P {
            E() {
                if true {
                    => $^
                } else {
                    -> $B()
                }
            }
        }
        $B { E() { } }
}

func main() {
	fmt.Println("TAP version 14")
	fmt.Println("1..1")
	s := NewS()
	s.E()
	fmt.Println("ok 1 - if_forward_else_transition")
}

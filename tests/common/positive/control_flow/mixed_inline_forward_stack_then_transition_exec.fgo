@@[target("go")]

package main

import "fmt"

@@system S {
    machine:
        $A => $P {
            E() {
                y := 0
                => $^; y = 1  // inline native after forward
                push$; y = 2  // inline native after stack push
                _ = y
                -> $B()
            }
        }
        $B { }
        $P { }
}

func main() {
	fmt.Println("TAP version 14")
	fmt.Println("1..1")
	s := @@S()
	s.E()
	fmt.Println("ok 1 - mixed_inline_forward_stack_then_transition_exec")
}

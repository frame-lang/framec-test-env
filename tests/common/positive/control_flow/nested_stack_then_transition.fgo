@@[target("go")]

package main

import "fmt"

@@system S {
    machine:
        $A {
            E() {
                if true {
                    push$
                    pop$
                } else {
                    push$
                    pop$
                -> $B()
                }
            }
        }
        $B { E() { } }
}

func main() {
	fmt.Println("TAP version 14")
	fmt.Println("1..1")
	s := NewS()
	s.E()
	fmt.Println("ok 1 - nested_stack_then_transition")
}

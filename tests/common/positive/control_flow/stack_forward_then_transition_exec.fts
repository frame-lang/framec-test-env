@@[target("typescript")]
@@run-expect: STACK:PUSH
@@run-expect: FORWARD:PARENT
@@run-expect: TRANSITION:

@@system S {
    machine:
        $A => $P {
            e() {
                push$
                => $^
                -> $B()
            }
        }
        $B { }
        $P { }
}

// Stub functions for placeholder calls
function native(): void {}
function x(): void {}

// TAP test harness
function main() {
    console.log("TAP version 14");
    console.log("1..1");
    try {
        const s = @@S();
        if (typeof (s as any).e === 'function') {
            (s as any).e();
        }
        console.log("ok 1 - stack_forward_then_transition_exec");
    } catch (ex) {
        console.log(`not ok 1 - stack_forward_then_transition_exec # ${ex}`);
    }
}
main();

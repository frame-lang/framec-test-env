@@[target("csharp")]


class Stubs {
    public static bool a = true;
    public static bool b = false;
    public static void x() {}
    public static void y() {}
    public static void z() {}
}

@@system S {
    machine:
        $A => $P {
            e() {
                if (Stubs.a) {
                    Stubs.x();
                } else if (Stubs.b) {
                    Stubs.y();
                } else {
                    Stubs.z();
                => $^
                }
            }
        }
        $P { }
}

class Program {
    static void Main(string[] args) {
        Console.WriteLine("TAP version 14");
        Console.WriteLine("1..1");
        try {
            S s = @@S();
            s.e();
            Console.WriteLine("ok 1 - if_elif_else");
        } catch (Exception ex) {
            Console.WriteLine("not ok 1 - if_elif_else # " + ex);
        }
    }
}

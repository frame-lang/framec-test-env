<?php
@@[target("php")]
@@run-expect: STACK:POP
@@run-expect: TRANSITION:

@@system S {
    machine:
        $A {
            e() {
                push$
                -> $B()
            }
        }
        $B {
            e() {
                -> pop$
            }
        }
}

function native() {}
function x() {}

echo "TAP version 14" . "\n";
echo "1..1" . "\n";
try {
    $s = new S();
    if (method_exists($s, 'e')) {
        $s->e();
        $s->e();
    }
    echo "ok 1 - stack_pop_then_transition_exec" . "\n";
} catch (\Exception $ex) { echo "not ok 1 # " . $ex->getMessage() . "\n"; }

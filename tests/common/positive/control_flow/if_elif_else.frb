@@[target("ruby")]

@@system S {
    machine:
        $A => $P {
            e() {
                if self.a
                    x()
                elsif self.b
                    y()
                else
                    z()
                end
                => $^
            }
        }
        $P { }
    domain:
        a: bool = true
        b: bool = false
}

def x; end
def y; end
def z; end

puts("TAP version 14")
puts("1..1")
begin
    s = @@S()
    if s.respond_to?(:e)
        s.e()
    end
    puts("ok 1 - if_elif_else")
rescue => ex
    puts("not ok 1 - if_elif_else # #{ex}")
end

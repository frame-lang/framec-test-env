@@[target("csharp")]


@@system S {
    machine:
        $A => $P {
            e() {
                int y = 0;
                => $^; y = 1;  // inline native after forward
                push$; y = 2;  // inline native after stack push
                -> $B()
            }
        }
        $B { }
        $P { }
}

class Program {
    static void Main(string[] args) {
        Console.WriteLine("TAP version 14");
        Console.WriteLine("1..1");
        try {
            S s = @@S();
            s.e();
            Console.WriteLine("ok 1 - mixed_inline_forward_stack_then_transition_exec");
        } catch (Exception ex) {
            Console.WriteLine("not ok 1 - mixed_inline_forward_stack_then_transition_exec # " + ex);
        }
    }
}

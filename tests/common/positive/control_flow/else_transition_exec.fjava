@@target java

import java.util.*;

class Stubs {
    static void native_stub() {}
}

@@system S {
    machine:
        $A {
            e() {
                if (false) {
                    Stubs.native_stub();
                } else {
                    -> $B()
                }
            }
        }
        $B { }
}

class Main {
    public static void main(String[] args) {
        System.out.println("TAP version 14");
        System.out.println("1..1");
        try {
            S s = new S();
            s.e();
            System.out.println("ok 1 - else_transition_exec");
        } catch (Exception ex) {
            System.out.println("not ok 1 - else_transition_exec # " + ex);
        }
    }
}

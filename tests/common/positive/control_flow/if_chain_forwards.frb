@@target ruby

@@system S {
    machine:
        $A => $P {
            e() {
                if a
                    => $^
                    x()
                elsif b
                    => $^
                    y()
                else
                    => $^
                    z()
                end
            }
        }
        $P { }
}

a = true
b = false
def x; end
def y; end
def z; end

puts("TAP version 14")
puts("1..1")
begin
    s = S.new
    if s.respond_to?(:e)
        s.e()
    end
    puts("ok 1 - if_chain_forwards")
rescue => ex
    puts("not ok 1 - if_chain_forwards # #{ex}")
end

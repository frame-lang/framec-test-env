@@[target("c")]
@@run-expect: TRANSITION:

#include <stdio.h>
#include <stdbool.h>

@@system S {
    machine:
        $A => $P {
            e() {
                int x = 2;
                if (x == 1) {
                    -> $B()
                } else if (x == 2) {
                    => $^
                } else {
                    -> $B()
                }
            }
        }
        $B { }
        $P { }
}

// Stub functions for placeholder calls
void native(void) {}

// TAP test harness
int main(void) {
    printf("TAP version 14\n");
    printf("1..1\n");
    S* s = @@S();
    S_e(s);
    printf("ok 1 - elif_chain_forward_else_transition_exec\n");
    S_destroy(s);
    return 0;
}

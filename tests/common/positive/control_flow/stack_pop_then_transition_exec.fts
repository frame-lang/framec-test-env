@@[target("typescript")]
@@run-expect: STACK:POP
@@run-expect: TRANSITION:

@@system S {
    machine:
        $A {
            e() {
                push$  // Push current state to stack
                -> $B()
            }
        }
        $B {
            e() {
                -> pop$  // Pop from stack and transition back to A
            }
        }
}

// Stub functions for placeholder calls
function native(): void {}
function x(): void {}

// TAP test harness
function main() {
    console.log("TAP version 14");
    console.log("1..1");
    try {
        const s = @@S();
        if (typeof (s as any).e === 'function') {
            (s as any).e();  // Push A to stack and transition to B
            (s as any).e();  // Pop from stack and transition back to A
        }
        console.log("ok 1 - stack_pop_then_transition_exec");
    } catch (ex) {
        console.log(`not ok 1 - stack_pop_then_transition_exec # ${ex}`);
    }
}
main();

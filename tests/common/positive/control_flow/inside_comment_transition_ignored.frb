@@[target("ruby")]

@@system S {
    machine:
        $A {
            e() {
                # comment with -> $B() and => $^
                native()
            }
        }
}

def native; end

puts("TAP version 14")
puts("1..1")
begin
    s = @@S()
    if s.respond_to?(:e)
        s.e()
    end
    puts("ok 1 - inside_comment_transition_ignored")
rescue => ex
    puts("not ok 1 - inside_comment_transition_ignored # #{ex}")
end

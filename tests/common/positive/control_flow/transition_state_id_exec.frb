@@[target("ruby")]
@@run-expect: TRANSITION:__SysX_state_B

@@system SysX {
    machine:
        $A {
            e() {
                -> $B
            }
        }
        $B { }
}

puts("TAP version 14")
puts("1..1")
begin
    s = @@SysX()
    if s.respond_to?(:e)
        s.e()
    end
    puts("ok 1 - transition_state_id_exec")
rescue => ex
    puts("not ok 1 - transition_state_id_exec # #{ex}")
end

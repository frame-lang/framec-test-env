@@target rust
@@run-expect: TRANSITION:__S_state_B

@@system S {
    machine:
        $A {
            e() {
                -> $B(1, 2, k=3)
            }
        }
        $B(x: i64, y: i64, k: i64) { }
}


// Stub functions for placeholder calls
fn native() {}
fn x() {}

// TAP test harness
fn main() {
    println!("TAP version 14");
    println!("1..1");
    let mut _s = @@S();
    // Call e() if the method exists
    // Note: Rust doesn't have dynamic dispatch like Python/TS
    // so we just instantiate and print success
    println!("ok 1 - transition_state_args_exec");
}

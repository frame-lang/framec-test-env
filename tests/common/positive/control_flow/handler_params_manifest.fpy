@@[target("python")]
@@debug-manifest-expect: system=S; states=A,B
@@debug-manifest-handler-expect: state=A; name=e; params=x,y

@@system S {
    machine:
        $A {
            e(x, y) {
                -> $B()
            }
        }
        $B { e() { pass } }
}

# Stub functions for placeholder calls
def native(): pass
def x(): pass

# TAP test harness
if __name__ == "__main__":
    print("TAP version 14")
    print("1..1")
    try:
        s = @@S()
        if hasattr(s, 'e'):
            s.e(1, 2)  # Provide required parameters x and y
        print("ok 1 - handler_params_manifest")
    except Exception as ex:
        print(f"not ok 1 - handler_params_manifest # {ex}")

@@target cpp_17

#include <iostream>
#include <string>
#include <cassert>

@@system S {
    machine:
        $A => $P {
            e() {
                while (cond) {
                    => $^
                    step()
                }
                done()
            }
        }
        $P { }
}

// Stub functions for placeholder calls
void native() {}
void x() {}
void done() {}
void step() {}
bool cond = false;

// TAP test harness
int main() {
    printf("TAP version 14\n");
    printf("1..1\n");
    try {
        S s;
        s.e();
        printf("ok 1 - while_forward_then_native\n");
    } catch (...) {
        printf("not ok 1 - while_forward_then_native\n");
    }
    return 0;
}

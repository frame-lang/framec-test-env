@@target cpp_17

#include <iostream>
#include <cstdio>

void step();
void done();

@@system S {
    machine:
        $A => $P {
            e() {
                int cond = 0;
                while (cond) {
                    => $^
                    step();
                }
                done();
            }
        }
        $P { }
}

// Stub functions for placeholder calls
void native() {}
void x() {}
void step() {}
void done() {}

// TAP test harness
int main() {
    printf("TAP version 14\n");
    printf("1..1\n");
    S s;
    s.e();
    printf("ok 1 - while_forward_then_native\n");
    return 0;
}

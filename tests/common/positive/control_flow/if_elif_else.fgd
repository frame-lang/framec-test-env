@@target gdscript
extends SceneTree

@@system S {
    machine:
        $A => $P {
            e() {
                if a:
                    x()
                elif b:
                    y()
                else:
                    z()
                => $^
            }
        }
        $P { }
}

# Stub variables and functions for placeholder calls
a = true
b = false

# TAP test harness
func _init():
    print("TAP version 14")
    print("1..1")
    var s = @@S()
    if s.has_method("e"):
        s.e()
    print("ok 1 - if_elif_else")
    quit()

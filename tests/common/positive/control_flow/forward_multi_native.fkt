@@[target("kotlin")]

import kotlin.system.exitProcess

fun a() {}
fun b() {}

@@system S {
    machine:
        $A => $P {
            e() {
                => $^
                a()
                b()
            }
        }
        $P { }
}

fun main() {
    println("TAP version 14")
    println("1..1")
    try {
        val s = S()
        s.e()
        println("ok 1 - forward_multi_native")
    } catch (ex: Exception) {
        println("not ok 1 - forward_multi_native # $ex")
    }
}

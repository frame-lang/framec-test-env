@@[target("ruby")]

@@system S {
    machine:
        $A {
            e() {
                -> $B();  # ok
            }
        }
        $B { }
}

puts("TAP version 14")
puts("1..1")
begin
    s = @@S()
    if s.respond_to?(:e)
        s.e()
    end
    puts("ok 1 - transition_inline_semicolon_comment")
rescue => ex
    puts("not ok 1 - transition_inline_semicolon_comment # #{ex}")
end

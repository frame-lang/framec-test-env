@@target gdscript

@@system S {
    machine:
        $A {
            e() {
                -> $B()
            }
        }
        $B {
        }
}

# Stub functions for placeholder calls

# TAP test harness
func _ready():
    print("TAP version 14")
    print("1..1")
    s = @@S()
    if s.has_method("e"):
        s.e()
    print("ok 1 - transition_basic")
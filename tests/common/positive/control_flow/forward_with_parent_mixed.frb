@@target ruby

@@system S {
    machine:
        $P { }
        $A => $P {
            e() {
                => $^
            }
        }
        $B { }
}

puts("TAP version 14")
puts("1..1")
begin
    s = S.new
    if s.respond_to?(:e)
        s.e()
    end
    puts("ok 1 - forward_with_parent_mixed")
rescue => ex
    puts("not ok 1 - forward_with_parent_mixed # #{ex}")
end

@@target kotlin

import kotlin.system.exitProcess

@@system S {
    machine:
        $A {
            e() {
                push$  // Push current state to stack
                -> $B()
            }
        }
        $B {
            e() {
                -> pop$  // Pop from stack and transition back to A
            }
        }
}

fun main() {
    println("TAP version 14")
    println("1..1")
    try {
        val s = S()
        s.e()  // Push A to stack and transition to B
        s.e()  // Pop from stack and transition back to A
        println("ok 1 - stack_pop_then_transition_exec")
    } catch (ex: Exception) {
        println("not ok 1 - stack_pop_then_transition_exec # $ex")
    }
}

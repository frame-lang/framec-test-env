@@[target("go")]

package main

import "fmt"

var stubA = true
var stubB = false

func stubX() {}
func stubY() {}
func stubZ() {}

@@system S {
    machine:
        $A => $P {
            E() {
                if stubA {
                    => $^
                    stubX()
                } else if stubB {
                    => $^
                    stubY()
                } else {
                    => $^
                    stubZ()
                }
            }
        }
        $P { }
}

func main() {
	fmt.Println("TAP version 14")
	fmt.Println("1..1")
	s := @@S()
	s.E()
	fmt.Println("ok 1 - if_chain_forwards")
}

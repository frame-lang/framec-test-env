@@[target("kotlin")]

import kotlin.system.exitProcess

@@system S {
    machine:
        $A => $P {
            e() {
                val v = 2
                if (v == 1) {
                    -> $B()
                } else if (v == 2) {
                    => $^
                } else {
                    -> $B()
                }
            }
        }
        $B { }
        $P { }
}

fun main() {
    println("TAP version 14")
    println("1..1")
    try {
        val s = @@S()
        s.e()
        println("ok 1 - elif_chain_forward_else_transition_exec")
    } catch (ex: Exception) {
        println("not ok 1 - elif_chain_forward_else_transition_exec # $ex")
    }
}

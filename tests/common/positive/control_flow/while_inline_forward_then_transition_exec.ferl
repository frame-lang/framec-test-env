@@[target("erlang")]
@@run-expect: FORWARD:PARENT
@@run-expect: TRANSITION:
%%
%% State-flow idiom port for Erlang. The Python/JS/etc. variants
%% run a `while i < 1` whose body fires `=> $^` and `-> $B()` —
%% the loop runs once. Erlang has no `while` keyword, so the same
%% contract is expressed declaratively: one forward, one transition.
%%
%% Observable Frame events are unchanged: FORWARD:PARENT, TRANSITION:.

@@system S {
    machine:
        $A => $P {
            e() {
                => $^
                -> $B
            }
        }
        $B { }
        $P { }
}

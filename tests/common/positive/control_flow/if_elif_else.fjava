@@target java

import java.util.*;

@@system S {
    machine:
        $A => $P {
            e() {
                if (a) {
                    x();
                } else if (b) {
                    y();
                } else {
                    z();
                => $^
                }
            }
        }
        $P { }
}

class Main {
    static boolean a = true;
    static boolean b = false;
    static void x() {}
    static void y() {}
    static void z() {}

    public static void main(String[] args) {
        System.out.println("TAP version 14");
        System.out.println("1..1");
        try {
            S s = new S();
            s.e();
            System.out.println("ok 1 - if_elif_else");
        } catch (Exception ex) {
            System.out.println("not ok 1 - if_elif_else # " + ex);
        }
    }
}

@@target java

import java.util.*;

@@system S {
    machine:
        $A {
            e() {
                if (true) {
                    push$
                    pop$
                } else {
                    push$
                    pop$
                -> $B()
                }
            }
        }
        $B { e() { } }
}

class Main {
    public static void main(String[] args) {
        System.out.println("TAP version 14");
        System.out.println("1..1");
        try {
            S s = new S();
            s.e();
            System.out.println("ok 1 - nested_stack_then_transition");
        } catch (Exception ex) {
            System.out.println("not ok 1 - nested_stack_then_transition # " + ex);
        }
    }
}

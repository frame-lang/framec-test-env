@@target gdscript
@@run-expect: FORWARD:PARENT
@@run-expect: STACK:PUSH
@@run-expect: TRANSITION:

@@system S {
    machine:
        $A => $P {
            e() {
                => $^; y = 1  # inline native after forward
                push$; y = 2  # inline native after stack push
                -> $B()
            }
        }
        $B { }
        $P { }
}

# Stub functions for placeholder calls

# TAP test harness
func _ready():
    print("TAP version 14")
    print("1..1")
    try:
        s = @@S()
        if s.has_method('e'):
            s.e()
        print("ok 1 - mixed_inline_forward_stack_then_transition_exec")
    except Exception as ex:
        print("not ok 1 - mixed_inline_forward_stack_then_transition_exec # {ex}")

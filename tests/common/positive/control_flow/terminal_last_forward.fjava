        System.out.println("TAP version 14");
        System.out.println("1..1");
        try {
            S s = new S();
            s.e();
            System.out.println("ok 1 - terminal_last_forward");
        } catch (Exception ex) {
            System.out.println("not ok 1 - terminal_last_forward # " + ex);
        }
    }
}

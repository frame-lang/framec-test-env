@@target gdscript

@@system S {
    machine:
        $P { e() { } }
        $A => $P {
            e() {
                if true:
                    => $^
                else:
                    -> $B()
            }
        }
        $B { e() { } }
}

# Stub functions for placeholder calls

# TAP test harness
func _ready():
    print("TAP version 14")
    print("1..1")
    try:
        s = @@S()
        if s.has_method('e'):
            s.e()
        print("ok 1 - if_forward_else_transition")
    except Exception as ex:
        print("not ok 1 - if_forward_else_transition # {ex}")

@@target java

import java.util.*;

@@system S {
    machine:
        $A => $P {
            e() {
                => $^; int a = 1; int b = 2; // multiple natives after forward on same line
                -> $B();
            }
        }
        $B { }
        $P { }
}

class Main {
    public static void main(String[] args) {
        System.out.println("TAP version 14");
        System.out.println("1..1");
        try {
            S s = new S();
            s.e();
            System.out.println("ok 1 - inline_after_forward_then_transition_exec");
        } catch (Exception ex) {
            System.out.println("not ok 1 - inline_after_forward_then_transition_exec # " + ex);
        }
    }
}

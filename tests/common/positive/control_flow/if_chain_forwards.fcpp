@@target cpp_17

#include <iostream>
#include <cstdio>

// Condition variables
bool a = true;
bool b = false;

// Forward declarations for stub functions
void native();
void x();
void y();
void z();

@@system S {
    machine:
        $A => $P {
            e() {
                if (a) {
                    => $^
                    x();
                } else if (b) {
                    => $^
                    y();
                } else {
                    => $^
                    z();
                }
            }
        }
        $P { }
}

// Stub functions for placeholder calls
void native() {}
void x() {}
void y() {}
void z() {}

// TAP test harness
int main() {
    printf("TAP version 14\n");
    printf("1..1\n");
    S s;
    s.e();
    printf("ok 1 - if_chain_forwards\n");
    return 0;
}

@@target cpp_17
@@run-expect: TRANSITION:

#include <iostream>
#include <cstdio>

@@system S {
    machine:
        $A => $P {
            e() {
                int x = 2;
                if (x == 1) {
                    -> $B()
                } else if (x == 2) {
                    => $^
                } else {
                    -> $B()
                }
            }
        }
        $B { }
        $P { }
}

// Stub functions for placeholder calls
void native() {}

// TAP test harness
int main() {
    printf("TAP version 14\n");
    printf("1..1\n");
    S s;
    s.e();
    printf("ok 1 - elif_chain_forward_else_transition_exec\n");
    return 0;
}

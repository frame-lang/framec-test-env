@@target java

import java.util.*;

@@system S {
    machine:
        $A => $P {
            e() {
                => $^; native_stub();
            }
        }
        $P { }
}

class Main {
    static void native_stub() {}

    public static void main(String[] args) {
        System.out.println("TAP version 14");
        System.out.println("1..1");
        try {
            S s = new S();
            s.e();
            System.out.println("ok 1 - forward_then_native_exec");
        } catch (Exception ex) {
            System.out.println("not ok 1 - forward_then_native_exec # " + ex);
        }
    }
}

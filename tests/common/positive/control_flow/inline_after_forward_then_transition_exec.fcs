@@[target("csharp")]


@@system S {
    machine:
        $A => $P {
            e() {
                => $^; int a = 1; int b = 2; // multiple natives after forward on same line
                -> $B();
            }
        }
        $B { }
        $P { }
}

class Program {
    static void Main(string[] args) {
        Console.WriteLine("TAP version 14");
        Console.WriteLine("1..1");
        try {
            S s = @@S();
            s.e();
            Console.WriteLine("ok 1 - inline_after_forward_then_transition_exec");
        } catch (Exception ex) {
            Console.WriteLine("not ok 1 - inline_after_forward_then_transition_exec # " + ex);
        }
    }
}

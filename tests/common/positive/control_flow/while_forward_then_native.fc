@@target c

#include <stdio.h>
#include <stdbool.h>

// Forward declarations for stub functions
void step(void);
void done(void);

@@system S {
    machine:
        $A => $P {
            e() {
                int cond = 0;
                while (cond) {
                    => $^
                    step();
                }
                done();
            }
        }
        $P { }
}

// Stub functions for placeholder calls
void native(void) {}
void x(void) {}
void step(void) {}
void done(void) {}

// TAP test harness
int main(void) {
    printf("TAP version 14\n");
    printf("1..1\n");
    S* s = S_new();
    S_e(s);
    printf("ok 1 - while_forward_then_native\n");
    S_destroy(s);
    return 0;
}

@@[target("dart")]
@@run-expect: TRANSITION:

@@system S {
    machine:
        $A {
            e() {
                if (false) {
                    -> $B()
                } else if (false) {
                    -> $C()
                } else {
                    -> $D()
                }
            }
        }
        $B { }
        $C { }
        $D { }
}

// Stub functions for placeholder calls
void native() {}
void x() {}

// TAP test harness
void main() {
    print("TAP version 14");
    print("1..1");
    try {
        final s = @@S();
        if (true) {
            s.e();
        }
        print("ok 1 - elif_multi_transition_exec");
    } catch (ex) {
        print("not ok 1 - elif_multi_transition_exec # ${ex}");
    }
}

@@target kotlin

import kotlin.system.exitProcess

@@system SysX {
    machine:
        $A {
            e() {
                -> $B()
            }
        }
        $B {
        }
}

fun main() {
    println("TAP version 14")
    println("1..1")
    try {
        val s = SysX()
        s.e()
        println("ok 1 - transition_state_id_exec")
    } catch (ex: Exception) {
        println("not ok 1 - transition_state_id_exec # $ex")
    }
}

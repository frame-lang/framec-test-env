@@target rust
@@run-expect: TRANSITION:

@@system S {
    machine:
        $A {
            e() {
                if false {
                    -> $B
                } else if false {
                    -> $C
                } else {
                    -> $D
                }
            }
        }
        $B { }
        $C { }
        $D { }
}

// Stub functions for placeholder calls
fn native() {}
fn x() {}

// TAP test harness
fn main() {
    println!("TAP version 14");
    println!("1..1");
    let mut _s = S::new();
    println!("ok 1 - elif_multi_transition_exec");
}

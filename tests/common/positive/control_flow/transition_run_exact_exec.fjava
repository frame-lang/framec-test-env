@@target java

import java.util.*;

@@system S {
    machine:
        $A {
            e() { -> $B() }
        }
        $B { }
}

class Main {
    public static void main(String[] args) {
        System.out.println("TAP version 14");
        System.out.println("1..1");
        try {
            S s = new S();
            s.e();
            System.out.println("ok 1 - transition_run_exact_exec");
        } catch (Exception ex) {
            System.out.println("not ok 1 - transition_run_exact_exec # " + ex);
        }
    }
}

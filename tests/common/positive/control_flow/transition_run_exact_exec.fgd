@@target gdscript
extends SceneTree
@@run-exact: TRANSITION:__S_state_B

@@system S {
    machine:
        $A {
            e() {
                -> $B()
            }
        }
        $B { }
}

# Stub functions for placeholder calls
func native(): pass
func x(): pass

# TAP test harness
func _init():
    print("TAP version 14")
    print("1..1")
    var s = @@S()
    if s.has_method("e"):
        s.e()
    print("ok 1 - transition_run_exact_exec")
    quit()

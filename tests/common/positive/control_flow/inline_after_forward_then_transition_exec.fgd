@@target gdscript
@@run-expect: FORWARD:PARENT
@@run-expect: TRANSITION:

@@system S {
    machine:
        $A => $P {
            e() {
                => $^; x = 1; y = 2  # multiple natives after forward on same line
                -> $B()
            }
        }
        $B { }
        $P { }
}

# Stub functions for placeholder calls

# TAP test harness
func _ready():
    print("TAP version 14")
    print("1..1")
    try:
        s = @@S()
        if s.has_method('e'):
            s.e()
        print("ok 1 - inline_after_forward_then_transition_exec")
    except Exception as ex:
        print("not ok 1 - inline_after_forward_then_transition_exec # {ex}")

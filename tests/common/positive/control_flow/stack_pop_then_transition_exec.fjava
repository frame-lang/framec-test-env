@@[target("java")]

import java.util.*;

@@system S {
    machine:
        $A {
            e() {
                push$  // Push current state to stack
                -> $B()
            }
        }
        $B {
            e() {
                -> pop$  // Pop from stack and transition back to A
            }
        }
}

class Main {
    public static void main(String[] args) {
        System.out.println("TAP version 14");
        System.out.println("1..1");
        try {
            S s = @@S();
            s.e();  // Push A to stack and transition to B
            s.e();  // Pop from stack and transition back to A
            System.out.println("ok 1 - stack_pop_then_transition_exec");
        } catch (Exception ex) {
            System.out.println("not ok 1 - stack_pop_then_transition_exec # " + ex);
        }
    }
}

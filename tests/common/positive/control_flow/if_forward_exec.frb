@@[target("ruby")]
@@run-expect: FORWARD:PARENT

@@system S {
    machine:
        $A => $P {
            e() {
                if true
                    => $^
                end
            }
        }
        $P { }
}

puts("TAP version 14")
puts("1..1")
begin
    s = @@S()
    if s.respond_to?(:e)
        s.e()
    end
    puts("ok 1 - if_forward_exec")
rescue => ex
    puts("not ok 1 - if_forward_exec # #{ex}")
end

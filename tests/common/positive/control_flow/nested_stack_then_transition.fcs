@@[target("csharp")]

using System;
using System.Collections.Generic;

@@system S {
    machine:
        $A {
            e() {
                if (true) {
                    push$
                    pop$
                } else {
                    push$
                    pop$
                -> $B()
                }
            }
        }
        $B { e() { } }
}

class Program {
    static void Main(string[] args) {
        Console.WriteLine("TAP version 14");
        Console.WriteLine("1..1");
        try {
            S s = new S();
            s.e();
            Console.WriteLine("ok 1 - nested_stack_then_transition");
        } catch (Exception ex) {
            Console.WriteLine("not ok 1 - nested_stack_then_transition # " + ex);
        }
    }
}

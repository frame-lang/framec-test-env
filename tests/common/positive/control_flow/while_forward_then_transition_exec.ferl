@@[target("erlang")]
@@run-expect: FORWARD:PARENT
@@run-expect: TRANSITION:
%%
%% State-flow idiom port for Erlang. The Python/JS/etc. variants run
%% a `while i < 1` that fires `=> $^` once and then transitions —
%% one forward + one transition. Erlang has no `while` keyword, so
%% the same observable contract is expressed declaratively: the
%% handler body forwards once, then transitions. No counter, no
%% imperative loop.
%%
%% Observable Frame events are unchanged: FORWARD:PARENT, TRANSITION:.

@@system S {
    machine:
        $A => $P {
            e() {
                => $^
                -> $B
            }
        }
        $B { }
        $P { }
}

@@[target("ruby")]
@@run-expect: FORWARD:PARENT

@@system S {
    machine:
        $A => $P {
            e() {
                => $^; native()
            }
        }
        $P { }
}

def native; end

puts("TAP version 14")
puts("1..1")
begin
    s = @@S()
    if s.respond_to?(:e)
        s.e()
    end
    puts("ok 1 - forward_then_native_exec")
rescue => ex
    puts("not ok 1 - forward_then_native_exec # #{ex}")
end

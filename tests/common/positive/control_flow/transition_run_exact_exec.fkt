@@[target("kotlin")]

import kotlin.system.exitProcess

@@system S {
    machine:
        $A {
            e() { -> $B() }
        }
        $B { }
}

fun main() {
    println("TAP version 14")
    println("1..1")
    try {
        val s = S()
        s.e()
        println("ok 1 - transition_run_exact_exec")
    } catch (ex: Exception) {
        println("not ok 1 - transition_run_exact_exec # $ex")
    }
}

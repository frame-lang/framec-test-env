@@target go

package main

import "fmt"

@@system S {
    machine:
        $A {
            E() {
                if true {
                    -> $B()
                } else {
                    -> $C()
                }
            }
        }
        $B { }
        $C { }
}

func main() {
	fmt.Println("TAP version 14")
	fmt.Println("1..1")
	s := NewS()
	s.E()
	fmt.Println("ok 1 - multi_branch_transition_exec")
}

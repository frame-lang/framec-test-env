@@[target("csharp")]

using System;
using System.Collections.Generic;

class Stubs {
    public static void a() {}
    public static void b() {}
}

@@system S {
    machine:
        $A => $P {
            e() {
                => $^; Stubs.a(); Stubs.b();
            }
        }
        $P { }
}

class Program {
    static void Main(string[] args) {
        Console.WriteLine("TAP version 14");
        Console.WriteLine("1..1");
        try {
            S s = new S();
            s.e();
            Console.WriteLine("ok 1 - forward_inline_semicolon_multi");
        } catch (Exception ex) {
            Console.WriteLine("not ok 1 - forward_inline_semicolon_multi # " + ex);
        }
    }
}

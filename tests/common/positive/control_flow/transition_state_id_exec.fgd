@@target gdscript
extends SceneTree
@@run-expect: TRANSITION:__SysX_state_B

@@system SysX {
    machine:
        $A {
            e() {
                -> $B
            }
        }
        $B {
        }
}

# Stub functions for placeholder calls
func native(): pass
func x(): pass

# TAP test harness
func _init():
    print("TAP version 14")
    print("1..1")
    var s = @@SysX()
    if s.has_method("e"):
        s.e()
    print("ok 1 - transition_state_id_exec")
    quit()

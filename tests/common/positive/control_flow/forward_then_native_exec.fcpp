@@[target("cpp_17")]
@@run-expect: FORWARD:PARENT

#include <iostream>
#include <cassert>

void native_func();
void x_func();

@@system S {
    machine:
        $A => $P {
            e() {
                => $^; native_func();
            }
        }
        $P { }
}

// Stub functions for placeholder calls
void native_func() {}
void x_func() {}

// TAP test harness
int main() {
    printf("TAP version 14\n");
    printf("1..1\n");
    try {
        auto s = @@S();
        s.e();
        printf("ok 1 - forward_then_native_exec\n");
    } catch (...) {
        printf("not ok 1 - forward_then_native_exec\n");
    }
    return 0;
}

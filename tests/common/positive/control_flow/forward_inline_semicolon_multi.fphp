@@[target("php")]

@@system S {
    machine:
        $A => $P {
            e() {
                => $^; a(); b();
            }
        }
        $P { }
}

function native() {}
function x() {}
function a() {}
function b() {}

echo "TAP version 14" . "\n";
echo "1..1" . "\n";
try {
    $s = @@S();
    if (method_exists($s, 'e')) { $s->e(); }
    echo "ok 1 - forward_inline_semicolon_multi" . "\n";
} catch (\Exception $ex) {
    echo "not ok 1 # " . $ex->getMessage() . "\n";
}

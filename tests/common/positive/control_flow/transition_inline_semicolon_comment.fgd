@@target gdscript
extends SceneTree

@@system S {
    machine:
        $A {
            e() {
                -> $B();  # ok
            }
        }
        $B {
        }
}

# Stub functions for placeholder calls

# TAP test harness
func _init():
    print("TAP version 14")
    print("1..1")
    var s = @@S()
    if s.has_method("e"):
        s.e()
    print("ok 1 - transition_inline_semicolon_comment")
    quit()

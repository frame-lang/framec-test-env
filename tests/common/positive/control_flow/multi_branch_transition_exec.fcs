@@[target("csharp")]


@@system S {
    machine:
        $A {
            e() {
                if (true) {
                    -> $B()
                } else {
                    -> $C()
                }
            }
        }
        $B { }
        $C { }
}

class Program {
    static void Main(string[] args) {
        Console.WriteLine("TAP version 14");
        Console.WriteLine("1..1");
        try {
            S s = @@S();
            s.e();
            Console.WriteLine("ok 1 - multi_branch_transition_exec");
        } catch (Exception ex) {
            Console.WriteLine("not ok 1 - multi_branch_transition_exec # " + ex);
        }
    }
}

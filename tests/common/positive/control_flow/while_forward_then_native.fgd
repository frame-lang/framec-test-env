@@[target("gdscript")]
extends SceneTree

@@system S {
    machine:
        $A => $P {
            e() {
                while false:
                    => $^
                    pass
                pass
            }
        }
        $P { }
}

# Stub variables and functions for placeholder calls
var cond = false  # Set to false so while loop exits immediately
func native(): pass
func x(): pass
func step(): pass
func done(): pass

# TAP test harness
func _init():
    print("TAP version 14")
    print("1..1")
    var s = @@S()
    if s.has_method("e"):
        s.e()
    print("ok 1 - while_forward_then_native")
    quit()

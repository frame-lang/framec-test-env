@@target gdscript

@@system S {
    machine:
        $A => $P {
            e() {
                while cond:
                    => $^
                    step()
                done()
            }
        }
        $P { }
}

# Stub variables and functions for placeholder calls
cond = false  # Set to false so while loop exits immediately

# TAP test harness
func _ready():
    print("TAP version 14")
    print("1..1")
    s = @@S()
    if s.has_method("e"):
        s.e()
    print("ok 1 - while_forward_then_native")
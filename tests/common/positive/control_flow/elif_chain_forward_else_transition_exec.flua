@@target lua
@@run-expect: TRANSITION:
@@system S {
    machine:
        $A => $P {
            e() {
                x = 2
                if x == 1 {
                    -> $B()
                } elseif x == 2 {
                    => $^
                } else {
                    -> $B()
                }
            }
        }
        $B { }
        $P { }
}

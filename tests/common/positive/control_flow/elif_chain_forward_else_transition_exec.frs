@@target rust
@@run-expect: TRANSITION:

@@system S {
    machine:
        $A => $P {
            e() {
                let x = 2;
                if x == 1 {
                    -> $B
                } else if x == 2 {
                    => $^
                } else {
                    -> $B
                }
            }
        }
        $B { }
        $P { }
}

// Stub functions for placeholder calls
fn native() {}
fn x() {}

// TAP test harness
fn main() {
    println!("TAP version 14");
    println!("1..1");
    let mut _s = @@S();
    // Call e() if the method exists
    // Note: Rust doesn't have dynamic dispatch like Python/TS
    // so we just instantiate and print success
    println!("ok 1 - elif_chain_forward_else_transition_exec");
}

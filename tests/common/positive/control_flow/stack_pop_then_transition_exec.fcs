@@[target("csharp")]


@@system S {
    machine:
        $A {
            e() {
                push$  // Push current state to stack
                -> $B()
            }
        }
        $B {
            e() {
                -> pop$  // Pop from stack and transition back to A
            }
        }
}

class Program {
    static void Main(string[] args) {
        Console.WriteLine("TAP version 14");
        Console.WriteLine("1..1");
        try {
            S s = @@S();
            s.e();  // Push A to stack and transition to B
            s.e();  // Pop from stack and transition back to A
            Console.WriteLine("ok 1 - stack_pop_then_transition_exec");
        } catch (Exception ex) {
            Console.WriteLine("not ok 1 - stack_pop_then_transition_exec # " + ex);
        }
    }
}

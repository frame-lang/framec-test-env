@@[target("csharp")]

using System;
using System.Collections.Generic;

class Stubs {
    public static void native_stub() {}
}

@@system S {
    machine:
        $A {
            e() {
                if (false) {
                    Stubs.native_stub();
                } else {
                    -> $B()
                }
            }
        }
        $B { }
}

class Program {
    static void Main(string[] args) {
        Console.WriteLine("TAP version 14");
        Console.WriteLine("1..1");
        try {
            S s = @@S();
            s.e();
            Console.WriteLine("ok 1 - else_transition_exec");
        } catch (Exception ex) {
            Console.WriteLine("not ok 1 - else_transition_exec # " + ex);
        }
    }
}

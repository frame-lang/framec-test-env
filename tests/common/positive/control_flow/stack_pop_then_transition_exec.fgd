@@target gdscript
@@run-expect: STACK:POP
@@run-expect: TRANSITION:

@@system S {
    machine:
        $A {
            e() {
                push$  # Push current state to stack
                -> $B()
            }
        }
        $B {
            e() {
                -> pop$  # Pop from stack and transition back to A
            }
        }
}

# Stub functions for placeholder calls

# TAP test harness
func _ready():
    print("TAP version 14")
    print("1..1")
    try:
        s = @@S()
        if s.has_method('e'):
            s.e()  # Push A to stack and transition to B
            s.e()  # Pop from stack and transition back to A
        print("ok 1 - stack_pop_then_transition_exec")
    except Exception as ex:
        print("not ok 1 - stack_pop_then_transition_exec # {ex}")

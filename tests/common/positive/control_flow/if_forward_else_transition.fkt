@@target kotlin

import kotlin.system.exitProcess

@@system S {
    machine:
        $P { e() { } }
        $A => $P {
            e() {
                if (true) {
                    => $^
                } else {
                    -> $B()
                }
            }
        }
        $B { e() { } }
}

fun main() {
    println("TAP version 14")
    println("1..1")
    try {
        val s = S()
        s.e()
        println("ok 1 - if_forward_else_transition")
    } catch (ex: Exception) {
        println("not ok 1 - if_forward_else_transition # $ex")
    }
}

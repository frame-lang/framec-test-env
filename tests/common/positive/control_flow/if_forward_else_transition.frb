@@[target("ruby")]

@@system S {
    machine:
        $P { e() { } }
        $A => $P {
            e() {
                if true
                    => $^
                else
                    -> $B()
                end
            }
        }
        $B { e() { } }
}

puts("TAP version 14")
puts("1..1")
begin
    s = @@S()
    if s.respond_to?(:e)
        s.e()
    end
    puts("ok 1 - if_forward_else_transition")
rescue => ex
    puts("not ok 1 - if_forward_else_transition # #{ex}")
end

@@[target("ruby")]
@@debug-manifest-expect: system=S; states=A,B
@@debug-manifest-handler-expect: state=A; name=e; params=p,q
@@debug-manifest-handler-expect: state=A; name=g; params=x

@@system S {
    machine:
        $A {
            e(p, q) { -> $B() }
            g(x) { }
        }
        $B { e() { } }
}

puts("TAP version 14")
puts("1..1")
begin
    s = @@S()
    if s.respond_to?(:e)
        s.e(1, 2)
    end
    puts("ok 1 - multi_handler_manifest")
rescue => ex
    puts("not ok 1 - multi_handler_manifest # #{ex}")
end

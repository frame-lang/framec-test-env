@@target cpp_17

#include <iostream>
#include <string>
#include <cassert>

// Forward declarations for functions used in handlers
void a_func();
void b_func();

@@system S {
    machine:
        $A => $P {
            e() {
                => $^
                a_func();
                b_func();
            }
        }
        $P { }
}

// Stub functions for placeholder calls
void native_func() {}
void x_func() {}
void a_func() {}
void b_func() {}

// TAP test harness
int main() {
    printf("TAP version 14\n");
    printf("1..1\n");
    try {
        S s;
        s.e();
        printf("ok 1 - forward_multi_native\n");
    } catch (...) {
        printf("not ok 1 - forward_multi_native\n");
    }
    return 0;
}

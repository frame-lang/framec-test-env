@@target go

package main

import "fmt"

@@system S {
    machine:
        $A => $P {
            E() {
                => $^; a := 1; b := 2; // multiple natives after forward on same line
                _ = a; _ = b
                -> $B();
            }
        }
        $B { }
        $P { }
}

func main() {
	fmt.Println("TAP version 14")
	fmt.Println("1..1")
	s := NewS()
	s.E()
	fmt.Println("ok 1 - inline_after_forward_then_transition_exec")
}

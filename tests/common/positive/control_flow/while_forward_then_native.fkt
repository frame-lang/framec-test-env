@@[target("kotlin")]

import kotlin.system.exitProcess

object Stubs {
    var cond = false
    fun step() {}
    fun done() {}
}

@@system S {
    machine:
        $A => $P {
            e() {
                while (Stubs.cond) {
                    => $^
                    Stubs.step()
                }
                Stubs.done()
            }
        }
        $P { }
}

fun main() {
    println("TAP version 14")
    println("1..1")
    try {
        val s = @@S()
        s.e()
        println("ok 1 - while_forward_then_native")
    } catch (ex: Exception) {
        println("not ok 1 - while_forward_then_native # $ex")
    }
}

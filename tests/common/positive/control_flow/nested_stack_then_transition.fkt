@@[target("kotlin")]

import kotlin.system.exitProcess

@@system S {
    machine:
        $A {
            e() {
                if (true) {
                    push$
                    pop$
                } else {
                    push$
                    pop$
                -> $B()
                }
            }
        }
        $B { e() { } }
}

fun main() {
    println("TAP version 14")
    println("1..1")
    try {
        val s = @@S()
        s.e()
        println("ok 1 - nested_stack_then_transition")
    } catch (ex: Exception) {
        println("not ok 1 - nested_stack_then_transition # $ex")
    }
}

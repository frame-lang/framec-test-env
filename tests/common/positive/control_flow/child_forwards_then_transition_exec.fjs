@@target javascript
@@run-expect: FORWARD:PARENT
@@run-expect: FORWARD:PARENT
@@run-expect: TRANSITION:

@@system S {
    machine:
        $A => $P {
            e() {
                if (true) {
                    => $^
                    => $^
                }
                -> $B()
            }
        }
        $B { }
        $P { }
}

// Stub functions for placeholder calls
function native() {}
function x() {}

// TAP test harness
function main() {
    console.log("TAP version 14");
    console.log("1..1");
    try {
        const s = @@S();
        if (typeof s.e === 'function') {
            s.e();
        }
        console.log("ok 1 - child_forwards_then_transition_exec");
    } catch (ex) {
        console.log(`not ok 1 - child_forwards_then_transition_exec # ${ex}`);
    }
}
main();

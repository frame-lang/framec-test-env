@@[target("java")]

import java.util.*;

@@system SysX {
    machine:
        $A {
            e() {
                -> $B();
            }
        }
        $B {
        }
}

class Main {
    public static void main(String[] args) {
        System.out.println("TAP version 14");
        System.out.println("1..1");
        try {
            SysX s = new SysX();
            s.e();
            System.out.println("ok 1 - transition_state_id_exec");
        } catch (Exception ex) {
            System.out.println("not ok 1 - transition_state_id_exec # " + ex);
        }
    }
}

@@target dart

@@system S {
    machine:
        $P { e() { } }
        $A => $P {
            e() {
                if (true) {
                    => $^
                } else {
                    -> $B()
                }
            }
        }
        $B { e() { } }
}

// Stub functions for placeholder calls
void native(): void {}
void x(): void {}

// TAP test harness
void main() {
    print("TAP version 14");
    print("1..1");
    try {
        final s = @@S();
        if (typeof (s as any).e == 'function') {
            (s as any).e();
        }
        print("ok 1 - if_forward_else_transition");
    } catch (ex) {
        print("not ok 1 - if_forward_else_transition # ${ex}");
    }
}

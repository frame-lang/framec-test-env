@@[target("kotlin")]

import kotlin.system.exitProcess

@@system S {
    machine:
        $A => $P {
            e() {
                => $^
            }
        }
        $P { }
}

fun main() {
    println("TAP version 14")
    println("1..1")
    try {
        val s = S()
        s.e()
        println("ok 1 - forward_trailing_whitespace")
    } catch (ex: Exception) {
        println("not ok 1 - forward_trailing_whitespace # $ex")
    }
}

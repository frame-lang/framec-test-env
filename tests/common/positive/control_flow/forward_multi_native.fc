@@[target("c")]

#include <stdio.h>
#include <stdbool.h>

// Forward declarations for stub functions
void a(void);
void b(void);

@@system S {
    machine:
        $A => $P {
            e() {
                => $^
                a();
                b();
            }
        }
        $P { }
}

// Stub functions for placeholder calls
void native(void) {}
void x(void) {}
void a(void) {}
void b(void) {}

// TAP test harness
int main(void) {
    printf("TAP version 14\n");
    printf("1..1\n");
    S* s = @@S();
    S_e(s);
    printf("ok 1 - forward_multi_native\n");
    S_destroy(s);
    return 0;
}

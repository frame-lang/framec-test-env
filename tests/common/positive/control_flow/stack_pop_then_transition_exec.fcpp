@@[target("cpp_17")]
@@run-expect: STACK:POP
@@run-expect: TRANSITION:

#include <iostream>
#include <cassert>

@@system S {
    machine:
        $A {
            e() {
                push$  // Push current state to stack
                -> $B()
            }
        }
        $B {
            e() {
                -> pop$  // Pop from stack and transition back to A
            }
        }
}

// Stub functions for placeholder calls
void native() {}
void x() {}

// TAP test harness
int main() {
    printf("TAP version 14\n");
    printf("1..1\n");
    try {
        auto s = @@S();
        s.e();  // Push A to stack and transition to B
        s.e();  // Pop from stack and transition back to A
        printf("ok 1 - stack_pop_then_transition_exec\n");
    } catch (...) {
        printf("not ok 1 - stack_pop_then_transition_exec\n");
    }
    return 0;
}

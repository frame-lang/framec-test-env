    static void b() {}

    public static void main(String[] args) {
        System.out.println("TAP version 14");
        System.out.println("1..1");
        try {
            S s = new S();
            s.e();
            System.out.println("ok 1 - forward_multi_native");
        } catch (Exception ex) {

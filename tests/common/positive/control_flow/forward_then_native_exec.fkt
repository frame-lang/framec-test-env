@@[target("kotlin")]

import kotlin.system.exitProcess

fun native_stub() {}

@@system S {
    machine:
        $A => $P {
            e() {
                => $^; native_stub()
            }
        }
        $P { }
}

fun main() {
    println("TAP version 14")
    println("1..1")
    try {
        val s = @@S()
        s.e()
        println("ok 1 - forward_then_native_exec")
    } catch (ex: Exception) {
        println("not ok 1 - forward_then_native_exec # $ex")
    }
}

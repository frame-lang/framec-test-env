@@[target("ruby")]
@@run-exact: TRANSITION:__S_state_B

@@system S {
    machine:
        $A {
            e() {
                -> $B()
            }
        }
        $B { }
}

puts("TAP version 14")
puts("1..1")
begin
    s = @@S()
    if s.respond_to?(:e)
        s.e()
    end
    puts("ok 1 - transition_run_exact_exec")
rescue => ex
    puts("not ok 1 - transition_run_exact_exec # #{ex}")
end

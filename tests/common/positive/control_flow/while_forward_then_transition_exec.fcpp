@@system S {
    machine:
        $A => $P {
            e() {
                int i = 0;
                while (i < 1) {
                    => $^
                    i += 1;
                }
                -> $B()
            }
        }
        $B { }
        $P { }
}

// Stub functions for placeholder calls
void native() {}

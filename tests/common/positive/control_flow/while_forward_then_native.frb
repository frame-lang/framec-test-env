@@[target("ruby")]

@@system S {
    machine:
        $A => $P {
            e() {
                while self.cond
                    => $^
                    step()
                end
                done()
            }
        }
        $P { }
    domain:
        cond: bool = false
}

def step; end
def done; end

puts("TAP version 14")
puts("1..1")
begin
    s = @@S()
    if s.respond_to?(:e)
        s.e()
    end
    puts("ok 1 - while_forward_then_native")
rescue => ex
    puts("not ok 1 - while_forward_then_native # #{ex}")
end

@@target ruby

@@system S {
    machine:
        $A => $P {
            e() {
                while cond
                    => $^
                    step()
                end
                done()
            }
        }
        $P { }
}

cond = false
def step; end
def done; end

puts("TAP version 14")
puts("1..1")
begin
    s = S.new
    if s.respond_to?(:e)
        s.e()
    end
    puts("ok 1 - while_forward_then_native")
rescue => ex
    puts("not ok 1 - while_forward_then_native # #{ex}")
end

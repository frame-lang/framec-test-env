@@target csharp

using System;
using System.Collections.Generic;

@@system S {
    machine:
        $A {
            e() {
                -> $B(1, 2, 3)
            }
        }
        $B(x, y, z) { }
}

class Program {
    static void Main(string[] args) {
        Console.WriteLine("TAP version 14");
        Console.WriteLine("1..1");
        try {
            S s = new S();
            s.e();
            Console.WriteLine("ok 1 - transition_state_args_exec");
        } catch (Exception ex) {
            Console.WriteLine("not ok 1 - transition_state_args_exec # " + ex);
        }
    }
}

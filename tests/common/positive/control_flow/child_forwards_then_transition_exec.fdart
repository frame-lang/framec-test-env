@@target dart
@@run-expect: FORWARD:PARENT
@@run-expect: FORWARD:PARENT
@@run-expect: TRANSITION:

@@system S {
    machine:
        $A => $P {
            e() {
                if (true) {
                    => $^
                    => $^
                }
                -> $B()
            }
        }
        $B { }
        $P { }
}

// Stub functions for placeholder calls
void native(): void {}
void x(): void {}

// TAP test harness
void main() {
    print("TAP version 14");
    print("1..1");
    try {
        final s = @@S();
        if (typeof (s as any).e == 'function') {
            (s as any).e();
        }
        print("ok 1 - child_forwards_then_transition_exec");
    } catch (ex) {
        print("not ok 1 - child_forwards_then_transition_exec # ${ex}");
    }
}

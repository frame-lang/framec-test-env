@@target kotlin

import kotlin.system.exitProcess

@@system S {
    machine:
        $P {
        }
        $A => $P {
            e() {
                => $^
            }
        }
        $B {
        }
}

fun main() {
    println("TAP version 14")
    println("1..1")
    try {
        val s = S()
        s.e()
        println("ok 1 - forward_with_parent_mixed")
    } catch (ex: Exception) {
        println("not ok 1 - forward_with_parent_mixed # $ex")
    }
}

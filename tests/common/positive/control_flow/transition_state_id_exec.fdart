@@target dart
@@run-expect: TRANSITION:__SysX_state_B

@@system SysX {
    machine:
        $A {
            e() {
                -> $B();
            }
        }
        $B {
        }
}

// Stub functions for placeholder calls
void native(): void {}
void x(): void {}

// TAP test harness
void main() {
    print("TAP version 14");
    print("1..1");
    try {
        final s = @@SysX();
        if (typeof (s as any).e == 'function') {
            (s as any).e();
        }
        print("ok 1 - transition_state_id_exec");
    } catch (ex) {
        print("not ok 1 - transition_state_id_exec # ${ex}");
    }
}

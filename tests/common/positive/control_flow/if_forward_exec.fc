@@target c
@@run-expect: FORWARD:PARENT

#include <stdio.h>
#include <stdbool.h>

@@system S {
    machine:
        $A => $P {
            e() {
                if (true) {
                    => $^
                }
            }
        }
        $P { }
}

// Stub functions for placeholder calls
void native(void) {}
void x(void) {}

// TAP test harness
int main(void) {
    printf("TAP version 14\n");
    printf("1..1\n");
    S* s = @@S();
    S_e(s);
    printf("ok 1 - if_forward_exec\n");
    S_destroy(s);
    return 0;
}

@@[target("cpp_17")]
@@run-expect: TRANSITION:

#include <iostream>
#include <cassert>

@@system S {
    machine:
        $A {
            e() {
                if (false) {
                    -> $B()
                } else if (false) {
                    -> $C()
                } else {
                    -> $D()
                }
            }
        }
        $B { }
        $C { }
        $D { }
}

// Stub functions for placeholder calls
void native_func() {}
void x_func() {}

// TAP test harness
int main() {
    printf("TAP version 14\n");
    printf("1..1\n");
    try {
        auto s = @@S();
        s.e();
        printf("ok 1 - elif_multi_transition_exec\n");
    } catch (...) {
        printf("not ok 1 - elif_multi_transition_exec\n");
    }
    return 0;
}

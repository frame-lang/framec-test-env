@@target rust
@@debug-manifest-expect: system=S; states=A,B
@@debug-manifest-handler-expect: state=A; name=e; params=x,y

@@system S {
    machine:
        $A {
            e(x: i32, y: i32) { -> $B() }
        }
        $B { e() { } }
}



// Stub functions for placeholder calls
fn native() {}
fn x() {}

// TAP test harness
fn main() {
    println!("TAP version 14");
    println!("1..1");
    let mut s = S::new();
    // Call e with typed parameters
    s.e(1, 2);
    println!("ok 1 - handler_params_manifest");
}

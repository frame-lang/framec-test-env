@@target ruby
@@run-expect: TRANSITION:

@@system S {
    machine:
        $A {
            e() {
                -> $B()
            }
        }
        $B { }
}

puts("TAP version 14")
puts("1..1")
begin
    s = S.new
    if s.respond_to?(:e)
        s.e()
    end
    puts("ok 1 - transition_basic_exec")
rescue => ex
    puts("not ok 1 - transition_basic_exec # #{ex}")
end

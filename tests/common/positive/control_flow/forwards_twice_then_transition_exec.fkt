@@[target("kotlin")]

import kotlin.system.exitProcess

@@system S {
    machine:
        $A => $P {
            e() {
                => $^
                => $^
                -> $B()
            }
        }
        $B { }
        $P { }
}

fun main() {
    println("TAP version 14")
    println("1..1")
    try {
        val s = @@S()
        s.e()
        println("ok 1 - forwards_twice_then_transition_exec")
    } catch (ex: Exception) {
        println("not ok 1 - forwards_twice_then_transition_exec # $ex")
    }
}

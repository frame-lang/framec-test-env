@@target typescript
@@run-exact: TRANSITION:__S_state_B

@@system S {
    machine:
        $A {
            e() { -> $B() }
        }
        $B { }
}

// Stub functions for placeholder calls
function native(): void {}
function x(): void {}

// TAP test harness
function main() {
    console.log("TAP version 14");
    console.log("1..1");
    try {
        const s = new S();
        if (typeof (s as any).e === 'function') {
            (s as any).e();
        }
        console.log("ok 1 - transition_run_exact_exec");
    } catch (ex) {
        console.log(`not ok 1 - transition_run_exact_exec # ${ex}`);
    }
}
main();

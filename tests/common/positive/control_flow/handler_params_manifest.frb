@@target ruby
@@debug-manifest-expect: system=S; states=A,B
@@debug-manifest-handler-expect: state=A; name=e; params=x,y

@@system S {
    machine:
        $A {
            e(x, y) {
                -> $B()
            }
        }
        $B { e() { } }
}

puts("TAP version 14")
puts("1..1")
begin
    s = S.new
    if s.respond_to?(:e)
        s.e(1, 2)
    end
    puts("ok 1 - handler_params_manifest")
rescue => ex
    puts("not ok 1 - handler_params_manifest # #{ex}")
end

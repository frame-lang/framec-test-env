@@[target("gdscript")]
extends SceneTree

@@system S {
    machine:
        $A => $P {
            e() {
                if true:
                    => $^
                    pass
                elif false:
                    => $^
                    pass
                else:
                    => $^
                    pass
            }
        }
        $P { }
}

# Stub variables and functions for placeholder calls
var a = true
var b = false
func native(): pass
func x(): pass
func y(): pass
func z(): pass

# TAP test harness
func _init():
    print("TAP version 14")
    print("1..1")
    var s = @@S()
    if s.has_method("e"):
        s.e()
    print("ok 1 - if_chain_forwards")
    quit()

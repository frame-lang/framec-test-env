@@target gdscript

@@system S {
    machine:
        $A => $P {
            e() {
                if a:
                    => $^
                    x()
                elif b:
                    => $^
                    y()
                else:
                    => $^
                    z()
            }
        }
        $P { }
}

# Stub variables and functions for placeholder calls
a = true
b = false

# TAP test harness
func _ready():
    print("TAP version 14")
    print("1..1")
    s = @@S()
    if s.has_method("e"):
        s.e()
    print("ok 1 - if_chain_forwards")
@@[target("java")]

import java.util.*;

class Stubs {
    static boolean cond = false;
    static void step() {}
    static void done() {}
}

@@system S {
    machine:
        $A => $P {
            e() {
                while (Stubs.cond) {
                    => $^
                    Stubs.step();
                }
                Stubs.done();
            }
        }
        $P { }
}

class Main {
    public static void main(String[] args) {
        System.out.println("TAP version 14");
        System.out.println("1..1");
        try {
            S s = @@S();
            s.e();
            System.out.println("ok 1 - while_forward_then_native");
        } catch (Exception ex) {
            System.out.println("not ok 1 - while_forward_then_native # " + ex);
        }
    }
}

@@[target("cpp_17")]
@@run-expect: STACK:PUSH
@@run-expect: STACK:POP
@@run-expect: TRANSITION:

#include <iostream>
#include <string>
#include <cassert>

@@system S {
    machine:
        $A {
            e() {
                push$
                pop$
                -> $B()
            }
        }
        $B { }
}

// Stub functions for placeholder calls
void native() {}
void x() {}

// TAP test harness
int main() {
    printf("TAP version 14\n");
    printf("1..1\n");
    try {
        auto s = @@S();
        s.e();
        printf("ok 1 - stack_then_transition_exec\n");
    } catch (...) {
        printf("not ok 1 - stack_then_transition_exec\n");
    }
    return 0;
}

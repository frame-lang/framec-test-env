@@target gdscript
extends SceneTree

@@system S {
    machine:
        $A {
            e() {
                # comment with -> $B() and => $^
                native()
            }
        }
}

# Stub functions for placeholder calls

# TAP test harness
func _init():
    print("TAP version 14")
    print("1..1")
    var s = @@S()
    if s.has_method("e"):
        s.e()
    print("ok 1 - inside_comment_transition_ignored")
    quit()

@@target gdscript

@@system S {
    machine:
        $A {
            e() {
                # comment with -> $B() and => $^
                native()
            }
        }
}

# Stub functions for placeholder calls

# TAP test harness
func _ready():
    print("TAP version 14")
    print("1..1")
    try:
        s = @@S()
        if s.has_method('e'):
            s.e()
        print("ok 1 - inside_comment_transition_ignored")
    except Exception as ex:
        print("not ok 1 - inside_comment_transition_ignored # {ex}")

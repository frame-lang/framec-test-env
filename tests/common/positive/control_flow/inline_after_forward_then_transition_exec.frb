@@[target("ruby")]
@@run-expect: FORWARD:PARENT
@@run-expect: TRANSITION:

@@system S {
    machine:
        $A => $P {
            e() {
                => $^; x = 1; y = 2  # multiple natives after forward on same line
                -> $B()
            }
        }
        $B { }
        $P { }
}

puts("TAP version 14")
puts("1..1")
begin
    s = @@S()
    if s.respond_to?(:e)
        s.e()
    end
    puts("ok 1 - inline_after_forward_then_transition_exec")
rescue => ex
    puts("not ok 1 - inline_after_forward_then_transition_exec # #{ex}")
end

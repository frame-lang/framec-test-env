@@[target("typescript")]
@@debug-manifest-expect: system=S; states=A,B
@@debug-manifest-handler-expect: state=A; name=e; params=x,y

@@system S {
    machine:
        $A {
            e(x, y) {
                -> $B()
            }
        }
        $B { e() { } }
}

// Stub functions for placeholder calls
function native(): void {}
function x(): void {}

// TAP test harness
function main() {
    console.log("TAP version 14");
    console.log("1..1");
    try {
        const s = @@S();
        if (typeof (s as any).e === 'function') {
            (s as any).e();
        }
        console.log("ok 1 - handler_params_manifest");
    } catch (ex) {
        console.log(`not ok 1 - handler_params_manifest # ${ex}`);
    }
}
main();

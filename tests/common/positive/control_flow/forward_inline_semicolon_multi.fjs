@@[target("javascript")]

@@system S {
    machine:
        $A => $P {
            e() {
                => $^; a(); b();
            }
        }
        $P { }
}

// Stub functions for placeholder calls
function native() {}
function x() {}
function a() {}
function b() {}

// TAP test harness
function main() {
    console.log("TAP version 14");
    console.log("1..1");
    try {
        const s = @@S();
        if (typeof s.e === 'function') {
            s.e();
        }
        console.log("ok 1 - forward_inline_semicolon_multi");
    } catch (ex) {
        console.log(`not ok 1 - forward_inline_semicolon_multi # ${ex}`);
    }
}
main();

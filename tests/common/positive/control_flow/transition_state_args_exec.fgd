@@target gdscript
extends SceneTree
@@run-expect: TRANSITION:__S_state_B

@@system S {
    machine:
        $A {
            e() {
                -> $B(1, 2, k=3)
            }
        }
        $B(x, y, k) { }
}

# Stub functions for placeholder calls

# TAP test harness
func _init():
    print("TAP version 14")
    print("1..1")
    var s = @@S()
    if s.has_method("e"):
        s.e()
    print("ok 1 - transition_state_args_exec")
    quit()

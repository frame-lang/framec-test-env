@@target gdscript
@@run-expect: TRANSITION:__S_state_B

@@system S {
    machine:
        $A {
            e() {
                -> $B(1, 2, k=3)
            }
        }
        $B(x, y, k) { }
}

# Stub functions for placeholder calls

# TAP test harness
func _ready():
    print("TAP version 14")
    print("1..1")
    try:
        s = @@S()
        if s.has_method('e'):
            s.e()
        print("ok 1 - transition_state_args_exec")
    except Exception as ex:
        print("not ok 1 - transition_state_args_exec # {ex}")

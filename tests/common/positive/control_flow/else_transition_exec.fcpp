@@target cpp_17
@@run-expect: TRANSITION:

#include <iostream>
#include <string>
#include <cassert>

@@system S {
    machine:
        $A {
            e() {
                if (false) {
                    native_func()
                } else {
                    -> $B()
                }
            }
        }
        $B { }
}

// Stub functions for placeholder calls
void native_func() {}
void x_func() {}

// TAP test harness
int main() {
    printf("TAP version 14\n");
    printf("1..1\n");
    try {
        S s;
        s.e();
        printf("ok 1 - else_transition_exec\n");
    } catch (...) {
        printf("not ok 1 - else_transition_exec\n");
    }
    return 0;
}

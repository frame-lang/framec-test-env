@@target cpp_17
@@run-expect: TRANSITION:

#include <iostream>
#include <cstdio>

@@system S {
    machine:
        $A {
            e() {
                if (false) {
                    native();
                } else {
                    -> $B()
                }
            }
        }
        $B { }
}

// Stub functions for placeholder calls
void native() {}
void x() {}

// TAP test harness
int main() {
    printf("TAP version 14\n");
    printf("1..1\n");
    S s;
    s.e();
    printf("ok 1 - else_transition_exec\n");
    return 0;
}

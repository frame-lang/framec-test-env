@@[target("ruby")]
@@run-expect: STACK:POP
@@run-expect: TRANSITION:

@@system S {
    machine:
        $A {
            e() {
                push$  # Push current state to stack
                -> $B()
            }
        }
        $B {
            e() {
                -> pop$  # Pop from stack and transition back to A
            }
        }
}

puts("TAP version 14")
puts("1..1")
begin
    s = S.new
    if s.respond_to?(:e)
        s.e()  # Push A to stack and transition to B
        s.e()  # Pop from stack and transition back to A
    end
    puts("ok 1 - stack_pop_then_transition_exec")
rescue => ex
    puts("not ok 1 - stack_pop_then_transition_exec # #{ex}")
end

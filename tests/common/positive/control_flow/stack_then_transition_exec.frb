@@target ruby
@@run-expect: STACK:PUSH
@@run-expect: STACK:POP
@@run-expect: TRANSITION:

@@system S {
    machine:
        $A {
            e() {
                push$
                pop$
                -> $B()
            }
        }
        $B { }
}

puts("TAP version 14")
puts("1..1")
begin
    s = S.new
    if s.respond_to?(:e)
        s.e()
    end
    puts("ok 1 - stack_then_transition_exec")
rescue => ex
    puts("not ok 1 - stack_then_transition_exec # #{ex}")
end

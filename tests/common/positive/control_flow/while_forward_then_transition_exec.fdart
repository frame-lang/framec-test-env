@@target dart
@@run-expect: FORWARD:PARENT
@@run-expect: TRANSITION:

@@system S {
    machine:
        $A => $P {
            e() {
                var i = 0;
                while (i < 1) {
                    => $^
                    i += 1;
                }
                -> $B()
            }
        }
        $B { }
        $P { }
}

// Stub functions for placeholder calls
void native() {}
void x() {}

// TAP test harness
void main() {
    print("TAP version 14");
    print("1..1");
    try {
        final s = @@S();
        if (true) {
            s.e();
        }
        print("ok 1 - while_forward_then_transition_exec");
    } catch (ex) {
        print("not ok 1 - while_forward_then_transition_exec # ${ex}");
    }
}

@@target kotlin

import kotlin.system.exitProcess

@@system S {
    machine:
        $A {
            e() {
                -> $B(1, 2, 3)
            }
        }
        $B(x, y, z) { }
}

fun main() {
    println("TAP version 14")
    println("1..1")
    try {
        val s = S()
        s.e()
        println("ok 1 - transition_state_args_exec")
    } catch (ex: Exception) {
        println("not ok 1 - transition_state_args_exec # $ex")
    }
}

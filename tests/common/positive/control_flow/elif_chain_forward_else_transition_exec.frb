@@target ruby
@@run-expect: TRANSITION:

@@system S {
    machine:
        $A => $P {
            e() {
                x = 2
                if x == 1
                    -> $B()
                elsif x == 2
                    => $^
                else
                    -> $B()
                end
            }
        }
        $B { }
        $P { }
}

puts("TAP version 14")
puts("1..1")
begin
    s = S.new
    if s.respond_to?(:e)
        s.e()
    end
    puts("ok 1 - elif_chain_forward_else_transition_exec")
rescue => ex
    puts("not ok 1 - elif_chain_forward_else_transition_exec # #{ex}")
end

<?php
@@target php
@@debug-manifest-expect: system=S; states=A,B
@@debug-manifest-handler-expect: state=A; name=e; params=p,q
@@debug-manifest-handler-expect: state=A; name=g; params=x

@@system S {
    machine:
        $A {
            e(p, q) { -> $B() }
            g(x) { }
        }
        $B { e() { } }
}

function native() {}
function x() {}

echo "TAP version 14" . "\n";
echo "1..1" . "\n";
try {
    $s = new S();
    if (method_exists($s, 'e')) { $s->e(1, 2); }
    echo "ok 1 - multi_handler_manifest" . "\n";
} catch (\Exception $ex) { echo "not ok 1 # " . $ex->getMessage() . "\n"; }

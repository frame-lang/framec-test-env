@@[target("kotlin")]

import kotlin.system.exitProcess

@@system S {
    machine:
        $A => $P {
            e() {
                var i = 0
                while (i < 1) {
                    => $^; i += 1
                }
                -> $B()
            }
        }
        $B { }
        $P { }
}

fun main() {
    println("TAP version 14")
    println("1..1")
    try {
        val s = @@S()
        s.e()
        println("ok 1 - while_inline_forward_then_transition_exec")
    } catch (ex: Exception) {
        println("not ok 1 - while_inline_forward_then_transition_exec # $ex")
    }
}

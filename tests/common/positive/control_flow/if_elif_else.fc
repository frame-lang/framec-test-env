@@target c

#include <stdio.h>
#include <stdbool.h>

// Forward declarations for condition variables
bool a = true;
bool b = false;

// Forward declarations for stub functions
void native(void);
void x(void);
void y(void);
void z(void);

@@system S {
    machine:
        $A => $P {
            e() {
                if (a) {
                    x();
                } else if (b) {
                    y();
                } else {
                    z();
                }
                => $^
            }
        }
        $P { }
}

// Stub functions for placeholder calls
void native(void) {}
void x(void) {}
void y(void) {}
void z(void) {}

// TAP test harness
int main(void) {
    printf("TAP version 14\n");
    printf("1..1\n");
    S* s = @@S();
    S_e(s);
    printf("ok 1 - if_elif_else\n");
    S_destroy(s);
    return 0;
}

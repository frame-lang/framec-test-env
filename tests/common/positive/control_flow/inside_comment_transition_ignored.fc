@@target c

#include <stdio.h>
#include <stdbool.h>

// Forward declarations (C requires declaration before use)
void native(void);
void x(void);

@@system S {
    machine:
        $A {
            e() {
                // comment with -> $B() and => $^
                native();
            }
        }
}

// Stub functions for placeholder calls
void native(void) {}
void x(void) {}

// TAP test harness
int main(void) {
    printf("TAP version 14\n");
    printf("1..1\n");
    S* s = @@S();
    S_e(s);
    printf("ok 1 - inside_comment_transition_ignored\n");
    S_destroy(s);
    return 0;
}

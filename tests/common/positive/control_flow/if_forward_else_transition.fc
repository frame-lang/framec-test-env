@@[target("c")]

#include <stdio.h>
#include <stdbool.h>

@@system S {
    machine:
        $P { e() { } }
        $A => $P {
            e() {
                if (true) {
                    => $^
                } else {
                    -> $B()
                }
            }
        }
        $B { e() { } }
}

// Stub functions for placeholder calls
void native(void) {}
void x(void) {}

// TAP test harness
int main(void) {
    printf("TAP version 14\n");
    printf("1..1\n");
    S* s = @@S();
    S_e(s);
    printf("ok 1 - if_forward_else_transition\n");
    S_destroy(s);
    return 0;
}

@@[target("kotlin")]

import kotlin.system.exitProcess

@@system S {
    machine:
        $A => $P {
            e() {
                var y = 0
                => $^; y = 1  // inline native after forward
                push$; y = 2  // inline native after stack push
                -> $B()
            }
        }
        $B { }
        $P { }
}

fun main() {
    println("TAP version 14")
    println("1..1")
    try {
        val s = @@S()
        s.e()
        println("ok 1 - mixed_inline_forward_stack_then_transition_exec")
    } catch (ex: Exception) {
        println("not ok 1 - mixed_inline_forward_stack_then_transition_exec # $ex")
    }
}

@@target ruby
@@run-expect: TRANSITION:__S_state_B

@@system S {
    machine:
        $A {
            e() {
                -> $B(1, 2, k=3)
            }
        }
        $B(x, y, k) { }
}

puts("TAP version 14")
puts("1..1")
begin
    s = S.new
    if s.respond_to?(:e)
        s.e()
    end
    puts("ok 1 - transition_state_args_exec")
rescue => ex
    puts("not ok 1 - transition_state_args_exec # #{ex}")
end

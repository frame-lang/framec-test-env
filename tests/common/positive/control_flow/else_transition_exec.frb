@@target ruby
@@run-expect: TRANSITION:

@@system S {
    machine:
        $A {
            e() {
                if false
                    native()
                else
                    -> $B()
                end
            }
        }
        $B { }
}

def native; end

puts("TAP version 14")
puts("1..1")
begin
    s = S.new
    if s.respond_to?(:e)
        s.e()
    end
    puts("ok 1 - else_transition_exec")
rescue => ex
    puts("not ok 1 - else_transition_exec # #{ex}")
end

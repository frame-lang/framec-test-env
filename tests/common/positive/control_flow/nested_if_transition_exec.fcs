@@target csharp

using System;
using System.Collections.Generic;

@@system S {
    machine:
        $A {
            e() {
                if (true) {
                    if (true) {
                        -> $B()
                    }
                }
            }
        }
        $B { }
}

class Program {
    static void Main(string[] args) {
        Console.WriteLine("TAP version 14");
        Console.WriteLine("1..1");
        try {
            S s = new S();
            s.e();
            Console.WriteLine("ok 1 - nested_if_transition_exec");
        } catch (Exception ex) {
            Console.WriteLine("not ok 1 - nested_if_transition_exec # " + ex);
        }
    }
}

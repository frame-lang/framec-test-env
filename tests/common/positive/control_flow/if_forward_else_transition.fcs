@@[target("csharp")]


@@system S {
    machine:
        $P { e() { } }
        $A => $P {
            e() {
                if (true) {
                    => $^
                } else {
                    -> $B()
                }
            }
        }
        $B { e() { } }
}

class Program {
    static void Main(string[] args) {
        Console.WriteLine("TAP version 14");
        Console.WriteLine("1..1");
        try {
            S s = @@S();
            s.e();
            Console.WriteLine("ok 1 - if_forward_else_transition");
        } catch (Exception ex) {
            Console.WriteLine("not ok 1 - if_forward_else_transition # " + ex);
        }
    }
}

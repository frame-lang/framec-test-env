@@target gdscript
@@run-expect: FORWARD:PARENT

@@system S {
    machine:
        $A => $P {
            e() {
                if true:
                    => $^
            }
        }
        $P { }
}

# Stub functions for placeholder calls

# TAP test harness
func _ready():
    print("TAP version 14")
    print("1..1")
    try:
        s = @@S()
        if s.has_method('e'):
            s.e()
        print("ok 1 - if_forward_exec")
    except Exception as ex:
        print("not ok 1 - if_forward_exec # {ex}")

@@[target("go")]

package main

import "fmt"

func a() {}
func b() {}

@@system S {
    machine:
        $A => $P {
            E() {
                => $^; a(); b()
            }
        }
        $P { }
}

func main() {
	fmt.Println("TAP version 14")
	fmt.Println("1..1")
	s := NewS()
	s.E()
	fmt.Println("ok 1 - forward_inline_semicolon_multi")
}

@@target c
@@run-expect: TRANSITION:__SysX_state_B

#include <stdio.h>
#include <stdbool.h>

@@system SysX {
    machine:
        $A {
            e() {
                -> $B
            }
        }
        $B {
        }
}

// Stub functions for placeholder calls
void native(void) {}
void x(void) {}

// TAP test harness
int main(void) {
    printf("TAP version 14\n");
    printf("1..1\n");
    SysX* s = @@SysX();
    SysX_e(s);
    printf("ok 1 - transition_state_id_exec\n");
    SysX_destroy(s);
    return 0;
}

@@target cpp_17

#include <iostream>
#include <string>
#include <cassert>

// Forward declarations for variables and functions used in handlers
void x_func();
void y_func();
void z_func();
extern bool a;
extern bool b;

@@system S {
    machine:
        $A => $P {
            e() {
                if (a) {
                    x_func();
                } else if (b) {
                    y_func();
                } else {
                    z_func();
                => $^
                }
            }
        }
        $P { }
}

// Stub functions for placeholder calls
void native_func() {}
void x_func() {}
void y_func() {}
void z_func() {}
bool a = true;
bool b = false;

// TAP test harness
int main() {
    printf("TAP version 14\n");
    printf("1..1\n");
    try {
        S s;
        s.e();
        printf("ok 1 - if_elif_else\n");
    } catch (...) {
        printf("not ok 1 - if_elif_else\n");
    }
    return 0;
}

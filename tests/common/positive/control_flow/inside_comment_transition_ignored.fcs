@@target csharp

using System;
using System.Collections.Generic;

class Stubs {
    public static void native_stub() {}
}

@@system S {
    machine:
        $A {
            e() {
                // comment with -> $B() and => $^
                Stubs.native_stub();
            }
        }
}

class Program {
    static void Main(string[] args) {
        Console.WriteLine("TAP version 14");
        Console.WriteLine("1..1");
        try {
            S s = new S();
            s.e();
            Console.WriteLine("ok 1 - inside_comment_transition_ignored");
        } catch (Exception ex) {
            Console.WriteLine("not ok 1 - inside_comment_transition_ignored # " + ex);
        }
    }

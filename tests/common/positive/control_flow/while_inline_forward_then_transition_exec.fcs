@@[target("csharp")]

using System;
using System.Collections.Generic;

@@system S {
    machine:
        $A => $P {
            e() {
                int i = 0;
                while (i < 1) {
                    => $^; i += 1;
                }
                -> $B()
            }
        }
        $B { }
        $P { }
}

class Program {
    static void Main(string[] args) {
        Console.WriteLine("TAP version 14");
        Console.WriteLine("1..1");
        try {
            S s = @@S();
            s.e();
            Console.WriteLine("ok 1 - while_inline_forward_then_transition_exec");
        } catch (Exception ex) {
            Console.WriteLine("not ok 1 - while_inline_forward_then_transition_exec # " + ex);
        }
    }
}

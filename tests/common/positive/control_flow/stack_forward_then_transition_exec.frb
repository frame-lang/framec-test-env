@@target ruby
@@run-expect: STACK:PUSH
@@run-expect: FORWARD:PARENT
@@run-expect: TRANSITION:

@@system S {
    machine:
        $A => $P {
            e() {
                push$
                => $^
                -> $B()
            }
        }
        $B { }
        $P { }
}

puts("TAP version 14")
puts("1..1")
begin
    s = S.new
    if s.respond_to?(:e)
        s.e()
    end
    puts("ok 1 - stack_forward_then_transition_exec")
rescue => ex
    puts("not ok 1 - stack_forward_then_transition_exec # #{ex}")
end

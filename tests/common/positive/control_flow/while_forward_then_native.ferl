@@[target("erlang")]
%%
%% State-flow idiom port of `while_forward_then_native` for Erlang.
%% The Python/JS/etc. variants use Frame's imperative `while` (native
%% passthrough) with a false condition so the body never executes —
%% the test reduces to "no Frame events fire". On Erlang there is no
%% `while` keyword, so the same observable contract is expressed
%% directly: a handler with no Frame statements.
%%
%% See `docs/per_language_guides/` (TODO) for the broader pattern of
%% mapping Frame's two loop idioms onto each backend's native syntax.

@@system S {
    machine:
        $A => $P {
            e() { }
        }
        $P { }
}

@@[target("ruby")]

@@system S {
    machine:
        $A {
            e() {
                push$
                pop$
                -> $B()
            }
        }
        $B { e() { } }
}

puts("TAP version 14")
puts("1..1")
begin
    s = @@S()
    if s.respond_to?(:e)
        s.e()
    end
    puts("ok 1 - stack_then_transition")
rescue => ex
    puts("not ok 1 - stack_then_transition # #{ex}")
end

@@[target("c")]
@@debug-manifest-expect: system=S; states=A,B
@@debug-manifest-handler-expect: state=A; name=e; params=x,y

#include <stdio.h>
#include <stdbool.h>

@@system S {
    machine:
        $A {
            e(x, y) {
                -> $B()
            }
        }
        $B { e() { } }
}

// Stub functions for placeholder calls
void native(void) {}

// TAP test harness
int main(void) {
    printf("TAP version 14\n");
    printf("1..1\n");
    S* s = @@S();
    // Note: e() takes parameters, but for manifest test we just check compilation
    printf("ok 1 - handler_params_manifest\n");
    S_destroy(s);
    return 0;
}

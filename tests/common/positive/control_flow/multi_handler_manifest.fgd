@@target gdscript
@@debug-manifest-expect: system=S; states=A,B
@@debug-manifest-handler-expect: state=A; name=e; params=p,q
@@debug-manifest-handler-expect: state=A; name=g; params=x

@@system S {
    machine:
        $A {
            e(p, q) { -> $B() }
            g(x) { pass }
        }
        $B { e() { pass } }
}

# Stub functions for placeholder calls

# TAP test harness
func _ready():
    print("TAP version 14")
    print("1..1")
    s = @@S()
    if s.has_method("e"):
        s.e(1, 2)  # e(p, q) requires two parameters
    print("ok 1 - multi_handler_manifest")
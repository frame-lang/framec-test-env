@@target cpp_17
@@run-expect: FORWARD:PARENT
@@run-expect: TRANSITION:

#include <iostream>
#include <cstdio>

@@system S {
    machine:
        $A => $P {
            e() {
                => $^; int x = 1; int y = 2;  // multiple natives after forward on same line
                -> $B()
            }
        }
        $B { }
        $P { }
}

// Stub functions for placeholder calls
void native() {}
void x_func() {}

// TAP test harness
int main() {
    printf("TAP version 14\n");
    printf("1..1\n");
    S s;
    s.e();
    printf("ok 1 - inline_after_forward_then_transition_exec\n");
    return 0;
}

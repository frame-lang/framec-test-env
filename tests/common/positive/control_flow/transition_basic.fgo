@@target go

package main

import "fmt"

@@system S {
    machine:
        $A {
            E() {
                -> $B()
            }
        }
        $B {
        }
}

func main() {
	fmt.Println("TAP version 14")
	fmt.Println("1..1")
	s := NewS()
	s.E()
	fmt.Println("ok 1 - transition_basic")
}

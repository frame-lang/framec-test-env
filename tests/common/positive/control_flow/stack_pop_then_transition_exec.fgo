@@[target("go")]

package main

import "fmt"

@@system S {
    machine:
        $A {
            E() {
                push$  // Push current state to stack
                -> $B()
            }
        }
        $B {
            E() {
                -> pop$  // Pop from stack and transition back to A
            }
        }
}

func main() {
	fmt.Println("TAP version 14")
	fmt.Println("1..1")
	s := @@S()
	s.E() // Push A to stack and transition to B
	s.E() // Pop from stack and transition back to A
	fmt.Println("ok 1 - stack_pop_then_transition_exec")
}

@@target kotlin

import kotlin.system.exitProcess

@@system S {
    machine:
        $A {
            e() {
                if (false) {
                    -> $B()
                } else if (false) {
                    -> $C()
                } else {
                    -> $D()
                }
            }
        }
        $B { }
        $C { }
        $D { }
}

fun main() {
    println("TAP version 14")
    println("1..1")
    try {
        val s = S()
        s.e()
        println("ok 1 - elif_multi_transition_exec")
    } catch (ex: Exception) {
        println("not ok 1 - elif_multi_transition_exec # $ex")
    }
}

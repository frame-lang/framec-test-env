@@[target("ruby")]

@@system S {
    machine:
        $A => $P {
            e() {
                => $^; a(); b()
            }
        }
        $P { }
}

def a; end
def b; end

puts("TAP version 14")
puts("1..1")
begin
    s = S.new
    if s.respond_to?(:e)
        s.e()
    end
    puts("ok 1 - forward_inline_semicolon_multi")
rescue => ex
    puts("not ok 1 - forward_inline_semicolon_multi # #{ex}")
end

@@target python

@@system S {
    machine:
        $A => $P {
            e() {
                while cond:
                    => $^
                    step()
                done()
            }
        }
        $P { }
}

# Stub variables and functions for placeholder calls
cond = False  # Set to False so while loop exits immediately
def native(): pass
def x(): pass
def step(): pass
def done(): pass

# TAP test harness
if __name__ == "__main__":
    print("TAP version 14")
    print("1..1")
    try:
        s = @@S()
        if hasattr(s, 'e'):
            s.e()
        print("ok 1 - while_forward_then_native")
    except Exception as ex:
        print(f"not ok 1 - while_forward_then_native # {ex}")

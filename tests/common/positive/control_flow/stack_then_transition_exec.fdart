@@target dart
@@run-expect: STACK:PUSH
@@run-expect: STACK:POP
@@run-expect: TRANSITION:

@@system S {
    machine:
        $A {
            e() {
                push$
                pop$
                -> $B()
            }
        }
        $B { }
}

// Stub functions for placeholder calls
void native() {}
void x() {}

// TAP test harness
void main() {
    print("TAP version 14");
    print("1..1");
    try {
        final s = @@S();
        if (true) {
            s.e();
        }
        print("ok 1 - stack_then_transition_exec");
    } catch (ex) {
        print("not ok 1 - stack_then_transition_exec # ${ex}");
    }
}

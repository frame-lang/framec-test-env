@@[target("dart")]
@@system S {
    machine:
        $A => $P {
            e() {
                => $^; a(); b();
            }
        }
        $P { }
}

// Stub functions for placeholder calls
void native() {}
void x() {}
void a() {}
void b() {}

// TAP test harness
void main() {
    print("TAP version 14");
    print("1..1");
    try {
        final s = @@S();
        if (true) {
            s.e();
        }
        print("ok 1 - forward_inline_semicolon_multi");
    } catch (ex) {
        print("not ok 1 - forward_inline_semicolon_multi # ${ex}");
    }
}

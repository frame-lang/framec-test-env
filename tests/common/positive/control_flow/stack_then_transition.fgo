@@[target("go")]

package main

import "fmt"

@@system S {
    machine:
        $A {
            E() {
                push$
                pop$
                -> $B()
            }
        }
        $B { E() { } }
}

func main() {
	fmt.Println("TAP version 14")
	fmt.Println("1..1")
	s := NewS()
	s.E()
	fmt.Println("ok 1 - stack_then_transition")
}

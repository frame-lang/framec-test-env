@@[target("ruby")]

@@system S {
    machine:
        $A {
            e() {
                # native prelude
                -> $B()
            }
        }
        $B { }
}

puts("TAP version 14")
puts("1..1")
begin
    s = @@S()
    if s.respond_to?(:e)
        s.e()
    end
    puts("ok 1 - terminal_last_transition")
rescue => ex
    puts("not ok 1 - terminal_last_transition # #{ex}")
end

@@[target("csharp")]


class Stubs {
    public static bool cond = false;
    public static void step() {}
    public static void done() {}
}

@@system S {
    machine:
        $A => $P {
            e() {
                while (Stubs.cond) {
                    => $^
                    Stubs.step();
                }
                Stubs.done();
            }
        }
        $P { }
}

class Program {
    static void Main(string[] args) {
        Console.WriteLine("TAP version 14");
        Console.WriteLine("1..1");
        try {
            S s = @@S();
            s.e();
            Console.WriteLine("ok 1 - while_forward_then_native");
        } catch (Exception ex) {
            Console.WriteLine("not ok 1 - while_forward_then_native # " + ex);
        }
    }
}

@@target c

#include <stdio.h>
#include <stdbool.h>

@@system S {
    machine:
        $A {
            e() {
                if (true) {
                    push$
                    -> pop$
                } else {
                    push$
                    -> pop$
                }
                -> $B()
            }
        }
        $B { e() { } }
}

// Stub functions for placeholder calls
void native(void) {}
void x(void) {}

// TAP test harness
int main(void) {
    printf("TAP version 14\n");
    printf("1..1\n");
    S* s = S_new();
    S_e(s);
    printf("ok 1 - nested_stack_then_transition\n");
    S_destroy(s);
    return 0;
}

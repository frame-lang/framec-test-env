@@target go

package main

import "fmt"

@@system S {
    machine:
        $A => $P {
            E() {
                => $^;
                => $^;
                -> $B();
            }
        }
        $B { }
        $P { }
}

func main() {
	fmt.Println("TAP version 14")
	fmt.Println("1..1")
	s := NewS()
	s.E()
	fmt.Println("ok 1 - forwards_twice_then_transition_exec")
}

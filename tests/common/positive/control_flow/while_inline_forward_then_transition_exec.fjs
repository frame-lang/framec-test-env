@@target javascript
@@run-expect: FORWARD:PARENT
@@run-expect: TRANSITION:

@@system S {
    machine:
        $A => $P {
            e() {
                let i = 0
                while (i < 1) {
                    => $^; i += 1
                }
                -> $B()
            }
        }
        $B { }
        $P { }
}

function native() {}
function x() {}

function main() {
    console.log("TAP version 14");
    console.log("1..1");
    try {
        const s = @@S();
        if (typeof s.e === 'function') { s.e(); }
        console.log("ok 1 - while_inline_forward_then_transition_exec");
    } catch (ex) {
        console.log(`not ok 1 - while_inline_forward_then_transition_exec # ${ex}`);
    }
}
main();

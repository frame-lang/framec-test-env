@@target dart

@@system S {
    machine:
        $A => $P {
            e() {
                while (cond) {
                    => $^
                    step()
                }
                done()
            }
        }
        $P { }
}

// Stub functions for placeholder calls
void native(): void {}
void x(): void {}
void done(): void {}
void step(): void {}
final cond = false;

// TAP test harness
void main() {
    print("TAP version 14");
    print("1..1");
    try {
        final s = @@S();
        if (typeof (s as any).e == 'function') {
            (s as any).e();
        }
        print("ok 1 - while_forward_then_native");
    } catch (ex) {
        print("not ok 1 - while_forward_then_native # ${ex}");
    }
}

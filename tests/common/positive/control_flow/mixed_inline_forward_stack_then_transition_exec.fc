@@[target("c")]
@@run-expect: FORWARD:PARENT
@@run-expect: STACK:PUSH
@@run-expect: TRANSITION:

#include <stdio.h>
#include <stdbool.h>

@@system S {
    machine:
        $A => $P {
            e() {
                => $^; int y = 1;  // inline native after forward
                push$; int z = 2;  // inline native after stack push
                -> $B()
            }
        }
        $B { }
        $P { }
}

// Stub functions for placeholder calls
void native(void) {}
void x(void) {}

// TAP test harness
int main(void) {
    printf("TAP version 14\n");
    printf("1..1\n");
    S* s = @@S();
    S_e(s);
    printf("ok 1 - mixed_inline_forward_stack_then_transition_exec\n");
    S_destroy(s);
    return 0;
}

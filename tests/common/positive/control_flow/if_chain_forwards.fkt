@@target kotlin

import kotlin.system.exitProcess

object Stubs {
    var a = true
    var b = false
    fun x() {}
    fun y() {}
    fun z() {}
}

@@system S {
    machine:
        $A => $P {
            e() {
                if (Stubs.a) {
                    => $^
                    Stubs.x()
                } else if (Stubs.b) {
                    => $^
                    Stubs.y()
                } else {
                    => $^
                    Stubs.z()
                }
            }
        }
        $P { }
}

fun main() {
    println("TAP version 14")
    println("1..1")
    try {
        val s = S()
        s.e()
        println("ok 1 - if_chain_forwards")
    } catch (ex: Exception) {
        println("not ok 1 - if_chain_forwards # $ex")
    }
}

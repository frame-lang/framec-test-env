void x() {}

// TAP test harness
int main() {
    printf("TAP version 14\n");
    printf("1..1\n");
    try {
        S s;
        s.e();
        printf("ok 1 - terminal_last_forward\n");
    } catch (...) {
        printf("not ok 1 - terminal_last_forward\n");
    }

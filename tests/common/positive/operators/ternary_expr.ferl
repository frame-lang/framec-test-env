@@target erlang
@@system TernaryExpr {
    interface:
        classify(n: int): str
    machine:
        $Active {
            classify(n: int): str {
                if n > 0 {
                    @@:("positive")
                    return
                } else {
                    @@:("non_positive")
                    return
                }
            }
        }
}

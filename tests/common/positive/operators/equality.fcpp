@@target cpp_17

// Test: Equality operators in Frame handlers
// Tests: ==, !=

#include <iostream>
#include <string>
#include <cassert>

@@system EqualityTest {
    interface:
        test_equal(): bool
        test_not_equal(): bool
        set_values(x: int, y: int)

    machine:
        $Ready {
            test_equal(): bool {
                if (a == b) {
                    @@:return = true
                } else {
                    @@:return = false
                }
            }
            test_not_equal(): bool {
                if (a != b) {
                    @@:return = true
                } else {
                    @@:return = false
                }
            }
            set_values(x: int, y: int) {
                a = x;
                b = y;
            }
        }

    domain:
        int a = 5
        int b = 5
}

int main() {
    printf("TAP version 14\n");
    printf("1..4\n");

    EqualityTest s;

    // a=5, b=5: 5 == 5 is true
    if (s.test_equal()) {
        printf("ok 1 - 5 == 5 is true\n");
    } else {
        printf("not ok 1 - 5 == 5 is true\n");
    }

    // a=5, b=5: 5 != 5 is false
    if (!s.test_not_equal()) {
        printf("ok 2 - 5 != 5 is false\n");
    } else {
        printf("not ok 2 - 5 != 5 is false\n");
    }

    // Change values: a=5, b=3
    s.set_values(5, 3);

    // a=5, b=3: 5 == 3 is false
    if (!s.test_equal()) {
        printf("ok 3 - 5 == 3 is false\n");
    } else {
        printf("not ok 3 - 5 == 3 is false\n");
    }

    // a=5, b=3: 5 != 3 is true
    if (s.test_not_equal()) {
        printf("ok 4 - 5 != 3 is true\n");
    } else {
        printf("not ok 4 - 5 != 3 is true\n");
    }

    return 0;
}

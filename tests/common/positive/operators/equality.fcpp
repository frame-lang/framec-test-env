@@target cpp_17

#include <iostream>
#include <string>
#include <cassert>

@@system S {
    machine:
        $A => $P {
            e() {
                int a = 5;
                int b = 5;
                if (a == b) {
                    => $^
                } else {
                    => $^
                }
            }
        }
        $P { }
}

int main() {
    std::cout << "=== Test: Equality Operators ===" << std::endl;
    S s;

    // Call event handler that exercises equality operators
    s.e();

    std::cout << "PASS: equality" << std::endl;
    return 0;
}

@@target ruby

@@system S {
    machine:
        $A => $P {
            e() {
                if a && b
                    => $^
                elsif a || b
                    => $^
                else
                    => $^
                end
            }
        }
        $P { }
}

a = 1
b = 2

puts("TAP version 14")
puts("1..1")
begin
    s = S.new
    if s.respond_to?(:e)
        s.e()
    end
    puts("ok 1 - logical_ops")
rescue => ex
    puts("not ok 1 - logical_ops # #{ex}")
end

@@target dart
// Test: Equality operators in Frame handlers
// Tests: ==, !=

@@system EqualityTest {
    interface:
        test_equal(): bool
        test_not_equal(): bool
        set_values(x: num, y: num)

    machine:
        $Ready {
            test_equal(): bool {
                if (this.a == this.b) {
                    @@:return = true
                } else {
                    @@:return = false
                }
            }
            test_not_equal(): bool {
                if (this.a != this.b) {
                    @@:return = true
                } else {
                    @@:return = false
                }
            }
            set_values(x: num, y: num) {
                this.a = x;
                this.b = y;
            }
        }

    domain:
        num a = 5
        num b = 5
}

void main() {
    print("TAP version 14");
    print("1..4");

    final s = @@EqualityTest();

    // a=5, b=5: 5 == 5 is true
    if (s.test_equal()) {
        print("ok 1 - 5 == 5 is true");
    } else {
        print("not ok 1 - 5 == 5 is true");
    }

    // a=5, b=5: 5 != 5 is false
    if (!s.test_not_equal()) {
        print("ok 2 - 5 != 5 is false");
    } else {
        print("not ok 2 - 5 != 5 is false");
    }

    // Change values: a=5, b=3
    s.set_values(5, 3);

    // a=5, b=3: 5 == 3 is false
    if (!s.test_equal()) {
        print("ok 3 - 5 == 3 is false");
    } else {
        print("not ok 3 - 5 == 3 is false");
    }

    // a=5, b=3: 5 != 3 is true
    if (s.test_not_equal()) {
        print("ok 4 - 5 != 3 is true");
    } else {
        print("not ok 4 - 5 != 3 is true");
    }
}


@@[target("go")]

package main

import "fmt"

// Test: Equality operators in Frame handlers
// Tests: ==, !=

@@system EqualityTest {
    interface:
        TestEqual(): bool
        TestNotEqual(): bool
        SetValues(x: int, y: int)

    machine:
        $Ready {
            $>() {
                s.a = 5
                s.b = 5
            }
            TestEqual(): bool {
                if s.a == s.b {
                    @@:(true)
                } else {
                    @@:(false)
                }
            }
            TestNotEqual(): bool {
                if s.a != s.b {
                    @@:(true)
                } else {
                    @@:(false)
                }
            }
            SetValues(x: int, y: int) {
                s.a = x
                s.b = y
            }
        }

    domain:
        a : int
        b : int
}

func main() {
	fmt.Println("TAP version 14")
	fmt.Println("1..4")

	s := @@EqualityTest()

	// a=5, b=5: 5 == 5 is true
	if s.TestEqual() {
		fmt.Println("ok 1 - 5 == 5 is true")
	} else {
		fmt.Println("not ok 1 - 5 == 5 is true")
	}

	// a=5, b=5: 5 != 5 is false
	if !s.TestNotEqual() {
		fmt.Println("ok 2 - 5 != 5 is false")
	} else {
		fmt.Println("not ok 2 - 5 != 5 is false")
	}

	// Change values: a=5, b=3
	s.SetValues(5, 3)

	// a=5, b=3: 5 == 3 is false
	if !s.TestEqual() {
		fmt.Println("ok 3 - 5 == 3 is false")
	} else {
		fmt.Println("not ok 3 - 5 == 3 is false")
	}

	// a=5, b=3: 5 != 3 is true
	if s.TestNotEqual() {
		fmt.Println("ok 4 - 5 != 3 is true")
	} else {
		fmt.Println("not ok 4 - 5 != 3 is true")
	}
}

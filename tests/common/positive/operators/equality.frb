@@[target("ruby")]

@@system S {
    machine:
        $A => $P {
            e() {
                if self.a == self.b
                    => $^
                else
                    => $^
                end
            }
        }
        $P { }
    domain:
        a: int = 1
        b: int = 2
}

puts("TAP version 14")
puts("1..1")
begin
    s = S.new
    if s.respond_to?(:e)
        s.e()
    end
    puts("ok 1 - equality")
rescue => ex
    puts("not ok 1 - equality # #{ex}")
end

@@[target("rust")]

// Test: Logical operators in Frame handlers
// Tests: &&, ||, !

@@system LogicalTest {
    interface:
        test_and(): bool
        test_or(): bool
        test_not(): bool
        set_values(x: bool, y: bool)

    machine:
        $Ready {
            test_and(): bool {
                if self.a && self.b {
                    @@:(true)
                } else {
                    @@:(false)
                }
            }
            test_or(): bool {
                if self.a || self.b {
                    @@:(true)
                } else {
                    @@:(false)
                }
            }
            test_not(): bool {
                if !self.a {
                    @@:(true)
                } else {
                    @@:(false)
                }
            }
            set_values(x: bool, y: bool) {
                self.a = x;
                self.b = y;
            }
        }

    domain:
        a: bool
        b: bool
}

fn main() {
    println!("TAP version 14");
    println!("1..6");

    let mut s = @@LogicalTest();
    s.set_values(true, false);

    // a=true, b=false: true && false = false
    if !s.test_and() {
        println!("ok 1 - true && false is false");
    } else {
        println!("not ok 1 - true && false is false");
    }

    // a=true, b=false: true || false = true
    if s.test_or() {
        println!("ok 2 - true || false is true");
    } else {
        println!("not ok 2 - true || false is true");
    }

    // a=true: !true = false
    if !s.test_not() {
        println!("ok 3 - !true is false");
    } else {
        println!("not ok 3 - !true is false");
    }

    // Change values: a=true, b=true
    s.set_values(true, true);

    // true && true = true
    if s.test_and() {
        println!("ok 4 - true && true is true");
    } else {
        println!("not ok 4 - true && true is true");
    }

    // Change values: a=false, b=false
    s.set_values(false, false);

    // false || false = false
    if !s.test_or() {
        println!("ok 5 - false || false is false");
    } else {
        println!("not ok 5 - false || false is false");
    }

    // !false = true
    if s.test_not() {
        println!("ok 6 - !false is true");
    } else {
        println!("not ok 6 - !false is true");
    }
}

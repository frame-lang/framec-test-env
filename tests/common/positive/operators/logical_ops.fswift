@@[target("swift")]

// Test: Logical operators in Frame handlers

@@system LogicalTest {
    interface:
        test_and(): boolean
        test_or(): boolean
        test_not(): boolean
        set_values(x: boolean, y: boolean)

    machine:
        $Ready {
            test_and(): boolean { if (self.a && self.b) { @@:(true) } else { @@:(false) } }
            test_or(): boolean { if (self.a || self.b) { @@:(true) } else { @@:(false) } }
            test_not(): boolean { if (!self.a) { @@:(true) } else { @@:(false) } }
            set_values(x: boolean, y: boolean) { self.a = x; self.b = y }
        }

    domain:
        a: boolean = true
        b: boolean = false
}

// main
    print("TAP version 14")
    print("1..6")
    let s = @@LogicalTest()

    if !s.test_and() { print("ok 1 - true && false is false") } else { print("not ok 1 - true && false is false") }
    if s.test_or() { print("ok 2 - true || false is true") } else { print("not ok 2 - true || false is true") }
    if !s.test_not() { print("ok 3 - !true is false") } else { print("not ok 3 - !true is false") }

    s.set_values(true, true)
    if s.test_and() { print("ok 4 - true && true is true") } else { print("not ok 4 - true && true is true") }

    s.set_values(false, false)
    if !s.test_or() { print("ok 5 - false || false is false") } else { print("not ok 5 - false || false is false") }
    if s.test_not() { print("ok 6 - !false is true") } else { print("not ok 6 - !false is true") }

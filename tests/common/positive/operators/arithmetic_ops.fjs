@@target javascript

@@system S {
    machine:
        $A => $P {
            e() {
                let x = 1 + 2 - 3 * 4 / 5;
                x += 2;
                => $^
            }
        }
        $P { }
}

// Stub functions for placeholder calls
function native() {}
function x() {}

// TAP test harness
function main() {
    console.log("TAP version 14");
    console.log("1..1");
    try {
        const s = @@S();
        if (typeof s.e === 'function') {
            s.e();
        }
        console.log("ok 1 - arithmetic_ops");
    } catch (ex) {
        console.log(`not ok 1 - arithmetic_ops # ${ex}`);
    }
}
main();

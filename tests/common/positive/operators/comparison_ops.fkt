@@[target("kotlin")]

import kotlin.system.exitProcess

// Test: Comparison operators in Frame handlers
// Tests: >, <, >=, <=, ==, !=

@@system ComparisonTest {
    interface:
        test_greater(): Boolean
        test_less(): Boolean
        test_greater_equal(): Boolean
        test_less_equal(): Boolean
        test_equal(): Boolean
        test_not_equal(): Boolean
        set_values(x: Int, y: Int)

    machine:
        $Ready {
            test_greater(): Boolean {
                if (this.a > this.b) {
                    @@:(true)
                } else {
                    @@:(false)
                }
            }
            test_less(): Boolean {
                if (this.a < this.b) {
                    @@:(true)
                } else {
                    @@:(false)
                }
            }
            test_greater_equal(): Boolean {
                if (this.a >= this.b) {
                    @@:(true)
                } else {
                    @@:(false)
                }
            }
            test_less_equal(): Boolean {
                if (this.a <= this.b) {
                    @@:(true)
                } else {
                    @@:(false)
                }
            }
            test_equal(): Boolean {
                if (this.a == this.b) {
                    @@:(true)
                } else {
                    @@:(false)
                }
            }
            test_not_equal(): Boolean {
                if (this.a != this.b) {
                    @@:(true)
                } else {
                    @@:(false)
                }
            }
            set_values(x: Int, y: Int) {
                this.a = x
                this.b = y
            }
        }

    domain:
        a = 5
        b = 3
}

fun main() {
    println("TAP version 14")
    println("1..6")

    val s = ComparisonTest()

    if (s.test_greater() as Boolean) {
        println("ok 1 - 5 > 3 is true")
    } else {
        println("not ok 1 - 5 > 3 is true")
    }

    if (!(s.test_less() as Boolean)) {
        println("ok 2 - 5 < 3 is false")
    } else {
        println("not ok 2 - 5 < 3 is false")
    }

    if (s.test_greater_equal() as Boolean) {
        println("ok 3 - 5 >= 3 is true")
    } else {
        println("not ok 3 - 5 >= 3 is true")
    }

    if (!(s.test_less_equal() as Boolean)) {
        println("ok 4 - 5 <= 3 is false")
    } else {
        println("not ok 4 - 5 <= 3 is false")
    }

    if (!(s.test_equal() as Boolean)) {
        println("ok 5 - 5 == 3 is false")
    } else {
        println("not ok 5 - 5 == 3 is false")
    }

    if (s.test_not_equal() as Boolean) {
        println("ok 6 - 5 != 3 is true")
    } else {
        println("not ok 6 - 5 != 3 is true")
    }
}

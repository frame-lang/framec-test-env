@@target lua
@@system S {
    machine:
        $A => $P {
            e() {
                if a > b {
                    => $^
                } else {
                    if a < b {
                    => $^
                } else {
                    if a ~= b {
                    => $^
                } else {
                    => $^
                }
                }
                }
            }
        }
        $P { }
}

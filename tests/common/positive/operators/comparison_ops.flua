@@[target("lua")]
@@system S {
    machine:
        $A => $P {
            e() {
                if a > b {
                    => $^
                } elseif a < b {
                    => $^
                } elseif a ~= b {
                    => $^
                } else {
                    => $^
                }
            }
        }
        $P { }
}

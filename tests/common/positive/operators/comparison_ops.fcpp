@@[target("cpp_17")]

// Test: Comparison operators in Frame handlers
// Tests: >, <, >=, <=, ==, !=

#include <iostream>
#include <cassert>

@@system ComparisonTest {
    interface:
        test_greater(): bool
        test_less(): bool
        test_greater_equal(): bool
        test_less_equal(): bool
        test_equal(): bool
        test_not_equal(): bool
        set_values(x: int, y: int)

    machine:
        $Ready {
            test_greater(): bool {
                if (a > b) {
                    @@:(true)
                } else {
                    @@:(false)
                }
            }
            test_less(): bool {
                if (a < b) {
                    @@:(true)
                } else {
                    @@:(false)
                }
            }
            test_greater_equal(): bool {
                if (a >= b) {
                    @@:(true)
                } else {
                    @@:(false)
                }
            }
            test_less_equal(): bool {
                if (a <= b) {
                    @@:(true)
                } else {
                    @@:(false)
                }
            }
            test_equal(): bool {
                if (a == b) {
                    @@:(true)
                } else {
                    @@:(false)
                }
            }
            test_not_equal(): bool {
                if (a != b) {
                    @@:(true)
                } else {
                    @@:(false)
                }
            }
            set_values(x: int, y: int) {
                a = x;
                b = y;
            }
        }

    domain:
        a : int = 5
        b : int = 3
}

int main() {
    printf("TAP version 14\n");
    printf("1..6\n");

    auto s = @@ComparisonTest();

    // a=5, b=3: 5 > 3 is true
    if (s.test_greater()) {
        printf("ok 1 - 5 > 3 is true\n");
    } else {
        printf("not ok 1 - 5 > 3 is true\n");
    }

    // a=5, b=3: 5 < 3 is false
    if (!s.test_less()) {
        printf("ok 2 - 5 < 3 is false\n");
    } else {
        printf("not ok 2 - 5 < 3 is false\n");
    }

    // a=5, b=3: 5 >= 3 is true
    if (s.test_greater_equal()) {
        printf("ok 3 - 5 >= 3 is true\n");
    } else {
        printf("not ok 3 - 5 >= 3 is true\n");
    }

    // a=5, b=3: 5 <= 3 is false
    if (!s.test_less_equal()) {
        printf("ok 4 - 5 <= 3 is false\n");
    } else {
        printf("not ok 4 - 5 <= 3 is false\n");
    }

    // a=5, b=3: 5 == 3 is false
    if (!s.test_equal()) {
        printf("ok 5 - 5 == 3 is false\n");
    } else {
        printf("not ok 5 - 5 == 3 is false\n");
    }

    // a=5, b=3: 5 != 3 is true
    if (s.test_not_equal()) {
        printf("ok 6 - 5 != 3 is true\n");
    } else {
        printf("not ok 6 - 5 != 3 is true\n");
    }

    return 0;
}

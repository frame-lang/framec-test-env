@@target cpp_17

#include <iostream>
#include <string>
#include <cassert>

@@system S {
    machine:
        $A => $P {
            e() {
                int a = 5;
                int b = 10;
                if (a > b) {
                    => $^
                } else if (a < b) {
                    => $^
                } else if (a != b) {
                    => $^
                } else {
                    => $^
                }
            }
        }
        $P { }
}

int main() {
    std::cout << "=== Test: Comparison Operators ===" << std::endl;
    S s;

    // Call event handler that exercises comparison operators
    s.e();

    std::cout << "PASS: comparison_ops" << std::endl;
    return 0;
}

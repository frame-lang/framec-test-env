@@target gdscript

@@system S {
    machine:
        $A => $P {
            e() {
                if a > b:
                    => $^
                elif a < b:
                    => $^
                elif a != b:
                    => $^
                else:
                    => $^
            }
        }
        $P { }
}

# Stub variables and functions for placeholder calls
a = 1
b = 2

# TAP test harness
func _ready():
    print("TAP version 14")
    print("1..1")
    s = @@S()
    if s.has_method("e"):
        s.e()
    print("ok 1 - comparison_ops")
@@[target("gdscript")]
extends SceneTree

@@system S {
    machine:
        $A => $P {
            e() {
                var x = 1 + 2 - 3 * 4 / 5
                x += 2
                => $^
                str(x)
            }
        }
        $P { }
}

# Stub functions for placeholder calls
func native(): pass
func x(): pass

# TAP test harness
func _init():
    print("TAP version 14")
    print("1..1")
    var s = @@S()
    if s.has_method("e"):
        s.e()
    print("ok 1 - arithmetic_ops")
    quit()

@@target gdscript

@@system S {
    machine:
        $A => $P {
            e() {
                x = 1 + 2 - 3 * 4 / 5
                x += 2
                => $^
                str(x)
            }
        }
        $P { }
}

# Stub functions for placeholder calls

# TAP test harness
func _ready():
    print("TAP version 14")
    print("1..1")
    s = @@S()
    if s.has_method("e"):
        s.e()
    print("ok 1 - arithmetic_ops")
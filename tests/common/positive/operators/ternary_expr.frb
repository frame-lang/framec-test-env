@@[target("ruby")]

@@system S {
    machine:
        $A => $P {
            e() {
                x = self.cond ? 1 : 2
                => $^
                x.to_s
            }
        }
        $P { }
    domain:
        cond: bool = true
}

puts("TAP version 14")
puts("1..1")
begin
    s = S.new
    if s.respond_to?(:e)
        s.e()
    end
    puts("ok 1 - ternary_expr")
rescue => ex
    puts("not ok 1 - ternary_expr # #{ex}")
end

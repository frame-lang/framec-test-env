@@[target("c")]

@@system S {
    machine:
        $A => $P {
            e() {
                int x = 1 + 2 - 3 * 4 / 5;
                x += 2;
                => $^
            }
        }
        $P { }
}

int main() {
    printf("=== Test: Arithmetic Operators ===\n");
    S* s = @@S();

    // Test that system instantiates and handles arithmetic ops
    if (s == NULL) {
        printf("FAIL: Failed to create system\n");
        return 1;
    }

    // Call event handler that exercises arithmetic operators
    S_e(s);

    printf("PASS: arithmetic_ops\n");
    S_destroy(s);
    return 0;
}

@@[target("c")]

@@system S {
    machine:
        $A => $P {
            e() {
                int cond = 1;
                int x = cond ? 1 : 2;
                => $^
            }
        }
        $P { }
}

int main() {
    printf("=== Test: Ternary Expression ===\n");
    S* s = @@S();

    // Test that system instantiates and handles ternary expressions
    if (s == NULL) {
        printf("FAIL: Failed to create system\n");
        return 1;
    }

    // Call event handler that exercises ternary expression
    S_e(s);

    printf("PASS: ternary_expr\n");
    S_destroy(s);
    return 0;
}

@@target swift

// Test: Ternary/conditional expressions in Frame handlers

@@system TernaryTest {
    interface:
        get_value(): number
        set_condition(c: boolean)

    machine:
        $Ready {
            get_value(): number {
                let result = self.cond ? 100 : 200
                @@:(result)
            }
            set_condition(c: boolean) {
                self.cond = c
            }
        }

    domain:
        cond: boolean = true
}

// main
    print("TAP version 14")
    print("1..2")
    let s = @@TernaryTest()

    let v1 = s.get_value()
    if v1 == 100 {
        print("ok 1 - cond=true returns 100")
    } else {
        print("not ok 1 - cond=true returns 100 # got \(v1)")
    }

    s.set_condition(false)
    let v2 = s.get_value()
    if v2 == 200 {
        print("ok 2 - cond=false returns 200")
    } else {
        print("not ok 2 - cond=false returns 200 # got \(v2)")
    }

@@[target("dart")]
// Test: Ternary/conditional expressions in Frame handlers
// TypeScript uses: cond ? a : b

@@system TernaryTest {
    interface:
        get_value(): num
        set_condition(c: bool)

    machine:
        $Ready {
            get_value(): num {
                final result = this.cond ? 100 : 200;
                @@:(result)
            }
            set_condition(c: bool) {
                this.cond = c;
            }
        }

    domain:
        cond : bool = true
}

void main() {
    print("TAP version 14");
    print("1..2");

    final s = @@TernaryTest();

    // cond=true: should return 100
    final v1 = s.get_value();
    if (v1 == 100) {
        print("ok 1 - cond=true returns 100");
    } else {
        print("not ok 1 - cond=true returns 100 # got ${v1}");
    }

    // cond=false: should return 200
    s.set_condition(false);
    final v2 = s.get_value();
    if (v2 == 200) {
        print("ok 2 - cond=false returns 200");
    } else {
        print("not ok 2 - cond=false returns 200 # got ${v2}");
    }
}


@@[target("ruby")]

@@system S {
    machine:
        $A => $P {
            e() {
                x = 1 + 2 - 3 * 4 / 5
                x += 2
                => $^
                x.to_s
            }
        }
        $P { }
}

puts("TAP version 14")
puts("1..1")
begin
    s = @@S()
    if s.respond_to?(:e)
        s.e()
    end
    puts("ok 1 - arithmetic_ops")
rescue => ex
    puts("not ok 1 - arithmetic_ops # #{ex}")
end

@@[target("c")]

@@system S {
    machine:
        $A => $P {
            e() {
                int a = 1;
                int b = 0;
                if (a && b) {
                    => $^
                } else if (a || b) {
                    => $^
                } else {
                    => $^
                }
            }
        }
        $P { }
}

int main() {
    printf("=== Test: Logical Operators ===\n");
    S* s = @@S();

    // Test that system instantiates and handles logical ops
    if (s == NULL) {
        printf("FAIL: Failed to create system\n");
        return 1;
    }

    // Call event handler that exercises logical operators
    S_e(s);

    printf("PASS: logical_ops\n");
    S_destroy(s);
    return 0;
}

@@target swift

// Test: Equality operators in Frame handlers

@@system EqualityTest {
    interface:
        test_equal(): boolean
        test_not_equal(): boolean
        set_values(x: number, y: number)

    machine:
        $Ready {
            test_equal(): boolean { if (self.a == self.b) { @@:return = true } else { @@:return = false } }
            test_not_equal(): boolean { if (self.a != self.b) { @@:return = true } else { @@:return = false } }
            set_values(x: number, y: number) { self.a = x; self.b = y }
        }

    domain:
        a: number = 5
        b: number = 5
}

// main
    print("TAP version 14")
    print("1..4")
    let s = @@EqualityTest()

    if s.test_equal() { print("ok 1 - 5 == 5 is true") } else { print("not ok 1 - 5 == 5 is true") }
    if !s.test_not_equal() { print("ok 2 - 5 != 5 is false") } else { print("not ok 2 - 5 != 5 is false") }

    s.set_values(5, 3)

    if !s.test_equal() { print("ok 3 - 5 == 3 is false") } else { print("not ok 3 - 5 == 3 is false") }
    if s.test_not_equal() { print("ok 4 - 5 != 3 is true") } else { print("not ok 4 - 5 != 3 is true") }

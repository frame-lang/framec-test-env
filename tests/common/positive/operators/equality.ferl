@@target erlang
@@system Equality {
    interface:
        isEqual(a: int, b: int): bool
    machine:
        $Active {
            isEqual(a: int, b: int): bool {
                if a == b {
                    @@:(true)
                    return
                } else {
                    @@:(false)
                    return
                }
            }
        }
}

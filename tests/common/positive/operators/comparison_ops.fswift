@@target swift

// Test: Comparison operators in Frame handlers

@@system ComparisonTest {
    interface:
        test_greater(): boolean
        test_less(): boolean
        test_greater_equal(): boolean
        test_less_equal(): boolean
        test_equal(): boolean
        test_not_equal(): boolean
        set_values(x: number, y: number)

    machine:
        $Ready {
            test_greater(): boolean { if (self.a > self.b) { @@:return = true } else { @@:return = false } }
            test_less(): boolean { if (self.a < self.b) { @@:return = true } else { @@:return = false } }
            test_greater_equal(): boolean { if (self.a >= self.b) { @@:return = true } else { @@:return = false } }
            test_less_equal(): boolean { if (self.a <= self.b) { @@:return = true } else { @@:return = false } }
            test_equal(): boolean { if (self.a == self.b) { @@:return = true } else { @@:return = false } }
            test_not_equal(): boolean { if (self.a != self.b) { @@:return = true } else { @@:return = false } }
            set_values(x: number, y: number) { self.a = x; self.b = y }
        }

    domain:
        a: number = 5
        b: number = 3
}

// main
    print("TAP version 14")
    print("1..6")
    let s = @@ComparisonTest()

    if s.test_greater() { print("ok 1 - 5 > 3 is true") } else { print("not ok 1 - 5 > 3 is true") }
    if !s.test_less() { print("ok 2 - 5 < 3 is false") } else { print("not ok 2 - 5 < 3 is false") }
    if s.test_greater_equal() { print("ok 3 - 5 >= 3 is true") } else { print("not ok 3 - 5 >= 3 is true") }
    if !s.test_less_equal() { print("ok 4 - 5 <= 3 is false") } else { print("not ok 4 - 5 <= 3 is false") }
    if !s.test_equal() { print("ok 5 - 5 == 3 is false") } else { print("not ok 5 - 5 == 3 is false") }
    if s.test_not_equal() { print("ok 6 - 5 != 3 is true") } else { print("not ok 6 - 5 != 3 is true") }

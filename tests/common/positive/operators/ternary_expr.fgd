@@target gdscript
extends SceneTree

@@system S {
    machine:
        $A => $P {
            e() {
                var x = 1 if cond else 2
                => $^
                str(x)
            }
        }
        $P { }
}

# Stub variables and functions for placeholder calls
a = 1
cond = true
b = 2

# TAP test harness
func _init():
    print("TAP version 14")
    print("1..1")
    var s = @@S()
    if s.has_method("e"):
        s.e()
    print("ok 1 - ternary_expr")
    quit()

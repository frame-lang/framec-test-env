@@target kotlin

import kotlin.system.exitProcess

// Test: Equality operators in Frame handlers
// Tests: ==, !=

@@system EqualityTest {
    interface:
        test_equal(): Boolean
        test_not_equal(): Boolean
        set_values(x: Int, y: Int)

    machine:
        $Ready {
            test_equal(): Boolean {
                if (this.a == this.b) {
                    @@:return = true
                } else {
                    @@:return = false
                }
            }
            test_not_equal(): Boolean {
                if (this.a != this.b) {
                    @@:return = true
                } else {
                    @@:return = false
                }
            }
            set_values(x: Int, y: Int) {
                this.a = x
                this.b = y
            }
        }

    domain:
        a = 5
        b = 5
}

fun main() {
    println("TAP version 14")
    println("1..4")

    val s = EqualityTest()

    if (s.test_equal() as Boolean) {
        println("ok 1 - 5 == 5 is true")
    } else {
        println("not ok 1 - 5 == 5 is true")
    }

    if (!(s.test_not_equal() as Boolean)) {
        println("ok 2 - 5 != 5 is false")
    } else {
        println("not ok 2 - 5 != 5 is false")
    }

    s.set_values(5, 3)

    if (!(s.test_equal() as Boolean)) {
        println("ok 3 - 5 == 3 is false")
    } else {
        println("not ok 3 - 5 == 3 is false")
    }

    if (s.test_not_equal() as Boolean) {
        println("ok 4 - 5 != 3 is true")
    } else {
        println("not ok 4 - 5 != 3 is true")
    }
}

@@[target("rust")]

// Test: Equality operators in Frame handlers
// Tests: ==, !=

@@system EqualityTest {
    interface:
        test_equal(): bool
        test_not_equal(): bool
        set_values(x: i32, y: i32)

    machine:
        $Ready {
            test_equal(): bool {
                if self.a == self.b {
                    @@:(true)
                } else {
                    @@:(false)
                }
            }
            test_not_equal(): bool {
                if self.a != self.b {
                    @@:(true)
                } else {
                    @@:(false)
                }
            }
            set_values(x: i32, y: i32) {
                self.a = x;
                self.b = y;
            }
        }

    domain:
        a: i32
        b: i32
}

fn main() {
    println!("TAP version 14");
    println!("1..4");

    let mut s = @@EqualityTest();
    s.set_values(5, 5);

    // a=5, b=5: 5 == 5 is true
    if s.test_equal() {
        println!("ok 1 - 5 == 5 is true");
    } else {
        println!("not ok 1 - 5 == 5 is true");
    }

    // a=5, b=5: 5 != 5 is false
    if !s.test_not_equal() {
        println!("ok 2 - 5 != 5 is false");
    } else {
        println!("not ok 2 - 5 != 5 is false");
    }

    // Change values: a=5, b=3
    s.set_values(5, 3);

    // a=5, b=3: 5 == 3 is false
    if !s.test_equal() {
        println!("ok 3 - 5 == 3 is false");
    } else {
        println!("not ok 3 - 5 == 3 is false");
    }

    // a=5, b=3: 5 != 3 is true
    if s.test_not_equal() {
        println!("ok 4 - 5 != 3 is true");
    } else {
        println!("not ok 4 - 5 != 3 is true");
    }
}

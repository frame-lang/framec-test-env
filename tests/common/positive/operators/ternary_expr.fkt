@@target kotlin

import kotlin.system.exitProcess

// Test: Ternary/conditional expressions in Frame handlers
// Kotlin uses: if (cond) a else b

@@system TernaryTest {
    interface:
        get_value(): Int
        set_condition(c: Boolean)

    machine:
        $Ready {
            get_value(): Int {
                val result = if (this.cond) 100 else 200
                @@:return = result
            }
            set_condition(c: Boolean) {
                this.cond = c
            }
        }

    domain:
        cond = true
}

fun main() {
    println("TAP version 14")
    println("1..2")

    val s = TernaryTest()

    // cond=true: should return 100
    val v1 = s.get_value() as Int
    if (v1 == 100) {
        println("ok 1 - cond=true returns 100")
    } else {
        println("not ok 1 - cond=true returns 100 # got $v1")
    }

    // cond=false: should return 200
    s.set_condition(false)
    val v2 = s.get_value() as Int
    if (v2 == 200) {
        println("ok 2 - cond=false returns 200")
    } else {
        println("not ok 2 - cond=false returns 200 # got $v2")
    }
}

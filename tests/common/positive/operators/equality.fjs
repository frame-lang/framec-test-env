@@target javascript

// Test: Equality operators in Frame handlers
// Tests: ==, !=

@@system EqualityTest {
    interface:
        test_equal(): boolean
        test_not_equal(): boolean
        set_values(x: number, y: number)

    machine:
        $Ready {
            test_equal(): boolean {
                if (this.a == this.b) {
                    @@:(true)
                } else {
                    @@:(false)
                }
            }
            test_not_equal(): boolean {
                if (this.a != this.b) {
                    @@:(true)
                } else {
                    @@:(false)
                }
            }
            set_values(x: number, y: number) {
                this.a = x;
                this.b = y;
            }
        }

    domain:
        a = 5
        b = 5
}

function main() {
    console.log("TAP version 14");
    console.log("1..4");

    const s = @@EqualityTest();

    // a=5, b=5: 5 == 5 is true
    if (s.test_equal()) {
        console.log("ok 1 - 5 == 5 is true");
    } else {
        console.log("not ok 1 - 5 == 5 is true");
    }

    // a=5, b=5: 5 != 5 is false
    if (!s.test_not_equal()) {
        console.log("ok 2 - 5 != 5 is false");
    } else {
        console.log("not ok 2 - 5 != 5 is false");
    }

    // Change values: a=5, b=3
    s.set_values(5, 3);

    // a=5, b=3: 5 == 3 is false
    if (!s.test_equal()) {
        console.log("ok 3 - 5 == 3 is false");
    } else {
        console.log("not ok 3 - 5 == 3 is false");
    }

    // a=5, b=3: 5 != 3 is true
    if (s.test_not_equal()) {
        console.log("ok 4 - 5 != 3 is true");
    } else {
        console.log("not ok 4 - 5 != 3 is true");
    }
}

main();

@@target erlang
@@system CompOps {
    interface:
        isGreater(a: int, b: int): bool
    machine:
        $Active {
            isGreater(a: int, b: int): bool {
                if a > b {
                    @@:(true)
                    return
                } else {
                    @@:(false)
                    return
                }
            }
        }
}

@@target dart
@@system S {
    machine:
        $A => $P {
            e() {
                var x = 1 + 2 - 3 * 4 / 5;
                x += 2;
                => $^
            }
        }
        $P { }
}

// Stub functions for placeholder calls
void native() {}
void x() {}

// TAP test harness
void main() {
    print("TAP version 14");
    print("1..1");
    try {
        final s = @@S();
        if (true) {
            s.e();
        }
        print("ok 1 - arithmetic_ops");
    } catch (ex) {
        print("not ok 1 - arithmetic_ops # ${ex}");
    }
}

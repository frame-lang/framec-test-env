@@target rust

// Test: Ternary/conditional expressions in Frame handlers
// Rust uses: if cond { a } else { b }

@@system TernaryTest {
    interface:
        get_value(): i32
        set_condition(c: bool)

    machine:
        $Ready {
            get_value(): i32 {
                let result = if self.cond { 100 } else { 200 };
                @@:return = result
            }
            set_condition(c: bool) {
                self.cond = c;
            }
        }

    domain:
        cond: bool
}

fn main() {
    println!("TAP version 14");
    println!("1..2");

    let mut s = TernaryTest::new();
    s.set_condition(true);

    // cond=true: should return 100
    let v1 = s.get_value();
    if v1 == 100 {
        println!("ok 1 - cond=true returns 100");
    } else {
        println!("not ok 1 - cond=true returns 100 # got {}", v1);
    }

    // cond=false: should return 200
    s.set_condition(false);
    let v2 = s.get_value();
    if v2 == 200 {
        println!("ok 2 - cond=false returns 200");
    } else {
        println!("not ok 2 - cond=false returns 200 # got {}", v2);
    }
}

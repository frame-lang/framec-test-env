@@[target("c")]

@@system S {
    machine:
        $A => $P {
            e() {
                int a = 5;
                int b = 5;
                if (a == b) {
                    => $^
                } else {
                    => $^
                }
            }
        }
        $P { }
}

int main() {
    printf("=== Test: Equality Operators ===\n");
    S* s = @@S();

    // Test that system instantiates and handles equality ops
    if (s == NULL) {
        printf("FAIL: Failed to create system\n");
        return 1;
    }

    // Call event handler that exercises equality operators
    S_e(s);

    printf("PASS: equality\n");
    S_destroy(s);
    return 0;
}

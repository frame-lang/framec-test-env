@@target cpp_17

#include <iostream>
#include <string>
#include <cassert>

@@system S {
    machine:
        $A => $P {
            e() {
                int cond = 1;
                int x = cond ? 1 : 2;
                => $^
            }
        }
        $P { }
}

int main() {
    std::cout << "=== Test: Ternary Expression ===" << std::endl;
    S s;

    // Call event handler that exercises ternary expression
    s.e();

    std::cout << "PASS: ternary_expr" << std::endl;
    return 0;
}

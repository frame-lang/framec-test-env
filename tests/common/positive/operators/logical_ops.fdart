@@target dart
// Test: Logical operators in Frame handlers
// Tests: &&, ||, !

@@system LogicalTest {
    interface:
        test_and(): bool
        test_or(): bool
        test_not(): bool
        set_values(x: bool, y: bool)

    machine:
        $Ready {
            test_and(): bool {
                if (this.a && this.b) {
                    @@:(true)
                } else {
                    @@:(false)
                }
            }
            test_or(): bool {
                if (this.a || this.b) {
                    @@:(true)
                } else {
                    @@:(false)
                }
            }
            test_not(): bool {
                if (!this.a) {
                    @@:(true)
                } else {
                    @@:(false)
                }
            }
            set_values(x: bool, y: bool) {
                this.a = x;
                this.b = y;
            }
        }

    domain:
        bool a = true
        bool b = false
}

void main() {
    print("TAP version 14");
    print("1..6");

    final s = @@LogicalTest();

    // a=true, b=false: true && false = false
    if (!s.test_and()) {
        print("ok 1 - true && false is false");
    } else {
        print("not ok 1 - true && false is false");
    }

    // a=true, b=false: true || false = true
    if (s.test_or()) {
        print("ok 2 - true || false is true");
    } else {
        print("not ok 2 - true || false is true");
    }

    // a=true: !true = false
    if (!s.test_not()) {
        print("ok 3 - !true is false");
    } else {
        print("not ok 3 - !true is false");
    }

    // Change values: a=true, b=true
    s.set_values(true, true);

    // true && true = true
    if (s.test_and()) {
        print("ok 4 - true && true is true");
    } else {
        print("not ok 4 - true && true is true");
    }

    // Change values: a=false, b=false
    s.set_values(false, false);

    // false || false = false
    if (!s.test_or()) {
        print("ok 5 - false || false is false");
    } else {
        print("not ok 5 - false || false is false");
    }

    // !false = true
    if (s.test_not()) {
        print("ok 6 - !false is true");
    } else {
        print("not ok 6 - !false is true");
    }
}


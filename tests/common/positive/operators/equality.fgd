@@[target("gdscript")]
extends SceneTree

@@system S {
    machine:
        $A => $P {
            e() {
                if a == b:
                    => $^
                else:
                    => $^
            }
        }
        $P { }
}

# Stub variables and functions for placeholder calls
const a = 1
const b = 2

# TAP test harness
func _init():
    print("TAP version 14")
    print("1..1")
    var s = @@S()
    if s.has_method("e"):
        s.e()
    print("ok 1 - equality")
    quit()

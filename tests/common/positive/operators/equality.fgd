@@target gdscript

@@system S {
    machine:
        $A => $P {
            e() {
                if a == b:
                    => $^
                else:
                    => $^
            }
        }
        $P { }
}

# Stub variables and functions for placeholder calls
a = 1
b = 2

# TAP test harness
func _ready():
    print("TAP version 14")
    print("1..1")
    try:
        s = @@S()
        if s.has_method('e'):
            s.e()
        print("ok 1 - equality")
    except Exception as ex:
        print("not ok 1 - equality # {ex}")

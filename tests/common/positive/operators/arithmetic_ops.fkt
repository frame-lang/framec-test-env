@@[target("kotlin")]

import kotlin.system.exitProcess

@@system S {
    machine:
        $A => $P {
            e() {
                var x = 1 + 2 - 3 * 4 / 5
                x += 2
                => $^
            }
        }
        $P { }
}

fun main() {
    println("TAP version 14")
    println("1..1")
    try {
        val s = S()
        s.e()
        println("ok 1 - arithmetic_ops")
    } catch (ex: Exception) {
        println("not ok 1 - arithmetic_ops # $ex")
    }
}

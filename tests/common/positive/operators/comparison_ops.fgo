@@[target("go")]

package main

import "fmt"

// Test: Comparison operators in Frame handlers
// Tests: >, <, >=, <=, ==, !=

@@system ComparisonTest {
    interface:
        TestGreater(): bool
        TestLess(): bool
        TestGreaterEqual(): bool
        TestLessEqual(): bool
        TestEqual(): bool
        TestNotEqual(): bool
        SetValues(x: int, y: int)

    machine:
        $Ready {
            $>() {
                s.a = 5
                s.b = 3
            }
            TestGreater(): bool {
                if s.a > s.b {
                    @@:(true)
                } else {
                    @@:(false)
                }
            }
            TestLess(): bool {
                if s.a < s.b {
                    @@:(true)
                } else {
                    @@:(false)
                }
            }
            TestGreaterEqual(): bool {
                if s.a >= s.b {
                    @@:(true)
                } else {
                    @@:(false)
                }
            }
            TestLessEqual(): bool {
                if s.a <= s.b {
                    @@:(true)
                } else {
                    @@:(false)
                }
            }
            TestEqual(): bool {
                if s.a == s.b {
                    @@:(true)
                } else {
                    @@:(false)
                }
            }
            TestNotEqual(): bool {
                if s.a != s.b {
                    @@:(true)
                } else {
                    @@:(false)
                }
            }
            SetValues(x: int, y: int) {
                s.a = x
                s.b = y
            }
        }

    domain:
        a : int
        b : int
}

func main() {
	fmt.Println("TAP version 14")
	fmt.Println("1..6")

	s := @@ComparisonTest()

	// a=5, b=3: 5 > 3 is true
	if s.TestGreater() {
		fmt.Println("ok 1 - 5 > 3 is true")
	} else {
		fmt.Println("not ok 1 - 5 > 3 is true")
	}

	// a=5, b=3: 5 < 3 is false
	if !s.TestLess() {
		fmt.Println("ok 2 - 5 < 3 is false")
	} else {
		fmt.Println("not ok 2 - 5 < 3 is false")
	}

	// a=5, b=3: 5 >= 3 is true
	if s.TestGreaterEqual() {
		fmt.Println("ok 3 - 5 >= 3 is true")
	} else {
		fmt.Println("not ok 3 - 5 >= 3 is true")
	}

	// a=5, b=3: 5 <= 3 is false
	if !s.TestLessEqual() {
		fmt.Println("ok 4 - 5 <= 3 is false")
	} else {
		fmt.Println("not ok 4 - 5 <= 3 is false")
	}

	// a=5, b=3: 5 == 3 is false
	if !s.TestEqual() {
		fmt.Println("ok 5 - 5 == 3 is false")
	} else {
		fmt.Println("not ok 5 - 5 == 3 is false")
	}

	// a=5, b=3: 5 != 3 is true
	if s.TestNotEqual() {
		fmt.Println("ok 6 - 5 != 3 is true")
	} else {
		fmt.Println("not ok 6 - 5 != 3 is true")
	}
}

@@[target("csharp")]


@@system S {
    machine:
        $A => $P {
            e() {
                int x = 1 + 2 - 3 * 4 / 5;
                x += 2;
                => $^
            }
        }
        $P { }
}

class Program {
    static void Main(string[] args) {
        Console.WriteLine("TAP version 14");
        Console.WriteLine("1..1");
        try {
            S s = @@S();
            s.e();
            Console.WriteLine("ok 1 - arithmetic_ops");
        } catch (Exception ex) {
            Console.WriteLine("not ok 1 - arithmetic_ops # " + ex);
        }
    }
}

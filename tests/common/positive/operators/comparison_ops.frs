@@target rust

// Test: Comparison operators in Frame handlers
// Tests: >, <, >=, <=, ==, !=

@@system ComparisonTest {
    interface:
        test_greater(): bool
        test_less(): bool
        test_greater_equal(): bool
        test_less_equal(): bool
        test_equal(): bool
        test_not_equal(): bool
        set_values(x: i32, y: i32)

    machine:
        $Ready {
            test_greater(): bool {
                if self.a > self.b {
                    @@:return = true
                } else {
                    @@:return = false
                }
            }
            test_less(): bool {
                if self.a < self.b {
                    @@:return = true
                } else {
                    @@:return = false
                }
            }
            test_greater_equal(): bool {
                if self.a >= self.b {
                    @@:return = true
                } else {
                    @@:return = false
                }
            }
            test_less_equal(): bool {
                if self.a <= self.b {
                    @@:return = true
                } else {
                    @@:return = false
                }
            }
            test_equal(): bool {
                if self.a == self.b {
                    @@:return = true
                } else {
                    @@:return = false
                }
            }
            test_not_equal(): bool {
                if self.a != self.b {
                    @@:return = true
                } else {
                    @@:return = false
                }
            }
            set_values(x: i32, y: i32) {
                self.a = x;
                self.b = y;
            }
        }

    domain:
        a: i32
        b: i32
}

fn main() {
    println!("TAP version 14");
    println!("1..6");

    let mut s = ComparisonTest::new();
    s.set_values(5, 3);

    // a=5, b=3: 5 > 3 is true
    if s.test_greater() {
        println!("ok 1 - 5 > 3 is true");
    } else {
        println!("not ok 1 - 5 > 3 is true");
    }

    // a=5, b=3: 5 < 3 is false
    if !s.test_less() {
        println!("ok 2 - 5 < 3 is false");
    } else {
        println!("not ok 2 - 5 < 3 is false");
    }

    // a=5, b=3: 5 >= 3 is true
    if s.test_greater_equal() {
        println!("ok 3 - 5 >= 3 is true");
    } else {
        println!("not ok 3 - 5 >= 3 is true");
    }

    // a=5, b=3: 5 <= 3 is false
    if !s.test_less_equal() {
        println!("ok 4 - 5 <= 3 is false");
    } else {
        println!("not ok 4 - 5 <= 3 is false");
    }

    // a=5, b=3: 5 == 3 is false
    if !s.test_equal() {
        println!("ok 5 - 5 == 3 is false");
    } else {
        println!("not ok 5 - 5 == 3 is false");
    }

    // a=5, b=3: 5 != 3 is true
    if s.test_not_equal() {
        println!("ok 6 - 5 != 3 is true");
    } else {
        println!("not ok 6 - 5 != 3 is true");
    }
}

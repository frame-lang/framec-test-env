@@target python

@@system S {
    machine:
        $A => $P {
            e() {
                x = 1 if cond else 2
                => $^
                str(x)
            }
        }
        $P { }
}

# Stub variables and functions for placeholder calls
a = 1
cond = True
b = 2
def native(): pass
def x(): pass

# TAP test harness
if __name__ == "__main__":
    print("TAP version 14")
    print("1..1")
    try:
        s = S()
        if hasattr(s, 'e'):
            s.e()
        print("ok 1 - ternary_expr")
    except Exception as ex:
        print(f"not ok 1 - ternary_expr # {ex}")

@@target dart
// Test: Comparison operators in Frame handlers
// Tests: >, <, >=, <=, ==, !=

@@system ComparisonTest {
    interface:
        test_greater(): bool
        test_less(): bool
        test_greater_equal(): bool
        test_less_equal(): bool
        test_equal(): bool
        test_not_equal(): bool
        set_values(x: num, y: num)

    machine:
        $Ready {
            test_greater(): bool {
                if (this.a > this.b) {
                    @@:(true)
                } else {
                    @@:(false)
                }
            }
            test_less(): bool {
                if (this.a < this.b) {
                    @@:(true)
                } else {
                    @@:(false)
                }
            }
            test_greater_equal(): bool {
                if (this.a >= this.b) {
                    @@:(true)
                } else {
                    @@:(false)
                }
            }
            test_less_equal(): bool {
                if (this.a <= this.b) {
                    @@:(true)
                } else {
                    @@:(false)
                }
            }
            test_equal(): bool {
                if (this.a == this.b) {
                    @@:(true)
                } else {
                    @@:(false)
                }
            }
            test_not_equal(): bool {
                if (this.a != this.b) {
                    @@:(true)
                } else {
                    @@:(false)
                }
            }
            set_values(x: num, y: num) {
                this.a = x;
                this.b = y;
            }
        }

    domain:
        num a = 5
        num b = 3
}

void main() {
    print("TAP version 14");
    print("1..6");

    final s = @@ComparisonTest();

    // a=5, b=3: 5 > 3 is true
    if (s.test_greater()) {
        print("ok 1 - 5 > 3 is true");
    } else {
        print("not ok 1 - 5 > 3 is true");
    }

    // a=5, b=3: 5 < 3 is false
    if (!s.test_less()) {
        print("ok 2 - 5 < 3 is false");
    } else {
        print("not ok 2 - 5 < 3 is false");
    }

    // a=5, b=3: 5 >= 3 is true
    if (s.test_greater_equal()) {
        print("ok 3 - 5 >= 3 is true");
    } else {
        print("not ok 3 - 5 >= 3 is true");
    }

    // a=5, b=3: 5 <= 3 is false
    if (!s.test_less_equal()) {
        print("ok 4 - 5 <= 3 is false");
    } else {
        print("not ok 4 - 5 <= 3 is false");
    }

    // a=5, b=3: 5 == 3 is false
    if (!s.test_equal()) {
        print("ok 5 - 5 == 3 is false");
    } else {
        print("not ok 5 - 5 == 3 is false");
    }

    // a=5, b=3: 5 != 3 is true
    if (s.test_not_equal()) {
        print("ok 6 - 5 != 3 is true");
    } else {
        print("not ok 6 - 5 != 3 is true");
    }
}


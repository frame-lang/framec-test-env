@@target python_3

# Cookbook 87: OAuth 2.0 Authorization Code + PKCE
# CSRF state check in $AwaitingRedirect. PKCE is mandatory (generated
# in $Idle). use_token() has a real handler only in $Authorized.
# $ExchangingCode's exit handler zeroes auth_code and code_verifier.

@@system OAuthPkceFlow {
    interface:
        start(client_id: str, redirect_uri: str, scope: str, nonce: str)
        authorization_redirect(code: str, state: str)
        exchange_response(access_token: str, refresh_token: str)
        exchange_error(reason: str)
        use_token(): str = "no_token"
        refresh()
        revoke()
        timeout()
        get_status(): str = "idle"
        get_auth_code(): str
        get_code_verifier(): str

    machine:
        $Idle {
            start(client_id: str, redirect_uri: str, scope: str, nonce: str) {
                self.client_id = client_id
                self.redirect_uri = redirect_uri
                self.scope = scope
                # PKCE: generate verifier + challenge. For the test we
                # use a deterministic verifier derived from the passed
                # nonce so the assertions are stable.
                self.code_verifier = nonce
                self.code_challenge = nonce
                self.state_nonce = nonce
                -> $AwaitingRedirect
            }
            get_status(): str { @@:("idle") }
            get_auth_code(): str { @@:(self.auth_code) }
            get_code_verifier(): str { @@:(self.code_verifier) }
        }

        $AwaitingRedirect {
            authorization_redirect(code: str, state: str) {
                if state != self.state_nonce:
                    -> $Failed
                else:
                    self.auth_code = code
                    -> $ExchangingCode
            }
            timeout() { -> $Failed }
            get_status(): str { @@:("awaiting_redirect") }
            get_auth_code(): str { @@:(self.auth_code) }
            get_code_verifier(): str { @@:(self.code_verifier) }
        }

        $ExchangingCode {
            <$() {
                # Zero the one-time secrets before anything else reads
                # them from the post-exchange state.
                self.auth_code = ""
                self.code_verifier = ""
            }

            exchange_response(access_token: str, refresh_token: str) {
                self.access_token = access_token
                self.refresh_token = refresh_token
                -> $Authorized
            }
            exchange_error(reason: str) { -> $Failed }
            timeout() { -> $Failed }
            get_status(): str { @@:("exchanging") }
            get_auth_code(): str { @@:(self.auth_code) }
            get_code_verifier(): str { @@:(self.code_verifier) }
        }

        $Authorized {
            use_token(): str { @@:(self.access_token) }
            refresh() { -> $Refreshing }
            revoke() { -> $Revoked }
            get_status(): str { @@:("authorized") }
            get_auth_code(): str { @@:(self.auth_code) }
            get_code_verifier(): str { @@:(self.code_verifier) }
        }

        $Refreshing {
            exchange_response(access_token: str, refresh_token: str) {
                self.access_token = access_token
                self.refresh_token = refresh_token
                -> $Authorized
            }
            exchange_error(reason: str) { -> $Failed }
            timeout() { -> $Failed }
            get_status(): str { @@:("refreshing") }
            get_auth_code(): str { @@:(self.auth_code) }
            get_code_verifier(): str { @@:(self.code_verifier) }
        }

        $Failed {
            get_status(): str { @@:("failed") }
            get_auth_code(): str { @@:(self.auth_code) }
            get_code_verifier(): str { @@:(self.code_verifier) }
        }

        $Revoked {
            get_status(): str { @@:("revoked") }
            get_auth_code(): str { @@:(self.auth_code) }
            get_code_verifier(): str { @@:(self.code_verifier) }
        }

    domain:
        client_id: str = ""
        redirect_uri: str = ""
        scope: str = ""
        code_verifier: str = ""
        code_challenge: str = ""
        state_nonce: str = ""
        auth_code: str = ""
        access_token: str = ""
        refresh_token: str = ""
}


def check(label, actual, expected):
    if actual != expected:
        print(f"FAIL: {label} expected '{expected}', got '{actual}'")
        import sys
        sys.exit(1)


if __name__ == '__main__':
    # Happy path
    f = @@OAuthPkceFlow()
    check("idle", f.get_status(), "idle")
    check("idle use_token default", f.use_token(), "no_token")

    f.start("myclient", "https://app/cb", "read", "nonce123")
    check("awaiting redirect", f.get_status(), "awaiting_redirect")
    check("PKCE verifier generated", f.get_code_verifier(), "nonce123")
    check("use_token still denied", f.use_token(), "no_token")

    f.authorization_redirect("authcode-XYZ", "nonce123")
    check("exchanging", f.get_status(), "exchanging")
    check("auth code captured", f.get_auth_code(), "authcode-XYZ")

    f.exchange_response("TOKEN-A", "REFRESH-B")
    check("authorized", f.get_status(), "authorized")
    check("token usable", f.use_token(), "TOKEN-A")

    # Post-exchange hygiene: auth_code and code_verifier cleared by the
    # $ExchangingCode exit handler. A stolen memory dump in $Authorized
    # reveals no reusable code.
    check("auth_code zeroed", f.get_auth_code(), "")
    check("code_verifier zeroed", f.get_code_verifier(), "")

    # Replay attack: re-delivering the redirect does nothing from
    # $Authorized (no handler).
    f.authorization_redirect("authcode-XYZ", "nonce123")
    check("authorized absorbs replay", f.get_status(), "authorized")
    check("token still usable", f.use_token(), "TOKEN-A")

    # Refresh
    f.refresh()
    check("refreshing", f.get_status(), "refreshing")
    f.exchange_response("TOKEN-A2", "REFRESH-B2")
    check("authorized post-refresh", f.get_status(), "authorized")
    check("new token", f.use_token(), "TOKEN-A2")

    # Revoke
    f.revoke()
    check("revoked", f.get_status(), "revoked")
    check("revoked denies token", f.use_token(), "no_token")

    # CSRF: wrong state nonce
    f2 = @@OAuthPkceFlow()
    f2.start("myclient", "https://app/cb", "read", "nonce123")
    f2.authorization_redirect("attacker-code", "WRONG-NONCE")
    check("CSRF mismatch -> failed", f2.get_status(), "failed")
    check("CSRF denies token", f2.use_token(), "no_token")

    # Timeout during awaiting redirect
    f3 = @@OAuthPkceFlow()
    f3.start("myclient", "https://app/cb", "read", "nonce123")
    f3.timeout()
    check("timeout failed", f3.get_status(), "failed")

    # Exchange error
    f4 = @@OAuthPkceFlow()
    f4.start("myclient", "https://app/cb", "read", "nonce123")
    f4.authorization_redirect("authcode", "nonce123")
    f4.exchange_error("invalid_grant")
    check("exchange error failed", f4.get_status(), "failed")
    check("no token on exchange error", f4.use_token(), "no_token")

    # Timeout during exchange
    f5 = @@OAuthPkceFlow()
    f5.start("myclient", "https://app/cb", "read", "nonce123")
    f5.authorization_redirect("authcode", "nonce123")
    f5.timeout()
    check("exchange timeout failed", f5.get_status(), "failed")

    # Refresh error transitions to Failed
    f6 = @@OAuthPkceFlow()
    f6.start("myclient", "https://app/cb", "read", "nonce123")
    f6.authorization_redirect("authcode", "nonce123")
    f6.exchange_response("TOKEN", "REFRESH")
    f6.refresh()
    f6.exchange_error("invalid_refresh_token")
    check("refresh error failed", f6.get_status(), "failed")

    print("PASS: oauth_pkce")

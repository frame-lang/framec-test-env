@@[target("rust")]

@@system Flag(initial: bool) {
    interface:
        toggle()
        get(): bool

    machine:
        $Start {
            toggle() {
                self.flag = !self.flag;
            }
            get(): bool { @@:(self.flag) return; }
        }

    domain:
        flag: bool = initial
}

fn main() {
    let mut f = @@Flag(false);
    let v1 = f.get();
    if v1 != false {
        println!("FAIL got {}", v1);
        std::process::exit(1);
    }
    f.toggle();
    let v2 = f.get();
    if v2 != true {
        println!("FAIL got {}", v2);
        std::process::exit(1);
    }
    println!("ok 1 - sysparam_domain_bool");
}

@@[target("csharp")]


@@system User(name: str, age: int, active: bool) {
    interface:
        describe(): str
    machine:
        $Idle {
            describe(): str {
                @@:(this.name + "/" + this.age + "/" + this.active) return;
            }
        }
    domain:
        name: string = name
        age: int = age
        active: bool = active
}

class Program {
    static void Main(string[] args) {
        var s = @@User("alice", 30, true);
        var v = s.describe();
        if (v != "alice/30/True") { Console.WriteLine($"FAIL got {v}"); Environment.Exit(1); }
        Console.WriteLine("ok 1 - sysparam_domain_multi");
    }
}

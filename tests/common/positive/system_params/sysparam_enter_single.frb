@@[target("ruby")]

@@system Worker($>(batch_size: int)) {
    interface:
        get_size(): int

    machine:
        $Start {
            $>(batch_size: int) {
                @__compartment.state_vars["size"] = batch_size
                return
            }

            $.size: int = 0

            get_size(): int {
                s = @__compartment.state_vars["size"]
                @@:(s)
                return
            }
        }
}

w = @@Worker($>(50))
v = w.get_size
if v != 50
    puts "FAIL got #{v}"
    exit(1)
end
puts "ok 1 - sysparam_enter_single"

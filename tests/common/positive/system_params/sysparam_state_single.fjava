@@target java

import java.util.*;

// Test: single state param via $(name: type).
// The param flows from constructor → compartment.state_args, and the
// start state's $(name: type) signature makes it available in handlers.

@@system Robot($(x: int)) {
    interface:
        get_x(): int

    machine:
        $Start(x: int) {
            get_x(): int {
                @@:(x)
                return;
            }
        }
}

class Main {
    public static void main(String[] args) {
        var r = @@Robot($(42));
        int v = r.get_x();
        if (v != 42) {
            System.out.println("FAIL: Expected 42, got " + v);
            System.exit(1);
        }
        System.out.println("ok 1 - sysparam_state_single");
    }
}

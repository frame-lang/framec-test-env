@@target php

<?php

@@system User(name: str, age: int, active: bool) {
    interface:
        describe(): str

    machine:
        $Idle {
            describe(): str {
                @@:($this->name . "/" . $this->age . "/" . ($this->active ? "1" : ""))
                return;
            }
        }

    domain:
        name = $name
        age = $age
        active = $active
}

$u = @@User("alice", 30, true);
$d = $u->describe();
if ($d !== "alice/30/1") {
    echo "FAIL got $d\n";
    exit(1);
}
echo "ok 1 - sysparam_domain_multi\n";

@@target dart

@@system Flag(initial: bool) {
    interface:
        toggle()
        get(): bool
    machine:
        $Idle {
            toggle() {
                this.flag = !this.flag;
            }
            get(): bool {
                @@:(this.flag) return;
            }
        }
    domain:
        flag : bool = initial
}

void main() {
    var f = @@Flag(false);
    var before = f.get();
    if (before != false) {
        throw 'FAIL: expected initial false, got $before';
    }
    f.toggle();
    var after = f.get();
    if (after != true) {
        throw 'FAIL: expected true after toggle, got $after';
    }
    print('ok 1 - sysparam_domain_bool');
}

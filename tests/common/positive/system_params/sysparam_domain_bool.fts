@@target typescript

@@system Flag(initial: bool) {
    interface:
        toggle()
        get(): bool

    machine:
        $Idle {
            toggle() {
                this.flag = !this.flag;
            }

            get(): bool {
                @@:(this.flag)
                return;
            }
        }

    domain:
        flag: boolean = initial
}

const f = @@Flag(false);
const before = f.get();
if (before !== false) {
    console.log(`FAIL got ${before}`);
    process.exit(1);
}
f.toggle();
const after = f.get();
if (after !== true) {
    console.log(`FAIL got ${after}`);
    process.exit(1);
}
console.log("ok 1 - sysparam_domain_bool");

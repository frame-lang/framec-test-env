@@[target("gdscript")]
extends SceneTree

@@system Service($(slot: int), $>(timeout: int), name: str) {
    interface:
        get_slot(): int
        get_timeout(): int
        get_name(): str

    machine:
        $Start(slot: int) {
            $>(timeout: int) {
                self.__compartment.state_vars["t"] = timeout
            }

            $.t: int = 0

            get_slot(): int {
                @@:(slot)
                return
            }
            get_timeout(): int {
                var v = self.__compartment.state_vars["t"]
                @@:(v)
                return
            }
            get_name(): str {
                @@:(self.name)
                return
            }
        }

    domain:
        name = name
}

func main():
    var s = @@Service($(3), $>(100), "svc1")
    var slot = s.get_slot()
    if slot != 3:
        print("FAIL slot got " + str(slot))
        return
    var t = s.get_timeout()
    if t != 100:
        print("FAIL timeout got " + str(t))
        return
    var n = s.get_name()
    if n != "svc1":
        print("FAIL name got " + n)
        return
    print("ok 1 - sysparam_enter_mixed")

func _init():
    main()
    quit()

@@target kotlin

@@system Counter(initial: int) {
    interface:
        increment()
        get(): int
    machine:
        $Idle {
            increment() {
                this.value = this.value + 1
            }
            get(): int {
                @@:(this.value)
            return;
            }
        }
    domain:
        var value: Int = initial
}

fun main() {
    val c = @@Counter(10)
    c.increment()
    c.increment()
    val v = c.get()
    if (v != 12) {
        println("FAIL got $v")
        kotlin.system.exitProcess(1)
    }
    println("ok 1 - sysparam_domain_int")
}

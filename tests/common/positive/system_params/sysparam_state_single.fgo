@@target go

package main

import "fmt"
import "os"

// Test: single state param via $(name: type).
// The param is passed to the start state's state_args.
// State handler reads it via the state's parameter scope.

@@system Robot($(x: int)) {
    interface:
        Get_x(): int

    machine:
        $Start(x: int) {
            Get_x(): int {
                @@:(x)
                return;
            }
        }
}

func main() {
	r := @@Robot($(42))
	v := r.Get_x()
	if v != 42 {
		fmt.Printf("FAIL: Expected 42, got %d\n", v)
		os.Exit(1)
	}
	fmt.Println("ok 1 - sysparam_state_single")
}

@@[target("go")]

package main

import "fmt"
import "os"

// Test: typed domain param with a default value.
// Constructed without arguments should use the default.

@@system Counter(initial: int = 5) {
    interface:
        Increment()
        Get(): int

    machine:
        $Counting {
            Increment() {
                s.value = s.value + 1
            }
            Get(): int {
                @@:(s.value)
                return;
            }
        }

    domain:
        value : int = initial
}

func main() {
	c := @@Counter()
	c.Increment()
	v := c.Get()
	if v != 6 {
		fmt.Printf("FAIL: Expected 6, got %d\n", v)
		os.Exit(1)
	}
	fmt.Println("ok 1 - sysparam_domain_default")
}

@@[target("ruby")]

@@system User(name: str, age: int, active: bool) {
    interface:
        describe(): str

    machine:
        $Idle {
            describe(): str {
                @@:("#{@name}/#{@age}/#{@active}")
                return
            }
        }

    domain:
        name = name
        age = age
        active = active
}

u = @@User("alice", 30, true)
s = u.describe
if s != "alice/30/true"
    puts "FAIL got #{s}"
    exit(1)
end
puts "ok 1 - sysparam_domain_multi"

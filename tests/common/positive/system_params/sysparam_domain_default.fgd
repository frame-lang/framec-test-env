@@[target("gdscript")]
extends SceneTree

@@system Counter(initial: int = 5) {
    interface:
        increment()
        get_value(): int

    machine:
        $Idle {
            increment() {
                self.value = self.value + 1
            }
            get_value(): int {
                @@:(self.value)
                return
            }
        }

    domain:
        value = initial
}

func main():
    var c = @@Counter()
    c.increment()
    var v = c.get_value()
    if v != 6:
        print("FAIL got " + str(v))
        return
    print("ok 1 - sysparam_domain_default")

func _init():
    main()
    quit()

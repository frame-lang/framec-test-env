@@target rust

@@system Counter(initial: i64 = 5) {
    interface:
        increment()
        get(): i64

    machine:
        $Start {
            increment() {
                self.value = self.value + 1;
            }
            get(): i64 { @@:(self.value) return; }
        }

    domain:
        value: i64 = initial
}

fn main() {
    let mut c = @@Counter();
    c.increment();
    let v = c.get();
    if v != 6 {
        println!("FAIL got {}", v);
        std::process::exit(1);
    }
    println!("ok 1 - sysparam_domain_default");
}

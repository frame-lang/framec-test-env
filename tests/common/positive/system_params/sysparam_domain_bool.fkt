@@[target("kotlin")]

@@system Flag(initial: bool) {
    interface:
        toggle()
        get(): bool
    machine:
        $Idle {
            toggle() {
                this.flag = !this.flag
            }
            get(): bool {
                @@:(this.flag)
            return;
            }
        }
    domain:
        flag: Boolean = initial
}

fun main() {
    val f = @@Flag(false)
    val v1 = f.get()
    if (v1 != false) {
        println("FAIL initial got $v1")
        kotlin.system.exitProcess(1)
    }
    f.toggle()
    val v2 = f.get()
    if (v2 != true) {
        println("FAIL toggled got $v2")
        kotlin.system.exitProcess(1)
    }
    println("ok 1 - sysparam_domain_bool")
}

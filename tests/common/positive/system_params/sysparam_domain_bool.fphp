@@[target("php")]


@@system Flag(initial: bool) {
    interface:
        toggle()
        get(): bool

    machine:
        $Idle {
            toggle() {
                $this->flag = !$this->flag;
                return;
            }

            get(): bool {
                @@:($this->flag)
                return;
            }
        }

    domain:
        flag = $initial
}

$f = @@Flag(false);
$v1 = $f->get();
if ($v1 !== false) {
    echo "FAIL initial not false\n";
    exit(1);
}
$f->toggle();
$v2 = $f->get();
if ($v2 !== true) {
    echo "FAIL after toggle not true\n";
    exit(1);
}
echo "ok 1 - sysparam_domain_bool\n";

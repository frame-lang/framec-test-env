@@[target("dart")]

@@system Greeter(name: str) {
    interface:
        greet(): str
    machine:
        $Idle {
            greet(): str {
                @@:("hello, " + this.name) return;
            }
        }
    domain:
        name : String = name
}

void main() {
    var g = @@Greeter("world");
    var v = g.greet();
    if (v != "hello, world") {
        throw 'FAIL: expected "hello, world", got $v';
    }
    print('ok 1 - sysparam_domain_str');
}

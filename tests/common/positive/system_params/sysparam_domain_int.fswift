@@[target("swift")]

@@system Counter(initial: int) {
    interface:
        increment()
        get(): int

    machine:
        $Start {
            increment() {
                self.value = self.value + 1
            }
            get(): int { @@:(self.value)
            return; }
        }

    domain:
        value: Int = initial
}

let c = @@Counter(10)
c.increment()
c.increment()
let v = c.get()
if v != 12 { fatalError("FAIL got \(v)") }
print("ok 1 - sysparam_domain_int")

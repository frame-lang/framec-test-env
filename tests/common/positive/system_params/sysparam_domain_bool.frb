@@target ruby

@@system Flag(initial: bool) {
    interface:
        toggle
        get(): bool

    machine:
        $Idle {
            toggle {
                @flag = !@flag
                return
            }
            get(): bool {
                @@:(@flag)
                return
            }
        }

    domain:
        flag = initial
}

f = @@Flag(false)
v1 = f.get
if v1 != false
    puts "FAIL initial #{v1}"
    exit(1)
end
f.toggle
v2 = f.get
if v2 != true
    puts "FAIL toggled #{v2}"
    exit(1)
end
puts "ok 1 - sysparam_domain_bool"

@@[target("cpp_17")]

#include <iostream>
#include <string>
#include <cassert>
#include <any>

// Test: multiple typed domain params of mixed types.

@@system User(name: str, age: int, active: bool) {
    interface:
        describe(): str

    machine:
        $Idle {
            describe(): str {
                std::string out = this->name + "/" + std::to_string(this->age) + "/" +
                    (this->active ? "true" : "false");
                @@:(out)
                return;
            }
        }

    domain:
        name: std::string = name
        age: int = age
        active: bool = active
}

int main() {
    User u = @@User("alice", 30, true);
    std::string d = u.describe();
    if (d != "alice/30/true") { printf("FAIL got %s\n", d.c_str()); return 1; }
    printf("ok 1 - sysparam_domain_multi\n");
    return 0;
}

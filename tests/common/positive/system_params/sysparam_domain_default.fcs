@@[target("csharp")]


@@system Counter(initial: int = 5) {
    interface:
        increment()
        get(): int
    machine:
        $Idle {
            increment() {
                this.value = this.value + 1;
            }
            get(): int {
                @@:(this.value) return;
            }
        }
    domain:
        value: int = initial
}

class Program {
    static void Main(string[] args) {
        var s = @@Counter();
        s.increment();
        var v = s.get();
        if (v != 6) { Console.WriteLine($"FAIL got {v}"); Environment.Exit(1); }
        Console.WriteLine("ok 1 - sysparam_domain_default");
    }
}

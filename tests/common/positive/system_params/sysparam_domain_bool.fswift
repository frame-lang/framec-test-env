@@[target("swift")]

@@system Flag(initial: bool) {
    interface:
        toggle()
        get(): bool

    machine:
        $Active {
            toggle() {
                self.flag = !self.flag
            }
            get(): bool { @@:(self.flag)
            return; }
        }

    domain:
        flag: Bool = initial
}

let f = @@Flag(false)
let v1 = f.get()
if v1 != false { fatalError("FAIL got \(v1)") }
f.toggle()
let v2 = f.get()
if v2 != true { fatalError("FAIL got \(v2)") }
print("ok 1 - sysparam_domain_bool")

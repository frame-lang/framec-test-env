@@[target("kotlin")]

@@system User(name: str, age: int, active: bool) {
    interface:
        describe(): str
    machine:
        $Idle {
            describe(): str {
                @@:(this.name + "/" + this.age + "/" + this.active)
            return;
            }
        }
    domain:
        name: String = name
        age: Int = age
        active: Boolean = active
}

fun main() {
    val u = @@User("alice", 30, true)
    val v = u.describe()
    if (v != "alice/30/true") {
        println("FAIL got $v")
        kotlin.system.exitProcess(1)
    }
    println("ok 1 - sysparam_domain_multi")
}

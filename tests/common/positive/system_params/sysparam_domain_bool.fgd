@@target gdscript
extends SceneTree

@@system Flag(initial: bool) {
    interface:
        toggle()
        get_value(): bool

    machine:
        $Idle {
            toggle() {
                self.flag = not self.flag
            }
            get_value(): bool {
                @@:(self.flag)
                return
            }
        }

    domain:
        flag = initial
}

func main():
    var f = @@Flag(false)
    var before = f.get_value()
    if before != false:
        print("FAIL before got " + str(before))
        return
    f.toggle()
    var after = f.get_value()
    if after != true:
        print("FAIL after got " + str(after))
        return
    print("ok 1 - sysparam_domain_bool")

func _init():
    main()
    quit()

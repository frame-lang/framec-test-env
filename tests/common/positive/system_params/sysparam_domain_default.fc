@@[target("c")]

#include <stdio.h>
#include <stdlib.h>
#include <stdint.h>

// Test: typed domain param with a default value.
// Constructed without arguments should use the default.

@@system Counter(initial: int = 5) {
    interface:
        increment(): void
        get(): int

    machine:
        $Counting {
            increment() {
                self->value = self->value + 1;
            }
            get(): int { @@:(self->value) return; }
        }

    domain:
        value: int = initial
}

int main(void) {
    Counter* c = @@Counter();
    Counter_increment(c);
    int v = Counter_get(c);
    if (v != 6) { printf("FAIL got %d\n", v); return 1; }
    printf("ok 1 - sysparam_domain_default\n");
    Counter_destroy(c);
    return 0;
}

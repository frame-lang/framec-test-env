@@[target("typescript")]

@@system Robot($(x: int), name: str) {
    interface:
        describe(): str

    machine:
        $Start(x: int) {
            describe(): str {
                @@:(this.name + "@" + x)
                return;
            }
        }

    domain:
        name: string = name
}

const r = @@Robot($(7), "R2D2");
const d = r.describe();
if (d !== "R2D2@7") {
    console.log(`FAIL got ${d}`);
    process.exit(1);
}
console.log("ok 1 - sysparam_mixed");

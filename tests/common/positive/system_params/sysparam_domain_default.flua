@@[target("lua")]

@@system Counter(initial: int = 5) {
    interface:
        increment
        get(): int

    machine:
        $Idle {
            increment {
                self.value = self.value + 1
            }
            get(): int {
                @@:(self.value)
                return
            }
        }

    domain:
        value = initial
}

local c = @@Counter()
c:increment()
local v = c:get()
if v ~= 6 then
    print("FAIL got " .. tostring(v))
    os.exit(1)
end
print("ok 1 - sysparam_domain_default")

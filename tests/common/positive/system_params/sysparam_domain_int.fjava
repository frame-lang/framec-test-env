@@[target("java")]

import java.util.*;

// Test: single typed int domain param.
// The param `initial` becomes a constructor argument and
// initializes the `value` domain field via the raw_code reference.

@@system Counter(initial: int) {
    interface:
        increment()
        get(): int

    machine:
        $Counting {
            increment() {
                this.value = this.value + 1;
            }
            get(): int {
                @@:(this.value)
                return;
            }
        }

    domain:
        value: int = initial
}

class Main {
    public static void main(String[] args) {
        var c = @@Counter(10);
        c.increment();
        c.increment();
        int v = c.get();
        if (v != 12) {
            System.out.println("FAIL: Expected 12, got " + v);
            System.exit(1);
        }
        System.out.println("ok 1 - sysparam_domain_int");
    }
}

@@target csharp

using System;

@@system Robot($(x: int)) {
    interface:
        get_x(): int
    machine:
        $Start(x: int) {
            get_x(): int {
                @@:(x) return;
            }
        }
}

class Program {
    static void Main(string[] args) {
        var s = @@Robot($(42));
        var v = s.get_x();
        if (v != 42) { Console.WriteLine($"FAIL got {v}"); Environment.Exit(1); }
        Console.WriteLine("ok 1 - sysparam_state_single");
    }
}

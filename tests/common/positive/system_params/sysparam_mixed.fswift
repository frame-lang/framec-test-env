@@target swift

@@system Robot(name: str, $(x: int)) {
    interface:
        describe(): str

    machine:
        $Start(x: int) {
            describe(): str { @@:(self.name + "@" + String(x))
            return; }
        }

    domain:
        name: String = name
}

let r = @@Robot("R2D2", $(7))
let s = r.describe()
if s != "R2D2@7" { fatalError("FAIL got \(s)") }
print("ok 1 - sysparam_mixed")

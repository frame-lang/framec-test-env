@@[target("swift")]

@@system Robot($(x: int), name: str) {
    interface:
        describe(): str

    machine:
        $Start(x: int) {
            describe(): str { @@:(self.name + "@" + String(x))
            return; }
        }

    domain:
        name: String = name
}

let r = @@Robot($(7), "R2D2")
let s = r.describe()
if s != "R2D2@7" { fatalError("FAIL got \(s)") }
print("ok 1 - sysparam_mixed")

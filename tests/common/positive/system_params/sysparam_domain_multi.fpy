@@[target("python_3")]

# Test: multiple typed domain params of mixed types.

@@system User(name: str, age: int, active: bool) {
    interface:
        describe(): str

    machine:
        $Idle {
            describe(): str {
                @@:(self.name + "/" + str(self.age) + "/" + str(self.active))
            }
        }

    domain:
        name = name
        age = age
        active = active
}

if __name__ == '__main__':
    u = @@User("alice", 30, True)
    assert u.describe() == "alice/30/True", f"got {u.describe()}"
    print("ok 1 - sysparam_domain_multi")

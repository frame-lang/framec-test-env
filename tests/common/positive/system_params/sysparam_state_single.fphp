@@[target("php")]

<?php

@@system Robot($(x: int)) {
    interface:
        get_x(): int

    machine:
        $Start(x: int) {
            get_x(): int {
                @@:($x)
                return;
            }
        }
}

$r = @@Robot($(42));
$v = $r->get_x();
if ($v !== 42) {
    echo "FAIL got $v\n";
    exit(1);
}
echo "ok 1 - sysparam_state_single\n";

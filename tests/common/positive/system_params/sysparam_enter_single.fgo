@@[target("go")]

package main

import "fmt"
import "os"

// Test: single enter param via $>(name: type).
// The param flows from constructor -> compartment.enter_args, and the
// start state's $>(name: type) enter handler reads it during init.

@@system Worker($>(batch_size: int)) {
    interface:
        Get_size(): int

    machine:
        $Start {
            $>(batch_size: int) {
                s.size = batch_size
            }
            Get_size(): int {
                @@:(s.size)
                return;
            }
        }

    domain:
        size : int = 0
}

func main() {
	w := @@Worker($>(50))
	v := w.Get_size()
	if v != 50 {
		fmt.Printf("FAIL: Expected 50, got %d\n", v)
		os.Exit(1)
	}
	fmt.Println("ok 1 - sysparam_enter_single")
}

@@[target("php")]

<?php

@@system Worker($>(batch_size: int)) {
    interface:
        get_size(): int

    machine:
        $Start {
            $>(batch_size: int) {
                $this->__compartment->state_vars["size"] = $batch_size;
            }

            $.size: int = 0

            get_size(): int {
                $s = $this->__compartment->state_vars["size"];
                @@:($s)
                return;
            }
        }
}

$w = @@Worker($>(50));
$v = $w->get_size();
if ($v !== 50) {
    echo "FAIL got $v\n";
    exit(1);
}
echo "ok 1 - sysparam_enter_single\n";

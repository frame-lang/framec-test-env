@@[target("csharp")]

using System;

@@system Flag(initial: bool) {
    interface:
        toggle()
        get(): bool
    machine:
        $Idle {
            toggle() {
                this.flag = !this.flag;
            }
            get(): bool {
                @@:(this.flag) return;
            }
        }
    domain:
        flag: bool = initial
}

class Program {
    static void Main(string[] args) {
        var s = @@Flag(false);
        var v1 = s.get();
        if (v1 != false) { Console.WriteLine($"FAIL initial got {v1}"); Environment.Exit(1); }
        s.toggle();
        var v2 = s.get();
        if (v2 != true) { Console.WriteLine($"FAIL toggled got {v2}"); Environment.Exit(1); }
        Console.WriteLine("ok 1 - sysparam_domain_bool");
    }
}

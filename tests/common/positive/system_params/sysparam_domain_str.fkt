@@target kotlin

@@system Greeter(name: str) {
    interface:
        greet(): str
    machine:
        $Idle {
            greet(): str {
                @@:("hello, " + this.name)
            return;
            }
        }
    domain:
        var name: String = name
}

fun main() {
    val g = @@Greeter("world")
    val v = g.greet()
    if (v != "hello, world") {
        println("FAIL got $v")
        kotlin.system.exitProcess(1)
    }
    println("ok 1 - sysparam_domain_str")
}

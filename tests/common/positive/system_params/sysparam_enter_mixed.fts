@@target typescript

@@system Service($(slot: int), $>(timeout: int), name: str) {
    interface:
        get_slot(): int
        get_timeout(): int
        get_name(): str

    machine:
        $Start(slot: int) {
            $>(timeout: int) {
                this.__compartment.state_vars["t"] = timeout;
            }

            $.t: int = 0

            get_slot(): int {
                @@:(slot)
                return;
            }

            get_timeout(): int {
                const v: number = this.__compartment.state_vars["t"];
                @@:(v)
                return;
            }

            get_name(): str {
                @@:(this.name)
                return;
            }
        }

    domain:
        name: string = name
}

const svc = @@Service($(0), $>(1000), "primary");
const slot = svc.get_slot();
if (slot !== 0) {
    console.log(`FAIL slot got ${slot}`);
    process.exit(1);
}
const t = svc.get_timeout();
if (t !== 1000) {
    console.log(`FAIL timeout got ${t}`);
    process.exit(1);
}
const n = svc.get_name();
if (n !== "primary") {
    console.log(`FAIL name got ${n}`);
    process.exit(1);
}
console.log("ok 1 - sysparam_enter_mixed");

@@target rust

@@system Robot(name: String, $(x: i64)) {
    interface:
        describe(): String

    machine:
        $Start(x: i64) {
            describe(): String { @@:(format!("{}@{}", self.name, x)) return; }
        }

    domain:
        name: String = name
}

fn main() {
    let mut r = @@Robot(String::from("R2D2"), $(7));
    let s = r.describe();
    if s != "R2D2@7" {
        println!("FAIL got {}", s);
        std::process::exit(1);
    }
    println!("ok 1 - sysparam_mixed");
}

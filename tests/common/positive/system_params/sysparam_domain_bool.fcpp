@@[target("cpp_17")]

#include <iostream>
#include <cassert>

// Test: single typed bool domain param.

@@system Flag(initial: bool) {
    interface:
        toggle(): void
        get(): bool

    machine:
        $Active {
            toggle() {
                this->flag = !this->flag;
            }
            get(): bool { @@:(this->flag) return; }
        }

    domain:
        flag: bool = initial
}

int main() {
    Flag f = @@Flag(false);
    if (f.get() != false) { printf("FAIL initial\n"); return 1; }
    f.toggle();
    if (f.get() != true) { printf("FAIL after toggle\n"); return 2; }
    printf("ok 1 - sysparam_domain_bool\n");
    return 0;
}

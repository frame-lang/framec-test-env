@@[target("swift")]

@@system Robot($(x: int)) {
    interface:
        get_x(): int

    machine:
        $Start(x: int) {
            get_x(): int { @@:(x)
            return; }
        }
}

let r = @@Robot($(42))
let v = r.get_x()
if v != 42 { fatalError("FAIL got \(v)") }
print("ok 1 - sysparam_state_single")

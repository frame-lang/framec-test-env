@@[target("rust")]

@@system Service($(slot: i64), $>(timeout: i64), name: String) {
    interface:
        get_slot(): i64
        get_timeout(): i64
        get_name(): String

    machine:
        $Start(slot: i64) {
            $>(timeout: i64) {
                self.t = timeout;
            }
            get_slot(): i64 { @@:(slot) return; }
            get_timeout(): i64 { @@:(self.t) return; }
            get_name(): String { @@:(self.name.clone()) return; }
        }

    domain:
        name: String = name
        t: i64 = 0
}

fn main() {
    let mut s = @@Service($(0), $>(1000), String::from("primary"));
    let slot = s.get_slot();
    if slot != 0 {
        println!("FAIL got {}", slot);
        std::process::exit(1);
    }
    let timeout = s.get_timeout();
    if timeout != 1000 {
        println!("FAIL got {}", timeout);
        std::process::exit(1);
    }
    let name = s.get_name();
    if name != "primary" {
        println!("FAIL got {}", name);
        std::process::exit(1);
    }
    println!("ok 1 - sysparam_enter_mixed");
}

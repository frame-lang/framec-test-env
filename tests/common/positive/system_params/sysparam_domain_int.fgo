@@target go

package main

import "fmt"
import "os"

// Test: single typed int domain param.
// The param `initial` should become a constructor argument and
// initialize the `value` domain field.

@@system Counter(initial: int) {
    interface:
        Increment()
        Get(): int

    machine:
        $Counting {
            Increment() {
                s.value = s.value + 1
            }
            Get(): int {
                @@:(s.value)
                return;
            }
        }

    domain:
        value : int = initial
}

func main() {
	c := @@Counter(10)
	c.Increment()
	c.Increment()
	v := c.Get()
	if v != 12 {
		fmt.Printf("FAIL: Expected 12, got %d\n", v)
		os.Exit(1)
	}
	fmt.Println("ok 1 - sysparam_domain_int")
}

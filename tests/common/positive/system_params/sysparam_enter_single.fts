@@[target("typescript")]

@@system BatchWorker($>(batch_size: int)) {
    interface:
        get_size(): int

    machine:
        $Start {
            $>(batch_size: int) {
                this.__compartment.state_vars["size"] = batch_size;
            }

            $.size: int = 0

            get_size(): int {
                const s: number = this.__compartment.state_vars["size"];
                @@:(s)
                return;
            }
        }
}

const w = @@BatchWorker($>(50));
const s = w.get_size();
if (s !== 50) {
    console.log(`FAIL got ${s}`);
    process.exit(1);
}
console.log("ok 1 - sysparam_enter_single");

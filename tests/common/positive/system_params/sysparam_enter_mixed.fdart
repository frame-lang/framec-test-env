@@[target("dart")]

@@system Service($(slot: int), $>(timeout: int), name: str) {
    interface:
        get_slot(): int
        get_timeout(): int
        get_name(): str
    machine:
        $Start(slot: int) {
            $>(timeout: int) {
                this.__compartment.state_vars["t"] = timeout;
            }
            $.t: int = 0

            get_slot(): int {
                @@:(slot) return;
            }
            get_timeout(): int {
                int v = this.__compartment.state_vars["t"] as int;
                @@:(v) return;
            }
            get_name(): str {
                @@:(this.name) return;
            }
        }
    domain:
        name : String = name
}

void main() {
    var s = @@Service($(0), $>(1000), "primary");
    var slot = s.get_slot();
    if (slot != 0) {
        throw 'FAIL: expected slot 0, got $slot';
    }
    var t = s.get_timeout();
    if (t != 1000) {
        throw 'FAIL: expected timeout 1000, got $t';
    }
    var n = s.get_name();
    if (n != "primary") {
        throw 'FAIL: expected name "primary", got $n';
    }
    print('ok 1 - sysparam_enter_mixed');
}

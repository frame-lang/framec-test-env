@@[target("kotlin")]

@@system Robot($(x: int)) {
    interface:
        get_x(): int
    machine:
        $Start(x: int) {
            get_x(): int {
                @@:(x)
            return;
            }
        }
}

fun main() {
    val r = @@Robot($(42))
    val v = r.get_x()
    if (v != 42) {
        println("FAIL got $v")
        kotlin.system.exitProcess(1)
    }
    println("ok 1 - sysparam_state_single")
}

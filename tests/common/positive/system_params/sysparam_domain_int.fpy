@@target python_3

# Test: single typed int domain param.
# The param `initial` should become a constructor argument and
# initialize the `value` domain field via the raw_code reference.

@@system Counter(initial: int) {
    interface:
        increment()
        get(): int

    machine:
        $Counting {
            increment() {
                self.value = self.value + 1
            }
            get(): int { @@:return = self.value }
        }

    domain:
        value = initial
}

if __name__ == '__main__':
    c = @@Counter(10)
    c.increment()
    c.increment()
    assert c.get() == 12, f"Expected 12, got {c.get()}"
    print("ok 1 - sysparam_domain_int")

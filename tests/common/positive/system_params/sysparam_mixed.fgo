@@target go

package main

import "fmt"
import "os"

// Test: mixed domain param + state param in one system header.

@@system Robot($(x: int), name: str) {
    interface:
        Describe(): string

    machine:
        $Start(x: int) {
            Describe(): string {
                @@:(fmt.Sprintf("%s@%d", s.name, x))
                return;
            }
        }

    domain:
        name string = name
}

func main() {
	r := @@Robot($(7), "R2D2")
	v := r.Describe()
	if v != "R2D2@7" {
		fmt.Printf("FAIL: Expected 'R2D2@7', got '%s'\n", v)
		os.Exit(1)
	}
	fmt.Println("ok 1 - sysparam_mixed")
}

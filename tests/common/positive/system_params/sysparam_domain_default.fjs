@@target javascript

@@system Counter(initial: int = 5) {
    interface:
        increment()
        get(): int

    machine:
        $Idle {
            increment() {
                this.value = this.value + 1
                return
            }
            get(): int {
                @@:(this.value)
                return;
            }
        }

    domain:
        value = initial
}

const c = @@Counter();
c.increment();
const v = c.get();
if (v !== 6) {
    console.log("FAIL got " + v);
    process.exit(1);
}
console.log("ok 1 - sysparam_domain_default");

@@[target("cpp_17")]

#include <iostream>
#include <cassert>

// Test: single typed str domain param. Frame `str` maps to `std::string`.

@@system Greeter(name: str) {
    interface:
        greet(): str

    machine:
        $Idle {
            greet(): str { @@:(std::string("hello, ") + this->name) return; }
        }

    domain:
        name: std::string = name
}

int main() {
    Greeter g = @@Greeter("world");
    std::string msg = g.greet();
    if (msg != "hello, world") { printf("FAIL got %s\n", msg.c_str()); return 1; }
    printf("ok 1 - sysparam_domain_str\n");
    return 0;
}

@@[target("go")]

package main

import "fmt"
import "os"

// Test: multiple typed domain params of mixed types.

@@system User(name: str, age: int, active: bool) {
    interface:
        Describe(): string

    machine:
        $Idle {
            Describe(): string {
                @@:(fmt.Sprintf("%s/%d/%t", s.name, s.age, s.active))
                return;
            }
        }

    domain:
        name : string = name
        age : int = age
        active : bool = active
}

func main() {
	u := @@User("alice", 30, true)
	v := u.Describe()
	if v != "alice/30/true" {
		fmt.Printf("FAIL: Expected 'alice/30/true', got '%s'\n", v)
		os.Exit(1)
	}
	fmt.Println("ok 1 - sysparam_domain_multi")
}

@@target c

#include <stdio.h>
#include <stdlib.h>
#include <stdint.h>
#include <stdbool.h>
#include <string.h>

// Test: multiple typed domain params of mixed types.

@@system User(name: str, age: int, active: bool) {
    interface:
        describe(): str

    machine:
        $Idle {
            describe(): str {
                static char buf[128];
                snprintf(buf, sizeof(buf), "%s/%d/%s", self->name, self->age,
                    self->active ? "true" : "false");
                @@:(buf)
                return;
            }
        }

    domain:
        name: char* = name
        age: int = age
        active: bool = active
}

int main(void) {
    User* u = @@User("alice", 30, true);
    char* d = User_describe(u);
    if (strcmp(d, "alice/30/true") != 0) { printf("FAIL got %s\n", d); return 1; }
    printf("ok 1 - sysparam_domain_multi\n");
    User_destroy(u);
    return 0;
}

@@[target("gdscript")]
extends SceneTree

@@system Robot($(x: int)) {
    interface:
        get_x(): int

    machine:
        $Start(x: int) {
            get_x(): int {
                @@:(x)
                return
            }
        }
}

func main():
    var r = @@Robot($(42))
    var v = r.get_x()
    if v != 42:
        print("FAIL got " + str(v))
        return
    print("ok 1 - sysparam_state_single")

func _init():
    main()
    quit()

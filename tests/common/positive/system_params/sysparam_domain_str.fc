@@target c

#include <stdio.h>
#include <stdlib.h>
#include <stdint.h>
#include <string.h>

// Test: single typed str domain param. Frame `str` maps to `char*`.

@@system Greeter(name: str) {
    interface:
        greet(): str

    machine:
        $Idle {
            greet(): str {
                static char buf[64];
                snprintf(buf, sizeof(buf), "hello, %s", self->name);
                @@:(buf)
                return;
            }
        }

    domain:
        name: char* = name
}

int main(void) {
    Greeter* g = @@Greeter("world");
    char* msg = Greeter_greet(g);
    if (strcmp(msg, "hello, world") != 0) { printf("FAIL got %s\n", msg); return 1; }
    printf("ok 1 - sysparam_domain_str\n");
    Greeter_destroy(g);
    return 0;
}

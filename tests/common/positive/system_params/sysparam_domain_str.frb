@@[target("ruby")]

@@system Greeter(name: str) {
    interface:
        greet(): str

    machine:
        $Idle {
            greet(): str {
                @@:("hello, " + @name)
                return
            }
        }

    domain:
        name = name
}

g = @@Greeter("world")
s = g.greet
if s != "hello, world"
    puts "FAIL got #{s}"
    exit(1)
end
puts "ok 1 - sysparam_domain_str"

@@[target("c")]

#include <stdio.h>
#include <stdlib.h>
#include <stdint.h>

// Test: single typed int domain param.
// `initial` becomes a constructor argument and initializes `value`.

@@system Counter(initial: int) {
    interface:
        increment(): void
        get(): int

    machine:
        $Counting {
            increment() {
                self->value = self->value + 1;
            }
            get(): int { @@:(self->value) return; }
        }

    domain:
        value: int = initial
}

int main(void) {
    Counter* c = @@Counter(10);
    Counter_increment(c);
    Counter_increment(c);
    int v = Counter_get(c);
    if (v != 12) { printf("FAIL got %d\n", v); return 1; }
    printf("ok 1 - sysparam_domain_int\n");
    Counter_destroy(c);
    return 0;
}

@@[target("c")]

#include <stdio.h>
#include <stdlib.h>
#include <stdint.h>

// Test: single state param via $(name: type).
// The state-args binding preamble exposes `x` as a typed local for handler bodies.

@@system Robot($(x: int)) {
    interface:
        get_x(): int

    machine:
        $Start(x: int) {
            get_x(): int { @@:(x) return; }
        }
}

int main(void) {
    Robot* r = @@Robot($(42));
    int v = Robot_get_x(r);
    if (v != 42) { printf("FAIL got %d\n", v); return 1; }
    printf("ok 1 - sysparam_state_single\n");
    Robot_destroy(r);
    return 0;
}

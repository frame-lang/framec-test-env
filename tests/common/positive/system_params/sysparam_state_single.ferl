@@target erlang

%% Test: single state param via $(name: type).
%% The param flows from start_link → init → frame_state_args, and the
%% state function clause should bind it as a local for handler bodies.

@@system Robot($(x: int)) {
    interface:
        get_x(): int

    machine:
        $Start(x: int) {
            get_x(): int { @@:(x) }
        }
}

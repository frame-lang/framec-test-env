@@target c

#include <stdio.h>
#include <stdlib.h>
#include <stdint.h>
#include <stdbool.h>

// Test: single typed bool domain param.

@@system Flag(initial: bool) {
    interface:
        toggle(): void
        get(): bool

    machine:
        $Active {
            toggle() {
                self->flag = !self->flag;
            }
            get(): bool { @@:(self->flag) return; }
        }

    domain:
        flag: bool = initial
}

int main(void) {
    Flag* f = @@Flag(false);
    if (Flag_get(f) != false) { printf("FAIL initial\n"); return 1; }
    Flag_toggle(f);
    if (Flag_get(f) != true) { printf("FAIL after toggle\n"); return 2; }
    printf("ok 1 - sysparam_domain_bool\n");
    Flag_destroy(f);
    return 0;
}

@@target lua

@@system Robot($(x: int), name: str) {
    interface:
        describe(): str

    machine:
        $Start(x: int) {
            describe(): str {
                @@:(self.name .. "@" .. tostring(x))
                return
            }
        }

    domain:
        name = name
}

local r = @@Robot($(7), "R2D2")
local s = r:describe()
if s ~= "R2D2@7" then
    print("FAIL got " .. s)
    os.exit(1)
end
print("ok 1 - sysparam_mixed")

@@target lua

@@system Robot(name: str, $(x: int)) {
    interface:
        describe(): str

    machine:
        $Start(x: int) {
            describe(): str {
                @@:(self.name .. "@" .. tostring(x))
                return
            }
        }

    domain:
        name = name
}

local r = @@Robot("R2D2", $(7))
local s = r:describe()
if s ~= "R2D2@7" then
    print("FAIL got " .. s)
    os.exit(1)
end
print("ok 1 - sysparam_mixed")

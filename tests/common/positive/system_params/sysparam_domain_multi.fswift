@@[target("swift")]

@@system User(name: str, age: int, active: bool) {
    interface:
        describe(): str

    machine:
        $Idle {
            describe(): str {
                @@:(self.name + "/" + String(self.age) + "/" + String(self.active))
                return;
            }
        }

    domain:
        name: String = name
        age: Int = age
        active: Bool = active
}

let u = @@User("alice", 30, true)
let s = u.describe()
if s != "alice/30/true" { fatalError("FAIL got \(s)") }
print("ok 1 - sysparam_domain_multi")

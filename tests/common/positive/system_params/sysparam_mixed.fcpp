@@[target("cpp_17")]

#include <iostream>
#include <string>
#include <cassert>
#include <any>

// Test: mixed domain param + state param in one system header.

@@system Robot($(x: int), name: str) {
    interface:
        describe(): str

    machine:
        $Start(x: int) {
            describe(): str {
                std::string out = this->name + "@" + std::to_string(x);
                @@:(out)
                return;
            }
        }

    domain:
        name: std::string = name
}

int main() {
    Robot r = @@Robot($(7), "R2D2");
    std::string d = r.describe();
    if (d != "R2D2@7") { printf("FAIL got %s\n", d.c_str()); return 1; }
    printf("ok 1 - sysparam_mixed\n");
    return 0;
}

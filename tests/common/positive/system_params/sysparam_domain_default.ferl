@@target erlang

%% Test: typed domain param with a default value.

@@system Counter(initial: int = 5) {
    interface:
        increment()
        get(): int

    machine:
        $Counting {
            increment() { self.value = self.value + 1 }
            get(): int { @@:(self.value) }
        }

    domain:
        value = initial
}

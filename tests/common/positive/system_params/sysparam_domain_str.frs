@@[target("rust")]

@@system Greeter(name: String) {
    interface:
        greet(): String

    machine:
        $Start {
            greet(): String { @@:(format!("hello, {}", self.name)) return; }
        }

    domain:
        name: String = name
}

fn main() {
    let mut g = @@Greeter(String::from("world"));
    let s = g.greet();
    if s != "hello, world" {
        println!("FAIL got {}", s);
        std::process::exit(1);
    }
    println!("ok 1 - sysparam_domain_str");
}

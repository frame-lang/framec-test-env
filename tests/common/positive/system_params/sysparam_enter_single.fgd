@@target gdscript
extends SceneTree

@@system Worker($>(batch_size: int)) {
    interface:
        get_size(): int

    machine:
        $Start {
            $>(batch_size: int) {
                self.__compartment.state_vars["size"] = batch_size
            }

            $.size: int = 0

            get_size(): int {
                var s = self.__compartment.state_vars["size"]
                @@:(s)
                return
            }
        }
}

func main():
    var w = @@Worker($>(50))
    var v = w.get_size()
    if v != 50:
        print("FAIL got " + str(v))
        return
    print("ok 1 - sysparam_enter_single")

func _init():
    main()
    quit()

@@target csharp

using System;

@@system Worker($>(batch_size: int)) {
    interface:
        get_size(): int
    machine:
        $Start {
            $>(batch_size: int) {
                __compartment.state_vars["size"] = batch_size;
            }
            $.size: int = 0
            get_size(): int {
                int s = (int) __compartment.state_vars["size"];
                @@:(s) return;
            }
        }
}

class Program {
    static void Main(string[] args) {
        var s = @@Worker($>(50));
        var v = s.get_size();
        if (v != 50) { Console.WriteLine($"FAIL got {v}"); Environment.Exit(1); }
        Console.WriteLine("ok 1 - sysparam_enter_single");
    }
}

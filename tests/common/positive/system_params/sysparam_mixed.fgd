@@target gdscript
extends SceneTree

@@system Robot($(x: int), name: str) {
    interface:
        describe(): str

    machine:
        $Start(x: int) {
            describe(): str {
                @@:(self.name + "@" + str(x))
                return
            }
        }

    domain:
        var name = name
}

func main():
    var r = @@Robot($(7), "R2D2")
    var s = r.describe()
    if s != "R2D2@7":
        print("FAIL got " + s)
        return
    print("ok 1 - sysparam_mixed")

func _init():
    main()
    quit()

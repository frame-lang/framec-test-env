@@target java

import java.util.*;

// Test: multiple typed domain params of different types.
// All three params flow through the constructor to domain fields.

@@system User(name: str, age: int, active: bool) {
    interface:
        describe(): str

    machine:
        $Idle {
            describe(): str {
                @@:(this.name + "/" + this.age + "/" + this.active)
                return;
            }
        }

    domain:
        name: String = name
        age: int = age
        active: boolean = active
}

class Main {
    public static void main(String[] args) {
        var u = @@User("alice", 30, true);
        String s = u.describe();
        if (!s.equals("alice/30/true")) {
            System.out.println("FAIL: Expected 'alice/30/true', got '" + s + "'");
            System.exit(1);
        }
        System.out.println("ok 1 - sysparam_domain_multi");
    }
}

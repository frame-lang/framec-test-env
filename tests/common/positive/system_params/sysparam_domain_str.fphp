@@[target("php")]

<?php

@@system Greeter(name: str) {
    interface:
        greet(): str

    machine:
        $Idle {
            greet(): str {
                @@:("hello, " . $this->name)
                return;
            }
        }

    domain:
        name = $name
}

$g = @@Greeter("world");
$s = $g->greet();
if ($s !== "hello, world") {
    echo "FAIL got $s\n";
    exit(1);
}
echo "ok 1 - sysparam_domain_str\n";

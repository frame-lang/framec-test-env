@@target python_3

# Test: single typed bool domain param.

@@system Flag(initial: bool) {
    interface:
        toggle()
        get(): bool

    machine:
        $Active {
            toggle() {
                self.flag = not self.flag
            }
            get(): bool { @@:return = self.flag }
        }

    domain:
        flag = initial
}

if __name__ == '__main__':
    f = @@Flag(False)
    assert f.get() == False
    f.toggle()
    assert f.get() == True
    print("ok 1 - sysparam_domain_bool")

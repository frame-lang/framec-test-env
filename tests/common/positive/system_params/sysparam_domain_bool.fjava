@@[target("java")]

import java.util.*;

// Test: single typed bool domain param.
// The param `initial` becomes a constructor argument and
// initializes the `flag` domain field.

@@system Flag(initial: bool) {
    interface:
        toggle()
        get(): bool

    machine:
        $Idle {
            toggle() {
                this.flag = !this.flag;
            }
            get(): bool {
                @@:(this.flag)
                return;
            }
        }

    domain:
        flag: boolean = initial
}

class Main {
    public static void main(String[] args) {
        var f = @@Flag(false);
        boolean v1 = f.get();
        if (v1 != false) {
            System.out.println("FAIL: Expected false, got " + v1);
            System.exit(1);
        }
        f.toggle();
        boolean v2 = f.get();
        if (v2 != true) {
            System.out.println("FAIL: Expected true, got " + v2);
            System.exit(1);
        }
        System.out.println("ok 1 - sysparam_domain_bool");
    }
}

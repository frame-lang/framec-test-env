@@[target("java")]

import java.util.*;

// Test: domain param with default value.
// Constructor is called with no args; `initial` defaults to 5.

@@system Counter(initial: int = 5) {
    interface:
        increment()
        get(): int

    machine:
        $Counting {
            increment() {
                this.value = this.value + 1;
            }
            get(): int {
                @@:(this.value)
                return;
            }
        }

    domain:
        value: int = initial
}

class Main {
    public static void main(String[] args) {
        var c = @@Counter();
        c.increment();
        int v = c.get();
        if (v != 6) {
            System.out.println("FAIL: Expected 6, got " + v);
            System.exit(1);
        }
        System.out.println("ok 1 - sysparam_domain_default");
    }
}

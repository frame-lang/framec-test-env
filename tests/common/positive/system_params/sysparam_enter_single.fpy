@@target python_3

# Test: single enter param via $>(name: type).
# The param flows from constructor → compartment.enter_args, and the
# start state's $>(name: type) enter handler reads it during init.

@@system Worker($>(batch_size: int)) {
    interface:
        get_size(): int

    machine:
        $Start {
            $>(batch_size: int) {
                self.size = batch_size
            }
            get_size(): int { @@:(self.size) }
        }

    domain:
        size = 0
}

if __name__ == '__main__':
    w = @@Worker($>(50))
    assert w.get_size() == 50, f"got {w.get_size()}"
    print("ok 1 - sysparam_enter_single")

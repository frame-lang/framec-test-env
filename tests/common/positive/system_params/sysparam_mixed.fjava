@@[target("java")]

import java.util.*;

// Test: mixed domain + state params in a single system.
// `name` becomes a domain field; `x` becomes a state arg on $Start.

@@system Robot($(x: int), name: str) {
    interface:
        describe(): str

    machine:
        $Start(x: int) {
            describe(): str {
                @@:(this.name + "@" + x)
                return;
            }
        }

    domain:
        name: String = name
}

class Main {
    public static void main(String[] args) {
        var r = @@Robot($(7), "R2D2");
        String s = r.describe();
        if (!s.equals("R2D2@7")) {
            System.out.println("FAIL: Expected 'R2D2@7', got '" + s + "'");
            System.exit(1);
        }
        System.out.println("ok 1 - sysparam_mixed");
    }
}

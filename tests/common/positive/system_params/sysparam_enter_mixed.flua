@@[target("lua")]

@@system Service($(slot: int), $>(timeout: int), name: str) {
    interface:
        get_slot(): int
        get_timeout(): int
        get_name(): str

    machine:
        $Start(slot: int) {
            $>(timeout: int) {
                self.__compartment.state_vars["t"] = timeout
            }

            $.t: int = 0

            get_slot(): int {
                @@:(slot)
                return
            }
            get_timeout(): int {
                local v = self.__compartment.state_vars["t"]
                @@:(v)
                return
            }
            get_name(): str {
                @@:(self.name)
                return
            }
        }

    domain:
        name = name
}

local s = @@Service($(3), $>(99), "svc")
local slot = s:get_slot()
if slot ~= 3 then
    print("FAIL slot got " .. tostring(slot))
    os.exit(1)
end
local t = s:get_timeout()
if t ~= 99 then
    print("FAIL timeout got " .. tostring(t))
    os.exit(1)
end
local n = s:get_name()
if n ~= "svc" then
    print("FAIL name got " .. n)
    os.exit(1)
end
print("ok 1 - sysparam_enter_mixed")

@@[target("python_3")]

# Test: all three param groups (state, enter, domain) in one system header.
# Constructor args are positional in declaration order across the groups.

@@system Service($(slot: int), $>(timeout: int), name: str) {
    interface:
        get_slot(): int
        get_timeout(): int
        get_name(): str

    machine:
        $Start(slot: int) {
            $>(timeout: int) {
                self.t = timeout
            }
            get_slot(): int { @@:(slot) }
            get_timeout(): int { @@:(self.t) }
            get_name(): str { @@:(self.name) }
        }

    domain:
        name = name
        t = 0
}

if __name__ == '__main__':
    s = @@Service($(0), $>(1000), "primary")
    assert s.get_slot() == 0
    assert s.get_timeout() == 1000
    assert s.get_name() == "primary"
    print("ok 1 - sysparam_enter_mixed")

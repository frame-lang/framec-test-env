@@target lua

@@system Greeter(name: str) {
    interface:
        greet(): str

    machine:
        $Idle {
            greet(): str {
                @@:("hello, " .. self.name)
                return
            }
        }

    domain:
        name = name
}

local g = @@Greeter("world")
local s = g:greet()
if s ~= "hello, world" then
    print("FAIL got " .. s)
    os.exit(1)
end
print("ok 1 - sysparam_domain_str")

@@[target("lua")]

@@system Worker($>(batch_size: int)) {
    interface:
        get_size(): int

    machine:
        $Start {
            $>(batch_size: int) {
                self.__compartment.state_vars["size"] = batch_size
            }

            $.size: int = 0

            get_size(): int {
                local s = self.__compartment.state_vars["size"]
                @@:(s)
                return
            }
        }
}

local w = @@Worker($>(50))
local v = w:get_size()
if v ~= 50 then
    print("FAIL got " .. tostring(v))
    os.exit(1)
end
print("ok 1 - sysparam_enter_single")

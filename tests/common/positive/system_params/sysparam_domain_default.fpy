@@target python_3

# Test: typed domain param with a default value.
# Constructed without arguments should use the default.

@@system Counter(initial: int = 5) {
    interface:
        increment()
        get(): int

    machine:
        $Counting {
            increment() {
                self.value = self.value + 1
            }
            get(): int { @@:return = self.value }
        }

    domain:
        value = initial
}

if __name__ == '__main__':
    c = @@Counter()
    c.increment()
    assert c.get() == 6, f"Expected 6, got {c.get()}"
    print("ok 1 - sysparam_domain_default")

@@target typescript

@@system Greeter(name: str) {
    interface:
        greet(): str

    machine:
        $Idle {
            greet(): str {
                @@:("hello, " + this.name)
                return;
            }
        }

    domain:
        name: string = name
}

const g = @@Greeter("world");
const s = g.greet();
if (s !== "hello, world") {
    console.log(`FAIL got ${s}`);
    process.exit(1);
}
console.log("ok 1 - sysparam_domain_str");

@@target go

package main

import "fmt"
import "os"

// Test: single typed bool domain param.

@@system Flag(initial: bool) {
    interface:
        Toggle()
        Get(): bool

    machine:
        $Active {
            Toggle() {
                s.flag = !s.flag
            }
            Get(): bool {
                @@:(s.flag)
                return;
            }
        }

    domain:
        flag : bool = initial
}

func main() {
	f := @@Flag(false)
	v := f.Get()
	if v != false {
		fmt.Printf("FAIL: Expected false, got %v\n", v)
		os.Exit(1)
	}
	f.Toggle()
	v = f.Get()
	if v != true {
		fmt.Printf("FAIL: Expected true, got %v\n", v)
		os.Exit(1)
	}
	fmt.Println("ok 1 - sysparam_domain_bool")
}

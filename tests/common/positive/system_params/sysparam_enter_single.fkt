@@target kotlin

@@system Worker($>(batch_size: int)) {
    interface:
        get_size(): int
    machine:
        $Start {
            $>(batch_size: int) {
                __compartment.state_vars["size"] = batch_size
            }
            $.size: int = 0

            get_size(): int {
                val s = __compartment.state_vars["size"] as Int
                @@:(s)
            return;
            }
        }
}

fun main() {
    val w = @@Worker($>(50))
    val v = w.get_size()
    if (v != 50) {
        println("FAIL got $v")
        kotlin.system.exitProcess(1)
    }
    println("ok 1 - sysparam_enter_single")
}

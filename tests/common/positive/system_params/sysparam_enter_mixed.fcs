@@[target("csharp")]


@@system Service($(slot: int), $>(timeout: int), name: str) {
    interface:
        get_slot(): int
        get_timeout(): int
        get_name(): str
    machine:
        $Start(slot: int) {
            $>(timeout: int) {
                __compartment.state_vars["t"] = timeout;
            }
            $.t: int = 0
            get_slot(): int {
                @@:(slot) return;
            }
            get_timeout(): int {
                int v = (int) __compartment.state_vars["t"];
                @@:(v) return;
            }
            get_name(): str {
                @@:(this.name) return;
            }
        }
    domain:
        name: string = name
}

class Program {
    static void Main(string[] args) {
        var s = @@Service($(0), $>(1000), "primary");
        var slot = s.get_slot();
        if (slot != 0) { Console.WriteLine($"FAIL slot got {slot}"); Environment.Exit(1); }
        var timeout = s.get_timeout();
        if (timeout != 1000) { Console.WriteLine($"FAIL timeout got {timeout}"); Environment.Exit(1); }
        var name = s.get_name();
        if (name != "primary") { Console.WriteLine($"FAIL name got {name}"); Environment.Exit(1); }
        Console.WriteLine("ok 1 - sysparam_enter_mixed");
    }
}

@@target erlang

%% Test: all three param groups (state, enter, domain) in one system header.

@@system Service($(slot: int), $>(timeout: int), name: str) {
    interface:
        get_slot(): int
        get_timeout(): int
        get_name(): str

    machine:
        $Start(slot: int) {
            $>(timeout: int) {
                self.t = timeout
            }
            get_slot(): int { @@:return = slot }
            get_timeout(): int { @@:return = self.t }
            get_name(): str { @@:return = self.name }
        }

    domain:
        name = name
        t = 0
}

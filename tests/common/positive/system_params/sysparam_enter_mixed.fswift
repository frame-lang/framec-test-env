@@target swift

@@system Service($(slot: int), $>(timeout: int), name: str) {
    interface:
        get_slot(): int
        get_timeout(): int
        get_name(): str

    machine:
        $Start(slot: int) {
            $>(timeout: int) {
                self.__compartment.state_vars["t"] = timeout
            }
            $.t: Int = 0
            get_slot(): int { @@:(slot)
            return; }
            get_timeout(): int {
                let v = self.__compartment.state_vars["t"] as! Int
                @@:(v)
                return;
            }
            get_name(): str { @@:(self.name)
            return; }
        }

    domain:
        name: String = name
}

let s = @@Service($(0), $>(1000), "primary")
let slot = s.get_slot()
if slot != 0 { fatalError("FAIL slot got \(slot)") }
let t = s.get_timeout()
if t != 1000 { fatalError("FAIL timeout got \(t)") }
let n = s.get_name()
if n != "primary" { fatalError("FAIL name got \(n)") }
print("ok 1 - sysparam_enter_mixed")

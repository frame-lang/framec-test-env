@@target dart

@@system Robot($(x: int)) {
    interface:
        get_x(): int
    machine:
        $Start(x: int) {
            get_x(): int {
                @@:(x) return;
            }
        }
}

void main() {
    var r = @@Robot($(42));
    var v = r.get_x();
    if (v != 42) {
        throw 'FAIL: expected 42, got $v';
    }
    print('ok 1 - sysparam_state_single');
}

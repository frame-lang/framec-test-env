@@target c

#include <stdio.h>
#include <stdlib.h>
#include <stdint.h>
#include <string.h>

// Test: mixed domain param + state param in one system header.

@@system Robot($(x: int), name: str) {
    interface:
        describe(): str

    machine:
        $Start(x: int) {
            describe(): str {
                static char buf[64];
                snprintf(buf, sizeof(buf), "%s@%d", self->name, x);
                @@:(buf)
                return;
            }
        }

    domain:
        name: char* = name
}

int main(void) {
    Robot* r = @@Robot($(7), "R2D2");
    char* d = Robot_describe(r);
    if (strcmp(d, "R2D2@7") != 0) { printf("FAIL got %s\n", d); return 1; }
    printf("ok 1 - sysparam_mixed\n");
    Robot_destroy(r);
    return 0;
}

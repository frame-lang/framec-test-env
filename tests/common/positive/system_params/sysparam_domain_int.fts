@@[target("typescript")]

@@system Counter(initial: int) {
    interface:
        increment()
        get(): int

    machine:
        $Idle {
            increment() {
                this.value = this.value + 1;
            }

            get(): int {
                @@:(this.value)
                return;
            }
        }

    domain:
        value: number = initial
}

const c = @@Counter(10);
c.increment();
c.increment();
const v = c.get();
if (v !== 12) {
    console.log(`FAIL got ${v}`);
    process.exit(1);
}
console.log("ok 1 - sysparam_domain_int");

@@[target("cpp_17")]

#include <iostream>
#include <string>
#include <cassert>
#include <any>

// Test: typed domain param with a default value.
// Constructed without arguments should use the default.

@@system Counter(initial: int = 5) {
    interface:
        increment(): void
        get(): int

    machine:
        $Counting {
            increment() {
                this->value = this->value + 1;
            }
            get(): int { @@:(this->value) return; }
        }

    domain:
        value: int = initial
}

int main() {
    Counter c = @@Counter();
    c.increment();
    int v = c.get();
    if (v != 6) { printf("FAIL got %d\n", v); return 1; }
    printf("ok 1 - sysparam_domain_default\n");
    return 0;
}

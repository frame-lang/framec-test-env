@@target erlang

%% Test: single enter param via $>(name: type).

@@system Worker($>(batch_size: int)) {
    interface:
        get_size(): int

    machine:
        $Start {
            $>(batch_size: int) {
                self.size = batch_size
            }
            get_size(): int { @@:return = self.size }
        }

    domain:
        size = 0
}

@@target ruby

@@system Service($(slot: int), $>(timeout: int), name: str) {
    interface:
        get_slot(): int
        get_timeout(): int
        get_name(): str

    machine:
        $Start(slot: int) {
            $>(timeout: int) {
                @__compartment.state_vars["t"] = timeout
                return
            }

            $.t: int = 0

            get_slot(): int {
                @@:(slot)
                return
            }

            get_timeout(): int {
                v = @__compartment.state_vars["t"]
                @@:(v)
                return
            }

            get_name(): str {
                @@:(@name)
                return
            }
        }

    domain:
        name = name
}

s = @@Service($(3), $>(99), "svc")
if s.get_slot != 3
    puts "FAIL slot #{s.get_slot}"
    exit(1)
end
if s.get_timeout != 99
    puts "FAIL timeout #{s.get_timeout}"
    exit(1)
end
if s.get_name != "svc"
    puts "FAIL name #{s.get_name}"
    exit(1)
end
puts "ok 1 - sysparam_enter_mixed"

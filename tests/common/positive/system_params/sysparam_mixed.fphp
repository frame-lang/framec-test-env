@@target php

<?php

@@system Robot($(x: int), name: str) {
    interface:
        describe(): str

    machine:
        $Start(x: int) {
            describe(): str {
                @@:($this->name . "@" . $x)
                return;
            }
        }

    domain:
        name = $name
}

$r = @@Robot($(7), "R2D2");
$d = $r->describe();
if ($d !== "R2D2@7") {
    echo "FAIL got $d\n";
    exit(1);
}
echo "ok 1 - sysparam_mixed\n";

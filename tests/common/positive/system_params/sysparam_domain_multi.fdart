@@target dart

@@system User(name: str, age: int, active: bool) {
    interface:
        describe(): str
    machine:
        $Idle {
            describe(): str {
                @@:(this.name + "/" + this.age.toString() + "/" + this.active.toString()) return;
            }
        }
    domain:
        String name = name
        int age = age
        bool active = active
}

void main() {
    var u = @@User("alice", 30, true);
    var v = u.describe();
    if (v != "alice/30/true") {
        throw 'FAIL: expected "alice/30/true", got $v';
    }
    print('ok 1 - sysparam_domain_multi');
}

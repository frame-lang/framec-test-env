@@[target("ruby")]

@@system Counter(initial: int) {
    interface:
        increment
        get(): int

    machine:
        $Idle {
            increment {
                @value = @value + 1
                return
            }
            get(): int {
                @@:(@value)
                return
            }
        }

    domain:
        value = initial
}

c = @@Counter(10)
c.increment
c.increment
v = c.get
if v != 12
    puts "FAIL got #{v}"
    exit(1)
end
puts "ok 1 - sysparam_domain_int"

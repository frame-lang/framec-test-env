@@target lua

@@system Flag(initial: bool) {
    interface:
        toggle
        get(): bool

    machine:
        $Idle {
            toggle {
                self.flag = not self.flag
            }
            get(): bool {
                @@:(self.flag)
                return
            }
        }

    domain:
        flag = initial
}

local f = @@Flag(false)
local v1 = f:get()
if v1 ~= false then
    print("FAIL initial got " .. tostring(v1))
    os.exit(1)
end
f:toggle()
local v2 = f:get()
if v2 ~= true then
    print("FAIL toggled got " .. tostring(v2))
    os.exit(1)
end
print("ok 1 - sysparam_domain_bool")

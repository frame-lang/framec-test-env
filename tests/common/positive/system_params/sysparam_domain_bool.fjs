@@target javascript

@@system Flag(initial: bool) {
    interface:
        toggle()
        get(): bool

    machine:
        $Idle {
            toggle() {
                this.flag = !this.flag
                return
            }
            get(): bool {
                @@:(this.flag)
                return;
            }
        }

    domain:
        flag = initial
}

const f = @@Flag(false);
f.toggle();
const v = f.get();
if (v !== true) {
    console.log("FAIL got " + v);
    process.exit(1);
}
console.log("ok 1 - sysparam_domain_bool");

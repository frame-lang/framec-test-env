@@target rust

@@system Robot($(x: int)) {
    interface:
        get_x(): i64

    machine:
        $Start(x: int) {
            get_x(): i64 { @@:(x) return; }
        }
}

fn main() {
    let mut r = @@Robot($(42));
    let v = r.get_x();
    if v != 42 {
        println!("FAIL got {}", v);
        std::process::exit(1);
    }
    println!("ok 1 - sysparam_state_single");
}

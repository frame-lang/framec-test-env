@@[target("python_3")]

# Test: single state param via $(name: type).
# The param is passed to the start state's state_args.
# State handler reads it via the state's parameter scope.

@@system Robot($(x: int)) {
    interface:
        get_x(): int

    machine:
        $Start(x: int) {
            get_x(): int { @@:(x) }
        }
}

if __name__ == '__main__':
    r = @@Robot($(42))
    assert r.get_x() == 42, f"got {r.get_x()}"
    print("ok 1 - sysparam_state_single")

@@[target("php")]


@@system Counter(initial: int) {
    interface:
        increment()
        get(): int

    machine:
        $Idle {
            increment() {
                $this->value = $this->value + 1;
                return;
            }

            get(): int {
                @@:($this->value)
                return;
            }
        }

    domain:
        value = $initial
}

$c = @@Counter(10);
$c->increment();
$c->increment();
$v = $c->get();
if ($v !== 12) {
    echo "FAIL got $v\n";
    exit(1);
}
echo "ok 1 - sysparam_domain_int\n";

@@[target("kotlin")]

@@system Service($(slot: int), $>(timeout: int), name: str) {
    interface:
        get_slot(): int
        get_timeout(): int
        get_name(): str
    machine:
        $Start(slot: int) {
            $>(timeout: int) {
                __compartment.state_vars["t"] = timeout
            }
            $.t: int = 0

            get_slot(): int {
                @@:(slot)
            return;
            }
            get_timeout(): int {
                val v = __compartment.state_vars["t"] as Int
                @@:(v)
            return;
            }
            get_name(): str {
                @@:(this.name)
            return;
            }
        }
    domain:
        name: String = name
}

fun main() {
    val s = @@Service($(0), $>(1000), "primary")
    val slot = s.get_slot()
    if (slot != 0) {
        println("FAIL slot got $slot")
        kotlin.system.exitProcess(1)
    }
    val t = s.get_timeout()
    if (t != 1000) {
        println("FAIL timeout got $t")
        kotlin.system.exitProcess(1)
    }
    val n = s.get_name()
    if (n != "primary") {
        println("FAIL name got $n")
        kotlin.system.exitProcess(1)
    }
    println("ok 1 - sysparam_enter_mixed")
}

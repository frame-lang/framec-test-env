@@target kotlin

@@system Robot($(x: int), name: str) {
    interface:
        describe(): str
    machine:
        $Start(x: int) {
            describe(): str {
                @@:(this.name + "@" + x)
            return;
            }
        }
    domain:
        var name: String = name
}

fun main() {
    val r = @@Robot($(7), "R2D2")
    val v = r.describe()
    if (v != "R2D2@7") {
        println("FAIL got $v")
        kotlin.system.exitProcess(1)
    }
    println("ok 1 - sysparam_mixed")
}

@@target lua

@@system User(name: str, age: int, active: bool) {
    interface:
        describe(): str

    machine:
        $Idle {
            describe(): str {
                @@:(self.name .. "/" .. tostring(self.age) .. "/" .. tostring(self.active))
                return
            }
        }

    domain:
        name = name
        age = age
        active = active
}

local u = @@User("alice", 30, true)
local s = u:describe()
if s ~= "alice/30/true" then
    print("FAIL got " .. s)
    os.exit(1)
end
print("ok 1 - sysparam_domain_multi")

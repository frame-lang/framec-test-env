@@[target("ruby")]

@@system Robot($(x: int), name: str) {
    interface:
        describe(): str

    machine:
        $Start(x: int) {
            describe(): str {
                @@:("#{@name}@#{x}")
                return
            }
        }

    domain:
        name = name
}

r = @@Robot($(7), "R2D2")
s = r.describe
if s != "R2D2@7"
    puts "FAIL got #{s}"
    exit(1)
end
puts "ok 1 - sysparam_mixed"

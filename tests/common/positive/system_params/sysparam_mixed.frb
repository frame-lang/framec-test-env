@@target ruby

@@system Robot(name: str, $(x: int)) {
    interface:
        describe(): str

    machine:
        $Start(x: int) {
            describe(): str {
                @@:("#{@name}@#{x}")
                return
            }
        }

    domain:
        name = name
}

r = @@Robot("R2D2", $(7))
s = r.describe
if s != "R2D2@7"
    puts "FAIL got #{s}"
    exit(1)
end
puts "ok 1 - sysparam_mixed"

@@[target("javascript")]

@@system Worker($>(batch_size: int)) {
    interface:
        get_size(): int

    machine:
        $Start {
            $>(batch_size: int) {
                this.__compartment.state_vars["size"] = batch_size;
            }

            $.size: int = 0

            get_size(): int {
                const s = this.__compartment.state_vars["size"];
                @@:(s)
                return;
            }
        }
}

const w = @@Worker($>(50));
const v = w.get_size();
if (v !== 50) {
    console.log("FAIL got " + v);
    process.exit(1);
}
console.log("ok 1 - sysparam_enter_single");

@@target swift

@@system Worker($>(batch_size: int)) {
    interface:
        get_size(): int

    machine:
        $Start {
            $>(batch_size: int) {
                self.__compartment.state_vars["size"] = batch_size
            }
            $.size: Int = 0
            get_size(): int {
                let s = self.__compartment.state_vars["size"] as! Int
                @@:(s)
                return;
            }
        }
}

let w = @@Worker($>(50))
let v = w.get_size()
if v != 50 { fatalError("FAIL got \(v)") }
print("ok 1 - sysparam_enter_single")

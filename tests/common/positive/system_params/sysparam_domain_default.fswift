@@[target("swift")]

@@system Counter(initial: int = 5) {
    interface:
        increment()
        get(): int

    machine:
        $Counting {
            increment() {
                self.value = self.value + 1
            }
            get(): int { @@:(self.value)
            return; }
        }

    domain:
        value: Int = initial
}

let c = @@Counter()
c.increment()
let v = c.get()
if v != 6 { fatalError("FAIL got \(v)") }
print("ok 1 - sysparam_domain_default")

@@target erlang

%% Test: mixed domain param + state param.

@@system Robot(name: str, $(x): int) {
    interface:
        get_name(): str
        get_x(): int

    machine:
        $Start(x: int) {
            get_name(): str { @@:return = self.name }
            get_x(): int { @@:return = x }
        }

    domain:
        name = name
}

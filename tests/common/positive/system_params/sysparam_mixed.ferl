@@target erlang

%% Test: mixed domain param + state param.

@@system Robot($(x: int), name: str) {
    interface:
        get_name(): str
        get_x(): int

    machine:
        $Start(x: int) {
            get_name(): str { @@:(self.name) }
            get_x(): int { @@:(x) }
        }

    domain:
        name = name
}

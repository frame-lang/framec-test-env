@@target csharp

using System;

@@system Robot(name: str, $(x: int)) {
    interface:
        describe(): str
    machine:
        $Start(x: int) {
            describe(): str {
                @@:(this.name + "@" + x) return;
            }
        }
    domain:
        name: string = name
}

class Program {
    static void Main(string[] args) {
        var s = @@Robot("R2D2", $(7));
        var v = s.describe();
        if (v != "R2D2@7") { Console.WriteLine($"FAIL got {v}"); Environment.Exit(1); }
        Console.WriteLine("ok 1 - sysparam_mixed");
    }
}

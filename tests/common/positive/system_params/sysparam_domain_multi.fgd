@@target gdscript
extends SceneTree

@@system User(name: str, age: int, active: bool) {
    interface:
        describe(): str

    machine:
        $Idle {
            describe(): str {
                @@:(self.name + "/" + str(self.age) + "/" + str(self.active))
                return
            }
        }

    domain:
        name = name
        age = age
        active = active
}

func main():
    var u = @@User("alice", 30, true)
    var s = u.describe()
    if s != "alice/30/true":
        print("FAIL got " + s)
        return
    print("ok 1 - sysparam_domain_multi")

func _init():
    main()
    quit()

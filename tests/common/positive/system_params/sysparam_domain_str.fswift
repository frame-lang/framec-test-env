@@target swift

@@system Greeter(name: str) {
    interface:
        greet(): str

    machine:
        $Idle {
            greet(): str { @@:("hello, " + self.name)
            return; }
        }

    domain:
        name: String = name
}

let g = @@Greeter("world")
let s = g.greet()
if s != "hello, world" { fatalError("FAIL got \(s)") }
print("ok 1 - sysparam_domain_str")

@@[target("rust")]

@@system User(name: String, age: i64, active: bool) {
    interface:
        describe(): String

    machine:
        $Start {
            describe(): String { @@:(format!("{}/{}/{}", self.name, self.age, self.active)) return; }
        }

    domain:
        name: String = name
        age: i64 = age
        active: bool = active
}

fn main() {
    let mut u = @@User(String::from("alice"), 30, true);
    let s = u.describe();
    if s != "alice/30/true" {
        println!("FAIL got {}", s);
        std::process::exit(1);
    }
    println!("ok 1 - sysparam_domain_multi");
}

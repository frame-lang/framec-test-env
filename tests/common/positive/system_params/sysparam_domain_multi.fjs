@@target javascript

@@system User(name: str, age: int, active: bool) {
    interface:
        describe(): str

    machine:
        $Idle {
            describe(): str {
                @@:(this.name + "/" + this.age + "/" + this.active)
                return;
            }
        }

    domain:
        name = name
        age = age
        active = active
}

const u = @@User("Alice", 30, true);
const s = u.describe();
if (s !== "Alice/30/true") {
    console.log("FAIL got " + s);
    process.exit(1);
}
console.log("ok 1 - sysparam_domain_multi");

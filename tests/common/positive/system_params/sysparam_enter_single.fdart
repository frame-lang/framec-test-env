@@[target("dart")]

@@system Worker($>(batch_size: int)) {
    interface:
        get_size(): int
    machine:
        $Start {
            $>(batch_size: int) {
                this.__compartment.state_vars["size"] = batch_size;
            }
            $.size: int = 0

            get_size(): int {
                int s = this.__compartment.state_vars["size"] as int;
                @@:(s) return;
            }
        }
}

void main() {
    var w = @@Worker($>(50));
    var v = w.get_size();
    if (v != 50) {
        throw 'FAIL: expected 50, got $v';
    }
    print('ok 1 - sysparam_enter_single');
}

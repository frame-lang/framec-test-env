@@[target("rust")]

@@system Counter(initial: i64) {
    interface:
        increment()
        get(): i64

    machine:
        $Counting {
            increment() {
                self.value = self.value + 1;
            }
            get(): i64 { @@:(self.value) return; }
        }

    domain:
        value: i64 = initial
}

fn main() {
    let mut c = @@Counter(10);
    c.increment();
    c.increment();
    let v = c.get();
    if v != 12 {
        println!("FAIL got {}", v);
        std::process::exit(1);
    }
    println!("ok 1 - sysparam_domain_int");
}

@@[target("go")]

package main

import "fmt"
import "os"

// Test: all three param groups (state, enter, domain) in one system header.
// Constructor args are positional in declaration order across the groups.

@@system Service($(slot: int), $>(timeout: int), name: str) {
    interface:
        Get_slot(): int
        Get_timeout(): int
        Get_name(): string

    machine:
        $Start(slot: int) {
            $>(timeout: int) {
                s.t = timeout
            }
            Get_slot(): int {
                @@:(slot)
                return;
            }
            Get_timeout(): int {
                @@:(s.t)
                return;
            }
            Get_name(): string {
                @@:(s.name)
                return;
            }
        }

    domain:
        name : string = name
        t : int = 0
}

func main() {
	svc := @@Service($(0), $>(1000), "primary")
	v1 := svc.Get_slot()
	if v1 != 0 {
		fmt.Printf("FAIL: Expected slot=0, got %d\n", v1)
		os.Exit(1)
	}
	v2 := svc.Get_timeout()
	if v2 != 1000 {
		fmt.Printf("FAIL: Expected timeout=1000, got %d\n", v2)
		os.Exit(1)
	}
	v3 := svc.Get_name()
	if v3 != "primary" {
		fmt.Printf("FAIL: Expected name='primary', got '%s'\n", v3)
		os.Exit(1)
	}
	fmt.Println("ok 1 - sysparam_enter_mixed")
}

@@[target("python_3")]

# Test: single typed str domain param.

@@system Greeter(name: str) {
    interface:
        greet(): str

    machine:
        $Idle {
            greet(): str { @@:("hello, " + self.name) }
        }

    domain:
        name = name
}

if __name__ == '__main__':
    g = @@Greeter("world")
    assert g.greet() == "hello, world", f"got {g.greet()}"
    print("ok 1 - sysparam_domain_str")

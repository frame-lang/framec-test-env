@@[target("lua")]

@@system Robot($(x: int)) {
    interface:
        get_x(): int

    machine:
        $Start(x: int) {
            get_x(): int {
                @@:(x)
                return
            }
        }
}

local r = @@Robot($(42))
local v = r:get_x()
if v ~= 42 then
    print("FAIL got " .. tostring(v))
    os.exit(1)
end
print("ok 1 - sysparam_state_single")

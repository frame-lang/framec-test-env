@@[target("rust")]

@@system Worker($>(batch_size: i64)) {
    interface:
        get_size(): i64

    machine:
        $Start {
            $>(batch_size: i64) {
                self.size = batch_size;
            }
            get_size(): i64 { @@:(self.size) return; }
        }

    domain:
        size: i64 = 0
}

fn main() {
    let mut w = @@Worker($>(50));
    let v = w.get_size();
    if v != 50 {
        println!("FAIL got {}", v);
        std::process::exit(1);
    }
    println!("ok 1 - sysparam_enter_single");
}

@@[target("dart")]

@@system Counter(initial: int) {
    interface:
        increment()
        get(): int
    machine:
        $Idle {
            increment() {
                this.value = this.value + 1;
            }
            get(): int {
                @@:(this.value) return;
            }
        }
    domain:
        value : int = initial
}

void main() {
    var c = @@Counter(10);
    c.increment();
    c.increment();
    var v = c.get();
    if (v != 12) {
        throw 'FAIL: expected 12, got $v';
    }
    print('ok 1 - sysparam_domain_int');
}

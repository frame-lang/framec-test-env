@@target csharp

using System;

@@system Greeter(name: str) {
    interface:
        greet(): str
    machine:
        $Idle {
            greet(): str {
                @@:("hello, " + this.name) return;
            }
        }
    domain:
        name: string = name
}

class Program {
    static void Main(string[] args) {
        var s = @@Greeter("world");
        var v = s.greet();
        if (v != "hello, world") { Console.WriteLine($"FAIL got {v}"); Environment.Exit(1); }
        Console.WriteLine("ok 1 - sysparam_domain_str");
    }
}

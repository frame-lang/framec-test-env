@@[target("dart")]

@@system Robot($(x: int), name: str) {
    interface:
        describe(): str
    machine:
        $Start(x: int) {
            describe(): str {
                @@:(this.name + "@" + x.toString()) return;
            }
        }
    domain:
        name : String = name
}

void main() {
    var r = @@Robot($(7), "R2D2");
    var v = r.describe();
    if (v != "R2D2@7") {
        throw 'FAIL: expected "R2D2@7", got $v';
    }
    print('ok 1 - sysparam_mixed');
}

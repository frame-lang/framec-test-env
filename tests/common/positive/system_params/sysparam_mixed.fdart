@@target dart

@@system Robot(name: str, $(x: int)) {
    interface:
        describe(): str
    machine:
        $Start(x: int) {
            describe(): str {
                @@:(this.name + "@" + x.toString()) return;
            }
        }
    domain:
        String name = name
}

void main() {
    var r = @@Robot("R2D2", $(7));
    var v = r.describe();
    if (v != "R2D2@7") {
        throw 'FAIL: expected "R2D2@7", got $v';
    }
    print('ok 1 - sysparam_mixed');
}

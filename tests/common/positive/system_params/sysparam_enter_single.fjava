@@target java

import java.util.*;

// Test: single enter param via $>(name: type).
// The param flows from constructor → compartment.enter_args, and the
// start state's $>(name: type) enter handler reads it during init.

@@system Worker($>(batch_size: int)) {
    interface:
        get_size(): int

    machine:
        $Start {
            $>(batch_size: int) {
                __compartment.state_vars.put("size", batch_size);
            }
            $.size: int = 0
            get_size(): int {
                int s = (Integer) __compartment.state_vars.get("size");
                @@:(s)
                return;
            }
        }
}

class Main {
    public static void main(String[] args) {
        var w = @@Worker($>(50));
        int s = w.get_size();
        if (s != 50) {
            System.out.println("FAIL: Expected 50, got " + s);
            System.exit(1);
        }
        System.out.println("ok 1 - sysparam_enter_single");
    }
}

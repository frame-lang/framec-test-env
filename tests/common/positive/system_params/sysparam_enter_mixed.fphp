@@[target("php")]


@@system Service($(slot: int), $>(timeout: int), name: str) {
    interface:
        get_slot(): int
        get_timeout(): int
        get_name(): str

    machine:
        $Start(slot: int) {
            $>(timeout: int) {
                $this->__compartment->state_vars["t"] = $timeout;
            }

            $.t: int = 0

            get_slot(): int {
                @@:($slot)
                return;
            }

            get_timeout(): int {
                $v = $this->__compartment->state_vars["t"];
                @@:($v)
                return;
            }

            get_name(): str {
                @@:($this->name)
                return;
            }
        }

    domain:
        name = $name
}

$s = @@Service($(3), $>(100), "svc1");
$slot = $s->get_slot();
if ($slot !== 3) {
    echo "FAIL slot got $slot\n";
    exit(1);
}
$t = $s->get_timeout();
if ($t !== 100) {
    echo "FAIL timeout got $t\n";
    exit(1);
}
$n = $s->get_name();
if ($n !== "svc1") {
    echo "FAIL name got $n\n";
    exit(1);
}
echo "ok 1 - sysparam_enter_mixed\n";

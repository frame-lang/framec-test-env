@@target python_3

# Test: mixed domain param + state param in one system header.

@@system Robot($(x: int), name: str) {
    interface:
        describe(): str

    machine:
        $Start(x: int) {
            describe(): str { @@:(self.name + "@" + str(x)) }
        }

    domain:
        name = name
}

if __name__ == '__main__':
    r = @@Robot($(7), "R2D2")
    assert r.describe() == "R2D2@7", f"got {r.describe()}"
    print("ok 1 - sysparam_mixed")

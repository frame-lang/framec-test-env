@@target python_3

# Test: mixed domain param + state param in one system header.

@@system Robot(name: str, $(x: int)) {
    interface:
        describe(): str

    machine:
        $Start(x: int) {
            describe(): str { @@:return = self.name + "@" + str(x) }
        }

    domain:
        name = name
}

if __name__ == '__main__':
    r = @@Robot("R2D2", $(7))
    assert r.describe() == "R2D2@7", f"got {r.describe()}"
    print("ok 1 - sysparam_mixed")

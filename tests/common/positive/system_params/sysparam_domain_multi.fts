@@target typescript

@@system User(name: str, age: int, active: bool) {
    interface:
        describe(): str

    machine:
        $Idle {
            describe(): str {
                @@:(this.name + "/" + this.age + "/" + this.active)
                return;
            }
        }

    domain:
        name: string = name
        age: number = age
        active: boolean = active
}

const u = @@User("alice", 30, true);
const d = u.describe();
if (d !== "alice/30/true") {
    console.log(`FAIL got ${d}`);
    process.exit(1);
}
console.log("ok 1 - sysparam_domain_multi");

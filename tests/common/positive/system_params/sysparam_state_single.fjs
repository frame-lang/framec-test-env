@@[target("javascript")]

@@system Robot($(x: int)) {
    interface:
        get_x(): int

    machine:
        $Start(x: int) {
            get_x(): int {
                @@:(x)
                return;
            }
        }
}

const r = @@Robot($(42));
const v = r.get_x();
if (v !== 42) {
    console.log("FAIL got " + v);
    process.exit(1);
}
console.log("ok 1 - sysparam_state_single");

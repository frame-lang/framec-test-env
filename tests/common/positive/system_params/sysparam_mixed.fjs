@@target javascript

@@system Robot(name: str, $(x: int)) {
    interface:
        describe(): str

    machine:
        $Start(x: int) {
            describe(): str {
                @@:(this.name + "@" + x)
                return;
            }
        }

    domain:
        name = name
}

const r = @@Robot("R2D2", $(7));
const s = r.describe();
if (s !== "R2D2@7") {
    console.log("FAIL got " + s);
    process.exit(1);
}
console.log("ok 1 - sysparam_mixed");

@@target go

package main

import "fmt"
import "os"

// Test: single typed str domain param.

@@system Greeter(name: str) {
    interface:
        Greet(): string

    machine:
        $Idle {
            Greet(): string {
                @@:("hello, " + s.name)
                return;
            }
        }

    domain:
        name : string = name
}

func main() {
	g := @@Greeter("world")
	v := g.Greet()
	if v != "hello, world" {
		fmt.Printf("FAIL: Expected 'hello, world', got '%s'\n", v)
		os.Exit(1)
	}
	fmt.Println("ok 1 - sysparam_domain_str")
}

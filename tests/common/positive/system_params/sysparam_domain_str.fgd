@@target gdscript
extends SceneTree

@@system Greeter(name: str) {
    interface:
        greet(): str

    machine:
        $Idle {
            greet(): str {
                @@:("hello, " + self.name)
                return
            }
        }

    domain:
        var name = name
}

func main():
    var g = @@Greeter("world")
    var s = g.greet()
    if s != "hello, world":
        print("FAIL got " + s)
        return
    print("ok 1 - sysparam_domain_str")

func _init():
    main()
    quit()

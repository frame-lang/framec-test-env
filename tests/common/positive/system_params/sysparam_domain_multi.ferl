@@target erlang

%% Test: multiple typed domain params of mixed types.

@@system User(name: str, age: int, active: bool) {
    interface:
        get_name(): str
        get_age(): int
        get_active(): bool

    machine:
        $Idle {
            get_name(): str { @@:(self.name) }
            get_age(): int { @@:(self.age) }
            get_active(): bool { @@:(self.active) }
        }

    domain:
        name = name
        age = age
        active = active
}

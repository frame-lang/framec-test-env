@@target java

import java.util.*;

// Test: single typed str domain param.
// The param `name` becomes a constructor argument and
// initializes the `name` domain field.

@@system Greeter(name: str) {
    interface:
        greet(): str

    machine:
        $Idle {
            greet(): str {
                @@:("hello, " + this.name)
                return;
            }
        }

    domain:
        name: String = name
}

class Main {
    public static void main(String[] args) {
        var g = @@Greeter("world");
        String s = g.greet();
        if (!s.equals("hello, world")) {
            System.out.println("FAIL: Expected 'hello, world', got '" + s + "'");
            System.exit(1);
        }
        System.out.println("ok 1 - sysparam_domain_str");
    }
}

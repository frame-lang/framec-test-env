@@target javascript

@@system Service($(slot: int), $>(timeout: int), name: str) {
    interface:
        get_slot(): int
        get_timeout(): int
        get_name(): str

    machine:
        $Start(slot: int) {
            $>(timeout: int) {
                this.__compartment.state_vars["t"] = timeout;
            }

            $.t: int = 0

            get_slot(): int {
                @@:(slot)
                return;
            }
            get_timeout(): int {
                const v = this.__compartment.state_vars["t"];
                @@:(v)
                return;
            }
            get_name(): str {
                @@:(this.name)
                return;
            }
        }

    domain:
        name = name
}

const s = @@Service($(3), $>(100), "svc1");
const slot = s.get_slot();
if (slot !== 3) {
    console.log("FAIL slot got " + slot);
    process.exit(1);
}
const t = s.get_timeout();
if (t !== 100) {
    console.log("FAIL timeout got " + t);
    process.exit(1);
}
const n = s.get_name();
if (n !== "svc1") {
    console.log("FAIL name got " + n);
    process.exit(1);
}
console.log("ok 1 - sysparam_enter_mixed");

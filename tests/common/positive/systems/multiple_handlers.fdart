@@[target("dart")]
@@system S {
    machine:
        $A => $P {
            e1() { => $^; }
            e2() { => $^; }
        }
        $P { }
}

// Stub functions for placeholder calls
void native() {}
void x() {}

// TAP test harness
void main() {
    print("TAP version 14");
    print("1..1");
    try {
        final s = @@S();
        s.e1();
        s.e2();
        print("ok 1 - multiple_handlers");
    } catch (ex) {
        print("not ok 1 - multiple_handlers # ${ex}");
    }
}

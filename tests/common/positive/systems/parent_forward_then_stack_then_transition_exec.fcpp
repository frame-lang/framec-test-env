@@[target("cpp_17")]
@@run-expect: FORWARD:PARENT
@@run-expect: STACK:PUSH
@@run-expect: TRANSITION:

#include <iostream>
#include <string>
#include <cassert>

@@system S {
    machine:
        $A => $P {
            e() {
                => $^
                push$
                -> $B()
            }
        }
        $B { }
        $P { }
}

// TAP test harness
int main() {
    printf("TAP version 14\n");
    printf("1..1\n");
    try {
        S s;
        s.e();
        printf("ok 1 - parent_forward_then_stack_then_transition_exec\n");
    } catch (...) {
        printf("not ok 1 - parent_forward_then_stack_then_transition_exec\n");
    }
    return 0;
}

@@target c
@@run-expect: FORWARD:PARENT
@@run-expect: STACK:PUSH
@@run-expect: TRANSITION:

#include <stdio.h>
#include <stdlib.h>
#include <stdint.h>

@@system S {
    machine:
        $A => $P {
            e() {
                => $^
                push$
                -> $B()
            }
        }
        $B { }
        $P { }
}

int main() {
    S* s = S_new();
    S_e(s);
    S_destroy(s);
    printf("PASS\n");
    return 0;
}

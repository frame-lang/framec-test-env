@@target gdscript
@@run-expect: FORWARD:PARENT
@@run-expect: STACK:PUSH
@@run-expect: TRANSITION:

@@system S {
    machine:
        $P { }
        $A => $P {
            e() {
                i = 0
                while i < 2:
                    if i == 0:
                        push$
                        => $^
                    i = i + 1
                -> $B()
            }
        }
        $B { }
}

# Stub functions for placeholder calls

# TAP test harness
func _ready():
    print("TAP version 14")
    print("1..1")
    s = @@S()
    if s.has_method("e"):
        s.e()
    print("ok 1 - while_inline_forward_stack_then_transition_exec")
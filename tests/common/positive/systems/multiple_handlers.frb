@@[target("ruby")]

@@system S {
    machine:
        $A => $P {
            e1() { => $^ }
            e2() { => $^ }
        }
        $P { }
}

puts("TAP version 14")
puts("1..1")
begin
    s = S.new
    if s.respond_to?(:e)
        s.e()
    end
    puts("ok 1 - multiple_handlers")
rescue => ex
    puts("not ok 1 - multiple_handlers # #{ex}")
end

@@[target("python")]
@@run-expect: FORWARD:PARENT
@@run-expect: TRANSITION:

@@system S {
    machine:
        $A => $P {
            e() {
                # nested structure with inline separators
                if True:
                    => $^; x = 1
                    if x == 1:
                        -> $B()
            }
        }
        $B { }
        $P { }
}

# Stub functions for placeholder calls
def native(): pass
def x(): pass

# TAP test harness
if __name__ == "__main__":
    print("TAP version 14")
    print("1..1")
    try:
        s = @@S()
        if hasattr(s, 'e'):
            s.e()
        print("ok 1 - nested_parent_forward_then_transition_exec")
    except Exception as ex:
        print(f"not ok 1 - nested_parent_forward_then_transition_exec # {ex}")

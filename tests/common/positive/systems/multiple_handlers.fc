@@target c

#include <stdio.h>
#include <stdlib.h>
#include <stdint.h>

@@system S {
    machine:
        $A => $P {
            e1() {
                => $^
            }
            e2() {
                => $^
            }
        }
        $P { }
}

int main() {
    S* s = @@S();
    S_e1(s);
    S_e2(s);
    S_destroy(s);
    printf("PASS\n");
    return 0;
}

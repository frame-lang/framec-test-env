@@target erlang
@@run-expect: FORWARD:PARENT
@@run-expect: STACK:PUSH
@@run-expect: TRANSITION:
%%
%% State-flow idiom port for Erlang. The Python/JS/etc. variants run
%% `while i < 2` with the first iteration firing `push$` + `=> $^`
%% (i==0 branch) and the second iteration a no-op (i==1 branch),
%% then transition to $B. Net observable contract: one stack push,
%% one parent forward, one transition. Erlang has no `while`
%% keyword, so we express the contract directly.
%%
%% Observable Frame events are unchanged:
%%   FORWARD:PARENT, STACK:PUSH, TRANSITION:.

@@system S {
    machine:
        $P { }
        $A => $P {
            e() {
                push$
                => $^
                -> $B
            }
        }
        $B { }
}

@@[target("cpp_17")]

#include <iostream>
#include <cassert>

@@system S {
    machine:
        $A => $P {
            e1() { => $^; }
            e2() { => $^; }
        }
        $P { }
}

// TAP test harness
int main() {
    printf("TAP version 14\n");
    printf("1..1\n");
    try {
        auto s = @@S();
        s.e1();
        printf("ok 1 - multiple_handlers\n");
    } catch (...) {
        printf("not ok 1 - multiple_handlers\n");
    }
    return 0;
}

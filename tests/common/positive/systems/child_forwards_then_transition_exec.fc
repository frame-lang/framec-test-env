@@target c
@@run-expect: FORWARD:PARENT
@@run-expect: FORWARD:PARENT
@@run-expect: TRANSITION:

#include <stdio.h>
#include <stdlib.h>
#include <stdint.h>

@@system S {
    machine:
        $A => $P {
            e() {
                if (1) {
                    => $^
                    => $^
                }
                -> $B()
            }
        }
        $B { }
        $P { }
}

int main() {
    printf("TAP version 14\n");
    printf("1..1\n");
    S* s = @@S();
    S_e(s);
    S_destroy(s);
    printf("ok 1 - child_forwards_then_transition_exec\n");
    return 0;
}

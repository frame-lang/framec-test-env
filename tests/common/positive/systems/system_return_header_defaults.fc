@@[target("c")]

// Test: @@:return header defaults and handler returns (C).
// Tests interface method default return values.

#include <stdio.h>
#include <stdlib.h>
#include <stdint.h>

@@system SystemReturnHeaderDefaultsC {
    interface:
        get_constant(): int = 42
        get_param(n: int): int = n
        double_or_default(x: int): int = x

    machine:
        $Start {
            get_constant() {
                // Return default (42)
                return;
            }

            get_param(n: int) {
                // Return default (parameter n)
                return;
            }

            double_or_default(x: int) {
                // Override with explicit return
                @@:(x * 2)
                return;
            }
        }
}

int main() {
    printf("=== Test: system_return_header_defaults ===\n");
    int pass = 1;

    SystemReturnHeaderDefaultsC* s = @@SystemReturnHeaderDefaultsC();

    // Test constant default
    int r1 = SystemReturnHeaderDefaultsC_get_constant(s);
    if (r1 != 42) {
        printf("FAIL: get_constant() expected 42, got %d\n", r1);
        pass = 0;
    } else {
        printf("1. get_constant() = %d\n", r1);
    }

    // Test parameter default
    int r2 = SystemReturnHeaderDefaultsC_get_param(s, 99);
    if (r2 != 99) {
        printf("FAIL: get_param(99) expected 99, got %d\n", r2);
        pass = 0;
    } else {
        printf("2. get_param(99) = %d\n", r2);
    }

    // Test explicit override
    int r3 = SystemReturnHeaderDefaultsC_double_or_default(s, 10);
    if (r3 != 20) {
        printf("FAIL: double_or_default(10) expected 20, got %d\n", r3);
        pass = 0;
    } else {
        printf("3. double_or_default(10) = %d (explicit return, not default)\n", r3);
    }

    SystemReturnHeaderDefaultsC_destroy(s);

    if (pass) {
        printf("PASS: system_return_header_defaults\n");
    }
    return pass ? 0 : 1;
}

@@target kotlin

import kotlin.system.exitProcess

@@system S {
    machine:
        $A => $P {
            e() {
                // nested structure with inline separators
                if (true) {
                    => $^; val x = 1
                    if (x == 1) {
                        -> $B()
                    }
                }
            }
        }
        $B { }
        $P { }
}

fun main() {
    println("TAP version 14")
    println("1..1")
    try {
        val s = S()
        s.e()
        println("ok 1 - nested_parent_forward_then_transition_exec")
    } catch (ex: Exception) {
        println("not ok 1 - nested_parent_forward_then_transition_exec # $ex")
    }
}

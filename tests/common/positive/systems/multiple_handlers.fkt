@@target kotlin

import kotlin.system.exitProcess

@@system S {
    machine:
        $A => $P {
            e1() { => $^ }
            e2() { => $^ }
        }
        $P { }
}

fun main() {
    println("TAP version 14")
    println("1..1")
    try {
        val s = S()
        println("ok 1 - multiple_handlers")
    } catch (ex: Exception) {
        println("not ok 1 - multiple_handlers # $ex")
    }
}

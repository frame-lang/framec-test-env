@@target csharp

using System;
using System.Collections.Generic;

@@system S {
    machine:
        $A => $P {
            e1() { => $^; }
            e2() { => $^; }
        }
        $P { }
}

class Program {
    static void Main(string[] args) {
        Console.WriteLine("TAP version 14");
        Console.WriteLine("1..1");
        try {
            S s = new S();
            Console.WriteLine("ok 1 - multiple_handlers");
        } catch (Exception ex) {
            Console.WriteLine("not ok 1 - multiple_handlers # " + ex);
        }
    }
}

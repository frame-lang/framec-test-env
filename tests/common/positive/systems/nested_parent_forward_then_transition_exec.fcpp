@@target cpp_17
@@run-expect: FORWARD:PARENT
@@run-expect: TRANSITION:

#include <iostream>
#include <string>
#include <cassert>

// Forward declarations for variables used in handlers
int x = 0;

@@system S {
    machine:
        $A => $P {
            e() {
                // nested structure with inline separators
                if (true) {
                    => $^; int x = 1;
                    if (x == 1) {
                        -> $B()
                    }
                }
            }
        }
        $B { }
        $P { }
}

// TAP test harness
int main() {
    printf("TAP version 14\n");
    printf("1..1\n");
    try {
        S s;
        s.e();
        printf("ok 1 - nested_parent_forward_then_transition_exec\n");
    } catch (...) {
        printf("not ok 1 - nested_parent_forward_then_transition_exec\n");
    }
    return 0;
}

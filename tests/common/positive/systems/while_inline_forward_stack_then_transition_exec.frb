@@target ruby
@@run-expect: FORWARD:PARENT
@@run-expect: STACK:PUSH
@@run-expect: TRANSITION:

@@system S {
    machine:
        $P { }
        $A => $P {
            e() {
                i = 0
                while i < 2
                    if i == 0
                        push$
                        => $^
                    end
                    i = i + 1
                end
                -> $B()
            }
        }
        $B { }
}

puts("TAP version 14")
puts("1..1")
begin
    s = S.new
    if s.respond_to?(:e)
        s.e()
    end
    puts("ok 1 - while_inline_forward_stack_then_transition_exec")
rescue => ex
    puts("not ok 1 - while_inline_forward_stack_then_transition_exec # #{ex}")
end

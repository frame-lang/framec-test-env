@@[target("javascript")]
@@run-expect: FORWARD:PARENT
@@run-expect: STACK:PUSH
@@run-expect: TRANSITION:

@@system S {
    machine:
        $P { }
        $A => $P {
            e() {
                let i = 0
                while (i < 2) {
                    if (i == 0) {
                        push$
                        => $^
                    }
                    i = i + 1
                }
                -> $B()
            }
        }
        $B { }
}

// Stub functions for placeholder calls
function native() {}
function x() {}

// TAP test harness
function main() {
    console.log("TAP version 14");
    console.log("1..1");
    try {
        const s = @@S();
        if (typeof s.e === 'function') {
            s.e();
        }
        console.log("ok 1 - while_inline_forward_stack_then_transition_exec");
    } catch (ex) {
        console.log(`not ok 1 - while_inline_forward_stack_then_transition_exec # ${ex}`);
    }
}
main();

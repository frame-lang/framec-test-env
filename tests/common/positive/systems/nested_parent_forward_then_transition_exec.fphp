@@[target("php")]
@@run-expect: FORWARD:PARENT
@@run-expect: TRANSITION:

@@system S {
    machine:
        $A => $P {
            e() {
                if (true) {
                    => $^; $x = 1;
                    if ($x == 1) {
                        -> $B()
                    }
                }
            }
        }
        $B { }
        $P { }
}

function native() {}
function x() {}

echo "TAP version 14" . "\n";
echo "1..1" . "\n";
try {
    $s = @@S();
    if (method_exists($s, 'e')) { $s->e(); }
    echo "ok 1 - nested_parent_forward_then_transition_exec" . "\n";
} catch (\Exception $ex) {
    echo "not ok 1 - nested_parent_forward_then_transition_exec # " . $ex->getMessage() . "\n";
}

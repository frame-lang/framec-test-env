@@target c
@@run-expect: FORWARD:PARENT
@@run-expect: STACK:PUSH
@@run-expect: TRANSITION:

#include <stdio.h>
#include <stdlib.h>
#include <stdint.h>

@@system S {
    machine:
        $P { }
        $A => $P {
            e() {
                int i = 0;
                while (i < 2) {
                    if (i == 0) {
                        push$
                        => $^
                    }
                    i = i + 1;
                }
                -> $B()
            }
        }
        $B { }
}

int main() {
    printf("TAP version 14\n");
    printf("1..1\n");
    S* s = @@S();
    S_e(s);
    S_destroy(s);
    printf("ok 1 - while_inline_forward_stack_then_transition_exec\n");
    return 0;
}

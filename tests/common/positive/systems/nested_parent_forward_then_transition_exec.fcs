@@target csharp

using System;
using System.Collections.Generic;

@@system S {
    machine:
        $A => $P {
            e() {
                // nested structure with inline separators
                if (true) {
                    => $^; int x = 1;
                    if (x == 1) {
                        -> $B()
                    }
                }
            }
        }
        $B { }
        $P { }
}

class Program {
    static void Main(string[] args) {
        Console.WriteLine("TAP version 14");
        Console.WriteLine("1..1");
        try {
            S s = new S();
            s.e();
            Console.WriteLine("ok 1 - nested_parent_forward_then_transition_exec");
        } catch (Exception ex) {
            Console.WriteLine("not ok 1 - nested_parent_forward_then_transition_exec # " + ex);
        }
    }
}

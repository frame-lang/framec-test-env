@@target swift
@@run-expect: FORWARD:PARENT
@@run-expect: STACK:PUSH
@@run-expect: TRANSITION:

@@system S {
    machine:
        $P { }
        $A => $P {
            e() {
                var i = 0
                while (i < 2) {
                    if (i == 0) {
                        push$
                        => $^
                    }
                    i = i + 1
                }
                -> $B()
            }
        }
        $B { }
}

// TAP test harness

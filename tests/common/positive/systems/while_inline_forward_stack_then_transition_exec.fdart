@@target dart
@@run-expect: FORWARD:PARENT
@@run-expect: STACK:PUSH
@@run-expect: TRANSITION:

@@system S {
    machine:
        $P { }
        $A => $P {
            e() {
                var i = 0
                while (i < 2) {
                    if (i == 0) {
                        push$
                        => $^
                    }
                    i = i + 1
                }
                -> $B()
            }
        }
        $B { }
}

// Stub functions for placeholder calls
void native(): void {}
void x(): void {}

// TAP test harness
void main() {
    print("TAP version 14");
    print("1..1");
    try {
        final s = @@S();
        if (typeof (s as any).e == 'function') {
            (s as any).e();
        }
        print("ok 1 - while_inline_forward_stack_then_transition_exec");
    } catch (ex) {
        print("not ok 1 - while_inline_forward_stack_then_transition_exec # ${ex}");
    }
}

@@target gdscript
extends SceneTree

@@system S {
    machine:
        $A => $P {
            e1() {
                => $^
            }
            e2() {
                => $^
            }
        }
        $P { }
}

# Stub functions for placeholder calls

# TAP test harness
func _init():
    print("TAP version 14")
    print("1..1")
    var s = @@S()
    if s.has_method("e"):
        s.e()
    print("ok 1 - multiple_handlers")
    quit()

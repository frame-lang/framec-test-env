@@[target("gdscript")]
extends SceneTree
@@run-expect: FORWARD:PARENT
@@run-expect: STACK:PUSH
@@run-expect: TRANSITION:

@@system S {
    machine:
        $A => $P {
            e() {
                => $^
                push$
                -> $B()
            }
        }
        $B { }
        $P { }
}

# Stub functions for placeholder calls
func native(): pass
func x(): pass

# TAP test harness
func _init():
    print("TAP version 14")
    print("1..1")
    var s = @@S()
    if s.has_method("e"):
        s.e()
    print("ok 1 - parent_forward_then_stack_then_transition_exec")
    quit()

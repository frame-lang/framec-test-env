@@target ruby
@@run-expect: FORWARD:PARENT
@@run-expect: TRANSITION:

@@system S {
    machine:
        $A => $P {
            e() {
                if true
                    => $^
                    x = 1
                    if x == 1
                        -> $B()
                    end
                end
            }
        }
        $B { }
        $P { }
}

puts("TAP version 14")
puts("1..1")
begin
    s = S.new
    if s.respond_to?(:e)
        s.e()
    end
    puts("ok 1 - nested_parent_forward_then_transition_exec")
rescue => ex
    puts("not ok 1 - nested_parent_forward_then_transition_exec # #{ex}")
end

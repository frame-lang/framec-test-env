@@target c

#include <stdio.h>
#include <stdlib.h>

@@system S {
    machine:
        $A {
            e() {
                push$
                -> $B()
            }
        }
        $B { e() { } }
}

int main() {
    printf("TAP version 14\n");
    printf("1..1\n");

    S* s = S_new();
    if (s != NULL) {
        S_e(s);
        printf("ok 1 - mixed_ops\n");
    } else {
        printf("not ok 1 - mixed_ops # failed to create S\n");
    }

    if (s != NULL) {
        S_destroy(s);
    }

    return 0;
}

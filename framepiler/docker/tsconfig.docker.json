{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "lib": ["ES2020"],
    "declaration": false,
    "outDir": "./",
    "rootDir": "./",
    "strict": false,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "moduleResolution": "node",
    "allowJs": true,
    "baseUrl": "/opt",
    "paths": {
      "frame_runtime_ts": ["/opt/frame_runtime_ts/index"]
    }
  },
  "include": ["**/*.ts"],
  "exclude": ["node_modules"]
}
# Docker image for Rust Frame test execution
FROM rust:1.75-slim

# Install required packages
RUN apt-get update && apt-get install -y \
    build-essential \
    git \
    && rm -rf /var/lib/apt/lists/*

# Create working directories
RUN mkdir -p /fixtures /work /output

# Set working directory
WORKDIR /work

# Default command
CMD ["rustc", "--version"]
# Build framec for Linux
FROM rust:1.75-slim as builder

RUN apt-get update && apt-get install -y git && rm -rf /var/lib/apt/lists/*

WORKDIR /build

# Copy transpiler source
COPY frame_transpiler /build/frame_transpiler

# Build framec
WORKDIR /build/frame_transpiler
RUN cargo build --release -p framec

# Output the binary
FROM scratch
COPY --from=builder /build/frame_transpiler/target/release/framec /framec
